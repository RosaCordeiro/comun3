 retrieve="select 	1 as nr_base,
			'homologa' as cd_base,
			 'HOMOLOGA$$HEX2$$c700c300$$ENDHEX$$O' as de_base,
			 1 as id_tipo 
 from parametro

union

select 2 as nr_base,
		'central' as cd_base,
		 'PRODU$$HEX2$$c700c300$$ENDHEX$$O' as de_base,
		 1 as id_tipo 
 from parametro

union

select 3 as nr_base, 
		'homologa2025' as cd_base,
		 'HOMOLOGA$$HEX2$$c700c300$$ENDHEX$$O: UPGRADE SAP 2025' as de_base,
		 1 as id_tipo 
 from parametro" )
