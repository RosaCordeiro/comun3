table(column=(type=long updatewhereclause=yes name=nr_seq dbname="consulta_generica.nr_seq" )
 column=(type=char(30) updatewhereclause=yes name=nm_campo dbname="consulta_generica.nm_campo" )
 column=(type=char(32768) updatewhereclause=yes name=de_sqlcampo dbname="consulta_generica.de_sqlcampo" )
 column=(type=char(1) updatewhereclause=yes name=id_visivel dbname="consulta_generica.id_visivel" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_agregacao dbname="consulta_generica.id_agregacao" )
 column=(type=char(1) updatewhereclause=yes name=id_sumariza dbname="consulta_generica.id_sumariza" )
 column=(type=long updatewhereclause=yes name=nr_seq_original dbname="consulta_generica.nr_seq_original" )
 retrieve="SELECT 	nr_seq,   
			nm_campo,   
         	de_sqlcampo,   
         	id_visivel,
			id_agregacao,
			id_sumariza,
			nr_seq as nr_seq_original 
FROM consulta_generica
WHERE cd_consulta = :consulta
" arguments=(("consulta", number))  sort="nr_seq A " )
