event clicked;If Not gvo_Aplicacao.ivb_Usa_Biometria Then Return

String ls_Operador

uo_GE040_Leitor_Biometrico lvo_Biometria
lvo_Biometria = Create uo_GE040_Leitor_Biometrico

If Not lvo_Biometria.of_Inicializa() Then
	MessageBox( "Aten$$HEX2$$e700e300$$ENDHEX$$o", "N$$HEX1$$e300$$ENDHEX$$o foi identificado nenhum leitor biom$$HEX1$$e900$$ENDHEX$$trico instalado.", StopSign! )
	Destroy lvo_Biometria
	Return
End If

MessageBox( "Aten$$HEX2$$e700e300$$ENDHEX$$o", "A identifica$$HEX2$$e700e300$$ENDHEX$$o a seguir $$HEX1$$e900$$ENDHEX$$ do usu$$HEX1$$e100$$ENDHEX$$rio que est$$HEX1$$e100$$ENDHEX$$ cadastrando a impress$$HEX1$$e300$$ENDHEX$$o digital" )

If gvo_Aplicacao.ivo_Seguranca.of_Libera_Acesso_Usuario( ref ls_Operador) Then 

	Select coalesce( nr_cpf, '0' )
		Into :gvo_Aplicacao.ivo_Seguranca.Nr_Cpf
	 From usuario
	Where nr_matricula = :ls_Operador
	  Using SqlCa;
	  
	Choose Case SqlCa.SqlCode
		Case -1
			SqlCa.of_MsgDbError()					
	End Choose
	
	If gvo_Aplicacao.ivo_Seguranca.Nr_Cpf = '0' Then
		MessageBox( "Aten$$HEX2$$e700e300$$ENDHEX$$o", "N$$HEX1$$e300$$ENDHEX$$o foi encontrado CPF para este usu$$HEX1$$e100$$ENDHEX$$rio." )
		Return
	End If
	
	If lvo_Biometria.of_Cadastra( gvo_Aplicacao.ivo_Seguranca.Nr_Cpf ) Then
		Messagebox( "Aten$$HEX2$$e700e300$$ENDHEX$$o", "Digital cadastrada com sucesso." )
	End If
End If

Destroy lvo_Biometria
end event

type m_trocadeusurio from menu within m_arquivo
end type

event clicked;SetPointer(HourGlass!)

// Abre a janela de Logon

If IsValid(ParentWindow.GetFirstSheet()) Then
	MessageBox("Aten$$HEX2$$e700e300$$ENDHEX$$o!", "Para trocar de usu$$HEX1$$e100$$ENDHEX$$rio, todas as janelas dever$$HEX1$$e300$$ENDHEX$$o estar fechadas.", Information!, Ok!)
	Return
End If

// Dispara a fun$$HEX2$$e700e300$$ENDHEX$$o PFC de login
gvo_Aplicacao.ivo_seguranca.of_Login_Sistema()
end event

