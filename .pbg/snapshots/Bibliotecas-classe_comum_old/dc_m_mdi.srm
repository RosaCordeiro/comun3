public subroutine mf_habilita_biometria ();This.m_Arquivo.m_CadastrarImpressaoDigital.Visible = gvo_Aplicacao.ivb_Usa_Biometria
end subroutine

public subroutine mf_abre_janela (string ps_janela, boolean pb_seguranca, boolean pb_controle_usuario);Try
	SetPointer(HourGlass!)

	//Fernando Cambiaghi - 26/07/2016
	//Se a situa$$HEX2$$e700e300$$ENDHEX$$o do usu$$HEX1$$e100$$ENDHEX$$rio passar para I = Inativo ap$$HEX1$$f300$$ENDHEX$$s ele ter logado no sistema, n$$HEX1$$e300$$ENDHEX$$o permite abrir as telas.
	//Se o usu$$HEX1$$e100$$ENDHEX$$rio conseguir n$$HEX1$$e300$$ENDHEX$$o estiver com situa$$HEX2$$e700e300$$ENDHEX$$o I, registra o $$HEX1$$fa00$$ENDHEX$$ltimo acesso.
	If gvo_Aplicacao.ivo_Seguranca.ivb_LogIn Then
		gvo_Aplicacao.ivo_Seguranca.of_Localiza_Usuario( gvo_Aplicacao.ivo_Seguranca.Nr_Matricula )
		If Not gvo_Aplicacao.ivo_Seguranca.ivb_Usuario_Localizado Then Return
	End If
	
	dc_uo_Menu_Base lvm_Menu

	lvm_Menu = Create dc_uo_Menu_Base
	
	If pb_Seguranca Then
		If gvo_Aplicacao.ivo_Seguranca.cd_Sistema = 'RL' Then
			gvo_Aplicacao.ivo_Seguranca.of_Permite_Incluir_Alterar_Excluir( pb_controle_usuario, ps_Janela )
			
			Message.StringParm = ps_janela
			lvm_Menu.of_SendMessage(This, "ue_Open")
		Else		
			If gvo_Aplicacao.ivo_Seguranca.of_Acesso_Procedimento(ps_Janela, pb_controle_usuario) Then
				Message.StringParm = ps_janela
				lvm_Menu.of_SendMessage(This, "ue_Open")
			Else
				MessageBox("Seguran$$HEX1$$e700$$ENDHEX$$a do Sistema", "Procedimento n$$HEX1$$e300$$ENDHEX$$o liberado para este usu$$HEX1$$e100$$ENDHEX$$rio.", StopSign!)
			End If
		End If
	Else
		gvo_Aplicacao.ivo_Seguranca.of_Set_Id_Inclusao( True )
		gvo_Aplicacao.ivo_Seguranca.of_Set_Id_Alteracao( True )
		gvo_Aplicacao.ivo_Seguranca.of_Set_Id_Exclusao( True )
		
		Message.StringParm = ps_janela
		lvm_Menu.of_SendMessage(This, "ue_Open")
	End If

Catch ( runtimeerror  lo_rte )
	MessageBox (	"Erro", "Ocorreu erro ao abrir a janela. ~r~r"+ & 						
 						"Erro: "+lo_rte.GetMessage( ), StopSign!)
	
Finally	
	Destroy(lvm_Menu)
	SetPointer(Arrow!)
End Try
end subroutine

public subroutine mf_abre_janela (string as_janela, boolean pb_seguranca);mf_Abre_Janela(as_Janela, pb_seguranca, False)
end subroutine

public subroutine mf_copiar (boolean pb_habilita);This.m_Editar.m_c.Enabled = pb_Habilita
end subroutine

public subroutine mf_colar (boolean pb_habilita);This.m_Editar.m_colar.Enabled = pb_Habilita
end subroutine

public subroutine mf_recortar (boolean pb_habilita);This.m_Editar.m_cortar.Enabled = pb_Habilita
end subroutine

on dc_m_mdi.create
dc_m_mdi=this
call super::create
this.menutextcolor = 134217735
this.menubackcolor = 134217732
this.menuhighlightcolor = 134217741
this.textsize = -8
this.weight = 400
this.facename = "Tahoma"
this.titlebackcolor = 134217730
this.bitmapbackcolor = 12632256
this.menubitmaps = true
this.titlegradient = true
this.toolbartextcolor = 134217746
this.toolbarbackcolor = 67108864
this.toolbarhighlightcolor = 134217741
this.toolbargradient = true
this.bitmapgradient = true
this.m_arquivo=create m_arquivo
this.m_editar=create m_editar
this.m_janela=create m_janela
this.m_ajuda=create m_ajuda
this.Item[UpperBound(this.Item)+1]=this.m_arquivo
this.Item[UpperBound(this.Item)+1]=this.m_editar
this.Item[UpperBound(this.Item)+1]=this.m_janela
this.Item[UpperBound(this.Item)+1]=this.m_ajuda
end on

on dc_m_mdi.destroy
call super::destroy
destroy(this.m_arquivo)
destroy(this.m_editar)
destroy(this.m_janela)
destroy(this.m_ajuda)
end on

