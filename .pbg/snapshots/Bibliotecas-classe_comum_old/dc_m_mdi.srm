public subroutine mf_executa_evento (string ps_evento);SetPointer(HourGlass!)

dc_uo_Menu_Base lvm_Menu

lvm_Menu = Create dc_uo_Menu_Base
lvm_Menu.of_SendMessage(This, ps_Evento)

gvo_Aplicacao.of_SetMicroHelp()

SetPointer(Arrow!)
end subroutine

public subroutine mf_incluir (boolean pb_habilita);If pb_Habilita and Not This.ivb_Permite_Incluir Then
	pb_Habilita = False
End If

This.m_Editar.m_Incluir.Enabled = pb_Habilita
end subroutine

public subroutine mf_excluir (boolean pb_habilita);If pb_Habilita and Not This.ivb_Permite_Excluir Then
	pb_Habilita = False
End If

This.m_Editar.m_Excluir.Enabled = pb_Habilita
end subroutine

public subroutine mf_alterar (boolean pb_habilita);If pb_Habilita and Not This.ivb_Permite_Alterar Then
	pb_Habilita = False
End If

This.m_Editar.m_Alterar.Enabled = pb_Habilita
end subroutine

public subroutine mf_classificar (boolean pb_habilita);If pb_Habilita and Not This.ivb_Permite_Classificar Then
	pb_Habilita = False
End If

This.m_Editar.m_Classificar.Enabled = pb_Habilita
end subroutine

public subroutine mf_filtrar (boolean pb_habilita);If pb_Habilita and Not This.ivb_Permite_Filtrar Then
