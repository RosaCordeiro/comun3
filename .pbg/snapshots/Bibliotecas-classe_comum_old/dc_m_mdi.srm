public subroutine mf_localizar (boolean pb_habilita);If pb_Habilita and Not This.ivb_Permite_Localizar Then
	pb_Habilita = False
End If

This.m_Editar.m_Localizar.Enabled = pb_Habilita
end subroutine

public subroutine mf_imprimir (boolean pb_habilita);If pb_Habilita and Not This.ivb_Permite_Imprimir Then
	pb_Habilita = False
End If

This.m_Arquivo.m_Imprimir.Enabled         = pb_Habilita
This.m_Arquivo.m_ImprimirImediato.Enabled = pb_Habilita
end subroutine

public subroutine mf_recuperar (boolean pb_habilita);If pb_Habilita and Not This.ivb_Permite_Recuperar Then
	pb_Habilita = False
End If

This.m_Editar.m_Recuperar.Enabled = pb_Habilita
end subroutine

public subroutine mf_confirmar (boolean pb_habilita);This.m_Editar.m_ConfirmarOperacao.Enabled = pb_Habilita

If pb_Habilita Then
	mf_Executa_Evento("ue_startchanging")
Else
	mf_Executa_Evento("ue_endchanging")
End If
end subroutine

public subroutine mf_cancelar (boolean pb_habilita);This.m_Editar.m_CancelarOperacao.Enabled = pb_Habilita
end subroutine

public subroutine mf_abre_janela (string as_janela);mf_Abre_Janela(as_Janela, True, False)
end subroutine

