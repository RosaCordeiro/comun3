table(column=(type=char(3) update=yes updatewhereclause=yes name=cd_ambiente_sap dbname="cd_ambiente_sap" )
 column=(type=char(46) update=yes updatewhereclause=yes name=de_ambiente_sap dbname="de_ambiente_sap" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=long updatewhereclause=yes name=ordem dbname="ordem" )
 column=(type=char(1) updatewhereclause=yes name=id_car dbname="id_car" )
 column=(type=char(1) updatewhereclause=yes name=id_tdf dbname="id_tdf" )
 column=(type=char(1) updatewhereclause=yes name=id_guepardo dbname="id_guepardo" )
 retrieve="SELECT 	a.cd_ambiente_sap,   
			a.de_ambiente_sap  || ' (' || a.cd_ambiente_sap || ')' as de_ambiente_sap, 
			a.id_situacao,
			3 ordem, 
			car.id_ativo as id_car, 
			tdf.id_ativo as id_tdf, 
			gue.id_ativo as id_guepardo
FROM ambiente_sap a 
LEFT OUTER JOIN  (	select p1.cd_ambiente_sap, 'S' as id_ativo  
							from parametro_sap p1 
							where p1.cd_parametro = 'CD_URL_CAR_ENVIO' ) car
	ON car.cd_ambiente_sap = a.cd_ambiente_sap
LEFT OUTER JOIN  (	select p1.cd_ambiente_sap , 'S' as id_ativo
							from parametro_sap p1 
							where p1.cd_parametro = 'CD_URL_TDF_ENVIO' ) tdf
	ON tdf.cd_ambiente_sap = a.cd_ambiente_sap
LEFT OUTER JOIN  (	select p1.cd_ambiente_sap , 'S' as id_ativo
							from parametro_sap p1 
							where p1.cd_parametro = 'CD_URL_GUEPARDO_ENVIO' ) gue
	ON gue.cd_ambiente_sap = a.cd_ambiente_sap
WHERE (car.id_ativo = 'S' or tdf.id_ativo = 'S' or gue.id_ativo = 'S')

UNION

SELECT	'XXX' as cd_ambiente_sap, 
			'XXX - GERA$$HEX2$$c700c300$$ENDHEX$$O XML' as de_ambiente_sap, 
			'A' as id_situacao,
			2 ordem, 
			'S' as id_car,
			'S' as id_tdf,
			'S' as id_guepardo
from parametro 
where id_parametro = '1'

UNION

SELECT	'' as cd_ambiente_sap, 
			'TODOS' as de_ambiente_sap, 
			'A' as id_situacao,
			1 ordem, 
			'S' as id_car,
			'S' as id_tdf,
			'S' as id_guepardo
from parametro 
where id_parametro = '1'

"  sort="ordem A de_ambiente_sap A " )
