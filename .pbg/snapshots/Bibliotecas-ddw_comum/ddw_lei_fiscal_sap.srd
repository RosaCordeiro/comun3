 column=(type=char(1) update=yes updatewhereclause=yes name=cd_tributacao_icms dbname="lei_fiscal_sap.cd_tributacao_icms" dbalias="lf.cd_tributacao_icms" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_tributacao dbname="tributacao_icms.cd_cst_tributacao" dbalias="tic.cd_cst_tributacao" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf dbname="lei_fiscal_sap.cd_uf" dbalias="lf.cd_uf" )
 retrieve="  SELECT 	lf.cd_lei_fiscal_sap,   
				lf.id_entrada_saida,   
				lf.de_lei_fiscal_sap,   
				lf.cd_lei_fiscal_sap||' - '||lf.de_lei_fiscal_sap as lei_fiscal,
				lf.cd_tributacao_icms,
				tic.cd_cst_tributacao,
				lf.cd_uf
    FROM lei_fiscal_sap lf
LEFT OUTER JOIN tributacao_icms tic
	on tic.cd_tributacao_icms = lf.cd_tributacao_icms
"  sort="lei_fiscal A " )
