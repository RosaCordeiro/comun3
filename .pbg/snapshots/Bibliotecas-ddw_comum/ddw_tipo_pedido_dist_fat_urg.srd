table(column=(type=char(1) update=yes updatewhereclause=yes name=id_tipo dbname="tipo_pedido_distribuidora.id_tipo" dbalias="tpd.id_tipo" )
 column=(type=char(20) update=yes updatewhereclause=yes name=de_tipo dbname="tipo_pedido_distribuidora.de_tipo" dbalias="tpd.de_tipo" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_envia_sap dbname="tipo_pedido_distribuidora.id_envia_sap" dbalias="tpd.id_envia_sap" )
 column=(type=char(4) update=yes updatewhereclause=yes name=id_tipo_pedido_sap dbname="tipo_pedido_distribuidora.id_tipo_pedido_sap" dbalias="tpd.id_tipo_pedido_sap" )
 column=(type=char(1) updatewhereclause=yes name=id_devolucao dbname="tipo_pedido_distribuidora.id_devolucao" dbalias="tpd.id_devolucao" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_movimento dbname="wms_tipo_movimento_estoque.id_tipo_movimento" dbalias="tme.id_tipo_movimento" )
 retrieve="	 SELECT tpd.id_tipo,   
			  tpd.de_tipo,   
			  tpd.id_envia_sap,   
			  tpd.id_tipo_pedido_sap,
			  tpd.id_devolucao,
			  tme.id_tipo_movimento
		FROM tipo_pedido_distribuidora  tpd
INNER JOIN wms_tipo_movimento_estoque tme
		  ON tme.cd_tipo_movimento = tpd.cd_tipo_movto_saida
	  WHERE tpd.id_faturamento_urgente = 'S'
  ORDER BY tpd.de_tipo ASC   
" )
