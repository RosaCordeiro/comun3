table(column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_unidade_federacao dbname="unidade_federacao.nm_unidade_federacao" )
 retrieve="select distinct c.cd_unidade_federacao,
                u.nm_unidade_federacao
from filial f,
     cidade c,
     unidade_federacao u
where f.id_situacao = 'A'
  and c.cd_cidade = f.cd_cidade
  and u.cd_unidade_federacao = c.cd_unidade_federacao
order by  (Case When c.cd_unidade_federacao = 'SC' Then 0 
					   When c.cd_unidade_federacao = 'PR' Then 1
					   When	c.cd_unidade_federacao = 'RS' Then 2 
				Else 3 
				End),  u.nm_unidade_federacao" )
