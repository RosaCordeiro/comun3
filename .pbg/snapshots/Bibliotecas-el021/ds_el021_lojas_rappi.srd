table(column=(type=long updatewhereclause=yes name=store_id dbname="filial.store_id" dbalias="f.store_id" )
 column=(type=long updatewhereclause=yes name=id dbname="saldo_produto.id" dbalias="a.id" )
 column=(type=char(20) updatewhereclause=yes name=gtin dbname="codigo_barras_produto.gtin" dbalias="c.gtin" )
 column=(type=char(60) updatewhereclause=yes name=nome dbname="nome" )
 column=(type=char(100) updatewhereclause=yes name=description dbname="description" )
 column=(type=char(40) updatewhereclause=yes name=brand dbname="brand" )
 column=(type=char(40) updatewhereclause=yes name=trademark dbname="trademark" )
 column=(type=char(40) updatewhereclause=yes name=primeiro_nivel dbname="primeiro_nivel" )
 column=(type=char(40) updatewhereclause=yes name=segundo_nivel dbname="segundo_nivel" )
 column=(type=decimal(2) updatewhereclause=yes name=price dbname="price" )
 column=(type=decimal(2) updatewhereclause=yes name=discount dbname="discount" )
 column=(type=decimal(2) updatewhereclause=yes name=discount_price dbname="discount_price" )
 column=(type=char(10) updatewhereclause=yes name=discount_start_at dbname="discount_start_at" )
 column=(type=char(10) updatewhereclause=yes name=discount_end_at dbname="discount_end_at" )
 column=(type=long updatewhereclause=yes name=stock dbname="saldo_produto.stock" dbalias="a.stock" )
 column=(type=char(5) updatewhereclause=yes name=is_avaliable dbname="is_avaliable" )
 column=(type=char(5) updatewhereclause=yes name=is_discontined dbname="is_discontined" )
 column=(type=char(3) updatewhereclause=yes name=sale_type dbname="sale_type" )
 column=(type=char(1) updatewhereclause=yes name=imagem_url dbname="imagem_url" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="saldo_produto.cd_produto" dbalias="a.cd_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="b.vl_fator_conversao" )
 retrieve="select  f.cd_filial as store_id,  
		  a.cd_produto as id,      
         c.de_codigo_barras as gtin,   
	     Rtrim(Ltrim( de_produto )) as nome, 
	    case when b.de_descricao_internet  is null then Rtrim(Ltrim(de_produto)) else Rtrim(Ltrim(b.de_descricao_internet)) end as description,
       Rtrim(Ltrim( d1.de_marca ))   as brand,
		Rtrim(Ltrim(cp.de_grupo ))   as trademark,
       Rtrim(Ltrim(cp.de_subgrupo ))   as primeiro_nivel ,
       Rtrim(Ltrim(cp.de_subcategoria ))  as segundo_nivel , 
	   	000.00 as price, 
		000.00 as discount,
		000.00 as discount_price,
		'1900-00-00'  as discount_start_at,
		'1900-00-00'  as discount_end_at,
       a.qt_saldo_final as stock,
 		case when b.id_situacao =  'A' then 'true' else 'false' end as is_avaliable ,
       case when b.id_situacao <>  'A' then 'true' else 'false' end as is_discontined,
       Rtrim(Ltrim( b.cd_unidade_medida_venda))  as sale_type,
       '' as imagem_url, 
		a.cd_produto,
		b.vl_fator_conversao
from   saldo_produto a
inner  join produto_geral b 
    on a.cd_produto  = b.cd_produto 
inner  join produto_central as pc 
    on  pc.cd_produto = b.cd_produto
inner join codigo_barras_produto c 
    on c.cd_produto = a.cd_produto 
left   join vw_classificacao_produto As cp
    on cp.cd_subcategoria = b.cd_subcategoria
inner join marca_produto d1 
    on d1.cd_marca = b.cd_marca
inner join unidade_medida d2 
    on d2.cd_unidade_medida = b.cd_unidade_medida_venda   
inner join filial f 
    on f.cd_filial  = a.cd_filial
inner join produto_uf p 
    on p.cd_produto = b.cd_produto       
inner join cidade cid 
    on cid.cd_cidade = f.cd_cidade
    and cid.cd_unidade_federacao = p.cd_unidade_federacao
where  f.cd_filial =  :al_filial 
and    a.dh_saldo = :dh_saldo
and    c.id_principal = 'S' 
and    b.id_liberado_ecommerce = 'S'
and    cp.cd_grupo<>'9'
////and   a.qt_saldo_final >=5
//and   b.id_situacao  = 'A'
//and   a.cd_produto = 683785
// Coluna antes
// cast( (p.vl_preco_venda_atual / b.vl_fator_conversao) as decimal(10,2))  as price, 
" arguments=(("al_filial", number),("dh_saldo", date))  sort="store_id A cd_produto A " )
