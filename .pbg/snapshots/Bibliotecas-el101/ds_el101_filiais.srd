table(column=(type=long updatewhereclause=yes name=cd_filial dbname="vw_filial.cd_filial" dbalias="f1.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=vw_filial_nm_fantasia dbname="vw_filial.nm_fantasia" dbalias="f1.nm_fantasia" )
 column=(type=char(2) updatewhereclause=yes name=vw_filial_id_rede dbname="vw_filial.id_rede" dbalias="f1.id_rede" )
 column=(type=char(2) updatewhereclause=yes name=vw_filial_cd_uf dbname="vw_filial.cd_uf" dbalias="f1.cd_uf" )
 column=(type=long updatewhereclause=yes name=cidade_cd_cidade dbname="cidade.cd_cidade" dbalias="c.cd_cidade" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" dbalias="c.nm_cidade" )
 column=(type=char(40) updatewhereclause=yes name=vw_filial_nm_gerente_regional dbname="vw_filial.nm_gerente_regional" dbalias="f1.nm_gerente_regional" )
 column=(type=char(1) updatewhereclause=yes name=vw_filial_id_24horas dbname="vw_filial.id_24horas" dbalias="f1.id_24horas" )
 column=(type=char(1) updatewhereclause=yes name=vw_filial_id_abre_domingo dbname="vw_filial.id_abre_domingo" dbalias="f1.id_abre_domingo" )
 retrieve="  SELECT  f1.cd_filial, 
         f1.nm_fantasia, 
         f1.id_rede, 
         f1.cd_uf, 
         c.cd_cidade, 
         c.nm_cidade,
         f1.nm_gerente_regional, 
         f1.id_24horas,
         f1.id_abre_domingo         
  FROM filial f  
  inner join vw_filial f1 on f1.cd_filial  = f.cd_filial 
  inner join cidade c on c.cd_cidade = f1.cd_cidade
  where f.id_situacao  ='A'
  and f.cd_filial not in (1, 2)
  order by f1.cd_filial   " )
