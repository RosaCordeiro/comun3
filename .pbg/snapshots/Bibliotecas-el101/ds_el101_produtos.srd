table(column=(type=long updatewhereclause=yes name=cod_sku dbname="produto_geral.Cod_sku" )
 column=(type=char(60) updatewhereclause=yes name=desc_sku1 dbname="produto_geral.Desc_sku1" )
 column=(type=char(40) updatewhereclause=yes name=desc_sku2 dbname="produto_geral.Desc_sku2" )
 column=(type=char(8) updatewhereclause=yes name=situacao dbname="Situacao" )
 column=(type=char(40) updatewhereclause=yes name=subcategoria dbname="SubCategoria" )
 column=(type=char(40) updatewhereclause=yes name=categoria dbname="Categoria" )
 column=(type=char(40) updatewhereclause=yes name=subgrupo dbname="SubGrupo" )
 column=(type=char(40) updatewhereclause=yes name=grupo dbname="Grupo" )
 retrieve="select g.cd_produto as Cod_sku, 
       g.de_produto as Desc_sku1, 
       g.de_apresentacao_estoque as Desc_sku2, 
       case g.id_situacao when 'A' Then 'Ativo' when 'I' Then 'Inativo' else 'Pendente' end as Situacao, 
      (select de_subcategoria 	from subcategoria su where su.cd_subcategoria = g.cd_subcategoria) as SubCategoria, 
	  (select de_categoria 		from categoria ca where ca.cd_categoria = substring(g.cd_subcategoria, 1,6)) as Categoria, 
	  (select de_subgrupo 		from subgrupo sub where sub.cd_subgrupo = substring(g.cd_subcategoria, 1,3)) as SubGrupo, 
	  (select de_grupo 			from grupo gr where gr.cd_grupo = substring(g.cd_subcategoria, 1,1)) as Grupo
from   produto_geral g
where g.cd_produto >0"  sort="cod_sku A " )
