table(column=(type=long updatewhereclause=yes key=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_futuro dbname="produto_geral.pc_desconto_futuro" )
 column=(type=datetime updatewhereclause=yes name=dh_desconto_futuro dbname="produto_geral.dh_desconto_futuro" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_desconto_futuro dbname="produto_geral.nr_matricula_desconto_futuro" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_desconto_futuro dbname="produto_geral.id_tipo_desconto_futuro" )
 retrieve="select cd_produto,   
       pc_desconto_futuro,   
       dh_desconto_futuro,   
       nr_matricula_desconto_futuro,
       id_tipo_desconto_futuro
from produto_geral  
where dh_desconto_futuro <= :data_base    
  and pc_desconto_futuro is not null" update="produto_geral" updatewhere=0 updatekeyinplace=no arguments=(("data_base", date)) )
