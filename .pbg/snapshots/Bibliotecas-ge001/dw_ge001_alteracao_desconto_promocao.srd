table(column=(type=long updatewhereclause=yes key=yes name=cd_produto dbname="produto_loja.cd_produto" dbalias="l.cd_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="cd_promocao_sos" )
 retrieve="select l.cd_produto,   
		 cast(0.00 as decimal(9,2)) pc_desconto,
		 null cd_promocao_sos
from produto_loja l
where l.cd_promocao_sos is not null
  and not exists (select *
						from promocao_sos a,
							  promocao_sos_produto b,	   
							  produto_geral g,
							  parametro x
						where a.id_tipo_promocao = 'N'
						  and a.id_situacao      = 'L'
						  and a.dh_inicio <= x.dh_movimentacao and (a.dh_termino >= x.dh_movimentacao or a.dh_termino is null)
						  and b.cd_promocao_sos  = a.cd_promocao_sos
                    and b.cd_produto = l.cd_produto
						  and g.cd_produto = b.cd_produto
						  and ((b.pc_desconto > g.pc_desconto_atual and g.id_tipo_desconto_atual = 'F') or g.id_tipo_desconto_atual = 'N'))

union

select b.cd_produto,   
       b.pc_desconto pc_desconto,
       b.cd_promocao_sos
from promocao_sos a,
	  promocao_sos_produto b,	   
     produto_geral g,
     produto_loja l,
     parametro x
where a.id_tipo_promocao = 'N'
  and a.id_situacao      = 'L'
  and a.dh_inicio <= x.dh_movimentacao and (a.dh_termino >= x.dh_movimentacao or a.dh_termino is null)
  and b.cd_promocao_sos = a.cd_promocao_sos
  and g.cd_produto = b.cd_produto
  and l.cd_produto = b.cd_produto
  and ((b.pc_desconto > g.pc_desconto_atual and g.id_tipo_desconto_atual = 'F') or g.id_tipo_desconto_atual = 'N')
  and (l.pc_desconto_promocao is null or
       (l.pc_desconto_promocao is not null and b.pc_desconto > l.pc_desconto_promocao) or
       ((l.pc_desconto_promocao is not null and b.pc_desconto < l.pc_desconto_promocao)
        and not exists (select *
                        from promocao_sos y
                        where y.cd_promocao_sos = l.cd_promocao_sos
							     and y.id_tipo_promocao = 'N'
								  and y.id_situacao      = 'L'
								  and y.dh_inicio <= x.dh_movimentacao and (y.dh_termino >= x.dh_movimentacao or y.dh_termino is null))) or
		 (l.pc_desconto_promocao is not null 
        and exists (select *
                    from promocao_sos_produto z
                    where z.cd_promocao_sos = l.cd_promocao_sos
                      and z.cd_produto      = l.cd_produto
                      and z.pc_desconto < b.pc_desconto)))" update="produto_loja" updatewhere=0 updatekeyinplace=no  sort="cd_produto A pc_desconto A " )
