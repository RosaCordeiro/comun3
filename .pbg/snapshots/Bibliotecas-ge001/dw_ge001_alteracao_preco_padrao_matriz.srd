 retrieve="select cd_unidade_federacao,
       cd_produto,   
       vl_preco_venda_futuro,   
       dh_preco_venda_futuro,   
       nr_matric_preco_venda_futuro  
from produto_uf 
where dh_preco_venda_futuro <= :data_base
  and vl_preco_venda_futuro is not null" update="produto_uf" updatewhere=1 updatekeyinplace=no arguments=(("data_base", date)) )
