 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matric_preco_venda_futuro dbname="preco_regionalizado.nr_matric_preco_venda_futuro" )
 retrieve="select cd_filial,
       cd_produto,   
       vl_preco_venda_futuro,   
       dh_preco_venda_futuro,
       nr_matric_preco_venda_futuro
from preco_regionalizado   
where dh_preco_venda_futuro <= :data_base
  and vl_preco_venda_futuro is not null" update="preco_regionalizado" updatewhere=0 updatekeyinplace=no arguments=(("data_base", date)) )
