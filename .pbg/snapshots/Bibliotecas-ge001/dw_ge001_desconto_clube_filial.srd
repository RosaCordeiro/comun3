table(column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="promocao_sos.cd_promocao_sos" dbalias="p.cd_promocao_sos" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_clube dbname="pc_desconto_clube" )
 retrieve="select p.cd_promocao_sos,
		coalesce( pp.pc_desconto_clube, 0 ) as pc_desconto_clube
from	promocao_sos p, 
		parametro r, 
		promocao_sos_produto pp, 
		promocao_sos_filial pf
where p.id_tipo_promocao 		= 'N'
    and p.id_situacao 				= 'L'
    and p.dh_inicio 					<= r.dh_movimentacao
    and (p.dh_termino 				>= r.dh_movimentacao or p.dh_termino is null)
    and pp.cd_promocao_sos 	= p.cd_promocao_sos
    and pp.pc_desconto_clube	> 0
    and pp.cd_produto				= :produto
    and pf.cd_promocao_sos 	= p.cd_promocao_sos
    and pf.cd_filial 					= :filial
order by coalesce(pp.pc_desconto_clube, 0 ) desc" arguments=(("produto", number),("filial", number)) )
