table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="g.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="g.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="g.de_apresentacao_venda" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" dbalias="g.de_apresentacao_estoque" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" dbalias="g.cd_grupo_psico" )
 column=(type=char(1) updatewhereclause=yes name=id_cartao_genio dbname="produto_geral.id_cartao_genio" dbalias="g.id_cartao_genio" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_matriz dbname="produto_geral.id_situacao_matriz" dbalias="g.id_situacao_matriz" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_filial dbname="produto_loja.id_situacao_filial" dbalias="l.id_situacao_filial" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="vw_saldo_atual_produto.qt_saldo_final" dbalias="v.qt_saldo_final" )
 column=(type=char(13) updatewhereclause=yes name=de_registro_ms dbname="produto_geral.de_registro_ms" dbalias="g.de_registro_ms" )
 column=(type=char(1) updatewhereclause=yes name=id_promover_venda dbname="produto_geral.id_promover_venda" dbalias="g.id_promover_venda" initial="S" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="produto_geral.id_lei_generico" dbalias="g.id_lei_generico" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="g.cd_produto_sap" )
 retrieve="select g.cd_produto,   
		g.de_produto,   
		g.de_apresentacao_venda,   
		g.de_apresentacao_estoque,   
		g.cd_grupo_psico,
		g.id_cartao_genio,
		g.id_situacao id_situacao_matriz,
		l.id_situacao id_situacao_filial,
		v.qt_saldo_final  ,
		g.de_registro_ms,
		g.id_promover_venda,
		g.id_lei_generico,
		g.cd_produto_sap
from produto_geral g,  
     produto_loja l, 
     vw_saldo_atual_produto v
where l.cd_produto = g.cd_produto
  and v.cd_produto = g.cd_produto
and (g.cd_produto_sap is not null and Trim(g.cd_produto_sap) <> '')
"  sort="de_descricao_apresentacao A " )
