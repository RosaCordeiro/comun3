 retrieve="select cd_cliente_de,   
       cd_cliente_para,   
       dh_alteracao,   
       dh_exclusao  
from cliente_de_para   
where dh_alteracao <= :data_base
  and dh_exclusao is null
" update="cliente_de_para" updatewhere=1 updatekeyinplace=no arguments=(("data_base", date)) )
