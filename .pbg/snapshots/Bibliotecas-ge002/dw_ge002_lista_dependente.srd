table(column=(type=char(13) updatewhereclause=yes key=yes name=cd_dependente_cliente dbname="cliente_dependente.cd_dependente_cliente" )
 column=(type=char(40) updatewhereclause=yes name=nm_dependente dbname="cliente_dependente.nm_dependente" )
 column=(type=datetime updatewhereclause=yes name=dh_nascimento dbname="cliente_dependente.dh_nascimento" )
 column=(type=char(16) updatewhereclause=yes name=de_grau_parentesco dbname="de_grau_parentesco" )
 retrieve="select cd_dependente_cliente,   
       nm_dependente,   
       dh_nascimento,   
       case id_grau_parentesco
			when '1' then 'PAI'
			when '2' then 'M$$HEX1$$c300$$ENDHEX$$E'	
			when '3' then 'FILHO / FILHA'	
			when '4' then 'MARIDO / ESPOSA'
			when '5' then 'OUTROS'
         else 'N$$HEX1$$c300$$ENDHEX$$O IDENTIFICADO'
		 end de_grau_parentesco
from cliente_dependente
where id_situacao = 'A'
" update="cliente_dependente" updatewhere=0 updatekeyinplace=no )
