table(column=(type=long updatewhereclause=yes name=cd_convenio dbname="convenio.cd_convenio" )
 column=(type=char(60) updatewhereclause=yes name=nm_fantasia dbname="convenio.nm_fantasia" )
 column=(type=char(15) updatewhereclause=yes name=nr_cgc dbname="convenio.nr_cgc" )
 column=(type=char(40) updatewhereclause=yes name=cidade_nm_cidade dbname="cidade.nm_cidade" )
 retrieve="  SELECT convenio.cd_convenio,   
		 convenio.nm_fantasia,   
         convenio.nr_cgc,   
         cidade.nm_cidade  
    FROM convenio,   
         cidade  
   WHERE ( cidade.cd_cidade = convenio.cd_cidade )    
"  sort="nm_fantasia A " )
