HA$PBExportHeader$ds_conveniado_nao_atualizado.srd
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=144 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=92 color="536870912" )
table(column=(type=char(15) updatewhereclause=yes name=cd_conveniado dbname="conveniado.cd_conveniado" )
 retrieve="Select co.cd_conveniado
From convenio cv, 
     conveniado co
Where cv.cd_convenio = :convenio
  and co.cd_convenio = cv.cd_convenio
  and co.dh_atualizacao < cv.dh_atualizacao_conveniado
  and not exists (Select *
						From bloqueio b
						Where b.id_tipo_bloqueio   = 'CDO' 
						  and b.cd_convenio        = co.cd_convenio
						  and b.cd_conveniado      = co.cd_conveniado 
						  and b.cd_motivo_bloqueio = :Motivo
						  and b.dh_liberacao is null)
" arguments=(("convenio", number),("motivo", string)) )
text(band=header alignment="2" text="Conveniado
Cd Conveniado"border="0" color="0" x="9" y="8" height="128" width="439"  name=conveniado_cd_conveniado_t  font.face="Arial" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
column(band=detail id=1 alignment="0" tabsequence=32766 border="0" color="0" x="9" y="8" height="76" width="439" format="[general]"  name=cd_conveniado edit.limit=15 edit.case=any edit.focusrectangle=no edit.autoselect=yes edit.autohscroll=yes  font.face="Arial" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
htmltable(border="1" cellpadding="0" cellspacing="0" generatecss="no" nowrap="yes")