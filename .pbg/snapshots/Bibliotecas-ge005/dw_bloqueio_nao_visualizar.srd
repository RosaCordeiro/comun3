release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=144 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=92 color="536870912" )
table(column=(type=long updatewhereclause=yes name=cd_convenio dbname="bloqueio.cd_convenio" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="convenio.nm_fantasia" )
 column=(type=char(15) updatewhereclause=yes name=cd_conveniado dbname="bloqueio.cd_conveniado" )
 column=(type=char(40) updatewhereclause=yes name=nm_conveniado dbname="conveniado.nm_conveniado" )
 column=(type=char(3) updatewhereclause=yes name=cd_motivo_bloqueio dbname="bloqueio.cd_motivo_bloqueio" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo_bloqueio dbname="motivo_bloqueio.de_motivo_bloqueio" )
 retrieve="  SELECT b.cd_convenio,   
         convenio.nm_fantasia,   
         b.cd_conveniado,   
         conveniado.nm_conveniado,   
         b.cd_motivo_bloqueio, 
         m.de_motivo_bloqueio  
    FROM bloqueio b,   
         motivo_bloqueio m,   
         conveniado,   
         convenio  
   WHERE ( b.cd_motivo_bloqueio = m.cd_motivo_bloqueio ) and  
         ( conveniado.cd_convenio = b.cd_convenio ) and  
         ( conveniado.cd_conveniado = b.cd_conveniado ) and  
         ( convenio.cd_convenio = conveniado.cd_convenio ) and  
         ( convenio.cd_convenio = b.cd_convenio ) and  
         ( ( b.cd_convenio = :Convenio ) AND  
         ( b.cd_conveniado = :Conveniado ) AND  
         ( b.id_tipo_bloqueio <> 'DCO' ) and
         ( b.dh_liberacao is null ) AND  
         ( m.id_permite_visualizacao = 'N' ) )    
" arguments=(("convenio", number),("conveniado", string)) )
