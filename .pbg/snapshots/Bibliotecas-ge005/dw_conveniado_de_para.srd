 column=(type=char(15) updatewhereclause=yes key=yes name=cd_conveniado_de dbname="conveniado_de_para.cd_conveniado_de" )
 column=(type=char(15) updatewhereclause=yes key=yes name=cd_conveniado_para dbname="conveniado_de_para.cd_conveniado_para" )
 column=(type=datetime updatewhereclause=yes key=yes name=dh_alteracao dbname="conveniado_de_para.dh_alteracao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_exclusao dbname="conveniado_de_para.dh_exclusao" )
 retrieve="select cd_convenio,   
       cd_conveniado_de,   
       cd_conveniado_para,
       dh_alteracao,
       dh_exclusao
from conveniado_de_para
where dh_alteracao <= :data_base
  and dh_exclusao is null
" update="conveniado_de_para" updatewhere=0 updatekeyinplace=no arguments=(("data_base", date)) )
