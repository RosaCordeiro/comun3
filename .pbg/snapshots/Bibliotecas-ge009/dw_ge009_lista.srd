table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="filial.nr_cgc" )
 column=(type=char(15) updatewhereclause=yes name=nr_inscricao_estadual dbname="filial.nr_inscricao_estadual" )
 retrieve="select cd_filial,   
       nm_fantasia,   
       nr_cgc,   
       nr_inscricao_estadual
from filial f
inner join cidade c
	on c.cd_cidade = f.cd_cidade
"  sort="nm_fantasia A " )
