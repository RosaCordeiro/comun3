 retrieve="select nr_parcela,   
       qt_dias_vencimento,   
       pc_valor_total,
       Cast( '2005/01/01' As Date ) dt_parcela,
       0.00 vl_parcela
from condicao_pagamento_parcela
where cd_condicao = :condicao
" arguments=(("condicao", number))  sort="nr_parcela A " )
