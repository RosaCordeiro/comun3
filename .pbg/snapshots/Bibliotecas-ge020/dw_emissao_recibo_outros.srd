table(column=(type=char(40) updatewhereclause=yes name=cidade_nm_cidade dbname="cidade.nm_cidade" dbalias=".nm_cidade" )
 column=(type=char(11) updatewhereclause=yes name=recibo_cobranca_nr_recibo_cobranca dbname="recibo_cobranca.nr_recibo_cobranca" dbalias=".nr_recibo_cobranca" )
 column=(type=datetime updatewhereclause=yes name=recibo_cobranca_dh_emissao dbname="recibo_cobranca.dh_emissao" dbalias=".dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=recibo_cobranca_vl_recebido dbname="recibo_cobranca.vl_recebido" dbalias=".vl_recebido" )
 column=(type=char(40) updatewhereclause=yes name=recibo_cobranca_nm_cliente dbname="recibo_cobranca.nm_cliente" dbalias=".nm_cliente" )
 column=(type=char(40) updatewhereclause=yes name=recibo_cobranca_de_observacao dbname="recibo_cobranca.de_observacao" dbalias=".de_observacao" )
 column=(type=char(255) updatewhereclause=yes name=extenso dbname="extenso" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_razao_social dbname="filial.nm_razao_social" dbalias=".nm_razao_social" )
 column=(type=char(13) updatewhereclause=yes name=recibo_cobranca_nr_titulo dbname="recibo_cobranca.nr_titulo" dbalias=".nr_titulo" )
 retrieve="  SELECT cidade.nm_cidade,   
         recibo_cobranca.nr_recibo_cobranca,   
         recibo_cobranca.dh_emissao,   
         recibo_cobranca.vl_recebido,   
         recibo_cobranca.nm_cliente,
         recibo_cobranca.de_observacao,
         Space(60) extenso,
         filial.nm_razao_social,
		recibo_cobranca.nr_titulo
    FROM recibo_cobranca
    Join filial on filial.cd_filial = recibo_cobranca.cd_filial    
    Join cidade on cidade.cd_cidade = filial.cd_cidade 
   WHERE recibo_cobranca.nr_recibo_cobranca = :recibo" arguments=(("recibo", string)) )
