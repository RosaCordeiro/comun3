table(column=(type=char(6) update=yes updatewhereclause=yes name=cd_caixa dbname="controle_caixa.cd_caixa" )
 column=(type=long update=yes updatewhereclause=yes name=nr_controle_caixa dbname="controle_caixa.nr_controle_caixa" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_movimentacao_caixa dbname="controle_caixa.dh_movimentacao_caixa" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_fechamento_caixa dbname="controle_caixa.dh_fechamento_caixa" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_saldo_final dbname="controle_caixa.vl_saldo_final" )
 column=(type=char(40) updatewhereclause=yes name=caixa_de_caixa dbname="caixa.de_caixa" )
 column=(type=datetime updatewhereclause=yes name=controle_caixa_dh_abertura_caixa dbname="controle_caixa.dh_abertura_caixa" )
 column=(type=char(40) updatewhereclause=yes name=usuario_nm_usuario dbname="usuario.nm_usuario" )
 retrieve="select cc.cd_caixa,   
		 cc.nr_controle_caixa,    
		 cc.dh_movimentacao_caixa,   
		 cc.dh_fechamento_caixa,     
		 cc.vl_saldo_final,     
		 cx.de_caixa,     
		 cc.dh_abertura_caixa,   
		 us.nm_usuario
from controle_caixa cc,    
     caixa cx,        
     usuario us     
where cc.cd_caixa = :caixa
  and cc.dh_movimentacao_caixa between :dt_inicio and :dt_termino
  and cx.cd_caixa     = cc.cd_caixa
  and us.nr_matricula = cc.nr_matricula_operador
" arguments=(("caixa", string),("dt_inicio", date),("dt_termino", date))  sort="nr_controle_caixa D " )
