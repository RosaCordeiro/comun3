table(column=(type=char(1) updatewhereclause=yes name=id_permissao_devolucao dbname="tipo_produto_fiscal_uf.id_permissao_devolucao" )
 column=(type=char(1) updatewhereclause=yes name=id_permissao_transferencia dbname="tipo_produto_fiscal_uf.id_permissao_transferencia" )
 column=(type=long updatewhereclause=yes name=cd_tipo_produto_fiscal dbname="tipo_produto_fiscal_uf.cd_tipo_produto_fiscal" )
 column=(type=char(1) updatewhereclause=yes name=ordem dbname="ordem" )
 retrieve="SELECT u.id_permissao_devolucao, u.id_permissao_transferencia, u.cd_tipo_produto_fiscal, CAST('A' as varchar(1) ) AS ordem
FROM tipo_produto_fiscal f
	INNER JOIN tipo_produto_fiscal_ncm n
		ON n.cd_tipo_produto_fiscal = f.cd_tipo_produto_fiscal
	INNER JOIN tipo_produto_fiscal_uf u
		ON u.cd_tipo_produto_fiscal = f.cd_tipo_produto_fiscal
	   AND u.cd_uf = :UF
WHERE n.nr_ncm_final IS NULL
AND n.nr_ncm_inicial = :NCM

UNION

SELECT u.id_permissao_devolucao, u.id_permissao_transferencia, u.cd_tipo_produto_fiscal, CAST('B' as varchar(1) ) as ordem
FROM tipo_produto_fiscal f
	INNER JOIN tipo_produto_fiscal_ncm n
		ON n.cd_tipo_produto_fiscal = f.cd_tipo_produto_fiscal
	INNER JOIN tipo_produto_fiscal_uf u
		ON u.cd_tipo_produto_fiscal = f.cd_tipo_produto_fiscal
	   AND u.cd_uf = :UF
WHERE n.nr_ncm_final IS NOT NULL
AND (:NCM >= n.nr_ncm_inicial And :NCM <= n.nr_ncm_final)

UNION

--OUTROS
SELECT u.id_permissao_devolucao, u.id_permissao_transferencia, u.cd_tipo_produto_fiscal, CAST('C' as varchar(1) ) as ordem
FROM tipo_produto_fiscal f	
INNER JOIN tipo_produto_fiscal_uf u
	ON u.cd_tipo_produto_fiscal = f.cd_tipo_produto_fiscal
       AND u.cd_uf = :UF
WHERE f.cd_tipo_produto = 4

Order by ordem
LIMIT 1;
" arguments=(("NCM", number),("UF", string)) )
