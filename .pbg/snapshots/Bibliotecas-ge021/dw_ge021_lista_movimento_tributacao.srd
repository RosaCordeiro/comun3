table(column=(type=datetime updatewhereclause=yes name=dh_movimento dbname="dh_movimento" )
 column=(type=long updatewhereclause=yes name=nr_movimento dbname="nr_movimento" )
 column=(type=long updatewhereclause=yes name=qt_movimento dbname="qt_movimento" )
 column=(type=long updatewhereclause=yes name=qt_disponivel dbname="qt_disponivel" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_bc_icms_st dbname="vl_bc_icms_st" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_icms_st dbname="vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_st dbname="pc_icms_st" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_icms dbname="vl_icms" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_icms_st_fiscal dbname="vl_icms_st_fiscal" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_ipi dbname="vl_ipi" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf_destino dbname="cd_uf_destino" )
 retrieve="select	tudo.dh_movimento, 
		tudo.nr_movimento, 
		tudo.qt_movimento, 
		tudo.qt_disponivel, 
		tudo.vl_bc_icms_st, 
		tudo.vl_icms_st,
		tudo.pc_icms_st,
		tudo.vl_icms,
		tudo.vl_icms_st_fiscal,
		tudo.vl_ipi,
		tudo.cd_uf_destino
from 
(
	SELECT	case when m.cd_tipo_movimento = 18 then 99 else 1 end nr_ordem, //deixa os segregados por $$HEX1$$fa00$$ENDHEX$$ltimo
			m.dh_movimento,
			m.nr_movimento,
			m.qt_disponivel,
			coalesce(m.vl_bc_icms_st,0) vl_bc_icms_st,
			coalesce(m.vl_icms_st,0) vl_icms_st,
			m.qt_movimento,
			coalesce(m.vl_icms_st_fiscal, 0) as vl_icms_st_fiscal,
			m.pc_icms_st,
			coalesce(m.vl_icms,0) as vl_icms, 
			coalesce(inc.qt_faturada * inc.vl_ipi,0) as vl_ipi,
			c1.cd_unidade_federacao cd_uf_destino
	FROM movimento_produto_tributacao  m
	inner join tipo_movimento_estoque t
		on t.cd_tipo_movimento = m.cd_tipo_movimento
	inner join filial f1
		on f1.cd_filial  = m.cd_filial_movimento
	inner join cidade c1
		on c1.cd_cidade = f1.cd_cidade 
	left outer join item_nf_compra inc
		on inc.cd_filial = m.cd_filial_movimento
		and inc.cd_fornecedor = m.cd_fornecedor
		and inc.nr_nf = m.nr_nf
		and inc.de_serie = m.de_serie
		and inc.de_especie = m.de_especie
		and inc.cd_produto = m.cd_produto
	Where m.cd_filial_movimento 	= :al_filial
	  and m.cd_produto				=:al_produto
	  and m.dh_movimento 			<=:dt_movimento
   	  and m.qt_disponivel 			> 0
	  and t.id_entrada_saida 		= 'E'
	  and t.id_cancelamento 		= 'N'
	  and m.cd_fornecedor <> '053479585'
) as tudo
order by tudo.nr_ordem asc, tudo.dh_movimento asc




" arguments=(("al_filial", number),("al_produto", number),("dt_movimento", date)) )
