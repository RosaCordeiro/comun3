table(column=(type=char(9) updatewhereclause=yes name=cd_subcategoria dbname="subcategoria.cd_subcategoria" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="subcategoria.de_subcategoria" )
 column=(type=char(40) updatewhereclause=yes name=de_categoria dbname="categoria.de_categoria" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo dbname="subgrupo.de_subgrupo" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="grupo.de_grupo" )
 retrieve="select 	sc.cd_subcategoria, 
			sc.de_subcategoria, 
			c.de_categoria, 
			s.de_subgrupo, 
			g.de_grupo 
from subcategoria sc
Inner Join categoria c
	on c.cd_categoria = sc.cd_categoria
Inner join subgrupo s
	On s.cd_subgrupo = c.cd_subgrupo
Inner join grupo g
	On g.cd_grupo = s.cd_grupo" )
