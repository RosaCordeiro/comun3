table(column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" dbalias="filial_a.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=filial_cd_filial dbname="filial.cd_filial" dbalias="filial_a.cd_filial" )
 column=(type=char(11) updatewhereclause=yes name=nr_recibo_cobranca dbname="recibo_cobranca.nr_recibo_cobranca" dbalias=".nr_recibo_cobranca" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="recibo_cobranca.dh_emissao" dbalias=".dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_nominal dbname="recibo_cobranca.vl_nominal" dbalias=".vl_nominal" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_juros dbname="recibo_cobranca.vl_juros" dbalias=".vl_juros" )
 column=(type=decimal(2) updatewhereclause=yes name=recibo_cobranca_vl_multa_recebida dbname="recibo_cobranca.vl_multa_recebida" dbalias=".vl_multa_recebida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto dbname="recibo_cobranca.vl_desconto" dbalias=".vl_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_recebido dbname="recibo_cobranca.vl_recebido" dbalias=".vl_recebido" )
 column=(type=char(60) updatewhereclause=yes name=nm_fantasia dbname="convenio.nm_fantasia" dbalias=".nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="convenio.cd_convenio" dbalias=".cd_convenio" )
 column=(type=char(40) updatewhereclause=yes name=nm_conveniado dbname="conveniado.nm_conveniado" dbalias=".nm_conveniado" )
 column=(type=char(15) updatewhereclause=yes name=cd_conveniado dbname="conveniado.cd_conveniado" dbalias=".cd_conveniado" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia_1 dbname="filial.nm_fantasia" dbalias="filial_b.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_nf_venda dbname="recibo_cobranca.nr_nf_venda" dbalias=".nr_nf_venda" )
 column=(type=char(3) updatewhereclause=yes name=de_especie_venda dbname="recibo_cobranca.de_especie_venda" dbalias=".de_especie_venda" )
 column=(type=char(3) updatewhereclause=yes name=de_serie_venda dbname="recibo_cobranca.de_serie_venda" dbalias=".de_serie_venda" )
 column=(type=char(40) updatewhereclause=yes name=de_observacao dbname="recibo_cobranca.de_observacao" dbalias=".de_observacao" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_recibo dbname="tipo_recibo_cobranca.de_tipo_recibo" dbalias=".de_tipo_recibo" )
 retrieve="  SELECT filial_a.nm_fantasia,  
         filial_a.cd_filial, 
         recibo_cobranca.nr_recibo_cobranca,   
         recibo_cobranca.dh_emissao,   
         recibo_cobranca.vl_nominal,   
         recibo_cobranca.vl_juros,
		recibo_cobranca.vl_multa_recebida,   
         recibo_cobranca.vl_desconto,   
         recibo_cobranca.vl_recebido,   
         convenio.nm_fantasia,   
         convenio.cd_convenio,
         conveniado.nm_conveniado,
         conveniado.cd_conveniado,   
         filial_b.nm_fantasia,   
         recibo_cobranca.nr_nf_venda,   
         recibo_cobranca.de_especie_venda,   
         recibo_cobranca.de_serie_venda,   
         recibo_cobranca.de_observacao,   
         tipo_recibo_cobranca.de_tipo_recibo  
    FROM recibo_cobranca
	JOIN  filial filial_a ON filial_a.cd_filial = recibo_cobranca.cd_filial
	JOIN  filial filial_b ON filial_b.cd_filial = recibo_cobranca.cd_filial
	JOIN  tipo_recibo_cobranca ON tipo_recibo_cobranca.cd_tipo_recibo = recibo_cobranca.cd_tipo_recibo
	JOIN  nf_venda ON nf_venda.cd_filial  = recibo_cobranca.cd_filial_venda   
		     		and nf_venda.nr_nf = recibo_cobranca.nr_nf_venda    
     				and nf_venda.de_especie = recibo_cobranca.de_especie_venda
     				and nf_venda.de_serie = recibo_cobranca.de_serie_venda
	JOIN convenio ON convenio.cd_convenio = nf_venda.cd_convenio
	JOIN conveniado ON conveniado.cd_convenio = nf_venda.cd_convenio
     					and conveniado.cd_conveniado = nf_venda.cd_conveniado
   WHERE recibo_cobranca.nr_recibo_cobranca = :nr_recibo_cobranca" arguments=(("nr_recibo_cobranca", string)) )
