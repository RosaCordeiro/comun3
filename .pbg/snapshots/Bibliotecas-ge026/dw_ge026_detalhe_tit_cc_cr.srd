table(column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" dbalias="filial_a.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=filial_cd_filial dbname="filial.cd_filial" dbalias="filial_a.cd_filial" )
 column=(type=char(11) updatewhereclause=yes name=recibo_cobranca_nr_recibo_cobranca dbname="recibo_cobranca.nr_recibo_cobranca" dbalias=".nr_recibo_cobranca" )
 column=(type=datetime updatewhereclause=yes name=recibo_cobranca_dh_emissao dbname="recibo_cobranca.dh_emissao" dbalias=".dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=recibo_cobranca_vl_nominal dbname="recibo_cobranca.vl_nominal" dbalias=".vl_nominal" )
 column=(type=decimal(2) updatewhereclause=yes name=recibo_cobranca_vl_juros dbname="recibo_cobranca.vl_juros" dbalias=".vl_juros" )
 column=(type=decimal(2) updatewhereclause=yes name=recibo_cobranca_vl_multa_recebida dbname="recibo_cobranca.vl_multa_recebida" dbalias=".vl_multa_recebida" )
 column=(type=decimal(2) updatewhereclause=yes name=recibo_cobranca_vl_desconto dbname="recibo_cobranca.vl_desconto" dbalias=".vl_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=recibo_cobranca_vl_recebido dbname="recibo_cobranca.vl_recebido" dbalias=".vl_recebido" )
 column=(type=char(13) updatewhereclause=yes name=recibo_cobranca_nr_titulo dbname="recibo_cobranca.nr_titulo" dbalias=".nr_titulo" )
 column=(type=char(11) updatewhereclause=yes name=cliente_cd_cliente dbname="cliente.cd_cliente" dbalias=".cd_cliente" )
 column=(type=char(40) updatewhereclause=yes name=cliente_nm_cliente dbname="nm_cliente" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia_1 dbname="filial.nm_fantasia" dbalias="filial_b.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=recibo_cobranca_de_observacao dbname="recibo_cobranca.de_observacao" dbalias=".de_observacao" )
 column=(type=char(40) updatewhereclause=yes name=tipo_recibo_cobranca_de_tipo_recibo dbname="tipo_recibo_cobranca.de_tipo_recibo" dbalias=".de_tipo_recibo" )
 retrieve="  SELECT filial_a.nm_fantasia,   
         filial_a.cd_filial,
         recibo_cobranca.nr_recibo_cobranca,   
         recibo_cobranca.dh_emissao,   
         recibo_cobranca.vl_nominal,   
         recibo_cobranca.vl_juros,
		recibo_cobranca.vl_multa_recebida,   
         recibo_cobranca.vl_desconto,   
         recibo_cobranca.vl_recebido,   
         recibo_cobranca.nr_titulo,   
         cliente.cd_cliente,
         (CASE WHEN cliente.nm_social is not null THEN cliente.nm_social ELSE cliente.nm_cliente END) as nm_cliente,
         filial_b.nm_fantasia,   
         recibo_cobranca.de_observacao,   
         tipo_recibo_cobranca.de_tipo_recibo  
    FROM recibo_cobranca
	JOIN	filial filial_a ON filial_a.cd_filial = recibo_cobranca.cd_filial
	JOIN  filial filial_b ON filial_b.cd_filial = recibo_cobranca.cd_filial
	JOIN  tipo_recibo_cobranca ON tipo_recibo_cobranca.cd_tipo_recibo = recibo_cobranca.cd_tipo_recibo
		AND tipo_recibo_cobranca.id_venda_avista  <> 'S'
	JOIN  titulo_receber ON titulo_receber. nr_titulo = recibo_cobranca.nr_titulo
	JOIN  cliente ON cliente.cd_cliente = titulo_receber.cd_cliente
   WHERE recibo_cobranca.nr_recibo_cobranca    = :nr_recibo_cobranca

" arguments=(("nr_recibo_cobranca", string)) )
