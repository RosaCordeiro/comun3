table(column=(type=char(11) updatewhereclause=yes name=nr_recibo_cobranca dbname="recibo_cobranca.nr_recibo_cobranca" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="recibo_cobranca.dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_nominal dbname="recibo_cobranca.vl_nominal" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_juros dbname="recibo_cobranca.vl_juros" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_multa_recebida dbname="recibo_cobranca.vl_multa_recebida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto dbname="recibo_cobranca.vl_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_recebido dbname="recibo_cobranca.vl_recebido" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_recibo dbname="tipo_recibo_cobranca.de_tipo_recibo" )
 column=(type=long updatewhereclause=yes name=cd_tipo_recibo dbname="tipo_recibo_cobranca.cd_tipo_recibo" )
 column=(type=char(13) updatewhereclause=yes name=nr_titulo dbname="recibo_cobranca.nr_titulo" )
 retrieve="  SELECT recibo_cobranca.nr_recibo_cobranca,   
         recibo_cobranca.dh_emissao,   
         recibo_cobranca.vl_nominal,   
         recibo_cobranca.vl_juros,
		recibo_cobranca.vl_multa_recebida,   
         recibo_cobranca.vl_desconto,   
         recibo_cobranca.vl_recebido,   
         tipo_recibo_cobranca.de_tipo_recibo,
         tipo_recibo_cobranca.cd_tipo_recibo,
		recibo_cobranca.nr_titulo
    FROM recibo_cobranca
    Join tipo_recibo_cobranca on  tipo_recibo_cobranca.cd_tipo_recibo = recibo_cobranca.cd_tipo_recibo
				 					and tipo_recibo_cobranca.id_venda_avista <> 'S' 
   WHERE 1=1"  sort="nr_recibo_cobranca A " )
