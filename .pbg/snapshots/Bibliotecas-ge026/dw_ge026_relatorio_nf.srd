table(column=(type=char(11) updatewhereclause=yes name=nr_recibo_cobranca dbname="recibo_cobranca.nr_recibo_cobranca" dbalias=".nr_recibo_cobranca" )
 column=(type=datetime updatewhereclause=yes name=recibo_cobranca_dh_emissao dbname="recibo_cobranca.dh_emissao" dbalias=".dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=recibo_cobranca_vl_nominal dbname="recibo_cobranca.vl_nominal" dbalias=".vl_nominal" )
 column=(type=decimal(2) updatewhereclause=yes name=recibo_cobranca_vl_juros dbname="recibo_cobranca.vl_juros" dbalias=".vl_juros" )
 column=(type=decimal(2) updatewhereclause=yes name=recibo_cobranca_vl_desconto dbname="recibo_cobranca.vl_desconto" dbalias=".vl_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=recibo_cobranca_vl_recebido dbname="recibo_cobranca.vl_recebido" dbalias=".vl_recebido" )
 column=(type=long updatewhereclause=yes name=recibo_cobranca_nr_nf_venda dbname="recibo_cobranca.nr_nf_venda" dbalias=".nr_nf_venda" )
 column=(type=char(3) updatewhereclause=yes name=recibo_cobranca_de_especie_venda dbname="recibo_cobranca.de_especie_venda" dbalias=".de_especie_venda" )
 column=(type=char(3) updatewhereclause=yes name=recibo_cobranca_de_serie_venda dbname="recibo_cobranca.de_serie_venda" dbalias=".de_serie_venda" )
 column=(type=long updatewhereclause=yes name=recibo_cobranca_cd_filial dbname="recibo_cobranca.cd_filial" dbalias=".cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_recibo dbname="tipo_recibo_cobranca.de_tipo_recibo" dbalias=".de_tipo_recibo" )
 column=(type=long updatewhereclause=yes name=convenio_cd_convenio dbname="convenio.cd_convenio" dbalias=".cd_convenio" )
 column=(type=char(60) updatewhereclause=yes name=convenio_nm_fantasia dbname="convenio.nm_fantasia" dbalias=".nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=conveniado_nm_conveniado dbname="conveniado.nm_conveniado" dbalias=".nm_conveniado" )
 retrieve="SELECT	recibo_cobranca.nr_recibo_cobranca,   
			recibo_cobranca.dh_emissao,   
			recibo_cobranca.vl_nominal,   
			recibo_cobranca.vl_juros,   
			recibo_cobranca.vl_desconto,   
			recibo_cobranca.vl_recebido,   
			recibo_cobranca.nr_nf_venda,   
			recibo_cobranca.de_especie_venda,   
			recibo_cobranca.de_serie_venda,   
			recibo_cobranca.cd_filial,   
			tipo_recibo_cobranca.de_tipo_recibo,   
			convenio.cd_convenio,   
			convenio.nm_fantasia,   
			conveniado.nm_conveniado  
    FROM recibo_cobranca
			INNER JOIN	tipo_recibo_cobranca
				ON tipo_recibo_cobranca.cd_tipo_recibo = recibo_cobranca.cd_tipo_recibo
			INNER JOIN nf_venda
				ON nf_venda.cd_filial			= recibo_cobranca.cd_filial_venda   
				AND nf_venda.nr_nf			= recibo_cobranca.nr_nf_venda    
				AND nf_venda.de_especie	= recibo_cobranca.de_especie_venda
				AND nf_venda.de_serie		= recibo_cobranca.de_serie_venda
			INNER JOIN convenio
				ON convenio.cd_convenio	= nf_venda.cd_convenio
			INNER JOIN conveniado
				ON conveniado.cd_convenio			= nf_venda.cd_convenio
     			AND conveniado.cd_conveniado	= nf_venda.cd_conveniado
   WHERE dbo.ToChar( recibo_cobranca.dh_emissao, 'yyyymmdd' ) >= :ps_data_ini
	   AND dbo.ToChar( recibo_cobranca.dh_emissao, 'yyyymmdd' ) <= :ps_data_fim" arguments=(("ps_data_ini", string),("ps_data_fim", string))  sort="recibo_cobranca_cd_filial A recibo_cobranca_dh_emissao A " )
