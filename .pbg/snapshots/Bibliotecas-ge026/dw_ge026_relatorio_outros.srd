table(column=(type=char(11) updatewhereclause=yes name=nr_recibo_cobranca dbname="recibo_cobranca.nr_recibo_cobranca" dbalias=".nr_recibo_cobranca" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="recibo_cobranca.dh_emissao" dbalias=".dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_nominal dbname="recibo_cobranca.vl_nominal" dbalias=".vl_nominal" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_juros dbname="recibo_cobranca.vl_juros" dbalias=".vl_juros" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto dbname="recibo_cobranca.vl_desconto" dbalias=".vl_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_recebido dbname="recibo_cobranca.vl_recebido" dbalias=".vl_recebido" )
 column=(type=char(40) updatewhereclause=yes name=de_observacao dbname="recibo_cobranca.de_observacao" dbalias=".de_observacao" )
 column=(type=char(40) updatewhereclause=yes name=cliente_nm_cliente dbname="nm_cliente" )
 column=(type=char(11) updatewhereclause=yes name=cliente_cd_cliente dbname="cliente.cd_cliente" dbalias=".cd_cliente" )
 column=(type=long updatewhereclause=yes name=recibo_cobranca_cd_filial dbname="recibo_cobranca.cd_filial" dbalias=".cd_filial" )
 retrieve="SELECT	recibo_cobranca.nr_recibo_cobranca,   
			recibo_cobranca.dh_emissao,   
			recibo_cobranca.vl_nominal,   
			recibo_cobranca.vl_juros,   
			recibo_cobranca.vl_desconto,   
			recibo_cobranca.vl_recebido,
			recibo_cobranca.de_observacao,
			(CASE WHEN cliente.nm_social is not null THEN cliente.nm_social ELSE cliente.nm_cliente END) as nm_cliente,
			cliente.cd_cliente,
			recibo_cobranca.cd_filial
    FROM recibo_cobranca
		LEFT OUTER JOIN cliente
			ON  cliente.nm_cliente = recibo_cobranca.nm_cliente
   WHERE  dbo.ToChar( recibo_cobranca.dh_emissao, 'yyyymmdd' ) >= :ps_data_ini
        AND dbo.ToChar( recibo_cobranca.dh_emissao, 'yyyymmdd' ) <= :ps_data_fim" arguments=(("ps_data_ini", string),("ps_data_fim", string))  sort="recibo_cobranca_cd_filial A dh_emissao A " )
