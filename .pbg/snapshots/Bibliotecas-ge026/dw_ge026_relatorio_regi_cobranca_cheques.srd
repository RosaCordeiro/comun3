table(column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="recibo_cobranca.dh_emissao" dbalias=".dh_emissao" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="recibo_cobranca.nm_cliente" dbalias=".nm_cliente" )
 column=(type=char(40) updatewhereclause=yes name=de_banco dbname="recibo_cobranca.de_banco" dbalias=".de_banco" )
 column=(type=char(15) updatewhereclause=yes name=nr_cheque dbname="recibo_cobranca.nr_cheque" dbalias=".nr_cheque" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_nominal dbname="recibo_cobranca.vl_nominal" dbalias=".vl_nominal" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto dbname="recibo_cobranca.vl_desconto" dbalias=".vl_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_juros dbname="recibo_cobranca.vl_juros" dbalias=".vl_juros" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_recebido dbname="recibo_cobranca.vl_recebido" dbalias=".vl_recebido" )
 column=(type=char(40) updatewhereclause=yes name=de_observacao dbname="recibo_cobranca.de_observacao" dbalias=".de_observacao" )
 retrieve="SELECT	recibo_cobranca.dh_emissao,   
			recibo_cobranca.nm_cliente,   
			recibo_cobranca.de_banco,   
			recibo_cobranca.nr_cheque,   
			recibo_cobranca.vl_nominal,   
			recibo_cobranca.vl_desconto,   
			recibo_cobranca.vl_juros,   
			recibo_cobranca.vl_recebido,   
			recibo_cobranca.de_observacao  
    FROM recibo_cobranca   
   WHERE dbo.ToChar( recibo_cobranca.dh_emissao, 'yyyymmdd' ) >= :ps_data_ini
       AND dbo.ToChar( recibo_cobranca.dh_emissao, 'yyyymmdd' ) <= :ps_data_fim
" arguments=(("ps_data_ini", string),("ps_data_fim", string))  sort="nm_cliente A " )
