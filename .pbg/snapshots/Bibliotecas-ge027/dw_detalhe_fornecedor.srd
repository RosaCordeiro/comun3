 column=(type=char(1) updatewhereclause=yes name=nm_cidade dbname="nm_cidade" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_regime_especial dbname="fornecedor.id_regime_especial" initial="N" values="Utiliza Regime Especial de ICMS ?	S/Utiliza Regime Especial de ICMS ?	N" )
 retrieve="  SELECT fornecedor.cd_filial,   
         fornecedor.cd_fornecedor,   
         fornecedor.cd_cidade,
         fornecedor.nm_fantasia,   
         fornecedor.nm_razao_social,   
         fornecedor.id_fisica_juridica,   
         fornecedor.nr_cgc,   
         fornecedor.nr_cpf,   
         fornecedor.nr_inscricao_estadual,   
         fornecedor.de_endereco,   
         fornecedor.de_bairro,   
         fornecedor.nr_cep,   
         fornecedor.nr_telefone,   
         fornecedor.nr_fax,   
         fornecedor.nr_ddd_telefone,   
         fornecedor.nr_ddd_fax,   
         fornecedor.nr_ddd_fax_compras,   
         fornecedor.pc_desconto_usual,   
         fornecedor.nm_contato,   
         fornecedor.nr_ddd_telefone_compras,   
         fornecedor.nr_telefone_compras,   
         fornecedor.nr_fax_compras,   
         fornecedor.id_fornecedor_transportadora,
         fornecedor.de_email,
			fornecedor.cd_condicao_pagamento,
			''de_condicao_pagamento,
         ''nm_localiza,
         ''nm_cidade,   
         fornecedor.id_regime_especial 
    FROM fornecedor,   
         cidade  
   WHERE ( cidade.cd_cidade = fornecedor.cd_cidade ) and  
         ( ( fornecedor.cd_fornecedor = :cd_fornecedor ) )    
" update="fornecedor" updatewhere=0 updatekeyinplace=no arguments=(("cd_fornecedor", string)) )
