 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="cartao_comprovante_operacao.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="cartao_comprovante_operacao.de_serie" )
 column=(type=char(1) updatewhereclause=yes name=id_captura dbname="cartao_comprovante_operacao.id_captura" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_operacao dbname="cartao_comprovante_operacao.vl_operacao" )
 column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="cartao_comprovante_operacao.cd_caixa" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="cartao_comprovante_operacao.nr_controle_caixa" )
 column=(type=long updatewhereclause=yes name=nr_comprovante_caixa dbname="cartao_comprovante_operacao.nr_comprovante_caixa" )
 retrieve="select a.nr_comprovante nr_comprovante_deposito,
       b.nr_comprovante nr_comprovante_venda,
       b.cd_filial,
       b.nr_nf,
       b.de_especie,
       b.de_serie,
       b.id_captura,
       b.vl_operacao,
       b.cd_caixa,
       b.nr_controle_caixa,
       b.nr_comprovante_caixa
from cartao_comprovante_operacao a,
	  cartao_comprovante_operacao b
where a.cd_administradora  = 1
  and a.id_captura         = 'A'
  and b.cd_administradora  = a.cd_administradora
  and b.cd_estabelecimento = a.cd_estabelecimento
  and b.dh_operacao        = a.dh_operacao
  and b.id_tipo_operacao   = a.id_tipo_operacao
  and b.nr_autorizacao    <> a.nr_autorizacao
  and b.nr_parcela         = a.nr_parcela
  and b.vl_parcela         = a.vl_parcela
  and b.nr_nsu             = a.nr_nsu
  and b.id_captura         = 'T'
  and b.id_situacao        = 'A'
  and substring(b.nr_cartao, 1, 16) = substring(a.nr_cartao, 1, 16)
" )
