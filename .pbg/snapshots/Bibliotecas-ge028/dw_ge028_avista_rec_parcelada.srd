 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="cartao_comprovante_operacao.de_serie" )
 column=(type=char(1) updatewhereclause=yes name=id_captura dbname="cartao_comprovante_operacao.id_captura" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_operacao dbname="cartao_comprovante_operacao.vl_operacao" )
 column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="cartao_comprovante_operacao.cd_caixa" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="cartao_comprovante_operacao.nr_controle_caixa" )
 column=(type=long updatewhereclause=yes name=nr_comprovante_caixa dbname="cartao_comprovante_operacao.nr_comprovante_caixa" )
 column=(type=char(10) updatewhereclause=yes name=cd_estabelecimento dbname="cartao_comprovante_operacao.cd_estabelecimento" )
 column=(type=char(19) updatewhereclause=yes name=nr_cartao dbname="cartao_comprovante_operacao.nr_cartao" )
 retrieve="select a.nr_comprovante,
       a.cd_administradora,
       a.id_tipo_operacao,
       a.nr_autorizacao,
       a.dh_operacao,
       a.cd_filial,
       a.nr_nf,
       a.de_especie,
       a.de_serie,
       a.id_captura,
       a.vl_operacao,
       a.cd_caixa,
       a.nr_controle_caixa,
       a.nr_comprovante_caixa,
       a.cd_estabelecimento,
       a.nr_cartao
from cartao_comprovante_operacao a
where a.cd_administradora = 1
  and a.id_tipo_operacao  = 'VC'
  and a.id_situacao in ('A', 'T')
  and a.qt_parcelas       = 1
  and exists (select *
				  from cartao_comprovante_operacao b
				  where b.cd_administradora = a.cd_administradora
					 and b.id_tipo_operacao  = a.id_tipo_operacao
					 and b.nr_autorizacao    = a.nr_autorizacao
				    and (b.cd_estabelecimento = a.cd_estabelecimento or
						   b.dh_operacao        = a.dh_operacao or
						   substring(b.nr_cartao, 1, 16) = substring(a.nr_cartao, 1, 16))
                and b.qt_parcelas > 1
					 and b.id_captura = 'A')" update="cartao_comprovante_operacao" updatewhere=0 updatekeyinplace=no )
