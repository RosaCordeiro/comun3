table(column=(type=decimal(0) updatewhereclause=yes key=yes identity=yes name=nr_comprovante dbname="cartao_comprovante_operacao.nr_comprovante" )
 column=(type=long updatewhereclause=yes name=cd_administradora dbname="cartao_comprovante_operacao.cd_administradora" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_operacao dbname="cartao_comprovante_operacao.id_tipo_operacao" )
 column=(type=char(6) updatewhereclause=yes name=nr_autorizacao dbname="cartao_comprovante_operacao.nr_autorizacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_operacao dbname="cartao_comprovante_operacao.vl_operacao" )
 retrieve="select a.nr_comprovante,
       a.cd_administradora,
		 a.id_tipo_operacao,
		 a.nr_autorizacao,
		 a.vl_operacao
from cartao_comprovante_operacao a
where a.cd_administradora = 1
  and a.id_tipo_operacao  = 'VC'
  and a.id_captura        = 'A'
  and a.qt_parcelas       = 1
  and a.vl_parcela = (select sum(b.vl_parcela)
						    from cartao_comprovante_operacao b
						    where b.cd_administradora = a.cd_administradora
							   and b.id_tipo_operacao  = a.id_tipo_operacao
							   and b.nr_autorizacao    = a.nr_autorizacao
							   and b.vl_operacao       = a.vl_operacao
                        and b.qt_parcelas > 1
							   and b.id_situacao = 'A')" update="cartao_comprovante_operacao" updatewhere=0 updatekeyinplace=no )
