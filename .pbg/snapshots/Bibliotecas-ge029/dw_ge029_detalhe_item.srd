 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_bc_icms_st_retido dbname="item_nf_diversa.vl_bc_icms_st_retido" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_st_retido dbname="item_nf_diversa.pc_st_retido" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_icms_st_retido dbname="item_nf_diversa.vl_icms_st_retido" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao_fiscal dbname="id_alteracao_fiscal" )
 retrieve="  SELECT i.cd_filial_origem,	
			i.nr_nf,
			i.de_especie,
			i.de_serie,
			i.cd_item,
			i.de_item,   
			i.de_unidade_medida,   
			i.qt_item,   
			i.vl_preco_unitario,   
			i.pc_desconto,
			i.vl_total_desconto,
			i.pc_icms,
			i.vl_outras_despesas,
			i.cd_cest,
			i.cd_bem, 
			i.cd_situacao_tributaria,
			i.cd_cst_origem,
			i.cd_cst_tributacao,
			i.nr_classificacao_fiscal,
			i.vl_frete, 
			i.cd_beneficio,
			i.vl_bc_icms, 
			i.vl_icms,
			i.vl_bc_ipi,
			i.pc_ipi,
			i.vl_ipi,
			i.pc_mva,
			i.vl_bc_icms_st,
			i.pc_icms_st,
			i.vl_icms_st,
			i.vl_icms_retido,
			i.vl_bc_icms_st_retido,
			i.pc_st_retido,
			i.vl_icms_st_retido,
			Cast('N' as char(1)) as id_alteracao_fiscal
    FROM item_nf_diversa i 
   WHERE i.cd_filial_origem 	= :cd_filial_origem
	  	AND i.nr_nf 				= :nr_nf
        	AND i.de_especie 		= :de_especie
		AND i.de_serie 			= :de_serie
" update="item_nf_diversa" updatewhere=0 updatekeyinplace=yes arguments=(("cd_filial_origem", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
