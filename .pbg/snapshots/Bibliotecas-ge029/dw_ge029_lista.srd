table(column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="nf_diversa.cd_filial_origem" dbalias="n.cd_filial_origem" )
 column=(type=long update=yes updatewhereclause=yes name=nr_nf dbname="nf_diversa.nr_nf" dbalias="n.nr_nf" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_especie dbname="nf_diversa.de_especie" dbalias="n.de_especie" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_serie dbname="nf_diversa.de_serie" dbalias="n.de_serie" )
 column=(type=char(255) updatewhereclause=yes name=dh_emissao dbname="tochar" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_diversa.vl_total_nf" dbalias="n.vl_total_nf" )
 column=(type=char(255) updatewhereclause=yes name=dh_cancelamento dbname="tochar" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(15) updatewhereclause=yes name=nr_protocolo_cancelamento dbname="nf_diversa_nfe.nr_protocolo_cancelamento" dbalias="nfe.nr_protocolo_cancelamento" )
 column=(type=char(15) updatewhereclause=yes name=nr_protocolo_envio dbname="nf_diversa_nfe.nr_protocolo_envio" dbalias="nfe.nr_protocolo_envio" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_diversa_nfe.de_chave_acesso" dbalias="nfe.de_chave_acesso" )
 column=(type=char(255) updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 retrieve="SELECT	n.cd_filial_origem,
			n.nr_nf,   
			n.de_especie,   
			n.de_serie,   
			dbo.tochar( n.dh_emissao, 'dd/mm/yyyy hh:mi:ss' ),
			n.vl_total_nf, 
			dbo.tochar( n.dh_cancelamento, 'dd/mm/yyyy hh:mi:ss' ) ,
			f.nm_fantasia,
			nfe.nr_protocolo_cancelamento,
			nfe.nr_protocolo_envio,
			nfe.de_chave_acesso,
			dbo.tochar( n.dh_movimentacao_caixa, 'dd/mm/yyyy' ) as dh_movimentacao_caixa
    FROM nf_diversa AS n
			LEFT OUTER JOIN nf_diversa_nfe AS nfe
				ON nfe.cd_filial_origem	= n.cd_filial_origem
				AND nfe.nr_nf				= n.nr_nf
				AND nfe.de_especie		= n.de_especie
				AND nfe.de_serie			= n.de_serie
			INNER JOIN filial AS f
				ON n.cd_filial_origem = f.cd_filial" )
