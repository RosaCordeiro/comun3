table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_compra.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="nf_compra.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_compra.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_compra.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_compra.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_compra.dh_movimentacao_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_compra.dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms dbname="nf_compra.vl_bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="nf_compra.vl_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_st dbname="nf_compra.vl_bc_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="nf_compra.vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_produtos dbname="nf_compra.vl_total_produtos" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_ipi dbname="nf_compra.vl_ipi" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_frete dbname="nf_compra.vl_frete" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_seguro dbname="nf_compra.vl_seguro" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_outras_despesas dbname="nf_compra.vl_outras_despesas" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto dbname="nf_compra.vl_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_indenizacao dbname="nf_compra.vl_indenizacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_repassado dbname="nf_compra.vl_icms_repassado" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_compra.vl_total_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_repassado dbname="nf_compra.vl_icms_repassado" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="nf_compra.nr_pedido_distribuidora" )
 column=(type=long updatewhereclause=yes name=nr_pedido_central dbname="nf_compra.nr_pedido_central" )
 column=(type=char(31) updatewhereclause=yes name=id_bonificacao dbname="id_bonificacao" )
 column=(type=long updatewhereclause=yes name=cd_condicao_pagamento dbname="nf_compra.cd_condicao_pagamento" )
 column=(type=datetime updatewhereclause=yes name=dh_registro dbname="nf_compra.dh_registro" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_registro dbname="nf_compra.nr_matricula_registro" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_conferente dbname="nf_compra.nr_matricula_conferente" )
 column=(type=char(40) updatewhereclause=yes name=nm_registro dbname="usuario.nm_registro" )
 column=(type=char(40) updatewhereclause=yes name=nm_conferente dbname="usuario.nm_conferente" )
 column=(type=char(1) updatewhereclause=yes name=id_recebimento_divergente dbname="nf_compra.id_recebimento_divergente" values="Recebimento Divergente ?	S/Recebimento Divergente ?	N" )
 column=(type=char(40) updatewhereclause=yes name=de_condicao dbname="condicao_pagamento.de_condicao" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_compra.de_chave_acesso" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao_estoque dbname="nf_compra.dh_atualizacao_estoque" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_atualizacao_estoque dbname="nf_compra.nr_matric_atualizacao_estoque" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=char(20) updatewhereclause=yes name=cd_fornecedor_sap dbname="fornecedor.cd_fornecedor_sap" )
 retrieve="select n.cd_filial,
       i.nm_fantasia,
       n.cd_fornecedor,
       f.nm_razao_social,
       n.nr_nf,
       n.de_especie,
       n.de_serie,
       n.dh_movimentacao_caixa,
       n.dh_emissao,
       n.vl_bc_icms,
       n.vl_icms,
       n.vl_bc_icms_st,
       n.vl_icms_st,
       n.vl_total_produtos,
       n.vl_ipi,
       n.vl_frete,
       n.vl_seguro,
       n.vl_outras_despesas,
       n.vl_desconto,
       n.vl_indenizacao,
       n.vl_icms_repassado,
       n.vl_total_nf,
       n.vl_icms_repassado,
       n.nr_pedido_distribuidora,
       n.nr_pedido_central,
       case n.id_bonificacao
			when 'N' then 'N$$HEX1$$c300$$ENDHEX$$O (ENTRADA NORMAL)'
			when 'C' then 'SIM (COM ATUALIZA$$HEX2$$c700c300$$ENDHEX$$O DE CUSTOS)'
			when 'S' then 'SIM (SEM ATUALIZA$$HEX2$$c700c300$$ENDHEX$$O DE CUSTOS)'
		 end id_bonificacao,
       n.cd_condicao_pagamento,
       n.dh_registro,
       n.nr_matricula_registro,
		 n.nr_matricula_conferente,
       u.nm_usuario nm_registro,
		 x.nm_usuario nm_conferente,
       n.id_recebimento_divergente,
       c.de_condicao,
	   n.de_chave_acesso,
		n.dh_atualizacao_estoque,
		n.nr_matric_atualizacao_estoque,
		a.nm_usuario,
		f.cd_fornecedor_sap
from nf_compra n
	inner join fornecedor f
		on f.cd_fornecedor 	= n.cd_fornecedor
	inner join filial i
		on i.cd_filial    			= n.cd_filial
	left outer join usuario u
		on u.nr_matricula 		= n.nr_matricula_registro
	left outer join usuario x
		on x.nr_matricula 		= n.nr_matricula_conferente
	left outer join condicao_pagamento c
		on c.cd_condicao  		= n.cd_condicao_pagamento
	left outer join usuario a
		on a.nr_matricula  	= n.nr_matric_atualizacao_estoque
where n.cd_filial     		= :cd_filial
  and n.cd_fornecedor 	= :cd_fornecedor 
  and n.nr_nf         		= :nr_nf 
  and n.de_especie    		= :de_especie
  and n.de_serie      		= :de_serie 

union all 

select n.cd_filial,
       i.nm_fantasia,
       n.cd_fornecedor,
       f.nm_razao_social,
       n.nr_nf,
       n.de_especie,
       n.de_serie,
       n.dh_movimentacao_caixa,
       n.dh_emissao,
       n.vl_bc_icms,
       n.vl_icms,
       n.vl_bc_icms_st,
       n.vl_icms_st,
       n.vl_total_produtos,
       n.vl_ipi,
       n.vl_frete,
       n.vl_seguro,
       n.vl_outras_despesas,
       n.vl_desconto,
       n.vl_indenizacao,
       n.vl_icms_repassado,
       n.vl_total_nf,
       n.vl_icms_repassado,
       n.nr_pedido nr_pedido_distribuidora,
       null nr_pedido_central,
       case n.id_bonificacao
			when 'N' then 'N$$HEX1$$c300$$ENDHEX$$O (ENTRADA NORMAL)'
			when 'C' then 'SIM (COM ATUALIZA$$HEX2$$c700c300$$ENDHEX$$O DE CUSTOS)'
			when 'S' then 'SIM (SEM ATUALIZA$$HEX2$$c700c300$$ENDHEX$$O DE CUSTOS)'
		 end id_bonificacao,
       n.cd_condicao_pagamento,
       n.dh_registro,
       n.nr_matricula_registro,
		 n.nr_matricula_conferente,
       u.nm_usuario nm_registro,
		 x.nm_usuario nm_conferente,
       null id_recebimento_divergente,
       c.de_condicao,
	   n.de_chave_acesso,
		n.dh_atualizacao_estoque,
		n.nr_matric_atualizacao_estoque,
		a.nm_usuario,
		f.cd_fornecedor_sap
from nf_compra_pendente n
	inner join fornecedor f
		on f.cd_fornecedor 	= n.cd_fornecedor
	inner join filial i
		on i.cd_filial    			= n.cd_filial
	left outer join usuario u
		on u.nr_matricula 		= n.nr_matricula_registro
	left outer join usuario x
		on x.nr_matricula 		= n.nr_matricula_conferente
	left outer join condicao_pagamento c
		on c.cd_condicao  		= n.cd_condicao_pagamento
	left outer join usuario a
		on a.nr_matricula  	= n.nr_matric_atualizacao_estoque
where n.cd_filial     		= :cd_filial
  and n.cd_fornecedor 	= :cd_fornecedor 
  and n.nr_nf        			= :nr_nf 
  and n.de_especie    		= :de_especie
  and n.de_serie      		= :de_serie 
 " arguments=(("cd_filial", number),("cd_fornecedor", string),("nr_nf", number),("de_especie", string),("de_serie", string)) )
