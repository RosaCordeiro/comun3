table(column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_compra.cd_produto" )
 column=(type=char(1) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="item_nf_compra.qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="item_nf_compra.qt_recebida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_compra.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="item_nf_compra.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="item_nf_compra.pc_icms" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_ipi dbname="item_nf_compra.pc_ipi" initial="0" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="item_nf_compra.cd_natureza_operacao" )
 column=(type=char(2) updatewhereclause=yes name=cd_situacao_tributaria dbname="item_nf_compra.cd_situacao_tributaria" )
 column=(type=char(1) updatewhereclause=yes name=id_lista_pis_cofins dbname="item_nf_compra.id_lista_pis_cofins" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_repassado dbname="item_nf_compra.vl_icms_repassado" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_reducao_base_icms dbname="pc_reducao_base_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo dbname="vl_custo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_base_icms_st dbname="item_nf_compra.vl_preco_base_icms_st" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_ipi dbname="item_nf_compra.vl_ipi" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_entrada dbname="item_nf_compra.vl_custo_entrada" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_outras_despesas dbname="vl_outras_despesas" )
 column=(type=char(1) updatewhereclause=yes name=cd_produto_sap dbname="cd_produto_sap" )
 retrieve="select cd_produto,   
       '' de_produto, 
	   qt_faturada,
       qt_recebida,   
	   vl_preco_unitario,   
	   pc_desconto,   
	   pc_icms,   
	   pc_ipi,
       cd_natureza_operacao,   
       cd_situacao_tributaria,   
       id_lista_pis_cofins,   
       vl_icms_repassado,   
       isnull(pc_reducao_base_icms, 0) pc_reducao_base_icms,
       0.00 vl_custo,
	   case when vl_icms_st = 0 then
                    vl_icms_st_calculado
                else
                    vl_icms_st
        end as vl_icms_st ,
	   vl_preco_base_icms_st,
	   vl_ipi, 
    	   vl_custo_entrada,
	   0.0000 vl_outras_despesas,
		'' cd_produto_sap	
from item_nf_compra" )
