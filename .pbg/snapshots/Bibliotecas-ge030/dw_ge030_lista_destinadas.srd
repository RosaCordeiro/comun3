table(column=(type=char(44) update=yes updatewhereclause=yes key=yes name=de_chave_acesso dbname="nfe_destinadas.de_chave_acesso" )
 column=(type=char(100) update=yes updatewhereclause=yes name=nm_razao_social_origem dbname="nfe_destinadas.nm_razao_social_origem" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_emissao dbname="nfe_destinadas.dh_emissao" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_nf dbname="nfe_destinadas.vl_nf" )
 column=(type=char(1) update=yes updatewhereclause=yes key=yes name=id_situacao_nf dbname="nfe_destinadas.id_situacao_nf" )
 retrieve="select nd.de_chave_acesso, nd.nm_razao_social_origem, nd.dh_emissao, nd.vl_nf, nd.id_situacao_nf 
from dbo.nfe_destinadas nd 
where nr_cgc_destino in (select f.nr_cgc from filial f where cd_filial = :pl_cd_filial)
  and dh_emissao >= :pdh_ini
  and dh_emissao < :pdh_fim
  and nr_cgc_origem  in (select fo.nr_cgc from dbo.fornecedor fo where fo.cd_fornecedor = :ps_cd_fornecedor)
  and nd.vl_nf = :pdc_vl_nota
  and de_chave_acesso like :ps_nr_nota
  and coalesce(nd.id_situacao_nf,'')  = ''" update="nfe_destinadas" updatewhere=1 updatekeyinplace=no arguments=(("pl_Cd_filial", number),("ps_cd_fornecedor", string),("pdc_vl_nota", decimal),("pdh_ini", datetime),("pdh_fim", datetime),("ps_nr_nota", string)) )
