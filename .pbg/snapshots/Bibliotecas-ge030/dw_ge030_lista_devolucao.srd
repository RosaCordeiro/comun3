table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_devolucao_compra.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="nf_devolucao_compra.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=long updatewhereclause=yes name=nr_nf_compra dbname="nf_devolucao_compra.nr_nf_compra" )
 column=(type=char(3) updatewhereclause=yes name=de_especie_compra dbname="nf_devolucao_compra.de_especie_compra" )
 column=(type=char(3) updatewhereclause=yes name=de_serie_compra dbname="nf_devolucao_compra.de_serie_compra" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_devolucao_compra.dh_movimentacao_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_devolucao_compra.dh_emissao" )
 column=(type=long updatewhereclause=yes name=nr_nf_dev dbname="nf_devolucao_compra.nr_nf_dev" )
 column=(type=char(3) updatewhereclause=yes name=de_especie_dev dbname="nf_devolucao_compra.de_especie_dev" )
 column=(type=char(3) updatewhereclause=yes name=de_serie_dev dbname="nf_devolucao_compra.de_serie_dev" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa_dev dbname="nf_devolucao_compra.dh_movimentacao_caixa_dev" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo_devolucao dbname="motivo_devolucao_compra.de_motivo_devolucao" )
 retrieve="select dc.cd_filial,
       i.nm_fantasia,
       dc.cd_fornecedor,
       f.nm_razao_social,
       dc.nr_nf_compra,
       dc.de_especie_compra,
       dc.de_serie_compra,
       dc.dh_movimentacao_caixa,
       dc.dh_emissao,
		dc.nr_nf as nr_nf_dev,
		dc.de_especie as de_especie_dev,
		dc.de_serie as de_serie_dev,
		dc.dh_movimentacao_caixa as dh_movimentacao_caixa_dev,
		m.de_motivo_devolucao
from nf_devolucao_compra dc
	left outer join motivo_devolucao_compra m
		on m.cd_motivo_devolucao = dc.cd_motivo_devolucao
	inner join fornecedor f
		on f.cd_fornecedor = dc.cd_fornecedor
	inner join filial i
		on i.cd_filial = dc.cd_filial
where dc.cd_filial     				= :cd_filial
  and dc.cd_fornecedor 			= :cd_fornecedor
  and dc.nr_nf_compra         	= :nr_nf
  and dc.de_especie_compra	= :de_especie
  and dc.de_serie_compra		= :de_serie" arguments=(("cd_filial", number),("cd_fornecedor", string),("nr_nf", number),("de_especie", string),("de_serie", string)) )
