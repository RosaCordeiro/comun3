table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_compra.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="nf_compra.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_compra.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_compra.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_compra.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_compra.dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_compra.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_compra.vl_total_nf" )
 column=(type=long updatewhereclause=yes name=nr_pedido_central dbname="nf_compra.nr_pedido_central" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="nf_compra.nr_pedido_distribuidora" )
 column=(type=char(1) updatewhereclause=yes name=id_pendente dbname="id_pendente" )
 column=(type=long updatewhereclause=yes name=nr_nf_dev dbname="nr_nf_dev" )
 column=(type=long updatewhereclause=yes name=id_recebido dbname="id_recebido" )
 retrieve="select distinct n.cd_filial,
       i.nm_fantasia,
       n.cd_fornecedor,
	  f.nm_razao_social,
       n.nr_nf,
       n.de_especie,
       n.de_serie,
       n.dh_emissao,
       n.dh_movimentacao_caixa,
       n.vl_total_nf,
       n.nr_pedido_central,
       n.nr_pedido_distribuidora,
       'N' id_pendente,
	   count(dc.nr_nf) as nr_nf_dev,
	   count(receb.de_chave_acesso) as id_recebido	   
from nf_compra n
	inner join fornecedor f
		on f.cd_fornecedor = n.cd_fornecedor
	inner join filial i
		on i.cd_filial    		 = n.cd_filial
	inner   Join cidade As d
   	  On d.cd_cidade = i.cd_cidade
	left outer join nf_devolucao_compra dc
		on dc.cd_filial = n.cd_filial
		and dc.cd_fornecedor = n.cd_fornecedor
		and dc.nr_nf_compra = n.nr_nf
		and dc.de_serie_compra = n.de_serie
		and dc.de_especie_compra = n.de_especie
	left outer join nf_compra_recebimento receb
		on receb.de_chave_acesso = n.de_chave_acesso
where n.dh_movimentacao_caixa between :inicio and :termino
group by n.cd_filial,
			 i.nm_fantasia,
			 n.cd_fornecedor,
			 f.nm_razao_social,
			 n.nr_nf,
			 n.de_especie,
			 n.de_serie,
			 n.dh_emissao,
			 n.dh_movimentacao_caixa,
			 n.vl_total_nf,
			 n.nr_pedido_central,
			 n.nr_pedido_distribuidora

union all

select distinct n.cd_filial,
       i.nm_fantasia,
       n.cd_fornecedor,
	    f.nm_razao_social,
       n.nr_nf,
       n.de_especie,
       n.de_serie,
       n.dh_emissao ,
       n.dh_movimentacao_caixa,
       n.vl_total_nf,
       null nr_pedido_central,
       n.nr_pedido nr_pedido_distribuidora,
       'S' id_pendente,
	  count(dc.nr_nf) as nr_nf_dev,
	  count(receb.de_chave_acesso) as id_recebido
from nf_compra_pendente n
	inner join fornecedor f
		on f.cd_fornecedor = n.cd_fornecedor
	inner join filial i
		on i.cd_filial = n.cd_filial
	inner   Join cidade As d
   	  On d.cd_cidade = i.cd_cidade
	left outer join nf_devolucao_compra dc
		on dc.cd_filial = n.cd_filial
		and dc.cd_fornecedor = n.cd_fornecedor
		and dc.nr_nf_compra = n.nr_nf
		and dc.de_serie_compra = n.de_serie
		and dc.de_especie_compra = n.de_especie
	left outer join nf_compra_recebimento receb
		on receb.de_chave_acesso = n.de_chave_acesso
where cast(n.dh_registro as date) between :inicio and :termino
group by  n.cd_filial,
			 i.nm_fantasia,
			 n.cd_fornecedor,
			 f.nm_razao_social,
			 n.nr_nf,
			 n.de_especie,
			 n.de_serie,
			 n.dh_emissao,
			 n.dh_movimentacao_caixa,
			 n.vl_total_nf,
			 n.nr_pedido_central" arguments=(("inicio", date),("termino", date))  sort="cd_filial A dh_movimentacao_caixa A cd_fornecedor A nr_nf A " )
