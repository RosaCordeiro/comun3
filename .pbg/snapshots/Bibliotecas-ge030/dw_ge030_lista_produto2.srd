table(column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_compra.cd_produto" dbalias="i.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="item_nf_compra.qt_faturada" dbalias="i.qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="item_nf_compra.qt_recebida" dbalias="i.qt_recebida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_compra.vl_preco_unitario" dbalias="i.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="item_nf_compra.pc_desconto" dbalias="i.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="item_nf_compra.pc_icms" dbalias="i.pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_ipi dbname="item_nf_compra.pc_ipi" dbalias="i.pc_ipi" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="item_nf_compra.cd_natureza_operacao" dbalias="i.cd_natureza_operacao" )
 column=(type=char(2) updatewhereclause=yes name=cd_situacao_tributaria dbname="item_nf_compra.cd_situacao_tributaria" dbalias="i.cd_situacao_tributaria" )
 column=(type=char(1) updatewhereclause=yes name=id_lista_pis_cofins dbname="item_nf_compra.id_lista_pis_cofins" dbalias="i.id_lista_pis_cofins" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_repassado dbname="item_nf_compra.vl_icms_repassado" dbalias="i.vl_icms_repassado" )
 column=(type=char(1) updatewhereclause=yes name=id_reducao_base_icms dbname="item_nf_compra.id_reducao_base_icms" dbalias="i.id_reducao_base_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_reducao_base_icms dbname="item_nf_compra.pc_reducao_base_icms" dbalias="i.pc_reducao_base_icms" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_preco_liquido dbname="vl_preco_liquido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_entrada dbname="item_nf_compra.vl_custo_entrada" dbalias="i.vl_custo_entrada" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_icms_st dbname="vl_icms_st" )
 column=(type=char(1) updatewhereclause=yes name=id_icms_st_calculado dbname="id_icms_st_calculado" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_preco_base_icms_st dbname="vl_preco_base_icms_st" )
 column=(type=char(1) updatewhereclause=yes name=id_bc_icms_st_calculado dbname="id_bc_icms_st_calculado" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_ipi dbname="vl_ipi" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_outras_despesas dbname="vl_outras_despesas" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st_total dbname="vl_icms_st_total" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="g.cd_produto_sap" )
 retrieve="select i.cd_produto,   
       g.de_produto + ' : ' + g.de_apresentacao_estoque de_produto, 
	   i.qt_faturada,
       i.qt_recebida,   
	   i.vl_preco_unitario,   
	   i.pc_desconto,   
	   i.pc_icms,   
	   i.pc_ipi,
       i.cd_natureza_operacao,   
       i.cd_situacao_tributaria,   
       i.id_lista_pis_cofins,   
       i.vl_icms_repassado,   
       i.id_reducao_base_icms,   
       i.pc_reducao_base_icms,
       round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) vl_preco_liquido,
       i.vl_custo_entrada,
	  case when i.vl_icms_st = 0 then
                    round(isnull(i.vl_icms_st_calculado, 0) / i.qt_faturada, 2)
                else
                   round(i.vl_icms_st + coalesce(i.vl_st_fcp, 0.00), 2) 
        end as vl_icms_st ,
       case when i.vl_icms_st = 0 then
                   case when i.vl_icms_st_calculado is null then 'N' else 'S' end
                else
                    'N'
        end as id_icms_st_calculado ,
	   case when i.vl_preco_base_icms_st = 0 then
				round(isnull(i.vl_bc_icms_st_calculado, 0) / i.qt_faturada, 2)
			else
				i.vl_preco_base_icms_st	
        end as vl_preco_base_icms_st,
		case when i.vl_preco_base_icms_st = 0 then
				case when i.vl_bc_icms_st_calculado is null then 'N' else 'S' end
			else
				'N'
        end as id_bc_icms_st_calculado,
	   isnull(i.vl_ipi, 0) vl_ipi,
         Isnull(i.vl_outras_despesas, 0)  as vl_outras_despesas,
		coalesce(i.vl_icms_st_total, 0) as vl_icms_st_total,
		g.cd_produto_sap 
from item_nf_compra i,   
     produto_geral g
where i.cd_filial     = :cd_filial
  and i.cd_fornecedor = :cd_fornecedor
  and i.nr_nf         = :nr_nf
  and i.de_especie    = :de_especie
  and i.de_serie      = :de_serie
  and g.cd_produto = i.cd_produto

union all

select i.cd_produto, 
		 g.de_produto + ' : ' + g.de_apresentacao_estoque de_produto,
		 i.qt_faturada, 
       i.qt_recebida,
       i.vl_preco_unitario,
       i.pc_desconto,
       i.pc_icms,
       i.pc_ipi,
       i.cd_natureza_operacao,
       i.cd_situacao_tributaria,
       i.id_lista_pis_cofins,
       i.vl_icms_repassado,
       i.id_reducao_base_icms,
       i.pc_reducao_base_icms,
       round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) vl_preco_liquido,
	  0 vl_custo_entrada,	
       case when i.vl_icms_st = 0 then
                    round(isnull(i.vl_icms_st_calculado, 0) / i.qt_faturada, 2)
                else
                    round(i.vl_icms_st  + coalesce(i.vl_st_fcp, 0.00), 2) 
        end as vl_icms_st ,
       case when i.vl_icms_st = 0 then
                   case when i.vl_icms_st_calculado is null then 'N' else 'S' end
                else
                    'N'
        end as id_icms_st_calculado ,
	   case when i.vl_preco_base_icms_st = 0 then
				round(isnull(i.vl_bc_icms_st_calculado, 0) / i.qt_faturada, 2)
			else
				i.vl_preco_base_icms_st	
        end as vl_preco_base_icms_st,
		case when i.vl_preco_base_icms_st = 0 then
				case when i.vl_bc_icms_st_calculado is null then 'N' else 'S' end
			else
				'N'
        end as id_bc_icms_st_calculado,
	   isnull(i.vl_ipi, 0) vl_ipi,
	   Isnull(i.vl_outras_despesas, 0)  as vl_outras_despesas ,
		coalesce(i.vl_icms_st_total, 0) as vl_icms_st_total,
		g.cd_produto_sap  	        	                                      
from 	nf_compra_pendente_produto i,   
     	nf_compra_pendente n,
	  	produto_geral g 	
where n.cd_filial     = i.cd_filial
  and n.cd_fornecedor = i.cd_fornecedor
  and n.nr_nf         = i.nr_nf
  and n.de_especie    = i.de_especie
  and n.de_serie      = i.de_serie
  and g.cd_produto = i.cd_produto
  and  i.cd_filial     = :cd_filial
  and i.cd_fornecedor = :cd_fornecedor
  and i.nr_nf         = :nr_nf
  and i.de_especie    = :de_especie
  and i.de_serie      = :de_serie
" arguments=(("cd_filial", number),("cd_fornecedor", string),("nr_nf", number),("de_especie", string),("de_serie", string))  sort="de_produto A " )
