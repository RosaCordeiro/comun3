table(column=(type=char(3) updatewhereclause=yes key=yes name=cd_banco dbname="cheque.cd_banco" dbalias=".cd_banco" )
 column=(type=char(5) updatewhereclause=yes key=yes name=nr_agencia dbname="cheque.nr_agencia" dbalias=".nr_agencia" )
 column=(type=char(10) updatewhereclause=yes key=yes name=nr_conta dbname="cheque.nr_conta" dbalias=".nr_conta" )
 column=(type=char(10) updatewhereclause=yes key=yes name=nr_cheque dbname="cheque.nr_cheque" dbalias=".nr_cheque" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cheque dbname="cheque.vl_cheque" dbalias=".vl_cheque" )
 column=(type=char(255) updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=char(255) updatewhereclause=yes name=dh_vencimento dbname="dh_vencimento" )
 column=(type=char(255) updatewhereclause=yes name=dh_devolucao dbname="dh_devolucao" )
 column=(type=char(255) updatewhereclause=yes name=dh_baixa dbname="dh_baixa" )
 retrieve="  SELECT cd_banco,   
         nr_agencia,   
         nr_conta,   
         nr_cheque,   
         vl_cheque,              
		dbo.tochar( dh_emissao, 'yyyymmdd' ) as dh_emissao,
		dbo.tochar( dh_vencimento, 'yyyymmdd' ) as dh_vencimento,
		dbo.tochar( dh_devolucao, 'yyyymmdd' ) as dh_devolucao,
		dbo.tochar( dh_baixa, 'yyyymmdd' ) as dh_baixa
    FROM cheque
   WHERE  dh_devolucao is null 
     AND  dh_baixa is null 
  " update="cheque" updatewhere=0 updatekeyinplace=no  sort="dh_vencimento A " )
