 column=(type=char(40) update=yes updatewhereclause=yes name=de_endereco dbname="cliente_cheque.de_endereco" )
 column=(type=char(20) update=yes updatewhereclause=yes name=de_bairro dbname="cliente_cheque.de_bairro" )
