 column=(type=char(14) update=yes updatewhereclause=yes key=yes name=nr_cpf dbname="cliente_cheque.nr_cpf" )
 column=(type=char(14) update=yes updatewhereclause=yes name=nr_cpf_dependente dbname="cliente_cheque.nr_cpf_dependente" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_cliente dbname="cliente_cheque.nm_cliente" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_nascimento dbname="cliente_cheque.dh_nascimento" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_rg dbname="cliente_cheque.nr_rg" )
