 column=(type=char(100) update=yes updatewhereclause=yes name=de_endereco_email dbname="cliente_cheque.de_endereco_email" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial_inclusao dbname="cliente_cheque.cd_filial_inclusao" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial_atualizacao dbname="cliente_cheque.cd_filial_atualizacao" )
 column=(type=char(50) update=yes updatewhereclause=yes name=nm_pai dbname="cliente_cheque.nm_pai" )
 column=(type=char(50) update=yes updatewhereclause=yes name=nm_mae dbname="cliente_cheque.nm_mae" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_tipo_residencia dbname="cliente_cheque.id_tipo_residencia" initial="P" values="ALUGADA	A/PR$$HEX1$$d300$$ENDHEX$$PRIA	P/OUTRAS	O/" )
 column=(type=long update=yes updatewhereclause=yes name=qt_mes_residencia dbname="cliente_cheque.qt_mes_residencia" initial="0" )
 column=(type=char(50) update=yes updatewhereclause=yes name=nm_empresa dbname="cliente_cheque.nm_empresa" )
 column=(type=char(50) update=yes updatewhereclause=yes name=de_endereco_empresa dbname="cliente_cheque.de_endereco_empresa" )
 column=(type=char(30) update=yes updatewhereclause=yes name=de_bairro_empresa dbname="cliente_cheque.de_bairro_empresa" )
 column=(type=char(3) update=yes updatewhereclause=yes name=nr_ddd_empresa dbname="cliente_cheque.nr_ddd_empresa" )
 column=(type=char(10) update=yes updatewhereclause=yes name=nr_telefone_empresa dbname="cliente_cheque.nr_telefone_empresa" )
 column=(type=char(20) update=yes updatewhereclause=yes name=de_cargo dbname="cliente_cheque.de_cargo" )
 column=(type=long update=yes updatewhereclause=yes name=qt_mes_servico dbname="cliente_cheque.qt_mes_servico" initial="0" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_renda_mensal dbname="cliente_cheque.vl_renda_mensal" initial="0.00" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_bloqueado dbname="cliente_cheque.id_bloqueado" initial="N" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_bloqueio dbname="cliente_cheque.de_bloqueio" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_atualizacao dbname="cliente_cheque.dh_atualizacao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inclusao dbname="cliente_cheque.dh_inclusao" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_inclusao dbname="cliente_cheque.nr_matricula_inclusao" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_atualizacao dbname="cliente_cheque.nr_matricula_atualizacao" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_endereco dbname="cliente_cheque.nr_endereco" )
 column=(type=char(40) updatewhereclause=yes name=nm_dependente dbname="nm_dependente" )
 column=(type=char(60) updatewhereclause=yes name=localiza_endereco dbname="localiza_endereco" )
 retrieve="Select	e.nm_cidade,
		'N' id_habilita_alteracao,
		c.nr_cpf,
		c.nr_cpf_dependente,
		c.nm_cliente,
		c.dh_nascimento,
		c.nr_rg,
		c.cd_cidade,
		c.de_endereco,
		c.de_bairro,
		c.nr_cep,
		c.nr_ddd_telefone,
		c.nr_telefone,
		c.nr_celular,
		c.nr_ddd_celular,
		c.de_endereco_email,
		c.cd_filial_inclusao,
		c.cd_filial_atualizacao,
		c.nm_pai,
		c.nm_mae,
		c.id_tipo_residencia,
		c.qt_mes_residencia,
		c.nm_empresa,
		c.de_endereco_empresa,
		c.de_bairro_empresa,
		c.nr_ddd_empresa,
		c.nr_telefone_empresa,
		c.de_cargo,
		c.qt_mes_servico,
		c.vl_renda_mensal,
		c.id_bloqueado,
		c.de_bloqueio,
         c.dh_atualizacao,
		c.dh_inclusao,
		c.nr_matricula_inclusao,
		c.nr_matricula_atualizacao,
		c.nr_endereco,
		space(40) As nm_dependente,
 		space(60) as localiza_endereco
From cliente_cheque As c
	Inner Join cidade As e
		On e.cd_cidade = c.cd_cidade
Where c.nr_cpf = :nr_cpf" update="cliente_cheque" updatewhere=0 updatekeyinplace=no arguments=(("nr_cpf", string)) )
