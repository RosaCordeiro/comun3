table(column=(type=char(3) updatewhereclause=yes name=cd_banco dbname="cheque.cd_banco" )
 column=(type=char(5) updatewhereclause=yes name=nr_agencia dbname="cheque.nr_agencia" )
 column=(type=char(10) updatewhereclause=yes name=nr_conta dbname="cheque.nr_conta" )
 column=(type=char(10) updatewhereclause=yes name=nr_cheque dbname="cheque.nr_cheque" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cheque dbname="cheque.vl_cheque" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="cheque.dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_vencimento dbname="cheque.dh_vencimento" )
 column=(type=datetime updatewhereclause=yes name=dh_devolucao dbname="cheque.dh_devolucao" )
 column=(type=datetime updatewhereclause=yes name=dh_baixa dbname="cheque.dh_baixa" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" )
 retrieve="  SELECT cheque.cd_banco,   
         cheque.nr_agencia,   
         cheque.nr_conta,   
         cheque.nr_cheque,   
         cheque.vl_cheque,   
         cheque.dh_emissao,   
         cheque.dh_vencimento,   
         cheque.dh_devolucao,   
         cheque.dh_baixa,
         filial.nm_fantasia
    FROM cheque,
         filial
   WHERE ( cheque.nr_cpf_cliente = :ps_cpf )
     AND ( cheque.dh_devolucao is not null )
     AND ( cheque.dh_baixa is null )
     AND ( cheque.cd_filial_inclusao = filial.cd_filial )

UNION

  SELECT cheque.cd_banco,   
         cheque.nr_agencia,   
         cheque.nr_conta,   
         cheque.nr_cheque,   
         cheque.vl_cheque,   
         cheque.dh_emissao,   
         cheque.dh_vencimento,   
         cheque.dh_devolucao,   
         cheque.dh_baixa,
         filial.nm_fantasia
    FROM cheque,
         parametro,
			filial
   WHERE ( cheque.nr_cpf_cliente  = :ps_cpf ) 
     AND ( cheque.dh_vencimento  >= :dh_parametro )
     AND ( cheque.cd_filial_inclusao = filial.cd_filial )
     AND ( cheque.dh_devolucao is null )
       
" arguments=(("ps_cpf", string),("dh_parametro", date))  sort="dh_vencimento A " )
