 retrieve="  SELECT  nf_venda.cd_filial ,
          nf_venda.nr_nf , 
          nf_venda.de_especie ,  
          nf_venda.de_serie , 
          nf_venda.id_revenda , 
          nf_venda.id_tipo_venda , 
          nf_venda.nr_matric_operador , 
          nf_venda.dh_emissao , 
          nf_venda.dh_movimentacao_caixa , 
          nf_venda.vl_bc_icms , 
          nf_venda.vl_icms , 
          nf_venda.vl_bc_icms_st , 
          nf_venda.vl_icms_st , 
          nf_venda.vl_total_produtos , 
          nf_venda.vl_frete , 
          nf_venda.vl_outras_despesas , 
          nf_venda.pc_desconto , 
          nf_venda.vl_total_nf , 
          nf_venda.vl_pago_avista , 
          nf_venda.cd_condicao_crediario , 
          nf_venda.cd_condicao_convenio , 
          nf_venda.cd_cliente , 
          nf_venda.cd_clube_cliente , 
          nf_venda.cd_convenio , 
          nf_venda.cd_conveniado , 
          nf_venda.cd_dependente_cliente , 
          nf_venda.cd_dependente_conveniado , 
          nf_venda.nr_matric_alteracao_preco , 
          nf_venda.nr_matric_liberacao_bloqueio , 
          nf_venda.nr_matric_liberacao_restricao , 
          nf_venda.dh_cancelamento , 
          nf_venda.dh_devolucao , 
          nf_venda.id_cancelamento_impressora , 
          nf_venda.nr_ecf , 
          nf_venda.nr_operacao_ecf , 
          nf_venda.cd_caixa , 
          nf_venda.nr_nf_anexa , 
          nf_venda.de_especie_anexa , 
          nf_venda.de_serie_anexa , 
          nf_venda.nr_matricula_vendedor , 
          nf_venda.nr_matricula_cancelamento , 
          nf_venda.nr_controle_caixa ,
		 nf_venda.nr_nsu,
		 cidade.cd_unidade_federacao
        FROM nf_venda, filial, cidade      
        WHERE nf_venda.cd_filial 		= :cd_filial
		    and nf_venda.nr_nf 			= :nf_nf
			and nf_venda.de_especie 	= :de_especie
			and nf_venda.de_serie 		= :de_serie   
			and filial.cd_filial				= nf_venda.cd_filial
			and cidade.cd_cidade			= filial.cd_cidade" update="nf_venda" updatewhere=2 updatekeyinplace=no arguments=(("cd_filial", number),("nf_nf", number),("de_especie", string),("de_serie", string)) )
