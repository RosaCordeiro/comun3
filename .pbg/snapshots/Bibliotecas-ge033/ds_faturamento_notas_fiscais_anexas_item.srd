 column=(type=long update=yes updatewhereclause=yes name=qt_vendida dbname="item_nf_venda.qt_vendida" dbalias="i.qt_vendida" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_venda.vl_preco_unitario" dbalias="i.vl_preco_unitario" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto_tabela dbname="item_nf_venda.pc_desconto_tabela" dbalias="i.pc_desconto_tabela" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_praticado dbname="item_nf_venda.vl_preco_praticado" dbalias="i.vl_preco_praticado" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_icms dbname="item_nf_venda.pc_icms" dbalias="i.pc_icms" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_comissao_extra dbname="item_nf_venda.pc_comissao_extra" dbalias="i.pc_comissao_extra" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_comissao_normal dbname="item_nf_venda.pc_comissao_normal" dbalias="i.pc_comissao_normal" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_alteracao_preco dbname="item_nf_venda.id_alteracao_preco" dbalias="i.id_alteracao_preco" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_restricao_convenio dbname="item_nf_venda.id_restricao_convenio" dbalias="i.id_restricao_convenio" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_comissionado dbname="item_nf_venda.id_comissionado" dbalias="i.id_comissionado" )
 column=(type=char(1) update=yes updatewhereclause=yes name=cd_cst_origem dbname="item_nf_venda.cd_cst_origem" dbalias="i.cd_cst_origem" )
 column=(type=char(2) update=yes updatewhereclause=yes name=cd_cst_tributacao dbname="item_nf_venda.cd_cst_tributacao" dbalias="i.cd_cst_tributacao" )
 column=(type=char(10) update=yes updatewhereclause=yes name=cd_beneficio dbname="item_nf_venda.cd_beneficio" dbalias="i.cd_beneficio" )
 column=(type=long update=yes updatewhereclause=yes name=nr_item dbname="item_nf_venda.nr_item" dbalias="i.nr_item" )
 retrieve="  SELECT i.cd_filial,   
         i.nr_nf,   
         i.de_especie,   
         i.de_serie,
		i.nr_sequencial,   
         i.cd_produto,
         i.cd_natureza_operacao,   
         i.cd_situacao_tributaria,   
         i.qt_vendida,   
         i.vl_preco_unitario,   
         i.pc_desconto_tabela,   
         i.vl_preco_praticado,   
         i.pc_icms,   
         i.pc_comissao_extra,   
         i.pc_comissao_normal,   
         i.id_alteracao_preco,   
         i.id_restricao_convenio,   
         i.id_comissionado,   
         i.cd_cst_origem,   
         i.cd_cst_tributacao,
		i.cd_beneficio,
		i.nr_item  
    FROM item_nf_venda i 
   WHERE i.cd_filial 	= :pl_filial
	AND i.nr_nf 			= :nr_nf
	AND i.de_especie 	= :de_especie
	AND i.de_serie 		= :de_serie
" update="item_nf_venda" updatewhere=2 updatekeyinplace=no arguments=(("pl_filial", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
