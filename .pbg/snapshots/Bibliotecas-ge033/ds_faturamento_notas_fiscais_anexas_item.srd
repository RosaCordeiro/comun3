table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="item_nf_venda.cd_filial" dbalias="i.cd_filial" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_nf dbname="item_nf_venda.nr_nf" dbalias="i.nr_nf" )
