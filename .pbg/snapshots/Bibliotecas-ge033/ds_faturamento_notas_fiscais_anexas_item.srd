 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_sequencial dbname="item_nf_venda.nr_sequencial" dbalias="i.nr_sequencial" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="item_nf_venda.cd_produto" dbalias="i.cd_produto" )
