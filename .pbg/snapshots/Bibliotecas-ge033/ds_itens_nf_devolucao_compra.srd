 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_compra dbname="produto_geral.cd_unidade_medida_compra" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" )
 column=(type=decimal(2) updatewhereclause=yes name=item_vl_icms_repassado dbname="item_nf_devolucao_compra.vl_icms_repassado" )
 column=(type=char(1) updatewhereclause=yes name=id_lista_pis_cofins dbname="item_nf_devolucao_compra.id_lista_pis_cofins" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo_devolucao dbname="nf_devolucao_compra.de_motivo_devolucao" )
 column=(type=long updatewhereclause=yes name=nr_nsu dbname="nf_devolucao_compra.nr_nsu" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_devolucao_compra.dh_emissao" )
 retrieve="  SELECT item_nf_devolucao_compra.cd_filial,   
         item_nf_devolucao_compra.nr_nf,   
         item_nf_devolucao_compra.de_especie,   
         item_nf_devolucao_compra.de_serie,   
         item_nf_devolucao_compra.cd_natureza_operacao,   
         item_nf_devolucao_compra.cd_produto,   
         item_nf_devolucao_compra.cd_situacao_tributaria,   
         item_nf_devolucao_compra.qt_devolvida,   
         item_nf_devolucao_compra.vl_preco_unitario,   
         item_nf_devolucao_compra.pc_desconto,   
         item_nf_devolucao_compra.pc_icms,   
         item_nf_devolucao_compra.pc_ipi,   
         nf_devolucao_compra.cd_filial,   
         nf_devolucao_compra.nr_nf,   
         nf_devolucao_compra.de_especie,   
         nf_devolucao_compra.de_serie,   
         nf_devolucao_compra.dh_movimentacao_caixa,   
         nf_devolucao_compra.vl_bc_icms,   
         nf_devolucao_compra.vl_icms,   
         nf_devolucao_compra.vl_bc_icms_st,   
         nf_devolucao_compra.vl_icms_st,   
         nf_devolucao_compra.vl_icms_repassado,   
         nf_devolucao_compra.vl_total_produtos,   
         nf_devolucao_compra.vl_ipi,   
         nf_devolucao_compra.vl_frete,   
         nf_devolucao_compra.vl_seguro,   
         nf_devolucao_compra.vl_outras_despesas,   
         nf_devolucao_compra.vl_desconto,   
         nf_devolucao_compra.vl_indenizacao,   
         nf_devolucao_compra.vl_total_nf,   
         nf_devolucao_compra.cd_fornecedor,   
         nf_devolucao_compra.nr_nf_compra,   
         nf_devolucao_compra.de_especie_compra,   
         nf_devolucao_compra.de_serie_compra,   
         nf_devolucao_compra.nr_matricula_operador,   
         nf_devolucao_compra.dh_cancelamento,   
         nf_devolucao_compra.nr_matricula_cancelamento,   
         produto_geral.cd_produto,   
         produto_geral.de_produto,   
         produto_geral.de_apresentacao_estoque,   
         produto_geral.cd_unidade_medida_compra,   
         produto_geral.cd_grupo_psico,   
         item_nf_devolucao_compra.vl_icms_repassado,   
         item_nf_devolucao_compra.id_lista_pis_cofins,   
         nf_devolucao_compra.de_motivo_devolucao,   
         nf_devolucao_compra.nr_nsu,   
         nf_devolucao_compra.dh_emissao  
    FROM item_nf_devolucao_compra,   
         nf_devolucao_compra,   
         produto_geral  
   WHERE ( nf_devolucao_compra.cd_filial = item_nf_devolucao_compra.cd_filial ) and  
         ( nf_devolucao_compra.nr_nf = item_nf_devolucao_compra.nr_nf ) and  
         ( nf_devolucao_compra.de_especie = item_nf_devolucao_compra.de_especie ) and  
         ( nf_devolucao_compra.de_serie = item_nf_devolucao_compra.de_serie ) and  
         ( produto_geral.cd_produto = item_nf_devolucao_compra.cd_produto ) and  
         ( ( item_nf_devolucao_compra.cd_filial = :pl_cd_filial ) AND  
         ( item_nf_devolucao_compra.nr_nf = :pl_nr_nf ) AND  
         ( item_nf_devolucao_compra.de_especie = :ps_de_especie ) AND  
         ( item_nf_devolucao_compra.de_serie = :ps_de_serie ) )    
" arguments=(("pl_cd_filial", number),("pl_nr_nf", number),("ps_de_especie", string),("ps_de_serie", string))  sort="cd_filial A nr_nf A de_especie A de_serie A de_produto A de_apresentacao_estoque A " )
