compute(band=detail alignment="0" expression="TRIM( desc_produto ) + ~":~" + TRIM( de_apresentacao_venda ) +                                 IF ( IsNull(cd_grupo_psico) , '' , '(' + cd_grupo_psico + ')' )"border="0" color="0" x="8649" y="12" height="68" width="535" format="[general]"  name=de_produto  font.face="Arial" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
compute(band=detail alignment="0" expression="ROUND(( vl_preco_unitario - ( (  vl_preco_unitario *  pc_desconto ) / 100 ) ) *  qt_devolvida , 2)"border="0" color="0" x="9193" y="12" height="68" width="393" format="[general]"  name=c_valor_total  font.face="Arial" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
