 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms dbname="nf_devolucao_venda.vl_bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="nf_devolucao_venda.vl_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_st dbname="nf_devolucao_venda.vl_bc_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="nf_devolucao_venda.vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_produtos dbname="nf_devolucao_venda.vl_total_produtos" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_frete dbname="nf_devolucao_venda.vl_frete" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_outras_despesas dbname="nf_devolucao_venda.vl_outras_despesas" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_devolucao_venda.vl_total_nf" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="nf_devolucao_venda.cd_convenio" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="nf_devolucao_venda.cd_cliente" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_nf dbname="nf_devolucao_venda.pc_desconto" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_operador dbname="nf_devolucao_venda.nr_matricula_operador" )
 column=(type=long updatewhereclause=yes name=nr_nsu dbname="nf_devolucao_venda.nr_nsu" )
 retrieve="  SELECT item_nf_devolucao_venda.cd_produto,   
         produto_geral.de_produto,   
         produto_geral.de_apresentacao_venda,   
         produto_geral.cd_unidade_medida_venda,   
         produto_geral.cd_grupo_psico,
         item_nf_devolucao_venda.cd_situacao_tributaria,   
         item_nf_devolucao_venda.cd_natureza_operacao,   
         item_nf_devolucao_venda.qt_devolvida,   
         item_nf_devolucao_venda.vl_preco_unitario,   
         item_nf_devolucao_venda.pc_icms,   
         item_nf_devolucao_venda.pc_desconto,   
         nf_devolucao_venda.dh_movimentacao_caixa,   
         nf_devolucao_venda.dh_recebimento,
         nf_devolucao_venda.vl_bc_icms,   
         nf_devolucao_venda.vl_icms,   
         nf_devolucao_venda.vl_bc_icms_st,   
         nf_devolucao_venda.vl_icms_st,   
         nf_devolucao_venda.vl_total_produtos,   
         nf_devolucao_venda.vl_frete,   
         nf_devolucao_venda.vl_outras_despesas,   
         nf_devolucao_venda.vl_total_nf,   
         nf_devolucao_venda.cd_convenio,   
         nf_devolucao_venda.cd_cliente,   
         nf_devolucao_venda.pc_desconto,   
         nf_devolucao_venda.nr_matricula_operador,
			nf_devolucao_venda.nr_nsu
    FROM nf_devolucao_venda,   
         item_nf_devolucao_venda,   
         produto_geral
   WHERE ( item_nf_devolucao_venda.cd_filial 	= nf_devolucao_venda.cd_filial 		) and  
         ( item_nf_devolucao_venda.nr_nf 			= nf_devolucao_venda.nr_nf 			) and  
         ( item_nf_devolucao_venda.de_especie 	= nf_devolucao_venda.de_especie 		) and  
         ( item_nf_devolucao_venda.de_serie 		= nf_devolucao_venda.de_serie 		) and  
         ( item_nf_devolucao_venda.id_origem_nf = nf_devolucao_venda.id_origem_nf 	) and  
         ( produto_geral.cd_produto 				= item_nf_devolucao_venda.cd_produto ) and  
         ( ( nf_devolucao_venda.cd_filial 		= :a_filial 	) AND  
         ( nf_devolucao_venda.nr_nf 				= :a_nf 			) AND  
         ( nf_devolucao_venda.de_especie 			= :a_especie 	) AND  
         ( nf_devolucao_venda.de_serie 			= :a_serie 		) )    
" arguments=(("a_filial", number),("a_nf", number),("a_especie", string),("a_serie", string)) )
