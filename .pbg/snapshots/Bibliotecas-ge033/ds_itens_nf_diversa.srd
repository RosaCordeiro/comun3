table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial_origem dbname="item_nf_diversa.cd_filial_origem" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_nf dbname="item_nf_diversa.nr_nf" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=de_especie dbname="item_nf_diversa.de_especie" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=de_serie dbname="item_nf_diversa.de_serie" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_item dbname="item_nf_diversa.cd_item" )
 column=(type=char(60) update=yes updatewhereclause=yes name=de_item dbname="item_nf_diversa.de_item" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_unidade_medida dbname="item_nf_diversa.de_unidade_medida" )
 column=(type=long update=yes updatewhereclause=yes name=qt_item dbname="item_nf_diversa.qt_item" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_diversa.vl_preco_unitario" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto dbname="item_nf_diversa.pc_desconto" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_icms dbname="item_nf_diversa.pc_icms" )
 retrieve="  SELECT item_nf_diversa.cd_filial_origem,   
         item_nf_diversa.nr_nf,   
         item_nf_diversa.de_especie,   
         item_nf_diversa.de_serie,   
         item_nf_diversa.cd_item,   
         item_nf_diversa.de_item,   
         item_nf_diversa.de_unidade_medida,   
         item_nf_diversa.qt_item,   
         item_nf_diversa.vl_preco_unitario,   
         item_nf_diversa.pc_desconto,   
         item_nf_diversa.pc_icms
    FROM item_nf_diversa  
   WHERE item_nf_diversa.cd_filial_origem = :a_filial
     AND item_nf_diversa.nr_nf            = :a_nr_nf
     AND item_nf_diversa.de_especie       = :a_especie
     AND item_nf_diversa.de_serie         = :a_serie" update="item_nf_diversa" updatewhere=1 updatekeyinplace=no arguments=(("a_filial", number),("a_nr_nf", number),("a_especie", string),("a_serie", string)) )
