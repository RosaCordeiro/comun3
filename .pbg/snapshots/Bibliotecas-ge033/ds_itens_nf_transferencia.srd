 column=(type=char(6) updatewhereclause=yes name=nr_matricula_operador dbname="nf_transferencia.nr_matricula_operador" )
 column=(type=char(1) updatewhereclause=yes name=id_produto_vencido dbname="nf_transferencia.id_produto_vencido" )
 column=(type=long updatewhereclause=yes name=nr_nsu dbname="nf_transferencia.nr_nsu" )
 retrieve="  SELECT item_nf_transferencia.cd_filial_origem,   
         item_nf_transferencia.nr_nf,   
         item_nf_transferencia.de_especie,   
         item_nf_transferencia.de_serie,   
         item_nf_transferencia.cd_natureza_operacao,   
         item_nf_transferencia.cd_produto,   
         item_nf_transferencia.cd_situacao_tributaria,   
         item_nf_transferencia.qt_transferida,   
         item_nf_transferencia.vl_custo_unitario,   
         item_nf_transferencia.pc_icms,   
         produto_geral.de_produto,   
         produto_geral.de_apresentacao_venda,   
         produto_geral.cd_grupo_psico,   
         produto_geral.cd_unidade_medida_venda,   
         nf_transferencia.cd_filial_destino,   
         nf_transferencia.dh_movimentacao_caixa,   
         nf_transferencia.dh_emissao,
         nf_transferencia.vl_bc_icms,   
         nf_transferencia.vl_icms,   
         nf_transferencia.vl_bc_icms_st,   
         nf_transferencia.vl_icms_st,   
         nf_transferencia.vl_total_produtos,   
         nf_transferencia.vl_total_nf,   
         nf_transferencia.nr_matricula_operador,   
         nf_transferencia.id_produto_vencido,
			nf_transferencia.nr_nsu
    FROM item_nf_transferencia,   
         produto_geral,   
         nf_transferencia  
   WHERE ( produto_geral.cd_produto = item_nf_transferencia.cd_produto ) and  
         ( nf_transferencia.cd_filial_origem = item_nf_transferencia.cd_filial_origem ) and  
         ( nf_transferencia.nr_nf = item_nf_transferencia.nr_nf ) and  
         ( nf_transferencia.de_especie = item_nf_transferencia.de_especie ) and  
         ( nf_transferencia.de_serie = item_nf_transferencia.de_serie ) and  
         ( ( item_nf_transferencia.cd_filial_origem = :a_filial ) AND  
         ( item_nf_transferencia.nr_nf = :a_nf ) AND  
         ( item_nf_transferencia.de_especie = :a_especie ) AND  
         ( item_nf_transferencia.de_serie = :a_serie ) )    
" arguments=(("a_filial", number),("a_nf", number),("a_especie", string),("a_serie", string))  sort="cd_filial_origem A nr_nf A de_especie A de_serie A de_produto A " )
