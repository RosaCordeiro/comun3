table(column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_venda.cd_produto" dbalias="i.cd_produto" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_venda dbname="produto_geral.cd_unidade_medida_venda" dbalias="p.cd_unidade_medida_venda" )
 column=(type=char(2) updatewhereclause=yes name=cd_situacao_tributaria dbname="item_nf_venda.cd_situacao_tributaria" dbalias="i.cd_situacao_tributaria" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="item_nf_venda.cd_natureza_operacao" dbalias="i.cd_natureza_operacao" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="item_nf_venda.qt_vendida" dbalias="i.qt_vendida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_praticado dbname="item_nf_venda.vl_preco_praticado" dbalias="i.vl_preco_praticado" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_venda.vl_preco_unitario" dbalias="i.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_tabela dbname="item_nf_venda.pc_desconto_tabela" dbalias="i.pc_desconto_tabela" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao_preco dbname="item_nf_venda.id_alteracao_preco" dbalias="i.id_alteracao_preco" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="item_nf_venda.pc_icms" dbalias="i.pc_icms" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_venda.dh_emissao" dbalias="n.dh_emissao" )
 column=(type=date updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_venda.dh_movimentacao_caixa" dbalias="n.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms dbname="nf_venda.vl_bc_icms" dbalias="n.vl_bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="nf_venda.vl_icms" dbalias="n.vl_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_st dbname="nf_venda.vl_bc_icms_st" dbalias="n.vl_bc_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="nf_venda.vl_icms_st" dbalias="n.vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_produtos dbname="nf_venda.vl_total_produtos" dbalias="n.vl_total_produtos" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_frete dbname="nf_venda.vl_frete" dbalias="n.vl_frete" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_outras_despesas dbname="nf_venda.vl_outras_despesas" dbalias="n.vl_outras_despesas" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_venda.vl_total_nf" dbalias="n.vl_total_nf" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="nf_venda.cd_convenio" dbalias="n.cd_convenio" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="nf_venda.cd_cliente" dbalias="n.cd_cliente" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_operador dbname="nf_venda.nr_matric_operador" dbalias="n.nr_matric_operador" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_vendedor dbname="nf_venda.nr_matricula_vendedor" dbalias="n.nr_matricula_vendedor" )
 column=(type=char(60) updatewhereclause=yes name=desc_produto dbname="produto_geral.de_produto" dbalias="p.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="p.de_apresentacao_venda" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" dbalias="p.cd_grupo_psico" )
 column=(type=char(60) updatewhereclause=yes name=nm_cliente dbname="nf_venda_loja.nm_cliente" dbalias="v.nm_cliente" )
 column=(type=char(15) updatewhereclause=yes name=nr_cgc_cpf dbname="nf_venda_loja.nr_cgc_cpf" dbalias="v.nr_cgc_cpf" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="nf_venda_loja.nm_cidade" dbalias="v.nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=nm_uf dbname="nf_venda_loja.nm_uf" dbalias="v.nm_uf" )
 column=(type=char(60) updatewhereclause=yes name=de_endereco dbname="nf_venda_loja.de_endereco" dbalias="v.de_endereco" )
 column=(type=char(20) updatewhereclause=yes name=de_bairro dbname="nf_venda_loja.de_bairro" dbalias="v.de_bairro" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep dbname="nf_venda_loja.nr_cep" dbalias="v.nr_cep" )
 column=(type=char(15) updatewhereclause=yes name=nr_telefone dbname="nf_venda_loja.nr_telefone" dbalias="v.nr_telefone" )
 column=(type=char(15) updatewhereclause=yes name=nr_inscricao_estadual dbname="nf_venda_loja.nr_inscricao_estadual" dbalias="v.nr_inscricao_estadual" )
 column=(type=long updatewhereclause=yes name=nr_nsu dbname="nf_venda.nr_nsu" dbalias="n.nr_nsu" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pago_avista dbname="nf_venda.vl_pago_avista" dbalias="n.vl_pago_avista" )
 retrieve="Select	i.cd_produto,
		p.cd_unidade_medida_venda,
		i.cd_situacao_tributaria,
		i.cd_natureza_operacao,
		i.qt_vendida,
		i.vl_preco_praticado,
		i.vl_preco_unitario,
		i.pc_desconto_tabela,
		i.id_alteracao_preco,
		i.pc_icms,
		n.dh_emissao,
		n.dh_movimentacao_caixa,
		n.vl_bc_icms,
		n.vl_icms,
		n.vl_bc_icms_st,
		n.vl_icms_st,
		n.vl_total_produtos,
		n.vl_frete,
		n.vl_outras_despesas,
		n.vl_total_nf,
		n.cd_convenio,
		n.cd_cliente,
		n.nr_matric_operador,
		n.nr_matricula_vendedor,
		p.de_produto,
		p.de_apresentacao_venda,
		p.cd_grupo_psico,
		v.nm_cliente,
		v.nr_cgc_cpf,
		v.nm_cidade,
		v.nm_uf,
		v.de_endereco,
		v.de_bairro,
		v.nr_cep,
		v.nr_telefone,
		v.nr_inscricao_estadual,
		n.nr_nsu,
		n.vl_pago_avista
From	nf_venda As n
	Inner Join item_nf_venda As i
		On i.cd_filial			= n.cd_filial
	   And i.nr_nf			= n.nr_nf
	   And i.de_especie	= n.de_especie
	   And i.de_serie		= n.de_serie
	Left Outer Join nf_venda_loja As v
		On v.cd_filial		= n.cd_filial
	   And v.nr_nf			= n.nr_nf
	   And v.de_especie	= n.de_especie
	   And v.de_serie		= n.de_serie
	Inner Join produto_geral As p
		On p.cd_produto = i.cd_produto
Where i.cd_filial		= :a_filial
    And i.nr_nf			= :a_nf
    And i.de_especie	= :a_especie
    And i.de_serie		= :a_serie" arguments=(("a_filial", number),("a_nf", number),("a_especie", string),("a_serie", string)) )
