table(column=(type=long update=yes updatewhereclause=yes name=cd_dependente dbname="dependente_conveniado.cd_dependente" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_dependente dbname="dependente_conveniado.nm_dependente" )
 column=(type=char(20) update=yes updatewhereclause=yes name=de_relacao_dependencia dbname="dependente_conveniado.de_relacao_dependencia" )
 retrieve="Select dependente_conveniado.cd_dependente,   
		 dependente_conveniado.nm_dependente,   
		 dependente_conveniado.de_relacao_dependencia  
 From dependente_conveniado  
Where dependente_conveniado.cd_convenio   = :convenio
  and dependente_conveniado.cd_conveniado = :conveniado
  and not Exists ( Select b.cd_dependente
	 		            From bloqueio b,
                          motivo_bloqueio m
  				        Where b.cd_convenio   		= dependente_conveniado.cd_convenio
					       and b.cd_conveniado 		= dependente_conveniado.cd_conveniado
					       and b.cd_dependente 		= dependente_conveniado.cd_dependente 
 							 and m.cd_motivo_bloqueio 	= b.cd_motivo_bloqueio 
  							 and m.id_permite_visualizacao = 'N' 
                      and b.dh_liberacao is null )
" arguments=(("convenio", number),("conveniado", string))  sort="nm_dependente A " )
