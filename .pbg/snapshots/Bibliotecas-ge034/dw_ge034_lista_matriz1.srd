 retrieve="select cd_dependente,   
       nm_dependente,   
       de_relacao_dependencia  
from dependente_conveniado   
where cd_convenio   = :convenio
  and cd_conveniado = :conveniado
" arguments=(("convenio", number),("conveniado", string))  sort="nm_dependente A " )
