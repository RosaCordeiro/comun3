table(column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="nm_cliente" )
 column=(type=char(40) updatewhereclause=yes name=de_endereco dbname="cliente.de_endereco" dbalias="cl.de_endereco" )
 column=(type=char(6) updatewhereclause=yes name=nr_endereco dbname="cliente.nr_endereco" dbalias="cl.nr_endereco" )
 column=(type=char(20) updatewhereclause=yes name=de_bairro dbname="cliente.de_bairro" dbalias="cl.de_bairro" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep dbname="cliente.nr_cep" dbalias="cl.nr_cep" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" dbalias="c.nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" dbalias="c.cd_unidade_federacao" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="cliente.cd_cliente" dbalias="cl.cd_cliente" )
 column=(type=char(40) updatewhereclause=yes name=de_portador dbname="portador.de_portador" dbalias="p.de_portador" )
 retrieve="select (CASE WHEN cl.nm_social is not null THEN cl.nm_social ELSE cl.nm_cliente END) as nm_cliente,   
		 cl.de_endereco,   
       cl.nr_endereco,
		 cl.de_bairro,   
		 cl.nr_cep,   
		 c.nm_cidade,   
		 c.cd_unidade_federacao,   
		 cl.cd_cliente,
		 p.de_portador
from cliente cl,
     cidade c,
	  portador p
where cl.cd_cliente = :cliente
  and c.cd_cidade   = cl.cd_cidade
  and p.cd_portador = cl.cd_portador

" arguments=(("cliente", string)) )
