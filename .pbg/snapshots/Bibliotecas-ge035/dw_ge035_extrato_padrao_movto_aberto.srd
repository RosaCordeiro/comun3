table(column=(type=datetime updatewhereclause=yes name=dh_movimento dbname="contas_receber_movimento.dh_movimento" )
 column=(type=datetime updatewhereclause=yes name=dh_sistema dbname="contas_receber_movimento.dh_sistema" )
 column=(type=long updatewhereclause=yes name=cd_tipo_movimento dbname="contas_receber_movimento.cd_tipo_movimento" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_movimento dbname="contas_receber_tipo_movimento.de_tipo_movimento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_movimento dbname="contas_receber_movimento.vl_movimento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_movimento1 dbname="vl_movimento1" )
 column=(type=char(30) updatewhereclause=yes name=nr_documento dbname="contas_receber_movimento.nr_documento" )
 column=(type=char(40) updatewhereclause=yes name=de_historico dbname="contas_receber_movimento.de_historico" )
 column=(type=char(1) updatewhereclause=yes name=id_credito_debito dbname="contas_receber_tipo_movimento.id_credito_debito" )
 column=(type=char(1) updatewhereclause=yes name=id_atualizacao_saldo dbname="contas_receber_tipo_movimento.id_atualizacao_saldo" )
 column=(type=datetime updatewhereclause=yes name=dh_vencimento dbname="contas_receber_movimento.dh_vencimento" )
 retrieve="select m.dh_movimento, 
       m.dh_sistema,  
       m.cd_tipo_movimento,   
       t.de_tipo_movimento,   
      m.vl_movimento,
       case t.id_alteracao_venda_credito when 'S' then m.vl_movimento * -1 else m.vl_movimento end vl_movimento1,   
       m.nr_documento,   
       m.de_historico,   
       t.id_credito_debito,   
       t.id_atualizacao_saldo,
		 m.dh_vencimento
from contas_receber_movimento m,   
     contas_receber_tipo_movimento t 
where m.cd_conta      = :cliente
  and m.id_tipo_conta = 'CC'
  and m.nr_titulo_fechamento is null
  and t.cd_tipo_movimento = m.cd_tipo_movimento 
  and t.id_atualizacao_saldo in ('1', '3')" arguments=(("cliente", string))  sort="ano A mes A dh_movimento A " )
