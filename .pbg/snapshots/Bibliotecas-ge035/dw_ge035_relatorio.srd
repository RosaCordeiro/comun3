table(column=(type=char(40) updatewhereclause=yes name=cliente_nm_cliente dbname="cliente.nm_cliente" )
 column=(type=char(40) updatewhereclause=yes name=cliente_de_endereco dbname="cliente.de_endereco" )
 column=(type=char(20) updatewhereclause=yes name=cliente_de_bairro dbname="cliente.de_bairro" )
 column=(type=char(8) updatewhereclause=yes name=cliente_nr_cep dbname="cliente.nr_cep" )
 column=(type=char(40) updatewhereclause=yes name=cidade_nm_cidade dbname="cidade.nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=cidade_cd_unidade_federacao dbname="cidade.cd_unidade_federacao" )
 column=(type=char(11) updatewhereclause=yes name=cliente_cd_cliente dbname="cliente.cd_cliente" )
 column=(type=char(40) updatewhereclause=yes name=portador_de_portador dbname="portador.de_portador" )
 retrieve="  SELECT (CASE WHEN cl.nm_social is not null THEN cl.nm_social ELSE cl.nm_cliente END) as nm_cliente,   
         cl.de_endereco,   
         cl.de_bairro,   
         cl.nr_cep,   
         c.nm_cidade,   
         c.cd_unidade_federacao,   
         cl.cd_cliente,
		   p.de_portador
    FROM cliente cl,
         cidade c,
			portador p
   WHERE cl.cd_cliente = :ps_cliente
     AND c.cd_cidade   = cl.cd_cidade
	  AND p.cd_portador = cl.cd_portador

" arguments=(("ps_cliente", string),("pdt_Data_de", date),("pdt_Data_ate", date)) )
