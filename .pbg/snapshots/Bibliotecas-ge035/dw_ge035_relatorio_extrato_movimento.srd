table(column=(type=datetime updatewhereclause=yes name=dh_movimento dbname="contas_receber_movimento.dh_movimento" dbalias="m.dh_movimento" )
 column=(type=datetime updatewhereclause=yes name=dh_sistema dbname="contas_receber_movimento.dh_sistema" dbalias="m.dh_sistema" )
 column=(type=long updatewhereclause=yes name=cd_tipo_movimento dbname="contas_receber_movimento.cd_tipo_movimento" dbalias="m.cd_tipo_movimento" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_movimento dbname="contas_receber_tipo_movimento.de_tipo_movimento" dbalias="t.de_tipo_movimento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_movimento dbname="contas_receber_movimento.vl_movimento" dbalias="m.vl_movimento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_movimento1 dbname="vl_movimento1" )
 column=(type=char(30) updatewhereclause=yes name=nr_documento dbname="contas_receber_movimento.nr_documento" dbalias="m.nr_documento" )
 column=(type=char(40) updatewhereclause=yes name=de_historico dbname="contas_receber_movimento.de_historico" dbalias="m.de_historico" )
 column=(type=char(1) updatewhereclause=yes name=id_credito dbname="contas_receber_tipo_movimento.id_credito_debito" dbalias="t.id_credito_debito" )
 column=(type=char(1) updatewhereclause=yes name=id_atualizacao_saldo dbname="contas_receber_tipo_movimento.id_atualizacao_saldo" dbalias="t.id_atualizacao_saldo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_inicial_vendas dbname="vl_inicial_vendas" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_inicial_titulos dbname="vl_inicial_titulos" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_inicial_outros dbname="vl_inicial_outros" )
 retrieve="select m.dh_movimento, 
       m.dh_sistema,  
       m.cd_tipo_movimento,   
       t.de_tipo_movimento,   
      m.vl_movimento  ,
       case t.id_alteracao_venda_credito when 'S' then m.vl_movimento * -1 else m.vl_movimento end vl_movimento1,   
       m.nr_documento,   
       m.de_historico,   
       t.id_credito_debito,   
       t.id_atualizacao_saldo,
       cast(0.00 as decimal(9,2)) vl_inicial_vendas,
       cast(0.00 as decimal(9,2)) vl_inicial_titulos,
       cast(0.00 as decimal(9,2)) vl_inicial_outros           
from contas_receber_movimento m,   
     contas_receber_tipo_movimento t 
where m.cd_conta      = :ps_cliente
  and m.id_tipo_conta = 'CC'
  and m.dh_movimento between :dt_periodo_de and :dt_periodo_ate 
  and t.cd_tipo_movimento = m.cd_tipo_movimento " arguments=(("ps_cliente", string),("dt_periodo_de", date),("dt_periodo_ate", date))  sort="dh_movimento A dh_sistema A " )
