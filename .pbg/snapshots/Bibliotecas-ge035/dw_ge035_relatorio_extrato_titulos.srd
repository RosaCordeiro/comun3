HA$PBExportHeader$dw_ge035_relatorio_extrato_titulos.srd
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=276 color="536870912" )
summary(height=84 color="16777215" )
footer(height=4 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(13) update=yes updatewhereclause=yes name=nr_titulo dbname="titulo_receber.nr_titulo" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_emissao dbname="titulo_receber.dh_emissao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_vencimento dbname="titulo_receber.dh_vencimento" )
 column=(type=datetime updatewhereclause=yes name=dh_calculo_juros dbname="titulo_receber.dh_calculo_juros" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_baixa dbname="titulo_receber.dh_baixa" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_nominal dbname="titulo_receber.vl_nominal" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_aberto dbname="titulo_receber.vl_aberto" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_desconto_concedido dbname="titulo_receber.vl_desconto_concedido" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_despesas_recebidas dbname="titulo_receber.vl_despesas_recebidas" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="titulo_receber.id_situacao" values="ABERTO	A/PAGO	P/CANCELADO	C/ESTORNADO	E/" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_juros_diario dbname="vl_juros_diario" )
 column=(type=long updatewhereclause=yes name=nr_dias_atraso dbname="nr_dias_atraso" )
 retrieve="  SELECT tr.nr_titulo,   
         tr.dh_emissao,   
         tr.dh_vencimento,
         tr.dh_calculo_juros,
         tr.dh_baixa,   
         tr.vl_nominal,   
         tr.vl_aberto,   
         tr.vl_desconto_concedido,   
         tr.vl_despesas_recebidas,
         tr.id_situacao,
			round(round(p.pc_juros_diario * tr.vl_aberto,2)/100,2) vl_juros_diario,
			datediff(day,tr.dh_calculo_juros,getdate()) nr_dias_atraso
    FROM titulo_receber tr,
         parametro p
   WHERE tr.cd_cliente     = :ps_cliente
	  AND tr.dh_emissao    >= :pdt_Data_de
     AND tr.id_tipo_titulo = 'CC'
     AND p.id_parametro    = '1'

UNION

  SELECT tr.nr_titulo,   
         tr.dh_emissao,   
         tr.dh_vencimento,   
         tr.dh_calculo_juros,
         tr.dh_baixa,   
         tr.vl_nominal,   
         tr.vl_aberto,   
         tr.vl_desconto_concedido,   
         tr.vl_despesas_recebidas, 
         tr.id_situacao,
			round(round(p.pc_juros_diario * tr.vl_aberto,2)/100,2) vl_juros_diario,
			datediff(day,tr.dh_calculo_juros,getdate()) nr_dias_atraso
    FROM titulo_receber tr,
         parametro p 
   WHERE tr.cd_cliente     = :ps_cliente
     AND tr.id_situacao    = 'A'
     AND tr.id_tipo_titulo = 'CC'
	  AND p.id_parametro    = '1' 
" arguments=(("ps_cliente", string),("pdt_data_de", date))  sort="dh_emissao A nr_titulo A " )
