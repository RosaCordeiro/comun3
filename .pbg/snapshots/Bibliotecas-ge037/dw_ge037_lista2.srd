table(column=(type=long updatewhereclause=yes name=cd_filial_ajuste dbname="ajuste_estoque.cd_filial_ajuste" dbalias=".cd_filial_ajuste" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias=".nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_motivo_ajuste dbname="ajuste_estoque.cd_motivo_ajuste" dbalias=".cd_motivo_ajuste" )
 column=(type=char(1) updatewhereclause=yes name=id_entrada_saida dbname="ajuste_estoque.id_entrada_saida" dbalias=".id_entrada_saida" )
 column=(type=char(40) updatewhereclause=yes name=motivo_ajuste_de_motivo_ajuste dbname="motivo_ajuste.de_motivo_ajuste" dbalias=".de_motivo_ajuste" )
 column=(type=decimal(2) updatewhereclause=yes name=valor dbname="valor" )
 retrieve="Select ajuste_estoque.cd_filial_ajuste,   
         filial.nm_fantasia,   
         ajuste_estoque.cd_motivo_ajuste,   
         ajuste_estoque.id_entrada_saida,   
         motivo_ajuste.de_motivo_ajuste,
         sum(ajuste_estoque.vl_custo_unitario * ajuste_estoque.qt_ajuste) as valor  
From ajuste_estoque,   
         filial,   
         produto_geral,
         motivo_ajuste,
		fornecedor
Where filial.cd_filial                      = ajuste_estoque.cd_filial_ajuste 
     and produto_geral.cd_produto          = ajuste_estoque.cd_produto
     and motivo_ajuste.cd_motivo_ajuste = ajuste_estoque.cd_motivo_ajuste
     and fornecedor.cd_fornecedor = produto_geral.cd_fornecedor_usual
Group by ajuste_estoque.cd_filial_ajuste,
			filial.nm_fantasia,
			ajuste_estoque.cd_motivo_ajuste,   
			motivo_ajuste.de_motivo_ajuste,
			ajuste_estoque.id_entrada_saida   
"  sort="nm_fantasia A cd_filial_ajuste A motivo_ajuste_de_motivo_ajuste A " )
