table(column=(type=datetime updatewhereclause=yes name=dh_ajuste dbname="ajuste_estoque.dh_ajuste" )
 column=(type=long updatewhereclause=yes name=qt_ajuste dbname="ajuste_estoque.qt_ajuste" )
 column=(type=char(1) updatewhereclause=yes name=id_entrada_saida dbname="ajuste_estoque.id_entrada_saida" values="ENTRADA	E/SA$$HEX1$$cd00$$ENDHEX$$DA	S/" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo_ajuste dbname="motivo_ajuste.de_motivo_ajuste" )
 column=(type=long updatewhereclause=yes name=cd_filial_ajuste dbname="ajuste_estoque.cd_filial_ajuste" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="ajuste_estoque.cd_produto" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=char(40) updatewhereclause=yes name=de_comentario_ajuste dbname="ajuste_estoque.de_comentario_ajuste" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 retrieve="  SELECT ajuste_estoque.dh_ajuste,   
         ajuste_estoque.qt_ajuste,   
         ajuste_estoque.id_entrada_saida,   
         motivo_ajuste.de_motivo_ajuste,   
         ajuste_estoque.cd_filial_ajuste,   
         ajuste_estoque.cd_produto,   
         usuario.nm_usuario,   
         ajuste_estoque.de_comentario_ajuste,   
         produto_geral.de_produto,   
         produto_geral.de_apresentacao_venda,   
         filial.nm_fantasia  
    FROM ajuste_estoque,   
         motivo_ajuste,   
         usuario,   
         produto_geral,   
         filial  
   WHERE ( motivo_ajuste.cd_motivo_ajuste = ajuste_estoque.cd_motivo_ajuste ) and  
         ( usuario.nr_matricula = ajuste_estoque.nr_matricula_responsavel ) and  
         ( produto_geral.cd_produto = ajuste_estoque.cd_produto ) and  
         ( filial.cd_filial = ajuste_estoque.cd_filial_ajuste )    
"  sort="nm_usuario A cd_filial_ajuste A id_entrada_saida A de_motivo_ajuste A de_produto A " )
