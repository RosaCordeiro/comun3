table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="p.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="p.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="p.de_apresentacao_venda" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" dbalias="p.de_codigo_barras" )
 column=(type=char(3) updatewhereclause=yes name=cd_um dbname="produto_geral.cd_unidade_medida_venda" dbalias="p.cd_unidade_medida_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_atual dbname="produto_geral.vl_preco_venda_atual" dbalias="p.vl_preco_venda_atual" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="saldo_produto.qt_saldo_final" dbalias="s.qt_saldo_final" )
 column=(type=char(7) updatewhereclause=yes name=cd_cest dbname="produto_geral.cd_cest" dbalias="p.cd_cest" )
 column=(type=long updatewhereclause=yes name=nr_classificacao_fiscal dbname="produto_geral.nr_classificacao_fiscal" dbalias="p.nr_classificacao_fiscal" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_reposicao dbname="produto_geral.vl_preco_reposicao" dbalias="p.vl_preco_reposicao" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="p.vl_fator_conversao" )
 column=(type=decimal(0) updatewhereclause=yes name=qt_aquisicao dbname="qt_aquisicao" )
 retrieve="select p.cd_produto,   
       p.de_produto,   
       p.de_apresentacao_venda, 
       p.de_codigo_barras,  
       p.cd_unidade_medida_venda,
       p.vl_preco_venda_atual,
       s.qt_saldo_final,
	  p.cd_cest,
	  p.nr_classificacao_fiscal,
	  p.vl_preco_reposicao,
	  p.vl_fator_conversao,
	  (select sum(m.qt_movimento)  from movimento_estoque m
		inner join tipo_movimento_estoque te
			on te.cd_tipo_movimento = m.cd_tipo_movimento
			and te.id_tipo_movimento in ('C','T','A')
			and te.id_entrada_saida = 'E'
		where m.cd_produto = p.cd_produto
		and m.dh_movimento >= :pdt_saldo
		and m.dh_movimento <= :pdt_saldo_fim) as qt_aquisicao	 
from produto_geral p
	inner join produto_loja pl
		on pl.cd_produto = p.cd_produto
		and pl.id_situacao <> 'I'
    inner join saldo_produto s
		on s.cd_produto = p.cd_produto
		and s.dh_saldo = :pdt_saldo
order by p.de_produto Asc, p.de_apresentacao_venda Asc" arguments=(("pdt_saldo", date),("pdt_saldo_fim", date))  sort="de_produto A de_apresentacao_venda A " )
