 retrieve="  SELECT mapa_resumo.dh_emissao,
		mapa_resumo_ecf.cd_filial,   
         mapa_resumo_ecf.nr_mapa,   
         mapa_resumo_ecf.de_especie,   
         mapa_resumo_ecf.de_serie,   
         mapa_resumo_ecf.nr_ecf,   
         mapa_resumo_ecf.nr_operacao_inicial,   
         mapa_resumo_ecf.nr_operacao_final,   
         mapa_resumo_ecf.vl_total_geral_inicial,   
         mapa_resumo_ecf.vl_total_geral_final,   
         mapa_resumo_ecf.vl_cancelamento,   
         mapa_resumo_ecf.vl_desconto,   
         mapa_resumo_ecf.vl_contabil,   
         mapa_resumo_ecf.vl_isenta,   
         mapa_resumo_ecf.vl_nao_incidencia,   
         mapa_resumo_ecf.vl_st,   
         mapa_resumo_ecf.qt_reducao_z,   
         mapa_resumo_ecf.qt_cupom_cancelado,   
         mapa_resumo_ecf.qt_item_cancelado,   
         mapa_resumo_ecf.vl_cancelamento_item,
         mapa_resumo_ecf.dh_reducao,   
         mapa_resumo_ecf.qt_reinicio_z,   
         mapa_resumo_ecf.vl_st_iss,   
         mapa_resumo_ecf.vl_isento_iss,   
         mapa_resumo_ecf.vl_nao_incidencia_iss,   
         mapa_resumo_ecf.vl_operacao_nao_fiscal,   
         mapa_resumo_ecf.vl_desconto_iss,   
         mapa_resumo_ecf.vl_acrescimo,   
         mapa_resumo_ecf.vl_acrescimo_iss,   
         mapa_resumo_ecf.vl_cancelamento_iss
    FROM mapa_resumo
	INNER JOIN mapa_resumo_ecf ON
			mapa_resumo_ecf.cd_filial = mapa_resumo.cd_filial  and  
         	mapa_resumo_ecf.nr_mapa = mapa_resumo.nr_mapa  and  
         	mapa_resumo_ecf.de_especie = mapa_resumo.de_especie  and  
         	mapa_resumo_ecf.de_serie = mapa_resumo.de_serie
   WHERE mapa_resumo.cd_filial = :pl_filial AND
			 mapa_resumo.nr_mapa = :pl_mapa AND
			 mapa_resumo_ecf.nr_ecf = :pl_ecf AND
			 mapa_resumo.dh_emissao >= :pdh_inicial  AND  
         	 mapa_resumo.dh_emissao < dbo.adddate('day', 1, :pdh_final)
         	 
" arguments=(("pl_filial", number),("pl_mapa", number),("pl_ecf", number),("pdh_inicial", date),("pdh_final", date))  sort="qt_reducao_z A " )
