 retrieve="SELECT  nf_venda.cd_filial ,
           nf_venda.nr_nf ,
           nf_venda.de_especie ,
           nf_venda.de_serie ,
           nf_venda.id_revenda ,
           nf_venda.id_tipo_venda ,
           nf_venda.nr_matric_operador ,
           nf_venda.dh_emissao ,
           nf_venda.dh_movimentacao_caixa ,
           nf_venda.vl_bc_icms ,
           nf_venda.vl_icms ,
           nf_venda.vl_bc_icms_st ,
           nf_venda.vl_icms_st ,
           nf_venda.vl_total_produtos ,
           nf_venda.vl_frete ,
           nf_venda.vl_outras_despesas ,
           nf_venda.pc_desconto ,
           nf_venda.vl_total_nf ,
           nf_venda.vl_pago_avista ,
           nf_venda.nr_matricula_vendedor ,
           nf_venda.cd_condicao_crediario ,
           nf_venda.cd_condicao_convenio ,
           nf_venda.cd_cliente ,
           nf_venda.cd_clube_cliente ,
           nf_venda.cd_convenio ,
           nf_venda.cd_conveniado ,
           nf_venda.cd_dependente_cliente ,
           nf_venda.cd_dependente_conveniado ,
           nf_venda.nr_matric_alteracao_preco ,
           nf_venda.nr_matric_liberacao_bloqueio ,
           nf_venda.nr_matric_liberacao_restricao ,
           nf_venda.dh_cancelamento ,
           nf_venda.dh_devolucao ,
           nf_venda.nr_ecf ,
           nf_venda.nr_operacao_ecf ,
           nf_venda.nr_nf_anexa ,
           nf_venda.de_especie_anexa ,
           nf_venda.de_serie_anexa ,
           nf_venda.nr_matricula_cancelamento ,
           nf_venda.cd_caixa ,
           nf_venda.nr_controle_caixa ,
           nf_venda.dh_pagamento_conta ,
           nf_venda.cd_forma_pagamento ,
           nf_venda.nr_pedido_drogaexpress ,
           nf_venda.vl_total_nf_bruto ,
           nf_venda.id_cancelamento_impressora ,
           nf_venda.vl_taxa_entrega ,
           nf_venda.vl_total_nf_tabela ,
           nf_venda.nr_cartao_edm ,
           nf_venda.id_venda_clube ,
           nf_venda.cd_cliente_dependente ,
           nf_venda.nr_cartao_clube ,
           nf_venda.qt_pontos_clube ,
           nf_venda.nr_matric_liberacao_senha ,
           nf_venda.nr_nsu	,
		  nf_venda.dh_data_fiscal ,
		  coalesce(nf_venda.nr_ccf,0) as nr_ccf,
		  cliente.nm_cliente,
		  cliente.nr_cpf_cgc
        FROM nf_venda      
			left outer join cliente
				on cliente.cd_cliente = nf_venda.cd_cliente 
        WHERE ( nf_venda.dh_data_fiscal >= :pdh_inicial ) and          ( nf_venda.dh_data_fiscal < dbo.adddate('day', 1, :pdh_final) ) and          ( nf_venda.nr_ecf = :pl_ecf )   " arguments=(("pl_ecf", number),("pdh_inicial", date),("pdh_final", date))  sort="nr_ecf A nr_operacao_ecf A " )
