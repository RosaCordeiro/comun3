table(column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_venda.nr_nf" dbalias="nf.nr_nf" )
 column=(type=long updatewhereclause=yes name=nr_operacao_ecf dbname="nf_venda.nr_operacao_ecf" dbalias="nf.nr_operacao_ecf" )
 column=(type=long updatewhereclause=yes name=nr_ccf dbname="nf_venda.nr_ccf" dbalias="nf.nr_ccf" )
 column=(type=char(8190) updatewhereclause=yes name=cd_forma_pagamento dbname="cd_forma_pagamento" )
 column=(type=char(8190) updatewhereclause=yes name=id_documento dbname="id_documento" )
 column=(type=date updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_venda.dh_movimentacao_caixa" dbalias="nf.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pagamento dbname="nf_venda.vl_pagamento" dbalias=".vl_pagamento" )
 retrieve="  SELECT nf.nr_nf,
			nf.nr_operacao_ecf,
			nf.nr_ccf,
			Case nf.cd_forma_pagamento
				When 'DI' Then 'DINHEIRO       '
				When 'HA' Then 'CHEQUE         '
				When 'HP' Then 'CHEQUE-PRE     '
				When 'CA' Then 'CARTAO DEBITO  '
				When 'CP' Then 'CARTAO CREDITO '
				When 'CV' Then 'CONVENIO       '
				Else 'DINHEIRO       '
			End as cd_forma_pagamento,
		 	'CF' as id_documento,
		 	nf.dh_data_fiscal as dh_movimentacao_caixa,   
		 	vl_total_nf as vl_pagamento
	FROM 	nf_venda  nf
	WHERE nf.cd_forma_pagamento is not null
	  AND nf.cd_forma_pagamento <> 'MF'
	  AND nf.nr_ecf = :ecf
	  AND nf.dh_data_fiscal >= :Inicio
	  AND nf.dh_data_fiscal < dbo.adddate('day', 1, :Termino)

Union All

  SELECT nf.nr_nf,
			nf.nr_operacao_ecf,
			nf.nr_ccf,
			Case np.cd_forma_pagamento
				When 'DI' Then 'DINHEIRO       '
				When 'HA' Then 'CHEQUE         '
				When 'HP' Then 'CHEQUE-PRE     '
				When 'CA' Then 'CARTAO DEBITO  '
				When 'CP' Then 'CARTAO CREDITO '
				When 'CV' Then 'CONVENIO       '
				Else 'DINHEIRO       '
			End as cd_forma_pagamento,
		 	'CF' as id_documento,
		 	nf.dh_data_fiscal as dh_movimentacao_caixa,   
			vl_pagamento
	FROM 	nf_venda_pagamento np,
		 	nf_venda nf
	WHERE nf.nr_nf 		= np.nr_nf
	 AND 	nf.cd_filial 	= np.cd_filial
	 AND 	nf.de_especie	= np.de_especie
	 AND 	nf.de_serie	= np.de_serie
	 AND 	np.cd_forma_pagamento is not null
	 AND 	nf.cd_forma_pagamento = 'MF'
    AND	nf.nr_ecf = :ecf
	 AND 	nf.dh_data_fiscal >= :Inicio
	 AND 	nf.dh_data_fiscal < dbo.adddate('day', 1, :Termino)

Union All

  SELECT 0,
			d.nr_coo,
			d.nr_ccf,
			'DINHEIRO       ',
		 	'CN' as id_documento,
		 	d.dh_movimento,   
			d.vl_documento
	FROM 	documento_ecf d
	WHERE d.nr_ecf = :ecf
	 AND 	d.dh_movimento >= :Inicio
	 AND 	d.dh_movimento < dbo.adddate('day', 1, :Termino)
	 AND	d.id_documento = 'CN'
" arguments=(("ecf", number),("inicio", date),("termino", date))  sort="nr_operacao_ecf A cd_forma_pagamento A " )
