table(column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="filial.nr_cgc" dbalias="f.nr_cgc" )
 column=(type=char(15) updatewhereclause=yes name=nr_inscricao_estadual dbname="filial.nr_inscricao_estadual" dbalias="f.nr_inscricao_estadual" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="filial.nm_razao_social" dbalias="f.nm_razao_social" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" dbalias="c.nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" dbalias="c.cd_unidade_federacao" )
 column=(type=char(3) updatewhereclause=yes name=nr_ddd_fax dbname="filial.nr_ddd_fax" dbalias="f.nr_ddd_fax" )
 column=(type=char(8) updatewhereclause=yes name=nr_fax dbname="filial.nr_fax" dbalias="f.nr_fax" )
 column=(type=char(40) updatewhereclause=yes name=de_endereco dbname="filial.de_endereco" dbalias="f.de_endereco" )
 column=(type=char(20) updatewhereclause=yes name=de_bairro dbname="filial.de_bairro" dbalias="f.de_bairro" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep dbname="filial.nr_cep" dbalias="f.nr_cep" )
 column=(type=char(40) updatewhereclause=yes name=nm_contato dbname="filial.nm_contato" dbalias="f.nm_contato" )
 column=(type=char(3) updatewhereclause=yes name=nr_ddd_telefone dbname="filial.nr_ddd_telefone" dbalias="f.nr_ddd_telefone" )
 column=(type=char(8) updatewhereclause=yes name=nr_telefone dbname="filial.nr_telefone" dbalias="f.nr_telefone" initial=" " )
 column=(type=long updatewhereclause=yes name=nr_endereco dbname="filial.nr_endereco" dbalias="f.nr_endereco" )
 retrieve="Select		f.nr_cgc,
			f.nr_inscricao_estadual,
			f.nm_fantasia,
			f.nm_razao_social,
			c.nm_cidade,
			c.cd_unidade_federacao,
			f.nr_ddd_fax,
			f.nr_fax,
			f.de_endereco,
			f.de_bairro,
			f.nr_cep,
			f.nm_contato,
			f.nr_ddd_telefone,
			f.nr_telefone,
			f.nr_endereco as nr_endereco
  From	filial f
Inner Join cidade c
	On f.cd_cidade = c.cd_cidade
Where	f.cd_filial = :filial" arguments=(("filial", number)) )
