table(column=(type=long updatewhereclause=yes name=nr_coo dbname="documento_ecf.nr_coo" dbalias=".nr_coo" )
 column=(type=datetime updatewhereclause=yes name=dh_movimento dbname="documento_ecf.dh_movimento" dbalias=".dh_movimento" )
 column=(type=long updatewhereclause=yes name=nr_ecf dbname="documento_ecf.nr_ecf" dbalias=".nr_ecf" )
 column=(type=datetime updatewhereclause=yes name=dh_final dbname="documento_ecf.dh_final" dbalias=".dh_final" )
 column=(type=char(2) updatewhereclause=yes name=id_documento dbname="documento_ecf.id_documento" dbalias=".id_documento" )
 column=(type=long updatewhereclause=yes name=nr_gnf dbname="documento_ecf.nr_gnf" dbalias=".nr_gnf" )
 column=(type=long updatewhereclause=yes name=nr_grg dbname="documento_ecf.nr_grg" dbalias=".nr_grg" )
 column=(type=long updatewhereclause=yes name=nr_cdc dbname="documento_ecf.nr_cdc" dbalias=".nr_cdc" )
 column=(type=char(15) updatewhereclause=yes name=cd_forma_pagamento dbname="documento_ecf.cd_forma_pagamento" dbalias=".cd_forma_pagamento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_documento dbname="documento_ecf.vl_documento" dbalias=".vl_documento" )
 column=(type=long updatewhereclause=yes name=nr_ccf dbname="documento_ecf.nr_ccf" dbalias=".nr_ccf" )
 retrieve="  SELECT documento_ecf.nr_coo,   
         documento_ecf.dh_movimento,   
         documento_ecf.nr_ecf,   
         documento_ecf.dh_final,   
         documento_ecf.id_documento,   
         documento_ecf.nr_gnf,   
         documento_ecf.nr_grg,   
         documento_ecf.nr_cdc,
  			documento_ecf.cd_forma_pagamento,
			documento_ecf.vl_documento,
			documento_ecf.nr_ccf
    FROM documento_ecf, impressora_fiscal
where documento_ecf.dh_movimento >= :pdh_inicial
  and documento_ecf.dh_movimento < dbo.adddate('day', 1, :pdh_final)
  and documento_ecf.nr_ecf        = :pl_ecf
  and documento_ecf.nr_ecf        = impressora_fiscal.nr_ecf" arguments=(("pl_ecf", number),("pdh_inicial", date),("pdh_final", date)) )
