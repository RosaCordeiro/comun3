 column=(type=long update=yes updatewhereclause=yes name=cd_cidade dbname="fornecedor.cd_cidade" )
 retrieve="  SELECT fornecedor.cd_fornecedor,   
         fornecedor.nm_razao_social,   
         fornecedor.nr_cgc,   
         fornecedor.nr_cpf,   
         fornecedor.nr_inscricao_estadual,   
         fornecedor.de_bairro,   
         fornecedor.de_endereco,   
         fornecedor.cd_cidade  
    FROM fornecedor
   WHERE fornecedor.id_situacao = 'A'
	  AND fornecedor.id_distribuidora = 'S'
" update="fornecedor" updatewhere=1 updatekeyinplace=no )
