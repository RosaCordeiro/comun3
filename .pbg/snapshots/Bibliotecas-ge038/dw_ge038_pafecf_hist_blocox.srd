 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="historico_envio_arquivo_paf.id_situacao" dbalias=".id_situacao" values="ENTREGUE	E/PENDENTE	P/" )
 column=(type=datetime updatewhereclause=yes name=dh_geracao_arquivo dbname="historico_envio_arquivo_paf.dh_geracao_arquivo" dbalias=".dh_geracao_arquivo" )
 column=(type=char(1) updatewhereclause=yes name=id_enviado_matriz dbname="historico_envio_arquivo_paf.id_enviado_matriz" dbalias=".id_enviado_matriz" )
 retrieve="  SELECT nr_sequencial,   
         cd_filial,   
         cd_tipo,   
         qt_reducao_z,   
         nr_ecf,   
         nr_mapa_resumo,   
         dh_movimento,   
         nr_recibo,   
         id_situacao,
		dh_geracao_arquivo,
		id_enviado_matriz		  
    FROM historico_envio_arquivo_paf   
" update="historico_envio_arquivo_paf" updatewhere=1 updatekeyinplace=no )
