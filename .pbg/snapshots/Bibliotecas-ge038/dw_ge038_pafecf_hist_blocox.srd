table(column=(type=long update=yes updatewhereclause=yes key=yes name=nr_sequencial dbname="historico_envio_arquivo_paf.nr_sequencial" dbalias=".nr_sequencial" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="historico_envio_arquivo_paf.cd_filial" dbalias=".cd_filial" )
