table(column=(type=char(255) updatewhereclause=yes name=cd_forma_pagamento dbname="cd_forma_pagamento" )
 column=(type=char(8190) updatewhereclause=yes name=id_documento dbname="id_documento" )
 column=(type=date updatewhereclause=yes name=dh_movimentacao dbname="dh_movimentacao" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_total_venda dbname="vl_total_venda" )
 retrieve="Select 	cd_forma_pagamento, 
			id_documento,
			Cast( dh_emissao As Date ) as dh_movimentacao,
			sum(vl_total_venda) as vl_total_venda
FROM( SELECT nf.cd_forma_pagamento,
					 'CF' as id_documento,
					 Cast( nf.dh_data_fiscal as date ) as dh_emissao,   
					 vl_total_nf as vl_total_venda  
			FROM nf_venda  nf
			WHERE nf.cd_forma_pagamento is not null
			  AND nf.cd_forma_pagamento <> 'MF'
			  AND nf.de_especie = 'CF'
			
			Union All
			
			SELECT np.cd_forma_pagamento,
				 'CF' as id_documento,
				 Cast( nf.dh_data_fiscal as date ) as dh_emissao,   
				 np.vl_pagamento as vl_total_venda
			FROM nf_venda_pagamento np
			INNER JOIN nf_venda nf 
					ON nf.nr_nf 		= np.nr_nf
			 		AND nf.cd_filial 	= np.cd_filial
			 		AND nf.de_especie	= np.de_especie
			 		AND nf.de_serie	= np.de_serie
			WHERE np.cd_forma_pagamento is not null
				   AND nf.de_especie = 'CF'

			Union All

			SELECT nf.cd_forma_pagamento,
					 'NF' as id_documento,
					 Cast( nf.dh_data_fiscal as date ) as dh_emissao,   
					 vl_total_nf as vl_total_venda  
			FROM nf_venda  nf
			WHERE nf.cd_forma_pagamento is not null
			  AND nf.cd_forma_pagamento <> 'MF'
			  AND nf.nr_nf_manual > 0
			  AND nf.de_especie = 'NF'
			
			Union All

			SELECT nf.cd_forma_pagamento,
					 'NF' as id_documento,
					 Cast( nf.dh_emissao as date ) as dh_emissao,   
					 vl_total_nf as vl_total_venda  
			FROM nf_venda  nf
			WHERE nf.cd_forma_pagamento is not null
			  AND nf.cd_forma_pagamento <> 'MF'
			  AND nf.nr_nf_anexa is null
			  AND nf.de_especie = 'NFE'
			
			Union All
			
			SELECT dc.cd_forma_pagamento,
				 'CN' as id_documento,
				 Cast( dc.dh_movimento as date ) as dh_emissao,   
				 vl_documento as vl_total_venda  
			FROM documento_ecf  dc
			WHERE dc.cd_forma_pagamento is not null
			  AND dc.id_documento = 'CN'
			  AND dc.cd_forma_pagamento IN ('CARTAO CREDITO','CARTAO DEBITO','DINHEIRO','SUPRIMENTO','SANGRIA')
	
) AS selecao
GROUP BY cd_forma_pagamento, id_documento, dh_movimentacao"  sort="dh_movimentacao A id_documento A cd_forma_pagamento A " )
