table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_devolucao_venda.cd_filial" dbalias=".cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_devolucao_venda.nr_nf" dbalias=".nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_devolucao_venda.de_especie" dbalias=".de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_devolucao_venda.de_serie" dbalias=".de_serie" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_venda dbname="nf_devolucao_venda.id_tipo_venda" dbalias=".id_tipo_venda" )
 column=(type=char(1) updatewhereclause=yes name=id_origem_nf dbname="nf_devolucao_venda.id_origem_nf" dbalias=".id_origem_nf" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_operador dbname="nf_devolucao_venda.nr_matricula_operador" dbalias=".nr_matricula_operador" )
 column=(type=datetime updatewhereclause=yes name=dh_recebimento dbname="nf_devolucao_venda.dh_recebimento" dbalias=".dh_recebimento" )
 column=(type=date updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_devolucao_venda.dh_movimentacao_caixa" dbalias=".dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms dbname="nf_devolucao_venda.vl_bc_icms" dbalias=".vl_bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="nf_devolucao_venda.vl_icms" dbalias=".vl_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_st dbname="nf_devolucao_venda.vl_bc_icms_st" dbalias=".vl_bc_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="nf_devolucao_venda.vl_icms_st" dbalias=".vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_produtos dbname="nf_devolucao_venda.vl_total_produtos" dbalias=".vl_total_produtos" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_frete dbname="nf_devolucao_venda.vl_frete" dbalias=".vl_frete" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_outras_despesas dbname="nf_devolucao_venda.vl_outras_despesas" dbalias=".vl_outras_despesas" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="nf_devolucao_venda.pc_desconto" dbalias=".pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_devolucao_venda.vl_total_nf" dbalias=".vl_total_nf" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_vendedor dbname="nf_devolucao_venda.nr_matricula_vendedor" dbalias=".nr_matricula_vendedor" )
 column=(type=date updatewhereclause=yes name=dh_cancelamento dbname="nf_devolucao_venda.dh_cancelamento" dbalias=".dh_cancelamento" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_cancelamento dbname="nf_devolucao_venda.nr_matricula_cancelamento" dbalias=".nr_matricula_cancelamento" )
 column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="nf_devolucao_venda.cd_caixa" dbalias=".cd_caixa" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="nf_devolucao_venda.nr_controle_caixa" dbalias=".nr_controle_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf_bruto dbname="nf_devolucao_venda.vl_total_nf_bruto" dbalias=".vl_total_nf_bruto" )
 retrieve="SELECT  nf_devolucao_venda.cd_filial ,
           nf_devolucao_venda.nr_nf ,
           nf_devolucao_venda.de_especie ,
           nf_devolucao_venda.de_serie ,
           nf_devolucao_venda.id_tipo_venda ,
           nf_devolucao_venda.id_origem_nf ,
           nf_devolucao_venda.nr_matricula_operador ,
           nf_devolucao_venda.dh_recebimento ,
           nf_devolucao_venda.dh_movimentacao_caixa ,
           nf_devolucao_venda.vl_bc_icms ,
           nf_devolucao_venda.vl_icms ,
           nf_devolucao_venda.vl_bc_icms_st ,
           nf_devolucao_venda.vl_icms_st ,
           nf_devolucao_venda.vl_total_produtos ,
           nf_devolucao_venda.vl_frete ,
           nf_devolucao_venda.vl_outras_despesas ,
           nf_devolucao_venda.pc_desconto ,
           nf_devolucao_venda.vl_total_nf ,
           nf_devolucao_venda.nr_matricula_vendedor ,
           nf_devolucao_venda.dh_cancelamento ,
           nf_devolucao_venda.nr_matricula_cancelamento ,
           nf_devolucao_venda.cd_caixa ,
           nf_devolucao_venda.nr_controle_caixa,
           nf_devolucao_venda.vl_total_nf_bruto
        FROM nf_devolucao_venda
		Inner join nf_venda 
			on			nf_venda.cd_filial = nf_devolucao_venda.cd_filial_venda
			AND nf_venda.nr_nf = nf_devolucao_venda.nr_nf_venda
			and nf_venda.de_especie = nf_devolucao_venda.de_especie_venda
			and nf_venda.de_serie = nf_devolucao_venda.de_serie_venda
             and ( nf_venda.dh_emissao >= :pdh_inicial ) and ( nf_venda.dh_emissao < dbo.adddate('day', 1, :pdh_final) )    
		WHERE	nf_devolucao_venda.de_especie = 'NFE'


" arguments=(("pdh_inicial", date),("pdh_final", date))  sort="cd_filial A nr_nf A de_especie A de_serie A " )
