table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias=".cd_produto" )
 column=(type=char(255) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(3) updatewhereclause=yes name=cd_un dbname="produto_geral.cd_unidade_medida_venda" dbalias=".cd_unidade_medida_venda" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="vw_saldo_atual_produto.qt_saldo_final" dbalias=".qt_saldo_final" )
 column=(type=long updatewhereclause=yes name=nr_classificacao_fiscal dbname="produto_geral.nr_classificacao_fiscal" dbalias=".nr_classificacao_fiscal" )
 retrieve="  SELECT distinct produto_geral.cd_produto,   
         produto_geral.de_produto+':'+produto_geral.de_apresentacao_estoque as de_produto,   
         produto_geral.cd_unidade_medida_venda,   
         vw_saldo_atual_produto.qt_saldo_final,
			produto_geral.nr_classificacao_fiscal
    FROM produto_geral,   
         vw_saldo_atual_produto,
			item_nf_venda,
			nf_venda
   WHERE //produto_geral.id_situacao = 'A' and
			( produto_geral.cd_produto = vw_saldo_atual_produto.cd_produto ) and          
			( item_nf_venda.cd_produto = produto_geral.cd_produto) and
			( nf_venda.nr_nf = item_nf_venda.nr_nf) and
			( nf_venda.de_especie = item_nf_venda.de_especie) and
			( nf_venda.de_serie = item_nf_venda.de_serie) and
			( nf_venda.cd_filial = item_nf_venda.cd_filial)
"  sort="cd_produto A de_produto A " )
