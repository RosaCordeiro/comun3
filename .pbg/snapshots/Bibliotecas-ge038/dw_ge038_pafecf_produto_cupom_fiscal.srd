 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="item_nf_venda.pc_icms" dbalias=".pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_comissao_extra dbname="item_nf_venda.pc_comissao_extra" dbalias=".pc_comissao_extra" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_comissao_normal dbname="item_nf_venda.pc_comissao_normal" dbalias=".pc_comissao_normal" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao_preco dbname="item_nf_venda.id_alteracao_preco" dbalias=".id_alteracao_preco" )
 column=(type=char(1) updatewhereclause=yes name=id_restricao_convenio dbname="item_nf_venda.id_restricao_convenio" dbalias=".id_restricao_convenio" )
 column=(type=char(1) updatewhereclause=yes name=id_comissionado dbname="item_nf_venda.id_comissionado" dbalias=".id_comissionado" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_pontos_clube dbname="item_nf_venda.qt_pontos_clube" dbalias=".qt_pontos_clube" )
 column=(type=char(255) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(3) updatewhereclause=yes name=cd_un dbname="produto_geral.cd_unidade_medida_venda" dbalias=".cd_unidade_medida_venda" )
 column=(type=long updatewhereclause=yes name=nr_classificacao_fiscal dbname="produto_geral.nr_classificacao_fiscal" dbalias=".nr_classificacao_fiscal" )
 column=(type=long updatewhereclause=yes name=nr_operacao_ecf dbname="nf_venda.nr_operacao_ecf" dbalias=".nr_operacao_ecf" )
 column=(type=long updatewhereclause=yes name=nr_ccf dbname="nr_ccf" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_venda.dh_emissao" dbalias=".dh_emissao" )
 column=(type=long updatewhereclause=yes name=nr_ecf dbname="nf_venda.nr_ecf" dbalias=".nr_ecf" )
 column=(type=date updatewhereclause=yes name=dh_data_fiscal dbname="nf_venda.dh_data_fiscal" dbalias=".dh_data_fiscal" )
 retrieve="SELECT	item_nf_venda.cd_filial ,
			item_nf_venda.nr_nf ,
			item_nf_venda.de_especie ,
			item_nf_venda.de_serie,
			item_nf_venda.cd_natureza_operacao ,
			item_nf_venda.cd_produto ,
			item_nf_venda.cd_situacao_tributaria ,
			item_nf_venda.qt_vendida ,
			item_nf_venda.vl_preco_unitario ,
			item_nf_venda.pc_desconto_tabela ,
			item_nf_venda.vl_preco_praticado ,
			item_nf_venda.pc_icms ,
			item_nf_venda.pc_comissao_extra ,
			item_nf_venda.pc_comissao_normal ,
			item_nf_venda.id_alteracao_preco ,
			item_nf_venda.id_restricao_convenio ,
			item_nf_venda.id_comissionado ,
			item_nf_venda.qt_pontos_clube ,
			produto_geral.de_produto + ' : ' + produto_geral.de_apresentacao_venda as de_produto,
			produto_geral.cd_unidade_medida_venda ,
			produto_geral.nr_classificacao_fiscal ,
			nf_venda.nr_operacao_ecf,
			coalesce(nf_venda.nr_ccf,0) as nr_ccf,
			nf_venda.dh_emissao,
			nf_venda.nr_ecf,
			nf_venda.dh_data_fiscal
  FROM nf_venda ,
	  item_nf_venda ,
		  produto_geral     
  WHERE ( item_nf_venda.cd_filial = nf_venda.cd_filial ) 
	and  ( item_nf_venda.nr_nf = nf_venda.nr_nf ) 
	and  ( item_nf_venda.de_especie = nf_venda.de_especie ) 
	and  ( item_nf_venda.de_serie = nf_venda.de_serie ) 
	and  ( produto_geral.cd_produto = item_nf_venda.cd_produto ) 
	and  ( ( nf_venda.dh_data_fiscal >= :pdh_inicial ) 
	and  ( nf_venda.dh_data_fiscal < dbo.adddate('day', 1, :pdh_final) ) 
	and  ( nf_venda.nr_ecf = :pl_ecf ) )  " arguments=(("pl_ecf", number),("pdh_inicial", date),("pdh_final", date))  sort="nr_operacao_ecf A cd_natureza_operacao A " )
