datawindow(units=0 timer_interval=0 color=80269524 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=96 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=108 color="536870912" )
table(column=(type=char(2) updatewhereclause=yes name=cd_situacao_tributaria dbname="item_nf_venda.cd_situacao_tributaria" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="item_nf_venda.cd_natureza_operacao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="item_nf_venda.pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_praticado dbname="vl_preco_praticado" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms dbname="vl_bc_icms" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_icms dbname="vl_icms" )
 retrieve="SELECT	i.cd_situacao_tributaria ,
			i.cd_natureza_operacao ,
			i.pc_icms,
			Sum(i.vl_preco_unitario * i.qt_vendida) as vl_preco_unitario,
			Sum(i.vl_preco_praticado * i.qt_vendida) as vl_preco_praticado,
			Sum(i.vl_preco_praticado * i.qt_vendida) as vl_bc_icms,
			Sum(Round(Round(i.vl_preco_praticado * i.qt_vendida,2) * (pc_icms * 0.01),2)) as vl_icms
  FROM	item_nf_venda i
  WHERE i.cd_filial = :cd_filial
	and  i.nr_nf = :nr_nota
GROUP BY i.cd_situacao_tributaria ,
		 i.cd_natureza_operacao,
		 i.pc_icms
" arguments=(("nr_nota", number),("cd_filial", number)) )
