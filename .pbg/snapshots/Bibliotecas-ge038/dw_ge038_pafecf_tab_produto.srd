         produto_geral.de_produto+':'+produto_geral.de_apresentacao_estoque as de_produto,   
         produto_geral.cd_unidade_medida_venda,
			produto_geral.nr_classificacao_fiscal
    FROM produto_geral
   WHERE produto_geral.id_situacao = 'A' "  sort="cd_produto A de_produto A " )
