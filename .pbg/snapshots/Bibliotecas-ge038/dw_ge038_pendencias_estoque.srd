table(column=(type=long updatewhereclause=yes name=nr_sequencial dbname="historico_envio_arquivo_paf.nr_sequencial" dbalias=".nr_sequencial" )
 column=(type=char(3) updatewhereclause=yes name=cd_tipo dbname="historico_envio_arquivo_paf.cd_tipo" dbalias=".cd_tipo" )
 column=(type=long updatewhereclause=yes name=mes dbname="mes" )
 column=(type=long updatewhereclause=yes name=ano dbname="ano" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="historico_envio_arquivo_paf.id_situacao" dbalias=".id_situacao" )
 column=(type=char(40) updatewhereclause=yes name=nr_recibo dbname="historico_envio_arquivo_paf.nr_recibo" dbalias=".nr_recibo" )
 retrieve="  SELECT nr_sequencial,   
             	cd_tipo,   
         	month(dh_movimento) as mes,
			year(dh_movimento) as ano,
         	id_situacao,   
         	nr_recibo  
    FROM historico_envio_arquivo_paf
	WHERE cd_tipo = 'EST' 
	AND id_situacao in ('P','A','E')" )
