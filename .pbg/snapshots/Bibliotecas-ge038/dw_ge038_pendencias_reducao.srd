table(column=(type=long updatewhereclause=yes name=nr_sequencial dbname="historico_envio_arquivo_paf.nr_sequencial" )
 column=(type=char(3) updatewhereclause=yes name=cd_tipo dbname="historico_envio_arquivo_paf.cd_tipo" )
 column=(type=long updatewhereclause=yes name=nr_ecf dbname="historico_envio_arquivo_paf.nr_ecf" )
 column=(type=long updatewhereclause=yes name=qt_reducao_z dbname="historico_envio_arquivo_paf.qt_reducao_z" )
 column=(type=long updatewhereclause=yes name=nr_mapa_resumo dbname="historico_envio_arquivo_paf.nr_mapa_resumo" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="historico_envio_arquivo_paf.id_situacao" )
 column=(type=char(40) updatewhereclause=yes name=nr_recibo dbname="historico_envio_arquivo_paf.nr_recibo" )
 column=(type=date updatewhereclause=yes name=dh_movimento dbname="historico_envio_arquivo_paf.dh_movimento" )
 column=(type=datetime updatewhereclause=yes name=dh_consulta_processo dbname="historico_envio_arquivo_paf.dh_consulta_processo" )
 column=(type=char(100) updatewhereclause=yes name=de_descricao_processamento dbname="historico_envio_arquivo_paf.de_descricao_processamento" )
 column=(type=char(200) updatewhereclause=yes name=de_mensagem_retorno dbname="historico_envio_arquivo_paf.de_mensagem_retorno" )
 retrieve="  SELECT nr_sequencial,   
             	cd_tipo,   
         	nr_ecf,   
         	qt_reducao_z,   
         	nr_mapa_resumo,   
         	id_situacao,   
         	nr_recibo,
			dh_movimento,
			dh_consulta_processo,
			de_descricao_processamento,
			de_mensagem_retorno
    FROM historico_envio_arquivo_paf
	WHERE cd_tipo = 'RZ'
	AND id_situacao in ('P','A','E')
"  sort="nr_sequencial A " )
