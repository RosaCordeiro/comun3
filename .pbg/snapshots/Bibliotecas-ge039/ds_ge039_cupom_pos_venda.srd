table(column=(type=long updatewhereclause=yes name=nr_campanha dbname="campanha.nr_campanha" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="campanha_produto.cd_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="campanha_produto.pc_desconto" )
 column=(type=date updatewhereclause=yes name=dh_inicio dbname="campanha.dh_inicio" )
 column=(type=date updatewhereclause=yes name=dh_termino dbname="campanha.dh_termino" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_filial dbname="filial.id_rede_filial" )
 column=(type=char(255) updatewhereclause=yes name=nm_rede_filial dbname="nm_rede_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="filial.nm_razao_social" )
 column=(type=char(40) updatewhereclause=yes name=de_endereco dbname="filial.de_endereco" )
 column=(type=char(8190) updatewhereclause=no name=localidade dbname="localidade" )
 column=(type=char(8190) updatewhereclause=no name=de_produto_ecf dbname="de_produto_ecf" )
 column=(type=char(8190) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(20) updatewhereclause=yes name=nr_vale_desconto dbname="nr_vale_desconto" )
 column=(type=char(20) updatewhereclause=yes name=de_vale_desconto dbname="de_vale_desconto" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" )
 column=(type=char(200) updatewhereclause=yes name=de_mensagem_cupom_desconto dbname="campanha.de_mensagem_cupom_desconto" )
 column=(type=long updatewhereclause=yes name=qt_maxima_venda dbname="qt_maxima_venda" )
 column=(type=char(300) updatewhereclause=no name=de_ref_utilizacao dbname="de_ref_utilizacao" )
 retrieve="select  c.nr_campanha,
		p.cd_produto, 
		p.pc_desconto, 
		c.dh_inicio,
		c.dh_termino,
		f.id_rede_filial, 
		( CASE f.id_rede_filial
			WHEN 'DC' then 'DROGARIA CATARINENSE'
			WHEN 'FA' then 'FARMAGORA'
			WHEN 'MP' then 'MANIPULA$$HEX2$$c700c300$$ENDHEX$$O'
			WHEN 'PP' then 'FARM$$HEX1$$c100$$ENDHEX$$CIA PRE$$HEX1$$c700$$ENDHEX$$O POPULAR'
			WHEN	 'PF' then 'PROF$$HEX1$$d300$$ENDHEX$$RMULA'
			ELSE f.id_rede_filial
		END ) as nm_rede_filial,
		f.nm_razao_social, 
		f.de_endereco, 
		f.de_bairro || ' - ' || d.nm_cidade || ' - ' || d.cd_unidade_federacao AS localidade,
		(case when c.de_mensagem_cupom_desconto is not null and TRIM(c.de_mensagem_cupom_desconto) <> '' THEN c.de_mensagem_cupom_desconto ELSE '(Cod.' || Cast(p.cd_produto as Varchar) || ') ' || g.de_produto || ' : ' || g.de_apresentacao_venda end) as de_produto_ecf,
		(case when c.de_mensagem_cupom_desconto is not null and TRIM(c.de_mensagem_cupom_desconto) <> '' THEN c.de_mensagem_cupom_desconto ELSE g.de_produto || ' : ' || g.de_apresentacao_venda || ' (cod.' || Cast(p.cd_produto as Varchar) || ')' end) as de_produto,
		Cast('' as varchar(20) ) as nr_vale_desconto,
		Cast('' as varchar(20) ) as de_vale_desconto,
		d.cd_unidade_federacao,
		c.de_mensagem_cupom_desconto,
		COALESCE(p.qt_maxima_venda,0) AS qt_maxima_venda,
		Cast('' as Varchar(300)) as de_ref_utilizacao
   from campanha c
		inner join campanha_cliente cc
		  on cc.nr_campanha = c.nr_campanha
		inner join campanha_produto p
		  on p.nr_campanha = c.nr_campanha
		inner join vw_saldo_atual_produto v
			on v.cd_produto = p.cd_produto
		inner join produto_geral g
			on g.cd_produto = p.cd_produto
		inner join filial f
			on f.cd_filial = dbo.uf_filial_parametro()
		inner join cidade d
			ON d.cd_cidade = f.cd_cidade
	where c.id_tipo_campanha = 'CD'
	 and cc.cd_cliente = :cliente
	 and not exists (select * from vale_desconto v where v.nr_campanha = c.nr_campanha and v.cd_cliente_entrega = :cliente)
LIMIT 1
     
" arguments=(("cliente", string)) )
