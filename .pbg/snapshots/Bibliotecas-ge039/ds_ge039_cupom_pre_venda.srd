table(column=(type=long updatewhereclause=yes name=cd_produto dbname="filial.cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap_generico dbname="filial.cd_produto_sap_generico" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="filial.pc_desconto" )
 column=(type=decimal(0) updatewhereclause=yes name=id_rank dbname="filial.id_rank" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_filial dbname="filial.id_rede_filial" )
 column=(type=char(255) updatewhereclause=yes name=nm_rede_filial dbname="nm_rede_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="filial.nm_razao_social" )
 column=(type=char(8190) updatewhereclause=yes name=de_endereco dbname="de_endereco" )
 column=(type=char(8190) updatewhereclause=no name=localidade dbname="localidade" )
 column=(type=char(255) updatewhereclause=yes name=de_produto dbname="filial.de_produto" )
 column=(type=char(255) updatewhereclause=yes name=de_produto_ecf dbname="filial.de_produto_ecf" )
 column=(type=date updatewhereclause=yes name=dh_inicio dbname="filial.dh_inicio" )
 column=(type=date updatewhereclause=yes name=dh_termino dbname="filial.dh_termino" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_final dbname="vl_preco_final" )
 column=(type=datetime updatewhereclause=yes name=dh_parametro dbname="dh_parametro" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="nm_cliente" )
 retrieve="select	x.cd_produto,
	x.cd_produto_sap_generico, 
	 x.pc_desconto,
	x.id_rank, 
	f.id_rede_filial,
	( CASE f.id_rede_filial
							WHEN 'DC' then 'DROGARIA CATARINENSE'
							WHEN 'FA' then 'FARMAGORA'
							WHEN 'MP' then 'MANIPULA$$HEX2$$c700c300$$ENDHEX$$O'
							WHEN 'PP' then 'FARM$$HEX1$$c100$$ENDHEX$$CIA PRE$$HEX1$$c700$$ENDHEX$$O POPULAR'
							WHEN	 'PF' then 'PROF$$HEX1$$d300$$ENDHEX$$RMULA'
							ELSE f.id_rede_filial
						END ) as nm_rede_filial,
	f.nm_razao_social, 
	f.de_endereco || ', ' || f.nr_endereco as de_endereco, 
	f.de_bairro || ' - ' || c.nm_cidade || ' - ' || c.cd_unidade_federacao AS localidade,
	x.de_produto,
	x.de_produto_ecf,
	x.dh_inicio,
	x.dh_termino,
	Cast( 0.00 as numeric(12,2) ) as vl_preco_final,
	dbo.uf_dh_parametro() as dh_parametro,
	(CASE WHEN cli.nm_social is not null AND TRIM(cli.nm_social) <> '' THEN cli.nm_social ELSE cli.nm_cliente END) as nm_cliente
 from (  
	
	select  (CASE WHEN c.de_mensagem_cupom_desconto IS NULL THEN p.cd_produto ELSE 0 END) as cd_produto, (CASE WHEN c.de_mensagem_cupom_desconto IS NULL THEN g.de_produto || ' : ' || g.de_apresentacao_venda || ' (cod. ' || Cast(p.cd_produto as Varchar) || ')' ELSE c.de_mensagem_cupom_desconto END) as de_produto, 
			 (CASE WHEN c.de_mensagem_cupom_desconto IS NULL THEN '(Cod. ' || Cast(p.cd_produto as Varchar) || ') ' || g.de_produto || ' : ' || g.de_apresentacao_venda ELSE c.de_mensagem_cupom_desconto END) as de_produto_ecf, 
			 g.cd_produto_sap_generico, p.pc_desconto, c.dh_inicio, c.dh_termino, rank() OVER ( ORDER BY  FLOOR (Random() * 94 +1 ) ) as id_rank 
		from campanha c
			inner join campanha_cliente cc
			  on cc.nr_campanha = c.nr_campanha
			inner join campanha_produto p
			  on p.nr_campanha = c.nr_campanha
			inner join vw_saldo_atual_produto v
			  on v.cd_produto = p.cd_produto
			Inner join produto_geral g
			  on g.cd_produto = p.cd_produto
			Left Outer join ( select COALESCE(SUM(vp.qt_saldo), 0) as qt_saldo_pendente, vp.cd_produto from vw_saldo_produto_pendente vp
				Where vp.tipo_movimento in ('TRANSF. FILIAL', 'RESERVA CLIENTE', 'RESERVA VEND. MACHINE', 'PEDIDO ECOMMERCE')
				Group by vp.cd_produto) As pendente
				On pendente.cd_produto = p.cd_produto
			where c.id_tipo_campanha = 'CP'
			  and v.qt_saldo_final - COALESCE(pendente.qt_saldo_pendente,0) > 0
			 and cc.cd_cliente =:cliente
			 and (c.dh_inicio <= dbo.uf_dh_parametro() and c.dh_termino >= dbo.uf_dh_parametro()) 
			 group by (CASE WHEN c.de_mensagem_cupom_desconto IS NULL THEN p.cd_produto ELSE 0 END), (CASE WHEN c.de_mensagem_cupom_desconto IS NULL THEN g.de_produto || ' : ' || g.de_apresentacao_venda || ' (cod. ' || Cast(p.cd_produto as Varchar) || ')' ELSE c.de_mensagem_cupom_desconto END), 
			 (CASE WHEN c.de_mensagem_cupom_desconto IS NULL THEN '(Cod. ' || Cast(p.cd_produto as Varchar) || ') ' || g.de_produto || ' : ' || g.de_apresentacao_venda ELSE c.de_mensagem_cupom_desconto END), 
			  g.cd_produto_sap_generico, p.pc_desconto, c.dh_inicio, c.dh_termino

) as x
	inner join filial f
	   on f.cd_filial = dbo.uf_filial_parametro()
	inner join cidade c
		ON c.cd_cidade = f.cd_cidade
	inner join cliente cli
		ON cli.cd_cliente = :cliente
LIMIT 15
" arguments=(("cliente", string)) )
