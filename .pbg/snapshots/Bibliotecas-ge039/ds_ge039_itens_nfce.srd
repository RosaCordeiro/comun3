 column=(type=decimal(4) updatewhereclause=yes name=pc_red_bc_icms_efetivo dbname="item_nf_venda.pc_red_bc_icms_efetivo" dbalias=".pc_red_bc_icms_efetivo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_efetivo dbname="item_nf_venda.vl_bc_icms_efetivo" dbalias=".vl_bc_icms_efetivo" )
