 column=(type=long updatewhereclause=yes key=yes name=nr_sequencial dbname="item_nf_venda.nr_sequencial" dbalias=".nr_sequencial" )
 column=(type=char(10) updatewhereclause=yes name=cd_beneficio dbname="item_nf_venda.cd_beneficio" dbalias=".cd_beneficio" )
 column=(type=long updatewhereclause=yes name=nr_item dbname="nr_item" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_pis dbname="item_nf_venda.cd_cst_pis" dbalias=".cd_cst_pis" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_cofins dbname="item_nf_venda.cd_cst_cofins" dbalias=".cd_cst_cofins" )
 retrieve="  SELECT cd_filial,   
         nr_nf,   
         de_especie,   
         de_serie,   
         cd_natureza_operacao,   
         cd_produto,   
         cd_situacao_tributaria,   
         qt_vendida,   
         vl_preco_unitario,   
         pc_desconto_tabela,   
         vl_preco_praticado,   
         pc_icms,   
         pc_comissao_extra,   
         pc_comissao_normal,   
         id_alteracao_preco,   
         id_restricao_convenio,   
         id_comissionado,   
         qt_pontos_clube,   
         id_cancelado,   
         cd_cst_origem,   
         cd_cst_tributacao,   
         cd_promocao_sos,
		pc_red_bc_icms_efetivo,
		vl_bc_icms_efetivo,
		pc_icms_efetivo,
		vl_icms_efetivo,
		nr_sequencial,
		cd_beneficio,
		COALESCE(nr_item, nr_sequencial) AS nr_item,
		cd_cst_pis,
		cd_cst_cofins
    FROM item_nf_venda
	WHERE cd_filial = :pl_filial
		AND nr_nf = :pl_nf
		AND de_especie = :ps_especie
		AND de_serie = :ps_serie   
" update="item_nf_venda" updatewhere=0 updatekeyinplace=no arguments=(("pl_filial", number),("pl_nf", number),("ps_especie", string),("ps_serie", string))  sort="nr_item A " )
