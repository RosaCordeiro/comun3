table(column=(type=long updatewhereclause=yes name=cd_filial dbname="mapa_resumo_ecf.cd_filial" dbalias="me.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_mapa dbname="mapa_resumo_ecf.nr_mapa" dbalias="me.nr_mapa" )
 column=(type=long updatewhereclause=yes name=nr_ecf dbname="mapa_resumo_ecf.nr_ecf" dbalias="me.nr_ecf" )
 column=(type=date updatewhereclause=yes name=dh_emissao dbname="mapa_resumo.dh_emissao" dbalias="mr.dh_emissao" )
 column=(type=long updatewhereclause=yes name=qt_reducao_z dbname="mapa_resumo_ecf.qt_reducao_z" dbalias="me.qt_reducao_z" )
 retrieve="select me.cd_filial, 
		me.nr_mapa, 
		me.nr_ecf, 
		mr.dh_emissao, 
		me.qt_reducao_z
from mapa_resumo_ecf me
inner join mapa_resumo mr
	on mr.cd_filial = me.cd_filial
	and mr.nr_mapa = me.nr_mapa
	and dh_emissao >= :pdt_inicio
where not exists (select h.nr_sequencial from historico_envio_arquivo_paf h 
			where h.cd_filial = me.cd_filial
			  and h.nr_mapa_resumo = me.nr_mapa
			  and h.nr_ecf = me.nr_ecf)
and me.cd_filial = :pl_filial
and me.nr_mapa >= :pl_mapa 
and me.nr_ecf = :pl_ecf
and me.nr_mapa <> :pl_mapa_atual
" arguments=(("pdt_inicio", date),("pl_filial", number),("pl_mapa", number),("pl_ecf", number),("pl_mapa_atual", number)) )
