table(column=(type=long updatewhereclause=yes name=nr_nf dbname="item_nf_venda.nr_nf" dbalias="itv.nr_nf" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_venda.cd_produto" dbalias="itv.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="item_nf_venda.qt_vendida" dbalias="itv.qt_vendida" )
 column=(type=decimal(2) updatewhereclause=yes name=preco_unitario dbname="item_nf_venda.vl_preco_unitario" dbalias="itv.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_tabela dbname="item_nf_venda.pc_desconto_tabela" dbalias="itv.pc_desconto_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_praticado dbname="item_nf_venda.vl_preco_praticado" dbalias="itv.vl_preco_praticado" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_nf dbname="nf_venda.pc_desconto_nf" dbalias="nf.pc_desconto_nf" )
 retrieve="select itv.nr_nf, 
		itv.cd_produto, 
		itv.qt_vendida, 
		itv.vl_preco_unitario,
		itv.pc_desconto_tabela, 
		itv.vl_preco_praticado, 
		nf.pc_desconto as pc_desconto_nf
from item_nf_venda itv
	join nf_venda nf on nf.cd_filial = itv.cd_filial
			and nf.nr_nf = itv.nr_nf
			and nf.de_especie = itv.de_especie
			and nf.de_serie = itv.de_serie
	join produto_geral p on p.cd_produto = itv.cd_produto
			and substring(p.cd_subcategoria,1,1) <> '1'
where itv.id_cancelado is null and itv.cd_filial = :cd_filial and itv.nr_nf = :nr_nf and itv.cd_produto <> 684431" arguments=(("cd_filial", number),("nr_nf", number)) )
