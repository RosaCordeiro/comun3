release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=long update=yes updatewhereclause=yes key=yes name=nr_coo dbname="documento_ecf.nr_coo" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=dh_movimento dbname="documento_ecf.dh_movimento" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_ecf dbname="documento_ecf.nr_ecf" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_final dbname="documento_ecf.dh_final" )
 column=(type=char(2) update=yes updatewhereclause=yes name=id_documento dbname="documento_ecf.id_documento" )
 column=(type=long update=yes updatewhereclause=yes name=nr_gnf dbname="documento_ecf.nr_gnf" )
 column=(type=long update=yes updatewhereclause=yes name=nr_grg dbname="documento_ecf.nr_grg" )
 column=(type=long update=yes updatewhereclause=yes name=nr_cdc dbname="documento_ecf.nr_cdc" )
 column=(type=char(15) updatewhereclause=yes name=cd_forma_pagamento dbname="documento_ecf.cd_forma_pagamento" )
 retrieve="  SELECT documento_ecf.nr_coo,   
         documento_ecf.dh_movimento,   
         documento_ecf.nr_ecf,   
         documento_ecf.dh_final,   
         documento_ecf.id_documento,   
         documento_ecf.nr_gnf,   
         documento_ecf.nr_grg,   
         documento_ecf.nr_cdc,
  			documento_ecf.cd_forma_pagamento
    FROM documento_ecf   
where documento_ecf.dh_movimento >= :pdh_inicial
  and documento_ecf.dh_movimento <= :pdh_final
  and documento_ecf.nr_ecf        = :pl_ecf
 " update="documento_ecf" updatewhere=1 updatekeyinplace=no arguments=(("pl_ecf", number),("pdh_inicial", date),("pdh_final", date)) )
