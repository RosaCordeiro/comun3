table(column=(type=long updatewhereclause=yes name=nr_ecf dbname="nr_ecf" )
 retrieve="  SELECT distinct(mapa_resumo_ecf.nr_ecf)
    FROM mapa_resumo,   
         mapa_resumo_ecf,   
         parametro  
   WHERE ( mapa_resumo_ecf.cd_filial = mapa_resumo.cd_filial ) and  
         ( mapa_resumo_ecf.nr_mapa = mapa_resumo.nr_mapa ) and  
         ( mapa_resumo_ecf.de_especie = mapa_resumo.de_especie ) and  
         ( mapa_resumo_ecf.de_serie = mapa_resumo.de_serie ) and  
         ( parametro.cd_filial = mapa_resumo.cd_filial ) and  
         ( mapa_resumo.dh_movimentacao_caixa >= :pdh_inicial ) AND  
         ( mapa_resumo.dh_movimentacao_caixa <= :pdh_final ) AND  
         ( mapa_resumo_ecf.nr_ecf >= :pl_ecf_inicial ) AND
         ( mapa_resumo_ecf.nr_ecf <= :pl_ecf_final )
" arguments=(("pl_ecf_inicial", number),("pl_ecf_final", number),("pdh_inicial", date),("pdh_final", date))  sort="nr_ecf A " )
