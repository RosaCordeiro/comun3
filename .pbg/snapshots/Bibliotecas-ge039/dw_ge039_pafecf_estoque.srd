table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(101) updatewhereclause=yes name=de_produto dbname="compute_0002" )
 column=(type=char(3) updatewhereclause=yes name=cd_un dbname="produto_geral.cd_unidade_medida_venda" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="vw_saldo_atual_produto.qt_saldo_final" )
 retrieve="  SELECT produto_geral.cd_produto,   
         produto_geral.de_produto+':'+produto_geral.de_apresentacao_estoque,   
         produto_geral.cd_unidade_medida_venda,   
         vw_saldo_atual_produto.qt_saldo_final  
    FROM produto_geral,   
         vw_saldo_atual_produto  
   WHERE ( produto_geral.cd_produto = vw_saldo_atual_produto.cd_produto ) and  
         ( produto_geral.id_situacao = 'A' ) and 
         ( produto_geral.cd_produto < 10000 )
" )
