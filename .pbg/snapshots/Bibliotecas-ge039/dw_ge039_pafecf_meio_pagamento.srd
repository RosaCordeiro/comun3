table(column=(type=char(2) updatewhereclause=yes name=cd_forma_pagamento dbname="nf_venda.cd_forma_pagamento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_venda dbname="vl_total_venda" )
 retrieve="  SELECT nf_venda.cd_forma_pagamento,   
         sum(vl_total_nf) as vl_total_venda  
    FROM nf_venda  
   WHERE ( dh_movimentacao_caixa >= :pdt_periodo_de ) AND  
         ( dh_movimentacao_caixa <= :pdt_periodo_ate )
		and cd_forma_pagamento is not null
GROUP BY nf_venda.cd_forma_pagamento   
" arguments=(("pdt_periodo_de", date),("pdt_periodo_ate", date))  sort="cd_forma_pagamento A " )
text(band=header alignment="2" text="Vl Total Venda"border="0" color="0" x="590" y="4" height="64" width="389"  name=vl_total_venda_t  font.face="Arial" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
