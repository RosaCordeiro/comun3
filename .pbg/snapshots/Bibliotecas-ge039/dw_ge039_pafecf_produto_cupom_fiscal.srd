 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"nf_venda~" )  TABLE(NAME=~"item_nf_venda~" )  TABLE(NAME=~"produto_geral~" ) COLUMN(NAME=~"item_nf_venda.cd_filial~") COLUMN(NAME=~"item_nf_venda.nr_nf~") COLUMN(NAME=~"item_nf_venda.de_especie~") COLUMN(NAME=~"item_nf_venda.de_serie~") COLUMN(NAME=~"item_nf_venda.cd_natureza_operacao~") COLUMN(NAME=~"item_nf_venda.cd_produto~") COLUMN(NAME=~"item_nf_venda.cd_situacao_tributaria~") COLUMN(NAME=~"item_nf_venda.qt_vendida~") COLUMN(NAME=~"item_nf_venda.vl_preco_unitario~") COLUMN(NAME=~"item_nf_venda.pc_desconto_tabela~") COLUMN(NAME=~"item_nf_venda.vl_preco_praticado~") COLUMN(NAME=~"item_nf_venda.pc_icms~") COLUMN(NAME=~"item_nf_venda.pc_comissao_extra~") COLUMN(NAME=~"item_nf_venda.pc_comissao_normal~") COLUMN(NAME=~"item_nf_venda.id_alteracao_preco~") COLUMN(NAME=~"item_nf_venda.id_restricao_convenio~") COLUMN(NAME=~"item_nf_venda.id_comissionado~") COLUMN(NAME=~"item_nf_venda.qt_pontos_clube~") COMPUTE(NAME=~"produto_geral.de_produto + ' : ' + produto_geral.de_apresentacao_venda de_produto~") COLUMN(NAME=~"produto_geral.cd_unidade_medida_venda~") COLUMN(NAME=~"nf_venda.nr_operacao_ecf~")    JOIN (LEFT=~"item_nf_venda.cd_filial~"    OP =~"=~"RIGHT=~"nf_venda.cd_filial~" )    JOIN (LEFT=~"item_nf_venda.nr_nf~"    OP =~"=~"RIGHT=~"nf_venda.nr_nf~" )    JOIN (LEFT=~"item_nf_venda.de_especie~"    OP =~"=~"RIGHT=~"nf_venda.de_especie~" )    JOIN (LEFT=~"item_nf_venda.de_serie~"    OP =~"=~"RIGHT=~"nf_venda.de_serie~" )    JOIN (LEFT=~"produto_geral.cd_produto~"    OP =~"=~"RIGHT=~"item_nf_venda.cd_produto~" )WHERE(    EXP1 =~"nf_venda.dh_movimentacao_caixa~"   OP =~">=~"    EXP2 =~":pdh_inicial~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"nf_venda.dh_movimentacao_caixa~"   OP =~"<=~"    EXP2 =~":pdh_final~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"nf_venda.nr_ecf~"   OP =~"=~"    EXP2 =~":pl_ecf~" ) ) ARG(NAME = ~"pl_ecf~" TYPE = number)  ARG(NAME = ~"pdh_inicial~" TYPE = date)  ARG(NAME = ~"pdh_final~" TYPE = date) " arguments=(("pl_ecf", number),("pdh_inicial", date),("pdh_final", date))  sort="cd_filial A nr_nf A de_especie A de_serie A cd_natureza_operacao A " )
