HA$PBExportHeader$dw_mapa_resumo.srd
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="mapa_resumo.cd_filial" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_mapa dbname="mapa_resumo.nr_mapa" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=de_especie dbname="mapa_resumo.de_especie" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=de_serie dbname="mapa_resumo.de_serie" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_emissao dbname="mapa_resumo.dh_emissao" )
 retrieve="  SELECT mapa_resumo.cd_filial,   
         mapa_resumo.nr_mapa,   
         mapa_resumo.de_especie,   
         mapa_resumo.de_serie,   
         mapa_resumo.dh_emissao  
    FROM mapa_resumo  
   WHERE ( mapa_resumo.cd_filial  = :pl_filial ) AND  
         ( mapa_resumo.nr_mapa    = :pl_mapa ) AND  
         ( mapa_resumo.de_especie = :ps_especie ) AND  
         ( mapa_resumo.de_serie   = :ps_serie )    
" update="mapa_resumo" updatewhere=1 updatekeyinplace=no arguments=(("pl_filial", number),("pl_mapa", number),("ps_especie", string),("ps_serie", string)) )
text(band=header alignment="2" text="Cd Filial"border="0" color="0" x="5" y="4" height="64" width="329"  name=cd_filial_t  font.face="Arial" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
