 column=(type=long update=yes updatewhereclause=yes name=qt_reducao_z dbname="mapa_resumo_ecf.qt_reducao_z" )
 retrieve="  SELECT mapa_resumo_ecf.cd_filial,   
         mapa_resumo_ecf.nr_mapa,   
         mapa_resumo_ecf.de_especie,   
         mapa_resumo_ecf.de_serie,   
         mapa_resumo_ecf.nr_ecf,   
         mapa_resumo_ecf.nr_operacao_inicial,   
         mapa_resumo_ecf.nr_operacao_final,   
         mapa_resumo_ecf.vl_total_geral_inicial,   
         mapa_resumo_ecf.vl_total_geral_final,   
         mapa_resumo_ecf.vl_cancelamento,   
         mapa_resumo_ecf.vl_desconto,   
         mapa_resumo_ecf.vl_contabil,   
         mapa_resumo_ecf.vl_isenta,   
         mapa_resumo_ecf.vl_nao_incidencia,   
         mapa_resumo_ecf.vl_st,   
         mapa_resumo_ecf.qt_reducao_z  
    FROM mapa_resumo_ecf   
WHERE ( mapa_resumo_ecf.cd_filial  = :pl_filial ) AND  
      ( mapa_resumo_ecf.nr_mapa    = :pl_mapa ) AND  
      ( mapa_resumo_ecf.de_especie = :ps_especie ) AND  
      ( mapa_resumo_ecf.de_serie   = :ps_serie )    

" update="mapa_resumo_ecf" updatewhere=1 updatekeyinplace=no arguments=(("pl_filial", number),("pl_mapa", number),("ps_especie", string),("ps_serie", string)) )
