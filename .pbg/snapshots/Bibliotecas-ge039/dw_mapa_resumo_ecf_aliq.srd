table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="aliquota_mapa_resumo_ecf.cd_filial" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_mapa dbname="aliquota_mapa_resumo_ecf.nr_mapa" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=de_especie dbname="aliquota_mapa_resumo_ecf.de_especie" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=de_serie dbname="aliquota_mapa_resumo_ecf.de_serie" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_ecf dbname="aliquota_mapa_resumo_ecf.nr_ecf" )
 column=(type=decimal(2) update=yes updatewhereclause=yes key=yes name=pc_aliquota dbname="aliquota_mapa_resumo_ecf.pc_aliquota" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_base_calculo dbname="aliquota_mapa_resumo_ecf.vl_base_calculo" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_icms dbname="aliquota_mapa_resumo_ecf.vl_icms" )
 column=(type=char(1) updatewhereclause=yes name=ordem_aliq dbname="ordem_aliq" )
 retrieve="  SELECT aliquota_mapa_resumo_ecf.cd_filial,   
         aliquota_mapa_resumo_ecf.nr_mapa,   
         aliquota_mapa_resumo_ecf.de_especie,   
         aliquota_mapa_resumo_ecf.de_serie,   
         aliquota_mapa_resumo_ecf.nr_ecf,   
         aliquota_mapa_resumo_ecf.pc_aliquota,   
         aliquota_mapa_resumo_ecf.vl_base_calculo,   
         aliquota_mapa_resumo_ecf.vl_icms,
			Case pc_aliquota
				When 7.00 Then '1'
				When 12.00 Then '2'
				When 25.00 Then '3'
				When 17.00 Then '4'
				When 18.00 Then '5'
				Else '1'
			End as ordem_aliq				
    FROM aliquota_mapa_resumo_ecf 
   WHERE ( aliquota_mapa_resumo_ecf.cd_filial = :pl_filial ) AND  
         ( aliquota_mapa_resumo_ecf.nr_mapa = :pl_mapa ) AND  
         ( aliquota_mapa_resumo_ecf.de_especie = :ps_especie ) AND  
         ( aliquota_mapa_resumo_ecf.de_serie = :ps_serie )    
" update="aliquota_mapa_resumo_ecf" updatewhere=1 updatekeyinplace=no arguments=(("pl_filial", number),("pl_mapa", number),("ps_especie", string),("ps_serie", string))  sort="cd_filial A nr_mapa A de_especie A de_serie A nr_ecf A ordem_aliq A " )
