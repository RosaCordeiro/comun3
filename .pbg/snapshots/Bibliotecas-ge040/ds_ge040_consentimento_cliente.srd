table(column=(type=long updatewhereclause=yes key=yes name=cd_tipo_aviso dbname="tipo_aviso.cd_tipo_aviso" dbalias="a.cd_tipo_aviso" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo dbname="tipo_aviso.de_tipo" dbalias="a.de_tipo" )
 column=(type=char(2) updatewhereclause=yes name=id_rede dbname="tipo_aviso.id_rede" dbalias="a.id_rede" )
 column=(type=char(255) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=date updatewhereclause=yes name=dh_consentimento dbname="dh_consentimento" )
 retrieve="select a.cd_tipo_aviso, 
		a.de_tipo, 
		a.id_rede, 
		COALESCE((select  c.id_situacao 		from tipo_aviso_cliente c where c.cd_cliente = :cliente and c.cd_tipo_aviso = a.cd_tipo_aviso),'I') as id_situacao, 
		CAST(COALESCE((select  c.dh_consentimento	from tipo_aviso_cliente c where c.cd_cliente = :cliente and c.cd_tipo_aviso = a.cd_tipo_aviso),'1900/01/01') AS DATE) as dh_consentimento
from tipo_aviso a
where a.id_rede = :rede
And a.cd_tipo_aviso not in (31, 32,33,34,35)
Order by (CASE a.de_tipo WHEN 'SMS' THEN 'A'
			WHEN 'WHATSAPP' THEN 'B'
			WHEN 'LIGA$$HEX2$$c700c300$$ENDHEX$$O TELEF$$HEX1$$d400$$ENDHEX$$NICA' THEN 'C'
			WHEN 'EMAIL' THEN 'D'
			WHEN 'CORRESPOND$$HEX1$$ca00$$ENDHEX$$NCIA' THEN 'E'
			WHEN 'REDES SOCIAIS' THEN 'F'
			WHEN 'PARTICIPA$$HEX2$$c700c300$$ENDHEX$$O EM PESQUISAS' THEN 'G'
			ELSE 'Z' END ) " update="tipo_aviso" updatewhere=0 updatekeyinplace=no arguments=(("cliente", string),("rede", string)) )
