 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias=".cd_produto_sap" )
 column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="distribuidora_produto.cd_distribuidora" dbalias=".cd_distribuidora" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="distribuidora_produto.cd_produto" dbalias=".cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_estoque_disponivel dbname="distribuidora_produto.qt_estoque_disponivel" dbalias=".qt_estoque_disponivel" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_atual dbname="distribuidora_produto.vl_preco_atual" dbalias=".vl_preco_atual" )
