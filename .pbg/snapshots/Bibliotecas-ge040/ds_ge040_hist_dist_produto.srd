 column=(type=char(20) updatewhereclause=yes name=cd_produto_distribuidora dbname="distribuidora_produto.cd_produto_distribuidora" dbalias=".cd_produto_distribuidora" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_atual dbname="distribuidora_produto.pc_desconto_atual" dbalias=".pc_desconto_atual" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao_situacao dbname="distribuidora_produto.dh_alteracao_situacao" dbalias=".dh_alteracao_situacao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_repasse_icms dbname="distribuidora_produto.pc_repasse_icms" dbalias=".pc_repasse_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="distribuidora_produto.pc_icms" dbalias=".pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_reducao_base_icms dbname="distribuidora_produto.pc_reducao_base_icms" dbalias=".pc_reducao_base_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_base_icms_st dbname="distribuidora_produto.vl_preco_base_icms_st" dbalias=".vl_preco_base_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="distribuidora_produto.vl_icms_st" dbalias=".vl_icms_st" )
 column=(type=long updatewhereclause=yes name=nr_dias_pagamento dbname="distribuidora_produto.nr_dias_pagamento" dbalias=".nr_dias_pagamento" )
 column=(type=char(1) updatewhereclause=yes name=id_produto_hpc dbname="distribuidora_produto.id_produto_hpc" dbalias=".id_produto_hpc" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_conexao dbname="distribuidora_produto.pc_desconto_conexao" dbalias=".pc_desconto_conexao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st_farmacia_popular dbname="distribuidora_produto.vl_icms_st_farmacia_popular" dbalias=".vl_icms_st_farmacia_popular" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras_arquivo_preco dbname="distribuidora_produto.de_codigo_barras_arquivo_preco" dbalias=".de_codigo_barras_arquivo_preco" )
 column=(type=long updatewhereclause=yes name=ncm_produto dbname="distribuidora_produto.ncm_produto" dbalias=".ncm_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_comissao_midia dbname="distribuidora_produto.pc_comissao_midia" dbalias=".pc_comissao_midia" )
 column=(type=long updatewhereclause=yes name=cd_cest dbname="distribuidora_produto.cd_cest" dbalias=".cd_cest" )
 column=(type=char(3) updatewhereclause=yes name=cd_cst dbname="distribuidora_produto.cd_cst" dbalias=".cd_cst" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st_retido dbname="distribuidora_produto.vl_icms_st_retido" dbalias=".vl_icms_st_retido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_st_retido dbname="distribuidora_produto.vl_bc_st_retido" dbalias=".vl_bc_st_retido" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_st dbname="distribuidora_produto.pc_icms_st" dbalias=".pc_icms_st" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_mva dbname="distribuidora_produto.pc_mva" dbalias=".pc_mva" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pmc dbname="distribuidora_produto.vl_pmc" dbalias=".vl_pmc" )
 retrieve="	SELECT fornecedor.cd_fornecedor_sap,   
         fornecedor.nm_razao_social,   
         produto_geral.de_produto,   
         produto_geral.cd_produto_sap,   
         distribuidora_produto.cd_distribuidora,   
         distribuidora_produto.cd_produto,   
         distribuidora_produto.qt_estoque_disponivel,   
         distribuidora_produto.vl_preco_atual,   
         distribuidora_produto.cd_unidade_federacao,   
         distribuidora_produto.cd_produto_distribuidora,   
         distribuidora_produto.pc_desconto_atual,   
         distribuidora_produto.dh_alteracao_situacao,   
         distribuidora_produto.pc_repasse_icms,   
         distribuidora_produto.pc_icms,   
         distribuidora_produto.pc_reducao_base_icms,   
         distribuidora_produto.vl_preco_base_icms_st,   
         distribuidora_produto.vl_icms_st,   
         distribuidora_produto.nr_dias_pagamento,   
         distribuidora_produto.id_produto_hpc,   
         distribuidora_produto.pc_desconto_conexao,   
         distribuidora_produto.vl_icms_st_farmacia_popular,   
         distribuidora_produto.de_codigo_barras_arquivo_preco,
         distribuidora_produto.ncm_produto,   
         distribuidora_produto.pc_comissao_midia,   
         distribuidora_produto.cd_cest,   
         distribuidora_produto.cd_cst,   
         distribuidora_produto.vl_icms_st_retido,   
         distribuidora_produto.vl_bc_st_retido,   
         distribuidora_produto.pc_icms_st,   
         distribuidora_produto.pc_mva,   
         distribuidora_produto.vl_pmc  
    FROM fornecedor,   
         produto_geral,   
         distribuidora_produto  
  WHERE	( fornecedor.cd_fornecedor = distribuidora_produto.cd_distribuidora )	and  
       		( produto_geral.cd_produto = distribuidora_produto.cd_produto )		and 
			distribuidora_produto.dh_atualizacao_distribuidora > dateadd(day, -5, getdate())" )
