table(column=(type=date updatewhereclause=yes name=dh_movimento dbname="dh_movimento" )
 column=(type=long updatewhereclause=yes name=cd_filial_nf dbname="cd_filial_nf" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="vl_custo_unitario" )
 column=(type=long updatewhereclause=yes name=qt_movimento dbname="qt_movimento" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_bc_icms_retido dbname="vl_bc_icms_retido" )
 column=(type=decimal(6) updatewhereclause=yes name=pc_icms_retido dbname="pc_icms_retido" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_icms_retido dbname="vl_icms_retido" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_bc_icms_st_retido dbname="vl_bc_icms_st_retido" )
 column=(type=decimal(6) updatewhereclause=yes name=pc_icms_st_retido dbname="pc_icms_st_retido" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_icms_st_retido dbname="vl_icms_st_retido" )
 retrieve="select 	dh_movimento,
			cd_filial_nf,
			nr_nf,
			cd_fornecedor,
			de_serie,
			de_especie,
			cd_produto,
			vl_custo_unitario,
			qt_movimento,
			vl_bc_icms_retido,
			pc_icms_retido,
			vl_icms_retido,
			vl_bc_icms_st_retido,
			pc_icms_st_retido,
			vl_icms_st_retido
from (select  m.dh_movimento,
				 coalesce(m.cd_filial, p.cd_filial) as cd_filial_nf,
				m.nr_nf,
				m.cd_fornecedor,		
				m.de_serie,
				m.de_especie,
				m.cd_produto,
				m.vl_custo_unitario,
				m.qt_movimento,	

				case when m.cd_tipo_movimento = 3 then	
					case when inc.vl_bc_icms > 0.00 then  inc.vl_bc_icms else 0.00 end 
				else 
					case when int.vl_bc_icms > 0.00 then  round(int.vl_bc_icms / m.qt_movimento,2) else 0.00 end 
				end as vl_bc_icms_retido,

				case when m.cd_tipo_movimento = 3 then	
					case when inc.pc_icms > 0.00 then  inc.pc_icms else 0.00 end 
				else 
					case when int.pc_icms > 0.00 then  int.pc_icms else 0.00 end 
				end as pc_icms_retido,

				case when m.cd_tipo_movimento = 3 then	
					case when inc.vl_icms > 0.00 then  inc.vl_icms else round(inc.vl_icms_retido / m.qt_movimento,2) end 
				else 
					case when int.vl_icms > 0.00 then  round(int.vl_icms / m.qt_movimento,2) else round(int.vl_icms_retido / m.qt_movimento,2) end 
				end as vl_icms_retido,

				case when m.cd_tipo_movimento = 3 then	
					case when inc.vl_bc_icms_st_retido > 0.00 then  inc.vl_bc_icms_st_retido else case when inc.vl_bc_icms_st_calculado > 0.00 then round(inc.vl_bc_icms_st_calculado / m.qt_movimento,2) else inc.vl_preco_base_icms_st end end 
				else 
					case when int.vl_bc_icms_st_retido > 0.00 then  round(int.vl_bc_icms_st_retido / m.qt_movimento,2) else round(int.vl_bc_icms_st / m.qt_movimento,2) end 
				end as vl_bc_icms_st_retido,

				case when m.cd_tipo_movimento = 3 then	
					case when inc.pc_st_retido > 0.00 then  inc.pc_st_retido else case when inc.pc_icms_st > 0.00 then inc.pc_icms_st else coalesce(ti.pc_icms,0) + coalesce(ti.pc_fcp, 0) end end 
				else 
					case when int.pc_st_retido > 0.00 then  int.pc_st_retido else case when int.pc_icms_st > 0.00 then int.pc_icms_st else coalesce(ti.pc_icms,0) + coalesce(ti.pc_fcp, 0) end end 
				end as pc_icms_st_retido,

				case when m.cd_tipo_movimento = 3 then	
					case when inc.vl_icms_st_retido > 0.00 then inc.vl_icms_st_retido else case when inc.vl_icms_st_calculado > 0.00 then round(inc.vl_icms_st_calculado / m.qt_movimento,2) else inc.vl_icms_st end end 
				else
					case when int.vl_icms_st_retido > 0.00 then  round(int.vl_icms_st_retido / m.qt_movimento,2) else round(int.vl_icms_st / m.qt_movimento,2) end 
				end as vl_icms_st_retido
		from movimento_estoque m
		inner join parametro p
			on id_parametro = '1'
		left outer join item_nf_compra inc
			on inc.cd_filial = p.cd_filial
			and inc.nr_nf = m.nr_nf
			and inc.de_serie = m.de_serie
			and inc.de_especie = m.de_especie
			and inc.cd_fornecedor = m.cd_fornecedor
			and inc.cd_produto = m.cd_produto
			and m.cd_tipo_movimento = 3
		
		left outer join item_nf_transferencia int
			on int.cd_filial_origem = m.cd_filial
			and int.nr_nf = m.nr_nf
			and int.de_serie = m.de_serie
			and int.de_especie = m.de_especie
			and int.cd_produto = m.cd_produto
			and m.cd_tipo_movimento = 5

		left outer join fornecedor fo
			on fo.cd_fornecedor = inc.cd_fornecedor
		left outer join filial fid
			on fid.cd_filial = p.cd_filial
		left outer join cidade cd
			on cd.cd_cidade = fid.cd_cidade
		left outer join unidade_federacao uf
			on uf.cd_unidade_federacao = cd.cd_unidade_federacao
		left outer join filial fio
			on fo.cd_filial = int.cd_filial_origem
		left outer join cidade co
			on co.cd_cidade = coalesce(fo.cd_cidade,  fio.cd_cidade)

		left outer join produto_geral g
			on g.cd_produto = m.cd_produto
		left outer join tipo_icms ti
			on ti.cd_tipo_icms = g.cd_tipo_icms
		where m.cd_produto = :produto
			and m.cd_tipo_movimento in (3,5)
			and m.dh_movimentacao_custo = m.dh_movimentacao_custo
		order by m.dh_movimento desc
		limit 10
	) x
where x.vl_bc_icms_st_retido > 0.00
//limit 1" arguments=(("produto", number))  sort="dh_movimento D " )
