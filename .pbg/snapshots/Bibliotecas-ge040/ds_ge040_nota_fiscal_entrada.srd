table(column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="movimento_estoque.de_especie" dbalias="a.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="movimento_estoque.de_serie" dbalias="a.de_serie" )
 column=(type=char(13) updatewhereclause=yes name=dh_movimento dbname="dh_movimento" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_transferencia_nfe.de_chave_acesso" dbalias="b.de_chave_acesso" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="item_nf_transferencia.vl_custo_unitario" dbalias="c.vl_custo_unitario" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_bc_icms dbname="vl_bc_icms" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_icms dbname="vl_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="pc_icms" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_bc_icms_st dbname="vl_bc_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_st dbname="pc_icms_st" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_icms_st dbname="vl_icms_st" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_bc_icms_antecipacao dbname="item_nf_transferencia.vl_bc_icms_antecipacao" dbalias="c.vl_bc_icms_antecipacao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_mva_icms_antecipacao dbname="item_nf_transferencia.pc_mva_icms_antecipacao" dbalias="c.pc_mva_icms_antecipacao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_antecipacao dbname="item_nf_transferencia.pc_icms_antecipacao" dbalias="c.pc_icms_antecipacao" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_icms_antecipacao dbname="item_nf_transferencia.vl_icms_antecipacao" dbalias="c.vl_icms_antecipacao" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_icms_operacao dbname="vl_icms_operacao" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_icms_diferido dbname="pc_icms_diferido" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_icms_diferido dbname="vl_icms_diferido" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_bc_icms_st_retido dbname="vl_bc_icms_st_retido" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_st_retido dbname="pc_st_retido" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_icms_st_retido dbname="vl_icms_st_retido" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_tributacao dbname="cd_cst_tributacao" )
 column=(type=char(1) updatewhereclause=yes name=cd_cst_origem dbname="item_nf_transferencia.cd_cst_origem" dbalias="c.cd_cst_origem" )
 retrieve="select top 1 a.nr_nf, 
				a.de_especie, 
				a.de_serie, 
				Convert (varchar(13), a.dh_movimento, 103) as dh_movimento,
				b.de_chave_acesso,
				c.vl_custo_unitario,
				Cast( coalesce(c.vl_bc_icms,0) / qt_transferida as decimal(11,6)) as vl_bc_icms,
				Cast( coalesce(c.vl_icms,0) / qt_transferida as decimal(11,6)) as vl_icms,
				coalesce( c.pc_icms, 0) as pc_icms,
				Cast( coalesce(c.vl_bc_icms_st,0) / qt_transferida as decimal(11,6)) as vl_bc_icms_st,
				coalesce( c.pc_icms_st, 0) as pc_icms_st,
				Cast( coalesce(c.vl_icms_st,0) / qt_transferida as decimal(11,6)) as vl_icms_st,
				c.vl_bc_icms_antecipacao,
				c.pc_mva_icms_antecipacao,
				c.pc_icms_antecipacao,
				c.vl_icms_antecipacao,
				Cast( coalesce(c.vl_icms_operacao,0) / qt_transferida as decimal(11,6)) as vl_icms_operacao, 
				coalesce( c.pc_icms_diferido, 0) as pc_icms_diferido, 			
				Cast( coalesce(c.vl_icms_diferido,0) / qt_transferida as decimal(11,6))  as vl_icms_diferido,
				Cast( coalesce(c.vl_bc_icms_st_retido,0) / qt_transferida as decimal(11,6))  as vl_bc_icms_st_retido,
				coalesce( c.pc_st_retido, 0) as pc_st_retido,	
				Cast( coalesce(c.vl_icms_st_retido,0) / qt_transferida as decimal(11,6)) as vl_icms_st_retido,				
				COALESCE(c.cd_cst_tributacao, SUBSTRING(c.cd_situacao_tributaria, 2,1) || '0') as cd_cst_tributacao,
				c.cd_cst_origem
from movimento_estoque a
inner join nf_transferencia d 	 on d.cd_filial_origem 			= a.cd_filial
											and d.nr_nf 						= a.nr_nf
											and d.de_especie 				= a.de_especie
											and d.de_serie 					= a.de_serie

inner join item_nf_transferencia c on c.cd_filial_origem 			= d.cd_filial_origem
											and c.nr_nf 						= d.nr_nf
											and c.de_especie 				= d.de_especie
											and c.de_serie 					= d.de_serie
											and c.cd_produto				= a.cd_produto
								
inner join nf_transferencia_nfe b on b.cd_filial_origem 			= d.cd_filial_origem
											and b.nr_nf 						= d.nr_nf
											and b.de_especie 				= d.de_especie
											and b.de_serie 					= d.de_serie

where a.cd_tipo_movimento	= 5 
  and d.dh_cancelamento 		is null
  and a.cd_filial 					= 534
  and a.dh_movimento in (select max(dh_movimento) from movimento_estoque
								  where cd_tipo_movimento = 5
									 and cd_filial = 534)
order by a.dh_movimento desc" )
