global function string gf_captura_hash (string ps_valor);//Long lvl_Count
//Long lvl_Digito
//
String lvs_Hash

lvs_Hash = ""

uo_MD5 lvo_MD5
lvo_MD5 = Create uo_MD5

lvs_Hash = lvo_MD5.of_MD5(ps_Valor)

Destroy(lvo_MD5)

Return lvs_Hash
end function

