global function string gf_colocar_mascara_cpf (string a_cgc);//
RETURN MidA(a_cgc, 1, 3) + "." + MidA(a_cgc, 4, 3) + "." + MidA(a_cgc, 7, 3) + "-" + MidA(a_cgc,10, 2)
//
end function

