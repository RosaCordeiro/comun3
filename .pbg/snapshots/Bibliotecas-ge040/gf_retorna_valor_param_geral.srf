global type gf_retorna_valor_param_geral from function_object
end type

forward prototypes
global function boolean gf_retorna_valor_param_geral (string as_cd_parametro, boolean ab_mostra_mensagem, ref string as_diretorio, ref string as_mensagem_erro)
