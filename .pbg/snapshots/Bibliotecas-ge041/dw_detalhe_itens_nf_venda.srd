table(column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="item_nf_venda.nr_sequencial" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="item_nf_venda.qt_vendida" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_preco_unitario dbname="vl_preco_unitario" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_preco_praticado dbname="vl_preco_praticado" )
 column=(type=decimal(6) updatewhereclause=yes name=pc_desconto_tabela dbname="pc_desconto_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="item_nf_venda.pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_comissao_extra dbname="item_nf_venda.pc_comissao_extra" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_comissao_normal dbname="item_nf_venda.pc_comissao_normal" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_venda.cd_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao_preco dbname="item_nf_venda.id_alteracao_preco" values="N$$HEX1$$c300$$ENDHEX$$O	N/SIM	S/" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_pontos_clube dbname="item_nf_venda.qt_pontos_clube" )
 column=(type=long updatewhereclause=yes name=cd_filial_fcerta dbname="registro_venda_manip.cd_filial_fcerta" )
 column=(type=long updatewhereclause=yes name=nr_registro dbname="registro_venda_manip.nr_registro" )
 column=(type=char(255) updatewhereclause=yes name=id_modo_venda_manip dbname="id_modo_venda_manip" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" )
 retrieve="SELECT	g.de_produto								AS de_produto,
			i.nr_sequencial								AS nr_sequencial,
			i.qt_vendida									AS qt_vendida,
			ISNULL(m.vl_registro, i.vl_preco_unitario)	AS vl_preco_unitario, 
			ISNULL(m.vl_registro, i.vl_preco_praticado)	AS vl_preco_praticado, 
			(CASE WHEN m.nr_registro IS NOT NULL THEN 0.00 ELSE i.pc_desconto_tabela END) AS pc_desconto_tabela,  
			i.pc_icms										AS pc_icms, 
			i.pc_comissao_extra						AS pc_comissao_extra, 
			i.pc_comissao_normal					AS pc_comissao_normal,
			i.cd_produto									AS cd_produto,
			g.de_apresentacao_venda				AS de_apresentacao_venda,
			i.id_alteracao_preco						AS id_alteracao_preco,
			i.qt_pontos_clube							AS qt_pontos_clube,
			m.cd_filial_fcerta							AS cd_filial_fcerta,
			m.nr_registro								AS nr_registro,
			COALESCE( m.id_modo_venda, 'R' )	AS id_modo_venda_manip,
			g.cd_grupo_psico							AS cd_grupo_psico
  FROM item_nf_venda i
			INNER JOIN produto_geral g
				ON i.cd_produto = g.cd_produto
			LEFT OUTER JOIN registro_venda_manip m
				ON m.cd_filial						= i.cd_filial
				AND m.nr_nf						= i.nr_nf
				AND m.de_especie					= i.de_especie
				AND m.de_serie					= i.de_serie
				AND m.nr_sequencial				= i.nr_sequencial
				AND m.cd_produto					= i.cd_produto
 WHERE	i.cd_filial		= :pl_filial 
	AND	i.nr_nf		= :pl_nr_nf 
	AND	i.de_especie	= :ps_especie
	AND	i.de_serie	= :ps_serie" arguments=(("pl_filial", number),("pl_nr_nf", number),("ps_especie", string),("ps_serie", string))  sort="de_produto A de_apresentacao_venda A nr_sequencial A cd_produto A " )
