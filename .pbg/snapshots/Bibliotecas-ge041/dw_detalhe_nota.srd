 column=(type=long updatewhereclause=yes name=nr_pedido_ecommerce dbname="nf_venda.nr_pedido_ecommerce" dbalias="n.nr_pedido_ecommerce" )
 column=(type=char(11) updatewhereclause=yes name=cliente_cd_cliente dbname="cliente.cd_cliente" dbalias="cl.cd_cliente" )
 column=(type=char(40) updatewhereclause=yes name=cliente_nm_cliente dbname="nm_cliente" )
 column=(type=char(13) updatewhereclause=yes name=cliente_dependente_cd_dependente_cliente dbname="cliente_dependente.cd_dependente_cliente" dbalias="cd.cd_dependente_cliente" )
 column=(type=char(40) updatewhereclause=yes name=cliente_dependente_nm_dependente dbname="cliente_dependente.nm_dependente" dbalias="cd.nm_dependente" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="convenio.cd_convenio" dbalias="co.cd_convenio" )
 column=(type=char(60) updatewhereclause=yes name=convenio_nm_fantasia dbname="convenio.nm_fantasia" dbalias="co.nm_fantasia" )
