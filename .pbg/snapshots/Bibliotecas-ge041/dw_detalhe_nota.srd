 column=(type=char(40) updatewhereclause=yes name=condicao_venda_convenio_de_condicao_conv dbname="condicao_venda_convenio.de_condicao_convenio" dbalias="cv.de_condicao_convenio" )
 column=(type=long updatewhereclause=yes name=condicao_venda_crediario_cd_condicao_cre dbname="condicao_venda_crediario.cd_condicao_crediario" dbalias="cc.cd_condicao_crediario" )
 column=(type=char(40) updatewhereclause=yes name=condicao_venda_crediario_de_condicao_cre dbname="condicao_venda_crediario.de_condicao_crediario" dbalias="cc.de_condicao_crediario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms dbname="nf_venda.vl_bc_icms" dbalias="n.vl_bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="nf_venda.vl_icms" dbalias="n.vl_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="nf_venda.pc_desconto" dbalias="n.pc_desconto" )
