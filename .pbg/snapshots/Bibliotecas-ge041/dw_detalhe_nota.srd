 column=(type=decimal(2) updatewhereclause=yes name=vl_frete dbname="nf_venda.vl_frete" dbalias="n.vl_frete" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_venda.vl_total_nf" dbalias="n.vl_total_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="nf_venda.vl_icms_st" dbalias="n.vl_icms_st" )
 column=(type=char(6) updatewhereclause=yes name=nf_venda_nr_matric_operador dbname="nf_venda.nr_matric_operador" dbalias="n.nr_matric_operador" )
 column=(type=char(40) updatewhereclause=yes name=usuario_operador dbname="usuario.operador" dbalias="uo.operador" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_vendedor dbname="nf_venda.nr_matricula_vendedor" dbalias="n.nr_matricula_vendedor" )
 column=(type=char(40) updatewhereclause=yes name=usuario_vendedor dbname="usuario.vendedor" dbalias="uv.vendedor" )
 column=(type=char(255) updatewhereclause=yes name=nm_dependente_conveniado dbname="nm_dependente_conveniado" )
 column=(type=long updatewhereclause=yes name=cd_dependente_conveniado dbname="cd_dependente_conveniado" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pago_avista dbname="nf_venda.vl_pago_avista" dbalias="n.vl_pago_avista" )
 column=(type=char(255) updatewhereclause=yes name=id_situacao dbname="id_situacao" values="N$$HEX1$$c300$$ENDHEX$$O ENVIADA	/AUTORIZADA	A/DENEGADA	D/CANCELADA	X/PENDENTE	P/" )
 retrieve="  SELECT	n.cd_filial,   
         	n.nr_nf,   
         	n.de_especie,   
         	n.de_serie,
         	n.id_tipo_venda,   
         	n.dh_emissao,   
         	n.dh_movimentacao_caixa,   
         	n.cd_caixa,   
         	n.nr_controle_caixa,   
         	n.dh_cancelamento, 
			n.nr_cartao_clube,
			n.qt_pontos_clube,
			n.nr_nf_anexa,   
         	n.de_especie_anexa,   
         	n.de_serie_anexa,   
         	n.nr_pedido_drogaexpress,
			n.nr_pedido_ecommerce,
         	cl.cd_cliente,
         	(CASE WHEN cl.nm_social is not null THEN cl.nm_social ELSE cl.nm_cliente END) as nm_cliente,
		   	cd.cd_dependente_cliente,
		   	cd.nm_dependente,
         	co.cd_convenio,
  			co.nm_fantasia,
         	ca.cd_conveniado,
         	ca.nm_conveniado,
			cv.cd_condicao_convenio,
		   	cv.de_condicao_convenio,
 		   	cc.cd_condicao_crediario,
			cc.de_condicao_crediario,
			n.vl_bc_icms,   
         	n.vl_icms,   
         	n.pc_desconto,   
         	n.vl_outras_despesas,   
         	n.vl_total_produtos,   
         	n.vl_bc_icms_st,   
         	n.vl_frete,   
         	n.vl_total_nf,   
         	n.vl_icms_st,
         	n.nr_matric_operador,
			uo.nm_usuario operador,
			n.nr_matricula_vendedor,
			uv.nm_usuario vendedor,
         	Space(80) nm_dependente_conveniado,
         	0 cd_dependente_conveniado,
			n.vl_pago_avista,
			coalesce(nfe.id_situacao,'') as id_situacao
FROM  nf_venda n
INNER JOIN usuario uo
	ON uo.nr_matricula = n.nr_matric_operador  
INNER JOIN usuario uv
	ON uv.nr_matricula = n.nr_matricula_vendedor  
LEFT OUTER JOIN cliente cl
	 ON cl.cd_cliente = n.cd_cliente		
LEFT OUTER JOIN cliente_dependente cd
	  ON cd.cd_dependente_cliente = n.cd_cliente_dependente
LEFT OUTER JOIN convenio co
	  ON co.cd_convenio = n.cd_convenio    			
LEFT OUTER JOIN conveniado ca
	  ON ca.cd_convenio    = n.cd_convenio
	AND ca.cd_conveniado = n.cd_conveniado		
LEFT OUTER JOIN condicao_venda_convenio cv
	  ON cv.cd_condicao_convenio = n.cd_condicao_convenio 
LEFT OUTER JOIN condicao_venda_crediario cc
	  ON cc.cd_condicao_crediario = n.cd_condicao_crediario
LEFT OUTER JOIN nf_venda_nfe nfe
	  ON nfe.cd_filial = n.cd_filial
	  And nfe.nr_nf = n.nr_nf
	  And nfe.de_serie = n.de_serie
	  And nfe.de_especie = n.de_especie
 WHERE n.cd_filial 	= :cd_filial 
     and n.nr_nf 		= :nr_nf 
     and n.de_especie = :de_especie 
     and n.de_serie 	= :de_serie 


" arguments=(("cd_filial", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
