table(column=(type=long updatewhereclause=yes key=yes name=cd_filial dbname="registro_venda_manip.cd_filial" dbalias="r.cd_filial" )
 column=(type=long updatewhereclause=yes key=yes name=nr_nf dbname="registro_venda_manip.nr_nf" dbalias="r.nr_nf" )
 column=(type=char(3) updatewhereclause=yes key=yes name=de_especie dbname="registro_venda_manip.de_especie" dbalias="r.de_especie" )
 column=(type=char(3) updatewhereclause=yes key=yes name=de_serie dbname="registro_venda_manip.de_serie" dbalias="r.de_serie" )
