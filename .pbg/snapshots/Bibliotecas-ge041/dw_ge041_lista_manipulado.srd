 column=(type=long updatewhereclause=yes key=yes name=nr_registro dbname="registro_venda_manip.nr_registro" dbalias="r.nr_registro" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="registro_venda_manip.vl_preco_unitario" dbalias="r.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="registro_venda_manip.pc_desconto" dbalias="r.pc_desconto" )
 column=(type=char(500) update=yes updatewhereclause=no name=de_dados_adicionais dbname="registro_venda_manip.de_dados_adicionais" dbalias="r.de_dados_adicionais" )
 retrieve="SELECT 	r.cd_filial,   
			r.nr_nf,   
			r.de_especie,   
			r.de_serie,
			r.nr_sequencial,  
			r.cd_produto,   
			r.nr_registro,
			r.vl_preco_unitario,
			r.pc_desconto,  
			r.de_dados_adicionais         
    FROM registro_venda_manip r 
WHERE r.cd_filial 		= :filial
	AND r.nr_nf			= :nota
	AND r.de_especie 	= :especie
	AND r.de_serie		= :serie
ORDER BY r.nr_registro" update="registro_venda_manip" updatewhere=0 updatekeyinplace=yes arguments=(("filial", number),("nota", number),("especie", string),("serie", string)) )
