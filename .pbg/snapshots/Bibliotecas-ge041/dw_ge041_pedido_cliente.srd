table(column=(type=long updatewhereclause=yes key=yes name=cd_filial dbname="nf_venda.cd_filial" )
 column=(type=long updatewhereclause=yes key=yes name=nr_nf dbname="nf_venda.nr_nf" )
 column=(type=char(3) updatewhereclause=yes key=yes name=nf_venda_de_especie dbname="nf_venda.de_especie" )
 column=(type=char(3) updatewhereclause=yes key=yes name=nf_venda_de_serie dbname="nf_venda.de_serie" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="cliente.cd_cliente" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="cliente.nm_cliente" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_pedido_cliente dbname="nf_venda.nr_pedido_cliente" )
 retrieve="select	a.cd_filial,
		a.nr_nf,
		a.de_especie,
		a.de_serie,
		b.cd_cliente,
		b.nm_cliente,
		a.nr_pedido_cliente
from nf_venda a
left join cliente b on b.cd_cliente = a.cd_cliente
where	a.cd_filial		= :cd_filial
	and	a.nr_nf			= :nr_nf
	and	a.de_especie	= :de_especie
	and	a.de_serie		= :de_serie" update="nf_venda" updatewhere=0 updatekeyinplace=no arguments=(("cd_filial", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
