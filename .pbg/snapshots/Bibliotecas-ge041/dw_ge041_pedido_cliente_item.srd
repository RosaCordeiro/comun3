table(column=(type=long update=yes updatewhereclause=yes name=nr_pedido_cliente_item dbname="item_nf_venda.nr_pedido_cliente_item" )
 column=(type=long updatewhereclause=yes key=yes name=cd_filial dbname="item_nf_venda.cd_filial" )
 column=(type=long updatewhereclause=yes key=yes name=nr_nf dbname="item_nf_venda.nr_nf" )
 column=(type=char(3) updatewhereclause=yes key=yes name=de_especie dbname="item_nf_venda.de_especie" )
 column=(type=char(3) updatewhereclause=yes key=yes name=de_serie dbname="item_nf_venda.de_serie" )
 column=(type=long updatewhereclause=yes key=yes name=nr_sequencial dbname="item_nf_venda.nr_sequencial" )
 column=(type=long updatewhereclause=yes key=yes name=cd_produto dbname="item_nf_venda.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="item_nf_venda.qt_vendida" )
 column=(type=decimal(2) updatewhereclause=yes name=item_nf_venda_vl_preco_praticado dbname="item_nf_venda.vl_preco_praticado" )
 column=(type=char(255) updatewhereclause=yes name=de_produto dbname="de_produto" )
 retrieve="select	a.nr_pedido_cliente_item,
		a.cd_filial,
		a.nr_nf,
		a.de_especie,
		a.de_serie,
		a.nr_sequencial,
		a.cd_produto,
		a.qt_vendida,
		a.vl_preco_praticado,
		b.de_produto +' : '+ b.de_apresentacao_venda as de_produto
from item_nf_venda a
inner join produto_geral b on b.cd_produto = a.cd_produto
where	a.cd_filial		= :cd_filial
	and	a.nr_nf			= :nr_nf
	and	a.de_especie	= :de_especie
	and	a.de_serie		= :de_serie" update="item_nf_venda" updatewhere=0 updatekeyinplace=no arguments=(("cd_filial", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
