table(column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_venda.nr_nf" dbalias="n.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_venda.de_especie" dbalias="n.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_venda.de_serie" dbalias="n.de_serie" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_cancelamento dbname="nf_venda.dh_cancelamento" dbalias="n.dh_cancelamento" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_venda dbname="nf_venda.id_tipo_venda" dbalias="n.id_tipo_venda" values="$$HEX1$$c000$$ENDHEX$$ VISTA	AV/CREDI$$HEX1$$c100$$ENDHEX$$RIO	CR/CONTA CORRENTE	CC/CONV$$HEX1$$ca00$$ENDHEX$$NIO	CV/" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_venda.cd_filial" dbalias="n.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_ecf dbname="nf_venda.nr_ecf" dbalias="n.nr_ecf" )
 column=(type=long updatewhereclause=yes name=nr_operacao_ecf dbname="nr_operacao_ecf" )
 column=(type=date updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_venda.dh_movimentacao_caixa" dbalias="n.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_venda.vl_total_nf" dbalias="n.vl_total_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="nf_venda.pc_desconto" dbalias="n.pc_desconto" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_cancelamento dbname="nf_venda.nr_matricula_cancelamento" dbalias="n.nr_matricula_cancelamento" )
 column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="nf_venda.cd_caixa" dbalias="n.cd_caixa" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="nf_venda.nr_controle_caixa" dbalias="n.nr_controle_caixa" )
 column=(type=long updatewhereclause=yes name=nr_nf_anexa dbname="nf_venda.nr_nf_anexa" dbalias="n.nr_nf_anexa" )
 column=(type=char(11) updatewhereclause=yes name=nr_pedido_drogaexpress dbname="nf_venda.nr_pedido_drogaexpress" dbalias="n.nr_pedido_drogaexpress" )
 column=(type=long updatewhereclause=yes name=nr_pedido_ecommerce dbname="nf_venda.nr_pedido_ecommerce" dbalias="n.nr_pedido_ecommerce" )
 column=(type=char(15) updatewhereclause=yes name=nr_protocolo_cancelamento dbname="nf_venda_nfe.nr_protocolo_cancelamento" dbalias="e.nr_protocolo_cancelamento" )
 column=(type=char(44) updatewhereclause=yes name=nf_venda_nfe_de_chave_acesso dbname="nf_venda_nfe.de_chave_acesso" dbalias="e.de_chave_acesso" )
 column=(type=char(15) updatewhereclause=yes name=nr_protocolo_envio dbname="nf_venda_nfe.nr_protocolo_envio" dbalias="e.nr_protocolo_envio" )
 column=(type=char(255) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=date updatewhereclause=yes name=dh_devolucao dbname="nf_venda.dh_devolucao" dbalias="n.dh_devolucao" )
 column=(type=char(255) updatewhereclause=yes name=id_exige_pedido_cliente dbname="id_exige_pedido_cliente" )
 column=(type=char(14) updatewhereclause=yes name=cliente_nr_cpf_cgc dbname="cliente.nr_cpf_cgc" dbalias="c.nr_cpf_cgc" )
 retrieve="  SELECT n.nr_nf,   
         n.de_especie,   
         n.de_serie, 
         n.dh_cancelamento,   
         n.id_tipo_venda,   
         n.cd_filial,   
         n.nr_ecf,
         coalesce(n.nr_operacao_ecf,n.nr_ccf) as nr_operacao_ecf,
         n.dh_movimentacao_caixa,   
         n.vl_total_nf,   
         n.pc_desconto,   
         n.nr_matricula_cancelamento,   
         n.cd_caixa,   
         n.nr_controle_caixa,   
         n.nr_nf_anexa,
         n.nr_pedido_drogaexpress,
	 	n.nr_pedido_ecommerce,
	 	e.nr_protocolo_cancelamento,
		e.de_chave_acesso,
		e.nr_protocolo_envio,
		coalesce(e.id_situacao,'A') as id_situacao,
		n.dh_devolucao,
		coalesce(c.id_exige_pedido_cliente, 'N') as id_exige_pedido_cliente,
		c.nr_cpf_cgc  nr_cpf_cgc
FROM nf_venda n
LEFT OUTER JOIN nf_venda_nfe e	ON e.cd_filial		= n.cd_filial
											AND e.nr_nf			= n.nr_nf
											AND e.de_especie	= n.de_especie
											AND e.de_serie		= n.de_serie
LEFT OUTER JOIN cliente c ON c.cd_cliente	= n.cd_cliente
"  sort="nr_nf A " )
