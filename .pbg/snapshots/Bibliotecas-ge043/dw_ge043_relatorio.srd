table(column=(type=long updatewhereclause=yes name=cd_produto dbname="desconto_regionalizado.cd_produto" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="desconto_regionalizado.dh_inicio" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="desconto_regionalizado.pc_desconto" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="desconto_regionalizado.dh_termino" )
 column=(type=char(40) updatewhereclause=yes name=desconto_regionalizado_de_desconto dbname="desconto_regionalizado.de_desconto" )
 column=(type=char(1) updatewhereclause=yes name=desconto_regionalizado_id_exige_document dbname="desconto_regionalizado.id_exige_documento" )
 retrieve="  SELECT desconto_regionalizado.cd_produto,   
         desconto_regionalizado.dh_inicio,   
         produto_geral.de_produto,   
         produto_geral.de_apresentacao_venda,   
         desconto_regionalizado.pc_desconto,   
         desconto_regionalizado.dh_termino,   
         desconto_regionalizado.de_desconto,
			desconto_regionalizado.id_exige_documento
    FROM desconto_regionalizado,   
         desconto_regionalizado_filial,   
         produto_geral  
   WHERE ( desconto_regionalizado_filial.cd_produto = desconto_regionalizado.cd_produto ) and  
         ( desconto_regionalizado_filial.dh_inicio = desconto_regionalizado.dh_inicio ) and  
         ( produto_geral.cd_produto = desconto_regionalizado.cd_produto ) and  
         ( CONVERT(CHAR(8), desconto_regionalizado.dh_termino, 112) >= :a_today OR  
         desconto_regionalizado.dh_termino Is Null) AND  
         desconto_regionalizado_filial.cd_filial = :cd_filial    
" arguments=(("cd_filial", number),("a_today", string))  sort="de_descricao_apresentacao A " )
