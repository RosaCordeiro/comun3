table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_venda.cd_filial" dbalias="nf.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_venda.dh_movimentacao_caixa" dbalias="nf.dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_venda.nr_nf" dbalias="nf.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_venda.de_especie" dbalias="nf.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_venda.de_serie" dbalias="nf.de_serie" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_venda.cd_produto" dbalias="inf.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="p.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="p.de_apresentacao_venda" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="qt_vendida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_venda.vl_preco_unitario" dbalias="inf.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_praticado dbname="item_nf_venda.vl_preco_praticado" dbalias="inf.vl_preco_praticado" )
 column=(type=decimal(10) updatewhereclause=yes name=desconto dbname="desconto" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_operador dbname="nf_venda.nr_matric_operador" dbalias="nf.nr_matric_operador" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="u.nm_usuario" )
 retrieve="  SELECT nf.cd_filial,   
		 f.nm_fantasia,
	     nf.dh_movimentacao_caixa,   
         nf.nr_nf,   
         nf.de_especie,   
         nf.de_serie,   
	    inf.cd_produto,   
         p.de_produto,   
         p.de_apresentacao_venda,   
         inf.qt_vendida - coalesce(infd.qt_devolvida,0) as qt_vendida,   
         inf.vl_preco_unitario,   
		inf.vl_preco_praticado,   
		round((( inf.vl_preco_unitario -   inf.vl_preco_praticado) / inf.vl_preco_unitario) * 100, 2) as desconto,
         nf.nr_matric_operador,  
		 u.nm_usuario
    FROM nf_venda nf
inner join item_nf_venda inf
	 on 	inf.cd_filial  		= nf.cd_filial
	 and 	inf.nr_nf 			= nf.nr_nf 
	 and 	inf.de_especie 	= nf.de_especie 
	 and	inf.de_serie 		= nf.de_serie 
inner join produto_geral p
	on 	p.cd_produto 	= inf.cd_produto
inner join filial  f
	 on 	f.cd_filial			= nf.cd_filial
left outer join usuario u
	on 	u.nr_matricula 	= nf.nr_matric_alteracao_preco 
left outer join nf_devolucao_venda nfd
	on 	nfd.cd_filial_venda			= nf.cd_filial
	and 	nfd.nr_nf_venda			= nf.nr_nf
	and 	nfd.de_especie_venda 	= nf.de_especie
	and 	nfd.de_serie_venda	 	= nf.de_serie
left outer join item_nf_devolucao_venda infd
	on 	infd.cd_filial			= nfd.cd_filial
	and 	infd.nr_nf			= nfd.nr_nf
	and 	infd.de_especie 	= nfd.de_especie
	and 	infd.de_serie	 	= nfd.de_serie
	and 	infd.cd_produto	 	= inf.cd_produto
WHERE nf.dh_movimentacao_caixa     between :dh_inicio and :dh_termino
	and inf.vl_preco_unitario 	<> inf.vl_preco_praticado 
	and inf.id_alteracao_preco 	= 'S' 
	and (inf.qt_vendida - coalesce(infd.qt_devolvida,0)) > 0
	and nf.dh_cancelamento      is null
	and nf.nr_nf_anexa             is null " arguments=(("dh_inicio", date),("dh_termino", date))  sort="cd_filial A dh_movimentacao_caixa A nr_nf A " )
