table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_venda.cd_filial" dbalias="nf.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_venda.nr_nf" dbalias="nf.nr_nf" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_venda.cd_produto" dbalias="inf.cd_produto" )
 column=(type=char(102) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(61) updatewhereclause=yes name=tipo_desconto dbname="tipo_desconto" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="qt_vendida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_bruto_total dbname="vl_preco_bruto_total" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_preco_tabela_total dbname="vl_preco_tabela_total" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_praticado_total dbname="vl_preco_praticado_total" )
 column=(type=decimal(10) updatewhereclause=yes name=pc_desconto_total dbname="pc_desconto_total" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desc_total dbname="vl_desc_total" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_desc_modalidade_total dbname="vl_desc_modalidade_total" )
 column=(type=decimal(23) updatewhereclause=yes name=pc_desconto_modalidade dbname="pc_desconto_modalidade" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_desc_considerado_total dbname="vl_desc_considerado_total" )
 column=(type=char(56) updatewhereclause=yes name=obs_desconto_considerado dbname="obs_desconto_considerado" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_total dbname="vl_custo_total" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_comissao_total dbname="vl_comissao_total" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_icms_total dbname="vl_icms_total" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_margem_total dbname="vl_margem_total" )
 column=(type=decimal(23) updatewhereclause=yes name=pc_rentabilidade dbname="pc_rentabilidade" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_alteracao_preco dbname="nf_venda.nr_matric_alteracao_preco" dbalias="nf.nr_matric_alteracao_preco" )
 column=(type=char(40) updatewhereclause=yes name=usuario_alteracao_preco dbname="usuario.usuario_alteracao_preco" dbalias="u.usuario_alteracao_preco" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="cliente.cd_cliente" dbalias="cli.cd_cliente" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="cliente.nm_cliente" dbalias="cli.nm_cliente" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="convenio.cd_convenio" dbalias="cv.cd_convenio" )
 column=(type=char(60) updatewhereclause=yes name=nm_convenio dbname="convenio.nm_convenio" dbalias="cv.nm_convenio" )
 column=(type=char(15) updatewhereclause=yes name=cd_conveniado dbname="conveniado.cd_conveniado" dbalias="cvo.cd_conveniado" )
 column=(type=char(40) updatewhereclause=yes name=nm_conveniado dbname="conveniado.nm_conveniado" dbalias="cvo.nm_conveniado" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_operador dbname="nf_venda.nr_matric_operador" dbalias="nf.nr_matric_operador" )
 column=(type=char(40) updatewhereclause=yes name=nm_operador dbname="usuario.nm_operador" dbalias="uop.nm_operador" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_vendedor dbname="nf_venda.nr_matricula_vendedor" dbalias="nf.nr_matricula_vendedor" )
 column=(type=char(40) updatewhereclause=yes name=usuario_nm_vendedor dbname="usuario.nm_vendedor" dbalias="uov.nm_vendedor" )
 retrieve="  SELECT nf.cd_filial,   
		 f.nm_fantasia,
	     cast(nf.dh_movimentacao_caixa as date) as dh_movimentacao_caixa,   
         nf.nr_nf,   
         //nf.de_especie,   
         //nf.de_serie,   
	    inf.cd_produto,   
         p.de_produto||': '||p.de_apresentacao_venda as de_produto,   
		Case
            When infvd.id_tipo_desconto = 'NEG' Then 'COBRE PRE$$HEX1$$c700$$ENDHEX$$O'
            When infvd.id_tipo_desconto = 'PVE' and  ppv.nr_etiqueta is Null Then 'PRESTES A VENCER - MANUAL'
		   When infvd.id_tipo_desconto = 'PD' Then 'F5 - PRODUTO DANIFICADO'
		   When infvd.id_tipo_desconto = 'LCT' Then 'F5 - LICITA$$HEX2$$c700c300$$ENDHEX$$O/OR$$HEX1$$c700$$ENDHEX$$AMENTO'
		   When infvd.id_tipo_desconto = 'DP' Then 'F5 - DESCONTO PRICING'
		   When infvd.id_tipo_desconto = 'GER' Then 'F5 - DESCONTO GERENTE'
		   When infvd.id_tipo_desconto = 'PEF' Then 'F5 - ETIQUETA PRE$$HEX1$$c700$$ENDHEX$$O ERRADO - FILIAL'
		   When infvd.id_tipo_desconto = 'PEE' Then 'F5 - ETIQUETA PRE$$HEX1$$c700$$ENDHEX$$O ERRADO - ENCARTE'
		   When infvd.id_tipo_desconto = 'PEP' Then 'F5 - ETIQUETA PRE$$HEX1$$c700$$ENDHEX$$O ERRADO - POSICIONAMENTO PRODUTOS/ETIQUETA'
		   When infvd.id_tipo_desconto = 'PEV' Then 'F5 - ETIQUETA PRE$$HEX1$$c700$$ENDHEX$$O ERRADO - VIRADA DE M$$HEX1$$ca00$$ENDHEX$$S'
		   When infvd.id_tipo_desconto = 'PSD' Then 'DESCONTO PLANO SA$$HEX1$$da00$$ENDHEX$$DE'
		   When infvd.id_tipo_desconto = 'MPI' Then 'F5 - MANIPULA$$HEX2$$c700c300$$ENDHEX$$O IDOSOS'
		   When infvd.id_tipo_desconto = 'MPM' Then 'F5 - MANIPULA$$HEX2$$c700c300$$ENDHEX$$O M$$HEX1$$c900$$ENDHEX$$DICOS'
		   When infvd.id_tipo_desconto = 'MPC' Then 'F5 - MANIPULA$$HEX2$$c700c300$$ENDHEX$$O CL$$HEX1$$cd00$$ENDHEX$$NICAS/PRESCRITORES/SECRETARIAS'
		   When infvd.id_tipo_desconto = 'FRT' Then 'F5 - PRODUTO FRETE'
		   When infvd.id_tipo_desconto = 'LUZ' Then 'F5 - FALTA DE ENERGIA'
		   When infvd.id_tipo_desconto = 'ORJ' Then 'OR$$HEX1$$c700$$ENDHEX$$AMENTO JUDICIAL'
		   When infvd.id_tipo_desconto = 'QDE' Then 'QUEDA DE ENERGIA'
            When ppv.nr_etiqueta is not null Then 'PRESTES A VENCER - ETIQUETA'
		   ELSE  infvd.id_tipo_desconto
		End As tipo_desconto,
         inf.qt_vendida - coalesce(infd.qt_devolvida,0) as qt_vendida,   
         (inf.qt_vendida - coalesce(infd.qt_devolvida,0)) * inf.vl_preco_unitario as vl_preco_bruto_total,   

         case when nf.dh_movimentacao_caixa >= '20190601' then 
           (inf.qt_vendida - coalesce(infd.qt_devolvida,0)) * round(inf.vl_preco_unitario*(1-(infvd.pc_desconto_tabela/100)),2)
          else 
           (inf.qt_vendida - coalesce(infd.qt_devolvida,0)) * round(inf.vl_preco_unitario*(1-(inf.pc_desconto_tabela/100)),2) end as vl_preco_tabela_total,

		(inf.qt_vendida - coalesce(infd.qt_devolvida,0)) * inf.vl_preco_praticado as vl_preco_praticado_total,   
		round((( inf.vl_preco_unitario -   inf.vl_preco_praticado) / inf.vl_preco_unitario) * 100, 2) as pc_desconto_total,
		(inf.qt_vendida - coalesce(infd.qt_devolvida,0)) * (inf.vl_preco_unitario - inf.vl_preco_praticado) as vl_desc_total,

          case when nf.dh_movimentacao_caixa >= '20190601' then
           (inf.qt_vendida - coalesce(infd.qt_devolvida,0)) * (round(inf.vl_preco_unitario*(1-(infvd.pc_desconto_tabela/100)),2) - inf.vl_preco_praticado)
          else
		 (inf.qt_vendida - coalesce(infd.qt_devolvida,0)) * (round(inf.vl_preco_unitario*(1-(inf.pc_desconto_tabela/100)),2) - inf.vl_preco_praticado) end as vl_desc_modalidade_total,

          case when nf.dh_movimentacao_caixa >= '20190601' then
		  round((( round(inf.vl_preco_unitario*(1-(infvd.pc_desconto_tabela/100)),2) - inf.vl_preco_praticado ) / inf.vl_preco_unitario) * 100, 2)
          else
		  round((( round(inf.vl_preco_unitario*(1-(inf.pc_desconto_tabela/100)),2) - inf.vl_preco_praticado ) / inf.vl_preco_unitario) * 100, 2) end as pc_desconto_modalidade,

          case when nf.dh_movimentacao_caixa >= '20190601' then
           (inf.qt_vendida - coalesce(infd.qt_devolvida,0)) * (round(inf.vl_preco_unitario*(1-(infvd.pc_desconto_tabela/100)),2) - inf.vl_preco_praticado)
          else
  		  Case When infvd.id_tipo_desconto = 'NEG' Then (inf.qt_vendida - coalesce(infd.qt_devolvida,0)) * (round(inf.vl_preco_unitario*(1-(inf.pc_desconto_tabela/100)),2) - inf.vl_preco_praticado) ELSE (inf.qt_vendida - coalesce(infd.qt_devolvida,0)) * (inf.vl_preco_unitario - inf.vl_preco_praticado) end end as vl_desc_considerado_total,

          case when nf.dh_movimentacao_caixa >= '20190601' then
		 'CONSIDERA O PRE$$HEX1$$c700$$ENDHEX$$O TABELA MENOS PRATICADO'
		else
		 Case When infvd.id_tipo_desconto = 'NEG' Then 'COBRE PRE$$HEX1$$c700$$ENDHEX$$O CONSIDERA O PRE$$HEX1$$c700$$ENDHEX$$O TABELA MENOS PRATICADO' ELSE 'PRESTES E DEMAIS CONSIDERA O PRE$$HEX1$$c700$$ENDHEX$$O BRUTO MENOS PRATICADO' end end as obs_desconto_considerado,

		(inf.qt_vendida - coalesce(infd.qt_devolvida,0)) * me.vl_custo_unitario As vl_custo_total,
		(inf.qt_vendida - coalesce(infd.qt_devolvida,0)) * round(inf.vl_preco_praticado * (inf.pc_comissao_extra / 100),2) As vl_comissao_total,
		(inf.qt_vendida - coalesce(infd.qt_devolvida,0)) * round(inf.vl_preco_praticado * (inf.pc_icms / 100), 2) as vl_icms_total,
		(inf.qt_vendida - coalesce(infd.qt_devolvida,0)) * ((inf.vl_preco_praticado) - round(inf.vl_preco_praticado * (inf.pc_comissao_extra / 100),2) - (me.vl_custo_unitario)) as vl_margem_total,
		round(((inf.vl_preco_praticado) - round(inf.vl_preco_praticado * (inf.pc_comissao_extra / 100),2) - (me.vl_custo_unitario)) / inf.vl_preco_unitario * 100, 2) as pc_rentabilidade,
         nf.nr_matric_alteracao_preco ,  
		u.nm_usuario as usuario_alteracao_preco,
		cli.cd_cliente,
		cli.nm_cliente,
		cv.cd_convenio,
		cv.nm_fantasia as nm_convenio,
		cvo.cd_conveniado,
		cvo.nm_conveniado, 
		nf.nr_matric_operador,
		uop.nm_usuario as nm_operador,
		nf.nr_matricula_vendedor,
		uov.nm_usuario as nm_vendedor
    FROM nf_venda nf
inner join item_nf_venda inf
	 on 	inf.cd_filial  		= nf.cd_filial
	 and 	inf.nr_nf 			= nf.nr_nf 
	 and 	inf.de_especie 	= nf.de_especie 
	 and	inf.de_serie 		= nf.de_serie 
inner join produto_geral p
	on 	p.cd_produto 	= inf.cd_produto
inner join filial  f
	 on 	f.cd_filial			= nf.cd_filial
inner join movimento_estoque me
	on me.cd_filial_movimento = inf.cd_filial
	and me.nr_nf = inf.nr_nf
	and me.de_serie = inf.de_serie
	and me.de_especie = inf.de_especie
	and me.cd_produto = inf.cd_produto
	and coalesce(me.nr_sequencial, 1) = coalesce(inf.nr_sequencial, 1)
left outer join usuario u
	on 	u.nr_matricula 	= nf.nr_matric_alteracao_preco 
Left Outer Join item_nf_venda_desconto As infvd
	On infvd.cd_filial		= inf.cd_filial
	And infvd.nr_nf			= inf.nr_nf
	And infvd.de_especie	= inf.de_especie
	And infvd.de_serie		= inf.de_serie
	And infvd.cd_produto	= inf.cd_produto
	And coalesce(infvd.nr_sequencial,1) = inf.nr_sequencial
Left Outer Join produto_preste_a_vencer ppv
	on ppv.cd_filial = inf.cd_filial
	and ppv.nr_nf = inf.nr_nf
	and ppv.de_especie = inf.de_especie
	and ppv.de_serie = inf.de_serie
	and ppv.cd_produto = inf.cd_produto
	and coalesce(ppv.nr_sequencial,1) = coalesce(inf.nr_sequencial, 1)
left outer join (		select infd1.cd_filial, infd1.nr_nf, infd1.de_especie, infd1.de_serie, infd1.cd_produto, infd1.nr_sequencial, sum(infd1.qt_devolvida) as qt_devolvida
						From item_nf_devolucao_venda infd1 
						inner join nf_devolucao_venda nfd1
							On nfd1.cd_filial		= infd1.cd_filial
							And nfd1.nr_nf			= infd1.nr_nf
							And nfd1.de_especie	= infd1.de_especie
							And nfd1.de_serie		= infd1.de_serie
						inner join nf_venda nfv1
							On nfv1.cd_filial		= nfd1.cd_filial_venda
							And nfv1.nr_nf			= nfd1.nr_nf_venda
							And nfv1.de_especie	= nfd1.de_especie_venda
							And nfv1.de_serie		= nfd1.de_serie_venda
						where nfd1.dh_cancelamento is null
							and nfv1.dh_movimentacao_caixa     between :dh_inicio and :dh_termino
							and nfd1.dh_movimentacao_caixa >= :dh_inicio
						group by infd1.cd_filial, infd1.nr_nf, infd1.de_especie, infd1.de_serie, infd1.cd_produto, infd1.nr_sequencial) infd
	On infd.cd_filial				= inf.cd_filial
	And infd.nr_nf				= inf.nr_nf
	And infd.de_especie		= inf.de_especie
	And infd.de_serie			= inf.de_serie
	And infd.cd_produto		= inf.cd_produto
	And coalesce(infd.nr_sequencial,1)	= inf.nr_sequencial
left outer join cliente cli
 on cli.cd_cliente = nf.cd_cliente
left outer join convenio cv
 on cv.cd_convenio = nf.cd_convenio
left outer join conveniado cvo
 on cvo.cd_convenio = nf.cd_convenio
  and cvo.cd_conveniado = nf.cd_conveniado
left outer join usuario uop
 on uop.nr_matricula = nf.nr_matric_operador
left outer join usuario uov
 on uov.nr_matricula = nf.nr_matricula_vendedor
WHERE nf.dh_movimentacao_caixa     between :dh_inicio and :dh_termino
	and inf.vl_preco_unitario 	<> inf.vl_preco_praticado 
	and (inf.id_alteracao_preco 	= 'S' or (nf.id_sistema_novo='S' and infvd.id_tipo_desconto='PVE'))
	and (inf.qt_vendida - coalesce(infd.qt_devolvida,0)) > 0
	and nf.dh_cancelamento      is null
	and nf.nr_nf_anexa             is null" arguments=(("dh_inicio", date),("dh_termino", date)) )
