table(column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_venda.nr_nf" dbalias="n.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_venda.de_especie" dbalias="n.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_venda.de_serie" dbalias="n.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_venda.dh_emissao" dbalias="n.dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_venda.dh_movimentacao_caixa" dbalias="n.dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_venda.cd_filial" dbalias="n.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=usuario_liberacao dbname="usuario_liberacao" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_venda dbname="nf_venda.id_tipo_venda" dbalias="n.id_tipo_venda" values="$$HEX1$$c000$$ENDHEX$$ VISTA	AV/CREDI$$HEX1$$c100$$ENDHEX$$RIO	CR/CONV$$HEX1$$ca00$$ENDHEX$$NIO	CV/CONTA CORRENTE	CC/" )
 column=(type=long updatewhereclause=yes name=qt_produto dbname="qt_produto" )
 retrieve="  SELECT n.nr_nf,   
         n.de_especie,   
         n.de_serie,   
         n.dh_emissao,
		n.dh_movimentacao_caixa,   
         n.cd_filial,   
         case when n.nr_matric_alteracao_preco is not null then nm_usuario else case when infd.id_tipo_desconto = 'PVE' then 'PRESTES A VENCER' else '' end end usuario_liberacao,
		n.id_tipo_venda,
		count(i.cd_produto) as qt_produto
    FROM nf_venda n
Inner Join  item_nf_venda i
	On   i.cd_filial		= n.cd_filial 
     and i.nr_nf			= n.nr_nf 
     and i.de_especie	= n.de_especie 
     and i.de_serie		= n.de_serie 
Left Outer Join usuario u
	On u.nr_matricula = n.nr_matric_alteracao_preco
Left Outer Join item_nf_venda_desconto infd
	on infd.cd_filial = i.cd_filial
	and infd.nr_nf = i.nr_nf
	and infd.de_especie = i.de_especie
	and infd.de_serie = i.de_serie
	and infd.cd_produto = i.cd_produto
	and coalesce(infd.nr_sequencial,1) = i.nr_sequencial
WHERE i.vl_preco_unitario	<> i.vl_preco_praticado
	and i.id_alteracao_preco	= 'S'
	and n.dh_cancelamento	is null
	and n.nr_nf_anexa			is null
Group by		n.nr_nf, 
				n.de_especie, 
				n.de_serie, 
				n.dh_emissao,
			  	n.dh_movimentacao_caixa, 
				n.cd_filial, 
				case when n.nr_matric_alteracao_preco is not null then nm_usuario else case when infd.id_tipo_desconto = 'PVE' then 'PRESTES A VENCER' else '' end end, 
				n.id_tipo_venda"  sort="dh_movimentacao_caixa A nr_nf A de_especie A de_serie A " )
