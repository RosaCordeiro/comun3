table(column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_venda.cd_produto" dbalias="i.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=produto_geral_de_produto dbname="produto_geral.de_produto" dbalias="g.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=produto_geral_de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="g.de_apresentacao_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_venda.vl_preco_unitario" dbalias="i.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_tabela dbname="item_nf_venda.pc_desconto_tabela" dbalias="i.pc_desconto_tabela" )
 column=(type=decimal(15) updatewhereclause=yes name=liquido dbname="liquido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_praticado dbname="item_nf_venda.vl_preco_praticado" dbalias="i.vl_preco_praticado" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="item_nf_venda.qt_vendida" dbalias="i.qt_vendida" )
 retrieve="Select	i.cd_produto,
		g.de_produto,
		g.de_apresentacao_venda,
		i.vl_preco_unitario,
		i.pc_desconto_tabela,
		i.vl_preco_unitario - ( (  i.vl_preco_unitario *  i.pc_desconto_tabela ) / 100 ) As liquido,
		i.vl_preco_praticado,
		i.qt_vendida
From item_nf_venda As i
	Inner Join produto_geral As g
		On g.cd_produto = i.cd_produto
Where i.cd_filial = :cd_filial
	And i.nr_nf = :nr_nf
	And i.de_especie = :de_especie
	And i.de_serie = :de_serie
	And i.id_alteracao_preco = 'S'" arguments=(("cd_filial", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
