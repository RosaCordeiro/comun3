table(column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_venda.cd_produto" dbalias="i.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=produto_geral_de_produto dbname="produto_geral.de_produto" dbalias="g.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=produto_geral_de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="g.de_apresentacao_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_venda.vl_preco_unitario" dbalias="i.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_tabela dbname="item_nf_venda.pc_desconto_tabela" dbalias="i.pc_desconto_tabela" )
 column=(type=decimal(15) updatewhereclause=yes name=liquido dbname="liquido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_praticado dbname="item_nf_venda.vl_preco_praticado" dbalias="i.vl_preco_praticado" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="item_nf_venda.qt_vendida" dbalias="i.qt_vendida" )
 column=(type=char(16) updatewhereclause=yes name=tipo_desconto dbname="tipo_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="movimento_estoque.vl_custo_unitario" dbalias="me.vl_custo_unitario" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_comissao dbname="vl_comissao" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_pis_cofins dbname="vl_pis_cofins" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_icms dbname="vl_icms" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_rentabilidade dbname="vl_rentabilidade" )
 column=(type=decimal(23) updatewhereclause=yes name=perc_rentabilidade dbname="perc_rentabilidade" )
 retrieve="Select	i.cd_produto,
		g.de_produto,
		g.de_apresentacao_venda,
		i.vl_preco_unitario,
		i.pc_desconto_tabela,
          case when n.dh_movimentacao_caixa >= '20190601' then  
		  i.vl_preco_unitario - ( (  i.vl_preco_unitario *  infd.pc_desconto_tabela ) / 100 )
          else
		  i.vl_preco_unitario - ( (  i.vl_preco_unitario *  i.pc_desconto_tabela ) / 100 ) end As liquido,
		i.vl_preco_praticado,
		i.qt_vendida,
		Case
            When infd.id_tipo_desconto = 'NEG' Then 'COBRE PRE$$HEX1$$c700$$ENDHEX$$O'
            When n.nr_matric_alteracao_preco Is Null And infd.id_tipo_desconto = 'PVE' Then 'PRESTES A VENCER'
		End As tipo_desconto,

		me.vl_custo_unitario As vl_custo_unitario,
		round(i.vl_preco_praticado * (i.pc_comissao_extra / 100),2) As vl_comissao,
		round(i.vl_preco_praticado * (Cast(p.vl_parametro As Numeric(5,2)) / 100), 2) as vl_pis_cofins ,
		round(i.vl_preco_praticado * (i.pc_icms / 100), 2) as vl_icms,
		((i.vl_preco_praticado) - round(i.vl_preco_praticado * (i.pc_comissao_extra / 100),2) - (me.vl_custo_unitario)) as vl_rentabilidade,
		round(((i.vl_preco_praticado) - round(i.vl_preco_praticado * (i.pc_comissao_extra / 100),2) - (me.vl_custo_unitario)) / i.vl_preco_unitario * 100, 2) as perc_rentabilidade
From nf_venda As n
	Inner Join item_nf_venda As i
		On i.cd_filial = n.cd_filial
		And i.nr_nf = n.nr_nf
		And i.de_especie = n.de_especie
		And i.de_serie = n.de_serie
	Inner Join produto_geral As g
		On g.cd_produto = i.cd_produto
	inner join movimento_estoque me
		on me.cd_filial_movimento = i.cd_filial
		and me.nr_nf = i.nr_nf
		and me.de_serie = i.de_serie
		and me.de_especie = i.de_especie
		and me.cd_produto = i.cd_produto
		and coalesce(me.nr_sequencial, 1) = coalesce(i.nr_sequencial, 1)
	Left Outer Join item_nf_venda_desconto As infd
		On infd.cd_filial = i.cd_filial
		And infd.nr_nf = i.nr_nf
		And infd.de_especie = i.de_especie
		And infd.de_serie = i.de_serie
		And infd.cd_produto = i.cd_produto
		And coalesce(infd.nr_sequencial,1) = i.nr_sequencial
	Left Outer Join parametro_geral p
		On p.cd_parametro = 'PC_PIS_COFINS_RENTABILIDADE'
Where i.cd_filial = :cd_filial
	And i.nr_nf = :nr_nf
	And i.de_especie = :de_especie
	And i.de_serie = :de_serie
	And (i.id_alteracao_preco = 'S' or (n.id_sistema_novo='S' and infd.id_tipo_desconto='PVE')) " arguments=(("cd_filial", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
