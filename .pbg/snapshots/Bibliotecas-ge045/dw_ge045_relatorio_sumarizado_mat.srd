table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_venda.cd_filial" dbalias="n.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=decimal(2) updatewhereclause=yes name=preco_liquido dbname="preco_liquido" )
 column=(type=decimal(2) updatewhereclause=yes name=preco_praticado dbname="preco_praticado" )
 column=(type=long updatewhereclause=yes name=qtde dbname="qtde" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_desc dbname="pc_desc" )
 retrieve="  SELECT n.cd_filial,   
		 f.nm_fantasia,   
         sum(((inf.qt_vendida - coalesce(infd.qt_devolvida,0)) * inf.vl_preco_unitario)) as preco_liquido,   
		sum(((inf.qt_vendida - coalesce(infd.qt_devolvida,0)) * inf.vl_preco_praticado)) as preco_praticado,   
         sum(inf.qt_vendida - coalesce(infd.qt_devolvida,0)) as qtde,
		cast(0.00 as numeric(18,4)) as pc_desc
    FROM nf_venda n
inner join item_nf_venda inf
	 on 	inf.cd_filial  		= n.cd_filial
	 and 	inf.nr_nf 			= n.nr_nf 
	 and 	inf.de_especie 	= n.de_especie 
	 and	inf.de_serie 		= n.de_serie 
inner join produto_geral p
	on 	p.cd_produto 	= inf.cd_produto
inner join filial  f
	 on 	f.cd_filial			= n.cd_filial
left outer join usuario u
	on 	u.nr_matricula 	= n.nr_matric_alteracao_preco 
left outer join nf_devolucao_venda nfd
	on 	nfd.cd_filial_venda			= n.cd_filial
	and 	nfd.nr_nf_venda			= n.nr_nf
	and 	nfd.de_especie_venda 	= n.de_especie
	and 	nfd.de_serie_venda	 	= n.de_serie
left outer join item_nf_devolucao_venda infd
	on 	infd.cd_filial			= nfd.cd_filial
	and 	infd.nr_nf			= nfd.nr_nf
	and 	infd.de_especie 	= nfd.de_especie
	and 	infd.de_serie	 	= nfd.de_serie
	and 	infd.cd_produto	 	= inf.cd_produto
left outer join item_nf_venda_desconto infdesc  (index pk_item_nf_venda_desconto)
	 on infdesc.cd_filial 		= inf.cd_filial
	  and infdesc.nr_nf 			= inf.nr_nf
	  and infdesc.de_especie 	= inf.de_especie
	  and infdesc.de_serie		= inf.de_serie
	  and infdesc.cd_produto 	= inf.cd_produto
	  and coalesce(infdesc.nr_sequencial,1) = inf.nr_sequencial
WHERE inf.vl_preco_unitario 	<> inf.vl_preco_praticado 
	and (inf.id_alteracao_preco 	= 'S' or (n.id_sistema_novo='S' and infdesc.id_tipo_desconto='PVE'))
	and (inf.qt_vendida - coalesce(infd.qt_devolvida,0)) > 0
	and n.dh_cancelamento      is null
	and n.nr_nf_anexa             is null 
group by n.cd_filial,   
		 f.nm_fantasia "  sort="pc_desc A " )
