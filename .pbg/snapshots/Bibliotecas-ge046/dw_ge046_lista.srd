table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_cidade dbname="cidade.cd_cidade" )
 column=(type=char(2) update=yes updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" )
 column=(type=char(5) update=yes updatewhereclause=yes name=cd_controle_bms dbname="cidade.cd_controle_bms" )
 column=(type=char(7) updatewhereclause=yes name=cd_cidade_ibge dbname="cidade.cd_cidade_ibge" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf_ibge dbname="unidade_federacao.cd_uf_ibge" )
 retrieve="  SELECT c.cd_cidade ,
         c.cd_unidade_federacao ,
         c.nm_cidade ,
         c.cd_controle_bms ,
         c.cd_cidade_ibge,
         u.cd_uf_ibge   
    FROM cidade c,
         unidade_federacao u
  WHERE  c.cd_unidade_federacao = u.cd_unidade_federacao    " update="cidade" updatewhere=0 updatekeyinplace=no  sort="nm_cidade A " )
