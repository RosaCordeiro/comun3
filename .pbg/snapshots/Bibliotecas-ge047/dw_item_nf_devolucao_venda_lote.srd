table(column=(type=long updatewhereclause=yes name=cd_filial dbname="item_nf_devolucao_venda_lote.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="item_nf_devolucao_venda_lote.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="item_nf_devolucao_venda_lote.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="item_nf_devolucao_venda_lote.de_serie" )
 column=(type=char(1) updatewhereclause=yes name=id_origem_nf dbname="item_nf_devolucao_venda_lote.id_origem_nf" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="item_nf_devolucao_venda_lote.cd_natureza_operacao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_devolucao_venda_lote.cd_produto" )
 column=(type=char(10) updatewhereclause=yes name=nr_lote dbname="item_nf_devolucao_venda_lote.nr_lote" )
 column=(type=long updatewhereclause=yes name=qt_lote dbname="item_nf_devolucao_venda_lote.qt_lote" )
 retrieve="  SELECT i.cd_filial,   
         i.nr_nf,   
         i.de_especie,   
         i.de_serie,   
         i.id_origem_nf,   
         i.cd_natureza_operacao,   
         i.cd_produto,   
         i.nr_lote,   
         i.qt_lote
    FROM item_nf_devolucao_venda_lote i,   
         nf_devolucao_venda n  
   WHERE n.cd_filial 	 = :filial
     and n.dh_exportacao = :data_base    
	  and n.cd_filial    = i.cd_filial
     and n.nr_nf 		 = i.nr_nf
     and n.de_especie    = i.de_especie
     and n.de_serie 	 = i.de_serie
     and n.id_origem_nf  = i.id_origem_nf

" arguments=(("filial", number),("data_base", date)) )
