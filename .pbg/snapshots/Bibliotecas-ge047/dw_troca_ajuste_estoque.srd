 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_custo_unitario dbname="ajuste_estoque.vl_custo_unitario" )
 retrieve="select a.nr_ajuste,   
       p.cd_filial cd_filial_ajuste,   
       a.cd_produto,   
       a.dh_ajuste,   
       a.dh_movimentacao_caixa,   
       a.qt_ajuste,   
       a.id_entrada_saida,   
       a.cd_motivo_ajuste,   
       a.nr_matricula_responsavel,   
       a.de_comentario_ajuste,   
       a.vl_custo_unitario  
from ajuste_estoque a,
     parametro p  
where dh_movimentacao_caixa = :data_base
" arguments=(("data_base", date)) )
