table(column=(type=number update=yes updatewhereclause=yes name=nr_ajuste dbname="ajuste_estoque.nr_ajuste" dbalias="a.nr_ajuste" )
 column=(type=long updatewhereclause=yes name=cd_filial_ajuste dbname="parametro.cd_filial_ajuste" dbalias="p.cd_filial_ajuste" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="ajuste_estoque.cd_produto" dbalias="a.cd_produto" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_ajuste dbname="ajuste_estoque.dh_ajuste" dbalias="a.dh_ajuste" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_movimentacao_caixa dbname="ajuste_estoque.dh_movimentacao_caixa" dbalias="a.dh_movimentacao_caixa" )
 column=(type=long update=yes updatewhereclause=yes name=qt_ajuste dbname="ajuste_estoque.qt_ajuste" dbalias="a.qt_ajuste" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_entrada_saida dbname="ajuste_estoque.id_entrada_saida" dbalias="a.id_entrada_saida" )
 column=(type=long update=yes updatewhereclause=yes name=cd_motivo_ajuste dbname="ajuste_estoque.cd_motivo_ajuste" dbalias="a.cd_motivo_ajuste" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_responsavel dbname="ajuste_estoque.nr_matricula_responsavel" dbalias="a.nr_matricula_responsavel" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_comentario_ajuste dbname="ajuste_estoque.de_comentario_ajuste" dbalias="a.de_comentario_ajuste" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_custo_unitario dbname="ajuste_estoque.vl_custo_unitario" dbalias="a.vl_custo_unitario" )
 column=(type=char(10) updatewhereclause=yes name=nr_lote dbname="ajuste_estoque.nr_lote" dbalias="a.nr_lote" )
 retrieve="select a.nr_ajuste,   
       p.cd_filial cd_filial_ajuste,   
       a.cd_produto,   
       a.dh_ajuste,   
       a.dh_movimentacao_caixa,   
       a.qt_ajuste,   
       a.id_entrada_saida,   
       a.cd_motivo_ajuste,   
       a.nr_matricula_responsavel,   
       a.de_comentario_ajuste,   
       a.vl_custo_unitario,
	   a.nr_lote
from ajuste_estoque a,
     parametro p  
where dh_movimentacao_caixa = :data_base
" arguments=(("data_base", date)) )
