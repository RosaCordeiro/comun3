 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"aliquota_mapa_resumo_ecf~" )  TABLE(NAME=~"mapa_resumo~" ) COLUMN(NAME=~"aliquota_mapa_resumo_ecf.cd_filial~") COLUMN(NAME=~"aliquota_mapa_resumo_ecf.nr_mapa~") COLUMN(NAME=~"aliquota_mapa_resumo_ecf.de_especie~") COLUMN(NAME=~"aliquota_mapa_resumo_ecf.de_serie~") COLUMN(NAME=~"aliquota_mapa_resumo_ecf.nr_ecf~") COLUMN(NAME=~"aliquota_mapa_resumo_ecf.pc_aliquota~") COLUMN(NAME=~"aliquota_mapa_resumo_ecf.vl_base_calculo~") COLUMN(NAME=~"aliquota_mapa_resumo_ecf.vl_icms~")    JOIN (LEFT=~"aliquota_mapa_resumo_ecf.cd_filial~"    OP =~"=~"RIGHT=~"mapa_resumo.cd_filial~" )    JOIN (LEFT=~"mapa_resumo.nr_mapa~"    OP =~"=~"RIGHT=~"aliquota_mapa_resumo_ecf.nr_mapa~" )    JOIN (LEFT=~"mapa_resumo.de_especie~"    OP =~"=~"RIGHT=~"aliquota_mapa_resumo_ecf.de_especie~" )    JOIN (LEFT=~"mapa_resumo.de_serie~"    OP =~"=~"RIGHT=~"aliquota_mapa_resumo_ecf.de_serie~" )WHERE(    EXP1 =~"aliquota_mapa_resumo_ecf.cd_filial~"   OP =~"=~"    EXP2 =~":cd_filial~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"mapa_resumo.dh_movimentacao_caixa~"   OP =~"=~"    EXP2 =~":data_base~" ) ) ARG(NAME = ~"cd_filial~" TYPE = number)  ARG(NAME = ~"data_base~" TYPE = date) " arguments=(("cd_filial", number),("data_base", date)) )
