 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="item_nf_venda.cd_natureza_operacao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_venda.cd_produto" )
 column=(type=char(2) updatewhereclause=yes name=cd_situacao_tributaria dbname="item_nf_venda.cd_situacao_tributaria" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="item_nf_venda.qt_vendida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_venda.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_tabela dbname="item_nf_venda.pc_desconto_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_praticado dbname="item_nf_venda.vl_preco_praticado" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="item_nf_venda.pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_comissao_extra dbname="item_nf_venda.pc_comissao_extra" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_comissao_normal dbname="item_nf_venda.pc_comissao_normal" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao_preco dbname="item_nf_venda.id_alteracao_preco" )
 column=(type=char(1) updatewhereclause=yes name=id_restricao_convenio dbname="item_nf_venda.id_restricao_convenio" )
 column=(type=char(1) updatewhereclause=yes name=id_comissionado dbname="item_nf_venda.id_comissionado" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="nf_venda.dh_cancelamento" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_cancelamento dbname="nf_venda.nr_matricula_cancelamento" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_pontos_clube dbname="item_nf_venda.qt_pontos_clube" )
 retrieve="  SELECT i.cd_filial,   
         i.nr_nf,   
         i.de_especie,   
         i.de_serie,   
         i.cd_natureza_operacao,   
         i.cd_produto,   
         i.cd_situacao_tributaria,   
         i.qt_vendida,   
         i.vl_preco_unitario,   
         i.pc_desconto_tabela,   
         i.vl_preco_praticado,   
         i.pc_icms,   
         i.pc_comissao_extra,   
         i.pc_comissao_normal,   
         i.id_alteracao_preco,   
         i.id_restricao_convenio,   
         i.id_comissionado,   
         n.dh_cancelamento,   
         n.nr_matricula_cancelamento,   
         i.qt_pontos_clube  
    FROM item_nf_venda i,   
         nf_venda n  
   WHERE ( n.cd_filial = i.cd_filial ) and  
         ( n.nr_nf = i.nr_nf ) and  
         ( n.de_especie = i.de_especie ) and  
         ( n.de_serie = i.de_serie ) and  
         ( ( n.cd_filial = :filial ) AND  
         ( n.dh_movimentacao_caixa = :data_base ) )    
" arguments=(("filial", number),("data_base", date)) )
