table(column=(type=long updatewhereclause=yes name=cd_filial dbname="item_nf_venda.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="item_nf_venda.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="item_nf_venda.de_especie" )
