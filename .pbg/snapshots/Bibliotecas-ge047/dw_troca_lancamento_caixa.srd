       nr_recibo_cobranca,   
       id_estorno,
	  nr_documento,
	  cd_filial_transferencia
from lancamento_caixa  
where dh_exportacao = :data_base" update="lancamento_caixa" updatewhere=0 updatekeyinplace=no arguments=(("data_base", date)) )
