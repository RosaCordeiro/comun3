 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"mapa_resumo~" )  TABLE(NAME=~"mapa_resumo_ecf~" ) COLUMN(NAME=~"mapa_resumo_ecf.cd_filial~") COLUMN(NAME=~"mapa_resumo_ecf.nr_mapa~") COLUMN(NAME=~"mapa_resumo_ecf.de_especie~") COLUMN(NAME=~"mapa_resumo_ecf.de_serie~") COLUMN(NAME=~"mapa_resumo_ecf.nr_ecf~") COLUMN(NAME=~"mapa_resumo_ecf.nr_operacao_inicial~") COLUMN(NAME=~"mapa_resumo_ecf.nr_operacao_final~") COLUMN(NAME=~"mapa_resumo_ecf.vl_total_geral_inicial~") COLUMN(NAME=~"mapa_resumo_ecf.vl_total_geral_final~") COLUMN(NAME=~"mapa_resumo_ecf.vl_cancelamento~") COLUMN(NAME=~"mapa_resumo_ecf.vl_desconto~") COLUMN(NAME=~"mapa_resumo_ecf.vl_contabil~") COLUMN(NAME=~"mapa_resumo_ecf.vl_isenta~") COLUMN(NAME=~"mapa_resumo_ecf.vl_nao_incidencia~") COLUMN(NAME=~"mapa_resumo_ecf.vl_st~") COLUMN(NAME=~"mapa_resumo_ecf.qt_reducao_z~")    JOIN (LEFT=~"mapa_resumo_ecf.cd_filial~"    OP =~"=~"RIGHT=~"mapa_resumo.cd_filial~" )    JOIN (LEFT=~"mapa_resumo_ecf.nr_mapa~"    OP =~"=~"RIGHT=~"mapa_resumo.nr_mapa~" )    JOIN (LEFT=~"mapa_resumo_ecf.de_especie~"    OP =~"=~"RIGHT=~"mapa_resumo.de_especie~" )    JOIN (LEFT=~"mapa_resumo_ecf.de_serie~"    OP =~"=~"RIGHT=~"mapa_resumo.de_serie~" )WHERE(    EXP1 =~"mapa_resumo_ecf.cd_filial~"   OP =~"=~"    EXP2 =~":cd_filial~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"mapa_resumo.dh_movimentacao_caixa~"   OP =~">=~"    EXP2 =~":data_base~" ) ) ARG(NAME = ~"cd_filial~" TYPE = number)  ARG(NAME = ~"data_base~" TYPE = date) " arguments=(("cd_filial", number),("data_base", date)) )
