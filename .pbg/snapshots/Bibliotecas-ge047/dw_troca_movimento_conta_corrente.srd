 column=(type=long update=yes updatewhereclause=yes name=nr_sequencial_fechamento dbname="movimento_conta_corrente.nr_sequencial_fechamento" )
 retrieve="select cd_cliente,   
       cd_filial_movimento,   
       nr_sequencial,   
       dh_sistema,   
       dh_movimento,   
       nr_matricula_responsavel,   
       cd_tipo_movimento,   
       nr_documento,   
       vl_movimento,   
       id_estorno,   
       de_historico,   
       cd_filial_fechamento,   
       nr_sequencial_fechamento  
from movimento_conta_corrente
where cd_filial_movimento = :filial
  and dh_movimento        = :data_movto
" update="movimento_conta_corrente" updatewhere=1 updatekeyinplace=no arguments=(("filial", number),("data_movto", date)) )
