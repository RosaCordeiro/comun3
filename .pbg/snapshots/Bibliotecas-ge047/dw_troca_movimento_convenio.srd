footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_convenio dbname="movimento_convenio.cd_convenio" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial_movimento dbname="movimento_convenio.cd_filial_movimento" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_movimento dbname="movimento_convenio.nr_movimento" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_sistema dbname="movimento_convenio.dh_sistema" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_movimento dbname="movimento_convenio.dh_movimento" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_responsavel dbname="movimento_convenio.nr_matricula_responsavel" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_movimento dbname="movimento_convenio.vl_movimento" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_credito_debito dbname="movimento_convenio.id_credito_debito" )
 column=(type=char(15) update=yes updatewhereclause=yes name=nr_documento dbname="movimento_convenio.nr_documento" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_historico dbname="movimento_convenio.de_historico" )
 retrieve="select cd_convenio,   
       cd_filial_movimento,   
       nr_movimento,   
       dh_sistema,   
       dh_movimento,   
       nr_matricula_responsavel,   
       vl_movimento,   
       id_credito_debito,   
       nr_documento,   
       de_historico  
from movimento_convenio
where cd_filial_movimento = :filial
  and dh_movimento        = :data_movto
" update="movimento_convenio" updatewhere=1 updatekeyinplace=no arguments=(("filial", number),("data_movto", date)) )
