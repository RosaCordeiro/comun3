 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_icms_repassado dbname="nf_compra.vl_icms_repassado" dbalias=".vl_icms_repassado" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_total_produtos dbname="nf_compra.vl_total_produtos" dbalias=".vl_total_produtos" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_ipi dbname="nf_compra.vl_ipi" dbalias=".vl_ipi" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_frete dbname="nf_compra.vl_frete" dbalias=".vl_frete" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_seguro dbname="nf_compra.vl_seguro" dbalias=".vl_seguro" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_outras_despesas dbname="nf_compra.vl_outras_despesas" dbalias=".vl_outras_despesas" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_desconto dbname="nf_compra.vl_desconto" dbalias=".vl_desconto" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_indenizacao dbname="nf_compra.vl_indenizacao" dbalias=".vl_indenizacao" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_total_nf dbname="nf_compra.vl_total_nf" dbalias=".vl_total_nf" )
 column=(type=char(1) updatewhereclause=yes name=id_entrada_matriz dbname="nf_compra.id_entrada_matriz" dbalias=".id_entrada_matriz" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_compra.de_chave_acesso" dbalias=".de_chave_acesso" )
 column=(type=char(1) updatewhereclause=yes name=id_bonificacao dbname="nf_compra.id_bonificacao" dbalias=".id_bonificacao" )
 retrieve="select cd_filial,   
       cd_fornecedor,   
       nr_nf,   
       de_especie,   
       de_serie,   
       dh_recebimento,   
       dh_movimentacao_caixa,   
       vl_bc_icms,   
       vl_icms,   
       vl_bc_icms_st,   
       vl_icms_st,   
       vl_icms_repassado,   
       vl_total_produtos,   
       vl_ipi,   
       vl_frete,   
       vl_seguro,   
       vl_outras_despesas,   
       vl_desconto,   
       vl_indenizacao,   
       vl_total_nf,
       id_entrada_matriz,
       de_chave_acesso,
	  id_bonificacao
from nf_compra  
where dh_movimentacao_caixa = :data_base
  and id_entrada_matriz in ('N', 'T')
" update="nf_compra" updatewhere=1 updatekeyinplace=no arguments=(("filial", number),("data_base", date)) )
