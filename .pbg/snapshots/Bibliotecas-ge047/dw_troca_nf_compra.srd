table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="nf_compra.cd_filial" dbalias=".cd_filial" )
 column=(type=char(9) update=yes updatewhereclause=yes key=yes name=cd_fornecedor dbname="nf_compra.cd_fornecedor" dbalias=".cd_fornecedor" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_nf dbname="nf_compra.nr_nf" dbalias=".nr_nf" )
