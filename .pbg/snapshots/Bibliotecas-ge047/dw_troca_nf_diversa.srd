 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_diversa.dh_movimentacao_caixa" )
 retrieve="  SELECT nf_diversa.cd_filial_origem,   
         nf_diversa.nr_nf,   
         nf_diversa.de_especie,   
         nf_diversa.de_serie,   
         nf_diversa.cd_natureza_operacao,   
         nf_diversa.de_natureza_operacao,   
         nf_diversa.dh_emissao,   
         nf_diversa.vl_bc_icms,   
         nf_diversa.vl_icms,   
         nf_diversa.vl_bc_icms_st,   
         nf_diversa.vl_icms_st,   
         nf_diversa.vl_frete,   
         nf_diversa.vl_outras_despesas,   
         nf_diversa.vl_seguro,   
         nf_diversa.vl_total_produtos,   
         nf_diversa.vl_total_nf,   
         nf_diversa.nm_destinatario,   
         nf_diversa.nr_cgc_cpf,   
         nf_diversa.nr_inscricao_estadual,   
         nf_diversa.nm_cidade,   
         nf_diversa.nm_uf,   
         nf_diversa.de_endereco,   
         nf_diversa.de_bairro,   
         nf_diversa.nr_cep,   
         nf_diversa.nr_telefone,   
         nf_diversa.dh_cancelamento,
			nf_diversa.nr_nsu,
			nf_diversa.dh_movimentacao_caixa
    FROM nf_diversa  
   WHERE nf_diversa.dh_movimentacao_caixa = :data_movto
" update="nf_diversa" updatewhere=1 updatekeyinplace=no arguments=(("data_movto", date)) )
