 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="item_nf_compra.pc_desconto" dbalias="i.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="item_nf_compra.pc_icms" dbalias="i.pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_ipi dbname="item_nf_compra.pc_ipi" dbalias="i.pc_ipi" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_base_icms_st dbname="item_nf_compra.vl_preco_base_icms_st" dbalias="i.vl_preco_base_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="item_nf_compra.vl_icms_st" dbalias="i.vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_st dbname="item_nf_compra.pc_icms_st" dbalias="i.pc_icms_st" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_bc_icms dbname="item_nf_compra.vl_bc_icms" dbalias="i.vl_bc_icms" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_icms dbname="item_nf_compra.vl_icms" dbalias="i.vl_icms" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_bc_ipi dbname="item_nf_compra.vl_bc_ipi" dbalias="i.vl_bc_ipi" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_ipi dbname="item_nf_compra.vl_ipi" dbalias="i.vl_ipi" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_outras_despesas dbname="item_nf_compra.vl_outras_despesas" dbalias="i.vl_outras_despesas" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_st_total dbname="item_nf_compra.vl_bc_icms_st_total" dbalias="i.vl_bc_icms_st_total" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st_total dbname="item_nf_compra.vl_icms_st_total" dbalias="i.vl_icms_st_total" )
 retrieve="select i.cd_filial,   
		 i.cd_fornecedor,   
		 i.nr_nf,   
		 i.de_especie,   
		 i.de_serie,   
		 i.cd_natureza_operacao,   
		 i.cd_produto,   
		 i.cd_situacao_tributaria,   
		 i.qt_faturada,   
		 i.qt_recebida,   
		 i.vl_preco_unitario,   
		 i.pc_desconto,   
		 i.pc_icms,   
		 i.pc_ipi,
		 i.vl_preco_base_icms_st,
		 i.vl_icms_st,
		 i.pc_icms_st,
		 i.vl_bc_icms,
		i.vl_icms,
		i.vl_bc_ipi,
		i.vl_ipi,
		i.vl_outras_despesas,
		i.vl_bc_icms_st_total,
		i.vl_icms_st_total
from item_nf_compra i,   
     nf_compra n  
where n.cd_filial             = :filial
  and n.dh_movimentacao_caixa = :data_base
  and n.id_entrada_matriz in ('N', 'T')
  and i.cd_filial     = n.cd_filial
  and i.cd_fornecedor = n.cd_fornecedor
  and i.nr_nf         = n.nr_nf
  and i.de_especie    = n.de_especie
  and i.de_serie      = n.de_serie
" arguments=(("filial", number),("data_base", date)) )
