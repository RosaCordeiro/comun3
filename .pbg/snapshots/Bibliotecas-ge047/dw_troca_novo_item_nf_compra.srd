table(column=(type=long updatewhereclause=yes name=cd_filial dbname="item_nf_compra.cd_filial" dbalias="i.cd_filial" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="item_nf_compra.cd_fornecedor" dbalias="i.cd_fornecedor" )
