 retrieve="select p.cd_filial,
       s.cd_promocao_sos,   
       s.cd_produto,   
       s.qt_estoque_minimo  
from promocao_sos_produto s,
     parametro p
where s.dh_alteracao_estoque = :data_base" arguments=(("data_base", date)) )
