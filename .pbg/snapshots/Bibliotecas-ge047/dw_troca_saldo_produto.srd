 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"saldo_produto~" )  TABLE(NAME=~"parametro~" ) COLUMN(NAME=~"parametro.cd_filial~") COLUMN(NAME=~"saldo_produto.cd_produto~") COLUMN(NAME=~"saldo_produto.dh_saldo~") COLUMN(NAME=~"saldo_produto.vl_custo_medio~")WHERE(    EXP1 =~"parametro.id_parametro~"   OP =~"=~"    EXP2 =~"'1'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"saldo_produto.dh_atualizacao_custo~"   OP =~"=~"    EXP2 =~":data_base~" ) ) ARG(NAME = ~"data_base~" TYPE = date) " arguments=(("data_base", date)) )
