 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"titulo_pagar~" ) COLUMN(NAME=~"titulo_pagar.cd_filial~") COLUMN(NAME=~"titulo_pagar.cd_fornecedor~") COLUMN(NAME=~"titulo_pagar.nr_titulo_pagar~") COLUMN(NAME=~"titulo_pagar.dh_emissao~") COLUMN(NAME=~"titulo_pagar.dh_vencimento~") COLUMN(NAME=~"titulo_pagar.vl_pagar~") COLUMN(NAME=~"titulo_pagar.nr_nf~") COLUMN(NAME=~"titulo_pagar.de_especie~") COLUMN(NAME=~"titulo_pagar.de_serie~")WHERE(    EXP1 =~"titulo_pagar.dh_emissao~"   OP =~"=~"    EXP2 =~":data_base~" ) ) ARG(NAME = ~"data_base~" TYPE = date) " update="titulo_pagar" updatewhere=1 updatekeyinplace=no arguments=(("data_base", date)) )
