 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"venda_epharma_produto~" )  TABLE(NAME=~"venda_epharma~" ) COLUMN(NAME=~"venda_epharma_produto.cd_filial~") COLUMN(NAME=~"venda_epharma_produto.nr_nf~") COLUMN(NAME=~"venda_epharma_produto.de_especie~") COLUMN(NAME=~"venda_epharma_produto.de_serie~") COLUMN(NAME=~"venda_epharma_produto.cd_produto~") COLUMN(NAME=~"venda_epharma_produto.qt_vendida~") COLUMN(NAME=~"venda_epharma_produto.vl_preco_maximo~") COLUMN(NAME=~"venda_epharma_produto.vl_preco_com_desconto~") COLUMN(NAME=~"venda_epharma_produto.vl_preco_epharma~") COLUMN(NAME=~"venda_epharma_produto.vl_preco_aquisicao~") COLUMN(NAME=~"venda_epharma_produto.vl_repasse_varejo~")    JOIN (LEFT=~"venda_epharma.cd_filial~"    OP =~"=~"RIGHT=~"venda_epharma_produto.cd_filial~" )    JOIN (LEFT=~"venda_epharma.nr_nf~"    OP =~"=~"RIGHT=~"venda_epharma_produto.nr_nf~" )    JOIN (LEFT=~"venda_epharma.de_especie~"    OP =~"=~"RIGHT=~"venda_epharma_produto.de_especie~" )    JOIN (LEFT=~"venda_epharma.de_serie~"    OP =~"=~"RIGHT=~"venda_epharma_produto.de_serie~" )WHERE(    EXP1 =~"venda_epharma.cd_filial~"   OP =~"=~"    EXP2 =~":filial~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"venda_epharma.dh_venda~"   OP =~"=~"    EXP2 =~":data_base~" ) ) ARG(NAME = ~"filial~" TYPE = number)  ARG(NAME = ~"data_base~" TYPE = date) " arguments=(("filial", number),("data_base", date)) )
