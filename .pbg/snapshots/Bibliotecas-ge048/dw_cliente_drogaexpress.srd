 column=(type=datetime update=yes updatewhereclause=yes name=dh_ultima_compra dbname="cliente_drogaexpress.dh_ultima_compra" )
 retrieve="  SELECT cd_cliente_drogaexpress,   
         nm_cliente,   
         de_endereco,   
         de_referencia,   
         de_bairro,   
         nr_cep,   
         nr_cgc_cpf,   
         nr_inscricao_estadual,   
         cd_conveniado,   
         cd_convenio,   
         cd_cliente,   
         id_fisica_juridica,   
         nr_telefone_principal,   
         nr_telefone_adicional,   
         nr_endereco,   
         de_complemento,   
         dh_atualizacao,   
         dh_ultima_compra  
    FROM cliente_drogaexpress  
   WHERE dh_atualizacao >= :data_base
     And dh_atualizacao < DateAdd(day, 1, :data_base)" update="cliente_drogaexpress" updatewhere=1 updatekeyinplace=no arguments=(("data_base", date)) )
