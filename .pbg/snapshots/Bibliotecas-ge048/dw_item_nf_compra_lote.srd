detail(height=92 color="536870912" )
table(column=(type=long updatewhereclause=yes name=cd_filial dbname="item_nf_compra_lote.cd_filial" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="item_nf_compra_lote.cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="item_nf_compra_lote.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="item_nf_compra_lote.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="item_nf_compra_lote.de_serie" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="item_nf_compra_lote.cd_natureza_operacao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_compra_lote.cd_produto" )
 column=(type=char(10) updatewhereclause=yes name=nr_lote dbname="item_nf_compra_lote.nr_lote" )
 column=(type=long updatewhereclause=yes name=qt_lote dbname="item_nf_compra_lote.qt_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao_estoque dbname="nf_compra.dh_atualizacao_estoque" )
 retrieve="select i.cd_filial,   
		 i.cd_fornecedor,   
		 i.nr_nf,   
		 i.de_especie,   
		 i.de_serie,
		 i.cd_natureza_operacao,   
		 i.cd_produto,
		 i.nr_lote,
		 i.qt_lote,
		 n.dh_atualizacao_estoque
from item_nf_compra_lote i,   
     nf_compra n
where n.cd_filial     = :filial
  and n.dh_exportacao = :data_base
  and i.cd_filial     = n.cd_filial
  and i.cd_fornecedor = n.cd_fornecedor
  and i.nr_nf         = n.nr_nf
  and i.de_especie    = n.de_especie
  and i.de_serie      = n.de_serie" arguments=(("filial", number),("data_base", date)) )
