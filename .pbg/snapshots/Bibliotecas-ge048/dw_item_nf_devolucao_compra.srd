 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"item_nf_devolucao_compra~" )  TABLE(NAME=~"nf_devolucao_compra~" ) COLUMN(NAME=~"item_nf_devolucao_compra.cd_filial~") COLUMN(NAME=~"item_nf_devolucao_compra.nr_nf~") COLUMN(NAME=~"item_nf_devolucao_compra.de_especie~") COLUMN(NAME=~"item_nf_devolucao_compra.de_serie~") COLUMN(NAME=~"item_nf_devolucao_compra.cd_natureza_operacao~") COLUMN(NAME=~"item_nf_devolucao_compra.cd_produto~") COLUMN(NAME=~"item_nf_devolucao_compra.cd_situacao_tributaria~") COLUMN(NAME=~"item_nf_devolucao_compra.qt_devolvida~") COLUMN(NAME=~"item_nf_devolucao_compra.vl_preco_unitario~") COLUMN(NAME=~"item_nf_devolucao_compra.pc_desconto~") COLUMN(NAME=~"item_nf_devolucao_compra.pc_icms~") COLUMN(NAME=~"item_nf_devolucao_compra.pc_ipi~") COLUMN(NAME=~"nf_devolucao_compra.dh_cancelamento~") COLUMN(NAME=~"nf_devolucao_compra.nr_matricula_cancelamento~") COLUMN(NAME=~"item_nf_devolucao_compra.vl_icms_repassado~") COLUMN(NAME=~"item_nf_devolucao_compra.vl_bc_icms_st~") COLUMN(NAME=~"item_nf_devolucao_compra.vl_icms_st~") COLUMN(NAME=~"item_nf_devolucao_compra.vl_bc_icms~") COLUMN(NAME=~"item_nf_devolucao_compra.vl_icms~") COLUMN(NAME=~"item_nf_devolucao_compra.vl_bc_ipi~") COLUMN(NAME=~"item_nf_devolucao_compra.vl_ipi~")    JOIN (LEFT=~"nf_devolucao_compra.cd_filial~"    OP =~"=~"RIGHT=~"item_nf_devolucao_compra.cd_filial~" )    JOIN (LEFT=~"nf_devolucao_compra.nr_nf~"    OP =~"=~"RIGHT=~"item_nf_devolucao_compra.nr_nf~" )    JOIN (LEFT=~"nf_devolucao_compra.de_especie~"    OP =~"=~"RIGHT=~"item_nf_devolucao_compra.de_especie~" )    JOIN (LEFT=~"nf_devolucao_compra.de_serie~"    OP =~"=~"RIGHT=~"item_nf_devolucao_compra.de_serie~" )WHERE(    EXP1 =~"nf_devolucao_compra.cd_filial~"   OP =~"=~"    EXP2 =~":filial~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"nf_devolucao_compra.dh_movimentacao_caixa~"   OP =~"=~"    EXP2 =~":data_base~" ) ) ARG(NAME = ~"filial~" TYPE = number)  ARG(NAME = ~"data_base~" TYPE = date) " arguments=(("filial", number),("data_base", date)) )
