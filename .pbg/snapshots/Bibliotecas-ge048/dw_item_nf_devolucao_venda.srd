 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"item_nf_devolucao_venda~" ALIAS=~"i~" )  TABLE(NAME=~"nf_devolucao_venda~" ALIAS=~"n~" ) COLUMN(NAME=~"i.cd_filial~") COLUMN(NAME=~"i.nr_nf~") COLUMN(NAME=~"i.de_especie~") COLUMN(NAME=~"i.de_serie~") COLUMN(NAME=~"i.id_origem_nf~") COLUMN(NAME=~"i.cd_natureza_operacao~") COLUMN(NAME=~"i.cd_produto~") COLUMN(NAME=~"i.cd_situacao_tributaria~") COLUMN(NAME=~"i.qt_devolvida~") COLUMN(NAME=~"i.vl_preco_unitario~") COLUMN(NAME=~"i.pc_icms~") COLUMN(NAME=~"i.pc_desconto~") COLUMN(NAME=~"i.pc_comissao_normal~") COLUMN(NAME=~"i.pc_comissao_extra~") COLUMN(NAME=~"i.id_comissionado~") COLUMN(NAME=~"n.dh_cancelamento~") COLUMN(NAME=~"n.nr_matricula_cancelamento~") COLUMN(NAME=~"i.qt_pontos_clube~") COLUMN(NAME=~"i.vl_bc_icms~") COLUMN(NAME=~"i.vl_icms~") COLUMN(NAME=~"i.vl_bc_icms_st~") COLUMN(NAME=~"i.vl_icms_st~")    JOIN (LEFT=~"n.cd_filial~"    OP =~"=~"RIGHT=~"i.cd_filial~" )    JOIN (LEFT=~"n.nr_nf~"    OP =~"=~"RIGHT=~"i.nr_nf~" )    JOIN (LEFT=~"n.de_especie~"    OP =~"=~"RIGHT=~"i.de_especie~" )    JOIN (LEFT=~"n.de_serie~"    OP =~"=~"RIGHT=~"i.de_serie~" )    JOIN (LEFT=~"n.id_origem_nf~"    OP =~"=~"RIGHT=~"i.id_origem_nf~" )WHERE(    EXP1 =~"n.cd_filial~"   OP =~"=~"    EXP2 =~":filial~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"n.dh_movimentacao_caixa~"   OP =~"=~"    EXP2 =~":data_base~" ) ) ARG(NAME = ~"filial~" TYPE = number)  ARG(NAME = ~"data_base~" TYPE = date) " arguments=(("filial", number),("data_base", date)) )
