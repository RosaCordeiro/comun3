table(column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="item_nf_diversa.cd_filial_origem" dbalias="i.cd_filial_origem" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="item_nf_diversa.nr_nf" dbalias="i.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="item_nf_diversa.de_especie" dbalias="i.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="item_nf_diversa.de_serie" dbalias="i.de_serie" )
 column=(type=long updatewhereclause=yes name=cd_item dbname="item_nf_diversa.cd_item" dbalias="i.cd_item" )
 column=(type=char(60) updatewhereclause=yes name=de_item dbname="item_nf_diversa.de_item" dbalias="i.de_item" )
 column=(type=char(3) updatewhereclause=yes name=de_unidade_medida dbname="item_nf_diversa.de_unidade_medida" dbalias="i.de_unidade_medida" )
 column=(type=long updatewhereclause=yes name=qt_item dbname="item_nf_diversa.qt_item" dbalias="i.qt_item" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_diversa.vl_preco_unitario" dbalias="i.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="item_nf_diversa.pc_desconto" dbalias="i.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="item_nf_diversa.pc_icms" dbalias="i.pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_st dbname="item_nf_diversa.vl_bc_icms_st" dbalias="i.vl_bc_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="item_nf_diversa.vl_icms_st" dbalias="i.vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms dbname="item_nf_diversa.vl_bc_icms" dbalias="i.vl_bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="item_nf_diversa.vl_icms" dbalias="i.vl_icms" )
 column=(type=char(2) updatewhereclause=yes name=cd_situacao_tributaria dbname="item_nf_diversa.cd_situacao_tributaria" dbalias="i.cd_situacao_tributaria" )
 column=(type=long updatewhereclause=yes name=nr_classificacao_fiscal dbname="item_nf_diversa.nr_classificacao_fiscal" dbalias="i.nr_classificacao_fiscal" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_st dbname="item_nf_diversa.pc_icms_st" dbalias="i.pc_icms_st" )
 column=(type=char(10) updatewhereclause=yes name=cd_bem dbname="item_nf_diversa.cd_bem" dbalias="i.cd_bem" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_outras_despesas dbname="item_nf_diversa.vl_outras_despesas" dbalias="i.vl_outras_despesas" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_ipi dbname="item_nf_diversa.vl_bc_ipi" dbalias="i.vl_bc_ipi" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_ipi dbname="item_nf_diversa.pc_ipi" dbalias="i.pc_ipi" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_ipi dbname="item_nf_diversa.vl_ipi" dbalias="i.vl_ipi" )
 retrieve="select i.cd_filial_origem,   
       i.nr_nf,   
       i.de_especie,   
       i.de_serie,   
       i.cd_item,   
       i.de_item,   
       i.de_unidade_medida,   
       i.qt_item,   
       i.vl_preco_unitario,   
       i.pc_desconto,   
       i.pc_icms,
       i.vl_bc_icms_st,
       i.vl_icms_st, 
       i.vl_bc_icms, 
       i.vl_icms, 
       i.cd_situacao_tributaria, 
       i.nr_classificacao_fiscal, 
       i.pc_icms_st,
	  i.cd_bem,
	  i.vl_outras_despesas,
	  i.vl_bc_ipi,
	  i.pc_ipi,
	  i.vl_ipi
from item_nf_diversa i,   
     nf_diversa n
where n.cd_filial_origem = i.cd_filial_origem
  and n.nr_nf            = i.nr_nf
  and n.de_especie       = i.de_especie
  and n.de_serie         = i.de_serie
  and n.dh_movimentacao_caixa = :data_movto
" arguments=(("data_movto", date)) )
