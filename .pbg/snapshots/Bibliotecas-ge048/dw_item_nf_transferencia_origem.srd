table(column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="item_nf_transferencia.cd_filial_origem" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="item_nf_transferencia.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="item_nf_transferencia.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="item_nf_transferencia.de_serie" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="item_nf_transferencia.cd_natureza_operacao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_transferencia.cd_produto" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="item_nf_transferencia.cd_filial_destino" )
 column=(type=char(2) updatewhereclause=yes name=cd_situacao_tributaria dbname="item_nf_transferencia.cd_situacao_tributaria" )
 column=(type=long updatewhereclause=yes name=qt_transferida dbname="item_nf_transferencia.qt_transferida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="item_nf_transferencia.vl_custo_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="item_nf_transferencia.pc_icms" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="nf_transferencia.dh_cancelamento" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_cancelamento dbname="nf_transferencia.nr_matricula_cancelamento" )
 column=(type=long updatewhereclause=yes name=nr_nsu dbname="nf_transferencia.nr_nsu" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_gerencial dbname="item_nf_transferencia.vl_custo_gerencial" )
 retrieve="select i.cd_filial_origem,   
       i.nr_nf,   
       i.de_especie,   
       i.de_serie,   
       i.cd_natureza_operacao,   
       i.cd_produto,   
       i.cd_filial_destino,   
       i.cd_situacao_tributaria,   
       i.qt_transferida,   
       i.vl_custo_unitario,   
       i.pc_icms,
       n.dh_cancelamento,
       n.nr_matricula_cancelamento,
		 n.nr_nsu,
		 i.vl_custo_gerencial
from item_nf_transferencia i,   
     nf_transferencia n
where n.cd_filial_origem = i.cd_filial_origem
  and n.nr_nf            = i.nr_nf 
  and n.de_especie       = i.de_especie
  and n.de_serie         = i.de_serie
  and n.cd_filial_origem = :filial
  and n.dh_movimentacao_caixa = :data_base
" arguments=(("filial", number),("data_base", date)) )
