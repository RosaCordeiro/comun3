table(column=(type=long updatewhereclause=yes name=cd_filial dbname="lancamento_psico_produto.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="lancamento_psico_produto.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="lancamento_psico_produto.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="lancamento_psico_produto.de_serie" )
 column=(type=long updatewhereclause=yes name=nr_nsr dbname="lancamento_psico_produto.nr_nsr" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="lancamento_psico_produto.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_dispensada dbname="lancamento_psico_produto.qt_dispensada" )
 column=(type=long updatewhereclause=yes name=qt_prescrita dbname="lancamento_psico_produto.qt_prescrita" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_posologia dbname="lancamento_psico_produto.qt_posologia" )
 column=(type=char(20) updatewhereclause=yes name=id_apresentacao dbname="lancamento_psico_produto.id_apresentacao" )
 column=(type=long updatewhereclause=yes name=qt_frequencia dbname="lancamento_psico_produto.qt_frequencia" )
 column=(type=char(1) updatewhereclause=yes name=id_frequencia dbname="lancamento_psico_produto.id_frequencia" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="lancamento_psico_produto.id_situacao" )
 column=(type=char(1) updatewhereclause=yes name=id_estorno dbname="lancamento_psico_produto.id_estorno" )
 retrieve="  SELECT p.cd_filial,   
         p.nr_nf,   
         p.de_especie,   
         p.de_serie,   
         p.nr_nsr,   
         p.cd_produto,   
         p.qt_dispensada,   
         p.qt_prescrita,   
         p.qt_posologia,   
         p.id_apresentacao,   
         p.qt_frequencia,   
         p.id_frequencia,   
         p.id_situacao,   
         p.id_estorno  
    FROM lancamento_psico l,   
         lancamento_psico_produto p  
   WHERE l.dh_exportacao = :data
     AND p.cd_filial		 = l.cd_filial
     AND p.nr_nf			 = l.nr_nf
     AND p.de_especie	 = l.de_especie
     AND p.de_serie		 = l.de_serie
     AND p.nr_nsr			 = l.nr_nsr
" arguments=(("data", date))  sort="cd_filial A nr_nf A de_especie A de_serie A cd_produto A " )
