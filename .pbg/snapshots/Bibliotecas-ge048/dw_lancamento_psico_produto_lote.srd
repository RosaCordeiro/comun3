HA$PBExportHeader$dw_lancamento_psico_produto_lote.srd
release 6;
datawindow(units=0 timer_interval=0 color=80269524 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=136 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=long updatewhereclause=yes name=cd_filial dbname="lancamento_psico_produto_lote.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="lancamento_psico_produto_lote.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="lancamento_psico_produto_lote.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="lancamento_psico_produto_lote.de_serie" )
 column=(type=long updatewhereclause=yes name=nr_nsr dbname="lancamento_psico_produto_lote.nr_nsr" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="lancamento_psico_produto_lote.cd_produto" )
 column=(type=char(10) updatewhereclause=yes name=nr_lote dbname="lancamento_psico_produto_lote.nr_lote" )
 column=(type=long updatewhereclause=yes name=qt_lote dbname="lancamento_psico_produto_lote.qt_lote" )
 retrieve="  SELECT p.cd_filial,   
         p.nr_nf,   
         p.de_especie,   
         p.de_serie,   
         p.nr_nsr,   
         p.cd_produto,   
         p.nr_lote,   
         p.qt_lote  
    FROM lancamento_psico l,
			lancamento_psico_produto  lp,
         lancamento_psico_produto_lote  p
   WHERE l.dh_exportacao = :data
     AND lp.cd_filial	 = l.cd_filial
     AND lp.nr_nf			 = l.nr_nf
     AND lp.de_especie	 = l.de_especie
     AND lp.de_serie		 = l.de_serie
     AND lp.nr_nsr		 = l.nr_nsr
     AND p.cd_filial		 = lp.cd_filial
     AND p.nr_nf			 = lp.nr_nf
     AND p.de_especie	 = lp.de_especie
     AND p.de_serie		 = lp.de_serie
	  AND p.nr_nsr			 = lp.nr_nsr
	  AND p.cd_produto	 = lp.cd_produto" arguments=(("data", date)) )
