table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_devolucao_venda_loja.cd_filial" dbalias="nvl.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_devolucao_venda_loja.nr_nf" dbalias="nvl.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_devolucao_venda_loja.de_especie" dbalias="nvl.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_devolucao_venda_loja.de_serie" dbalias="nvl.de_serie" )
 column=(type=char(1) updatewhereclause=yes name=id_origem_nf dbname="nf_devolucao_venda_loja.id_origem_nf" dbalias="nvl.id_origem_nf" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="nf_devolucao_venda_loja.nm_cliente" dbalias="nvl.nm_cliente" )
 column=(type=char(15) updatewhereclause=yes name=nr_cgc_cpf dbname="nf_devolucao_venda_loja.nr_cgc_cpf" dbalias="nvl.nr_cgc_cpf" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="nf_devolucao_venda_loja.nm_cidade" dbalias="nvl.nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=nm_uf dbname="nf_devolucao_venda_loja.nm_uf" dbalias="nvl.nm_uf" )
 column=(type=char(40) updatewhereclause=yes name=de_endereco dbname="nf_devolucao_venda_loja.de_endereco" dbalias="nvl.de_endereco" )
 column=(type=char(20) updatewhereclause=yes name=de_bairro dbname="nf_devolucao_venda_loja.de_bairro" dbalias="nvl.de_bairro" )
 column=(type=char(15) updatewhereclause=yes name=nr_telefone dbname="nf_devolucao_venda_loja.nr_telefone" dbalias="nvl.nr_telefone" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep dbname="nf_devolucao_venda_loja.nr_cep" dbalias="nvl.nr_cep" )
 column=(type=long updatewhereclause=yes name=cd_cidade dbname="nf_devolucao_venda_loja.cd_cidade" dbalias="nvl.cd_cidade" )
 column=(type=char(6) updatewhereclause=yes name=nr_endereco dbname="nf_devolucao_venda_loja.nr_endereco" dbalias="nvl.nr_endereco" )
 retrieve="  SELECT nvl.cd_filial,   
         nvl.nr_nf,   
         nvl.de_especie,   
         nvl.de_serie,   
         nvl.id_origem_nf,   
         nvl.nm_cliente,   
         nvl.nr_cgc_cpf,   
         nvl.nm_cidade,   
         nvl.nm_uf,   
         nvl.de_endereco,   
         nvl.de_bairro,   
         nvl.nr_telefone,   
         nvl.nr_cep, 
         nvl.cd_cidade,
	    nvl.nr_endereco
    FROM nf_devolucao_venda_loja nvl,   
         nf_devolucao_venda nf 
   WHERE nf.cd_filial    = nvl.cd_filial 
     and nf.nr_nf        = nvl.nr_nf
     and nf.de_especie   = nvl.de_especie 
     and nf.de_serie     = nvl.de_serie 
     and nf.id_origem_nf = nvl.id_origem_nf 
     and nf.cd_filial    = :filial 
     and nf.dh_movimentacao_caixa = :data_base
" arguments=(("filial", number),("data_base", date)) )
