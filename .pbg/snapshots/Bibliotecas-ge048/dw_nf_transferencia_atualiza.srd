table(column=(type=long updatewhereclause=yes key=yes name=cd_filial_origem dbname="nf_transferencia.cd_filial_origem" )
 column=(type=long updatewhereclause=yes key=yes name=nr_nf dbname="nf_transferencia.nr_nf" )
 column=(type=char(3) updatewhereclause=yes key=yes name=de_especie dbname="nf_transferencia.de_especie" )
 column=(type=char(3) updatewhereclause=yes key=yes name=de_serie dbname="nf_transferencia.de_serie" )
 column=(type=char(1) updatewhereclause=yes name=id_estoque_automatico dbname="nf_transferencia.id_estoque_automatico" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao_estoque dbname="nf_transferencia.dh_atualizacao_estoque" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_atualizacao_estoque dbname="nf_transferencia.nr_matric_atualizacao_estoque" )
 retrieve="select cd_filial_origem,   
       nr_nf,   
       de_especie,   
       de_serie,   
       id_estoque_automatico,
		 dh_atualizacao_estoque,
		 nr_matric_atualizacao_estoque
from nf_transferencia
where dh_exportacao = :data_base
" update="nf_transferencia" updatewhere=0 updatekeyinplace=no arguments=(("data_base", date)) )
