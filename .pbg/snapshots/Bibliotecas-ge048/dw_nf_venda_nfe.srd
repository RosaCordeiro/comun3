table(column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="nf_venda_nfe.cd_filial" dbalias="nfe.cd_filial" )
 column=(type=long update=yes updatewhereclause=yes name=nr_nf dbname="nf_venda_nfe.nr_nf" dbalias="nfe.nr_nf" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_especie dbname="nf_venda_nfe.de_especie" dbalias="nfe.de_especie" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_serie dbname="nf_venda_nfe.de_serie" dbalias="nfe.de_serie" )
 column=(type=char(44) update=yes updatewhereclause=yes name=de_chave_acesso dbname="nf_venda_nfe.de_chave_acesso" dbalias="nfe.de_chave_acesso" )
 column=(type=char(15) update=yes updatewhereclause=yes name=nr_protocolo_envio dbname="nf_venda_nfe.nr_protocolo_envio" dbalias="nfe.nr_protocolo_envio" )
 column=(type=char(15) update=yes updatewhereclause=yes name=nr_protocolo_cancelamento dbname="nf_venda_nfe.nr_protocolo_cancelamento" dbalias="nfe.nr_protocolo_cancelamento" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_envio dbname="nf_venda_nfe.dh_envio" dbalias="nfe.dh_envio" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="nf_venda_nfe.id_situacao" dbalias="nfe.id_situacao" )
 retrieve="  SELECT nfe.cd_filial,   
         nfe.nr_nf,   
         nfe.de_especie,   
         nfe.de_serie,   
         nfe.de_chave_acesso,   
         nfe.nr_protocolo_envio,   
         nfe.nr_protocolo_cancelamento,   
         nfe.dh_envio,   
         nfe.id_situacao  
    FROM nf_venda_nfe nfe,
		nf_venda nf
 Where	nfe.cd_filial	= nf.cd_filial
   and	nfe.nr_nf		= nf.nr_nf
   and	nfe.de_especie	= nf.de_especie
   and	nfe.de_serie	= nf.de_serie
   and	nfe.cd_filial 	= :filial
   and	nfe.dh_exportacao = :data_base
" arguments=(("filial", number),("data_base", date)) )
