table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_venda_pagamento.cd_filial" dbalias="np.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_venda_pagamento.nr_nf" dbalias="np.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_venda_pagamento.de_especie" dbalias="np.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_venda_pagamento.de_serie" dbalias="np.de_serie" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="nf_venda_pagamento.nr_sequencial" dbalias="np.nr_sequencial" )
 column=(type=char(2) updatewhereclause=yes name=cd_forma_pagamento dbname="nf_venda_pagamento.cd_forma_pagamento" dbalias="np.cd_forma_pagamento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pagamento dbname="nf_venda_pagamento.vl_pagamento" dbalias="np.vl_pagamento" )
 column=(type=long updatewhereclause=yes name=cd_filial_devolucao dbname="nf_venda_pagamento.cd_filial_devolucao" dbalias="np.cd_filial_devolucao" )
 column=(type=long updatewhereclause=yes name=nr_nf_devolucao dbname="nf_venda_pagamento.nr_nf_devolucao" dbalias="np.nr_nf_devolucao" )
 column=(type=char(3) updatewhereclause=yes name=de_especie_devolucao dbname="nf_venda_pagamento.de_especie_devolucao" dbalias="np.de_especie_devolucao" )
 column=(type=char(3) updatewhereclause=yes name=de_serie_devolucao dbname="nf_venda_pagamento.de_serie_devolucao" dbalias="np.de_serie_devolucao" )
 column=(type=char(1) updatewhereclause=yes name=id_origem_nf_devolucao dbname="nf_venda_pagamento.id_origem_nf_devolucao" dbalias="np.id_origem_nf_devolucao" )
 retrieve="Select	np.cd_filial,   
		np.nr_nf,   
		np.de_especie,   
		np.de_serie,   
		np.nr_sequencial,   
		np.cd_forma_pagamento,   
		np.vl_pagamento,
		np.cd_filial_devolucao,
		np.nr_nf_devolucao,
		np.de_especie_devolucao,
		np.de_serie_devolucao,
		np.id_origem_nf_devolucao
  From	nf_venda_pagamento np,   
		nf_venda nf
 Where 	nf.nr_nf = np.nr_nf
   and  nf.cd_filial = np.cd_filial
   and  nf.de_especie = np.de_especie
   and  nf.de_serie = np.de_serie
   and  nf.cd_filial = :filial
   and  nf.dh_movimentacao_caixa = :data_base
" arguments=(("filial", number),("data_base", date))  sort="cd_filial A nr_nf A de_especie A de_serie A nr_sequencial A " )
