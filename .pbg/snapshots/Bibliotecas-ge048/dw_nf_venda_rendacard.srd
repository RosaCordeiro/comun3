table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_venda_rendacard.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_venda_rendacard.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_venda_rendacard.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_venda_rendacard.de_serie" )
 column=(type=char(8) updatewhereclause=yes name=nr_cartao dbname="nf_venda_rendacard.nr_cartao" )
 retrieve="  SELECT r.cd_filial,   
         r.nr_nf,   
         r.de_especie,   
         r.de_serie,   
         r.nr_cartao  
    FROM nf_venda_rendacard r,
			nf_venda           n
   WHERE n.cd_filial  = :filial
     AND n.dh_movimentacao_caixa = :data_base
     AND n.cd_filial  = r.cd_filial 
     AND n.nr_nf      = r.nr_nf
     AND n.de_especie = r.de_especie
     AND n.de_serie   = r.de_serie" arguments=(("filial", number),("data_base", date)) )
