 retrieve="  Select id_registro,   
         nr_registro,   
         cd_unidade_federacao,   
         nm_prescritor,   
         de_endereco,   
         de_bairro,   
         cd_cidade,   
         nr_ddd_telefone,   
         nr_telefone,   
         nr_cep  
    From prescritor_receita  
   Where dh_exportacao >= :data_base
     And dh_exportacao < DateAdd(day, 1, :data_base)
" update="prescritor_receita" updatewhere=0 updatekeyinplace=no arguments=(("data_base", date)) )
