HA$PBExportHeader$dw_troca_cartao_clube.srd
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=char(13) update=yes updatewhereclause=yes key=yes name=nr_cartao_clube dbname="cartao_clube.nr_cartao_clube" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_entrega dbname="cartao_clube.dh_entrega" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial_entrega dbname="cartao_clube.cd_filial_entrega" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_entrega dbname="cartao_clube.nr_matricula_entrega" )
 column=(type=char(11) update=yes updatewhereclause=yes name=cd_cliente dbname="cartao_clube.cd_cliente" )
 column=(type=char(13) update=yes updatewhereclause=yes name=cd_dependente_cliente dbname="cartao_clube.cd_dependente_cliente" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_bloqueio dbname="cartao_clube.dh_bloqueio" )
 column=(type=long update=yes updatewhereclause=yes name=cd_motivo_bloqueio dbname="cartao_clube.cd_motivo_bloqueio" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial_bloqueio dbname="cartao_clube.cd_filial_bloqueio" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_bloqueio dbname="cartao_clube.nr_matricula_bloqueio" )
 retrieve="  SELECT nr_cartao_clube,   
         dh_entrega,   
         cd_filial_entrega,   
         nr_matricula_entrega,   
         cd_cliente,   
         cd_dependente_cliente,   
         dh_bloqueio,   
         cd_motivo_bloqueio,   
         cd_filial_bloqueio,   
         nr_matricula_bloqueio  
    FROM cartao_clube
	Where dh_entrega >= :data_base
	  and dh_entrega < DateAdd(day, 1, :data_base)
	  and cd_filial_entrega = :filial

Union

  SELECT nr_cartao_clube,   
         dh_entrega,   
         cd_filial_entrega,   
         nr_matricula_entrega,   
         cd_cliente,   
         cd_dependente_cliente,   
         dh_bloqueio,   
         cd_motivo_bloqueio,   
         cd_filial_bloqueio,   
         nr_matricula_bloqueio  
    FROM cartao_clube
	Where dh_bloqueio >= :data_base
	  and dh_bloqueio	< DateAdd(day, 1, :data_base)
	  and cd_filial_bloqueio = :filial
" update="cartao_clube" updatewhere=1 updatekeyinplace=no arguments=(("filial", number),("data_base", date)) )
