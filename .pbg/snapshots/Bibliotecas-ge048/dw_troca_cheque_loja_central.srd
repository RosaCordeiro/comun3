 column=(type=datetime update=yes updatewhereclause=yes name=dh_baixa dbname="cheque.dh_baixa" )
 column=(type=char(14) updatewhereclause=yes name=nr_cpf_cliente dbname="cheque.nr_cpf_cliente" )
 retrieve="  SELECT cheque.cd_banco,   
         cheque.nr_agencia,   
         cheque.nr_conta,   
         cheque.nr_cheque,   
         cheque.vl_cheque,   
         cheque.cd_filial_inclusao,   
         cheque.cd_filial_atualizacao,   
         cheque.cd_portador,   
         cheque.dh_emissao,   
         cheque.dh_vencimento,   
         cheque.pc_juros_diaria,   
         cheque.pc_multa,   
         cheque.vl_pago,   
         cheque.dh_devolucao,   
         cheque.de_motivo_devolucao,   
         cheque.dh_baixa,   
         cheque.nr_cpf_cliente  
    FROM cheque  
   WHERE dh_exportacao = :data_base" update="cheque" updatewhere=1 updatekeyinplace=no arguments=(("data_base", date)) )
