table(column=(type=char(3) update=yes updatewhereclause=yes key=yes name=cd_banco dbname="cheque.cd_banco" )
 column=(type=char(5) update=yes updatewhereclause=yes key=yes name=nr_agencia dbname="cheque.nr_agencia" )
