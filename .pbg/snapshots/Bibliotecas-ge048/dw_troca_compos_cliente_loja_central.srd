table(column=(type=char(11) update=yes updatewhereclause=yes key=yes name=cd_cliente dbname="composicao_social_cliente.cd_cliente" )
 column=(type=char(30) update=yes updatewhereclause=yes key=yes name=nm_socio dbname="composicao_social_cliente.nm_socio" )
 column=(type=char(20) update=yes updatewhereclause=yes name=de_cargo dbname="composicao_social_cliente.de_cargo" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_participacao_capital dbname="composicao_social_cliente.pc_participacao_capital" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial_atualizacao dbname="composicao_social_cliente.cd_filial_atualizacao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_atualizacao_filial dbname="composicao_social_cliente.dh_atualizacao_filial" )
 retrieve="  SELECT composicao_social_cliente.cd_cliente,   
         composicao_social_cliente.nm_socio,   
         composicao_social_cliente.de_cargo,   
         composicao_social_cliente.pc_participacao_capital,   
         composicao_social_cliente.cd_filial_atualizacao,   
         composicao_social_cliente.dh_atualizacao_filial  
    FROM composicao_social_cliente  
   WHERE ( composicao_social_cliente.cd_filial_atualizacao = :filial ) AND  
         ( composicao_social_cliente.dh_atualizacao_filial = :data_base )    
" update="composicao_social_cliente" updatewhere=1 updatekeyinplace=no arguments=(("filial", number),("data_base", date)) )
