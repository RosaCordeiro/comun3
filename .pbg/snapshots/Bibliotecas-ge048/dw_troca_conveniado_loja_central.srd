table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_convenio dbname="conveniado.cd_convenio" )
 column=(type=char(15) update=yes updatewhereclause=yes key=yes name=cd_conveniado dbname="conveniado.cd_conveniado" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_conveniado dbname="conveniado.nm_conveniado" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_somente_titular dbname="conveniado.id_somente_titular" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_obedece_restricao dbname="conveniado.id_obedece_restricao" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial_atualizacao dbname="conveniado.cd_filial_atualizacao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_atualizacao dbname="conveniado.dh_atualizacao" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_atualizacao dbname="conveniado.nr_matricula_atualizacao" )
 column=(type=char(4) updatewhereclause=yes name=de_senha dbname="conveniado.de_senha" )
 retrieve="select cd_convenio,   
       cd_conveniado,   
       nm_conveniado,   
       id_somente_titular,   
       id_obedece_restricao,   
       cd_filial_atualizacao,   
       dh_atualizacao,   
       nr_matricula_atualizacao,
       de_senha
from conveniado
where cd_filial_atualizacao = :filial
  and dh_atualizacao        = :data_base
" update="conveniado" updatewhere=1 updatekeyinplace=no arguments=(("filial", number),("data_base", date)) )
