 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"fornecedor~" ) COLUMN(NAME=~"fornecedor.cd_fornecedor~") COLUMN(NAME=~"fornecedor.id_fornecedor_transportadora~") COLUMN(NAME=~"fornecedor.cd_filial~") COLUMN(NAME=~"fornecedor.nm_fantasia~") COLUMN(NAME=~"fornecedor.nm_razao_social~") COLUMN(NAME=~"fornecedor.id_fisica_juridica~") COLUMN(NAME=~"fornecedor.nr_cgc~") COLUMN(NAME=~"fornecedor.nr_cpf~") COLUMN(NAME=~"fornecedor.nr_inscricao_estadual~") COLUMN(NAME=~"fornecedor.cd_cidade~") COLUMN(NAME=~"fornecedor.de_endereco~") COLUMN(NAME=~"fornecedor.de_bairro~") COLUMN(NAME=~"fornecedor.nr_cep~") COLUMN(NAME=~"fornecedor.nr_ddd_telefone~") COLUMN(NAME=~"fornecedor.nr_telefone~") COLUMN(NAME=~"fornecedor.nr_ddd_fax~") COLUMN(NAME=~"fornecedor.nr_fax~") COLUMN(NAME=~"fornecedor.nr_ddd_telefone_compras~") COLUMN(NAME=~"fornecedor.nr_telefone_compras~") COLUMN(NAME=~"fornecedor.nr_ddd_fax_compras~") COLUMN(NAME=~"fornecedor.nr_fax_compras~") COLUMN(NAME=~"fornecedor.pc_desconto_usual~") COLUMN(NAME=~"fornecedor.nm_contato~") COLUMN(NAME=~"fornecedor.id_regime_especial~") COLUMN(NAME=~"fornecedor.cd_filial_atualizacao~") COLUMN(NAME=~"fornecedor.dh_atualizacao_filial~") COLUMN(NAME=~"fornecedor.nr_matricula_comprador~")WHERE(    EXP1 =~"fornecedor.cd_filial_atualizacao~"   OP =~"=~"    EXP2 =~":filial~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"fornecedor.dh_atualizacao_filial~"   OP =~"=~"    EXP2 =~":data_base~" ) ) ARG(NAME = ~"filial~" TYPE = number)  ARG(NAME = ~"data_base~" TYPE = date) " update="fornecedor" updatewhere=1 updatekeyinplace=no arguments=(("filial", number),("data_base", date)) )
