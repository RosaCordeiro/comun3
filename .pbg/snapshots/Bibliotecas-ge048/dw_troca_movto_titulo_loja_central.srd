 column=(type=datetime updatewhereclause=yes name=dh_atualizacao_filial dbname="movimento_titulo_receber.dh_atualizacao_filial" )
 retrieve="select nr_titulo,   
       nr_movimento,   
       cd_tipo_movimento,   
       nr_matricula_responsavel,   
       dh_sistema,   
       dh_movimento,   
       dh_credito,   
       vl_movimento,   
       vl_juros_recebidos,   
       vl_desconto_concedido,   
       vl_despesas_recebidas,   
       id_estorno,   
       de_historico,   
       nr_recibo_cobranca,   
       cd_filial_movimento,   
       nr_matric_juros_desconto,
       cd_filial_atualizacao,
       dh_atualizacao_filial
from movimento_titulo_receber
where cd_filial_atualizacao = :filial
  and dh_atualizacao_filial = :data_movto
" update="movimento_titulo_receber" updatewhere=1 updatekeyinplace=no arguments=(("filial", number),("data_movto", date))  sort="nr_titulo A cd_filial_movimento A nr_movimento A dh_sistema A " )
