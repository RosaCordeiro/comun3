 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_devolucao_compra.dh_emissao" dbalias=".dh_emissao" )
 column=(type=long updatewhereclause=yes name=cd_motivo_devolucao dbname="nf_devolucao_compra.cd_motivo_devolucao" dbalias=".cd_motivo_devolucao" )
 retrieve="  SELECT nf_devolucao_compra.cd_filial,   
         nf_devolucao_compra.nr_nf,   
         nf_devolucao_compra.de_especie,   
         nf_devolucao_compra.de_serie,   
         nf_devolucao_compra.dh_movimentacao_caixa,   
         nf_devolucao_compra.vl_bc_icms,   
         nf_devolucao_compra.vl_icms,   
         nf_devolucao_compra.vl_bc_icms_st,   
         nf_devolucao_compra.vl_icms_st,   
         nf_devolucao_compra.vl_icms_repassado,   
         nf_devolucao_compra.vl_total_produtos,   
         nf_devolucao_compra.vl_ipi,   
         nf_devolucao_compra.vl_frete,   
         nf_devolucao_compra.vl_seguro,   
         nf_devolucao_compra.vl_outras_despesas,   
         nf_devolucao_compra.vl_desconto,   
         nf_devolucao_compra.vl_indenizacao,   
         nf_devolucao_compra.vl_total_nf,   
         nf_devolucao_compra.cd_fornecedor,   
         nf_devolucao_compra.nr_nf_compra,   
         nf_devolucao_compra.de_especie_compra,   
         nf_devolucao_compra.de_serie_compra,   
         nf_devolucao_compra.nr_matricula_operador,   
         nf_devolucao_compra.dh_cancelamento,   
         nf_devolucao_compra.nr_matricula_cancelamento,
		nf_devolucao_compra.nr_nsu,
		nf_devolucao_compra.dh_emissao,
		nf_devolucao_compra.cd_motivo_devolucao
    FROM nf_devolucao_compra  
   WHERE ( nf_devolucao_compra.cd_filial = :filial ) AND  
         ( nf_devolucao_compra.dh_movimentacao_caixa = :data_base )    
" update="nf_devolucao_compra" updatewhere=1 updatekeyinplace=no arguments=(("filial", number),("data_base", date)) )
