table(column=(type=long updatewhereclause=yes key=yes name=cd_filial_origem dbname="nf_transferencia.cd_filial_origem" dbalias=".cd_filial_origem" )
 column=(type=long updatewhereclause=yes key=yes name=nr_nf dbname="nf_transferencia.nr_nf" dbalias=".nr_nf" )
