 column=(type=char(6) updatewhereclause=yes name=nr_matricula_operador dbname="nf_transferencia.nr_matricula_operador" dbalias=".nr_matricula_operador" )
 column=(type=char(1) updatewhereclause=yes name=id_produto_vencido dbname="nf_transferencia.id_produto_vencido" dbalias=".id_produto_vencido" )
 column=(type=datetime updatewhereclause=yes name=dh_recebimento dbname="nf_transferencia.dh_recebimento" dbalias=".dh_recebimento" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="nf_transferencia.dh_cancelamento" dbalias=".dh_cancelamento" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_cancelamento dbname="nf_transferencia.nr_matricula_cancelamento" dbalias=".nr_matricula_cancelamento" )
 column=(type=long updatewhereclause=yes name=nr_nsu dbname="nf_transferencia.nr_nsu" dbalias=".nr_nsu" )
 column=(type=long updatewhereclause=yes name=cd_filial_entrada dbname="nf_transferencia.cd_filial_entrada" dbalias=".cd_filial_entrada" )
 column=(type=long updatewhereclause=yes name=nr_nf_entrada dbname="nf_transferencia.nr_nf_entrada" dbalias=".nr_nf_entrada" )
 column=(type=char(3) updatewhereclause=yes name=de_especie_entrada dbname="nf_transferencia.de_especie_entrada" dbalias=".de_especie_entrada" )
 column=(type=char(3) updatewhereclause=yes name=de_serie_entrada dbname="nf_transferencia.de_serie_entrada" dbalias=".de_serie_entrada" )
 retrieve="select cd_filial_origem,   
       nr_nf,   
       de_especie,   
       de_serie,   
       cd_filial_destino,   
       dh_emissao,   
       dh_movimentacao_caixa,   
       vl_bc_icms,   
       vl_icms,   
       vl_bc_icms_st,   
       vl_icms_st,   
       vl_total_produtos,   
       vl_total_nf,   
       nr_matricula_operador,   
       id_produto_vencido,   
       dh_recebimento,   
       dh_cancelamento,   
       nr_matricula_cancelamento,
		 nr_nsu,
		cd_filial_entrada,
		nr_nf_entrada,
		de_especie_entrada,
		de_serie_entrada
from nf_transferencia
where cd_filial_origem = :filial
  and dh_movimentacao_caixa = :data_base
" update="nf_transferencia" updatewhere=0 updatekeyinplace=no arguments=(("filial", number),("data_base", date)) )
