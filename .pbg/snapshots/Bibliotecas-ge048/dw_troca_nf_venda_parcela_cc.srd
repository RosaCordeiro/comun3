footer(height=0 color="536870912" )
detail(height=116 color="536870912" )
table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_venda_parcela_cc.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_venda_parcela_cc.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_venda_parcela_cc.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_venda_parcela_cc.de_serie" )
 column=(type=long updatewhereclause=yes name=nr_parcela dbname="nf_venda_parcela_cc.nr_parcela" )
 column=(type=datetime updatewhereclause=yes name=dh_vencimento dbname="nf_venda_parcela_cc.dh_vencimento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_parcela dbname="nf_venda_parcela_cc.vl_parcela" )
 retrieve="  SELECT p.cd_filial,   
         p.nr_nf,   
         p.de_especie,   
         p.de_serie,   
         p.nr_parcela,   
         p.dh_vencimento,   
         p.vl_parcela  
    FROM nf_venda n,
         nf_venda_parcela_cc p
   WHERE p.cd_filial					= n.cd_filial
     and p.nr_nf 						= n.nr_nf
     and p.de_especie				= n.de_especie
     and p.de_serie					= n.de_serie
     and n.cd_filial					= p.cd_filial
     and n.nr_nf 						= p.nr_nf
     and n.de_especie			 	= p.de_especie
     and n.de_serie					= p.de_serie
     and n.cd_filial 				= :filial
     and n.dh_movimentacao_caixa = :data_base" arguments=(("filial", number),("data_base", date)) )
