table(column=(type=char(11) update=yes updatewhereclause=yes key=yes name=cd_cliente dbname="referencia_comercial_cliente.cd_cliente" )
 column=(type=char(40) update=yes updatewhereclause=yes key=yes name=nm_referencia dbname="referencia_comercial_cliente.nm_referencia" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_endereco dbname="referencia_comercial_cliente.de_endereco" )
 column=(type=char(20) update=yes updatewhereclause=yes name=de_bairro dbname="referencia_comercial_cliente.de_bairro" )
 column=(type=char(8) update=yes updatewhereclause=yes name=nr_cep dbname="referencia_comercial_cliente.nr_cep" )
 column=(type=char(3) update=yes updatewhereclause=yes name=nr_ddd_telefone dbname="referencia_comercial_cliente.nr_ddd_telefone" )
 column=(type=char(8) update=yes updatewhereclause=yes name=nr_telefone dbname="referencia_comercial_cliente.nr_telefone" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial_atualizacao dbname="referencia_comercial_cliente.cd_filial_atualizacao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_atualizacao_filial dbname="referencia_comercial_cliente.dh_atualizacao_filial" )
 retrieve="  SELECT referencia_comercial_cliente.cd_cliente,   
         referencia_comercial_cliente.nm_referencia,   
         referencia_comercial_cliente.de_endereco,   
         referencia_comercial_cliente.de_bairro,   
         referencia_comercial_cliente.nr_cep,   
         referencia_comercial_cliente.nr_ddd_telefone,   
         referencia_comercial_cliente.nr_telefone,   
         referencia_comercial_cliente.cd_filial_atualizacao,   
         referencia_comercial_cliente.dh_atualizacao_filial  
    FROM referencia_comercial_cliente  
   WHERE ( referencia_comercial_cliente.cd_filial_atualizacao = :filial ) AND  
         ( referencia_comercial_cliente.dh_atualizacao_filial = :data_base )    
" update="referencia_comercial_cliente" updatewhere=1 updatekeyinplace=no arguments=(("filial", number),("data_base", date)) )
