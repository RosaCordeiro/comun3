 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"usuario~" ) COLUMN(NAME=~"usuario.nr_matricula~") COLUMN(NAME=~"usuario.nm_usuario~") COLUMN(NAME=~"usuario.de_senha~") COLUMN(NAME=~"usuario.cd_filial~") COLUMN(NAME=~"usuario.cd_filial_atualizacao~") COLUMN(NAME=~"usuario.dh_atualizacao_filial~")WHERE(    EXP1 =~"usuario.cd_filial_atualizacao~"   OP =~"=~"    EXP2 =~":filial~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"usuario.dh_atualizacao_filial~"   OP =~"=~"    EXP2 =~":data_base~" ) ) ARG(NAME = ~"filial~" TYPE = number)  ARG(NAME = ~"data_base~" TYPE = date) " update="usuario" updatewhere=1 updatekeyinplace=no arguments=(("filial", number),("data_base", date)) )
