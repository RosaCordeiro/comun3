 column=(type=long update=yes updatewhereclause=yes name=cd_convenio dbname="venda_pbm.cd_convenio" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_venda dbname="venda_pbm.dh_venda" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_total_venda dbname="venda_pbm.vl_total_venda" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_autorizacao dbname="venda_pbm.nr_autorizacao" )
