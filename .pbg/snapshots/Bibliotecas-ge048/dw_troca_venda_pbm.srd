 column=(type=char(6) update=yes updatewhereclause=yes name=nr_cupom dbname="venda_pbm.nr_cupom" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_cancelamento dbname="venda_pbm.dh_cancelamento" )
 column=(type=char(20) update=yes updatewhereclause=yes name=cd_convenio_pbm dbname="venda_pbm.cd_convenio_pbm" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_cartao dbname="venda_pbm.nr_cartao" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_reembolso_total dbname="venda_pbm.vl_reembolso_total" )
 retrieve="SELECT cd_filial,   
		 nr_nf,   
		 de_especie,   
		 de_serie,   
		 cd_convenio,   
		 dh_venda,   
		 vl_total_venda,   
		 nr_autorizacao,   
		 nr_comprovante_venda,   
		 nr_ecf,   
		 nr_cupom,   
		 dh_cancelamento,   
		 cd_convenio_pbm,   
		 nr_cartao,   
		 vl_reembolso_total  
  FROM venda_pbm
 WHERE cd_filial = :pl_filial
   AND dh_venda  = :pdt_data
" update="venda_pbm" updatewhere=1 updatekeyinplace=no arguments=(("pl_filial", number),("pdt_data", date)) )
