HA$PBExportHeader$dw_troca_venda_pbm_produto.srd
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=long updatewhereclause=yes name=cd_filial dbname="venda_pbm_produto.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="venda_pbm_produto.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="venda_pbm_produto.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="venda_pbm_produto.de_serie" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="venda_pbm_produto.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="venda_pbm_produto.qt_vendida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_maximo dbname="venda_pbm_produto.vl_preco_maximo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_praticado dbname="venda_pbm_produto.vl_praticado" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pago_avista dbname="venda_pbm_produto.vl_pago_avista" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_subsidio dbname="venda_pbm_produto.vl_subsidio" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_reembolso dbname="venda_pbm_produto.vl_reembolso" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_reposicao dbname="venda_pbm_produto.vl_reposicao" )
 retrieve="SELECT p.cd_filial,   
		 p.nr_nf,   
		 p.de_especie,   
		 p.de_serie,   
		 p.cd_produto,   
		 p.qt_vendida,   
		 p.vl_preco_maximo,   
		 p.vl_praticado,   
		 p.vl_pago_avista,   
		 p.vl_subsidio,   
		 p.vl_reembolso,   
		 p.vl_reposicao  
  FROM venda_pbm v,   
		 venda_pbm_produto p
 WHERE v.cd_filial    = :pl_filial  
	AND v.dh_venda     = :pdt_data    
   AND p.cd_filial  = v.cd_filial
	AND p.nr_nf      = v.nr_nf
	AND p.de_especie = v.de_especie
	AND p.de_serie   = v.de_serie" arguments=(("pl_filial", number),("pdt_data", date)) )
