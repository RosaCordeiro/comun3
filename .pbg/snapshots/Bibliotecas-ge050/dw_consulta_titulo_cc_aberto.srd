table(column=(type=long updatewhereclause=yes name=cd_filial_centralizadora dbname="cliente.cd_filial_centralizadora" dbalias="c.cd_filial_centralizadora" )
 column=(type=char(40) updatewhereclause=yes name=de_portador dbname="portador.de_portador" dbalias="p.de_portador" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="cliente.nm_cliente" dbalias="c.nm_cliente" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="cliente.cd_cliente" dbalias="c.cd_cliente" )
 column=(type=char(13) updatewhereclause=yes name=nr_titulo dbname="titulo_receber.nr_titulo" dbalias="t.nr_titulo" )
 column=(type=char(20) updatewhereclause=yes name=nr_titulo_banco dbname="titulo_receber.nr_titulo_banco" dbalias="t.nr_titulo_banco" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="titulo_receber.dh_emissao" dbalias="t.dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_nominal dbname="titulo_receber.vl_nominal" dbalias="t.vl_nominal" )
 column=(type=datetime updatewhereclause=yes name=dh_vencimento dbname="titulo_receber.dh_vencimento" dbalias="t.dh_vencimento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_aberto dbname="titulo_receber.vl_aberto" dbalias="t.vl_aberto" )
 column=(type=datetime updatewhereclause=yes name=titulo_receber_dh_venda_inicial dbname="titulo_receber.dh_venda_inicial" dbalias="t.dh_venda_inicial" )
 column=(type=datetime updatewhereclause=yes name=titulo_receber_dh_venda_final dbname="titulo_receber.dh_venda_final" dbalias="t.dh_venda_final" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_juros_diario dbname="vl_juros_diario" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_multa dbname="vl_multa" )
 column=(type=long updatewhereclause=yes name=nr_dias_atraso dbname="nr_dias_atraso" )
 retrieve="select c.cd_filial_centralizadora,
		p.de_portador,
		f.nm_fantasia,
		c.nm_cliente,   
		c.cd_cliente,
		t.nr_titulo,
		t.nr_titulo_banco,
		t.dh_emissao,   
		t.vl_nominal,
		t.dh_vencimento,   
		t.vl_aberto,
		t.dh_venda_inicial,
		t.dh_venda_final,
		round(round(pr.pc_juros_diario * t.vl_aberto,2)/100,2) as vl_juros_diario,
		case when datediff(day,t.dh_calculo_juros,pr.dh_movimentacao) > 0 then round((cast(coalesce(pg.vl_parametro,'0') as decimal) /100) * t.vl_aberto,2) else 0.00 end as vl_multa,
		datediff(day,t.dh_calculo_juros,pr.dh_movimentacao) as nr_dias_atraso
from titulo_receber t
inner join portador p
  	on p.cd_portador = t.cd_portador
inner join cliente c
	on t.cd_cliente = c.cd_cliente
inner join filial f
  	on f.cd_filial = c.cd_filial_centralizadora
inner join parametro pr
     On pr.id_parametro        = '1'
left outer join parametro_geral pg
	on pg.cd_parametro = 'PERC_MULTA_BOLETO'
where t.id_tipo_titulo = 'CC'
  and t.id_situacao    = 'A'"  sort="filial_nm_fantasia A nm_cliente A dh_vencimento A " )
