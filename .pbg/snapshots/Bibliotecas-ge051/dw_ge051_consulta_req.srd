table(column=(type=long updatewhereclause=yes name=nr_registro dbname="registro_venda_manip.nr_registro" )
 column=(type=long updatewhereclause=yes name=qt_registro dbname="registro_venda_manip.qt_registro" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_registro dbname="registro_venda_manip.vl_registro" )
 column=(type=long updatewhereclause=yes name=cd_filial_fcerta dbname="registro_venda_manip.cd_filial_fcerta" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="registro_venda_manip.nr_sequencial" )
 retrieve="  SELECT dbo.registro_venda_manip.nr_registro,   
         dbo.registro_venda_manip.qt_registro,   
         dbo.registro_venda_manip.vl_registro,   
         dbo.registro_venda_manip.cd_filial_fcerta,   
         dbo.registro_venda_manip.nr_sequencial  
    FROM dbo.registro_venda_manip
where dbo.registro_venda_manip.cd_filial = :cd_filial
	and dbo.registro_venda_manip.nr_nf = :nr_nf
	and dbo.registro_venda_manip.de_especie = :de_especie
	and dbo.registro_venda_manip.de_serie = :de_serie
" arguments=(("cd_filial", number),("nr_nf", number),("de_especie", string),("de_serie", string))  sort="nr_sequencial A " )
