table(column=(type=long updatewhereclause=yes name=cd_convenio dbname="titulo_receber.cd_convenio" )
 column=(type=char(40) updatewhereclause=yes name=convenio_nm_fantasia dbname="convenio.nm_fantasia" )
 column=(type=char(13) updatewhereclause=yes name=nr_titulo dbname="titulo_receber.nr_titulo" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="titulo_receber.dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_nominal dbname="titulo_receber.vl_nominal" )
 retrieve="select titulo_receber.cd_convenio,   
       convenio.nm_fantasia,   
		 titulo_receber.nr_titulo,       
       titulo_receber.dh_emissao,   
       titulo_receber.vl_nominal
from convenio,   
     titulo_receber
where convenio.cd_convenio = titulo_receber.cd_convenio
  and titulo_receber.id_situacao = 'A'
"  sort="convenio_nm_fantasia A " )
