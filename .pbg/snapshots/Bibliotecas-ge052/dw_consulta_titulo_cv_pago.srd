table(column=(type=long updatewhereclause=yes name=convenio_cd_filial_centralizadora dbname="convenio.cd_filial_centralizadora" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=convenio_cd_convenio dbname="convenio.cd_convenio" )
 column=(type=char(60) updatewhereclause=yes name=convenio_nm_fantasia dbname="convenio.nm_fantasia" )
 column=(type=char(13) updatewhereclause=yes name=nr_titulo dbname="titulo_receber.nr_titulo" )
 column=(type=char(20) updatewhereclause=yes name=nr_titulo_banco dbname="titulo_receber.nr_titulo_banco" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="titulo_receber.dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_vencimento dbname="titulo_receber.dh_vencimento" )
 column=(type=datetime updatewhereclause=yes name=dh_baixa dbname="titulo_receber.dh_baixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_nominal dbname="titulo_receber.vl_nominal" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_recebido dbname="titulo_receber.vl_recebido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_multa_recebida dbname="titulo_receber.vl_multa_recebida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_juros_recebidos dbname="titulo_receber.vl_juros_recebidos" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_concedido dbname="titulo_receber.vl_desconto_concedido" )
 retrieve="select c.cd_filial_centralizadora,   
		f.nm_fantasia,  
		c.cd_convenio, 
		c.nm_fantasia,
		t.nr_titulo,
		t.nr_titulo_banco,   
		t.dh_emissao,
		t.dh_vencimento, 
		t.dh_baixa,
		t.vl_nominal,   
		t.vl_recebido,
		t.vl_multa_recebida,
		t.vl_juros_recebidos,
		t.vl_desconto_concedido
from titulo_receber t
inner join filial f
  	on f.cd_filial = t.cd_filial
inner join convenio c
	on c.cd_convenio = t.cd_convenio
inner join parametro pr
     On pr.id_parametro        = '1'
where t.id_situacao    = 'P'

"  sort="filial_nm_fantasia A convenio_nm_fantasia A dh_baixa A " )
