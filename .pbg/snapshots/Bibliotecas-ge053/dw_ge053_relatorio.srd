table(column=(type=long updatewhereclause=yes name=cd_filial dbname="resumo_movimento_estoque.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_venda_bruta dbname="vl_venda_bruta" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_liquida dbname="vl_venda_liquida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_tabela dbname="vl_venda_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_devolucao_venda_bruta dbname="vl_devolucao_venda_bruta" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_devolucao_venda_liquida dbname="vl_devolucao_venda_liquida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_sem_desconto dbname="vl_venda_sem_desconto" )
 column=(type=char(1) updatewhereclause=yes name=de_regiao dbname="de_regiao" )
 column=(type=long updatewhereclause=yes name=filial_cd_regiao dbname="filial.cd_regiao" )
 column=(type=char(40) updatewhereclause=yes name=parametro_loja_vl_parametro dbname="parametro_loja.vl_parametro" )
 column=(type=char(1) updatewhereclause=yes name=de_empresa dbname="de_empresa" )
 retrieve="select r.cd_filial,
       f.nm_fantasia,
       sum(r.vl_venda_bruta) vl_venda_bruta,   
       sum(r.vl_venda_avista + r.vl_venda_convenio + r.vl_venda_crediario + r.vl_venda_conta_corrente + r.vl_venda_cartao_credito + r.vl_venda_cartao_debito + r.vl_venda_cheque_avista + r.vl_venda_cheque_aprazo) vl_venda_liquida,
       sum(r.vl_venda_tabela) vl_venda_tabela,
		 sum(r.vl_devolucao_venda_bruta) vl_devolucao_venda_bruta,
       sum(r.vl_devolucao_venda) vl_devolucao_venda_liquida,
       0.00 vl_venda_sem_desconto,
		 ~"~" de_regiao,
	  f.cd_regiao,
	  p.vl_parametro,
       ~"~" de_empresa 
from resumo_movimento_estoque r,
     filial f,
	parametro_loja p
where r.dh_resumo between :inicio and :termino
  and r.cd_filial not in (1, 534)
  and f.cd_filial = r.cd_filial
  and p.cd_filial = f.cd_filial
  and p.cd_parametro = 'ID_REDE_FILIAL'
group by r.cd_filial,
         f.nm_fantasia,
		f.cd_regiao,
	  	p.vl_parametro
" arguments=(("inicio", date),("termino", date))  sort="filial_cd_regiao A nm_fantasia A " )
