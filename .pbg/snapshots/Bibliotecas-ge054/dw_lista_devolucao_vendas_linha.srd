table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_devolucao_venda.cd_filial" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_devolucao_venda.dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=qt_devolvida dbname="qt_devolvida" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_vendas dbname="vl_vendas" )
 retrieve="  SELECT n.cd_filial,
         n.dh_movimentacao_caixa,
		 Sum(i.qt_devolvida) qt_devolvida,
		 Sum(round((round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * i.qt_devolvida),2)) vl_vendas
    FROM nf_devolucao_venda n,
         item_nf_devolucao_venda i,
         produto_geral p
   WHERE n.cd_filial  				 	= i.cd_filial 
     and n.nr_nf      				 	= i.nr_nf
     and n.de_especie 				 	= i.de_especie 
     and n.de_serie   				 	= i.de_serie 
     and n.dh_cancelamento 		 	 	is null 
     and n.dh_movimentacao_caixa 		between :pdt_inicio and :pdt_termino 
     and i.cd_produto 		 	 		= p.cd_produto
     and n.cd_filial 					= :pl_cd_filial
   GROUP BY n.cd_filial, n.dh_movimentacao_caixa" arguments=(("pdt_inicio", datetime),("pdt_termino", datetime),("pl_cd_filial", number)) )
