table(column=(type=long updatewhereclause=yes name=nf_venda_cd_filial dbname="nf_venda.cd_filial" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_vendedor dbname="nf_venda.nr_matricula_vendedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_venda.dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="qt_vendida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_vendas dbname="vl_vendas" )
 retrieve="  SELECT nf_venda.cd_filial,
		 nf_venda.nr_matricula_vendedor,
		 usuario.nm_usuario,
		 nf_venda.dh_movimentacao_caixa,
		 Sum(item_nf_venda.qt_vendida) qt_vendida,
         Sum(item_nf_venda.vl_preco_praticado*item_nf_venda.qt_vendida) vl_vendas
    FROM nf_venda,
         item_nf_venda,
         produto_geral,
		 usuario
   WHERE nf_venda.cd_filial  				 = item_nf_venda.cd_filial 
     and nf_venda.nr_nf      				 = item_nf_venda.nr_nf
     and nf_venda.de_especie 				 = item_nf_venda.de_especie 
     and nf_venda.de_serie   				 = item_nf_venda.de_serie 
     and nf_venda.dh_cancelamento 		 is null 
     and nf_venda.nr_nf_anexa     		 is null 
	 and usuario.nr_matricula        	 = nf_venda.nr_matricula_vendedor
     and nf_venda.dh_movimentacao_caixa between :pdt_inicio and :pdt_termino 
     and item_nf_venda.cd_produto 		 = produto_geral.cd_produto 
     and nf_venda.cd_filial 				 = :pl_cd_filial
 GROUP BY nr_matricula_vendedor,usuario.nm_usuario,nf_venda.cd_filial,nf_venda.dh_movimentacao_caixa" arguments=(("pdt_inicio", datetime),("pdt_termino", datetime),("pl_cd_filial", number))  sort="nf_venda_cd_filial A nm_usuario A nr_matricula_vendedor A dh_movimentacao_caixa A " )
