table(column=(type=number updatewhereclause=yes name=nr_movimento_estoque dbname="nr_movimento_estoque" )
 column=(type=datetime updatewhereclause=yes name=dh_movimento dbname="dh_movimento" )
 column=(type=long updatewhereclause=yes name=cd_tipo_movimento dbname="cd_tipo_movimento" )
 column=(type=long updatewhereclause=yes name=qt_movimento dbname="qt_movimento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="vl_custo_unitario" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_movimento dbname="de_tipo_movimento" )
 column=(type=char(1) updatewhereclause=yes name=id_entrada_saida dbname="id_entrada_saida" )
 column=(type=char(1) updatewhereclause=yes name=id_cancelamento dbname="id_cancelamento" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=serie dbname="de_serie" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="cd_cliente" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="cd_convenio" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_movimento dbname="id_tipo_movimento" )
 column=(type=char(1) updatewhereclause=yes name=de_origem_destino dbname="de_origem_destino" )
 column=(type=long updatewhereclause=yes name=qt_saldo_inicial dbname="qt_saldo_inicial" )
 column=(type=long updatewhereclause=yes name=cd_filial_movimento dbname="cd_filial_movimento" )
 column=(type=long updatewhereclause=yes name=cd_tipo_movimento dbname="cd_tipo_movimento" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="dh_inclusao" )
 retrieve="select m.nr_movimento_estoque,
		 m.dh_movimento,   
		 m.cd_tipo_movimento,   
		 m.qt_movimento,   
		 m.vl_custo_unitario,   
		 m.nr_nf,   
		 t.de_tipo_movimento,   
		 t.id_entrada_saida,   
		 t.id_cancelamento,   
		 m.de_especie,   
		 m.de_serie,   
		 m.cd_cliente,   
		 m.cd_filial,   
		 m.cd_fornecedor,   
		 m.cd_convenio,   
		 t.id_tipo_movimento,
		'' de_origem_destino,
		:qt_saldo_inicial qt_saldo_inicial,
		m.cd_filial_movimento,
		m.cd_tipo_movimento,
		m.cd_produto,
		m.dh_inclusao
 from movimento_estoque m,   
	   tipo_movimento_estoque t
where m.cd_filial_movimento = :filial
  and m.cd_produto	 	    = :produto
  and m.dh_movimento between :inicio and :termino
  and t.cd_tipo_movimento = m.cd_tipo_movimento" arguments=(("filial", number),("produto", number),("inicio", date),("termino", date),("qt_saldo_inicial", number))  sort="dh_movimento A nr_movimento_estoque A " )
