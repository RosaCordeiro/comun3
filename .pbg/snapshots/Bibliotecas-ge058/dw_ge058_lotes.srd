table(column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="nr_lote" )
 column=(type=long updatewhereclause=yes name=qt_lote dbname="qt_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="dh_validade" )
 column=(type=char(2) updatewhereclause=yes name=de_tipo dbname="de_tipo" )
 retrieve="select	nr_lote,
		qt_lote,
		dh_validade,
		de_tipo
from (
	select	nr_lote,
			sum(qt_lote) qt_lote,
			dh_validade,
			'TR' de_tipo
	FROM item_nf_transferencia_lote 
	where cd_filial_origem	= :cd_filial 
	and cd_produto				= :cd_produto 
	and nr_nf					= :nr_nf 
	and de_especie				= :de_especie
	and de_serie				= :de_serie
	group by nr_lote,
				dh_validade
	
	union
	
	select	b.nr_lote,
			sum(b.qt_lote) qt_lote,
			b.dh_validade,
			'DC' de_tipo
	FROM nf_devolucao_compra_produto a
    inner join nf_devolucao_compra_prd_lote b on   b.cd_filial 		= a.cd_filial
															and b.nr_nf 			= a.nr_nf 
															and b.de_especie 	= b.de_especie
															and b.de_serie 		= b.de_serie
															and b.nr_item 		= a.nr_item
	where a.cd_filial	= :cd_filial 
	and a.cd_produto	= :cd_produto 
	and a.nr_nf			= :nr_nf 
	and a.de_especie	= :de_especie 
	and a.de_serie		= :de_serie
	group by b.nr_lote,
				b.dh_validade
	
	union
	
	select	nr_lote,
			sum(qt_lote) qt_lote,
			null dh_validade,
			'DV' de_tipo
	FROM item_nf_devolucao_venda_lote 
	where cd_filial		= :cd_filial 
	and cd_produto		= :cd_produto 
	and nr_nf			= :nr_nf 
	and de_especie		= :de_especie
	and de_serie		= :de_serie
	group by nr_lote
	
	union
	
	select	nr_lote,
			sum(qt_lote) qt_lote,
			dh_validade,
			'CO' de_tipo
	FROM item_nf_compra_lote 
	where cd_filial		= :cd_filial 
	and cd_produto		= :cd_produto 
	and nr_nf			= :nr_nf 
	and de_especie		= :de_especie
	and de_serie		= :de_serie
	group by nr_lote,
				dh_validade
) as tudo 
where de_tipo = :de_tipo" arguments=(("cd_filial", number),("cd_produto", number),("nr_nf", number),("de_especie", string),("de_serie", string),("de_tipo", string)) )
