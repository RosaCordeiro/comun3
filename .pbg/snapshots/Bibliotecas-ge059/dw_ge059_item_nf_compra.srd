table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="item_nf_compra.cd_filial" )
 column=(type=char(9) update=yes updatewhereclause=yes key=yes name=cd_fornecedor dbname="item_nf_compra.cd_fornecedor" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_nf dbname="item_nf_compra.nr_nf" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=de_especie dbname="item_nf_compra.de_especie" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=de_serie dbname="item_nf_compra.de_serie" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_natureza_operacao dbname="item_nf_compra.cd_natureza_operacao" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="item_nf_compra.cd_produto" )
 column=(type=long update=yes updatewhereclause=yes name=qt_faturada dbname="item_nf_compra.qt_faturada" )
 retrieve="select cd_filial,   
       cd_fornecedor,   
       nr_nf,   
       de_especie,   
       de_serie,   
       cd_natureza_operacao,   
       cd_produto,   
       qt_faturada  
from item_nf_compra   
where cd_filial     = :filial
  and cd_fornecedor = :fornecedor
  and nr_nf         = :nf
  and de_especie    = :especie
  and de_serie      = :serie
" update="item_nf_compra" updatewhere=1 updatekeyinplace=no arguments=(("filial", number),("fornecedor", string),("nf", number),("especie", string),("serie", string)) )
