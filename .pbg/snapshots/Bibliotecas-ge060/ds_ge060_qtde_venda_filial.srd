table(column=(type=long updatewhereclause=yes name=cd_filial dbname="resumo_movto_estq_prd.cd_filial" dbalias="r.cd_filial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="resumo_movto_estq_prd.cd_produto" dbalias="r.cd_produto" )
 column=(type=long updatewhereclause=yes name=qtde dbname="qtde" )
 retrieve="	Select r.cd_filial, r.cd_produto, Sum(r.qt_venda - r.qt_devolucao_venda) as qtde
	From resumo_movto_estq_prd r
	Where r.dh_resumo between :dt_inicio and :dt_fim
	  and exists (select pz1.cd_produto 
				     from produto_procurado_zerado pz1 
					where pz1.dh_movimentacao between :dt_inicio and :dt_fim
						and pz1.cd_produto = r.cd_produto
						and pz1.cd_filial = r.cd_filial
						and pz1.id_tipo = 'F')
	group by r.cd_filial, r.cd_produto" arguments=(("dt_inicio", date),("dt_fim", date))  sort="cd_filial A cd_produto A " )
