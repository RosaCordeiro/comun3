table(column=(type=char(1) updatewhereclause=yes name=cd_grupo_produto dbname="grupo.cd_grupo_produto" dbalias="vw.cd_grupo_produto" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_venda_grupo dbname="vl_venda_grupo" )
 retrieve="SELECT vw.cd_grupo as cd_grupo_produto,
         sum(round((rm.qt_venda - rm.qt_devolucao_venda) * (pg.vl_preco_venda_atual / pg.vl_fator_conversao),2)) as vl_venda_grupo
FROM resumo_movto_estq_prd  rm
INNER JOIN produto_geral pg
	ON rm.cd_produto = pg.cd_produto
INNER JOIN grupo vw
     ON vw.cd_grupo = substring(pg.cd_subcategoria,1,1)
WHERE rm.dh_resumo between :inicio and :fim
	  and exists (select pz1.cd_produto 
				     from produto_procurado_zerado pz1 
					INNER JOIN produto_geral pg1 (index pk_produto_geral)
						ON pg1.cd_produto = pz1.cd_produto
					where pz1.dh_movimentacao between :inicio and :fim
						and substring(pg1.cd_subcategoria,1,1) = vw.cd_grupo
						and pz1.cd_filial = rm.cd_filial
						and pz1.id_tipo = 'F')
group by vw.cd_grupo

" arguments=(("inicio", date),("fim", date))  sort="cd_grupo_produto A " )
