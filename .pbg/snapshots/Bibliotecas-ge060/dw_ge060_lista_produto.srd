table(column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(102) updatewhereclause=yes name=produto dbname="produto" )
 column=(type=char(1) updatewhereclause=yes name=cd_grupo_produto dbname="vw_classificacao_produto.cd_grupo_produto" dbalias="vw.cd_grupo_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo_produto dbname="vw_classificacao_produto.de_grupo_produto" dbalias="vw.de_grupo_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" dbalias="pg.id_situacao" values="INATIVO	I/PENDENTE	P/ATIVO	A/" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_reposicao dbname="cd_classe_reposicao" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_preco_venda_atual dbname="vl_preco_venda_atual" initial="0" )
 column=(type=long updatewhereclause=yes name=qt_consulta dbname="qt_consulta" initial="0" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="qt_recebida" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_grupo_geral dbname="vl_venda_grupo_geral" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_geral_vendas dbname="vl_total_geral_vendas" initial="0" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="qt_vendida" initial="0" )
 retrieve="  SELECT	ppc.cd_produto	as cd_produto,
			pg.de_produto + ': ' + pg.de_apresentacao_venda as produto,
			vw.cd_grupo	as cd_grupo_produto,
			vw.de_grupo	as de_grupo_produto,  
			pg.id_situacao	as id_situacao,
			min(r.cd_classe_reposicao) as cd_classe_reposicao,
			(pg.vl_preco_venda_atual / pg.vl_fator_conversao)  as vl_preco_venda_atual, 
			sum(ppc.qt_consulta) as qt_consulta,
			sum(ppc.qt_recebida_outra_filial) as qt_recebida,
			0.00	as vl_venda_grupo_geral,
			0.00	as vl_total_geral_vendas,
			0		as qt_vendida
    FROM produto_procurado_zerado ppc (index idx_dt_fil_produto) 
INNER JOIN	produto_geral	as pg
	ON pg.cd_produto = ppc.cd_produto
INNER JOIN	vw_classificacao_produto as vw
	ON pg.cd_subcategoria  = vw.cd_subcategoria
LEFT OUTER JOIN resumo_reposicao_estoque	as r
	ON r.cd_filial	 	= ppc.cd_filial
   AND r.cd_produto	= ppc.cd_produto
WHERE ppc.dh_movimentacao between :dt_inicio and :dt_termino
GROUP BY	ppc.cd_produto,   
				pg.de_produto + ': ' + pg.de_apresentacao_venda, 
				vw.cd_grupo,
				vw.de_grupo,  
				pg.id_situacao,
				(pg.vl_preco_venda_atual / pg.vl_fator_conversao)" arguments=(("dt_inicio", date),("dt_termino", date))  sort="cd_grupo_produto A cd_classe_reposicao A produto A " )
