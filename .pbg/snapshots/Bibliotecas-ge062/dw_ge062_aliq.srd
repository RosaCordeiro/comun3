table(column=(type=decimal(2) updatewhereclause=yes name=vl_base_calculo dbname="aliquota_mapa_resumo_ecf.vl_base_calculo" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_aliquota dbname="aliquota_mapa_resumo_ecf.pc_aliquota" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="aliquota_mapa_resumo_ecf.vl_icms" )
 retrieve="select vl_base_calculo, pc_aliquota, vl_icms
from aliquota_mapa_resumo_ecf
Where cd_filial = :filial
	And nr_mapa = :mapa
	And nr_ecf = :ecf
	And de_especie = :especie
	And de_serie = :serie
" arguments=(("filial", number),("mapa", number),("ecf", number),("especie", string),("serie", string))  sort="pc_aliquota A " )
