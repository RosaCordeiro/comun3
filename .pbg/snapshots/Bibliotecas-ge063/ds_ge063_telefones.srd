footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=char(2) update=yes updatewhereclause=yes key=yes name=nr_ddd dbname="telefone_drogaria.nr_ddd" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=nr_telefone dbname="telefone_drogaria.nr_telefone" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_tipo dbname="telefone_drogaria.id_tipo" )
 retrieve="  SELECT t.nr_ddd,   
         t.nr_telefone,   
         t.id_tipo  
    FROM telefone_drogaria t  
   WHERE t.cd_centro_custo = :centro_custo
     AND t.id_situacao = '4'
" update="telefone_drogaria" updatewhere=1 updatekeyinplace=no arguments=(("centro_custo", number)) )
text(band=header alignment="2" text="Nr Ddd"border="0" color="8388608" x="5" y="4" height="64" width="183"  name=nr_ddd_t  font.face="Arial" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
