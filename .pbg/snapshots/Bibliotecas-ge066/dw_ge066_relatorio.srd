table(column=(type=datetime updatewhereclause=yes name=dh_movimento dbname="movimento_estoque.dh_movimento" )
 column=(type=number updatewhereclause=yes name=nr_movimento_estoque dbname="movimento_estoque.nr_movimento_estoque" )
 column=(type=long updatewhereclause=yes name=cd_tipo_movimento dbname="movimento_estoque.cd_tipo_movimento" )
 column=(type=long updatewhereclause=yes name=qt_movimento dbname="movimento_estoque.qt_movimento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="movimento_estoque.vl_custo_unitario" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="movimento_estoque.nr_nf" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_movimento dbname="tipo_movimento_estoque.de_tipo_movimento" )
 column=(type=char(1) updatewhereclause=yes name=id_entrada_saida dbname="tipo_movimento_estoque.id_entrada_saida" )
 column=(type=char(1) updatewhereclause=yes name=id_cancelamento dbname="tipo_movimento_estoque.id_cancelamento" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="movimento_estoque.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=serie dbname="movimento_estoque.de_serie" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="movimento_estoque.cd_cliente" )
 column=(type=char(40) updatewhereclause=yes name=cliente_nm_cliente dbname="cliente.nm_cliente" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="movimento_estoque.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="movimento_estoque.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=fornecedor_nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="movimento_estoque.cd_convenio" )
 column=(type=char(40) updatewhereclause=yes name=convenio_nm_fantasia dbname="convenio.nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_movimento dbname="tipo_movimento_estoque.id_tipo_movimento" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_custo dbname="movimento_estoque.dh_movimentacao_custo" )
 column=(type=long updatewhereclause=yes name=saldo_inicial dbname="saldo_inicial" )
 retrieve="select me.dh_movimento,   
		 me.nr_movimento_estoque,   
       me.cd_tipo_movimento,   
       me.qt_movimento,   
       me.vl_custo_unitario,   
       me.nr_nf,   
       tm.de_tipo_movimento,   
       tm.id_entrada_saida,   
       tm.id_cancelamento,   
       me.de_especie,   
       me.de_serie,   
       me.cd_cliente,   
       cl.nm_cliente,   
       me.cd_filial,   
       fi.nm_fantasia,   
       me.cd_fornecedor,   
       fo.nm_fantasia, 
       me.cd_convenio,   
       co.nm_fantasia,   
       tm.id_tipo_movimento,
       me.dh_movimentacao_custo,
       :saldo_inicial saldo_inicial
from movimento_estoque me,   
     tipo_movimento_estoque tm,   
     cliente cl,   
     filial fi,   
     fornecedor fo,
	  convenio co
where me.cd_tipo_movimento = tm.cd_tipo_movimento
  and fi.cd_filial 			=* me.cd_filial
  and cl.cd_cliente 			=* me.cd_cliente
  and fo.cd_fornecedor 		=* me.cd_fornecedor
  and co.cd_convenio		 	=* me.cd_convenio
  and me.cd_filial_movimento = :filial
  and me.cd_produto          = :produto
  and me.dh_movimento       >= :inicio
  and me.dh_movimento       <= :termino" arguments=(("filial", number),("produto", number),("inicio", date),("termino", date),("saldo_inicial", number))  sort="dh_movimentacao_custo A nr_movimento_estoque A " )
