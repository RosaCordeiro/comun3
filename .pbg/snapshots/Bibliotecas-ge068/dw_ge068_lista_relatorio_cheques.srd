table(column=(type=char(3) updatewhereclause=yes name=cd_banco dbname="cheque.cd_banco" )
 column=(type=char(5) updatewhereclause=yes name=nr_agencia dbname="cheque.nr_agencia" )
 column=(type=char(10) updatewhereclause=yes name=nr_conta dbname="cheque.nr_conta" )
 column=(type=char(10) updatewhereclause=yes name=nr_cheque dbname="cheque.nr_cheque" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cheque dbname="cheque.vl_cheque" )
 column=(type=char(8190) updatewhereclause=no name=filial dbname="filial" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cheque.cd_filial" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="cheque.dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_vencimento dbname="cheque.dh_vencimento" )
 column=(type=datetime updatewhereclause=yes name=dh_devolucao dbname="cheque.dh_devolucao" )
 column=(type=long updatewhereclause=yes name=cd_portador dbname="cheque.cd_portador" )
 column=(type=datetime updatewhereclause=yes name=dh_baixa dbname="cheque.dh_baixa" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="cliente_cheque.nm_cliente" )
 column=(type=char(8190) updatewhereclause=no name=telefone dbname="telefone" )
 retrieve="SELECT	c.cd_banco,
			c.nr_agencia,
			c.nr_conta,
			c.nr_cheque,
			c.vl_cheque,
			f.nm_fantasia || ' (' || c.cd_filial_inclusao || ')' AS filial,
			c.cd_filial_inclusao AS cd_filial,
			c.dh_emissao,
			c.dh_vencimento,
			c.dh_devolucao,
			c.cd_portador,
			c.dh_baixa,
			cc.nm_cliente,
			'(' || cc.nr_ddd_telefone || ') ' || cc.nr_telefone AS telefone
FROM cheque AS c
	INNER JOIN cliente_cheque AS cc
		ON cc.nr_cpf = c.nr_cpf_cliente
	INNER JOIN filial AS f
		ON f.cd_filial= c.cd_filial_inclusao"  sort="cd_filial A nm_cliente A " )
