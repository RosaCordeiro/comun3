table(column=(type=datetime updatewhereclause=yes name=dh_vencimento dbname="titulo_receber.dh_vencimento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_nominal dbname="vl_nominal" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_aberto dbname="vl_aberto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_juros dbname="vl_juros" )
 retrieve="select t.dh_vencimento,
       sum(t.vl_nominal) vl_nominal,
       sum(t.vl_aberto) vl_aberto,
		 0.00 vl_juros
from titulo_receber t,
     parametro p
where t.id_situacao = 'A'  
  and t.dh_vencimento between :inicio and :termino
  and t.id_tipo_titulo in ('CC', 'CV', 'CR')
  and datediff(day, t.dh_calculo_juros, getdate()) <= 0
group by t.dh_vencimento

union

select t.dh_vencimento,
       sum(t.vl_nominal) vl_nominal,
       sum(t.vl_aberto) vl_aberto,
		 sum((round(round(p.pc_juros_diario * t.vl_aberto, 2) / 100, 2)) * (datediff(day, t.dh_calculo_juros, getdate()))) vl_juros
from titulo_receber t,
     parametro p
where t.id_situacao = 'A'  
  and t.dh_vencimento between :inicio and :termino
  and t.id_tipo_titulo in ('CC', 'CV', 'CR')
  and datediff(day, t.dh_calculo_juros, getdate()) > 0
group by t.dh_vencimento" arguments=(("inicio", date),("termino", date))  sort="dh_vencimento A " )
