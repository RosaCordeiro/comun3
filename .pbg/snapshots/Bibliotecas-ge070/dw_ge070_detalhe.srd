table(column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_filial_produto.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_sugerida dbname="pedido_filial_produto.qt_sugerida" initial="0" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_filial_produto.qt_pedida" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="pedido_filial_produto.vl_custo_unitario" )
 column=(type=long updatewhereclause=yes name=nr_pedido_filial dbname="pedido_filial_produto.nr_pedido_filial" )
 column=(type=long updatewhereclause=yes name=qt_saldo_momento dbname="pedido_filial_produto.qt_saldo_momento" initial="0" )
 column=(type=long updatewhereclause=yes name=qt_atendida dbname="pedido_filial_produto.qt_atendida" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="pedido_filial_produto.qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="vw_saldo_atual_produto.qt_saldo_final" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="vw_classificacao_produto.de_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo dbname="vw_classificacao_produto.de_subgrupo" )
 column=(type=char(40) updatewhereclause=yes name=de_categoria dbname="vw_classificacao_produto.de_categoria" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="vw_classificacao_produto.de_subcategoria" )
 retrieve="select	g.de_produto,
		g.de_apresentacao_venda,
		p.cd_produto,
		p.qt_sugerida,
		p.qt_pedida,
		p.vl_custo_unitario,
		p.nr_pedido_filial,
		p.qt_saldo_momento,
		p.qt_atendida,
		p.qt_faturada,
		s.qt_saldo_final,
		v.de_grupo,
		v.de_subgrupo,
		v.de_categoria,
		v.de_subcategoria
from pedido_filial_produto as p
	inner join produto_geral as g
		on g.cd_produto = p.cd_produto
inner join vw_saldo_atual_produto as s
		on s.cd_filial = p.cd_filial
  	  and s.cd_produto = p.cd_produto
inner join vw_classificacao_produto as v
	on v.cd_subcategoria = g.cd_subcategoria
where p.cd_filial = :filial
	and p.nr_pedido_filial = :pedido" arguments=(("filial", number),("pedido", number))  sort="produto A " )
