table(column=(type=long updatewhereclause=yes name=nr_pedido_filial dbname="pedido_filial.nr_pedido_filial" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_filial.dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_pedido dbname="pedido_filial.vl_total_pedido" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="pedido_filial.id_situacao" values="ENVIADO	E/COLOCADO	C/CANCELADO	X/URGENTE	U/FINALIZADO	F/REJEITADO	J/" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_filial.cd_filial" )
 column=(type=char(1) updatewhereclause=yes name=id_gerado_logistica dbname="pedido_filial.id_gerado_logistica" values="MULTITASK	S/CLAMED	N/" )
 column=(type=datetime updatewhereclause=yes name=dh_geracao dbname="pedido_filial.dh_geracao" )
 column=(type=long updatewhereclause=yes name=nr_prioridade_distribuidora dbname="nr_prioridade_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="vw_filial.nm_fantasia" )
 retrieve="SELECT	p.nr_pedido_filial,
			p.dh_emissao,
			p.vl_total_pedido,
			p.id_situacao,
			p.cd_filial,
			p.id_gerado_logistica,
			p.dh_geracao,
			(Case
				When p.nr_prioridade_distribuidora <= 0 Then 0
				Else p.nr_prioridade_distribuidora - 1
			End) 	As nr_prioridade_distribuidora,
			v.nm_fantasia
FROM pedido_filial AS p
	INNER JOIN vw_filial AS v
		ON v.cd_filial = p.cd_filial"  sort="cd_filial A nr_pedido_filial A " )
