 column=(type=long updatewhereclause=yes name=pedido_filial_produto_qt_estoque_base dbname="pedido_filial_produto.qt_estoque_base" )
 column=(type=long updatewhereclause=yes name=pedido_filial_produto_qt_estoque_minimo dbname="pedido_filial_produto.qt_estoque_minimo" )
 column=(type=long updatewhereclause=yes name=pedido_filial_produto_qt_dias_reforco dbname="pedido_filial_produto.qt_dias_reforco" )
 column=(type=long updatewhereclause=yes name=pedido_filial_produto_qt_dias_reforco_estoque dbname="pedido_filial_produto.qt_dias_reforco_estoque" )
