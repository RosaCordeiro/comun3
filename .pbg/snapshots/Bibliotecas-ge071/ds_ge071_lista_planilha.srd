 column=(type=char(1) updatewhereclause=yes name=pedido_filial_produto_cd_classe_reposicao dbname="pedido_filial_produto.cd_classe_reposicao" )
 column=(type=long updatewhereclause=yes name=pedido_filial_produto_qt_saldo_momento dbname="pedido_filial_produto.qt_saldo_momento" )
