 column=(type=long updatewhereclause=yes name=pedido_filial_produto_qt_dias_cobertura dbname="pedido_filial_produto.qt_dias_cobertura" )
 column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="pedido_distribuidora.cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia_forn dbname="fornecedor.nm_fantasia_forn" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="pedido_distribuidora.nr_pedido_distribuidora" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_distribuidora.DH_EMISSAO" )
 column=(type=decimal(2) updatewhereclause=yes name=valor dbname="pedido_distribuidora.VALOR" )
 column=(type=char(12) updatewhereclause=yes name=de_situacao dbname="de_situacao" )
 column=(type=long updatewhereclause=yes name=nr_pedido_conexao dbname="pedido_distribuidora.nr_pedido_conexao" )
 column=(type=char(30) updatewhereclause=yes name=de_motivo_rejeicao dbname="pedido_distribuidora.de_motivo_rejeicao" )
 column=(type=long updatewhereclause=yes name=nr_rodada dbname="pedido_distribuidora.nr_rodada" )
 column=(type=char(1) updatewhereclause=yes name=id_projeto_conexao dbname="pedido_distribuidora.id_projeto_conexao" )
 column=(type=char(1) updatewhereclause=yes name=id_pedido_almoxarifado dbname="pedido_distribuidora.id_pedido_almoxarifado" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_pedido dbname="pedido_distribuidora.id_tipo_pedido" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_distribuidora_produto.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_atendida dbname="pedido_distribuidora_produto.qt_atendida" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="pedido_distribuidora_produto.qt_faturada" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="pedido_distribuidora_produto.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="pedido_distribuidora_produto.vl_icms_st" )
 column=(type=long updatewhereclause=yes name=nr_dias_pagamento dbname="pedido_distribuidora_produto.nr_dias_pagamento" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_conexao_lab dbname="pedido_distribuidora_produto.pc_desconto_conexao_lab" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_conexao_adicional dbname="pedido_distribuidora_produto.pc_desconto_conexao_adicional" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_repasse_icms dbname="pedido_distribuidora_produto.pc_repasse_icms" )
 column=(type=long updatewhereclause=yes name=qt_embalagem_padrao_distrib dbname="pedido_distribuidora_produto.qt_embalagem_padrao_distrib" )
 column=(type=long updatewhereclause=yes name=qt_estoque_disponivel_distrib dbname="pedido_distribuidora_produto.qt_estoque_disponivel_distrib" )
 column=(type=long updatewhereclause=yes name=nr_pedido_filial dbname="pedido_distribuidora.nr_pedido_filial" )
 retrieve="  SELECT 	p.cd_filial,   
				f.nm_fantasia nm_fantasia_filial,
				pp.cd_produto,   
				g.de_produto + g.de_apresentacao_estoque de_produto,
				pf.cd_classe_reposicao,
				pf.qt_saldo_momento,   
				pf.qt_sugerida,   
				pf.qt_pedida,   
				pf.vl_custo_unitario,   
				pf.nr_pedido_empurrado,   
				pf.qt_atendida qt_atendida_ped,   
				pf.qt_encomendada,   
				pf.qt_faturada,   
				pf.cd_promocao_sos,   
				pf.qt_estoque_base,   
				pf.qt_estoque_minimo,   
				pf.qt_dias_reforco,   
				pf.qt_dias_reforco_estoque,   
				pf.qt_cobertura_extra,   
				pf.qt_demanda_diaria,   
				pf.qt_dias_cobertura,
				p.cd_distribuidora,   
				fo.nm_fantasia nm_fantasia_forn, 
				p.nr_pedido_distribuidora,   
				p.dh_emissao DH_EMISSAO,   
				p.vl_total_pedido VALOR,   
				(CASE p.id_situacao
					WHEN  'E' THEN 'ENVIADO'
					WHEN 'C' THEN 'COLOCADO'
					WHEN 'F' THEN 'FATURADO'
					WHEN 'J' THEN 'REJEITADO'
					WHEN 'X' THEN 'CANCELADO'
					WHEN 'S' THEN 'EM SEPARA$$HEX2$$c700c300$$ENDHEX$$O'
					ELSE p.id_situacao
				END) de_situacao,
				p.nr_pedido_conexao,   
				p.de_motivo_rejeicao,   
				p.nr_rodada,   
				p.id_projeto_conexao,   
				p.id_pedido_almoxarifado,   
				p.id_tipo_pedido,   
				pp.qt_pedida,   
				pp.qt_atendida,   
				pp.qt_faturada,   
				pp.vl_preco_unitario,   
				pp.vl_icms_st,   
				pp.nr_dias_pagamento,   
				pp.pc_desconto_conexao_lab,   
				pp.pc_desconto_conexao_adicional,   
				pp.pc_repasse_icms,   
				pp.qt_embalagem_padrao_distrib,   
				pp.qt_estoque_disponivel_distrib,
				p.nr_pedido_filial
    FROM pedido_distribuidora p
inner join pedido_distribuidora_produto  pp
	on pp.cd_filial = p.cd_filial
	and pp.nr_pedido_distribuidora = p.nr_pedido_distribuidora
inner join filial f
	on f.cd_filial = p.cd_filial 
inner join fornecedor fo
	on fo.cd_fornecedor = p.cd_distribuidora
inner join produto_geral g
		on g.cd_produto = pp.cd_produto
inner join pedido_filial_produto pf
	on pf.cd_filial = p.cd_filial
	and pf.nr_pedido_filial = p.nr_pedido_filial
	and pf.cd_produto = pp.cd_produto
   WHERE p.dh_emissao >= :dh_inicio
		and p.dh_emissao <= :dh_termino
		and p.cd_filial = 13
" arguments=(("dh_inicio", date),("dh_termino", date)) )
