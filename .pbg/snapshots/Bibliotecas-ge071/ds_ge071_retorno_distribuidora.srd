table(column=(type=char(1) updatewhereclause=yes name=id_tipo_registro dbname="ID_TIPO_REGISTRO" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="NR_SEQUENCIAL" )
 column=(type=char(3) updatewhereclause=yes name=tipo_arquivo dbname="TIPO_ARQUIVO" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="pedido_distribuidora.cd_fornecedor" )
 column=(type=char(20) updatewhereclause=yes name=cd_cliente dbname="filial_distribuidora.cd_cliente" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="pedido_distribuidora.nr_pedido_distribuidora" )
 column=(type=char(1) updatewhereclause=yes name=id_rejeicao dbname="id_rejeicao" )
 column=(type=char(1) updatewhereclause=yes name=de_rejeicao dbname="de_rejeicao" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="filial.nr_cgc" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_pedido dbname="id_tipo_pedido" )
 column=(type=char(4) updatewhereclause=yes name=de_horario dbname="de_horario" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_det dbname="id_tipo_det" )
 column=(type=long updatewhereclause=yes name=nr_sequencial_det dbname="nr_sequencial_det" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_det dbname="distribuidora_produto.cd_produto_det" )
 column=(type=long updatewhereclause=yes name=qt_atendida_det dbname="pedido_distribuidora_produto.qt_atendida_det" )
 column=(type=char(1) updatewhereclause=yes name=de_motivo_rejeicao_det dbname="de_motivo_rejeicao_det" )
 column=(type=char(20) updatewhereclause=yes name=de_ean_det dbname="produto_geral.de_ean_det" )
 column=(type=char(1) updatewhereclause=yes name=cd_origem_merc_det dbname="produto_geral.cd_origem_merc_det" )
 retrieve="select 	'1' ID_TIPO_REGISTRO, 
			0 NR_SEQUENCIAL, 
			'RET' TIPO_ARQUIVO, 
			p.cd_distribuidora cd_fornecedor,
			f.cd_filial_distribuidora cd_cliente,
			p.nr_pedido_distribuidora,
			'N' id_rejeicao,
			'' de_rejeicao,
			fi.nr_cgc,
			'1' id_tipo_pedido,
			'0000' de_horario,
			'2' id_tipo_det,
			0 nr_sequencial_det,
			cd_produto_distribuidora cd_produto_det,
			pp.qt_pedida qt_atendida_det,
			'' de_motivo_rejeicao_det,
			g.de_codigo_barras de_ean_det,
			g.cd_st_origem cd_origem_merc_det
from pedido_distribuidora p
inner join filial_distribuidora f
		on f.cd_filial = p.cd_filial
	   and f.cd_distribuidora = p.cd_distribuidora
inner join filial fi
	on fi.cd_filial = p.cd_filial
inner join cidade ci
	on ci.cd_cidade = fi.cd_cidade
inner join pedido_distribuidora_produto pp
	on pp.cd_filial = p.cd_filial
	and pp.nr_pedido_distribuidora = p.nr_pedido_distribuidora
inner join distribuidora_produto dp
	on dp.cd_unidade_federacao = ci.cd_unidade_federacao
	and dp.cd_distribuidora = p.cd_distribuidora
	and dp.cd_produto = pp.cd_produto
inner join produto_geral g
	on g.cd_produto = pp.cd_produto
where p.cd_filial = :pl_cd_filial
  and p.nr_pedido_distribuidora in (:pl_nr_pedido)" arguments=(("pl_cd_filial", number),("pl_nr_pedido", number)) )
