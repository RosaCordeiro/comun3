table(column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_distribuidora_produto.cd_produto" dbalias="p.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=produto_geral_de_produto dbname="produto_geral.de_produto" dbalias="g.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=produto_geral_de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="g.de_apresentacao_venda" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_distribuidora_produto.qt_pedida" dbalias="p.qt_pedida" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="pedido_distribuidora_produto.vl_preco_unitario" dbalias="p.vl_preco_unitario" initial="0" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="pedido_distribuidora_produto.id_situacao" dbalias="p.id_situacao" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="pedido_distribuidora_produto.qt_faturada" dbalias="p.qt_faturada" initial="0" )
 column=(type=long updatewhereclause=yes name=qt_atendida dbname="pedido_distribuidora_produto.qt_atendida" dbalias="p.qt_atendida" )
 column=(type=char(50) updatewhereclause=yes name=de_motivo_rejeicao dbname="pedido_distribuidora_produto.de_motivo_rejeicao" dbalias="p.de_motivo_rejeicao" )
 column=(type=long updatewhereclause=yes name=qt_estoque_disponivel_distrib dbname="pedido_distribuidora_produto.qt_estoque_disponivel_distrib" dbalias="p.qt_estoque_disponivel_distrib" )
 column=(type=char(1) updatewhereclause=yes name=id_erro_sap dbname="id_erro_sap" )
 retrieve="Select	p.cd_produto,
		g.de_produto,
		g.de_apresentacao_venda,
		p.qt_pedida,
		p.vl_preco_unitario,
		p.id_situacao,
		p.qt_faturada,
		p.qt_atendida,
		p.de_motivo_rejeicao,
		p.qt_estoque_disponivel_distrib,
		Case When (Select count(*)
			from pedido_distri_prd_item_log pl
			Where pl.cd_filial = p.cd_filial
				and pl.nr_pedido_distribuidora = p.nr_pedido_distribuidora
				and pl.cd_produto = p.cd_produto) > 0 Then 'S' Else 'N' End as id_erro_sap
From pedido_distribuidora_produto As p
	Inner Join produto_geral As g
		On g.cd_produto = p.cd_produto
Where p.cd_filial = :filial
	And p.nr_pedido_distribuidora = :pedido" arguments=(("filial", number),("pedido", number))  sort="id_situacao A produto A " )
