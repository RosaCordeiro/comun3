table(column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="pedido_distribuidora.nr_pedido_distribuidora" dbalias="p.nr_pedido_distribuidora" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_distribuidora.dh_emissao" dbalias="p.dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_pedido dbname="pedido_distribuidora.vl_total_pedido" dbalias="p.vl_total_pedido" )
 column=(type=long updatewhereclause=yes name=qt_produtos dbname="qt_produtos" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="pedido_distribuidora.id_situacao" dbalias="p.id_situacao" values="ENVIADO	E/COLOCADO	C/FATURADO	F/REJEITADO	J/NAO ATENDIDO	N/EM SEPARA$$HEX2$$c700c300$$ENDHEX$$O	S/VALOR ABAIXO	V/CANCELADO	X/PENDENTE	P/" )
 column=(type=char(54) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="pedido_distribuidora.cd_distribuidora" dbalias="p.cd_distribuidora" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_distribuidora.cd_filial" dbalias="p.cd_filial" )
 column=(type=char(1) updatewhereclause=yes name=cbx_selecao dbname="cbx_selecao" values="	S/	N" )
 column=(type=char(40) updatewhereclause=yes name=de_filial dbname="filial.de_filial" dbalias="a.de_filial" )
 column=(type=char(50) updatewhereclause=yes name=de_motivo_rejeicao dbname="pedido_distribuidora.de_motivo_rejeicao" dbalias="p.de_motivo_rejeicao" )
 column=(type=char(20) updatewhereclause=yes name=id_tipo_pedido_desc dbname="id_tipo_pedido_desc" values="NORMAL	1/E-COMMERCE	2/CONVENI$$HEX1$$ca00$$ENDHEX$$NCIA	3/" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_pedido dbname="id_tipo_pedido" )
 column=(type=long updatewhereclause=yes name=nr_rodada dbname="pedido_distribuidora.nr_rodada" dbalias="p.nr_rodada" )
 column=(type=char(1) updatewhereclause=yes name=id_exportacao_sap dbname="pedido_distribuidora.id_exportacao_sap" dbalias="p.id_exportacao_sap" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_minimo_pedido dbname="vl_minimo_pedido" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_produtos_separados dbname="qt_produtos_separados" )
 column=(type=long updatewhereclause=yes name=qt_prd_faturados dbname="qt_prd_faturados" )
 column=(type=long updatewhereclause=yes name=qt_prd_separados dbname="qt_prd_separados" )
 column=(type=long updatewhereclause=yes name=nr_rota dbname="rota_entrega.nr_rota" dbalias="re.nr_rota" )
 column=(type=long updatewhereclause=yes name=nr_prioridade_faturamento dbname="filial.nr_prioridade_faturamento" dbalias="a.nr_prioridade_faturamento" )
 retrieve="Select distinct p.nr_pedido_distribuidora,
		p.dh_emissao,
		p.vl_total_pedido,
		(select count(*) from pedido_distribuidora_produto d
			where d.cd_filial = p.cd_filial
				and d.nr_pedido_distribuidora = p.nr_pedido_distribuidora) as qt_produtos,
		p.id_situacao,
		(f.nm_fantasia + ' - (' + p.cd_distribuidora + ')') as nm_fantasia,
		p.cd_distribuidora,
		p.cd_filial,
		'' As cbx_selecao,
		a.nm_fantasia As de_filial,
		p.de_motivo_rejeicao,
		coalesce(t.de_tipo, 'NORMAL') id_tipo_pedido_desc,
		Coalesce(p.id_tipo_pedido, '1') As id_tipo_pedido, 
		p.nr_rodada,
		p.id_exportacao_sap,
		coalesce(p.vl_minimo_pedido,0) vl_minimo_pedido,
		(SELECT
			    count(distinct x.cd_produto )
			FROM
			    nf_transferencia z
			    INNER JOIN dbo.item_nf_transferencia x ON x.nr_nf = z.nr_nf
			                                              AND x.de_especie = z.de_especie
			                                              AND x.de_serie = z.de_serie
													AND x.cd_filial_origem = z.cd_filial_origem
			WHERE
			    z.nr_pedido_distribuidora = p.nr_pedido_distribuidora
			    AND z.dh_cancelamento IS NULL
		) as qt_faturada,
		(select count(*) from pedido_distribuidora_produto d
			where d.cd_filial = p.cd_filial
				and d.nr_pedido_distribuidora = p.nr_pedido_distribuidora and d.qt_separada > 0 ) as qt_produtos_separados, 
		(select  COALESCE(sum(d1.qt_faturada),0)   from pedido_distribuidora_produto d1
		where d1.cd_filial = p.cd_filial 
		and d1.nr_pedido_distribuidora = p.nr_pedido_distribuidora and d1.qt_faturada  > 0  ) as qt_prd_faturados, 		
		(select COALESCE(sum(d2.qt_separada),0)    	 from pedido_distribuidora_produto d2
		 where d2.cd_filial = p.cd_filial
		 and d2.nr_pedido_distribuidora = p.nr_pedido_distribuidora   and  d2.qt_separada >0   ) as qt_prd_separados, 
		 re.nr_rota, a.nr_prioridade_faturamento
From	pedido_distribuidora As p
	Left Outer Join pedido_distribuidora_produto pp
		on pp.cd_filial = p.cd_filial
		and pp.nr_pedido_distribuidora = p.nr_pedido_distribuidora
	Inner Join fornecedor As f
		On f.cd_fornecedor = p.cd_distribuidora
	Inner Join filial As a
		On a.cd_filial = p.cd_filial
	Left outer join tipo_pedido_distribuidora t
		on t.id_tipo = p.id_tipo_pedido
	Inner Join rota_entrega re 
		on re.nr_rota  =  a.nr_rota_entrega 
Where p.dh_emissao Between :inicio And :termino" arguments=(("inicio", date),("termino", date))  sort="nr_pedido_distribuidora A " )
