table(column=(type=char(10) updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="pedido_distribuidora.nr_pedido_distribuidora" )
 column=(type=char(12) updatewhereclause=yes name=id_situacao_pedido dbname="id_situacao_pedido" )
 column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="pedido_distribuidora.cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=pedido_distribuidora_nr_rodada dbname="pedido_distribuidora.nr_rodada" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_distribuidora.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia_filial dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_distribuidora_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_distribuidora_produto.qt_pedida" )
 column=(type=decimal(8) updatewhereclause=yes name=vl_preco_unitario dbname="vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_total dbname="vl_preco_total" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="pedido_distribuidora_produto.qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_atendida dbname="pedido_distribuidora_produto.qt_atendida" )
 column=(type=long updatewhereclause=yes name=qt_falta_anterior dbname="qt_falta_anterior" )
 column=(type=long updatewhereclause=yes name=qt_falta dbname="qt_falta" )
 column=(type=long updatewhereclause=yes name=qt_estoque_disponivel_distrib dbname="pedido_distribuidora_produto.qt_estoque_disponivel_distrib" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" )
 column=(type=char(50) updatewhereclause=yes name=motivo_rejeicao_pedido dbname="pedido_distribuidora.motivo_rejeicao_pedido" )
 column=(type=char(50) updatewhereclause=yes name=motivo_rejeicao_produto dbname="pedido_distribuidora_produto.motivo_rejeicao_produto" )
 column=(type=long updatewhereclause=yes name=qt_embalagem_padrao_distrib dbname="pedido_distribuidora_produto.qt_embalagem_padrao_distrib" )
 column=(type=decimal(2) updatewhereclause=yes name=vlr_preco_compra dbname="vlr_preco_compra" )
 column=(type=long updatewhereclause=yes name=nr_rota dbname="rota_entrega.nr_rota" )
 column=(type=long updatewhereclause=yes name=nr_prioridade_faturamento dbname="filial.nr_prioridade_faturamento" )
 retrieve="Select convert(char(10), p.dh_emissao, 103) As dh_emissao,
			p.nr_pedido_distribuidora,
			(case p.id_situacao
				when 'C' then 'COLOCADO'
				when 'E' then 'ENVIADO'
				when 'F' then 'FATURADO'
				when 'J' then 'REJEITADO'
				when 'N' then 'N$$HEX1$$c300$$ENDHEX$$O ATENDIDO'
				when 'S' then 'EM SEPARA$$HEX2$$c700c300$$ENDHEX$$O'
				when 'X' then 'CANCELADO'
			end) As id_situacao_pedido,
			p.cd_distribuidora,
			f.nm_fantasia,
			p.nr_rodada,
			p.cd_filial,
			fi.nm_fantasia,
			pp.cd_produto,
			g.de_produto + ' : ' + g.de_apresentacao_venda As de_produto,
			pp.qt_pedida,
			(Case
				When pp.qt_faturada > 0 And pp.qt_embalagem_padrao_distrib > 1 Then Round(pp.vl_preco_unitario / pp.qt_faturada, 2)
				Else pp.vl_preco_unitario
			End) As vl_preco_unitario,
			(pp.vl_preco_unitario * pp.qt_pedida) As vl_preco_total,
			pp.qt_faturada,
			pp.qt_atendida,
			(pp.qt_pedida - (pp.qt_atendida / (coalesce(pp.qt_embalagem_padrao_distrib,1)) )) As qt_falta_anterior,
			(pp.qt_pedida - (pp.qt_faturada / (coalesce(pp.qt_embalagem_padrao_distrib,1)) )) As qt_falta,
			pp.qt_estoque_disponivel_distrib,
			g.cd_grupo_psico,
			p.de_motivo_rejeicao As motivo_rejeicao_pedido,
			pp.de_motivo_rejeicao As motivo_rejeicao_produto,
			pp.qt_embalagem_padrao_distrib ,
			coalesce(dp.vl_preco_novo, dp.vl_preco_atual) AS vlr_preco_compra,
			re.nr_rota, 
			fi.nr_prioridade_faturamento
From pedido_distribuidora As p
	Left Outer Join pedido_distribuidora_produto As pp
		On pp.cd_filial = p.cd_filial
		And pp.nr_pedido_distribuidora = p.nr_pedido_distribuidora
	Inner Join fornecedor As f
		On f.cd_fornecedor = p.cd_distribuidora
	Inner Join filial As fi
		On fi.cd_filial = p.cd_filial
	Inner Join produto_geral As g
		On g.cd_produto = pp.cd_produto
	Inner Join cidade c 
		On c.cd_cidade = f.cd_cidade 
	Left Join distribuidora_produto dp
		On dp.cd_distribuidora = p.cd_distribuidora 
		And dp.cd_produto = g.cd_produto 
		And dp.cd_unidade_federacao = c.cd_unidade_federacao
	Inner Join rota_entrega re 
		on re.nr_rota  =   fi.nr_rota_entrega  
Where p.dh_emissao Between :inicio And :termino
	And (p.de_motivo_rejeicao <> 'DISTRIBUICAO' Or p.de_motivo_rejeicao Is Null)



	" arguments=(("inicio", date),("termino", date))  sort="nm_fantasia_filial A dh_emissao A nm_fantasia A nr_pedido_distribuidora A de_produto A " )
