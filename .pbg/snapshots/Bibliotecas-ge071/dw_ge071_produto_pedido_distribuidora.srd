release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=92 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=cd_produto_distribuidora dbname="distribuidora_produto.cd_produto_distribuidora" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_distribuidora_produto.qt_pedida" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_distribuidora_produto.cd_produto" )
 retrieve="select d.cd_produto_distribuidora,   
       p.qt_pedida,
       p.cd_produto
from pedido_distribuidora_produto p,
     distribuidora_produto d
where p.cd_filial               = :filial
  and p.nr_pedido_distribuidora = :pedido
  and d.cd_distribuidora = :distribuidora
  and d.cd_produto = p.cd_produto
  and d.cd_unidade_federacao = (select c.cd_unidade_federacao
                                from filial f,
                                     cidade c
                                where f.cd_filial = :filial
                                  and c.cd_cidade = f.cd_cidade)  

" arguments=(("filial", number),("pedido", number),("distribuidora", string)) )
