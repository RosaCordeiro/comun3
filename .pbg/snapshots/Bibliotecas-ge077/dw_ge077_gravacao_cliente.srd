 retrieve="select cd_cliente,   
       id_tipo_cliente,   
       id_fisica_juridica,   
	  nm_razao_social,
	  nr_inscricao_estadual,
	  de_endereco_email_envio_xml,
       nm_cliente,   
       nr_cpf_cgc,   
       nr_rg,   
       de_orgao_emissor_rg,   
	   cd_uf_emissor_rg,
       dh_nascimento,   
       nm_mae,   
       id_sexo,   
       id_estado_civil,   
       id_possui_filhos,   
       dh_nascimento_filho_1,   
       dh_nascimento_filho_2,   
       dh_nascimento_filho_3,   
       dh_nascimento_filho_4,   
       cd_cidade,   
       de_endereco,   
       nr_endereco,   
       de_complemento,   
       de_bairro,   
       nr_cep,   
       id_tempo_residencia,   
       id_tipo_residencia,  
       de_endereco_email,    
       nr_ddd_fone_residencial,   
       nr_fone_residencial,   
       nr_ddd_celular,   
       nr_celular,   
       nr_ddd_fone_comercial,   
       nr_fone_comercial,   
       nr_ddd_fone_recado,   
       nr_fone_recado,   
       nm_empresa,   
       de_profissao,   
       id_natureza_ocupacao,   
       id_tempo_empresa,   
       vl_renda_mensal,   
       dh_calculo_credito,   
       cd_filial_calc_credito,   
       nr_matric_calc_credito,   
       dh_aprovacao_credito,   
       cd_filial_aprov_credito,   
       nr_matric_aprov_credito,   
       vl_limite_credito_calculado,   
       vl_limite_credito_aprovado,   
       cd_filial_credito_pendente,   
       id_contato_cliente,   
       cd_filial_centralizadora,   
       cd_portador,   
       nr_dia_vencimento,   
       id_medicamento_uso_continuo,   
       id_autoriza_comunicacao,   
       cd_filial_inclusao,   
       nr_matricula_inclusao,   
       dh_inclusao,   
       cd_filial_atualizacao,   
       nr_matricula_atualizacao,   
       dh_atualizacao,
       qt_pontos_proxima_compra,
		 id_documentacao_pendente,
		 nm_conjuge,
		 de_natureza_ocupacao,
		 nm_empresa_convenio,
		 id_permite_resgate_dependente,
		 id_permite_credito_dependente,
		 cd_grau_instrucao,
		Coalesce(id_falecido,'N') as id_falecido,
		nm_social
from cliente   
where cd_cliente = :cliente" update="cliente" updatewhere=1 updatekeyinplace=no arguments=(("cliente", string)) )
