table(column=(type=char(30) updatewhereclause=yes name=qt_pontos_total dbname="compute_0001" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="recibo_resgate_clube.cd_cliente" dbalias="r.cd_cliente" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_recibo_resgate dbname="recibo_resgate_clube.nr_recibo_resgate" dbalias="r.nr_recibo_resgate" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="recibo_resgate_clube_produto.cd_produto" dbalias="p.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_produto dbname="compute_0005" )
 column=(type=char(30) updatewhereclause=yes name=qt_pontos dbname="compute_0006" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="g.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="g.de_apresentacao_venda" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" dbalias="c.nm_cidade" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="cliente.nm_cliente" dbalias="l.nm_cliente" )
 column=(type=char(61) updatewhereclause=yes name=dh_resgate dbname="compute_0011" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="recibo_resgate_clube.cd_filial" dbalias="r.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_resgate dbname="recibo_resgate_clube.nr_matricula_resgate" dbalias="r.nr_matricula_resgate" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="u.nm_usuario" )
 column=(type=char(9) updatewhereclause=yes name=nr_cartao_smiles dbname="recibo_resgate_clube.nr_cartao_smiles" dbalias="r.nr_cartao_smiles" )
 column=(type=long updatewhereclause=yes name=qt_milhas dbname="qt_milhas" )
 retrieve="  select cast( r.qt_pontos as varchar ) as 'r.qt_pontos',
      	r.cd_cliente,   
      	r.nr_recibo_resgate,   
     		p.cd_produto,   
      	cast( p.qt_produto as integer) as 'p.qt_produto',	
		cast( p.qt_pontos as varchar ) as 'p.qt_pontos',
			g.de_produto,
			g.de_apresentacao_venda,
			c.nm_cidade,
			l.nm_cliente,
			dbo.tochar( r.dh_resgate, 'dd/mm/yyyy' ) || ' ' || dbo.tochar( r.dh_resgate, 'hh:mi:ss' ) as 'r.dh_resgate',
			r.cd_filial,
			f.nm_fantasia,
			r.nr_matricula_resgate,
			u.nm_usuario,
			r.nr_cartao_smiles,
			p.qt_produto / cast( pg.vl_parametro as integer ) as 'qt_milhas'
    from	recibo_resgate_clube r
			inner join recibo_resgate_clube_produto p
				on p.nr_recibo_resgate = r.nr_recibo_resgate
			inner join produto_geral g
				on p.cd_produto = g.cd_produto
			inner join filial f
				on r.cd_filial = f.cd_filial
			inner join cidade c
				on f.cd_cidade = c.cd_cidade
			inner join cliente l
				on r.cd_cliente = l.cd_cliente
			left outer join usuario u
				on r.nr_matricula_resgate = u.nr_matricula
			inner join parametro_geral pg
				on pg.cd_parametro 	= 'VL_CONVERSAO_PONTOS_SMILES'
   where 1 = 1"  sort="de_produto A de_apresentacao_venda A " )
