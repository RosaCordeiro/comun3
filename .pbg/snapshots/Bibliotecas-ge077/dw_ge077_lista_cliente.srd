       (CASE WHEN nm_social is not null THEN nm_social ELSE nm_cliente END) as nm_cliente,
       nr_cpf_cgc,
       nr_rg,
       id_tipo_cliente,
       nm_mae
from cliente" update="cliente" updatewhere=0 updatekeyinplace=no  sort="nm_cliente A " )
