 column=(type=char(2) updatewhereclause=yes name=id_tipo_cliente dbname="cliente.id_tipo_cliente" dbalias=".id_tipo_cliente" values="SOMENTE CADASTRO	SC/FIDELIDADE	RC/FIDELIDADE & PRAZO	CC/" )
