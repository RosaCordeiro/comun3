table(column=(type=decimal(0) updatewhereclause=yes identity=yes name=nr_movimento dbname="pontuacao_clube_movimento.nr_movimento" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_saldo_pontos dbname="pontuacao_clube_movimento.qt_saldo_pontos" )
 column=(type=char(1) updatewhereclause=yes name=id_credito_debito dbname="pontuacao_clube_tipo_movimento.id_credito_debito" )
 retrieve="select m.nr_movimento,
       m.qt_saldo_pontos,
       t.id_credito_debito
from pontuacao_clube_movimento m,
     pontuacao_clube_tipo_movimento t
where m.id_situacao_pontos = 'D'
  and t.cd_tipo_movimento = m.cd_tipo_movimento
order by m.nr_movimento
" )
