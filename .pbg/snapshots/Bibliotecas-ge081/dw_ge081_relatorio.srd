table(column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(60) update=yes updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=decimal(13) update=yes updatewhereclause=yes name=vl_preco_venda_atual dbname="vl_preco_venda_atual" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto_clube_atual dbname="produto_geral.pc_desconto_clube_atual" )
 retrieve="Select	g.cd_produto,   
		g.de_produto,   
		g.de_apresentacao_venda,   
		round(u.vl_preco_venda_atual / g.vl_fator_conversao, 2) vl_preco_venda_atual,
		g.pc_desconto_clube_atual
 From produto_geral g, produto_uf u, vw_filial v
Where g.pc_desconto_clube_atual > 0   
	and v.cd_uf			= u.cd_unidade_federacao
	and u.cd_produto	= g.cd_produto
	and v.cd_filial		= :filial		" arguments=(("filial", number))  sort="de_produto A " )
