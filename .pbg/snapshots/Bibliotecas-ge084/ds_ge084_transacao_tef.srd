			vl_transacao,   
			dt_transacao,   
			id_situacao,   
			nr_nsu_sitef,   
			nr_autorizacao,   
			nr_cartao,   
			qt_parcelas,   
			nr_sequencial,   
			de_bandeira,   
			cd_estabelecimento,   
			de_via_caixa,   
			de_via_cliente,   
			nr_celular,   
			vl_saque,   
			cd_caixa,   
			nr_controle_caixa,   
			nr_transacao,   
			dt_predatado,
			nr_cnpj_credenciadora,
			cd_psp_recebedor,
			cd_autorizacao_cd,
			id_tipo_uso_cd,
			cd_bandeira_sefaz
    FROM transacao_tef" update="transacao_tef" updatewhere=1 updatekeyinplace=no )
