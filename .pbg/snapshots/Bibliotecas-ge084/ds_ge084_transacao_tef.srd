 retrieve="SELECT  nr_ecf,   
			nr_coo_ecf,   
			cd_funcao,   
			nr_nsu_host,   
			cd_modalidade,   
			de_modalidade,   
			cd_forma_pagamento,   
			cd_autorizadora,   
