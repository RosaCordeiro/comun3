table(column=(type=char(1) update=yes updatewhereclause=yes name=id_registro dbname="prescritor_receita.id_registro" values="CRM	M/CRO	O/CRV	V/CRN	N/COREN	E/PMM	P/RMS	R/" )
 column=(type=char(8) update=yes updatewhereclause=yes name=nr_registro dbname="prescritor_receita.nr_registro" )
 column=(type=char(2) update=yes updatewhereclause=yes name=cd_uf dbname="prescritor_receita.cd_unidade_federacao" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_prescritor dbname="prescritor_receita.nm_prescritor" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_endereco dbname="prescritor_receita.de_endereco" )
 column=(type=char(20) update=yes updatewhereclause=yes name=de_bairro dbname="prescritor_receita.de_bairro" )
 column=(type=long update=yes updatewhereclause=yes name=cd_cidade dbname="prescritor_receita.cd_cidade" )
 column=(type=char(3) update=yes updatewhereclause=yes name=nr_ddd_telefone dbname="prescritor_receita.nr_ddd_telefone" )
 column=(type=char(10) update=yes updatewhereclause=yes name=nr_telefone dbname="prescritor_receita.nr_telefone" )
 column=(type=char(8) update=yes updatewhereclause=yes name=nr_cep dbname="prescritor_receita.nr_cep" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" )
 retrieve="  SELECT p.id_registro,   
         p.nr_registro,   
         p.cd_unidade_federacao,   
         p.nm_prescritor,   
         p.de_endereco,   
         p.de_bairro,   
         p.cd_cidade,   
         p.nr_ddd_telefone,   
         p.nr_telefone,   
         p.nr_cep,   
         c.nm_cidade  
    FROM prescritor_receita p
			LEFT OUTER JOIN cidade c
  			   ON c.cd_cidade = p.cd_cidade
"  sort="cd_uf A nm_prescritor A " )
