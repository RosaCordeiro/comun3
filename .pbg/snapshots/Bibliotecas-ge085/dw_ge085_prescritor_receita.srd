 retrieve="SELECT pr.id_registro						AS id_registro,   
			pr.nr_registro					AS nr_registro,
			pr.cd_unidade_federacao 	AS cd_unidade_federacao,
			pr.id_registro					AS id_registro_anterior,
			pr.nr_registro					AS nr_registro_anterior,
			pr.cd_unidade_federacao 	AS cd_unidade_federacao_anterior,
			pr.nm_prescritor 				AS nm_prescritor,
			pr.de_endereco 				AS de_endereco,
			pr.de_bairro 					AS de_bairro,
			pr.cd_cidade 					AS cd_cidade,
			pr.nr_ddd_telefone 			AS nr_ddd_telefone,
			pr.nr_telefone 					AS nr_telefone,
			pr.nr_cep 						AS nr_cep,
			space(40) 						AS localizacao,
			ci.nm_cidade 					AS nm_cidade,
			pr.cd_filial_atualizacao 		AS cd_filial_atualizacao,
			pr.nr_matricula_alteracao 	AS nr_matricula_alteracao,
			'S' 								AS id_localizado
    FROM prescritor_receita as pr
			LEFT OUTER JOIN cidade as ci
			  ON ci.cd_cidade = pr.cd_cidade 
	WHERE pr.id_registro					= :ps_id_registro 
		AND pr.nr_registro					= :ps_nr_registro 
		AND pr.cd_unidade_federacao	= :ps_uf" update="prescritor_receita" updatewhere=0 updatekeyinplace=yes arguments=(("ps_id_registro", string),("ps_nr_registro", string),("ps_uf", string)) )
