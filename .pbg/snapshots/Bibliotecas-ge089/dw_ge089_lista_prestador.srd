 column=(type=char(40) updatewhereclause=yes name=nm_prestador dbname="prestador_servico_clube.nm_prestador" )
 column=(type=long updatewhereclause=yes name=cd_cidade dbname="prestador_servico_clube.cd_cidade" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" )
 retrieve="  SELECT p.cd_prestador,   
         p.nm_prestador,   
         p.cd_cidade,   
         c.nm_cidade  
    FROM prestador_servico_clube p,   
         cidade c  
   WHERE c.cd_cidade = p.cd_cidade 
	 and (p.id_situacao = 'A' or p.id_situacao is null)  
						
"  sort="nm_prestador A " )
