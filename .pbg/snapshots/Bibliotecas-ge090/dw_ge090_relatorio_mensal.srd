table(column=(type=datetime updatewhereclause=yes name=dt_mes dbname="dt_mes" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_regiao dbname="cd_regiao" )
 column=(type=char(40) updatewhereclause=yes name=id_rede_filial dbname="parametro_loja.id_rede_filial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_medicamento dbname="vl_medicamento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_popular dbname="vl_popular" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_perfumaria dbname="vl_perfumaria" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_conveniencia dbname="vl_conveniencia" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_diversos dbname="vl_diversos" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_manipulado dbname="vl_manipulado" )
 retrieve="select 	r.dh_resumo as dt_mes,
			r.cd_filial,
			f.nm_fantasia, 
			f.cd_regiao,
			p.vl_parametro as id_rede_filial,
			sum(case when substring(pg.cd_subcategoria,1,1) = '1' then r.vl_venda else 0.00 end) as vl_medicamento,
			sum(case when substring(pg.cd_subcategoria,1,1) = '2' then r.vl_venda else 0.00 end) as vl_popular,
			sum(case when substring(pg.cd_subcategoria,1,1) = '3' then r.vl_venda else 0.00 end) as vl_perfumaria,
			sum(case when substring(pg.cd_subcategoria,1,1) = '4' then r.vl_venda else 0.00 end) as vl_conveniencia,
			sum(case when substring(pg.cd_subcategoria,1,1) not in ('1','2','3','4','6') then r.vl_venda else 0.00 end) as vl_diversos,
			sum(case when substring(pg.cd_subcategoria,1,1) = '6' then r.vl_venda else 0.00 end) as vl_manipulado
from resumo_produto_filial r (index idx_data_filial)
Inner join filial f (index pk_filial)
	on f.cd_filial = r.cd_filial
Inner Join produto_geral pg (index pk_produto_geral)
	on pg.cd_produto = r.cd_produto
Left outer Join parametro_loja p
	on p.cd_filial = f.cd_filial
	and p.cd_parametro = 'ID_REDE_FILIAL'
Where r.dh_resumo between :dt_inicio and :dt_fim
Group by r.dh_resumo,
			r.cd_filial,
			f.nm_fantasia, 
			f.cd_regiao,
			p.vl_parametro" arguments=(("dt_inicio", date),("dt_fim", date)) )
