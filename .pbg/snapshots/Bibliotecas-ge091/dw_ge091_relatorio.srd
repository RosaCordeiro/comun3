table(column=(type=char(3) updatewhereclause=yes name=cd_banco dbname="cheque.cd_banco" )
 column=(type=char(5) updatewhereclause=yes name=nr_agencia dbname="cheque.nr_agencia" )
 column=(type=char(10) updatewhereclause=yes name=nr_conta dbname="cheque.nr_conta" )
 column=(type=char(10) updatewhereclause=yes name=nr_cheque dbname="cheque.nr_cheque" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cheque dbname="cheque.vl_cheque" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="cheque.dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_vencimento dbname="cheque.dh_vencimento" )
 column=(type=datetime updatewhereclause=yes name=dh_devolucao dbname="cheque.dh_devolucao" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo_devolucao dbname="cheque.de_motivo_devolucao" )
 column=(type=datetime updatewhereclause=yes name=dh_baixa dbname="cheque.dh_baixa" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="cliente_cheque.nm_cliente" )
 column=(type=char(40) updatewhereclause=yes name=nm_filial dbname="filial.nm_fantasia" )
 column=(type=char(14) updatewhereclause=yes name=nr_cpf_cliente dbname="cheque.nr_cpf_cliente" )
 column=(type=char(1) updatewhereclause=yes name=id_funcionario dbname="id_funcionario" )
 retrieve="SELECT cheque.cd_banco, 
		 cheque.nr_agencia, 
		 cheque.nr_conta,   
		 cheque.nr_cheque ,    
		 cheque.vl_cheque ,   
		 cheque.cd_filial_inclusao 'cd_filial',    
		 cheque.dh_emissao ,     
		 cheque.dh_vencimento ,   
		 cheque.dh_devolucao ,  
		 cheque.de_motivo_devolucao , 
		 cheque.dh_baixa ,       
		 cliente_cheque.nm_cliente ,  
		 filial.nm_fantasia,
		 cheque.nr_cpf_cliente,
		 'N' id_funcionario    
FROM cheque,
     cliente_cheque,
     filial
WHERE ( cliente_cheque.nr_cpf = cheque.nr_cpf_cliente )
  AND ( filial.cd_filial      = cheque.cd_filial_inclusao )"  sort="cd_filial A nm_cliente A " )
