 column=(type=char(2) updatewhereclause=yes name=hr_fechamento dbname="HR_FECHAMENTO" values="10	10/11	11/12	12/13	13/14	14/15	15/16	16/17	17/18	18/19	19/20	20/21	21/22	22/23	23/00	00/01	01/02	02/03	03/04	04/05	05/06	06/07	07/08	08/09	09/" )
 column=(type=char(4) updatewhereclause=yes name=mn_fechamento dbname="MN_FECHAMENTO" values="00	00/10	10/15	15/20	20/30	30/40	40/50	50/" )
 retrieve="  SELECT SUBSTRING(vl_parametro, 1, 2) AS DIA,
			SUBSTRING(vl_parametro, 3, 2) AS HR_ABERTURA,
			SUBSTRING(vl_parametro, 5, 2) AS MN_ABERTURA,
			SUBSTRING(vl_parametro, 7, 2) AS HR_FECHAMENTO,
			SUBSTRING(vl_parametro, 9, 4) AS MN_FECHAMENTO
    FROM parametro_loja  
   WHERE cd_parametro like 'DE_HORARIO_%'
" )
