 retrieve="SELECT 	cd_filial_origem,
			 nr_nf,
			 de_especie,
			 de_serie,
			 cd_natureza_operacao,
			 cd_produto,
			 cd_filial_destino,
			 cd_situacao_tributaria,
			 qt_transferida,
			 vl_custo_unitario,
			 pc_icms,
			 vl_custo_gerencial,
			 vl_bc_icms_st,
			 vl_icms_st,
			 vl_bc_icms,
			 vl_icms,
			 pc_icms_st,
			 pc_reducao_base_st,
			 cd_cst_origem,
			 cd_cst_tributacao,
			 cd_mensagem_fiscal,
			 vl_bc_icms_antecipacao,
			 pc_mva_icms_antecipacao,
			 pc_icms_antecipacao,
			 vl_icms_antecipacao,
			 vl_bc_icms_st_origem,
			 pc_icms_st_origem,
			 vl_icms_st_origem,
			 de_chave_acesso_origem,
			 nr_sequencial,
			 vl_bc_icms_st_retido,
			 vl_icms_st_retido,
			 pc_st_retido,
			 vl_icms_retido,
			 cd_beneficio,
			 vl_icms_operacao,
			 pc_icms_diferido,
			 vl_icms_diferido
    FROM item_nf_transferencia  
   WHERE cd_filial_origem = :filial AND  
         nr_nf				  = :nota AND  
         de_especie		  = :especie AND  
         de_serie			  = :serie" update="item_nf_transferencia" updatewhere=1 updatekeyinplace=no arguments=(("filial", number),("nota", number),("especie", string),("serie", string)) )
