 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=nr_lote dbname="item_nf_transferencia_lote.nr_lote" )
 column=(type=long update=yes updatewhereclause=yes name=qt_lote dbname="item_nf_transferencia_lote.qt_lote" )
 column=(type=date updatewhereclause=yes name=dt_fabricacao dbname="item_nf_transferencia_lote.dt_fabricacao" )
 column=(type=date updatewhereclause=yes name=dt_validade dbname="item_nf_transferencia_lote.dt_validade" )
 retrieve="  SELECT cd_filial_origem,   
         nr_nf,   
         de_especie,   
         de_serie,   
         cd_natureza_operacao,   
         cd_produto,   
         nr_lote,   
         qt_lote,
		dt_fabricacao,
		dt_validade  
    FROM item_nf_transferencia_lote   
	Where cd_filial_origem = :filial AND  
         nr_nf				  = :nota AND  
         de_especie		  = :especie AND  
         de_serie			  = :serie
" update="item_nf_transferencia_lote" updatewhere=1 updatekeyinplace=no arguments=(("filial", number),("nota", number),("especie", string),("serie", string)) )
