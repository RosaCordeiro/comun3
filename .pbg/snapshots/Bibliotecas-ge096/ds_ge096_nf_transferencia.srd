 retrieve=" SELECT nf_transferencia.cd_filial_origem ,
	     nf_transferencia.nr_nf ,
		  nf_transferencia.de_especie ,
		  nf_transferencia.de_serie ,
		  nf_transferencia.cd_filial_destino ,
		  nf_transferencia.dh_emissao ,
		  nf_transferencia.dh_movimentacao_caixa ,
		  nf_transferencia.vl_bc_icms ,
		  nf_transferencia.vl_icms ,
		  nf_transferencia.vl_bc_icms_st ,
		  nf_transferencia.vl_icms_st ,
		  nf_transferencia.vl_total_produtos ,
		  nf_transferencia.vl_total_nf ,
		  nf_transferencia.nr_matricula_operador ,
		  nf_transferencia.id_produto_vencido ,
		  nf_transferencia.dh_recebimento ,
		  nf_transferencia.dh_cancelamento ,
		  nf_transferencia.nr_matricula_cancelamento ,
		  nf_transferencia.cd_distribuidora ,
		  nf_transferencia.nr_pedido_distribuidora ,
		  nf_transferencia.id_estoque_automatico ,
		  nf_transferencia.dh_atualizacao_estoque ,
		  nf_transferencia.nr_matric_atualizacao_estoque ,
		  nf_transferencia.dh_exportacao ,
		  nf_transferencia.nr_nsu,
		  nf_transferencia.cd_remanejamento,
		   nf_transferencia.nr_itens
   FROM nf_transferencia
  WHERE ( nf_transferencia.cd_filial_origem = :filial_origem )
	 and ( nf_transferencia.nr_nf = :nota )
	 and ( nf_transferencia.de_especie = :especie )
	 and ( nf_transferencia.de_serie = :serie )   " update="nf_transferencia" updatewhere=1 updatekeyinplace=no arguments=(("filial_origem", number),("nota", number),("especie", string),("serie", string)) )
