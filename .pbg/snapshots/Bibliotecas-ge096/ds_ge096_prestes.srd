table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial_inclusao dbname="produto_preste_a_vencer.cd_filial_inclusao" dbalias=".cd_filial_inclusao" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=nr_etiqueta dbname="produto_preste_a_vencer.nr_etiqueta" dbalias=".nr_etiqueta" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="produto_preste_a_vencer.cd_produto" dbalias=".cd_produto" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_lote dbname="produto_preste_a_vencer.nr_lote" dbalias=".nr_lote" )
 column=(type=date update=yes updatewhereclause=yes name=dh_validade dbname="produto_preste_a_vencer.dh_validade" dbalias=".dh_validade" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="produto_preste_a_vencer.id_situacao" dbalias=".id_situacao" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_inclusao dbname="produto_preste_a_vencer.nr_matricula_inclusao" dbalias=".nr_matricula_inclusao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inclusao dbname="produto_preste_a_vencer.dh_inclusao" dbalias=".dh_inclusao" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_concede_desconto dbname="produto_preste_a_vencer.id_concede_desconto" dbalias=".id_concede_desconto" )
 retrieve="select  	cd_filial_inclusao,
			nr_etiqueta, 
			cd_produto, 
			nr_lote, 
			dh_validade, 
			id_situacao, 
			nr_matricula_inclusao, 
			dh_inclusao, 
			id_concede_desconto 
from  produto_preste_a_vencer
where cd_filial 		= :filial
and nr_nf 			= :nota
and de_especie 	= :especie
and de_serie		= :serie
and id_tipo_baixa  = 'T'	" update="produto_preste_a_vencer" updatewhere=1 updatekeyinplace=no arguments=(("filial", number),("nota", number),("especie", string),("serie", string)) )
