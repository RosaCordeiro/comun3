table(column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="nf_transferencia_online.cd_filial_origem" dbalias="o.cd_filial_origem" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_transferencia_online.nr_nf" dbalias="o.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_transferencia_online.de_especie" dbalias="o.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_transferencia_online.de_serie" dbalias="o.de_serie" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="nf_transferencia_online.cd_filial_destino" dbalias="o.cd_filial_destino" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao dbname="nf_transferencia_online.dh_atualizacao" dbalias="o.dh_atualizacao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_operador dbname="nf_transferencia.nr_matricula_operador" dbalias="n.nr_matricula_operador" )
 retrieve="SELECT	o.cd_filial_origem,   
			o.nr_nf,   
			o.de_especie,   
			o.de_serie,   
			o.cd_filial_destino,   
			f.nm_fantasia,   
			o.dh_atualizacao,
			n.nr_matricula_operador
    FROM nf_transferencia_online as o
			INNER JOIN filial as f
				ON f.cd_filial = o.cd_filial_destino
			INNER JOIN nf_transferencia n
				ON n.cd_filial_origem	= o.cd_filial_origem
			   AND n.nr_nf				= o.nr_nf
			   AND n.de_especie		= o.de_especie
			   AND n.de_serie			= o.de_serie
   WHERE o.dh_transferencia is null
"  sort="dh_atualizacao A " )
