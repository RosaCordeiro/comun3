table(column=(type=char(6) updatewhereclause=yes name=nr_matricula_conferente dbname="nr_matricula_conferente" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="nm_usuario" )
 column=(type=long updatewhereclause=yes name=qt_separada dbname="qt_separada" )
 column=(type=long updatewhereclause=yes name=segundos_trabalhados dbname="segundos_trabalhados" )
 retrieve="
select  nr_matricula_conferente,
		nm_usuario,
       sum(qt_separada) as qt_separada, 
        sum(segundos_trabalhados) as segundos_trabalhados
from(
select 
			nr_matricula_conferente,
			nm_usuario,
			sum(qt_separada) as qt_separada,
			dh_conferencia,
			cast(cast(datepart(month, dh_conferencia) as varchar)+'/01'+'/'+cast(datepart(year, dh_conferencia) as varchar) as date) as dh_mes_conferencia,
			case when sum(segundos_trabalhados) < 1 then
						1
					else
						case when id_noite = 'S' then
								case when sum(segundos_trabalhados) < 14400 then -- 4 horas
										sum(segundos_trabalhados)
									else
										sum(segundos_trabalhados) - 3600 --Desconta 1 hora de almo$$HEX1$$e700$$ENDHEX$$o
								end
							else
								sum(segundos_trabalhados)
						end
			end as segundos_trabalhados
from(
	--------------------------------Das 05:00 as 10:10----------------------------------------------------------------------
							 Select nr_matricula_conferente,
									  nm_usuario,
									  qt_separada,
									  dh_conferencia,
										DATEDIFF(SS, (select min(dh_inicio_conferencia) from wms_lista_separacao 
														  where nr_matricula_conferente = tudo1.nr_matricula_conferente 
														  and dh_termino_conferencia between tudo1.dh_inicio_filtro and  tudo1.dh_fim_filtro
                                                          and dh_inicio_conferencia between tudo1.dh_inicio_filtro and  tudo1.dh_fim_filtro),
														  (select max(dh_inicio_conferencia) from wms_lista_separacao 
														  where nr_matricula_conferente = tudo1.nr_matricula_conferente                       
														  and dh_termino_conferencia between tudo1.dh_inicio_filtro and  tudo1.dh_fim_filtro
                                                          and dh_inicio_conferencia between tudo1.dh_inicio_filtro and  tudo1.dh_fim_filtro)) 
										as segundos_trabalhados,
                                        'N' id_noite
							 from( 
										select tudo.nr_matricula_conferente,
												  tudo.nm_usuario,
												  isnull(sum(tudo.qt_separada), 0) as qt_separada,
												  tudo.dh_conferencia,
												  tudo.dh_inicio_filtro,
												  tudo.dh_fim_filtro
										from(
												  select 
												  a.nr_matricula_conferente,
												  b.nm_usuario,
												  case when sum(p.qt_separada)is not null then
															 sum(p.qt_separada)
														else
															 sum(p.qt_pedida * p.qt_caixa_padrao)
													end as qt_separada,
												  convert(date, a.dh_inicio_conferencia) dh_conferencia,
												  a.dh_inicio_conferencia,
												  a.dh_termino_conferencia,
												  convert(datetime,convert(varchar, a.dh_inicio_conferencia, 112)+' 05:00:00') as dh_inicio_filtro,
												  convert(datetime,convert(varchar, a.dh_inicio_conferencia, 112)+' 10:10:00') as dh_fim_filtro
												  from wms_lista_separacao a
												  inner join wms_lista_separacao_produto p on p.cd_filial = a.cd_filial
																										and p.nr_pedido_distribuidora = a.nr_pedido_distribuidora
																										and p.nr_volume = a.nr_volume
												  inner join usuario b on b.nr_matricula = a.nr_matricula_conferente
												  where a.dh_termino_conferencia  between :dh_inicio and :dh_termino
													  and a.nr_matricula_conferente is not null
													  and cast(a.dh_inicio_conferencia as time) between '05:00:00' and '10:10:00' --Somente funcion$$HEX1$$e100$$ENDHEX$$rios que trabalham de dia
												  group by    a.nr_matricula_conferente,
																  b.nm_usuario,
																  a.dh_inicio_conferencia,
																  a.dh_termino_conferencia
										) as tudo
										group by tudo.nr_matricula_conferente,
												  tudo.nm_usuario,
												  tudo.dh_conferencia,
												  tudo.dh_inicio_filtro,
												  tudo.dh_fim_filtro
							 ) as tudo1
--------------------------------------------------------------------------------------------------------------------------
                            union all
--------------------------------Das 11:10 as 21:00----------------------------------------------------------------------
                               Select nr_matricula_conferente,
									  nm_usuario,
									  qt_separada,
									  dh_conferencia,
										DATEDIFF(SS, (select min(dh_inicio_conferencia) from wms_lista_separacao 
														  where nr_matricula_conferente = tudo1.nr_matricula_conferente 
														  and dh_termino_conferencia between tudo1.dh_inicio_filtro and  tudo1.dh_fim_filtro
                                                          and dh_inicio_conferencia between tudo1.dh_inicio_filtro and  tudo1.dh_fim_filtro),
														  (select max(dh_termino_conferencia) from wms_lista_separacao 
														  where nr_matricula_conferente = tudo1.nr_matricula_conferente                       
														  and dh_termino_conferencia between tudo1.dh_inicio_filtro and  tudo1.dh_fim_filtro
                                                          and dh_inicio_conferencia between tudo1.dh_inicio_filtro and  tudo1.dh_fim_filtro)) 
										as segundos_trabalhados,
                                        'N' id_noite
							 from( 
										select tudo.nr_matricula_conferente,
												  tudo.nm_usuario,
												  isnull(sum(tudo.qt_separada), 0) as qt_separada,
												  tudo.dh_conferencia,
												  tudo.dh_inicio_filtro,
												  tudo.dh_fim_filtro
										from(
												  select 
												  a.nr_matricula_conferente,
												  b.nm_usuario,
												  case when sum(p.qt_separada)is not null then
															 sum(p.qt_separada)
														else
															 sum(p.qt_pedida * p.qt_caixa_padrao)
													end as qt_separada,
												  convert(date, a.dh_inicio_conferencia) dh_conferencia,
												  a.dh_inicio_conferencia,
												  a.dh_termino_conferencia,
												  convert(datetime,convert(varchar, a.dh_inicio_conferencia, 112)+' 11:10:00') as dh_inicio_filtro,
												  convert(datetime,convert(varchar, a.dh_inicio_conferencia, 112)+' 21:00:00') as dh_fim_filtro
												  from wms_lista_separacao a
												  inner join wms_lista_separacao_produto p on p.cd_filial = a.cd_filial
																										and p.nr_pedido_distribuidora = a.nr_pedido_distribuidora
																										and p.nr_volume = a.nr_volume
												  inner join usuario b on b.nr_matricula = a.nr_matricula_conferente
												  where a.dh_termino_conferencia  between :dh_inicio and :dh_termino
													  and a.nr_matricula_conferente is not null
													  and cast(a.dh_inicio_conferencia as time) between '11:10:00' and '21:00:00' --Somente funcion$$HEX1$$e100$$ENDHEX$$rios que trabalham de dia
												  group by    a.nr_matricula_conferente,
																  b.nm_usuario,
																  a.dh_inicio_conferencia,
																  a.dh_termino_conferencia
										) as tudo
										group by tudo.nr_matricula_conferente,
												  tudo.nm_usuario,
												  tudo.dh_conferencia,
												  tudo.dh_inicio_filtro,
												  tudo.dh_fim_filtro
							 ) as tudo1
---------------------------------------------Funcion$$HEX1$$e100$$ENDHEX$$rios que trabalham a noite-------------------------------------------
                            union all
                            Select nr_matricula_conferente,
									  nm_usuario,
									  qt_separada,
									  dh_conferencia,
										DATEDIFF(SS, (select case when min(dh_inicio_conferencia)is not null then min(dh_inicio_conferencia) else convert(datetime,convert(varchar, tudo1.dh_inicio_filtro, 112)+' 00:00:00') end  from wms_lista_separacao 
														  where nr_matricula_conferente = tudo1.nr_matricula_conferente 
														  and dh_termino_conferencia between convert(datetime,convert(varchar, dateadd(day, -1, tudo1.dh_inicio_filtro), 112)+' 21:00:00') and  convert(datetime,convert(varchar, dateadd(day, -1, tudo1.dh_fim_filtro), 112)+' 23:59:59')),
														  (select case when max(dh_termino_conferencia) is not null then max(dh_termino_conferencia) else convert(datetime,convert(varchar, dateadd(day, -1, tudo1.dh_inicio_filtro), 112)+' 00:00:00') end  from wms_lista_separacao 
														  where nr_matricula_conferente = tudo1.nr_matricula_conferente                       
														  and dh_termino_conferencia between convert(datetime,convert(varchar, tudo1.dh_inicio_filtro, 112)+' 00:00:00') and  convert(datetime,convert(varchar, tudo1.dh_inicio_filtro, 112)+' 05:00:00'))) 
										as segundos_trabalhados,
                                        'S' id_noite

							 from( 
										select tudo.nr_matricula_conferente,
												  tudo.nm_usuario,
												  isnull(sum(tudo.qt_separada), 0) as qt_separada,
												  tudo.dh_conferencia,
												  tudo.dh_inicio_filtro,
												  tudo.dh_fim_filtro
										from(
												  select 
												  a.nr_matricula_conferente,
												  b.nm_usuario,
												  case when sum(p.qt_separada)is not null then
															 sum(p.qt_separada)
														else
															 sum(p.qt_pedida * p.qt_caixa_padrao)
													end as qt_separada,
                                                  case when cast(a.dh_inicio_conferencia as time) > '21:00:00' then  convert(date, dateadd(day, 1, a.dh_inicio_conferencia)) else convert(date, a.dh_inicio_conferencia) end dh_conferencia,
												  a.dh_inicio_conferencia,
												  a.dh_termino_conferencia,
                                                  convert(datetime,convert(varchar, case when cast(a.dh_inicio_conferencia as time) > '21:00:00' then dateadd(day, 1, a.dh_inicio_conferencia) else a.dh_inicio_conferencia end, 112)+' 21:00:00') as dh_inicio_filtro,
                                                  convert(datetime,convert(varchar, case when cast(a.dh_inicio_conferencia as time) > '05:00:00' then dateadd(day, 1, a.dh_inicio_conferencia) else a.dh_inicio_conferencia end, 112)+' 05:00:00') as dh_fim_filtro 
												  from wms_lista_separacao a
												  inner join wms_lista_separacao_produto p on p.cd_filial = a.cd_filial
																										and p.nr_pedido_distribuidora = a.nr_pedido_distribuidora
																										and p.nr_volume = a.nr_volume
												  inner join usuario b on b.nr_matricula = a.nr_matricula_conferente
												  where a.dh_termino_conferencia between convert(datetime,convert(varchar, dateadd(day, -1, cast(:dh_inicio as date)), 112)+' 21:00:00') and convert(datetime,convert(varchar,  cast(:dh_termino as date), 112)+' 05:00:00')
													  and a.nr_matricula_conferente is not null
													  and (cast(dateadd(day, -1, a.dh_inicio_conferencia) as time) between '00:00:00' and '05:00:00' or cast(a.dh_inicio_conferencia as time) between '21:00:00' and '23:59:59' )--Somente funcion$$HEX1$$e100$$ENDHEX$$rios que trabalham a noite
												  group by    a.nr_matricula_conferente,
																  b.nm_usuario,
																  a.dh_inicio_conferencia,
																  a.dh_termino_conferencia
										) as tudo
										group by tudo.nr_matricula_conferente,
												  tudo.nm_usuario,
												  tudo.dh_conferencia,
												  tudo.dh_inicio_filtro,
												  tudo.dh_fim_filtro
                          ) as tudo1
--------------------------------------------------------------------------------------------------------------------

) as tudo2
group by	nr_matricula_conferente,
			nm_usuario,
			dh_conferencia,
			id_noite
) as tudo3
group by    nr_matricula_conferente,
		    nm_usuario
order by nm_usuario
" arguments=(("dh_inicio", datetime),("dh_termino", datetime)) )
