table(column=(type=datetime updatewhereclause=yes name=dh_cota dbname="dh_cota" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cota_prevista dbname="vl_cota_prevista" )
 column=(type=decimal(2) updatewhereclause=yes name=venda dbname="venda" )
 column=(type=decimal(2) updatewhereclause=yes name=perc_venda dbname="perc_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=cota_acm dbname="cota_acm" )
 column=(type=decimal(2) updatewhereclause=yes name=venda_acm dbname="venda_acm" )
 column=(type=decimal(2) updatewhereclause=yes name=perc_venda_acm dbname="perc_venda_acm" )
 column=(type=char(1) updatewhereclause=yes name=dia_semana dbname="dia_semana" )
 retrieve="  SELECT distinct(cota_filial.dh_cota),  
         sum(cota_filial.vl_cota) vl_cota_prevista,
         0.00 venda,
      	0.00 perc_venda,
         0.00 cota_acm,
         0.00 venda_acm,
			0.00 perc_venda_acm,
         ''dia_semana       
      FROM filial,   
           cota_filial
   WHERE filial.cd_filial     >= :pl_filial
     and filial.cd_filial     <= :pl_filial_ate
     and cota_filial.dh_cota  >= :pdt_inicio
     and cota_filial.dh_cota  <= :pdt_final
     and filial.cd_filial      = cota_filial.cd_filial
group by cota_filial.dh_cota
Order by cota_filial.dh_cota" arguments=(("pl_filial", number),("pl_filial_ate", number),("pdt_inicio", date),("pdt_final", date)) )
