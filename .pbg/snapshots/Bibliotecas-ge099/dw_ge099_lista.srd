 column=(type=char(100) updatewhereclause=yes name=de_complemento dbname="vw_endereco.de_complemento" )
 retrieve="SELECT nr_chave,
	   nr_cep,
	   de_endereco,
	   de_endereco || ' ' || coalesce( de_complemento, '' ) as de_endereco_complemento,
	   de_endereco_abreviado,
	   cd_uf,
	   de_bairro,
	   nr_bairro,
	   de_bairro_abreviado,
	   cd_cidade,
 	   nm_cidade,
	   de_complemento
  FROM vw_endereco"  sort="de_bairro A de_bairro_abreviado A de_endereco A de_endereco_abreviado A de_complemento A " )
