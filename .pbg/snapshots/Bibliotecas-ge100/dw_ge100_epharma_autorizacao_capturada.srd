 column=(type=char(101) updatewhereclause=yes name=de_produto dbname="de_produto" )
 retrieve="SELECT autorizacao_epharma_produto.nr_autorizacao,
			autorizacao_epharma_produto.cd_produto, 
			autorizacao_epharma_produto.de_codigo_barras, 
			autorizacao_epharma_produto.qt_autorizada, 
			autorizacao_epharma_produto.vl_preco_maximo,
			autorizacao_epharma_produto.vl_preco_com_desconto,
			autorizacao_epharma_produto.vl_preco_epharma,  
			autorizacao_epharma_produto.vl_preco_aquisicao,
			autorizacao_epharma_produto.vl_repasse_varejo, 
			autorizacao_epharma_produto.cd_motivo_rejeicao,
         produto_geral.de_produto + ':' + produto_geral.de_apresentacao_venda as de_produto
			FROM autorizacao_epharma_produto,
              produto_geral
			WHERE ( autorizacao_epharma_produto.nr_autorizacao = :ps_autorizacao )
           and ( autorizacao_epharma_produto.cd_produto     = produto_geral.cd_produto )
			  and (autorizacao_epharma_produto.qt_autorizada 	> 0)" arguments=(("ps_autorizacao", string)) )
