table(column=(type=char(7) updatewhereclause=yes name=dh_venda dbname="dh_venda" )
 column=(type=long updatewhereclause=yes name=qtd dbname="qtd" )
 retrieve="select substring(CONVERT( CHAR(10), v.dh_venda, 103 ), 4, 7) as dh_venda, sum(i.qt_devolvida) as qtd
from venda_pbm v
inner join nf_devolucao_venda d
    on d.cd_filial_venda = v.cd_filial
    and d.nr_nf_venda = v.nr_nf
    and d.de_especie_venda = v.de_especie
    and d.de_serie_venda = v.de_serie
inner join item_nf_devolucao_venda i
    on i.cd_filial = d.cd_filial
    and i.nr_nf = d.nr_nf
    and i.de_especie = d.de_especie
    and i.de_serie = d.de_serie
inner join venda_pbm_produto pp
    on pp.cd_filial = d.cd_filial_venda
  and pp.nr_nf    = d.nr_nf_venda
  and pp.de_especie = d.de_especie_venda
  and pp.de_serie = d.de_serie_venda
  and pp.cd_produto = i.cd_produto
  and pp.id_pbm = 'S'
where v.dh_venda >= :inicio
  and v.dh_venda <= :termino
  and d.dh_cancelamento is null
  and i.cd_produto = :produto
group by substring(CONVERT( CHAR(10), v.dh_venda, 103 ), 4, 7)" arguments=(("produto", number),("inicio", date),("termino", date))  sort="dh_venda D " )
