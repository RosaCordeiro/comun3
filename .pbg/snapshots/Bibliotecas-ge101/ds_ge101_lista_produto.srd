table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="produto_geral.cd_fornecedor_usual" )
 column=(type=char(100) updatewhereclause=yes name=de_descricao_internet dbname="produto_geral.de_descricao_internet" )
 column=(type=char(32771) updatewhereclause=no name=de_principal_internet dbname="produto_geral.de_principal_internet" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_largura_cm dbname="produto_geral.qt_largura_cm" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_altura_cm dbname="produto_geral.qt_altura_cm" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_profundidade_cm dbname="produto_geral.qt_profundidade_cm" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_grama dbname="produto_geral.qt_peso_grama" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="vw_saldo_atual_produto.qt_saldo_final" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" )
 column=(type=char(1) updatewhereclause=yes name=id_liberado_ecommerce dbname="produto_geral.id_liberado_ecommerce" )
 retrieve="   SELECT p.cd_produto as cd_produto,   
         p.de_produto as de_produto,   
         p.cd_fornecedor_usual as cd_fornecedor_usual,   
         p.de_descricao_internet as de_descricao_internet,
		 p.de_principal_internet as de_principal_internet,   
         p.qt_largura_cm as qt_largura_cm,   
         p.qt_altura_cm as qt_altura_cm,   
         p.qt_profundidade_cm as qt_profundidade_cm,   
         p.qt_peso_grama as qt_peso_grama,   
		 s.qt_saldo_final as qt_saldo_final,
		 p.id_situacao as id_situacao,
		 p.id_liberado_ecommerce as id_liberado_ecommerce
    FROM produto_geral p,
		 vw_saldo_atual_produto s,
		 parametro r
   WHERE s.cd_produto				= p.cd_produto
	 and s.cd_filial				= r.cd_filial
	 and r.id_parametro				= '1'
     and p.cd_grupo_psico			is null
	 and p.de_produto				not like 'ZZ%'
	 " )
