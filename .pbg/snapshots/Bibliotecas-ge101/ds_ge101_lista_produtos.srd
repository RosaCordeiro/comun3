table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_reposicao dbname="produto_uf.vl_preco_reposicao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_fornecedor dbname="produto_central.pc_desconto_fornecedor" )
 column=(type=long updatewhereclause=yes name=nr_embalagem_padrao dbname="produto_geral.nr_embalagem_padrao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_ipi dbname="produto_geral.pc_ipi" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_gerencial dbname="produto_central.vl_custo_gerencial" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="produto_geral.cd_fornecedor_usual" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" )
 column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="vw_classificacao_produto.cd_grupo" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="tipo_icms.pc_icms" )
 column=(type=char(1) updatewhereclause=yes name=id_icms_normal dbname="tributacao_icms.id_icms_normal" )
 column=(type=char(1) updatewhereclause=yes name=cd_tributacao_icms dbname="produto_uf.cd_tributacao_icms" )
 column=(type=long updatewhereclause=yes name=cd_tributacao_produto dbname="produto_uf.cd_tributacao_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_caderno_abcfarma dbname="produto_geral.id_caderno_abcfarma" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="produto_geral.id_lei_generico" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_pis_cofins dbname="produto_geral.id_situacao_pis_cofins" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_maximo dbname="vl_preco_venda_maximo" )
 column=(type=char(9) updatewhereclause=yes name=cd_subcategoria dbname="produto_geral.cd_subcategoria" )
 column=(type=char(1) updatewhereclause=yes name=id_resgate_clube dbname="id_resgate_clube" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_largura_cm_caixa_estoque dbname="qt_largura_cm_caixa_estoque" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_altura_cm_caixa_estoque dbname="qt_altura_cm_caixa_estoque" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_profund_cm_caixa_estoque dbname="qt_profund_cm_caixa_estoque" )
 column=(type=long updatewhereclause=yes name=cd_mix_produto dbname="produto_central.cd_mix_produto" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" )
 column=(type=long updatewhereclause=yes name=nr_classificacao_fiscal dbname="produto_geral.nr_classificacao_fiscal" )
 column=(type=char(1) updatewhereclause=yes name=id_revisao_fiscal dbname="id_revisao_fiscal" )
 column=(type=char(1) updatewhereclause=yes name=id_icms_st dbname="tributacao_icms.id_icms_st" )
 column=(type=char(1) updatewhereclause=yes name=id_farmacia_popular dbname="produto_geral.id_farmacia_popular" )
 column=(type=char(1) updatewhereclause=yes name=cd_curva_abc_filiais dbname="cd_curva_abc_filiais" )
 column=(type=char(1) updatewhereclause=yes name=cd_curva_abc_perini dbname="cd_curva_abc_perini" )
 retrieve="Select g.cd_produto,
		g.de_produto + ' : '  + g.de_apresentacao_estoque as de_produto,
	   	p.vl_preco_reposicao,
       	c.pc_desconto_fornecedor,
	   	g.nr_embalagem_padrao,
	   	g.pc_ipi,
	   	c.vl_custo_gerencial,
	   	g.id_situacao,
	   	g.vl_fator_conversao,
	   	g.cd_fornecedor_usual,
	   	f.nm_razao_social,
	   	g.cd_grupo_psico,
		v.cd_grupo,
		i.pc_icms,
		t.id_icms_normal,
		p.cd_tributacao_icms,
		p.cd_tributacao_produto,
		g.id_caderno_abcfarma,
		g.id_lei_generico,
		g.id_situacao_pis_cofins,
		coalesce(p.vl_preco_venda_maximo,0) as vl_preco_venda_maximo,
		g.cd_subcategoria,
		(CASE WHEN coalesce(g.qt_pontos_resgate, 0) > 0 THEN 'S' ELSE 'N' END) AS id_resgate_clube, 
		isnull(c.qt_largura_cm_caixa_estoque,0) as qt_largura_cm_caixa_estoque,
		isnull(c.qt_altura_cm_caixa_estoque, 0) as qt_altura_cm_caixa_estoque,
		isnull(c.qt_profund_cm_caixa_estoque, 0) as qt_profund_cm_caixa_estoque,
		c.cd_mix_produto,
		g.de_codigo_barras,
		g.nr_classificacao_fiscal,
		coalesce(c.id_revisao_fiscal, 'N') as id_revisao_fiscal,
		t.id_icms_st,
		g.id_farmacia_popular,
		coalesce(c.cd_curva_abc_filiais, 'E') As cd_curva_abc_filiais,
		coalesce(c.cd_curva_abc_perini, 'E') As cd_curva_abc_perini
From 	produto_geral g
inner join produto_central c on c.cd_produto = g.cd_produto
inner join fornecedor f on f.cd_fornecedor 		 	= g.cd_fornecedor_usual
inner join produto_uf p on p.cd_produto	  		 	= c.cd_produto
inner join vw_classificacao_produto v on v.cd_subcategoria			= g.cd_subcategoria
inner join tributacao_icms t on p.cd_tributacao_icms		= t.cd_tributacao_icms
inner join tipo_icms i on p.cd_tipo_icms				= i.cd_tipo_icms
inner join cidade ci on ci.cd_unidade_federacao = p.cd_unidade_federacao
inner join filial fi on fi.cd_cidade = ci.cd_cidade
Where fi.cd_filial = :filial" arguments=(("filial", number)) )
