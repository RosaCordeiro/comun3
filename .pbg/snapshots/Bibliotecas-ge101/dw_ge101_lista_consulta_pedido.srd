table(column=(type=char(10) updatewhereclause=yes name=nr_pedido_sap dbname="nr_pedido_sap" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="nr_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_pedido dbname="dh_pedido" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="nm_razao_social" )
 column=(type=long updatewhereclause=yes name=qt_estoque_momento dbname="qt_estoque_momento" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="qt_recebida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=long updatewhereclause=yes name=cd_condicao_pagamento dbname="cd_condicao_pagamento" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=char(9) updatewhereclause=yes name=de_situacao dbname="de_situacao" )
 retrieve="Select a.nr_pedido_sap,	
		a.nr_pedido,
		a.dh_emissao as dh_pedido,
		a.cd_fornecedor,
		f.nm_razao_social,
		b.qt_estoque_momento,
		b.qt_pedida,
		b.qt_recebida - coalesce(b.qt_devolvida, 0) qt_recebida,
		b.vl_preco_unitario,
		b.pc_desconto,
		a.cd_condicao_pagamento,
		a.id_situacao,
		Case a.id_situacao
			When 'X' then 'CANCELADO'
			When 'C' then 'COLOCADO'
			When 'A' then 'ATENDIDO'
			When 'P' then 'PENDENTE'
			When 'R' then 'RASCUNHO'
		End As de_situacao
From pedido_central As a
	Inner Join pedido_central_produto As b
		On b.nr_pedido = a.nr_pedido
	Inner Join fornecedor As f
		On f.cd_fornecedor = a.cd_fornecedor
Where a.dh_emissao Between :inicio And :termino
	And a.cd_filial = :filial
	And b.cd_produto = :produto

Union

Select a.nr_pedido_sap,	
		a.nr_pedido,
		a.dh_emissao as dh_pedido,
		a.cd_fornecedor,
		f.nm_razao_social,
		b.qt_estoque_momento,
		b.qt_pedida,
		b.qt_recebida - coalesce(b.qt_devolvida, 0) qt_recebida,
		b.vl_preco_unitario,
		b.pc_desconto,
		a.cd_condicao_pagamento,
		a.id_situacao,
		Case a.id_situacao
			When 'X' then 'CANCELADO'
			When 'C' then 'COLOCADO'
			When 'A' then 'ATENDIDO'
			When 'P' then 'PENDENTE'
			When 'R' then 'RASCUNHO'
		End As de_situacao
From pedido_central As a
	Inner Join pedido_central_produto As b
		On b.nr_pedido = a.nr_pedido
	Inner Join fornecedor As f
		On f.cd_fornecedor = a.cd_fornecedor
Where a.dh_emissao > :termino
	And a.cd_filial = :filial
	And b.cd_produto = :produto
	And a.id_situacao = 'C'" arguments=(("produto", number),("inicio", date),("termino", date),("filial", number))  sort="dh_pedido D " )
