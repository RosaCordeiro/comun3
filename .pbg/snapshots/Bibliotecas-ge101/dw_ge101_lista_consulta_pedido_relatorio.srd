table(column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_central.nr_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_pedido dbname="pedido_central.dh_pedido" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="pedido_central.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=long updatewhereclause=yes name=qt_estoque_momento dbname="pedido_central_produto.qt_estoque_momento" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_central_produto.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="qt_recebida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="pedido_central_produto.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pedido_central_produto.pc_desconto" )
 column=(type=long updatewhereclause=yes name=cd_condicao_pagamento dbname="pedido_central.cd_condicao_pagamento" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="pedido_central.id_situacao" )
 column=(type=char(9) updatewhereclause=yes name=de_situacao dbname="de_situacao" )
 retrieve="Select	a.nr_pedido,
		a.dh_pedido,
		a.cd_fornecedor,
		f.nm_razao_social,
		b.qt_estoque_momento,
		b.qt_pedida,
		b.qt_recebida - coalesce(b.qt_devolvida, 0) qt_recebida,
		b.vl_preco_unitario,
		b.pc_desconto,
		a.cd_condicao_pagamento,
		a.id_situacao,
		Case a.id_situacao
			When 'X' then 'CANCELADO'
			When 'C' then 'COLOCADO'
			When 'A' then 'ATENDIDO'
			When 'P' then 'PENDENTE'
			When 'R' then 'RASCUNHO'
		End As de_situacao
From pedido_central As a
	Inner Join pedido_central_produto As b
		On b.nr_pedido = a.nr_pedido
	Inner Join fornecedor As f
		On f.cd_fornecedor = a.cd_fornecedor
Where a.dh_pedido Between :inicio And :termino
	And b.cd_produto = :produto" arguments=(("produto", number),("inicio", date),("termino", date))  sort="dh_pedido D " )
