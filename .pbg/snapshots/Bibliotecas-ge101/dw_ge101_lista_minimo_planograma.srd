table(column=(type=long updatewhereclause=yes name=cd_filial dbname="vw_promocao_estoque_minimo.cd_filial" dbalias="m.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=qt_minimo dbname="qt_minimo" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="qt_saldo_final" )
 retrieve="Select m.cd_filial,
		f.nm_fantasia,
		coalesce(sum(m.qt_estoque_minimo), 0) As qt_minimo,
		coalesce(s.qt_saldo_final, 0) As qt_saldo_final
From vw_promocao_estoque_minimo As m
	Left Outer Join vw_saldo_atual_produto As s
		On s.cd_filial = m.cd_filial
		And s.cd_produto = m.cd_produto
	Inner Join filial As f
		On f.cd_filial = m.cd_filial
Where m.id_tipo_promocao = 'P'
	And m.cd_produto = :produto
Group By m.cd_filial,
			f.nm_fantasia,
			s.qt_saldo_final" arguments=(("produto", number))  sort="qt_minimo D nm_fantasia A " )
