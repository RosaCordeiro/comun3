table(column=(type=datetime updatewhereclause=yes name=dh_resumo dbname="dh_resumo" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="" )
 retrieve="select todos.dh_resumo,
		sum(todos.qt_faturada)
from (

	select  Convert( date, '01/' + Right( Convert( Char (10), p.dh_movimentacao_caixa, 103) , 7 ), 103) as dh_resumo ,  
			 sum(pp.qt_faturada) as qt_faturada
	from	nf_almoxarifado p  
	inner join item_nf_almoxarifado pp 
			on pp.nr_nf = p.nr_nf
	where p.dh_movimentacao_caixa between :inicio and :termino
	and pp.cd_produto = :produto
	and p.dh_cancelamento	is null 
	group by Convert( date, '01/' + Right( Convert( Char (10), p.dh_movimentacao_caixa, 103) , 7 ), 103)
	
	union
	
	select Convert( date, '01/' + Right( Convert( Char (10), p.dh_movimentacao_caixa, 103) , 7 ), 103) as dh_resumo , 
		sum(pp.qt_transferida) as qt_faturada
	from	nf_transferencia p  
	inner join item_nf_transferencia pp 
			on pp.cd_filial_origem = p.cd_filial_origem
			and pp.nr_nf = p.nr_nf 
			and pp.de_especie = p.de_especie
			and pp.de_serie	= p.de_serie
	where p.dh_movimentacao_caixa between :inicio and :termino
		and pp.cd_produto = :produto
		and p.cd_filial_origem = 534
		and p.id_almoxarifado = 'S'
		 and p.dh_cancelamento	is null 
	
	group by Convert( date, '01/' + Right( Convert( Char (10), p.dh_movimentacao_caixa, 103) , 7 ), 103)
) as todos
	group by todos.dh_resumo
	order by todos.dh_resumo" arguments=(("produto", number),("inicio", date),("termino", date))  sort="dh_resumo D " )
