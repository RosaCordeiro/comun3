table(column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_compra.dh_movimentacao_caixa" dbalias="n.dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_compra.nr_nf" dbalias="n.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=nf_compra_de_especie dbname="nf_compra.de_especie" dbalias="n.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_compra.de_serie" dbalias="n.de_serie" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="item_nf_compra.qt_faturada" dbalias="i.qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_devolvida dbname="qt_devolvida" )
 retrieve="Select	n.dh_movimentacao_caixa,
		n.nr_nf,
		n.de_especie,
		n.de_serie,
		i.qt_faturada,
		coalesce(sum(c.qt_devolvida), 0) As qt_devolvida
From	nf_compra As n
	Inner Join item_nf_compra As i
		 On i.cd_filial			= n.cd_filial
		And i.cd_fornecedor	= n.cd_fornecedor
		And i.nr_nf				= n.nr_nf
		And i.de_especie		= n.de_especie
		And i.de_serie			= n.de_serie
	Left Outer Join nf_devolucao_compra As d
		On d.cd_filial = n.cd_filial
		And d.cd_fornecedor = n.cd_fornecedor
		And d.nr_nf_compra = n.nr_nf
		And d.de_especie_compra = n.de_especie
		And d.de_serie_compra = n.de_serie
	Left Outer Join nf_devolucao_compra_produto As c
		 On c.cd_filial			= d.cd_filial
		And c.nr_nf				= d.nr_nf
		And c.de_especie		= d.de_especie
		And c.de_serie			= d.de_serie
		And c.cd_produto		= i.cd_produto
Where n.nr_pedido_central = :nr_pedido
	And i.cd_produto = :cd_produto
	And d.dh_cancelamento Is Null
Group By n.dh_movimentacao_caixa,
			n.nr_nf,
			n.de_especie,
			n.de_serie,
			i.qt_faturada" arguments=(("nr_pedido", number),("cd_produto", number)) )
