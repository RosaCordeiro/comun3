table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_almoxarifado.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="vw_filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=qt_venda dbname="qt_venda" )
 retrieve="select p.cd_filial as cd_filial, 
		v.nm_fantasia as nm_fantasia,
		sum(pp.qt_faturada) as qt_venda
from	nf_almoxarifado p  
inner join item_nf_almoxarifado pp 
		on pp.nr_nf = p.nr_nf
inner join vw_filial v
		on  v.cd_filial = p.cd_filial
where p.dh_movimentacao_caixa between :inicio and :termino
and pp.cd_produto 						= :produto
and p.dh_cancelamento	is null 
and p.cd_filial 				is not null
group by p.cd_filial, 
		v.nm_fantasia" arguments=(("inicio", date),("termino", date),("produto", number))  sort="qt_venda D " )
