table(column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" )
 column=(type=char(40) updatewhereclause=yes name=de_endereco dbname="cliente.de_endereco" )
 column=(type=char(20) updatewhereclause=yes name=de_bairro dbname="cliente.de_bairro" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep dbname="cliente.nr_cep" )
 column=(type=long updatewhereclause=yes name=cd_cidade dbname="cliente.cd_cidade" )
 column=(type=char(255) updatewhereclause=yes name=localizacao_endereco dbname="localizacao_endereco" )
 retrieve="  SELECT d.nm_cidade,   
         d.cd_unidade_federacao,   
         de_endereco,   
         de_bairro,   
         nr_cep,   
	    c.cd_cidade,   
         space(60) as localizacao_endereco
    FROM cliente c
	INNER JOIN cidade d
		on d.cd_cidade = c.cd_cidade
WHERE c.cd_cliente = :cliente" arguments=(("cliente", string)) )
