table(column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=id_disque_entrega dbname="id_disque_entrega" )
 column=(type=decimal(2) updatewhereclause=yes name=distancia_km dbname="distancia_km" )
 column=(type=long updatewhereclause=yes name=cd_cidade dbname="filial.cd_cidade" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_filial dbname="filial.id_rede_filial" )
 retrieve="select f.cd_filial, 
		f.nm_fantasia, 
		COALESCE(p.vl_parametro, 'N') AS id_disque_entrega,
		0.00 as distancia_km,
		f.cd_cidade,
		f.id_rede_filial
from filial f
left outer join parametro_loja p
	 on p.cd_filial = f.cd_filial
	and p.cd_parametro = 'ID_DISQUE_ENTREGA'
where f.nr_latitude 	is not null
and f.nr_longitude 	is not null
and f.id_rede_filial 	is not null
and f.id_situacao 		= 'A'
and f.id_aberta 		= 'S'
and COALESCE(f.id_recebe_nf_transferencia,'S') = 'S'
order by 3" )
