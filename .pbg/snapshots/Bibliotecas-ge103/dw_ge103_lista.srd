table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(15) updatewhereclause=yes name=telefone dbname="telefone" )
 column=(type=char(73) updatewhereclause=yes name=de_endereco dbname="de_endereco" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=char(40) updatewhereclause=yes name=id_tipo_rede dbname="id_tipo_rede" )
 column=(type=char(47) updatewhereclause=yes name=de_filial dbname="de_filial" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_clube dbname="pc_desconto_clube" )
 column=(type=char(1) updatewhereclause=yes name=de_rede dbname="de_rede" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="qt_saldo_final" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_sos_farm_popular dbname="Pc_Desconto_SOS_Farm_Popular" )
 column=(type=char(1) updatewhereclause=yes name=de_msg_promocao dbname="de_msg_promocao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_pago_fpb dbname="Vl_Preco_Pago_FPB" )
 column=(type=char(1) updatewhereclause=yes name=id_tem_progressiva dbname="id_tem_progressiva" )
 retrieve="SELECT f.cd_filial,   
         '(' + coalesce((select max(t1.nr_ddd) from telefone_drogaria t1 where t1.cd_centro_custo = f.cd_filial and t1.id_situacao = '4' and t1.id_tipo = 'N'), '') + ') ' + 
	           coalesce((select max(t1.nr_telefone) from telefone_drogaria t1 where t1.cd_centro_custo = f.cd_filial and t1.id_situacao = '4' and t1.id_tipo = 'N'), '') as telefone,   
         (f.de_endereco) + ', nr. ' + cast(f.nr_endereco as varchar(6)) + '-' + (f.de_bairro) as de_endereco,   
			000.00 vl_preco_unitario,
			000.00 pc_desconto,
		(select p.vl_parametro from parametro_loja p
		where p.cd_filial 			= f.cd_filial
		and p.cd_parametro 	= 'ID_REDE_FILIAL') as id_tipo_rede,
         (f.nm_fantasia + ' (' + Cast(f.cd_filial as varchar(4) ) + ')' ) as de_filial,   
			000.00 pc_desconto_clube,
			'' as de_rede,
			v.qt_saldo_final - dbo.uf_saldo_produto_pendente( v.cd_filial, v.cd_produto) as qt_saldo_final,
			000.00 as Pc_Desconto_SOS_Farm_Popular,
			'' as de_msg_promocao,
			coalesce(vl_reembolso_fpb,0.00) as Vl_Preco_Pago_FPB, 
			'' as id_tem_progressiva
FROM 	filial f
Inner join vw_saldo_atual_produto v
	on v.cd_filial = f.cd_filial
Inner join produto_geral pg
  on pg.cd_produto = v.cd_produto
WHERE v.cd_produto = :produto
  and f.cd_filial not in (534)
  and f.id_situacao = 'A'

union 

SELECT f.cd_filial,   
         '( ) ' as telefone,   
         (f.de_endereco) + ', nr. ' + cast(f.nr_endereco as varchar(6)) + '-' + (f.de_bairro) as de_endereco,   
			000.00 vl_preco_unitario,
			000.00 pc_desconto,
         (select p.vl_parametro from parametro_loja p
		where p.cd_filial 			= f.cd_filial
		and p.cd_parametro 	= 'ID_REDE_FILIAL') as id_tipo_rede,
         (f.nm_fantasia + ' (' + Cast(f.cd_filial as varchar(4) ) + ')' ) as de_filial,   
			000.00 pc_desconto_clube,
			''  as de_rede,
			v.qt_saldo_final - dbo.uf_saldo_produto_pendente( v.cd_filial, v.cd_produto) as qt_saldo_final,
			000.00 as Pc_Desconto_SOS_Farm_Popular,
			'' as de_msg_promocao,
		  coalesce(vl_reembolso_fpb,0.00) as Vl_Preco_Pago_FPB, 
		'' as id_tem_progressiva
FROM 	filial f
Inner join vw_saldo_atual_produto v
	on v.cd_filial = f.cd_filial
Inner join produto_geral pg
  on pg.cd_produto = v.cd_produto
WHERE v.cd_produto = :produto
  and f.cd_filial not in (534)
  and not exists (select * from telefone_drogaria x
					 where x.cd_centro_custo = f.cd_filial
						and x.id_situacao = '4'
						and x.id_tipo = 'N')
  and f.id_situacao = 'A'" arguments=(("produto", number))  sort="de_rede A de_filial A " )
