 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_clube dbname="vl_preco_clube" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"filial~" )  TABLE(NAME=~"parametro_loja~" ) COLUMN(NAME=~"filial.cd_filial~") COLUMN(NAME=~"filial.nr_ddd_telefone~") COLUMN(NAME=~"filial.nr_telefone~") COMPUTE(NAME=~"'(' + filial.nr_ddd_telefone + ') ' + (filial.nr_telefone) telefone~") COMPUTE(NAME=~"(filial.de_endereco) + ' ' + (filial.de_bairro) de_endereco~") COMPUTE(NAME=~"000.00 vl_preco~") COLUMN(NAME=~"parametro_loja.vl_parametro~") COMPUTE(NAME=~"(filial.nm_fantasia) de_filial~") COMPUTE(NAME=~"000.00 vl_preco_clube~")    JOIN (LEFT=~"parametro_loja.cd_filial~"    OP =~"=~"RIGHT=~"filial.cd_filial~" )WHERE(    EXP1 =~"filial.cd_cidade~"   OP =~"=~"    EXP2 =~":pl_cidade~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"filial.id_situacao~"   OP =~"=~"    EXP2 =~"'A'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"parametro_loja.cd_parametro~"   OP =~"=~"    EXP2 =~"'ID_REDE_FILIAL'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"filial.cd_filial~"   OP =~"<>~"    EXP2 =~"534~" ) ) ARG(NAME = ~"pl_cidade~" TYPE = number) " arguments=(("pl_cidade", number))  sort="de_filial A " )
