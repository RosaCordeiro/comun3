table(column=(type=char(40) updatewhereclause=yes name=nm_promocao_sos dbname="promocao_sos.nm_promocao_sos" dbalias="a.nm_promocao_sos" )
 column=(type=long updatewhereclause=yes name=qtd_minima_normal dbname="qtd_minima_normal" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_normal dbname="pc_desconto_normal" )
 retrieve="select a.nm_promocao_sos, 
                        isnull(d.qt_minima,0) as qtd_minima_normal,  
                        isnull(d.pc_desconto,0) as pc_desconto_normal                        
From  promocao_sos a
inner join promocao_sos_produto b  on a.cd_promocao_sos = b.cd_promocao_sos
inner join promocao_sos_filial c on a.cd_promocao_sos = c.cd_promocao_sos
inner join desconto_progressivo_qtd d on d.cd_desconto = b.cd_desc_progressivo 
where b.cd_produto  = :produto
and c.cd_filial =:filial
and a.id_situacao = 'L'
and a.id_tipo_promocao = 'Q'
and a.dh_inicio <= (select dh_movimentacao from parametro where id_parametro = '1')
and (a.dh_termino >= (select dh_movimentacao from parametro where id_parametro = '1') or a.dh_termino is null)" arguments=(("produto", number),("filial", number)) )
