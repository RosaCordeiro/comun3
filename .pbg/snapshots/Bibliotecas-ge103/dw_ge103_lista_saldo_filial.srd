table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(255) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_saldo_atual dbname="qt_saldo_atual" )
 column=(type=decimal(0) updatewhereclause=yes name=qt_reserva dbname="qt_reserva" )
 column=(type=decimal(0) updatewhereclause=yes name=qt_saldo_final dbname="qt_saldo_final" )
 retrieve="SELECT pg.cd_produto as cd_produto,
			pg.de_produto + ':' + pg.de_apresentacao_venda as de_produto,
			coalesce(v.qt_saldo_final,0) as qt_saldo_atual,
			coalesce((select SUM( qt_saldo ) FROM vw_saldo_produto_pendente WHERE cd_produto = v.cd_produto),0) as qt_reserva,
			coalesce(v.qt_saldo_final,0) - coalesce((select SUM( qt_saldo ) FROM vw_saldo_produto_pendente WHERE cd_produto = v.cd_produto),0) as qt_saldo_final
FROM  vw_saldo_atual_produto v
Inner join produto_geral pg
  on pg.cd_produto = v.cd_produto
WHERE v.cd_produto = :produto
" arguments=(("produto", number)) )
