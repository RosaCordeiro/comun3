table(column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="item_nf_venda.pc_icms" dbalias="i.pc_icms" )
 column=(type=char(2) updatewhereclause=yes name=cd_situacao_tributaria dbname="item_nf_venda.cd_situacao_tributaria" dbalias="i.cd_situacao_tributaria" )
 column=(type=decimal(28) updatewhereclause=yes name=vl_base_icms dbname="vl_base_icms" )
 retrieve="  SELECT i.pc_icms,
         i.cd_situacao_tributaria,  
         sum(round(i.qt_vendida*(i.vl_preco_praticado - (i.vl_preco_praticado * (n.pc_desconto/100))) * (1 - coalesce(i.pc_reducao_base_icms,0) / 100),2)) as vl_base_icms 
    FROM nf_venda n,   
         item_nf_venda i  
   WHERE ( i.cd_filial = n.cd_filial ) and  
         ( i.nr_nf = n.nr_nf ) and  
         ( i.de_especie = n.de_especie ) and  
         ( i.de_serie = n.de_serie ) and  
         ( ( n.cd_filial = :filial ) AND  
         ( n.dh_movimentacao_caixa = :dt_movimentacao ) AND
         ( n.dh_cancelamento is null ) AND  
         ( n.nr_nf_anexa is null ) AND  
         ( n.de_especie = 'CF' ) AND  
         ( n.nr_ecf = :ecf ) )   
GROUP BY i.pc_icms,
         i.cd_situacao_tributaria
  
" arguments=(("filial", number),("ecf", number),("dt_movimentacao", date))  sort="pc_icms D " )
