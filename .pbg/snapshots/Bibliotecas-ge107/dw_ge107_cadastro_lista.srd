table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial_destino dbname="filial.cd_filial_destino" dbalias="f.cd_filial_destino" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" dbalias="c.nm_cidade" )
 column=(type=long updatewhereclause=yes name=nr_ordem dbname="nr_ordem" initial="9999" )
 column=(type=long updatewhereclause=yes name=nr_ordem_original dbname="nr_ordem_original" )
 retrieve="SELECT	f.cd_filial 		AS cd_filial_destino,
			f.nm_fantasia	AS nm_fantasia,
			c.nm_cidade	AS nm_cidade,
			COALESCE( o.nr_ordem, 9999 )	AS nr_ordem,
			COALESCE( o.nr_ordem, 9999 )	AS nr_ordem_original
FROM filial f
		INNER JOIN cidade c
			ON c.cd_cidade = f.cd_cidade
		LEFT OUTER JOIN estoque_outras_filiais_ordenacao o
			ON o.cd_filial_destino = f.cd_filial
WHERE ( c.cd_unidade_federacao = :cd_uf Or f.cd_filial = 534 )
AND f.id_situacao = 'A'
AND EXISTS (SELECT * FROM parametro_odbc x WHERE x.cd_filial = f.cd_filial  Or f.cd_filial = 534 )" update="estoque_outras_filiais_ordenacao" updatewhere=0 updatekeyinplace=no arguments=(("cd_uf", string))  sort="nr_ordem A nm_cidade A nm_fantasia A " )
