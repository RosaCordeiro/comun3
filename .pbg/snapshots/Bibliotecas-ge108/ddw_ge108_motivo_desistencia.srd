table(column=(type=char(2) updatewhereclause=yes name=id_motivo dbname="id_motivo" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo dbname="de_motivo" )
 retrieve="select x.id_motivo, x.de_motivo
from (
	select       Cast('CP' as varchar(2)) as id_motivo, Cast('APENAS CONSULTA POR PARTE DO CLIENTE'             as varchar(40))  as de_motivo
	union select Cast('AT' as varchar(2)) as id_motivo, Cast('ATENDIMENTO TELEF$$HEX1$$d400$$ENDHEX$$NICO DE CLIENTE'             as varchar(40))  as de_motivo
	union select Cast('PC' as varchar(2)) as id_motivo, Cast('CONSULTA PONTOS CLIENTE'             							 as varchar(40))  as de_motivo
	union select Cast('ES' as varchar(2)) as id_motivo, Cast('SEM ESTOQUE SUFICIENTE'			 as varchar(40))  as de_motivo
	union select Cast('OT' as varchar(2)) as id_motivo, Cast('OUTROS' 	     				 as varchar(40))  as de_motivo
	union select Cast('RE' as varchar(2)) as id_motivo, Cast('RESERVA DE PRODUTO' 	      as varchar(40))  as de_motivo

union select Cast('DC' as varchar(2)) as id_motivo, Cast('CLIENTE DESISTIU DA COMPRA' as varchar(40))  as de_motivo
union select Cast('CB' as varchar(2)) as id_motivo, Cast('CONCORRENTE MAIS BARATO' as varchar(40))  as de_motivo
union select Cast('IP' as varchar(2)) as id_motivo, Cast('CONSULTA INTERNA DE PRE$$HEX1$$c700$$ENDHEX$$O' as varchar(40))  as de_motivo
union select Cast('EP' as varchar(2)) as id_motivo, Cast('ERRO DE PROCEDIMENTO' as varchar(40))  as de_motivo
union select Cast('FR' as varchar(2)) as id_motivo, Cast('FALTA DE UM ITEM NA RECEITA' as varchar(40))  as de_motivo
union select Cast('OJ' as varchar(2)) as id_motivo, Cast('OR$$HEX1$$c700$$ENDHEX$$AMENTO JUDICIAL' as varchar(40))  as de_motivo

) as x
order by (Case When x.id_motivo = 'CP' Then 0 
				   When x.id_motivo = 'AT' Then 1
				   When x.id_motivo = 'DC' Then 2
				   When x.id_motivo = 'CB' Then 3
				   When x.id_motivo = 'IP' Then 4	
				   When x.id_motivo = 'PC' Then 5
				   When x.id_motivo = 'EP' Then 6 
				   When x.id_motivo = 'FR' Then 7
				   When x.id_motivo = 'OJ' Then 8	
				   When x.id_motivo = 'RE' Then 9
				   When x.id_motivo = 'ES' Then 10					
				  When x.id_motivo = 'OT' Then 11
				Else 12
				End)" )
