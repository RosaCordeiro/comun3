table(column=(type=long updatewhereclause=yes name=nr_campanha dbname="nr_campanha" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="cd_cliente" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=desc_produto dbname="desc_produto" )
 column=(type=char(40) updatewhereclause=yes name=cd_mensagem dbname="cd_mensagem" )
 column=(type=char(255) updatewhereclause=yes name=de_titulo dbname="de_titulo" )
 column=(type=char(255) updatewhereclause=yes name=de_texto dbname="de_texto" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_campanha dbname="id_tipo_campanha" )
 column=(type=char(1) updatewhereclause=yes name=nr_mensagem dbname="nr_mensagem" )
 column=(type=char(30) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=char(1) updatewhereclause=yes name=id_aviso_realizado dbname="id_aviso_realizado" )
 retrieve="Select	 DISTINCT ca.nr_campanha												as 'nr_campanha',
		cc.cd_cliente 																as 'cd_cliente',
		COALESCE(cp.cd_produto, 0)											as 'cd_produto',
		pg.de_produto || ' : ' || pg.de_apresentacao_venda				as 'desc_produto',
		ca.cd_mensagem															as 'cd_mensagem',
		m.de_titulo																	as 'de_titulo',
		m.de_texto																	as 'de_texto',
		ca.id_tipo_campanha														as 'id_tipo_campanha',
		( case when cp.cd_produto is null then '2' Else '1' End  ) 		as 'nr_mensagem',
		COALESCE(CAST(cp.pc_desconto AS varchar), '0.00')			as 'pc_desconto',
		( case when cc.dh_aviso is null Then 'N' Else 'S' End) 			as 'id_aviso_realizado'
From	campanha as ca
		inner join campanha_filial as cf
		   on cf.nr_campanha = ca.nr_campanha
		left outer join campanha_produto as cp
		   on cp.nr_campanha = ca.nr_campanha
		inner join campanha_cliente as cc
		   on cc.nr_campanha = ca.nr_campanha
		left outer join produto_geral as pg
		   on pg.cd_produto = cp.cd_produto
		left outer join mensagem as m
			on m.cd_mensagem = ca.cd_mensagem
Where ca.dh_inicio <= getdate()
  And ca.dh_termino > getdate()
  And (ca.id_avisa_cliente = 'S' or id_tipo_campanha in ('CP'))
Order by cp.cd_produto, cp.pc_desconto desc" )
