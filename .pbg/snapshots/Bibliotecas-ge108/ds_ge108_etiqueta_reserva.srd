table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="g.cd_produto" )
 column=(type=char(8190) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_produto dbname="cliente_caixa_produto.qt_produto" dbalias="p.qt_produto" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="nm_cliente" )
 column=(type=char(15) updatewhereclause=yes name=nr_fone_recado_reserva dbname="cliente_caixa.nr_fone_recado_reserva" dbalias="c.nr_fone_recado_reserva" )
 column=(type=char(8190) updatewhereclause=no name=vendedor dbname="vendedor" )
 column=(type=date updatewhereclause=yes name=dh_inicio_reserva dbname="cliente_caixa.dh_inicio_reserva" dbalias="c.dh_inicio_reserva" )
 column=(type=date updatewhereclause=yes name=dh_termino_reserva dbname="cliente_caixa.dh_termino_reserva" dbalias="c.dh_termino_reserva" )
 column=(type=char(255) updatewhereclause=yes name=id_avisou_cliente_reserva dbname="id_avisou_cliente_reserva" )
 column=(type=char(4) updatewhereclause=yes name=filial_transferencia dbname="filial_transferencia" )
 column=(type=char(8190) updatewhereclause=no name=usuario_transferencia dbname="usuario_transferencia" )
 column=(type=char(14) updatewhereclause=yes name=nr_cpf_cgc dbname="cliente.nr_cpf_cgc" dbalias="cli.nr_cpf_cgc" )
 column=(type=long updatewhereclause=yes name=nr_reserva dbname="cliente_caixa.nr_reserva" dbalias="c.nr_reserva" )
 column=(type=date updatewhereclause=yes name=dh_movimentacao dbname="cliente_caixa.dh_movimentacao" dbalias="c.dh_movimentacao" )
 retrieve="select  g.cd_produto,
	g.de_produto || ' : ' || g.de_apresentacao_venda as de_produto,
	p.qt_produto,
	COALESCE( c.nm_recado_reserva, c.nm_cliente, c.nm_recado_reserva ) AS nm_cliente,
	c.nr_fone_recado_reserva,
	c.nr_matricula_vendedor || '-' || SPLIT_PART(u.nm_usuario, ' ', 1) AS vendedor,
	c.dh_inicio_reserva,
	c.dh_termino_reserva,
	Coalesce(id_avisou_cliente_reserva, 'N') as id_avisou_cliente_reserva,
	Cast(p.cd_filial_transferencia as varchar(4)) as filial_transferencia, 	
	p.nr_matricula_transferencia || '-' || SPLIT_PART(x.nm_usuario, ' ', 1) AS usuario_transferencia,
	cli.nr_cpf_cgc,
	c.nr_sequencial AS nr_reserva,
	c.dh_movimentacao AS dh_movimentacao
from cliente_caixa c
inner join cliente_caixa_produto p
	on p.nr_sequencial_cliente_caixa = c.nr_sequencial
inner join produto_geral g
	on g.cd_produto = p.cd_produto
inner join usuario u
	on u.nr_matricula = c.nr_matricula_vendedor
inner join cliente cli
	on cli.cd_cliente = c.cd_cliente
left outer join usuario x
	on x.nr_matricula = p.nr_matricula_transferencia
left outer join filial f
	on f.cd_filial = p.cd_filial_transferencia
where c.nr_sequencial = :sequencial
and c.id_tipo = 'R'
and p.id_situacao IN ('T', 'C', 'R')" arguments=(("sequencial", number)) )
