table(column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="promocao_sos_vinculo.cd_promocao_sos" dbalias="v.cd_promocao_sos" )
 column=(type=long updatewhereclause=yes name=nr_vinculo dbname="promocao_sos_vinculo.nr_vinculo" dbalias="v.nr_vinculo" )
 column=(type=char(30) updatewhereclause=yes name=de_vinculo dbname="promocao_sos_vinculo.de_vinculo" dbalias="v.de_vinculo" )
 column=(type=long updatewhereclause=yes name=qt_vinculo dbname="promocao_sos_vinculo.qt_vinculo" dbalias="v.qt_vinculo" )
 column=(type=long updatewhereclause=yes name=cd_produto_vinculo dbname="promocao_sos_vinculo_prd.cd_produto_vinculo" dbalias="vp.cd_produto_vinculo" )
 column=(type=long updatewhereclause=yes name=cd_produto_venda dbname="promocao_sos_produto.cd_produto_venda" dbalias="pp.cd_produto_venda" )
 column=(type=decimal(6) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=decimal(6) updatewhereclause=yes name=pc_desconto_clube dbname="pc_desconto_clube" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_replicacao dbname="promocao_sos.id_tipo_replicacao" dbalias="p.id_tipo_replicacao" )
 column=(type=char(255) updatewhereclause=yes name=id_utilizar dbname="id_utilizar" )
 column=(type=long updatewhereclause=yes name=qt_atendida_vinculo dbname="qt_atendida_vinculo" )
 retrieve="select v.cd_promocao_sos,
    v.nr_vinculo,
    v.de_vinculo,
    v.qt_vinculo,
    vp.cd_produto as cd_produto_vinculo,
    pp.cd_produto as cd_produto_venda,
    coalesce( pp.pc_desconto, 0 ) as pc_desconto,
    coalesce( pp.pc_desconto_clube, 0 ) as pc_desconto_clube,
    p.id_tipo_replicacao,
    'N' id_utilizar,
    0 qt_atendida_vinculo
from promocao_sos_produto pp
inner join promocao_sos p
    on p.cd_promocao_sos = pp.cd_promocao_sos
inner join promocao_sos_vinculo v
    on v.cd_promocao_sos = p.cd_promocao_sos
inner Join promocao_sos_vinculo_prd vp
    on vp.cd_promocao_sos = v.cd_promocao_sos
    and vp.nr_vinculo = v.nr_vinculo
    --and vp.cd_produto = pp.cd_produto
where pp.cd_produto = :cd_produto
  and p.id_tipo_promocao = 'C'
  and p.id_situacao = 'L'
  and p.dh_inicio 			<= dbo.uf_dh_parametro() 
  and (p.dh_termino >= dbo.uf_dh_parametro() or p.dh_termino is null)
  and ( p.id_tipo_replicacao is not null )" arguments=(("cd_produto", number))  sort="cd_promocao_sos A nr_vinculo A " )
