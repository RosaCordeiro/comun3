table(column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="promocao_sos.cd_promocao_sos" )
 column=(type=char(40) updatewhereclause=yes name=nm_promocao_sos dbname="promocao_sos.nm_promocao_sos" )
 column=(type=char(200) updatewhereclause=yes name=de_promocao dbname="promocao_sos.de_promocao" )
 column=(type=char(100) updatewhereclause=yes name=de_desconto dbname="desconto_progressivo.de_desconto" )
 column=(type=long updatewhereclause=yes name=qt_minima dbname="desconto_progressivo_qtd.qt_minima" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="desconto_progressivo_qtd.pc_desconto" )
 column=(type=char(8190) updatewhereclause=no name=tipo dbname="tipo" )
 column=(type=long updatewhereclause=yes name=cd_desc_progressivo dbname="promocao_sos_produto.cd_desc_progressivo" )
 retrieve="select p.cd_promocao_sos, p.nm_promocao_sos, p.de_promocao, dp.de_desconto, dq.qt_minima, dq.pc_desconto, 'NORMAL' AS tipo, pp.cd_desc_progressivo
   from promocao_sos_produto pp												
	join  parametro pr on pr.id_parametro = '1'											
	join promocao_sos p on	p.cd_promocao_sos = pp.cd_promocao_sos										
		and p.id_tipo_promocao = 'Q' 										
		and p.id_situacao = 'L'										
		and p.dh_inicio 			<= pr.dh_movimentacao and 							
			 (p.dh_termino >= pr.dh_movimentacao or p.dh_termino is null)
	join desconto_progressivo dp on dp.cd_desconto = pp.cd_desc_progressivo
	join desconto_progressivo_qtd dq on dq.cd_desconto = dp.cd_desconto
		and dq.pc_desconto > :pc_desc
where pp.cd_produto = :cd_produto
Union
select p.cd_promocao_sos, p.nm_promocao_sos, p.de_promocao, dp.de_desconto, dq.qt_minima, dq.pc_desconto, 'CLUBE' AS tipo, pp.cd_desc_progressivo_clube
   from promocao_sos_produto pp												
	join  parametro pr on pr.id_parametro = '1'											
	join promocao_sos p on	p.cd_promocao_sos = pp.cd_promocao_sos										
		and p.id_tipo_promocao = 'Q' 										
		and p.id_situacao = 'L'										
		and p.dh_inicio 			<= pr.dh_movimentacao and 							
			 (p.dh_termino >= pr.dh_movimentacao or p.dh_termino is null)
	join desconto_progressivo dp on dp.cd_desconto = pp.cd_desc_progressivo_clube
	join desconto_progressivo_qtd dq on dq.cd_desconto = dp.cd_desconto
		and dq.pc_desconto > :pc_desc
where pp.cd_produto = :cd_produto
order by 5;" arguments=(("cd_produto", number),("pc_desc", decimal)) )
