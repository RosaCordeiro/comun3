 column=(type=char(255) updatewhereclause=yes name=nm_fantasia dbname="vw_saldo_produto_pendente.nm_fantasia" dbalias="v.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="vw_saldo_produto_pendente.nr_nf" dbalias="v.nr_nf" )
