 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="g.de_apresentacao_venda" )
 column=(type=long updatewhereclause=yes name=qt_saldo dbname="vw_saldo_produto_pendente.qt_saldo" dbalias="v.qt_saldo" )
 column=(type=char(8190) updatewhereclause=no name=de_tipo_movimento dbname="vw_saldo_produto_pendente.de_tipo_movimento" dbalias="v.de_tipo_movimento" )
 retrieve="Select v.cd_fornecedor,
		 v.nm_fantasia,
		 v.nr_nf,
		 v.de_especie,
		 v.de_serie,
		 v.dh_emissao,
		 v.nr_pedido_distribuidora,
		 g.de_produto,
		 g.de_apresentacao_venda,
		 v.qt_saldo,
		 v.tipo_movimento AS de_tipo_movimento
  From vw_saldo_produto_pendente v
		INNER JOIN produto_geral g
			ON g.cd_produto = v.cd_produto" )
