table(column=(type=long updatewhereclause=yes name=cd_produto dbname="cliente_caixa_produto.cd_produto" dbalias="p.cd_produto" )
 column=(type=long updatewhereclause=yes name=nr_sequencial_cliente_caixa dbname="cliente_caixa_produto.nr_sequencial_cliente_caixa" dbalias="p.nr_sequencial_cliente_caixa" )
 column=(type=char(8190) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_produto dbname="cliente_caixa_produto.qt_produto" dbalias="p.qt_produto" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_operador dbname="roteiro_entrega.nr_matricula_operador" dbalias="r.nr_matricula_operador" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="cliente_caixa.cd_cliente" dbalias="c.cd_cliente" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="cliente_caixa.nm_cliente" dbalias="c.nm_cliente" )
 column=(type=long updatewhereclause=yes name=nr_ficha dbname="cliente_caixa.nr_ficha" dbalias="c.nr_ficha" )
 column=(type=char(8190) updatewhereclause=yes name=nr_cpf_cgc dbname="nr_cpf_cgc" )
 column=(type=char(15) updatewhereclause=yes name=nr_telefone dbname="roteiro_entrega.nr_telefone" dbalias="r.nr_telefone" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="u.nm_usuario" )
 column=(type=char(2) updatewhereclause=yes name=cd_forma_pagamento dbname="roteiro_entrega.cd_forma_pagamento" dbalias="r.cd_forma_pagamento" )
 column=(type=char(2) updatewhereclause=yes name=de_pagamento dbname="roteiro_entrega.de_pagamento" dbalias="r.de_pagamento" )
 column=(type=char(200) updatewhereclause=yes name=de_complemento dbname="roteiro_entrega.de_complemento" dbalias="r.de_complemento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_troco dbname="roteiro_entrega.vl_troco" dbalias="r.vl_troco" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_receita dbname="roteiro_entrega.id_tipo_receita" dbalias="r.id_tipo_receita" values="SEM RECEITA	S/COLETAR RECEITA	C/RECEITA DIGITAL	D/" )
 column=(type=char(60) updatewhereclause=yes name=de_pbm dbname="roteiro_entrega.de_pbm" dbalias="r.de_pbm" )
 column=(type=char(20) updatewhereclause=yes name=nr_autorizacao dbname="roteiro_entrega.nr_autorizacao" dbalias="r.nr_autorizacao" )
 column=(type=long updatewhereclause=yes name=nr_parcelas_cartao dbname="roteiro_entrega.nr_parcelas_cartao" dbalias="r.nr_parcelas_cartao" )
 column=(type=date updatewhereclause=yes name=roteiro_saida_dh_saida dbname="roteiro_saida.dh_saida" dbalias="s.dh_saida" )
 column=(type=char(40) updatewhereclause=yes name=roteiro_parametro_de_parametro dbname="roteiro_parametro.de_parametro" dbalias="rp.de_parametro" )
 retrieve="  SELECT p.cd_produto,   
        p.nr_sequencial_cliente_caixa,
	g.de_produto || ' : ' || g.de_apresentacao_venda as de_produto,
        p.qt_produto,   
	r.nr_matricula_operador, 
	c.cd_cliente,
	c.nm_cliente,
	c.nr_ficha,
	  (Case When CHAR_LENGTH(e.nr_cpf_cgc) = '11' Then LEFT(e.nr_cpf_cgc, 3) || '******' || RIGHT(e.nr_cpf_cgc, 2) Else LEFT(e.nr_cpf_cgc, 3) || '******' || RIGHT(e.nr_cpf_cgc, 6) End) as nr_cpf_cgc,
	r.nr_telefone,
	u.nm_usuario,
	r.cd_forma_pagamento,
	r.cd_forma_pagamento as de_pagamento,
	r.de_complemento,
	r.vl_troco,
	r.id_tipo_receita,
	r.de_pbm,
	r.nr_autorizacao,	
	r.nr_parcelas_cartao,
	s.dh_saida,
	rp.de_parametro
 	FROM cliente_caixa_produto p
		INNER JOIN produto_geral g
				  ON g.cd_produto = p.cd_produto	
		INNER JOIN cliente_caixa c
				ON c.nr_sequencial = p.nr_sequencial_cliente_caixa
		INNER JOIN roteiro_entrega r
				ON r.nr_sequencial_cliente_caixa = c.nr_sequencial
		INNER JOIN cliente e
				ON e.cd_cliente = c.cd_cliente
		INNER JOIN usuario u
				ON u.nr_matricula = r.nr_matricula_operador
		LEFT OUTER JOIN roteiro_saida s
				ON s.nr_roteiro = r.nr_roteiro
		LEFT OUTER JOIN roteiro_parametro rp
				ON rp.id_parametro = s.id_parametro
WHERE r.nr_sequencial_cliente_caixa = :sequencial
AND (p.id_situacao in( 'A', 'C' ) Or c.id_disque_entrega = 'S' )
ORDER BY (CASE WHEN g.de_produto = 'FRETE' THEN 9 ELSE 1 END)" arguments=(("sequencial", number)) )
