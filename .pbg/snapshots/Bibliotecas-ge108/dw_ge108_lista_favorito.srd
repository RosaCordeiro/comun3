table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_favorito_cliente.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=char(1) updatewhereclause=yes name=id_excluir dbname="id_excluir" values="	S/	N" )
 retrieve="select   c.cd_produto,
			g.de_produto,
			g.de_apresentacao_venda,
			'N' as id_excluir
from produto_favorito_cliente c
	inner join produto_geral g
		on g.cd_produto = c.cd_produto
Where c.id_situacao = 'A'
" )
