table(column=(type=long updatewhereclause=yes name=cd_filial dbname="negociacao_cliente.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="negociacao_cliente.nr_sequencial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="negociacao_cliente.cd_produto" )
 column=(type=char(8190) updatewhereclause=no name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="negociacao_cliente.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_liquido dbname="vl_preco_liquido" initial="0.00" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_tabela dbname="vl_preco_tabela" )
 column=(type=long updatewhereclause=yes name=qt_negociada dbname="negociacao_cliente.qt_negociada" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_negociado dbname="negociacao_cliente.pc_desconto_negociado" initial="0.00" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_negociado dbname="negociacao_cliente.vl_preco_negociado" initial="0.00" )
 column=(type=long updatewhereclause=yes name=cd_concorrente dbname="negociacao_cliente.cd_concorrente" )
 column=(type=char(60) updatewhereclause=yes name=de_concorrente dbname="de_concorrente" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_concorrente dbname="negociacao_cliente.vl_preco_concorrente" initial="0.00" )
 column=(type=char(60) updatewhereclause=yes name=de_laboratorio dbname="negociacao_cliente.de_laboratorio" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_rentabilidade_minima dbname="vl_rentabilidade_minima" )
 column=(type=decimal(6) updatewhereclause=yes name=pc_desconto_maximo dbname="pc_desconto_maximo" )
 column=(type=long updatewhereclause=yes name=cd_grupo_produto dbname="produto_geral.cd_grupo_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="produto_geral.id_lei_generico" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_negociacao dbname="nr_matricula_negociacao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_vendedor dbname="nr_matricula_vendedor" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_unitario dbname="negociacao_cliente.pc_desconto_unitario" )
 retrieve="  SELECT n.cd_filial,   
         n.nr_sequencial,   
         n.cd_produto,
		g.de_produto || ' : ' || g.de_apresentacao_venda as de_produto,    
         n.vl_preco_unitario,
		Cast( 0.00 as decimal(11,2) ) as vl_preco_liquido,
		Cast( 0.00 as decimal(11,2) ) as vl_preco_tabela,
         n.qt_negociada,   
         n.pc_desconto_negociado,   
         n.vl_preco_negociado,   
         n.cd_concorrente, 
		cast('' as varchar(60) ) as de_concorrente,  
         n.vl_preco_concorrente,   
         n.de_laboratorio,
		0.00 as vl_rentabilidade_minima,
		0.00 as pc_desconto_maximo,
		g.cd_grupo_produto,
		g.id_lei_generico,
		cast('' as varchar(6) ) as nr_matricula_negociacao,
		cast('' as varchar(6) ) as nr_matricula_vendedor,
		Cast( 0.00 as decimal (5,2) ) as pc_icms,
		n.pc_desconto_unitario
    FROM negociacao_cliente n
         INNER JOIN produto_geral g
			ON g.cd_produto = n.cd_produto
" )
