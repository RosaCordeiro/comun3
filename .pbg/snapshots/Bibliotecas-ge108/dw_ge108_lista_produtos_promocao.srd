table(column=(type=long updatewhereclause=yes name=cd_produto dbname="promocao_sos_produto.cd_produto" )
 column=(type=char(8190) updatewhereclause=no name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="promocao_sos_produto.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_clube dbname="promocao_sos_produto.pc_desconto_clube" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_final dbname="vl_preco_final" initial="0.00" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_clube dbname="vl_preco_clube" initial="0.00" )
 retrieve="SELECT 	psp.cd_produto,
			g.de_produto || ' : ' || g.de_apresentacao_venda as de_produto,
			psp.pc_desconto,
			psp.pc_desconto_clube,
			Cast('0.00' as dec(11,2)) as vl_preco_final,
			Cast('0.00' as dec(11,2)) as vl_preco_clube
FROM promocao_sos_produto psp
INNER JOIN produto_geral g
	ON g.cd_produto	= psp.cd_produto
WHERE psp.cd_promocao_sos = :promocao
ORDER BY 2" arguments=(("promocao", number)) )
