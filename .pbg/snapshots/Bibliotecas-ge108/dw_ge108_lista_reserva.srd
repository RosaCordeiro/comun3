table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cliente_caixa_produto.cd_filial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cliente_caixa_produto.cd_produto" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="cliente_caixa_produto.nr_sequencial" )
 column=(type=long updatewhereclause=yes name=nr_sequencial_cliente_caixa dbname="cliente_caixa_produto.nr_sequencial_cliente_caixa" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=long updatewhereclause=yes name=qt_produto dbname="cliente_caixa_produto.qt_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="cliente_caixa_produto.id_situacao" )
 column=(type=long updatewhereclause=yes name=cd_filial_transferencia dbname="cliente_caixa_produto.cd_filial_transferencia" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_transferencia dbname="cliente_caixa_produto.nr_matricula_transferencia" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="cliente_caixa_produto.vl_preco_unitario" )
 column=(type=long updatewhereclause=yes name=qt_saldo_atual dbname="cliente_caixa_produto.qt_saldo_atual" )
 column=(type=char(1) updatewhereclause=yes name=id_selecao dbname="id_selecao" values="	S/	N" )
 column=(type=long updatewhereclause=yes name=nr_pedido_empurrado dbname="nr_pedido_empurrado" )
 column=(type=long updatewhereclause=yes name=cd_mix_produto dbname="cd_mix_produto" )
 column=(type=long updatewhereclause=yes name=qt_minima_aprovacao dbname="qt_minima_aprovacao" )
 column=(type=long updatewhereclause=yes name=qt_reservada_ped_empurrado dbname="qt_reservada_ped_empurrado" )
 retrieve="  SELECT c.cd_filial,   
         c.cd_produto,   
		c.nr_sequencial,
         c.nr_sequencial_cliente_caixa,
		g.de_produto,
         c.qt_produto,   
         c.id_situacao,
		c.cd_filial_transferencia,
		c.nr_matricula_transferencia,
		c.vl_preco_unitario,
		c.qt_saldo_atual,
		Cast('N' as Varchar(1) ) as id_selecao,
		Cast( 0 as integer )  as nr_pedido_empurrado,
		Cast( 0 as integer )  as cd_mix_produto,	
		Cast( 0 as integer )  as qt_minima_aprovacao,
		Cast( 0 as integer )  as qt_reservada_ped_empurrado		
    FROM cliente_caixa_produto c
	INNER JOIN produto_geral g
ON g.cd_produto = c.cd_produto  " )
