table(column=(type=long updatewhereclause=yes name=nr_reserva dbname="cliente_caixa.nr_reserva" )
 column=(type=char(40) updatewhereclause=yes name=nm_responsavel dbname="nm_responsavel" )
 column=(type=char(15) updatewhereclause=yes name=nr_fone_recado_reserva dbname="cliente_caixa.nr_fone_recado_reserva" )
 column=(type=date updatewhereclause=yes name=dh_inicio_reserva dbname="cliente_caixa.dh_inicio_reserva" )
 column=(type=date updatewhereclause=yes name=dh_termino_reserva dbname="cliente_caixa.dh_termino_reserva" )
 column=(type=char(8190) updatewhereclause=no name=vendedor dbname="vendedor" )
 column=(type=char(255) updatewhereclause=yes name=id_avisou_cliente dbname="id_avisou_cliente" values="	S/	N" )
 retrieve="select	nr_sequencial as nr_reserva,
		coalesce( x.nm_recado_reserva, c.nm_cliente) as nm_responsavel,
		x.nr_fone_recado_reserva,
		x.dh_inicio_reserva,
		x.dh_termino_reserva,
		x.nr_matricula_vendedor || '-' || SPLIT_PART(u.nm_usuario, ' ', 1) AS vendedor,
		COALESCE( x.id_avisou_cliente_reserva, 'N' ) as id_avisou_cliente
from cliente_caixa x 
inner join cliente c
	on c.cd_cliente = x.cd_cliente
inner join usuario u
	on u.nr_matricula = x.nr_matricula_vendedor
where x.id_tipo 	= 'R'
and x.id_situacao	= 'R'
and dbo.uf_dh_parametro() > x.dh_termino_reserva

UNION

select	nr_sequencial as nr_reserva,
		coalesce( x.nm_recado_reserva, c.nm_cliente),
		x.nr_fone_recado_reserva,
		x.dh_inicio_reserva,
		x.dh_termino_reserva,
		x.nr_matricula_vendedor || '-' || SPLIT_PART(u.nm_usuario, ' ', 1),
		COALESCE( x.id_avisou_cliente_reserva, 'N' )	as id_avisou_cliente 
from cliente_caixa x 
inner join cliente c
	on c.cd_cliente = x.cd_cliente
inner join usuario u
	on u.nr_matricula = x.nr_matricula_vendedor
where x.id_tipo 	= 'R'
and x.id_situacao	IN ('R', 'C')
and COALESCE( x.id_avisou_cliente_reserva, 'N' ) = 'N'
and dbo.uf_dh_parametro() BETWEEN x.dh_inicio_reserva AND x.dh_termino_reserva

UNION

select	nr_sequencial as nr_reserva,
		coalesce( x.nm_recado_reserva, c.nm_cliente),
		x.nr_fone_recado_reserva,
		x.dh_inicio_reserva,
		x.dh_termino_reserva,
		x.nr_matricula_vendedor || '-' || SPLIT_PART(u.nm_usuario, ' ', 1),
		COALESCE( x.id_avisou_cliente_reserva, 'N' ) as id_avisou_cliente
from cliente_caixa x 
inner join cliente c
	on c.cd_cliente = x.cd_cliente
inner join usuario u
	on u.nr_matricula = x.nr_matricula_vendedor
where x.id_tipo 	= 'R'
and x.id_situacao	IN  ('C', 'R', 'T')
and COALESCE( x.id_avisou_cliente_reserva, 'N' ) = 'N'
and dbo.uf_dh_parametro() > x.dh_inicio_reserva
"  sort="dh_inicio_reserva A nm_responsavel A " )
