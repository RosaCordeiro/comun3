table(column=(type=char(40) updatewhereclause=yes name=de_parametro dbname="roteiro_parametro.de_parametro" )
 column=(type=long updatewhereclause=yes key=yes name=cd_filial dbname="roteiro_parametro.cd_filial" )
 column=(type=long updatewhereclause=yes key=yes name=id_parametro dbname="roteiro_parametro.id_parametro" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo dbname="roteiro_parametro.id_tipo" values="POR DEMANDA	D/HORARIO FIXO	F/" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="roteiro_parametro.id_situacao" )
 column=(type=datetime updatewhereclause=yes name=dh_horario_saida dbname="roteiro_parametro.dh_horario_saida" )
 column=(type=datetime updatewhereclause=yes name=dh_horario_corte dbname="roteiro_parametro.dh_horario_corte" )
 column=(type=long updatewhereclause=yes name=qt_limite_pedido dbname="roteiro_parametro.qt_limite_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="roteiro_parametro.dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="roteiro_parametro.dh_termino" )
 column=(type=char(1) updatewhereclause=yes name=id_dia_entrega dbname="roteiro_parametro.id_dia_entrega" values="SEGUNDA A SEXTA	1/S$$HEX1$$c100$$ENDHEX$$BADO	2/DOMINGO	3/" )
 column=(type=char(60) updatewhereclause=yes name=de_observacao dbname="roteiro_parametro.de_observacao" )
 column=(type=decimal(0) updatewhereclause=yes name=qt_pedido_roteiro dbname="qt_pedido_roteiro" )
 retrieve="  SELECT r.de_parametro,   
         r.cd_filial,   
         r.id_parametro,   
         r.id_tipo,   
         r.id_situacao,   
         r.dh_horario_saida,   
         r.dh_horario_corte,   
         r.qt_limite_pedido,   
         r.dh_inicio,   
         r.dh_termino,   
         r.id_dia_entrega,   
         r.de_observacao,
		COALESCE( (SELECT count(nr_roteiro) FROM roteiro_saida AS s 
					    WHERE s.id_parametro = r.id_parametro
					      AND s.dh_saida = CAST(dbo.uf_dh_parametro() as DATE)), 0) as qt_pedido_roteiro 
    FROM roteiro_parametro r  
   WHERE r.cd_filial = dbo.uf_Filial_Parametro()
AND r.id_parametro = :parametro  
" update="roteiro_parametro" updatewhere=1 updatekeyinplace=no arguments=(("parametro", number)) )
