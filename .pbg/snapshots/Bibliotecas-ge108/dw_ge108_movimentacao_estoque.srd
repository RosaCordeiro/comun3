table(column=(type=date updatewhereclause=yes name=dh_inicio dbname="dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="dh_termino" )
 column=(type=date updatewhereclause=yes name=dh_movimento dbname="movimento_estoque.dh_movimento" )
 column=(type=long updatewhereclause=yes name=nr_movimento_estoque dbname="movimento_estoque.nr_movimento_estoque" )
 column=(type=long updatewhereclause=yes name=cd_tipo_movimento dbname="movimento_estoque.cd_tipo_movimento" )
 column=(type=long updatewhereclause=yes name=qt_movimento dbname="movimento_estoque.qt_movimento" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="movimento_estoque.nr_nf" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_movimento dbname="tipo_movimento_estoque.de_tipo_movimento" )
 column=(type=char(1) updatewhereclause=yes name=id_entrada_saida dbname="tipo_movimento_estoque.id_entrada_saida" )
 column=(type=char(1) updatewhereclause=yes name=id_cancelamento dbname="tipo_movimento_estoque.id_cancelamento" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="movimento_estoque.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=serie dbname="movimento_estoque.de_serie" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="movimento_estoque.cd_cliente" )
 column=(type=char(40) updatewhereclause=yes name=cliente_nm_cliente dbname="cliente.nm_cliente" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="movimento_estoque.cd_filial" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="movimento_estoque.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=fornecedor_nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="movimento_estoque.cd_convenio" )
 column=(type=char(60) updatewhereclause=yes name=convenio_nm_fantasia dbname="convenio.nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_movimento dbname="tipo_movimento_estoque.id_tipo_movimento" )
 column=(type=long updatewhereclause=yes name=filial_cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=char(40) updatewhereclause=yes name=de_local_estocagem dbname="local_estocagem.de_local_estocagem" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 retrieve="  SELECT dbo.adddate('day', -10, getdate() )	as dh_inicio,
		getdate()									as dh_termino,
		me.dh_movimento,   
         me.nr_movimento_estoque,   
         me.cd_tipo_movimento,   
         me.qt_movimento,   
         me.nr_nf,   
         tm.de_tipo_movimento,   
         tm.id_entrada_saida,   
         tm.id_cancelamento,   
         me.de_especie,   
         me.de_serie,   
         me.cd_cliente,   
         cl.nm_cliente,   
         me.cd_filial,   
         me.cd_fornecedor,   
         fo.nm_fantasia,   
         me.cd_convenio,   
         co.nm_fantasia,   
         tm.id_tipo_movimento,   
         fi.cd_filial,   
         fi.nm_fantasia  ,
		g.de_produto,
		g.de_apresentacao_venda,
		e.de_local_estocagem,
		(case me.cd_tipo_movimento
			when 1 then (	select dh_emissao 
								  from nf_venda x 
								where x.cd_filial		= p.cd_filial
									and x.nr_nf			= me.nr_nf 
								    and x.de_especie	= me.de_especie
								    and x.de_serie		= me.de_serie )
			when 2 then (	select dh_cancelamento
								  from nf_venda x 
								where x.cd_filial		= p.cd_filial
									and x.nr_nf			= me.nr_nf 
								    and x.de_especie	= me.de_especie
								    and x.de_serie		= me.de_serie )
			when 3 then (	select ( case( coalesce( id_estoque_automatico, 'S' ) ) 
												when 'N' then dh_atualizacao_estoque 
												else dh_movimentacao_caixa end )
								  from nf_compra x 
								where x.cd_filial			= p.cd_filial
								    and x.cd_fornecedor	= me.cd_fornecedor
									and x.nr_nf				= me.nr_nf 
								    and x.de_especie		= me.de_especie
								    and x.de_serie			= me.de_serie )
			when 6 then (	select dh_emissao
								  from nf_transferencia x 
								where x.cd_filial_origem = p.cd_filial
								    and x.nr_nf				= me.nr_nf 
								    and x.de_especie		= me.de_especie
								    and x.de_serie			= me.de_serie )
			when 7 then (	select dh_cancelamento
								  from nf_transferencia x 
								where x.cd_filial_origem = p.cd_filial
								    and x.nr_nf				= me.nr_nf 
								    and x.de_especie		= me.de_especie
								    and x.de_serie			= me.de_serie )
			when 8 then (	select dh_ajuste
								  from ajuste_estoque x 
								where x.nr_ajuste			= me.nr_nf )
			when 9 then (	select dh_ajuste
								  from ajuste_estoque x 
								where x.nr_ajuste			= me.nr_nf )
			when 10 then (	select dh_recebimento
								  from nf_devolucao_venda x 
								where x.cd_filial		= p.cd_filial
									and x.nr_nf			= me.nr_nf 
								    and x.de_especie	= me.de_especie
								    and x.de_serie		= me.de_serie )
			when 11 then (	select dh_cancelamento
								  from nf_devolucao_venda x 
								where x.cd_filial		= p.cd_filial
									and x.nr_nf			= me.nr_nf 
								    and x.de_especie	= me.de_especie
								    and x.de_serie		= me.de_serie )
			when 14 then (	select dh_emissao
								  from nf_devolucao_compra x 
								where x.cd_filial		= p.cd_filial
									and x.nr_nf			= me.nr_nf 
								    and x.de_especie	= me.de_especie
								    and x.de_serie		= me.de_serie )
			when 15 then (	select dh_cancelamento
								  from nf_devolucao_compra x 
								where x.cd_filial		= p.cd_filial
									and x.nr_nf			= me.nr_nf 
								    and x.de_especie	= me.de_especie
								    and x.de_serie		= me.de_serie )
			else me.dh_movimento
		end) as dh_emissao 
    FROM movimento_estoque me
			INNER JOIN tipo_movimento_estoque tm
				ON me.cd_tipo_movimento = tm.cd_tipo_movimento
			INNER JOIN produto_geral as g
				ON g.cd_produto = me.cd_produto
			INNER JOIN produto_loja as l
				ON l.cd_produto = g.cd_produto
			INNER JOIN local_estocagem as e
				ON e.cd_local_estocagem = l.cd_local_estocagem
			INNER JOIN parametro as p
				ON 1 = 1
			LEFT OUTER JOIN cliente cl
			  ON cl.cd_cliente = me.cd_cliente
			LEFT OUTER JOIN filial fi
			   ON fi.cd_filial = me.cd_filial
			LEFT OUTER JOIN fornecedor fo
			   ON fo.cd_fornecedor = me.cd_fornecedor
			LEFT OUTER JOIN convenio co  
			   ON co.cd_convenio = me.cd_convenio
   WHERE me.dh_movimento between dbo.adddate('day', -10, getdate() ) and getdate()
	AND me.cd_produto = :produto
	AND p.id_parametro = '1'" arguments=(("produto", number))  sort="dh_movimento A nr_movimento_estoque A " )
