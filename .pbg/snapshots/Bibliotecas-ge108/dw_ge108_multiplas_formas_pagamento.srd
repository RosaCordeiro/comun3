 retrieve="  SELECT nr_sequencial,
		vl_pagamento,   
         cd_forma_pagamento,   
         nr_parcelas_cartao,
		cd_forma_pagamento as de_pagamento
    FROM roteiro_entrega_pagamento   
Where nr_roteiro =:roteiro" arguments=(("roteiro", number)) )
