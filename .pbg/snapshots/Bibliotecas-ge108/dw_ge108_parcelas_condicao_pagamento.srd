compute(band=detail alignment="1" expression="sum ( IF (GetRow() = 1,  0, c_tot_parc )for all)"border="0" color="0" x="2519" y="4" height="64" width="384" format="[general]"  name=c_soma_parcelas visible="1~t0"  font.face="Arial" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="65535" )
