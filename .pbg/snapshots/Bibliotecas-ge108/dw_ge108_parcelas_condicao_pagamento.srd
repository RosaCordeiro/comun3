compute(band=detail alignment="1" expression="Round(IF (GetRow() = 1, dec(c_total) - c_soma_parcelas, c_tot_parc),2)"border="2" color="0" x="1243" y="4" height="64" width="384" format="###,###,##0.00"  name=c_valor_final_parc  font.face="Arial" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="16777215" )
text(band=footer alignment="1" text="Total :"border="0" color="8388608" x="1029" y="12" height="64" width="197"  font.face="Arial" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
compute(band=footer alignment="1" expression="sum( c_valor_final_parc  for all)"border="2" color="0" x="1243" y="12" height="64" width="384" format="###,###,##0.00"  name=c_total_geral  tag="Deve ser igual ao valor passado menos o desconto"  font.face="Arial" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="16777215" )
