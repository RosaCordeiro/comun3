 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"parcela_crediario~" ) COLUMN(NAME=~"parcela_crediario.nr_parcela~") COLUMN(NAME=~"parcela_crediario.nr_dias_vencimento~") COLUMN(NAME=~"parcela_crediario.pc_valor_total~")WHERE(    EXP1 =~"parcela_crediario.cd_condicao_crediario~"   OP =~"=~"    EXP2 =~":a_condicao~" ) ) ARG(NAME = ~"a_condicao~" TYPE = number)  ARG(NAME = ~"a_total~" TYPE = string)  ARG(NAME = ~"a_data~" TYPE = date) " arguments=(("a_condicao", number),("a_total", string),("a_data", date)) )
