table(column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="promocao_sos.cd_promocao_sos" )
 column=(type=char(40) updatewhereclause=yes name=nm_promocao_sos dbname="promocao_sos.nm_promocao_sos" )
 column=(type=char(30) updatewhereclause=yes name=de_tipo_replicacao dbname="de_tipo_replicacao" )
 column=(type=date updatewhereclause=yes name=dh_inicio dbname="promocao_sos.dh_inicio" )
 column=(type=date updatewhereclause=yes name=dh_termino dbname="promocao_sos.dh_termino" )
 column=(type=char(200) updatewhereclause=yes name=de_promocao dbname="promocao_sos.de_promocao" )
 retrieve="SELECT  p.cd_promocao_sos,
			p.nm_promocao_sos,
			CAST( (CASE p.id_tipo_replicacao 
			WHEN 'U' THEN '$$HEX1$$da00$$ENDHEX$$NICA'
			WHEN 'M' THEN 'M$$HEX1$$da00$$ENDHEX$$LTIPLA'
			WHEN 'A' THEN 'A PARTIR'
			WHEN 'T' THEN 'TODOS'
	ELSE 'N$$HEX1$$c300$$ENDHEX$$O PREVISTO' END) AS VARCHAR(30)) AS de_tipo_replicacao,
	p.dh_inicio,
	p.dh_termino,
	p.de_promocao
FROM promocao_sos p 
INNER JOIN promocao_sos_produto psp
	ON psp.cd_promocao_sos 	= p.cd_promocao_sos

INNER JOIN parametro x
	ON x.id_parametro = '1'
	
WHERE
case
	when p.id_tipo_replicacao = 'T' then 
			p.dh_inicio <= x.dh_movimentacao AND (p.dh_termino >= x.dh_movimentacao OR p.dh_termino IS NULL)
			AND psp.cd_produto  			= :produto
			AND p.id_tipo_promocao 	= :tipo
			AND p.id_situacao 				= 'L'
			and (psp.pc_desconto > :desconto or psp.pc_desconto_clube > :desconto)
	else
		p.dh_inicio <= x.dh_movimentacao AND (p.dh_termino >= x.dh_movimentacao OR p.dh_termino IS NULL)
		AND psp.cd_produto  			= :produto
		AND p.id_tipo_promocao 	= :tipo
		AND p.id_situacao 				= 'L'
end

UNION

SELECT  p.cd_promocao_sos,
			p.nm_promocao_sos,
			CAST( (CASE p.id_tipo_replicacao 
			WHEN 'U' THEN '$$HEX1$$da00$$ENDHEX$$NICA'
			WHEN 'M' THEN 'M$$HEX1$$da00$$ENDHEX$$LTIPLA'
			WHEN 'A' THEN 'A PARTIR'
			WHEN 'T' THEN 'TODOS'
	ELSE 'N$$HEX1$$c300$$ENDHEX$$O PREVISTO' END) AS VARCHAR(30)) AS de_tipo_replicacao,
	p.dh_inicio,
	p.dh_termino,
	p.de_promocao
FROM promocao_sos p 
INNER JOIN promocao_sos_produto psp
	ON psp.cd_promocao_sos 	= p.cd_promocao_sos
INNER JOIN promocao_sos_vinculo_prd pvp
	ON pvp.cd_promocao_sos 	= psp.cd_promocao_sos

INNER JOIN parametro x
	ON x.id_parametro = '1'
	
WHERE
case
	when p.id_tipo_replicacao = 'T' then 
			p.dh_inicio <= x.dh_movimentacao AND (p.dh_termino >= x.dh_movimentacao OR p.dh_termino IS NULL)
			AND pvp.cd_produto  			= :produto
			AND p.id_tipo_promocao 	= :tipo
			AND p.id_situacao 				= 'L'
			and (psp.pc_desconto > :desconto or psp.pc_desconto_clube > :desconto)

	else
		p.dh_inicio <= x.dh_movimentacao AND (p.dh_termino >= x.dh_movimentacao OR p.dh_termino IS NULL)
		AND pvp.cd_produto  			= :produto
		AND p.id_tipo_promocao 	= :tipo
		AND p.id_situacao 				= 'L'
end

ORDER BY 2" arguments=(("produto", number),("tipo", string),("desconto", decimal)) )
