table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="g.cd_produto" initial="999999" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="g.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="g.de_apresentacao_venda" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" dbalias="g.cd_grupo_psico" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_filial dbname="produto_loja.id_situacao_filial" dbalias="l.id_situacao_filial" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="vw_saldo_atual_produto.qt_saldo_final" dbalias="v.qt_saldo_final" )
 column=(type=char(255) updatewhereclause=yes name=id_promover_venda dbname="id_promover_venda" initial="S" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="produto_geral.id_lei_generico" dbalias="g.id_lei_generico" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_tabela dbname="vl_preco_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_liquido dbname="vl_preco_liquido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_clube dbname="vl_preco_clube" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_pago_fpb dbname="vl_preco_pago_fpb" )
 column=(type=char(255) updatewhereclause=yes name=id_situacao_matriz dbname="id_situacao_matriz" )
 column=(type=char(1) updatewhereclause=yes name=id_farmacia_popular dbname="produto_geral.id_farmacia_popular" dbalias="g.id_farmacia_popular" initial="S" )
 column=(type=decimal(6) updatewhereclause=yes name=cd_produto_pbm dbname="cd_produto_pbm" )
 column=(type=decimal(0) updatewhereclause=yes name=cd_produto_dermaclub dbname="cd_produto_dermaclub" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_loja.id_situacao" dbalias="l.id_situacao" initial="I" )
 column=(type=decimal(0) updatewhereclause=yes name=id_saldo_pendente dbname="id_saldo_pendente" )
 column=(type=decimal(0) updatewhereclause=yes name=qt_saldo_pendente dbname="qt_saldo_pendente" )
 column=(type=char(255) updatewhereclause=yes name=id_pbm_clamed dbname="id_pbm_clamed" initial="N" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_filial dbname="pc_desconto_filial" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_clube dbname="pc_desconto_clube" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_custo_gerencial dbname="vl_custo_gerencial" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_rentabilidade dbname="pc_rentabilidade" )
 column=(type=char(255) updatewhereclause=yes name=id_positivo dbname="id_positivo" )
 column=(type=char(255) updatewhereclause=yes name=id_negativo dbname="id_negativo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_rentabilidade dbname="vl_rentabilidade" )
 column=(type=char(255) updatewhereclause=yes name=id_dermaclub dbname="id_dermaclub" )
 retrieve="SELECT
    g.cd_produto AS cd_produto,
    g.de_produto AS de_produto,
    g.de_apresentacao_venda AS de_apresentacao_venda,
    g.cd_grupo_psico AS cd_grupo_psico,
    l.id_situacao AS id_situacao_filial,
    v.qt_saldo_final AS qt_saldo_final,
    COALESCE(g.id_promover_venda, 'N') AS id_promover_venda,
    g.id_lei_generico AS id_lei_generico,
    CAST(0.00 AS DECIMAL(9,2)) AS vl_preco_tabela,
    CAST(0.00 AS DECIMAL(9,2)) AS vl_preco_liquido,
    CAST(0.00 AS DECIMAL(9,2)) AS vl_preco_clube,
    CAST(0.00 AS DECIMAL(9,2)) AS vl_preco_pago_fpb,
	'A' AS id_situacao_matriz, -- utilizado para mostrar que o produto foi adicionado a lista pelo F
	id_farmacia_popular AS id_farmacia_popular,
	COALESCE( (select sum(qtde) 
		from(
		SELECT Count(pro.cd_pbm) as qtde
		FROM		pbm AS pbm
			INNER JOIN pbm_produto AS pro
				ON pro.cd_pbm = pbm.cd_pbm
			LEFT OUTER JOIN parametro_loja p
				ON cd_parametro = 'ID_INTEGRA_PORTAL_DROGARIA'
		WHERE	pro.cd_produto = g.cd_produto
		and pbm.cd_convenio = 52568
		and (Case when p.vl_parametro = 'N' Then pbm.cd_pbm <> 175 Else pbm.cd_pbm = 175 end)
		
		Union all
		
		SELECT	Count(pro.cd_pbm) as qtde
		FROM		pbm AS pbm
			INNER JOIN pbm_produto AS pro
				ON pro.cd_pbm = pbm.cd_pbm
		WHERE	pro.cd_produto = g.cd_produto
		and (pbm.cd_convenio is null Or pbm.cd_convenio <> '52568')
		and coalesce (pbm.id_tipo, '') <> 'D' 
	) as x), 0 ) AS cd_produto_pbm,
    COALESCE( (SELECT COUNT(1) FROM pbm_produto pp2, pbm pg2 WHERE pg2.cd_pbm = pp2.cd_pbm and coalesce (pg2.id_tipo, '') = 'D'  and pp2.cd_produto = g.cd_produto GROUP BY cd_produto), 0 ) AS cd_produto_dermaclub,
	l.id_situacao	AS id_situacao,
	COALESCE( ( SELECT COUNT( 1 ) FROM vw_saldo_produto_pendente vp WHERE vp.cd_produto = g.cd_produto GROUP BY vp.cd_produto ) , 0 ) AS id_saldo_pendente,
	COALESCE( ( SELECT COUNT( 1 ) FROM vw_saldo_produto_pendente vp WHERE vp.cd_produto = g.cd_produto AND tipo_movimento = 'TRANSF. FILIAL' GROUP BY vp.cd_produto ) , 0 ) AS qt_saldo_pendente,
    'N' AS id_pbm_clamed,
	CAST(0.00 AS DECIMAL(9,2)) AS pc_desconto_filial,
    CAST(0.00 AS DECIMAL(9,2)) AS pc_desconto_clube,
	COALESCE(v.vl_custo_gerencial,0) AS vl_custo_gerencial,
    CAST(0.00 AS DECIMAL(9,2)) AS pc_rentabilidade,
	'N' AS id_positivo,
	'N' AS id_negativo,
	CAST(0.00 AS DECIMAL(9,2)) AS vl_rentabilidade,
    'N' AS id_dermaclub
FROM produto_geral g
	INNER JOIN produto_loja l
		ON l.cd_produto = g.cd_produto
	INNER JOIN vw_saldo_atual_produto v
		ON v.cd_produto = g.cd_produto
WHERE g.id_liberado_filial = 'S'
and (g.cd_produto_sap is not null and Trim(g.cd_produto_sap) <> '')"  sort="de_descricao_apresentacao A " )
