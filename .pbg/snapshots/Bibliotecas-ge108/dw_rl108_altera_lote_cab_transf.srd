table(column=(type=long updatewhereclause=yes name=item_nf_transferencia_lote_cd_filial_origem dbname="item_nf_transferencia_lote.cd_filial_origem" )
 column=(type=long updatewhereclause=yes name=item_nf_transferencia_lote_cd_filial dbname="item_nf_transferencia_lote.cd_filial" )
 column=(type=char(255) updatewhereclause=yes name=cd_fornecedor dbname="item_nf_transferencia.cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=item_nf_transferencia_lote_nr_nf dbname="item_nf_transferencia_lote.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=item_nf_transferencia_lote_de_especie dbname="item_nf_transferencia_lote.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=item_nf_transferencia_lote_de_serie dbname="item_nf_transferencia_lote.de_serie" )
 column=(type=long updatewhereclause=yes name=item_nf_transferencia_lote_cd_natureza_operacao dbname="item_nf_transferencia_lote.cd_natureza_operacao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_transferencia_lote.cd_produto" )
 column=(type=char(10) updatewhereclause=yes name=nr_lote dbname="item_nf_transferencia_lote.nr_lote" )
 column=(type=long updatewhereclause=yes name=qt_lote dbname="item_nf_transferencia_lote.qt_lote" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=char(10) updatewhereclause=yes name=cd_dcb dbname="dcb_produto.cd_dcb" )
 column=(type=char(40) updatewhereclause=yes name=de_dcb dbname="dcb_produto.de_dcb" )
 column=(type=char(13) updatewhereclause=yes name=de_registro_ms dbname="produto_geral.de_registro_ms" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" )
 column=(type=long updatewhereclause=yes name=total_nota dbname="item_nf_transferencia.total_nota" )
 retrieve="SELECT	l.cd_filial_origem				AS cd_filial_origem,
			l.cd_filial_origem				AS cd_filial,
			:fornecedor						AS cd_fornecedor,
			l.nr_nf							AS nr_nf,
			l.de_especie						AS de_especie,
			l.de_serie						AS de_serie,
			l.cd_natureza_operacao		AS cd_natureza_operacao,
			l.cd_produto						AS cd_produto,
			l.nr_lote							AS nr_lote,
			l.qt_lote							AS qt_lote,
			g.de_produto					AS de_produto,
			g.de_apresentacao_venda	AS de_apresentacao_venda,
			d.cd_dcb							AS cd_dcb,
			d.de_dcb							AS de_dcb,
			g.de_registro_ms				AS de_registro_ms,
			g.cd_grupo_psico				AS cd_grupo_psico,
			i.qt_transferida					AS total_nota
	FROM	item_nf_transferencia AS i
			INNER JOIN item_nf_transferencia_lote AS l
				ON l.cd_filial_origem			= i.cd_filial_origem
			   AND l.nr_nf						= i.nr_nf
			   AND l.de_especie				= i.de_especie
			   AND l.de_serie					= i.de_serie
			   AND l.cd_natureza_operacao	= i.cd_natureza_operacao
			   AND l.cd_produto				= i.cd_produto
			INNER JOIN produto_geral AS g
				ON g.cd_produto = l.cd_produto
			LEFT OUTER JOIN dcb_produto AS d
				ON d.cd_dcb = g.cd_dcb
			LEFT OUTER JOIN saldo_produto_lote AS s
				ON s.cd_produto	= l.cd_produto
			   AND s.nr_lote		= l.nr_lote
 WHERE l.cd_filial_origem	= :filial
	 AND l.nr_nf					= :nota
	 AND l.de_especie			= :especie
	 AND l.de_serie				= :serie
	 AND g.cd_produto			= :produto" arguments=(("filial", number),("fornecedor", string),("nota", number),("especie", string),("serie", string),("produto", number)) )
