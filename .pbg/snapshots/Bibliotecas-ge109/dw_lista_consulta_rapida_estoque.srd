table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(255) updatewhereclause=yes name=de_apresentacao_venda dbname="de_apresentacao_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_tabela dbname="vl_preco_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_fixo dbname="pc_desconto_fixo" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_negociavel dbname="pc_desconto_negociavel" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_sos dbname="pc_desconto_sos" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_clube_atual dbname="pc_desconto_clube_atual" )
 column=(type=long updatewhereclause=yes name=vw_saldo_atual_produto_qt_saldo_final dbname="vw_saldo_atual_produto.qt_saldo_final" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_loja.id_situacao" )
 column=(type=char(1) updatewhereclause=yes name=id_comissionado dbname="id_comissionado" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" )
 column=(type=char(1) updatewhereclause=yes name=id_promover_venda dbname="produto_geral.id_promover_venda" initial="S" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="produto_geral.id_lei_generico" initial="R" )
 retrieve="SELECT	pg.cd_produto,   
			pg.de_produto,   
			coalesce(pg.de_apresentacao_venda, '') as de_apresentacao_venda,   
			cast(0.00 as decimal(9,2)) vl_preco_tabela, 
			cast(0.00 as decimal(9,2)) pc_desconto_fixo,
			cast(0.00 as decimal(9,2)) pc_desconto_negociavel,
			cast(0.00 as decimal(9,2)) pc_desconto_sos,
			cast(0.00 as decimal(9,2)) pc_desconto_clube_atual,
			vw.qt_saldo_final,   
			pl.id_situacao,
			Cast((Case when (SELECT count(*) FROM tipo_comissao_produto tp WHERE tp.cd_produto  = pl.cd_produto AND tp.pc_comissao > 0) > 0 then '*' Else '' End ) as char(1) ) as id_comissionado, 
			pg.cd_grupo_psico,
			pg.id_promover_venda AS id_promover_venda,
			pg.id_lei_generico AS id_lei_generico
FROM produto_geral pg 
	INNER JOIN vw_saldo_atual_produto vw ON  vw.cd_produto 	= pg.cd_produto
	INNER JOIN produto_loja pl					ON pl.cd_produto 		= pg.cd_produto
WHERE pg.cd_produto = pg.cd_produto"  sort="de_produto A de_apresentacao_venda A " )
