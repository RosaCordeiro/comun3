table(column=(type=char(1) updatewhereclause=yes name=id_preco_fixo dbname="pbm_produto.id_preco_fixo" values="Possui pre$$HEX1$$e700$$ENDHEX$$o fixo?	S/Possui pre$$HEX1$$e700$$ENDHEX$$o fixo?	N" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_fixo dbname="pbm_produto.vl_preco_fixo" )
 column=(type=char(1) updatewhereclause=yes name=id_desconto dbname="pbm_produto.id_desconto" values="Possui desconto?	S/Possui desconto?	N" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pbm_produto.pc_desconto" )
 column=(type=char(1) updatewhereclause=yes name=id_gratis dbname="pbm_produto.id_gratis" values="Gratuito?	S/Gratuito?	N" )
 column=(type=char(1) updatewhereclause=yes name=id_caixa_bonus dbname="pbm_produto.id_caixa_bonus" values="Possui caixa b$$HEX1$$f400$$ENDHEX$$nus?	S/Possui caixa b$$HEX1$$f400$$ENDHEX$$nus?	N" )
 column=(type=char(255) updatewhereclause=yes name=de_observacao dbname="pbm_produto.de_observacao" )
 column=(type=long updatewhereclause=yes name=cd_progressiva dbname="cd_progressiva" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto dbname="pbm_produto.vl_desconto" )
 retrieve="  SELECT pro.id_preco_fixo,   
         pro.vl_preco_fixo,   
         pro.id_desconto,   
         pro.pc_desconto,   
         pro.id_gratis,   
         pro.id_caixa_bonus,   
         pro.de_observacao,
		COALESCE( (SELECT COUNT(1) FROM pbm_produto_progressivo pg WHERE pg.cd_pbm = :pbm and pg.cd_produto = :produto GROUP BY cd_produto), 0 ) AS cd_progressiva,
		pro.vl_desconto
    FROM pbm_produto pro
   WHERE pro.cd_pbm = :pbm
	  AND pro.cd_produto = :produto" arguments=(("pbm", number),("produto", number)) )
