table(column=(type=long updatewhereclause=yes name=cd_pbm dbname="pbm.cd_pbm" )
 column=(type=char(255) updatewhereclause=yes name=nm_pbm dbname="pbm.nm_pbm" )
 column=(type=char(1) updatewhereclause=yes name=id_preco_fixo dbname="pbm_produto.id_preco_fixo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_fixo dbname="pbm_produto.vl_preco_fixo" )
 column=(type=char(1) updatewhereclause=yes name=id_desconto dbname="pbm_produto.id_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pbm_produto.pc_desconto" )
 column=(type=char(255) updatewhereclause=yes name=de_observacao dbname="pbm.de_observacao" )
 retrieve="SELECT	pbm.cd_pbm,   
			pbm.nm_pbm,   
			pro.id_preco_fixo,   
			pro.vl_preco_fixo,   
			pro.id_desconto,   
			pro.pc_desconto,
			pbm.de_observacao
FROM		pbm AS pbm
			INNER JOIN pbm_produto AS pro
			 	ON pro.cd_pbm = pbm.cd_pbm
WHERE	pro.cd_produto = :produto" arguments=(("produto", number)) )
