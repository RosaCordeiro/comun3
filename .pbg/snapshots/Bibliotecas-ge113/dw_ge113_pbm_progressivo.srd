table(column=(type=long updatewhereclause=yes name=cd_produto dbname="pbm_produto_progressivo.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_produto dbname="pbm_produto_progressivo.qt_produto" )
 column=(type=char(255) updatewhereclause=yes name=de_tipo_operador dbname="de_tipo_operador" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto dbname="pbm_produto_progressivo.vl_desconto" )
 retrieve="select cd_produto,
		qt_produto,
		(Case 
			when de_tipo_operador = '=' Then 'IGUAL'
			when de_tipo_operador = '>=' Then 'MAIOR OU IGUAL'
			when de_tipo_operador = '<=' Then 'MENOR OU IGUAL'
			when de_tipo_operador = '<' Then 'MENOR'
		Else de_tipo_operador End) as de_tipo_operador,
		vl_desconto
from pbm_produto_progressivo
  WHERE cd_pbm		= :pbm
	  AND cd_produto = :produto" arguments=(("pbm", number),("produto", number)) )
