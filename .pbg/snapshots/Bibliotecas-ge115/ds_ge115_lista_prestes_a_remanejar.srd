table(column=(type=long updatewhereclause=yes name=cd_filial_inclusao dbname="produto_preste_a_vencer.cd_filial_inclusao" dbalias="ppv.cd_filial_inclusao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_preste_a_vencer.cd_produto" dbalias="ppv.cd_produto" )
 column=(type=char(10) updatewhereclause=yes name=nr_etiqueta dbname="produto_preste_a_vencer.nr_etiqueta" dbalias="ppv.nr_etiqueta" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="produto_preste_a_vencer.nr_lote" dbalias="ppv.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="produto_preste_a_vencer.dh_validade" dbalias="ppv.dh_validade" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="produto_preste_a_vencer.dh_inclusao" dbalias="ppv.dh_inclusao" )
 column=(type=char(1) updatewhereclause=yes name=id_remanejado dbname="id_remanejado" )
 retrieve="SELECT ppv.cd_filial_inclusao
	  , ppv.cd_produto
	  , ppv.nr_etiqueta
	  , ppv.nr_lote
	  , ppv.dh_validade
	  , ppv.dh_inclusao
	  , 'N' AS id_remanejado
  FROM
		produto_preste_a_vencer ppv
  INNER JOIN remanejamento_filial_produto rfp
			 ON rfp.cd_remanejamento = :al_cd_remanejamento
			AND rfp.cd_filial        = ppv.cd_filial_inclusao
			AND rfp.cd_produto       = ppv.cd_produto
 WHERE ppv.id_situacao  = 'A'
   AND ppv.dh_validade >= :adt_validade_ini
   AND ppv.dh_validade <= :adt_validade_fin
   AND ppv.dh_inclusao >= :adt_ini_prestes
 ORDER BY
	    ppv.dh_validade
	  , ppv.dh_inclusao

" arguments=(("al_cd_remanejamento", number),("adt_validade_ini", date),("adt_validade_fin", date),("adt_ini_prestes", date)) )
