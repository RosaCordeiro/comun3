table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=datetime updatewhereclause=yes name=dh_resumo dbname="dh_resumo" )
 retrieve="SELECT s.cd_filial
	  , s.cd_produto
	  , COALESCE(MAX(s.dh_ultimo_movimento), :adt_movto_inicial) AS dh_resumo
  FROM saldo_produto s
 WHERE s.cd_filial  IN (SELECT cd_filial
								  FROM remanejamento_filial
								 WHERE cd_remanejamento = :al_cd_remanejamento)
	AND s.cd_produto IN (SELECT cd_produto
								  FROM remanejamento_filial_produto
								 WHERE cd_remanejamento = :al_cd_remanejamento)
	AND s.dh_saldo   = :adt_saldo
	AND EXISTS (SELECT 1
					  FROM resumo_reposicao_estoque r
					 WHERE r.cd_filial  = s.cd_filial
						AND r.cd_produto = s.cd_produto)
	AND NOT EXISTS (SELECT 1
							FROM produto_preste_a_vencer ppv
						  WHERE ppv.cd_filial    = s.cd_filial
							 AND ppv.cd_produto   = s.cd_produto
							 AND ppv.id_situacao  = 'A'
							 AND ppv.dh_inclusao >= :adt_ini_prestes)
GROUP BY 
    s.cd_filial,
    s.cd_produto" arguments=(("al_cd_remanejamento", number),("adt_movto_inicial", date),("adt_saldo", date),("adt_ini_prestes", date)) )
