table(column=(type=long updatewhereclause=yes name=cd_remanejamento dbname="remanejamento_filial_produto.cd_remanejamento" dbalias="r.cd_remanejamento" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="remanejamento_filial_produto.cd_filial" dbalias="r.cd_filial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="remanejamento_filial_produto.cd_produto" dbalias="r.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_saldo dbname="remanejamento_filial_produto.qt_saldo" dbalias="r.qt_saldo" )
 column=(type=long updatewhereclause=yes name=qt_eb dbname="qt_eb" )
 column=(type=char(8) updatewhereclause=yes name=dh_ultimo_mvto dbname="dh_ultimo_mvto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_medio dbname="vl_custo_medio" )
 retrieve="SELECT	r.cd_remanejamento,
			r.cd_filial,
			r.cd_produto,
			r.qt_remanejar qt_saldo,
			0 as qt_eb,
			'20000101' as dh_ultimo_mvto,
			coalesce( s.vl_custo_medio, 0 ) as vl_custo_medio
FROM remanejamento_filial_produto	r
LEFT JOIN vw_saldo_atual_produto	s	ON s.cd_filial		= r.cd_filial
													AND s.cd_produto	= r.cd_produto
WHERE r.cd_remanejamento = :cd_remanejamento
" arguments=(("cd_remanejamento", number)) )
