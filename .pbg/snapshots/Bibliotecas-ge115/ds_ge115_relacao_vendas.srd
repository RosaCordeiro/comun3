table(column=(type=long update=yes updatewhereclause=yes name=cd_remanejamento dbname="remanejamento_processamento.cd_remanejamento" dbalias="rp.cd_remanejamento" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="remanejamento_processamento.cd_filial" dbalias="rp.cd_filial" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="remanejamento_processamento.cd_produto" dbalias="rp.cd_produto" )
 column=(type=long update=yes updatewhereclause=yes name=qt_saldo dbname="remanejamento_processamento.qt_saldo" dbalias="rp.qt_saldo" )
 column=(type=long update=yes updatewhereclause=yes name=qt_eb dbname="remanejamento_processamento.qt_eb" dbalias="rp.qt_eb" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="remanejamento_processamento.qt_vendida" dbalias="rp.qt_vendida" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_ultimo_mvto dbname="remanejamento_processamento.dh_ultimo_mvto" dbalias="rp.dh_ultimo_mvto" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="pg.vl_fator_conversao" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" dbalias="pg.cd_grupo_psico" )
 column=(type=long updatewhereclause=yes name=cd_cidade dbname="filial.cd_cidade" dbalias="fi.cd_cidade" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_reposicao dbname="remanejamento_processamento.cd_classe_reposicao" dbalias="rp.cd_classe_reposicao" )
 retrieve="    SELECT    rp.cd_remanejamento,  
            rp.cd_filial,  
            rp.cd_produto,  
            rp.qt_saldo_filial_destino  as qt_saldo,
            rp.qt_eb,  
            rp.qt_vendida,
            rp.dh_ultimo_mvto,
            pg.vl_fator_conversao,
            pg.cd_grupo_psico,
            fi.cd_cidade,
            rp.cd_classe_reposicao
    FROM remanejamento_processamento AS rp
            INNER JOIN produto_geral AS pg
                ON pg.cd_produto = rp.cd_produto
            INNER JOIN filial  as fi
                on fi.cd_filial = rp.cd_filial
  WHERE dh_ultimo_mvto >= dateadd( day, -:dias, getdate() )
      AND qt_vendida > 0
	 AND qt_saldo_filial_destino < qt_eb" arguments=(("dias", number))  sort="cd_produto A qt_vendida D " )
