table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_remanejamento dbname="remanejamento.cd_remanejamento" )
 column=(type=char(60) update=yes updatewhereclause=yes name=de_remanejamento dbname="remanejamento.de_remanejamento" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_calculo dbname="remanejamento.dh_calculo" )
 column=(type=long update=yes updatewhereclause=yes name=qt_dias_retirada dbname="remanejamento.qt_dias_retirada" )
 column=(type=long update=yes updatewhereclause=yes name=qt_dias_remanejamento dbname="remanejamento.qt_dias_remanejamento" )
 column=(type=long update=yes updatewhereclause=yes name=id_selecao_produto dbname="remanejamento.id_selecao_produto" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_psico dbname="remanejamento.id_psico" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_geladeira dbname="remanejamento.id_geladeira" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_planograma dbname="remanejamento.id_planograma" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_beauty_club dbname="remanejamento.id_beauty_club" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_promocao_estoque_minimo dbname="remanejamento.id_promocao_estoque_minimo" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" initial="N" values="	S/	N" )
 retrieve="SELECT	r.cd_remanejamento					as cd_remanejamento,   
			r.de_remanejamento					as de_remanejamento,
			r.dh_calculo								as dh_calculo,   
			r.qt_dias_retirada						as qt_dias_retirada,   
			r.qt_dias_remanejamento			as qt_dias_remanejamento,   
			r.id_selecao_produto					as id_selecao_produto,   
			r.id_psico								as id_psico,   
			r.id_geladeira							as id_geladeira,   
			r.id_planograma						as id_planograma,   
			r.id_beauty_club						as id_beauty_club,
			r.id_promocao_estoque_minimo	as id_promocao_estoque_minimo,
			'' id_selecionar
	FROM remanejamento as r
" update="remanejamento" updatewhere=1 updatekeyinplace=no  sort="cd_remanejamento D " )
