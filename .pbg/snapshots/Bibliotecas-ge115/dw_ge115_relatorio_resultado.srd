table(column=(type=long update=yes updatewhereclause=yes name=cd_remanejamento dbname="remanejamento_resultado.cd_remanejamento" dbalias="rr.cd_remanejamento" )
 column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="remanejamento_resultado.cd_filial_origem" dbalias="rr.cd_filial_origem" )
 column=(type=char(40) updatewhereclause=yes name=nm_filial_origem dbname="filial.nm_filial_origem" dbalias="fo.nm_filial_origem" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial_destino dbname="remanejamento_resultado.cd_filial_destino" dbalias="rr.cd_filial_destino" )
 column=(type=char(40) updatewhereclause=yes name=nm_filial_destino dbname="filial.nm_filial_destino" dbalias="fd.nm_filial_destino" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="remanejamento_resultado.cd_produto" dbalias="rr.cd_produto" )
 column=(type=char(108) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long update=yes updatewhereclause=yes name=qt_remanejamento dbname="remanejamento_resultado.qt_remanejamento" dbalias="rr.qt_remanejamento" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_remanejamento dbname="remanejamento_resultado.vl_remanejamento" dbalias="rr.vl_remanejamento" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="remanejamento_resultado.id_situacao" dbalias="rr.id_situacao" values="PENDENTE	P/FATURADO	F/REJEITADO	J/" )
 column=(type=long update=yes updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_serie dbname="de_serie" )
 retrieve="select	rr.cd_remanejamento			as cd_remanejamento,   
		rr.cd_filial_origem				as cd_filial_origem,   
		fo.nm_fantasia					as nm_filial_origem,
		rr.cd_filial_destino				as cd_filial_destino,   
		fd.nm_fantasia					as nm_filial_destino,
		rr.cd_produto					as cd_produto,   
		(CASE WHEN pg.cd_grupo_psico IS NULL THEN pg.de_produto || ' : ' || pg.de_apresentacao_venda ELSE pg.de_produto || ' : ' || pg.de_apresentacao_venda || ' (' ||  pg.cd_grupo_psico || ')'  END) AS de_produto,
		rr.qt_remanejamento			as qt_remanejamento,   
		(CASE WHEN rr.nr_nf IS NOT NULL THEN COALESCE(inf.qt_transferida,0) ELSE COALESCE(notas.qt_transferida,0) END)	as qt_faturada,    
		rr.vl_remanejamento			as vl_remanejamento,   
		rr.id_situacao										as id_situacao,  	
		ISNULL(rr.nr_nf, notas.nr_nf)					as nr_nf,   
		ISNULL(rr.de_especie, notas.de_especie)	as de_especie,   
		ISNULL(rr.de_serie, notas.de_serie)			as de_serie
from  remanejamento as r
	    inner join remanejamento_resultado as rr
		   on rr.cd_remanejamento = r.cd_remanejamento
	   inner join filial as fo
		  on fo.cd_filial = rr.cd_filial_origem
	   inner join filial as fd
		  on fd.cd_filial = rr.cd_filial_destino
	   inner join produto_geral as pg
		  on pg.cd_produto = rr.cd_produto

	   left outer join nf_transferencia as nf
		  on nf.cd_filial_origem		= rr.cd_filial_origem
		and nf.nr_nf						= rr.nr_nf
		and nf.de_especie					= rr.de_especie
		and nf.de_serie					= rr.de_serie
	
	   left outer join item_nf_transferencia as inf
		  on inf.cd_filial_origem		= nf.cd_filial_origem
		and inf.nr_nf					= nf.nr_nf
		and inf.de_especie				= nf.de_especie
		and inf.de_serie				= nf.de_serie
		and inf.cd_produto				= rr.cd_produto

		left outer join (select nf2.cd_filial_origem, nf2.cd_filial_destino, nf2.nr_nf, nf2.de_especie, nf2.de_serie, nf2.dh_movimentacao_caixa, i.cd_produto, nf2.cd_remanejamento, i.qt_transferida 
			From nf_transferencia as nf2
				inner join item_nf_transferencia i
				 on i.cd_filial_origem			= nf2.cd_filial_origem
				and i.nr_nf						= nf2.nr_nf
				and i.de_especie				= nf2.de_especie
				and i.de_serie					= nf2.de_serie
				and nf2.dh_cancelamento is null
			) as notas 
			on notas.cd_remanejamento 		= rr.cd_remanejamento
			and notas.cd_produto	  			= rr.cd_produto
			and notas.cd_filial_origem 	= rr.cd_filial_origem 
			and notas.cd_filial_destino 	= rr.cd_filial_destino"  sort="cd_filial_origem A cd_filial_destino A de_produto A " )
