table(column=(type=char(255) updatewhereclause=yes name=localizacao dbname="localizacao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" values="ANTIMICROBIANOS	W/" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fabricante.nm_razao_social" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="fabricante.nr_cgc" )
 column=(type=char(10) updatewhereclause=yes name=cd_dcb dbname="dcb_produto.cd_dcb" )
 column=(type=char(40) updatewhereclause=yes name=de_dcb dbname="dcb_produto.de_dcb" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_dosagem_minima dbname="dcb_produto.qt_dosagem_minima" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_dosagem_maxima dbname="dcb_produto.qt_dosagem_maxima" )
 column=(type=char(40) updatewhereclause=yes name=de_local_estocagem dbname="local_estocagem.de_local_estocagem" )
 column=(type=long updatewhereclause=yes name=cd_local_estocagem dbname="local_estocagem.cd_local_estocagem" )
 column=(type=char(13) updatewhereclause=yes name=de_registro_ms dbname="produto_geral.de_registro_ms" )
 retrieve="SELECT	SPACE( 40 )						AS localizacao,
			g.cd_produto					AS cd_produto,
			g.de_produto					AS de_produto,
			g.de_apresentacao_venda	AS de_apresentacao_venda,
			g.cd_grupo_psico				AS cd_grupo_psico,
			f.nm_razao_social				AS nm_razao_social,
			f.nr_cgc							AS nr_cgc,
			d.cd_dcb							AS cd_dcb,
			d.de_dcb							AS de_dcb,
			d.qt_dosagem_minima		AS qt_dosagem_minima,
			d.qt_dosagem_maxima		AS qt_dosagem_maxima,
			l.de_local_estocagem			AS de_local_estocagem,
			l.cd_local_estocagem			AS cd_local_estocagem,
			g.de_registro_ms				AS de_registro_ms
    FROM produto_geral AS g
			LEFT OUTER JOIN dcb_produto AS d
			  ON d.cd_dcb = g.cd_dcb
			LEFT OUTER JOIN fabricante AS f
			  ON f.cd_fabricante = g.cd_fabricante
			INNER JOIN produto_loja AS p
				ON p.cd_produto = g.cd_produto
			INNER JOIN local_estocagem AS l
				ON l.cd_local_estocagem = p.cd_local_estocagem
  WHERE g.cd_produto = :produto
" arguments=(("produto", number)) )
