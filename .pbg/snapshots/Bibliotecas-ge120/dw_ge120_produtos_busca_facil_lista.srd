table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="pg.cd_produto" )
 column=(type=char(102) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" dbalias="pg.id_situacao" )
 column=(type=char(1) updatewhereclause=yes name=grupo dbname="grupo" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="produto_geral.id_lei_generico" dbalias="pg.id_lei_generico" )
 retrieve="select distinct pg.cd_produto, pg.de_produto + ': ' + pg.de_apresentacao_venda as de_produto, pg.id_situacao,
    (Case pg.id_lei_generico
		When 'G' Then '1'
		When 'E' Then '2'
		When 'S' Then '3'
		When 'R' Then '4'
		Else '5'
	End) as grupo,
	pg.id_lei_generico
from produto_geral pg
Where  ( pg.id_situacao = 'A' or  exists (select 1
						  from vw_saldo_atual_produto v
						  where pg.cd_produto = v.cd_produto
							 and v.qt_saldo_final > 0 )  ) 
	and pg.cd_produto <> :pl_cd_produto
    and de_hash_busca_facil = (	Select x.de_hash_busca_facil
											from produto_geral x
											where x.cd_produto = :pl_cd_produto )
" update="produto_geral" updatewhere=0 updatekeyinplace=no arguments=(("pl_cd_produto", number))  sort="grupo A de_produto A " )
