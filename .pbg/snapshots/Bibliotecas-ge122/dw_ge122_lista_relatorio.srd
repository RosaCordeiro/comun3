table(column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_almoxarifado_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_poduto dbname="de_poduto" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="vw_saldo_atual_produto.qt_saldo_final" )
 column=(type=long updatewhereclause=yes name=qt_est_transito dbname="qt_est_transito" )
 column=(type=long updatewhereclause=yes name=falta dbname="falta" )
 retrieve="Select	pp.cd_produto 												AS cd_produto,
		g.de_produto + ' : ' + g.de_apresentacao_venda	As de_poduto,
		v.qt_saldo_final												As qt_saldo_final,
		0																As qt_est_transito,
		sum(pp.qt_pedida - (Case
										When pp.qt_atendida < 0 Then 0
										Else pp.qt_atendida
									End)) 	As falta
From pedido_almoxarifado p
	Inner Join pedido_almoxarifado_produto As pp
		On pp.cd_filial		= p.cd_filial
	   And pp.nr_pedido	= p.nr_pedido
	Inner Join produto_geral As g
		On g.cd_produto = pp.cd_produto
	Inner Join vw_saldo_atual_produto As v
		On v.cd_produto = g.cd_produto
Where Cast(p.dh_importacao As Date) >= :inicio
    And Cast(p.dh_importacao As Date) <= :termino
    And (pp.qt_pedida - pp.qt_atendida > 0)
    And p.id_situacao Not In ('C', 'X')
    And v.cd_filial = 534
Group By pp.cd_produto,
			g.de_produto,
			g.de_apresentacao_venda,
			v.qt_saldo_final" arguments=(("inicio", date),("termino", date))  sort="de_poduto A " )
