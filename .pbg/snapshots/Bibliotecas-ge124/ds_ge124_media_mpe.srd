table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=decimal(42) updatewhereclause=yes name=med_mpe dbname="med_mpe" )
 column=(type=decimal(42) updatewhereclause=yes name=valor dbname="valor" )
 column=(type=long updatewhereclause=yes name=demanda dbname="demanda" )
 retrieve="select cd_filial,
		case when valor <> 0 then
			round(valor / demanda, 4)
		else
			0
		end as med_mpe,
		valor,
		demanda
from(

	select r.cd_filial, 
		sum((case When qt_demanda_diaria > 0.00 then 
					round((((cast(qt_venda_periodo as decimal(6,2)) / 120) - qt_demanda_diaria) / (cast(qt_venda_periodo as decimal(6,2)) / 120)) * 100 * (cast(r.qt_dias_venda as decimal(6,2)) / 120) , 4)
				else 0
				end)) as valor,
	
				 (select count(*)
						from resumo_reposicao_estoque x
						where x.cd_filial = r.cd_filial
						and x.qt_demanda_diaria > 0)  as demanda	
			
	from resumo_reposicao_estoque r (index pk_resumo_reposicao_estoque)
		inner join parametro_reposicao_estoque p
			on p.cd_filial = r.cd_filial
		inner join filial f
			on f.cd_filial = p.cd_filial
		inner join produto_geral g
			on g.cd_produto = r.cd_produto
		inner join saldo_produto s (index saldo_prod_5850531202)
			on s.cd_filial = f.cd_filial
			and s.dh_saldo  = f.dh_ultimo_saldo
			and g.cd_produto = s.cd_produto
	where substring(g.cd_subcategoria, 1, 1) <> '5'
	and r.cd_filial < 1000
	and f.id_situacao = 'A'
	and p.id_tipo_reposicao = 'E'
	group by r.cd_filial
) as tudo" )
