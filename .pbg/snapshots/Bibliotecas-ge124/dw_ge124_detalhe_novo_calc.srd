table(column=(type=char(1) updatewhereclause=yes name=id_tipo dbname="parametro_estoque_base.id_tipo" dbalias=".id_tipo" values="ESTAVEL	E/SAZONAL	S/" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="dh_termino" )
 retrieve="select id_tipo_reposicao id_tipo, min(dh_venda) dh_inicio, max(dh_venda) dh_termino
from parametro_estoque_base
where cd_filial = :filial
   and id_tipo_reposicao = 'E'
group by id_tipo_reposicao

union

select id_tipo_reposicao id_tipo, min(dh_venda) dh_inicio, max(dh_venda) dh_termino
from parametro_estoque_base
where cd_filial = :filial
   and id_tipo_reposicao = 'S'
   and nr_dia <= 60
group by id_tipo_reposicao

union

select id_tipo_reposicao id_tipo, min(dh_venda) dh_inicio, max(dh_venda) dh_termino
from parametro_estoque_base
where cd_filial = :filial
   and id_tipo_reposicao = 'S'
   and nr_dia > 60
group by id_tipo_reposicao

" arguments=(("filial", number)) )
