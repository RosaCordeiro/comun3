table(column=(type=long updatewhereclause=yes name=cd_filial dbname="resumo_reposicao_estoque.cd_filial" )
 column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="vw_classificacao_produto.cd_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="vw_classificacao_produto.de_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo dbname="vw_classificacao_produto.de_subgrupo" )
 column=(type=char(40) updatewhereclause=yes name=de_categoria dbname="vw_classificacao_produto.de_categoria" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="vw_classificacao_produto.de_subcategoria" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_reposicao dbname="resumo_reposicao_estoque.id_tipo_reposicao" )
 column=(type=long updatewhereclause=yes name=qt_dias_venda dbname="resumo_reposicao_estoque.qt_dias_venda" )
 column=(type=long updatewhereclause=yes name=qt_venda_periodo dbname="resumo_reposicao_estoque.qt_venda_periodo" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_reposicao dbname="resumo_reposicao_estoque.cd_classe_reposicao" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_demanda_diaria dbname="resumo_reposicao_estoque.qt_demanda_diaria" )
 column=(type=decimal(30) updatewhereclause=yes name=mape dbname="MAPE" )
 column=(type=decimal(30) updatewhereclause=yes name=wmape dbname="WMAPE" )
 column=(type=decimal(30) updatewhereclause=yes name=mpe dbname="MPE" )
 column=(type=long updatewhereclause=yes name=qt_dias_cobertura dbname="resumo_reposicao_estoque.qt_dias_cobertura" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_gerencial dbname="produto_central.vl_custo_gerencial" )
 column=(type=long updatewhereclause=yes name=qt_estoque_filial dbname="qt_estoque_filial" )
 column=(type=decimal(2) updatewhereclause=yes name=custo_saldo dbname="custo_saldo" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo_eb dbname="resumo_reposicao_estoque.qt_estoque_minimo_eb" )
 column=(type=long updatewhereclause=yes name=qt_estoque_calculado dbname="resumo_reposicao_estoque.qt_estoque_calculado" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="resumo_reposicao_estoque.qt_estoque_base" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_anterior dbname="resumo_reposicao_estoque.qt_estoque_base_anterior" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_inicial dbname="resumo_reposicao_estoque.qt_estoque_base_inicial" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_avaliacao dbname="produto_geral.dh_termino_avaliacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_estoque_filial dbname="vl_estoque_filial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_estoque_minimo dbname="vl_estoque_minimo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_estoque_calculado dbname="vl_estoque_calculado" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_estoque_base dbname="vl_estoque_base" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_estoque_anterior dbname="vl_estoque_anterior" )
 column=(type=long updatewhereclause=yes name=qt_estoq_min_promo dbname="qt_estoq_min_promo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_estoque_minimo_promo dbname="vl_estoque_minimo_promo" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao dbname="resumo_reposicao_estoque.id_alteracao" values="MATRIZ	M/FILIAL	F/CALCULO	N/" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao dbname="resumo_reposicao_estoque.dh_alteracao" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_bloqueio dbname="resumo_reposicao_estoque.dh_termino_bloqueio" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=char(60) updatewhereclause=yes name=de_motivo_alteracao dbname="resumo_reposicao_estoque.de_motivo_alteracao" )
 retrieve="select r.cd_filial, 
		v.cd_grupo,   
       v.de_grupo,
	   v.de_subgrupo,
	   v.de_categoria,
	   v.de_subcategoria,
       g.cd_produto ,
       g.de_produto + ' : ' + g.de_apresentacao_venda de_produto, 
       g.vl_fator_conversao,
       r.id_tipo_reposicao,
		r.qt_dias_venda,
		r.qt_venda_periodo,
       r.cd_classe_reposicao,
       r.qt_demanda_diaria,
		(case
			when qt_demanda_diaria > 0.00 then round(abs((((cast(qt_venda_periodo as decimal(6,2)) / 120) - qt_demanda_diaria) / (cast(qt_venda_periodo as decimal(6,2)) / 120)) * 100), 4)
			else 0
		end) as MAPE,
		(case
			when qt_demanda_diaria > 0.00 then round(abs((((cast(qt_venda_periodo as decimal(6,2)) / 120) - qt_demanda_diaria) / (cast(qt_venda_periodo as decimal(6,2)) / 120)) * 100) * (cast(r.qt_dias_venda as decimal(6,2)) / 120) , 4)
			else 0
		end) as WMAPE,
		(case
			when qt_demanda_diaria > 0.00 then round((((cast(qt_venda_periodo as decimal(6,2)) / 120) - qt_demanda_diaria) / (cast(qt_venda_periodo as decimal(6,2)) / 120)) * 100 * (cast(r.qt_dias_venda as decimal(6,2)) / 120) , 4)
			else 0
		end) as MPE,
		 r.qt_dias_cobertura,
       c.vl_custo_gerencial,
       s.qt_saldo_final qt_estoque_filial,
	  s.vl_custo_medio custo_saldo,
       r.qt_estoque_minimo as qt_estoque_minimo_eb,
       r.qt_estoque_calculado,
       r.qt_estoque_base,
       r.qt_estoque_base_anterior,
	  r.qt_estoque_base_inicial,
	  g.dh_termino_avaliacao,
       0.00 vl_estoque_filial,
       0.00 vl_estoque_minimo,
       0.00 vl_estoque_calculado,
       0.00 vl_estoque_base,
       0.00 vl_estoque_anterior,
	  coalesce(f1.qt_estoque_minimo, 0)  qt_estoq_min_promo,
	  0.00 vl_estoque_minimo_promo,
	 r.id_alteracao,
	 r.dh_alteracao,
	 r.dh_termino_bloqueio,
     u.nm_usuario,
	 r.de_motivo_alteracao
from resumo_reposicao_estoque r   
inner join filial f on    f.cd_filial = r.cd_filial 
inner join produto_geral g on    g.cd_produto = r.cd_produto
inner join produto_central c on  c.cd_produto = g.cd_produto
	and   r.cd_produto = g.cd_produto
inner join vw_classificacao_produto as v
	on v.cd_subcategoria = g.cd_subcategoria
inner join saldo_produto s (index saldo_prod_5850531202)  on    s.cd_filial = f.cd_filial
	and   s.dh_saldo  = f.dh_ultimo_saldo
	and   g.cd_produto = s.cd_produto
left outer join resumo_estoque_minimo_filial f1
	on  r.cd_produto = f1.cd_produto
	and  r.cd_filial  = f1.cd_filial
left outer join usuario u
	on u.nr_matricula = r.nr_matricula_alteracao
where v.cd_grupo <> '5'
and     f.cd_filial = :filial_real
order by v.cd_grupo,g.de_produto" arguments=(("filial_real", number))  sort="de_produto A " )
