table(column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_transferencia.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_gerencial dbname="produto_central.vl_custo_gerencial" )
 column=(type=long updatewhereclause=yes name=qt_devolvida dbname="qt_devolvida" )
 column=(type=long updatewhereclause=yes name=qt_saldo_atual dbname="qt_saldo_atual" )
 retrieve="select i.cd_produto,
       g.de_produto,
       g.de_apresentacao_venda,
       g.vl_fator_conversao,
       c.vl_custo_gerencial,
		 sum(i.qt_transferida) qt_devolvida,
       0 qt_saldo_atual       
from nf_transferencia n,
     item_nf_transferencia i,
     produto_geral g,
     produto_central c
where n.cd_filial_origem in (68, 149, 152, 178, 246, 563, 291, 647, 589, 686, 628, 692, 698, 702, 722)
  and n.cd_filial_destino in (1, 534)
  and n.dh_movimentacao_caixa >= '2003/05/16'
  and n.dh_cancelamento is null
  and i.cd_filial_origem = n.cd_filial_origem
  and i.nr_nf            = n.nr_nf
  and i.de_especie       = n.de_especie
  and i.de_serie         = n.de_serie
  and g.cd_produto       = i.cd_produto
  and c.cd_produto       = i.cd_produto
group by i.cd_produto,
         g.de_produto,
         g.de_apresentacao_venda,
         g.vl_fator_conversao,
         c.vl_custo_gerencial" )
