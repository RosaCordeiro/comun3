table(column=(type=char(1) updatewhereclause=yes name=id_nivel_classificacao dbname="estoque_minimo_filial.id_nivel_classificacao" )
 column=(type=char(9) updatewhereclause=yes name=cd_classificacao_produto dbname="estoque_minimo_filial.cd_classificacao_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_classificacao_produto dbname="grupo.de_classificacao_produto" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe dbname="estoque_minimo_filial.cd_classe" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo dbname="estoque_minimo_filial.qt_estoque_minimo" )
 retrieve="select e.id_nivel_classificacao,
       e.cd_classificacao_produto,
       g.de_grupo de_classificacao_produto,
       e.cd_classe,
       e.qt_estoque_minimo
from estoque_minimo_filial e,
     grupo g
where e.cd_perfil_estoque = :perfil
  and e.id_nivel_classificacao = '1'
  and g.cd_grupo = e.cd_classificacao_produto

union

select e.id_nivel_classificacao,
       e.cd_classificacao_produto,
       s.de_subgrupo de_classificacao_produto,
       e.cd_classe,
       e.qt_estoque_minimo
from estoque_minimo_filial e,
     subgrupo s
where e.cd_perfil_estoque = :perfil
  and e.id_nivel_classificacao = '2'
  and s.cd_subgrupo = e.cd_classificacao_produto

union

select e.id_nivel_classificacao,
       e.cd_classificacao_produto,
       c.de_categoria de_classificacao_produto,
       e.cd_classe,
       e.qt_estoque_minimo
from estoque_minimo_filial e,
     categoria c
where e.cd_perfil_estoque = :perfil
  and e.id_nivel_classificacao = '3'
  and c.cd_categoria = e.cd_classificacao_produto

union

select e.id_nivel_classificacao,
       e.cd_classificacao_produto,
       s.de_subcategoria de_classificacao_produto,
       e.cd_classe,
       e.qt_estoque_minimo
from estoque_minimo_filial e,
     subcategoria s
where e.cd_perfil_estoque = :perfil
  and e.id_nivel_classificacao = '4'
  and s.cd_subcategoria = e.cd_classificacao_produto

union

select e.id_nivel_classificacao,
       e.cd_classificacao_produto,
       p.de_produto + ' : ' + p.de_apresentacao_venda de_classificacao_produto,
       e.cd_classe,
       e.qt_estoque_minimo
from estoque_minimo_filial e,
     produto_geral p
where e.cd_perfil_estoque = :perfil
  and e.id_nivel_classificacao = '5'
  and convert(char, p.cd_produto) = e.cd_classificacao_produto
" arguments=(("perfil", number))  sort="id_nivel_classificacao A cd_classificacao_produto A cd_classe A " )
