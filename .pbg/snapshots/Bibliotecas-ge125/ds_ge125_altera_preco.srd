table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_valor dbname="vl_valor" )
 retrieve="select i.cd_filial,
		case when min(n.dh_movimentacao_caixa) >= '20190601' then sum(round(i.vl_preco_unitario*(1-(COALESCE(ind.pc_desconto_maximo, ind.pc_desconto_tabela,0)/100)),2)*i.qt_vendida) - sum(i.vl_preco_praticado*i.qt_vendida)
		else sum(i.vl_preco_unitario) - sum(i.vl_preco_praticado) end as vl_valor
  from nf_venda n (index idx_data_filial)
inner join item_nf_venda i (index pk_item_nf_venda)
	on i.cd_filial 		= n.cd_filial 		and
		i.nr_nf 			= n.nr_nf 		and
		i.de_especie 	= n.de_especie	and
		i.de_serie 		= n.de_serie  
left outer join item_nf_venda_desconto ind  (index pk_item_nf_venda_desconto)
 on ind.cd_filial = i.cd_filial
  and ind.nr_nf = i.nr_nf
  and ind.de_especie = i.de_especie
  and ind.de_serie = i.de_serie
  and ind.cd_produto = i.cd_produto
  and coalesce(ind.nr_sequencial,1) = i.nr_sequencial
inner join filial fi (index pk_filial)
	on fi.cd_filial = n.cd_filial
 where n.dh_movimentacao_caixa between :inicio and :fim  and
		n.dh_cancelamento is null and
		n.nr_nf_anexa is null and
		//n.nr_matric_alteracao_preco is not null and  //prestes n$$HEX1$$e300$$ENDHEX$$o grava mais a matr$$HEX1$$ed00$$ENDHEX$$cula
		//i.cd_natureza_operacao > 0 and
		(i.id_alteracao_preco = 'S' or (n.id_sistema_novo='S' and ind.id_tipo_desconto='PVE')) and
		i.vl_preco_unitario	<> i.vl_preco_praticado
group by i.cd_filial
" arguments=(("inicio", datetime),("fim", datetime))  sort="cd_filial A " )
