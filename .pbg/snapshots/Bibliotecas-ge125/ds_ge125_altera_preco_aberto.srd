table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_desconto dbname="id_tipo_desconto" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_desconto dbname="vl_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto1 dbname="vl_desconto1" )
 retrieve="select n.cd_filial,  
		 infd.id_tipo_desconto, 
		case when min(n.dh_movimentacao_caixa) >= '20190601' then sum(round(i.vl_preco_unitario*(1-(COALESCE(infd.pc_desconto_maximo, infd.pc_desconto_tabela,0)/100)),2)*i.qt_vendida) - sum(i.vl_preco_praticado*i.qt_vendida)
           else
		  case infd.id_tipo_desconto when 'NEG' then sum(round(i.vl_preco_unitario*(1-(i.pc_desconto_tabela/100)),2)*i.qt_vendida) - sum(i.vl_preco_praticado*i.qt_vendida)
		   else sum(i.vl_preco_unitario) - sum(i.vl_preco_praticado) end end as vl_desconto,
		case when min(n.dh_movimentacao_caixa) >= '20190601' then 0.00
          else sum(i.vl_preco_unitario) - sum(i.vl_preco_praticado) end as vl_desconto1
from nf_venda n (index idx_data_filial)
inner join  item_nf_venda i (index pk_item_nf_venda)
 on i.cd_filial		= n.cd_filial 
  and i.nr_nf		= n.nr_nf 
  and i.de_especie	= n.de_especie 
  and i.de_serie	= n.de_serie 
inner join item_nf_venda_desconto infd  (index pk_item_nf_venda_desconto)
 on infd.cd_filial 		= i.cd_filial
  and infd.nr_nf 		= i.nr_nf
  and infd.de_especie 	= i.de_especie
  and infd.de_serie		= i.de_serie
  and infd.cd_produto 	= i.cd_produto
  and coalesce(infd.nr_sequencial,1) = i.nr_sequencial
inner join filial fi (index pk_filial)
 on fi.cd_filial = n.cd_filial
where n.dh_movimentacao_caixa  between :inicio and :fim 
  and n.dh_cancelamento is null
  and n.nr_nf_anexa is null
  and (i.id_alteracao_preco = 'S' or (n.id_sistema_novo='S' and infd.id_tipo_desconto='PVE'))
  and i.vl_preco_unitario	<> i.vl_preco_praticado
group by n.cd_filial, infd.id_tipo_desconto" arguments=(("inicio", datetime),("fim", datetime))  sort="cd_filial A id_tipo_desconto A " )
