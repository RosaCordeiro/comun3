table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=qt_total dbname="qt_total" )
 retrieve="SELECT 
	cd_filial, 
	SUM(qt_total_pdv_legado) + SUM(qt_total_pdv_novo) AS qt_total
FROM (
    SELECT l.cd_filial,
           COUNT(l.nr_sequencial) AS qt_total_pdv_legado,
           0 AS qt_total_pdv_novo
    FROM log_cancelamento_fiscal l (INDEX idx_data_caixa_filial)
    	INNER JOIN filial fi (INDEX pk_filial) 
    		ON fi.cd_filial = l.cd_filial
    WHERE dh_movimentacao_caixa BETWEEN :inicio AND :fim
    GROUP BY l.cd_filial
--
    UNION ALL
--
    SELECT nv.cd_filial,
           0 AS qt_total_pdv_legado,
           COUNT(inv.nr_sequencial) AS qt_total_pdv_novo
    FROM dbo.nf_venda nv (INDEX idx_data_filial)
    	INNER JOIN dbo.item_nf_venda inv 
    		ON nv.cd_filial = inv.cd_filial 
    		AND nv.nr_nf = inv.nr_nf 
    		AND nv.de_especie = inv.de_especie 
    		AND nv.de_serie = inv.de_serie
    	INNER JOIN filial fi (INDEX pk_filial) 
    		ON fi.cd_filial = nv.cd_filial
    WHERE nv.id_sistema_novo = 'S' 
    	AND nv.dh_cancelamento IS NOT NULL 
    	AND nv.dh_movimentacao_caixa BETWEEN :inicio AND :fim
    GROUP BY nv.cd_filial
) AS total
GROUP BY cd_filial" arguments=(("inicio", datetime),("fim", datetime))  sort="cd_filial A " )
