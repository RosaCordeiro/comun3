detail(height=108 color="536870912" transparency="0" gradient.color="8421504" gradient.transparency="0" gradient.angle="0" brushmode="0" gradient.repetition.mode="0" gradient.repetition.count="0" gradient.repetition.length="100" gradient.focus="0" gradient.scale="100" gradient.spread="100" )
table(column=(type=char(3) updatewhereclause=yes name=tipo dbname="tipo" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_devolucao dbname="vl_devolucao" )
 retrieve="select 	'VDL' as tipo,
			inf.cd_filial as cd_filial,
     	 	sum(Round(inf.qt_devolvida * (inf.vl_preco_unitario * (1 - (inf.pc_desconto /100))),2)) as vl_devolucao
from nf_devolucao_venda nf
inner join item_nf_devolucao_venda inf (index pk_item_nf_devolucao_venda)
		on inf.cd_filial = nf.cd_filial and
			inf.nr_nf = nf.nr_nf and
			inf.de_especie = nf.de_especie and
			inf.de_serie = nf.de_serie
inner join venda_pbm k (index pk_venda_pbm)
	on k.cd_filial = nf.cd_filial_venda and
		k.nr_nf = nf.nr_nf_venda and
		k.de_especie = nf.de_especie_venda and
		k.de_serie = nf.de_serie_venda 
inner join nf_venda v (index pk_nf_venda)
	on v.cd_filial = k.cd_filial and
		v.nr_nf = k.nr_nf and
		v.de_especie = k.de_especie and
		v.de_serie = k.de_serie 
inner join filial fi (index pk_filial)
	on fi.cd_filial = nf.cd_filial
inner join venda_pbm_produto x (index PK_VENDA_PBM_PRODUTO)
	on x.cd_filial = k.cd_filial and
		x.nr_nf = k.nr_nf and
		x.de_especie = k.de_especie and
		x.de_serie = k.de_serie and
		x.cd_produto = inf.cd_produto and
		x.nr_sequencial_pbm = k.nr_sequencial_pbm
where inf.cd_produto <> 684431	and 
		nf.dh_cancelamento is null and
		nf.dh_movimentacao_caixa between :dt_inicio and :dt_termino and
		v.nr_nf_anexa is null and
		k.cd_convenio in (52575,53724,53725) and
		(k.nr_comprovante_venda <> 'AVFARPOP' or k.nr_comprovante_venda is null)
group by inf.cd_filial

union all

  select 	'FPB',
	         inf.cd_filial,
     	 	sum(Round(inf.qt_devolvida * (inf.vl_preco_unitario * (1 - (inf.pc_desconto /100))),2)) as vl_devolucao
    from nf_devolucao_venda nf
inner join item_nf_devolucao_venda inf (index pk_item_nf_devolucao_venda)
		on inf.cd_filial = nf.cd_filial and
			inf.nr_nf = nf.nr_nf and
			inf.de_especie = nf.de_especie and
			inf.de_serie = nf.de_serie
inner join venda_pbm k (index pk_venda_pbm)
	on k.cd_filial = nf.cd_filial_venda and
		k.nr_nf = nf.nr_nf_venda and
		k.de_especie = nf.de_especie_venda and
		k.de_serie = nf.de_serie_venda 
inner join nf_venda v (index pk_nf_venda)
	on v.cd_filial = k.cd_filial and
		v.nr_nf = k.nr_nf and
		v.de_especie = k.de_especie and
		v.de_serie = k.de_serie  
inner join filial fi (index pk_filial)
	on fi.cd_filial = nf.cd_filial
inner join venda_pbm_produto x (index PK_VENDA_PBM_PRODUTO)
	on x.cd_filial = k.cd_filial and
		x.nr_nf = k.nr_nf and
		x.de_especie = k.de_especie and
		x.de_serie = k.de_serie and
		x.cd_produto = inf.cd_produto and
		x.nr_sequencial_pbm = k.nr_sequencial_pbm
where  nf.dh_movimentacao_caixa between :dt_inicio and :dt_termino and
         k.cd_convenio = 52575 and
         k.nr_comprovante_venda = 'AVFARPOP' and
         inf.cd_produto <> 684431 and 
		nf.dh_cancelamento is null and
         v.nr_nf_anexa is null and
         v.nr_pedido_drogaexpress is null
group by inf.cd_filial

union all

  select 	'TRN'  as tipo,
			inf.cd_filial,
     	 	sum(Round(inf.qt_devolvida * (inf.vl_preco_unitario * (1 - (inf.pc_desconto /100))),2)) as vl_devolucao
    from nf_devolucao_venda nf
inner join item_nf_devolucao_venda inf (index pk_item_nf_devolucao_venda)
		on inf.cd_filial = nf.cd_filial and
			inf.nr_nf = nf.nr_nf and
			inf.de_especie = nf.de_especie and
			inf.de_serie = nf.de_serie
inner join venda_pbm k (index pk_venda_pbm)
	on k.cd_filial = nf.cd_filial_venda and
		k.nr_nf = nf.nr_nf_venda and
		k.de_especie = nf.de_especie_venda and
		k.de_serie = nf.de_serie_venda 
inner join nf_venda v (index pk_nf_venda)
	on v.cd_filial = k.cd_filial and
		v.nr_nf = k.nr_nf and
		v.de_especie = k.de_especie and
		v.de_serie = k.de_serie  
inner join filial fi (index pk_filial)
	on fi.cd_filial = nf.cd_filial
inner join venda_pbm_produto x (index PK_VENDA_PBM_PRODUTO)
	on x.cd_filial = k.cd_filial and
		x.nr_nf = k.nr_nf and
		x.de_especie = k.de_especie and
		x.de_serie = k.de_serie and
		x.cd_produto = inf.cd_produto and
		x.nr_sequencial_pbm = k.nr_sequencial_pbm
   where nf.dh_movimentacao_caixa between :dt_inicio and :dt_termino and
			k.cd_convenio = 52568 AND //TRN
			coalesce(k.cd_convenio_pbm,'') <> 'PharmaSystem' and
         	nf.dh_cancelamento is null and
         	v.nr_nf_anexa is null and
			inf.cd_produto <> 684431
group by inf.cd_filial

union all

  select 	'PHS'  as tipo,
			inf.cd_filial,
     	 	sum(Round(inf.qt_devolvida * (inf.vl_preco_unitario * (1 - (inf.pc_desconto /100))),2)) as vl_devolucao
    from nf_devolucao_venda nf
inner join item_nf_devolucao_venda inf (index pk_item_nf_devolucao_venda)
		on inf.cd_filial = nf.cd_filial and
			inf.nr_nf = nf.nr_nf and
			inf.de_especie = nf.de_especie and
			inf.de_serie = nf.de_serie
inner join venda_pbm k (index pk_venda_pbm)
	on k.cd_filial = nf.cd_filial_venda and
		k.nr_nf = nf.nr_nf_venda and
		k.de_especie = nf.de_especie_venda and
		k.de_serie = nf.de_serie_venda 
inner join nf_venda v (index pk_nf_venda)
	on		v.cd_filial			= k.cd_filial	
	and	v.nr_nf			= k.nr_nf
	and 	v.de_especie	= k.de_especie
	and 	v.de_serie		= k.de_serie 
inner join filial fi (index pk_filial)
	on fi.cd_filial = nf.cd_filial
inner join venda_pbm_produto x (index PK_VENDA_PBM_PRODUTO)
	on x.cd_filial = k.cd_filial and
		x.nr_nf = k.nr_nf and
		x.de_especie = k.de_especie and
		x.de_serie = k.de_serie and
		x.cd_produto = inf.cd_produto and
		x.nr_sequencial_pbm = k.nr_sequencial_pbm
   where nf.dh_movimentacao_caixa between :dt_inicio and :dt_termino and
			k.cd_convenio in (53545,52568) and
         	((k.cd_convenio = 52568 and k.cd_convenio_pbm='PharmaSystem') or (k.cd_convenio = 53545)) and
			nf.dh_cancelamento is null and
         	v.nr_nf_anexa is null and
			inf.cd_produto <> 684431
group by inf.cd_filial

union all

  select 	'FUN',
         	inf.cd_filial,
     	 	sum(Round(inf.qt_devolvida * (inf.vl_preco_unitario * (1 - (inf.pc_desconto /100))),2)) as vl_devolucao
    from nf_devolucao_venda nf
inner join item_nf_devolucao_venda inf (index pk_item_nf_devolucao_venda)
		on inf.cd_filial = nf.cd_filial and
			inf.nr_nf = nf.nr_nf and
			inf.de_especie = nf.de_especie and
			inf.de_serie = nf.de_serie
inner join venda_pbm k (index pk_venda_pbm)
	on k.cd_filial = nf.cd_filial_venda and
      k.nr_nf = nf.nr_nf_venda and
      k.de_especie = nf.de_especie_venda and
      k.de_serie = nf.de_serie_venda 
inner join nf_venda v (index pk_nf_venda)
	on		v.cd_filial			= k.cd_filial	
	and	v.nr_nf			= k.nr_nf
	and 	v.de_especie	= k.de_especie
	and 	v.de_serie		= k.de_serie 
inner join filial fi (index pk_filial)
	on fi.cd_filial = nf.cd_filial
inner join venda_pbm_produto x (index PK_VENDA_PBM_PRODUTO)
	on x.cd_filial = k.cd_filial and
		x.nr_nf = k.nr_nf and
		x.de_especie = k.de_especie and
		x.de_serie = k.de_serie and
		x.cd_produto = inf.cd_produto and
		x.nr_sequencial_pbm = k.nr_sequencial_pbm
where 	nf.dh_movimentacao_caixa between :dt_inicio and :dt_termino and 
			k.cd_convenio = 52349 and
         	nf.dh_cancelamento is null and
         	v.nr_nf_anexa is null and
         	inf.cd_produto <> 684431
group by inf.cd_filial

union all

  select 	'EPH',
        		inf.cd_filial,
     	 	sum(Round(inf.qt_devolvida * (inf.vl_preco_unitario * (1 - (inf.pc_desconto /100))),2)) as vl_devolucao
    from nf_devolucao_venda nf
inner join item_nf_devolucao_venda inf (index pk_item_nf_devolucao_venda)
		on inf.cd_filial = nf.cd_filial and
			inf.nr_nf = nf.nr_nf and
			inf.de_especie = nf.de_especie and
			inf.de_serie = nf.de_serie
inner join venda_pbm k (index pk_venda_pbm)
	on k.cd_filial = nf.cd_filial_venda and
      k.nr_nf = nf.nr_nf_venda and
      k.de_especie = nf.de_especie_venda and
      k.de_serie = nf.de_serie_venda 
inner join nf_venda v (index pk_nf_venda)
	on		v.cd_filial			= k.cd_filial	
	and	v.nr_nf			= k.nr_nf
	and 	v.de_especie	= k.de_especie
	and 	v.de_serie		= k.de_serie 
inner join filial fi (index pk_filial)
	on fi.cd_filial = nf.cd_filial
inner join venda_pbm_produto x (index PK_VENDA_PBM_PRODUTO)
	on x.cd_filial = k.cd_filial and
		x.nr_nf = k.nr_nf and
		x.de_especie = k.de_especie and
		x.de_serie = k.de_serie and
		x.cd_produto = inf.cd_produto and
		x.nr_sequencial_pbm = k.nr_sequencial_pbm
   where nf.dh_movimentacao_caixa between :dt_inicio and :dt_termino and
			k.cd_convenio = 52718  and
			v.nr_nf_anexa is null and 
			nf.dh_cancelamento is null and	
			inf.cd_produto <> 684431
group by inf.cd_filial" arguments=(("dt_inicio", datetime),("dt_termino", datetime))  sort="tipo A cd_filial A " )
