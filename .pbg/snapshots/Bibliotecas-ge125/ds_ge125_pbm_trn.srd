table(column=(type=char(3) updatewhereclause=yes name=tipo dbname="tipo" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda dbname="vl_venda" )
 retrieve=" select 	'TRN'  as tipo,
			k.cd_filial,
         	sum(x.qt_vendida * inf.vl_preco_praticado) as vl_venda
    from venda_pbm k (index idx_data_convenio)
inner join nf_venda v (index pk_nf_venda)
	on v.cd_filial = k.cd_filial and
		v.nr_nf = k.nr_nf and
		v.de_especie = k.de_especie and
		v.de_serie = k.de_serie 
inner join item_nf_venda inf (index pk_item_nf_venda)
	on inf.cd_filial = v.cd_filial and
		inf.nr_nf = v.nr_nf and
		inf.de_especie = v.de_especie and
		inf.de_serie = v.de_serie
inner join venda_pbm_produto x (index PK_VENDA_PBM_PRODUTO)
	on x.cd_filial = inf.cd_filial and
		x.nr_nf = inf.nr_nf and
		x.de_especie = inf.de_especie and
		x.de_serie = inf.de_serie and
		x.cd_produto = inf.cd_produto and
		x.nr_sequencial = inf.nr_sequencial and
		x.nr_sequencial_pbm = k.nr_sequencial_pbm
inner join filial fi (index pk_filial)
	on fi.cd_filial = k.cd_filial
   where k.dh_venda between :dt_inicio and :dt_termino and
			k.cd_convenio = 52568 AND //TRN
			coalesce(k.cd_convenio_pbm, '') <> 'PharmaSystem' and
         	v.dh_cancelamento is null and
         	v.nr_nf_anexa is null and
			inf.qt_vendida > 0	and 
			inf.cd_produto <> 684431
group by k.cd_filial" arguments=(("dt_inicio", datetime),("dt_termino", datetime)) )
