table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_valor dbname="vl_valor" )
 retrieve="select n.cd_filial_destino as cd_filial,
       sum(i.qt_transferida * i.vl_custo_unitario) as vl_valor
  from nf_transferencia n (index idx_data_filial_origem)
inner join item_nf_transferencia i (index pk_item_nf_transferencia)
	on i.cd_filial_origem = n.cd_filial_origem and
       i.nr_nf = n.nr_nf and
       i.de_especie = n.de_especie and
       i.de_serie = n.de_serie 
inner join produto_geral p (index pk_produto_geral)
	on p.cd_produto = i.cd_produto
inner join filial fi (index pk_filial)
	on fi.cd_filial = n.cd_filial_destino
 where n.dh_movimentacao_caixa between :inicio and :fim and
		i.cd_natureza_operacao > 0 and
		substring(p.cd_subcategoria, 1, 1) < '4' and
		n.cd_filial_origem <> 534 and
		n.cd_filial_destino not in (1, 534) and
		coalesce(n.id_almoxarifado,'N')='N' and
		n.dh_cancelamento is null
  group by n.cd_filial_destino" arguments=(("inicio", datetime),("fim", datetime)) )
