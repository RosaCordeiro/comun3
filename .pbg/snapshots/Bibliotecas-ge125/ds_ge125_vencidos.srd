table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_valor dbname="vl_valor" )
 retrieve="select n.cd_filial_origem as cd_filial,
		sum(i.qt_transferida * i.vl_custo_unitario) as vl_valor
  from nf_transferencia n (index idx_data_filial_origem)
inner join item_nf_transferencia i (index pk_item_nf_transferencia)
	on i.cd_filial_origem	= n.cd_filial_origem and
		i.nr_nf					= n.nr_nf and
		i.de_especie			= n.de_especie and
		i.de_serie				= n.de_serie
inner join produto_geral p (index pk_produto_geral)
   on p.cd_produto	= i.cd_produto
inner join filial fi (index pk_filial)
   on fi.cd_filial = n.cd_filial_origem
inner join cidade c (index pk_cidade)
   on c.cd_cidade = fi.cd_cidade
 where	n.dh_movimentacao_caixa between :inicio and :fim and
			p.cd_grupo_produto <> 7 and 
			n.cd_filial_destino  in (1,534) and
			n.id_produto_vencido = 'S' and
	  		//2014.12.02 - Comentado para ficar igual CR104 (Email Vinicius Blum)
			//c.cd_unidade_federacao = 'SC' and
			n.dh_cancelamento is null
group by n.cd_filial_origem

union all

select asai.cd_filial_ajuste as cd_filial,
		sum(case when asai.id_entrada_saida = 'S' then (asai.qt_ajuste * asai.vl_custo_unitario) else (0 - (asai.qt_ajuste * asai.vl_custo_unitario)) end) as vl_valor
  from ajuste_estoque asai
inner join filial fi (index pk_filial)
   on fi.cd_filial = asai.cd_filial_ajuste
inner join cidade c (index pk_cidade)
   on c.cd_cidade = fi.cd_cidade
 where asai.cd_motivo_ajuste = 9 and
	   //2014.12.02 - Comentado para ficar igual GE037 (Email Vinicius Blum)
       //asai.id_entrada_saida = 'S' and
       //c.cd_unidade_federacao <> 'SC' and
       asai.dh_movimentacao_caixa between :inicio and :fim 
 group by asai.cd_filial_ajuste" arguments=(("inicio", datetime),("fim", datetime)) )
