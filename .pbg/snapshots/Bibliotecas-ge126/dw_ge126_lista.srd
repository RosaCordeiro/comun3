table(column=(type=char(14) updatewhereclause=yes name=nr_cpf dbname="cliente.nr_cpf" dbalias=".nr_cpf" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="cliente.nm_cliente" dbalias=".nm_cliente" )
 column=(type=char(14) updatewhereclause=yes name=tipo dbname="tipo" )
 retrieve="select distinct nr_cpf_cgc as nr_cpf
		 ,nm_cliente as nm_cliente
          ,'CLIENTE' as tipo
from cliente
where id_fisica_juridica = 'F'
  and coalesce(nr_cpf_cgc, 'NULO') <> 'NULO' 
union all
select distinct nr_cpf
		 ,nm_conveniado
          ,'CONVENIADO'
from conveniado
where nr_cpf is not null
	 and rtrim(nr_cpf) <> ''
union all
select distinct nr_cpf
		 ,nm_cliente
          ,'CLIENTE_CHEQUE'
from cliente_cheque
where coalesce(nr_cpf, 'NULO') <> 'NULO'
  and coalesce(nr_cpf_dependente, 'NULO') <> 'NULO'
union all
select distinct nr_cpf
		 ,nm_cliente
         ,'CLIENTE_CHEQUE'
from cliente_cheque
where coalesce(nr_cpf, 'NULO') <> 'NULO'
  and coalesce(nr_cpf_dependente, 'NULO') = 'NULO'
"  sort="nm_cliente A " )
