table(column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="filial.cd_filial_origem" dbalias="f.cd_filial_origem" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="g.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="g.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="g.de_apresentacao_venda" )
 column=(type=char(10) updatewhereclause=yes name=nr_licenca_vig_sanitaria dbname="filial.nr_licenca_vig_sanitaria" dbalias="fp.nr_licenca_vig_sanitaria" )
 column=(type=char(10) updatewhereclause=yes name=cd_dcb dbname="dcb_produto.cd_dcb" dbalias="d.cd_dcb" )
 column=(type=char(40) updatewhereclause=yes name=de_dcb dbname="dcb_produto.de_dcb" dbalias="d.de_dcb" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="filial.nr_cgc" dbalias="fp.nr_cgc" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" dbalias="fp.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="fp.nm_fantasia" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc_origem dbname="nr_cgc_origem" )
 column=(type=char(255) updatewhereclause=yes name=de_registro_ms dbname="de_registro_ms" )
 column=(type=char(8190) updatewhereclause=no name=de_origem_destino dbname="vw_movimento_estoque_produto_controlado.de_origem_destino" dbalias="m.de_origem_destino" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="vw_movimento_estoque_produto_controlado.nr_nf" dbalias="m.nr_nf" )
 column=(type=decimal(0) updatewhereclause=yes name=qt_lote dbname="qt_lote" )
 column=(type=char(8190) updatewhereclause=no name=cd_uf dbname="cd_uf" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" dbalias="g.cd_grupo_psico" )
 column=(type=datetime updatewhereclause=yes name=dh_aprovacao_farmaceutico dbname="vw_movimento_estoque_produto_controlado.dh_aprovacao_farmaceutico" dbalias="m.dh_aprovacao_farmaceutico" )
 retrieve="SELECT	f.cd_filial												AS cd_filial_origem,
			g.cd_produto										AS cd_produto,
			g.de_produto 										AS de_produto,
			g.de_apresentacao_venda						AS de_apresentacao_venda,
			fp.nr_licenca_vig_sanitaria						AS nr_licenca_vig_sanitaria,
			d.cd_dcb												AS cd_dcb,
			d.de_dcb												AS de_dcb,
			fp.nr_cgc												AS nr_cgc,
			fp.cd_filial											AS cd_filial,
			fp.nm_fantasia										AS nm_fantasia,
			(CASE m.id_tipo_movimento
				WHEN 'T' THEN f.nr_cgc
				ELSE 	fo.nr_cgc
			END ) 												AS nr_cgc_origem,
			uf_mascara_campo('registro_ms', g.de_registro_ms) AS de_registro_ms,
			m.de_origem_destino								AS de_origem_destino,
			m.nr_nf												AS nr_nf,
			sum(m.qt_lote)										AS qt_lote,
			''														AS cd_uf,
			g.cd_grupo_psico									AS cd_grupo_psico,
			m.dh_aprovacao_farmaceutico					AS dh_aprovacao_farmaceutico
  FROM vw_movimento_estoque_produto_controlado AS m
	INNER JOIN produto_geral AS g
		ON g.cd_produto = m.cd_produto
	INNER JOIN filial AS f
		ON f.cd_filial = m.cd_filial
	LEFT OUTER JOIN dcb_produto AS d
		ON d.cd_dcb = g.cd_dcb
	LEFT OUTER JOIN fornecedor AS fo
		ON fo.cd_fornecedor = m.cd_fornecedor
	INNER JOIN filial AS fp
		ON fp.cd_filial = uf_filial_parametro()
WHERE m.dh_aprovacao_farmaceutico >= :inicio
	AND m.dh_aprovacao_farmaceutico <= :termino
	AND g.cd_grupo_psico IS NOT NULL
	AND g.cd_grupo_psico IN (:portaria)
	AND (m.id_tipo_movimento = 'T' OR m.id_tipo_movimento = 'C')
	AND m.id_entrada_saida = 'E'
GROUP BY	f.cd_filial,
				g.cd_produto,
				g.de_produto,
				g.de_apresentacao_venda,
				f.nr_licenca_vig_sanitaria,
				d.cd_dcb,
				d.de_dcb,
				fp.nr_cgc,
				fp.cd_filial,
				fp.nm_fantasia,
				nr_cgc_origem,
				de_registro_ms,
				de_origem_destino,
				m.nr_nf,
				m.qt_lote,
				cd_uf,
				g.cd_grupo_psico,
				m.dh_aprovacao_farmaceutico" arguments=(("filial", number),("inicio", date),("termino", date),("farmaceuticos", string),("portaria", stringlist),("tipo_anual_trimestral", string),("tipo", string))  sort="compute_5 A " )
