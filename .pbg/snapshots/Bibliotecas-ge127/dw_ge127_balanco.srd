table(column=(type=long updatewhereclause=yes name=qt_est_anterior dbname="qt_est_anterior" )
 column=(type=decimal(0) updatewhereclause=yes name=qt_perda dbname="qt_perda" )
 column=(type=decimal(0) updatewhereclause=yes name=qt_entrada dbname="qt_entrada" )
 column=(type=decimal(0) updatewhereclause=yes name=qt_saida dbname="qt_saida" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="g.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="g.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="g.de_apresentacao_venda" )
 column=(type=char(10) updatewhereclause=yes name=cd_dcb dbname="dcb_produto.cd_dcb" dbalias="d.cd_dcb" )
 column=(type=char(255) updatewhereclause=yes name=de_dcb dbname="de_dcb" )
 column=(type=char(255) updatewhereclause=yes name=de_registro_ms dbname="de_registro_ms" )
 column=(type=char(255) updatewhereclause=yes name=de_fabricante dbname="de_fabricante" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" dbalias="g.cd_grupo_psico" )
 column=(type=char(255) updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(255) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=char(255) updatewhereclause=yes name=nr_cgc dbname="nr_cgc" )
 column=(type=char(255) updatewhereclause=yes name=nr_licenca_vig_sanitaria dbname="nr_licenca_vig_sanitaria" )
 column=(type=char(255) updatewhereclause=yes name=cd_uf dbname="cd_uf" )
 retrieve="SELECT	uf_saldo_produto_aprovado(g.cd_produto, :inicio) AS qt_est_anterior,
			SUM( (CASE m.id_tipo_movimento || m.id_entrada_saida
                             WHEN 'AS' THEN m.qt_lote
                             ELSE 0
              END ) ) AS qt_perda,
              SUM( (CASE m.id_tipo_movimento || m.id_entrada_saida
                             WHEN 'CE' THEN m.qt_lote
                             WHEN 'TE' THEN m.qt_lote
                             ELSE 0
              END ) ) AS qt_entrada,
              SUM( (CASE m.id_tipo_movimento || m.id_entrada_saida
                             WHEN 'TS' THEN m.qt_lote
                             WHEN 'VS' THEN m.qt_lote
                             ELSE 0
              END ) ) AS qt_saida,
			g.cd_produto										AS cd_produto,
			g.de_produto 										AS de_produto,
			g.de_apresentacao_venda						AS de_apresentacao_venda,
			d.cd_dcb												AS cd_dcb,
			COALESCE(d.de_dcb,'')												AS de_dcb,
			uf_mascara_campo('registro_ms', g.de_registro_ms) AS de_registro_ms,
			COALESCE(fab.nm_razao_social,'')								AS de_fabricante,
			g.cd_grupo_psico									AS cd_grupo_psico,
			''														AS cd_filial,
			''														AS nm_fantasia,
			''														AS nr_cgc,
			''														AS nr_licenca_vig_sanitaria,
			''														AS	cd_uf
  FROM vw_movimento_estoque_produto_controlado AS m
	INNER JOIN produto_geral AS g
		ON g.cd_produto = m.cd_produto
	LEFT OUTER JOIN dcb_produto AS d
		ON d.cd_dcb = g.cd_dcb
	LEFT OUTER JOIN fabricante AS fab
		ON fab.cd_fabricante = g.cd_fabricante
WHERE m.dh_aprovacao_farmaceutico >= :inicio
	AND m.dh_aprovacao_farmaceutico <= :termino
	AND g.cd_grupo_psico IS NOT NULL
	AND g.cd_grupo_psico IN (:portaria)
	AND m.id_tipo_movimento IS NOT NULL
GROUP BY	qt_est_anterior,
				g.cd_produto,
				g.de_produto,
				g.de_apresentacao_venda,
				d.cd_dcb,
				d.de_dcb,
				de_registro_ms,
				fab.nm_razao_social,
				g.cd_grupo_psico" arguments=(("filial", number),("inicio", date),("termino", date),("farmaceuticos", string),("portaria", stringlist),("tipo_anual_trimestral", string),("tipo", string)) )
