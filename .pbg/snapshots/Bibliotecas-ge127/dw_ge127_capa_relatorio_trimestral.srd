table(column=(type=char(255) updatewhereclause=yes name=lista_farmaceuticos dbname="filial.lista_farmaceuticos" )
 column=(type=long updatewhereclause=yes name=filial_cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_razao_social dbname="filial.nm_razao_social" )
 column=(type=char(14) updatewhereclause=yes name=filial_nr_cgc dbname="filial.nr_cgc" )
 column=(type=char(15) updatewhereclause=yes name=filial_nr_inscricao_estadual dbname="filial.nr_inscricao_estadual" )
 column=(type=char(40) updatewhereclause=yes name=cidade_nm_cidade dbname="cidade.nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=cidade_cd_unidade_federacao dbname="cidade.cd_unidade_federacao" )
 column=(type=char(40) updatewhereclause=yes name=filial_de_endereco dbname="filial.de_endereco" )
 column=(type=char(20) updatewhereclause=yes name=filial_de_bairro dbname="filial.de_bairro" )
 column=(type=char(8) updatewhereclause=yes name=filial_nr_cep dbname="filial.nr_cep" )
 column=(type=char(3) updatewhereclause=yes name=filial_nr_ddd_telefone dbname="filial.nr_ddd_telefone" )
 column=(type=char(8) updatewhereclause=yes name=filial_nr_telefone dbname="filial.nr_telefone" )
 column=(type=char(40) updatewhereclause=yes name=unidade_federacao_nm_unidade_federacao dbname="unidade_federacao.nm_unidade_federacao" )
 column=(type=char(10) updatewhereclause=yes name=nr_licenca_vig_sanitaria dbname="filial.nr_licenca_vig_sanitaria" )
 column=(type=char(20) updatewhereclause=yes name=crf dbname="usuario.crf" )
 column=(type=char(40) updatewhereclause=yes name=farmaceutico dbname="usuario.farmaceutico" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf_crf dbname="usuario.cd_uf_crf" )
 retrieve="SELECT	:farmaceuticos 							AS lista_farmaceuticos,
			f.cd_filial									AS cd_filial,
			f.nm_fantasia							AS nm_fantasia,
			f.nm_razao_social						AS nm_razao_social,
			f.nr_cgc									AS nr_cgc,
			f.nr_inscricao_estadual				AS nr_inscricao_estadual,
			c.nm_cidade							AS nm_cidade,
			c.cd_unidade_federacao				AS cd_unidade_federacao,
			f.de_endereco							AS de_endereco,
			f.de_bairro								AS de_bairro,
			f.nr_cep									AS nr_cep,
			f.nr_ddd_telefone						AS nr_ddd_telefone,
			f.nr_telefone							AS nr_telefone,
			un.nm_unidade_federacao			AS nm_unidade_federacao,
			f.nr_licenca_vig_sanitaria			AS nr_licenca_vig_sanitaria,
			u.nr_registro_crf						AS crf,
			u.nm_usuario							AS farmaceutico,
			u.cd_uf_crf								AS cd_uf_crf
FROM filial AS f
	INNER JOIN cidade AS c
		ON c.cd_cidade	= f.cd_cidade
	INNER JOIN unidade_federacao AS un
		ON un.cd_unidade_federacao = c.cd_unidade_federacao
	INNER JOIN parametro AS p
		ON p.id_parametro = '1'
	INNER JOIN usuario AS u
		ON u.nm_usuario = p.nm_responsavel_psico
	   AND u.nr_registro_crf IS NOT NULL
WHERE f.cd_filial = :filial" retrieve.asneeded=yes arguments=(("filial", number),("inicio", date),("termino", date),("farmaceuticos", string),("lista", stringlist),("tipo_anual_trimestral", string),("tipo_relatorio", string)) )
