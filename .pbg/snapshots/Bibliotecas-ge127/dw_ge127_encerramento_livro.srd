table(column=(type=long updatewhereclause=yes name=filial_cd_filial dbname="filial.cd_filial" dbalias="f.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_razao_social dbname="filial.nm_razao_social" dbalias="f.nm_razao_social" )
 column=(type=char(14) updatewhereclause=yes name=filial_nr_cgc dbname="filial.nr_cgc" dbalias="f.nr_cgc" )
 column=(type=char(15) updatewhereclause=yes name=filial_nr_inscricao_estadual dbname="filial.nr_inscricao_estadual" dbalias="f.nr_inscricao_estadual" )
 column=(type=char(40) updatewhereclause=yes name=cidade_nm_cidade dbname="cidade.nm_cidade" dbalias="c.nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=cidade_cd_unidade_federacao dbname="cidade.cd_unidade_federacao" dbalias="c.cd_unidade_federacao" )
 column=(type=char(40) updatewhereclause=yes name=filial_de_endereco dbname="filial.de_endereco" dbalias="f.de_endereco" )
 column=(type=char(20) updatewhereclause=yes name=filial_de_bairro dbname="filial.de_bairro" dbalias="f.de_bairro" )
 column=(type=char(8) updatewhereclause=yes name=filial_nr_cep dbname="filial.nr_cep" dbalias="f.nr_cep" )
 column=(type=char(3) updatewhereclause=yes name=filial_nr_ddd_telefone dbname="filial.nr_ddd_telefone" dbalias="f.nr_ddd_telefone" )
 column=(type=char(8) updatewhereclause=yes name=filial_nr_telefone dbname="filial.nr_telefone" dbalias="f.nr_telefone" )
 column=(type=char(40) updatewhereclause=yes name=unidade_federacao_nm_unidade_federacao dbname="unidade_federacao.nm_unidade_federacao" dbalias="u.nm_unidade_federacao" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="dh_termino" )
 retrieve="SELECT	f.cd_filial,
			f.nm_fantasia,
			f.nm_razao_social,
			f.nr_cgc,
			f.nr_inscricao_estadual,
			c.nm_cidade,
			c.cd_unidade_federacao,
			f.de_endereco,
			f.de_bairro,
			f.nr_cep,
			f.nr_ddd_telefone,
			f.nr_telefone,
			u.nm_unidade_federacao,
			getdate() dh_inicio,
			getdate() dh_termino
FROM filial AS f
	INNER JOIN cidade AS c
		ON c.cd_cidade	= f.cd_cidade 
	   AND f.cd_filial	= :filial
	INNER JOIN unidade_federacao AS u
		ON u.cd_unidade_federacao = c.cd_unidade_federacao" retrieve.asneeded=yes arguments=(("filial", number),("paginas", number)) )
