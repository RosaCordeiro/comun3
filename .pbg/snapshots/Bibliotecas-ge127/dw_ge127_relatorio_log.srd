table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="nm_razao_social" )
 column=(type=char(10) updatewhereclause=yes name=nr_licenca_vig_sanitaria dbname="nr_licenca_vig_sanitaria" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf dbname="cd_uf" )
 column=(type=char(8190) updatewhereclause=no name=nm_tabela dbname="nm_tabela" )
 column=(type=char(8190) updatewhereclause=no name=nm_aplicacao dbname="nm_aplicacao" )
 column=(type=char(8190) updatewhereclause=no name=nr_matricula dbname="nr_matricula" )
 column=(type=datetime updatewhereclause=yes name=dh_acao dbname="dh_acao" )
 column=(type=char(8190) updatewhereclause=no name=id_acao dbname="id_acao" values="A	U/R	D/" )
 column=(type=char(8190) updatewhereclause=no name=de_tipo_movimento dbname="de_tipo_movimento" values="E	/" )
 column=(type=char(8190) updatewhereclause=no name=valor_anterior dbname="valor_anterior" )
 column=(type=char(8190) updatewhereclause=no name=valor_novo dbname="valor_novo" )
 column=(type=char(8190) updatewhereclause=no name=query dbname="query" )
 column=(type=char(255) updatewhereclause=yes name=nr_cgc dbname="nr_cgc" )
 retrieve="SELECT	f.cd_filial										AS cd_filial,
			f.nm_fantasia								AS nm_fantasia,
			f.nm_razao_social							AS nm_razao_social,
			f.nr_licenca_vig_sanitaria				AS nr_licenca_vig_sanitaria,
			c.cd_unidade_federacao					AS cd_uf,
			u.nm_tabela									AS nm_tabela,
			u.nm_aplicacao								AS nm_aplicacao,
			u.nr_matricula								AS nr_matricula,
			u.dh_acao									AS dh_acao,
			u.id_acao									AS id_acao,
			u.de_tipo_movimento						AS de_tipo_movimento,
			u.de_tipo_movimento || ': ' 
				|| u.valor_anterior						AS valor_anterior,
			u.de_tipo_movimento || ': ' 
				|| u.valor_novo							AS valor_novo,
			u.query										AS query,
			uf_mascara_campo( 'CNPJ', f.nr_cgc)	AS nr_cgc
FROM uf_get_logged_action() AS u
	LEFT OUTER JOIN filial AS f
		ON f.cd_filial = uf_filial_parametro()
	INNER JOIN cidade AS c
		ON c.cd_cidade = f.cd_cidade
WHERE u.dh_movimentacao >= :inicio
	AND u.dh_movimentacao <= :termino" arguments=(("filial", number),("inicio", date),("termino", date),("farmaceuticos", string),("grupo_psico", stringlist),("tipo_anual_trimestral", string),("tipo_relatorio", string))  sort="dh_acao A " )
