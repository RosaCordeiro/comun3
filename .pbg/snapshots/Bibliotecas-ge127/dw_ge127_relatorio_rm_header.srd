table(column=(type=long updatewhereclause=yes name=arg_mes_exercicio dbname="arg_mes_exercicio" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="filial.nm_razao_social" )
 column=(type=char(40) updatewhereclause=yes name=de_endereco dbname="filial.de_endereco" )
 column=(type=char(20) updatewhereclause=yes name=de_bairro dbname="filial.de_bairro" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep dbname="filial.nr_cep" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="filial.nr_cgc" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" )
 column=(type=char(20) updatewhereclause=yes name=crf dbname="usuario.crf" )
 column=(type=char(40) updatewhereclause=yes name=farmaceutico dbname="usuario.farmaceutico" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf_crf dbname="usuario.cd_uf_crf" )
 column=(type=char(10) updatewhereclause=yes name=nr_licenca_vig_sanitaria dbname="filial.nr_licenca_vig_sanitaria" )
 retrieve="SELECT	month( :inicio )					AS arg_mes_exercicio,
			f.cd_filial							AS cd_filial,
			f.nm_fantasia					AS nm_fantasia,
			f.nm_razao_social				AS nm_razao_social,
			f.de_endereco					AS de_endereco,
			f.de_bairro						AS de_bairro,
			f.nr_cep							AS nr_cep,
			f.nr_cgc							AS nr_cgc,
			c.nm_cidade					AS nm_cidade,
			c.cd_unidade_federacao		AS cd_unidade_federacao,
			u.nr_registro_crf				AS crf,
			u.nm_usuario					AS farmaceutico,
			u.cd_uf_crf						AS cd_uf_crf,
			f.nr_licenca_vig_sanitaria 	AS nr_licenca_vig_sanitaria
FROM filial AS f
	INNER JOIN parametro AS p
		ON p.id_parametro = '1'
	INNER JOIN usuario AS u
		ON u.nm_usuario = p.nm_responsavel_psico
	   AND u.nr_registro_crf IS NOT NULL
	INNER JOIN cidade AS c
		ON c.cd_cidade = f.cd_cidade
WHERE f.cd_filial = :filial" arguments=(("filial", number),("inicio", date),("termino", date),("farmaceuticos", string),("grupo_psico", stringlist),("tipo_anual_trimestral", string),("tipo_relatorio", string)) )
