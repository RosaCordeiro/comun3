table(column=(type=long updatewhereclause=yes name=arg_mes_exercicio dbname="arg_mes_exercicio" )
 column=(type=char(10) updatewhereclause=yes name=cd_dcb dbname="dcb_produto.cd_dcb" dbalias="d.cd_dcb" )
 column=(type=char(40) updatewhereclause=yes name=de_dcb dbname="dcb_produto.de_dcb" dbalias="d.de_dcb" )
 column=(type=char(15) updatewhereclause=yes name=nr_notificacao dbname="lancamento_psico.nr_notificacao" dbalias="l.nr_notificacao" )
 column=(type=date updatewhereclause=yes name=dh_dispensacao dbname="lancamento_psico.dh_dispensacao" dbalias="l.dh_dispensacao" )
 column=(type=date updatewhereclause=yes name=dh_prescricao dbname="lancamento_psico.dh_prescricao" dbalias="l.dh_prescricao" )
 column=(type=char(1) updatewhereclause=yes name=id_registro dbname="lancamento_psico.id_registro" dbalias="l.id_registro" )
 column=(type=char(8) updatewhereclause=yes name=nr_registro dbname="lancamento_psico.nr_registro" dbalias="l.nr_registro" )
 column=(type=char(255) updatewhereclause=yes name=nm_prescritor dbname="nm_prescritor" )
 column=(type=long updatewhereclause=yes name=qt_prescrita dbname="lancamento_psico_produto.qt_prescrita" dbalias="lp.qt_prescrita" )
 column=(type=long updatewhereclause=yes name=qt_dispensada dbname="lancamento_psico_produto.qt_dispensada" dbalias="lp.qt_dispensada" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="g.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="g.de_apresentacao_venda" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" dbalias="g.cd_grupo_psico" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="lancamento_psico.cd_uf_registro" dbalias="l.cd_unidade_federacao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="g.cd_produto" )
 column=(type=char(255) updatewhereclause=yes name=de_registro_ms dbname="de_registro_ms" )
 retrieve="SELECT	month( :inicio ) 												AS arg_mes_exercicio,
			d.cd_dcb															AS cd_dcb,
			d.de_dcb															AS de_dcb,
			l.nr_notificacao													AS nr_notificacao,
			l.dh_dispensacao												AS dh_dispensacao,
			l.dh_prescricao													AS dh_prescricao,
			l.id_registro														AS id_registro,
			l.nr_registro														AS nr_registro,
			COALESCE( pr.nm_prescritor, '***' ) 					AS nm_prescritor,
			lp.qt_prescrita													AS qt_prescrita,
			lp.qt_dispensada												AS qt_dispensada,
			g.de_produto													AS de_produto,
			g.de_apresentacao_venda									AS de_apresentacao_venda,
			g.cd_grupo_psico												AS cd_grupo_psico,
			l.cd_uf_registro													AS cd_unidade_federacao,
			g.cd_produto													AS cd_produto,
			uf_mascara_campo('registro_ms', g.de_registro_ms) AS de_registro_ms
FROM lancamento_psico AS l
	INNER JOIN lancamento_psico_produto AS lp
		ON	 lp.nr_nsr		=  l.nr_nsr
	   AND lp.cd_filial		=  l.cd_filial
	   AND lp.nr_nf			=  l.nr_nf
	   AND lp.de_especie	=  l.de_especie
	   AND lp.de_serie		=  l.de_serie
	LEFT OUTER JOIN prescritor_receita AS pr
		ON pr.id_registro					= l.id_registro
	   AND pr.nr_registro					= l.nr_registro
	   AND pr.cd_unidade_federacao	= l.cd_uf_registro
	INNER JOIN produto_geral AS g
		ON g.cd_produto = lp.cd_produto
	LEFT OUTER JOIN dcb_produto AS d
		ON d.cd_dcb = g.cd_dcb
WHERE l.cd_filial							   = :filial
	AND l.dh_aprovacao_farmaceutico >= :inicio
	AND l.dh_aprovacao_farmaceutico <= :termino
	AND lp.id_estorno		   				   = 'N'
	AND g.cd_grupo_psico IN ( :grupo_psico );" arguments=(("filial", number),("inicio", date),("termino", date),("farmaceuticos", string),("grupo_psico", stringlist),("tipo_anual_trimestral", string),("tipo_relatorio", string))  sort="dh_dispensacao A " )
