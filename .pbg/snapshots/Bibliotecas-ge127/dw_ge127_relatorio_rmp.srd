table(column=(type=long updatewhereclause=yes name=arg_mes_exercicio dbname="arg_mes_exercicio" )
 column=(type=char(10) updatewhereclause=yes name=cd_dcb dbname="dcb_produto.cd_dcb" )
 column=(type=char(40) updatewhereclause=yes name=de_dcb dbname="dcb_produto.de_dcb" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="vw_filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="vw_filial.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="vw_filial.nm_razao_social" )
 column=(type=char(40) updatewhereclause=yes name=de_endereco dbname="vw_filial.de_endereco" )
 column=(type=char(20) updatewhereclause=yes name=de_bairro dbname="vw_filial.de_bairro" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep dbname="vw_filial.nr_cep" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="vw_filial.nr_cgc" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="vw_filial.nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf dbname="vw_filial.cd_uf" )
 column=(type=char(8190) updatewhereclause=yes name=de_secretaria dbname="de_secretaria" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" )
 column=(type=char(255) updatewhereclause=yes name=de_registro_ms dbname="de_registro_ms" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="ajuste_estoque.dh_movimentacao_caixa" )
 column=(type=char(10) updatewhereclause=yes name=nr_lote dbname="ajuste_estoque.nr_lote" )
 column=(type=char(8190) updatewhereclause=yes name=de_motivo dbname="de_motivo" )
 column=(type=long updatewhereclause=yes name=qt_ajuste dbname="ajuste_estoque.qt_ajuste" )
 column=(type=char(40) updatewhereclause=yes name=de_fabricante dbname="fabricante.de_fabricante" )
 retrieve="SELECT	month( :inicio )							AS arg_mes_exercicio,
			d.cd_dcb									AS cd_dcb,
			d.de_dcb									AS de_dcb,
			f.cd_filial									AS cd_filial,
			f.nm_fantasia							AS nm_fantasia,
			f.nm_razao_social						AS nm_razao_social,
			f.de_endereco							AS de_endereco,
			f.de_bairro								AS de_bairro,
			f.nr_cep									AS nr_cep,
			f.nr_cgc									AS nr_cgc,
			f.nm_cidade								AS nm_cidade,
			f.cd_uf									AS cd_uf, 
			(CASE f.cd_uf
				WHEN 'SC' THEN ' DE ' || f.nm_unidade_federacao
				WHEN 'SP' THEN ' DE ' || f.nm_unidade_federacao
				ELSE ' DO ' || f.nm_unidade_federacao
			END) 										AS de_secretaria,
			g.de_produto							AS de_produto,
			de_apresentacao_venda 				AS de_apresentacao_venda,
			g.cd_produto							AS cd_produto,
			g.cd_grupo_psico						AS cd_grupo_psico,
			uf_mascara_campo('registro_ms', g.de_registro_ms) AS de_registro_ms,
			ae.dh_aprovacao_farmaceutico		AS dh_movimentacao_caixa,
			ae.nr_lote								AS nr_lote,
			REPLACE( m.de_motivo_ajuste, 'CONTROLADO ', '' )	AS de_motivo,
			ae.qt_ajuste								AS qt_ajuste,
			fab.nm_razao_social					AS de_fabricante
FROM ajuste_estoque AS ae
	INNER JOIN produto_geral AS g
		ON g.cd_produto = ae.cd_produto
	LEFT OUTER JOIN dcb_produto AS d
		ON d.cd_dcb = g.cd_dcb
	INNER JOIN vw_filial AS f
		ON f.cd_filial = :filial
	INNER JOIN motivo_ajuste as m
		ON m.cd_motivo_ajuste = ae.cd_motivo_ajuste
	LEFT OUTER JOIN fabricante AS fab
		ON fab.cd_fabricante = g.cd_fabricante
WHERE ae.dh_aprovacao_farmaceutico >= :inicio
	AND ae.dh_aprovacao_farmaceutico <= :termino
	AND g.cd_grupo_psico IN ( :grupo_psico )" arguments=(("filial", number),("inicio", date),("termino", date),("farmaceuticos", string),("grupo_psico", stringlist),("tipo_anual_trimestral", string),("tipo_relatorio", string))  sort="dh_movimentacao_caixa A " )
