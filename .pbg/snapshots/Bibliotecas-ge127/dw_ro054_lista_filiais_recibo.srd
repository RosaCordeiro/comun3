 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=id_gerar dbname="id_gerar" values="	S/	N" )
 retrieve="  SELECT DISTINCT f.cd_filial,   
         f.nm_fantasia,
		   '' id_gerar  
    FROM parametro_impressao_psico p,   
         filial                    f  
   WHERE f.cd_filial = p.cd_filial
     AND p.de_midia = 'CD'
   ORDER BY f.cd_filial ASC
" )
