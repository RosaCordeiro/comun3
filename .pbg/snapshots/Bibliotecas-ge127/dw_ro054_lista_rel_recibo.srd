table(column=(type=char(10) updatewhereclause=yes name=cd_parametro dbname="parametro_impressao_psico.cd_parametro" dbalias=".cd_parametro" )
 column=(type=char(11) updatewhereclause=yes name=de_livro dbname="de_livro" )
 column=(type=char(10) updatewhereclause=yes name=vl_parametro dbname="parametro_impressao_psico.vl_parametro" dbalias=".vl_parametro" )
 column=(type=char(11) updatewhereclause=yes name=de_parametro dbname="de_parametro" )
 column=(type=char(1) updatewhereclause=yes name=id_anual dbname="id_anual" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_gerar dbname="id_gerar" values="	S/	N" )
 retrieve="  SELECT cd_parametro,  
			(case cd_parametro
				when ~"BALAQ~"  then ~"BAL. AQUIS.~"
            else cd_parametro
			end) de_livro,   
			vl_parametro,
         (case vl_parametro  
				when 'A1A2A3' then 'A1,A2,A3'
				when 'B1B2' then 'B1,B2'
				when 'C1C2C4C5' then 'C1,C2,C4,C5'
            else vl_parametro
			end) as de_parametro,
			'' id_anual,
			'' id_gerar
    FROM parametro_impressao_psico  
   WHERE cd_filial = :filial
     AND de_midia = 'CD'
     AND nr_vias > 0
 GROUP BY  cd_parametro,
	             vl_parametro
" arguments=(("filial", number)) )
