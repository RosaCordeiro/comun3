 column=(type=char(40) updatewhereclause=yes name=unidade_federacao_nm_unidade_federacao dbname="unidade_federacao.nm_unidade_federacao" )
 retrieve="  SELECT f.cd_filial,   
         f.nm_fantasia,   
         f.nm_razao_social,   
         f.nr_cgc,   
         f.nr_inscricao_estadual,   
         c.nm_cidade,   
         c.cd_unidade_federacao,   
         f.de_endereco,   
         f.de_bairro,   
         f.nr_cep,   
         f.nr_ddd_telefone,   
         f.nr_telefone,   
         u.nm_unidade_federacao  
    FROM filial f,   
         cidade c,   
         unidade_federacao u 
   WHERE f.cd_filial = :filial
     AND c.cd_cidade = f.cd_cidade
     AND u.cd_unidade_federacao = c.cd_unidade_federacao
" retrieve.asneeded=yes arguments=(("filial", number),("conteudo", string)) )
