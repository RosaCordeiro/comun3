table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_empurrado.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_pedido_empurrado dbname="pedido_empurrado.nr_pedido_empurrado" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_pedido dbname="pedido_empurrado.id_tipo_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_empurrado.dh_emissao" )
 column=(type=long updatewhereclause=yes name=qt_empurrada dbname="pedido_empurrado_produto.qt_empurrada" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="pedido_empurrado_produto.qt_faturada" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_empurrado_produto.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="pedido_empurrado_produto.id_situacao" )
 column=(type=char(9) updatewhereclause=yes name=tipo_pedido dbname="tipo_pedido" )
 column=(type=char(3) updatewhereclause=yes name=reserva_saldo dbname="reserva_saldo" )
 column=(type=char(13) updatewhereclause=yes name=desc_situacao dbname="desc_situacao" )
 column=(type=char(3) updatewhereclause=yes name=id_processado_prescador dbname="id_processado_prescador" )
 column=(type=char(1) updatewhereclause=yes name=id_cancelar dbname="id_cancelar" values="	S/	N" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_inclusao dbname="pedido_empurrado.nr_matricula_inclusao" )
 column=(type=char(40) updatewhereclause=yes name=nm_reponsavel dbname="usuario.nm_reponsavel" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="pedido_empurrado.dh_inclusao" )
 column=(type=datetime updatewhereclause=yes name=dh_situacao dbname="dh_situacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_responsavel_situacao dbname="nm_responsavel_situacao" )
 retrieve="	Select	a.cd_filial,
			f.nm_fantasia,
			a.nr_pedido_empurrado,
			a.id_tipo_pedido,
			a.dh_emissao,
			b.qt_empurrada,
			g.vl_fator_conversao,
			b.qt_faturada,
			b.cd_produto,
			g.de_produto,
			g.de_apresentacao_venda,
			b.id_situacao,
			Case a.id_tipo_pedido
				When 'E' Then 'EMPURRADO'
				When 'F' Then 'FARMAGORA'
				When 'U' Then 'URGENTE' 
			Else a.id_tipo_pedido end as tipo_pedido,
			Case a.id_reserva_saldo_cd
				When 'S' Then 'SIM'
				When 'N' Then 'NAO'
			Else a.id_reserva_saldo_cd end as reserva_saldo,
			(Case b.id_situacao
				When 'C' Then 'COLOCADO'
				When 'A' Then 'ATENDIDO'
				When 'X' Then 'CANCELADO'
				When 'B' Then 'REQUER APROV.'
				Else b.id_situacao
			End) As desc_situacao,
			Case a.id_processado
				When 'N' Then 'N$$HEX1$$c300$$ENDHEX$$O'
				WHEN 'S' Then 'SIM'
			else a.id_processado end as id_processado_prescador,
			'' As id_cancelar,
			a.nr_matricula_inclusao,
			u.nm_usuario As nm_reponsavel,
			a.dh_inclusao,
			coalesce(b.dh_aprovacao,b.dh_cancelamento) as dh_situacao,
			coalesce(ue.nm_usuario,ui.nm_usuario) as nm_responsavel_situacao
	From pedido_empurrado As a
		Inner Join pedido_empurrado_produto As b
			On b.cd_filial					= a.cd_filial
			And b.nr_pedido_empurrado	= a.nr_pedido_empurrado
		Inner Join produto_geral As g
			On g.cd_produto = b.cd_produto
		Inner Join filial As f
			On f.cd_filial = a.cd_filial
		Inner Join usuario As u
			On u.nr_matricula = a.nr_matricula_inclusao
		Left Join usuario ui
			On ui.nr_matricula = COALESCE(b.nr_matricula_cancelamento,a.nr_matricula_cancelamento)
		Left Join usuario ue
			On ue.nr_matricula = b.nr_matricula_aprovacao 
		Left Outer Join fornecedor As fo
			On fo.cd_fornecedor = a.cd_distribuidora
	Where a.dh_emissao Between :inicio And :termino" arguments=(("inicio", date),("termino", date))  sort="cd_filial A de_produto A de_apresentacao_venda A " )
