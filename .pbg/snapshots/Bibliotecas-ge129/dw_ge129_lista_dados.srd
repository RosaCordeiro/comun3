table(column=(type=long updatewhereclause=yes name=nr_pedido_filial dbname="nr_pedido_filial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_geracao_matriz dbname="id_geracao_matriz" )
 column=(type=datetime updatewhereclause=yes name=dh_geracao dbname="dh_geracao" )
 column=(type=char(1) updatewhereclause=yes name=id_gerado_logistica dbname="id_gerado_logistica" )
 column=(type=datetime updatewhereclause=yes name=dh_rateio_estoque_central dbname="dh_rateio_estoque_central" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="nr_pedido_distribuidora" )
 column=(type=long updatewhereclause=yes name=qt_empurrada dbname="qt_empurrada" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="qt_pedida" )
 column=(type=long updatewhereclause=yes name=qtd_sep_fatu dbname="qtd_sep_fatu" )
 column=(type=long updatewhereclause=yes name=qt_corte dbname="qt_corte" )
 column=(type=char(52) updatewhereclause=yes name=nm_fornecedor dbname="nm_fornecedor" )
 retrieve="Select
	pf.nr_pedido_filial,
	pfpe.cd_produto,
	pf.id_geracao_matriz,
	pf.dh_geracao,
	pf.id_gerado_logistica,
	pf.dh_rateio_estoque_central,
	pd.nr_pedido_distribuidora, 
	pep.qt_empurrada,
	pdp.qt_faturada,
	pdp.qt_pedida,
Case  pf.id_gerado_logistica  
     when 'S'    then coalesce(pdp.qt_separada,0) 
      else coalesce(pdp.qt_faturada,0)  end qtd_sep_fatu,
	case pdp.id_situacao_corte 
			when '14' then coalesce(pdp.qt_corte, 0)
			when '1' then coalesce(pdp.qt_corte, 0)
		    	else 0 end as qt_corte,
	f.cd_fornecedor + ' - ' + f.nm_fantasia AS nm_fornecedor
From dbo.pedido_filial_prd_empurrado pfpe
Inner join pedido_empurrado pe
	On pfpe.cd_filial = pe.cd_filial 
	And pfpe.nr_pedido_empurrado = pe.nr_pedido_empurrado 
Inner join dbo.pedido_empurrado_produto pep
	On pep.cd_filial = pfpe.cd_filial 
	And pep.nr_pedido_empurrado = pfpe.nr_pedido_empurrado 
	And pep.cd_produto = pfpe.cd_produto 
Inner join produto_geral pg
	On pg.cd_produto = pfpe.cd_produto 
Left join pedido_filial pf
	On pf.cd_filial = pfpe.cd_filial 
	And pf.nr_pedido_filial = pfpe.nr_pedido_filial 
Left Join dbo.pedido_filial_produto pfp
	On pfp.cd_filial = pf.cd_filial 
	And pfp.nr_pedido_filial = pf.nr_pedido_filial 
	And pfp.cd_produto = pg.cd_produto 
Left Join dbo.pedido_distribuidora pd
	On pd.cd_filial = pf.cd_filial 
	And pd.nr_pedido_filial = pf.nr_pedido_filial 
Inner Join dbo.fornecedor f
	On f.cd_fornecedor = pd.cd_distribuidora
Left Join dbo.pedido_distribuidora_produto pdp 
	On pdp.cd_filial = pd.cd_filial 
	And pdp.nr_pedido_distribuidora = pd.nr_pedido_distribuidora 
	And pdp.cd_produto = pfp.cd_produto 
Where pfpe.cd_filial = :filial
     And pfpe.nr_pedido_empurrado = :pedido_empurrado
	And (pd.nr_pedido_distribuidora is null or (pd.nr_pedido_distribuidora is not null and pdp.nr_pedido_distribuidora is not null))
	And pe.dh_inclusao >= :inclusao
	And pfpe.cd_produto = :produto
	And pd.id_situacao not in ('N', 'J')" arguments=(("filial", number),("pedido_empurrado", number),("inclusao", datetime),("produto", number))  sort="dh_geracao D " )
