table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_pedido_empurrado dbname="nr_pedido_empurrado" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=long updatewhereclause=yes name=qt_empurrada dbname="qt_empurrada" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="de_apresentacao_venda" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="id_situacao" values="COLOCADO	C/ATENDIDO	A/CANCELADO	X/" )
 column=(type=char(9) updatewhereclause=yes name=tipo_pedido dbname="tipo_pedido" )
 column=(type=char(3) updatewhereclause=yes name=reserva_saldo dbname="reserva_saldo" )
 column=(type=char(9) updatewhereclause=yes name=desc_situacao dbname="desc_situacao" )
 column=(type=char(3) updatewhereclause=yes name=id_processado_prescador dbname="id_processado_prescador" )
 column=(type=char(1) updatewhereclause=yes name=id_cancelar dbname="id_cancelar" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_inclusao dbname="nr_matricula_inclusao" )
 column=(type=char(40) updatewhereclause=yes name=nm_reponsavel dbname="nm_reponsavel" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="dh_cancelamento" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_cancelamento dbname="nr_matricula_cancelamento" )
 column=(type=char(40) updatewhereclause=yes name=nm_responsavel_cancelamento dbname="nm_responsavel_cancelamento" )
 retrieve="Select	a.cd_filial,
		f.nm_fantasia,
		a.nr_pedido_empurrado,
		a.dh_emissao,
		b.qt_empurrada,
		b.qt_faturada,
		b.cd_produto,
		g.de_produto,
		g.de_apresentacao_venda,
		b.id_situacao,
		Case a.id_tipo_pedido
			When 'E' Then 'EMPURRADO'
			When 'F' Then 'FARMAGORA'
			When 'U' Then 'URGENTE'
		else a.id_tipo_pedido end as tipo_pedido,
		Case a.id_reserva_saldo_cd
				When 'S' Then 'SIM'
				When 'N' Then 'NAO'
		Else a.id_reserva_saldo_cd end as reserva_saldo,
		(Case b.id_situacao
			When 'C' Then 'COLOCADO'
			When 'A' Then 'ATENDIDO'
			When 'X' Then 'CANCELADO'
			Else b.id_situacao
		End) As desc_situacao,
		Case a.id_processado
				When 'N' Then 'N$$HEX1$$c300$$ENDHEX$$O'
				WHEN 'S' Then 'SIM'
		else a.id_processado end as id_processado_prescador,
		'' As id_cancelar,
		a.nr_matricula_inclusao,
		u.nm_usuario As nm_reponsavel,
		a.dh_cancelamento,
		a.nr_matricula_cancelamento,
		ui.nm_usuario As nm_responsavel_cancelamento
From pedido_empurrado As a
	Inner Join pedido_empurrado_produto As b
		On b.cd_filial					= a.cd_filial
	   And b.nr_pedido_empurrado	= a.nr_pedido_empurrado
	Inner Join produto_geral As g
		On g.cd_produto = b.cd_produto
	Inner Join filial As f
		On f.cd_filial = a.cd_filial
	Inner Join usuario As u
		On u.nr_matricula = a.nr_matricula_inclusao
	Left Join usuario As ui
		On ui.nr_matricula = a.nr_matricula_cancelamento
Where a.dh_emissao Between :inicio And :termino
	And (a.id_tipo_pedido Is Null Or a.id_tipo_pedido = 'E')" arguments=(("inicio", date),("termino", date))  sort="cd_filial A de_produto A de_apresentacao_venda A " )
