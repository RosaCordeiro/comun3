table(column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="promocao_sos.cd_promocao_sos" )
 column=(type=char(40) updatewhereclause=yes name=nm_promocao_sos dbname="promocao_sos.nm_promocao_sos" )
 column=(type=char(100) updatewhereclause=yes name=de_movel dbname="promocao_sos_movel.de_movel" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="promocao_sos.dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="promocao_sos.dh_termino" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="promocao_sos_filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=saldo_filial dbname="saldo_produto.saldo_filial" )
 column=(type=long updatewhereclause=yes name=saldo_matriz dbname="saldo_produto.saldo_matriz" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo dbname="qt_estoque_minimo" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="qt_estoque_base" )
 column=(type=long updatewhereclause=yes name=qt_saldo_pendente dbname="qt_saldo_pendente" )
 retrieve="select p.cd_promocao_sos, 
		p.nm_promocao_sos,
		m.de_movel,
		p.dh_inicio,
		p.dh_termino,
		g.cd_produto, 
		g.de_produto, 
		g.de_apresentacao_venda,
		g.id_situacao,
		pf.cd_filial, 
 		fi.nm_fantasia,
		v.qt_saldo_final saldo_filial, 
		x.qt_saldo_final saldo_matriz,
		g.vl_fator_conversao,
		(select y.qt_estoque_minimo
			From promocao_sos_estoque_minimo y
		Where y.cd_promocao_sos = p.cd_promocao_sos
			and y.cd_filial				= pf.cd_filial
			and y.cd_produto			= pp.cd_produto) as qt_estoque_minimo,
		coalesce(r.qt_estoque_base, 0) as qt_estoque_base,
		(select coalesce(sum(i.qt_faturada), 0)
		from nf_compra_pendente n
			 join nf_compra_pendente_produto i
			  on i.cd_filial 			= n.cd_filial
			and i.cd_fornecedor 	= n.cd_fornecedor
			and i.nr_nf 				= n.nr_nf
			and i.de_especie		= n.de_especie
			and i.de_serie			= n.de_serie
			and i.cd_produto		= pp.cd_produto
			and n.cd_filial			= pf.cd_filial) as qt_saldo_pendente
from 	promocao_sos as p
	inner join promocao_sos_produto as pp
		on pp.cd_promocao_sos = p.cd_promocao_sos	
	inner join produto_geral as g
		on g.cd_produto = pp.cd_produto	
	inner join promocao_sos_filial as pf
		on pf.cd_promocao_sos = p.cd_promocao_sos	
	inner join saldo_produto as v
		on v.cd_filial		= pf.cd_filial
	  and v.cd_produto	= pp.cd_produto
	  and v.dh_saldo 	= :dh_saldo	
	inner join saldo_produto as x
		on x.cd_produto = pp.cd_produto
		and x.dh_saldo = :dh_saldo	
	inner join filial as fi
		on fi.cd_filial = pf.cd_filial
	left outer join resumo_reposicao_estoque as r
		on r.cd_filial = pf.cd_filial
		and r.cd_produto = pp.cd_produto
	left outer join promocao_sos_planograma_movel pm
		on pm.cd_promocao_sos = p.cd_promocao_sos
	left outer join promocao_sos_movel m
		on m.cd_movel = pm.cd_movel
where  p.cd_promocao_sos = :cd_promocao_sos
 	and x.cd_filial = 534" arguments=(("cd_promocao_sos", number),("dh_saldo", datetime))  sort="cd_filial A cd_produto A " )
