table(column=(type=char(40) updatewhereclause=yes name=id_rede dbname="vw_filial.id_rede" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="vw_saldo_atual_produto.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="vw_filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="vw_saldo_atual_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="vw_saldo_atual_produto.qt_saldo_final" )
 retrieve="select 	vf.id_rede, 
			vp.cd_filial, 
			vf.nm_fantasia, 
			vp.cd_produto, 
			g.de_produto + ' : ' + g.de_apresentacao_venda as de_produto, 
			g.id_situacao, 
			vp.qt_saldo_final 
from vw_saldo_atual_produto vp
	inner join vw_filial vf
		on vf.cd_filial = vp.cd_filial
	inner join produto_geral g
		on g.cd_produto = vp.cd_produto" )
