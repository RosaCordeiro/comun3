table(column=(type=char(11) updatewhereclause=yes name=grupo dbname="grupo" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_gerencial dbname="vl_custo_gerencial" )
 column=(type=long updatewhereclause=yes name=qt_estoquebase dbname="Qt_EstoqueBase" )
 column=(type=decimal(2) updatewhereclause=yes name=valor_estoque_base dbname="Valor_Estoque_Base" )
 column=(type=decimal(2) updatewhereclause=yes name=valor_excesso dbname="Valor_Excesso" )
 column=(type=long updatewhereclause=yes name=qt_excesso dbname="Qt_Excesso" )
 column=(type=long updatewhereclause=yes name=qt_estoquemin dbname="Qt_EstoqueMin" )
 column=(type=long updatewhereclause=yes name=vendas120dias dbname="Vendas120Dias" )
 retrieve="select --cd_filial, 
		--nm_fantasia,		
        --novo_eb,
        (CASE grupo	WHEN  '1' THEN 'MEDICAMENTO' WHEN '2' THEN 'POPULAR' WHEN '3' THEN 'PERFUMARIA' ELSE grupo END) grupo, 
        cd_produto,
        de_produto,
        vl_custo_gerencial,
        --cd_classe, 
        sum(qt_eb) Qt_EstoqueBase,
        sum(round(qt_eb * vl_custo, 2)) Valor_Estoque_Base, 
        sum((CASE WHEN qt_saldo > qt_eb THEN round((qt_saldo - qt_eb) * vl_custo, 2) ELSE 0 END)) Valor_Excesso,
        sum((CASE WHEN qt_saldo > qt_eb THEN (qt_saldo - qt_eb) ELSE 0 END)) Qt_Excesso,
        sum(qt_estoque_minimo) Qt_EstoqueMin,
        0 as  Vendas120Dias
from 
(
select 	    
			--r.cd_filial, 
			--f.nm_fantasia, 
			g.cd_produto,
             g.de_produto,
             g.de_apresentacao_estoque,
           --  (select x.vl_parametro from parametro_loja x where x.cd_filial = r.cd_filial and x.cd_parametro = 'ID_UTILIZA_NOVO_CALCULO_ESTOQUE_BASE') novo_eb, 
			---r.cd_classe_reposicao cd_classe, 
			substring(g.cd_subcategoria, 1,1) grupo,
			(CASE WHEN coalesce(a.qt_estoque_minimo, 0) > r.qt_estoque_base THEN coalesce(a.qt_estoque_minimo, 0) ELSE r.qt_estoque_base END) qt_eb,
			s.qt_saldo_final qt_saldo,
			(CASE WHEN s.vl_custo_medio <> 0 THEN s.vl_custo_medio ELSE c.vl_custo_gerencial END) AS vl_custo,
             coalesce(a.qt_estoque_minimo,0) qt_estoque_minimo  ,
             c.vl_custo_gerencial
from filial f
inner join resumo_reposicao_estoque r 	on r.cd_filial = f.cd_filial
inner join saldo_produto s 	on s.cd_filial = r.cd_filial
and s.cd_produto = r.cd_produto
inner join produto_central c    on c.cd_produto = r.cd_produto
inner join produto_geral g	on g.cd_produto = r.cd_produto
inner join cidade ci 	on ci.cd_cidade = f.cd_cidade
left outer join resumo_estoque_minimo_filial a   on a.cd_filial = r.cd_filial
and a.cd_produto = r.cd_produto
where f.id_situacao = 'A'
and f.id_pedido_centralizado = 'S'
and s.dh_saldo = f.dh_ultimo_saldo
and substring(g.cd_subcategoria, 1,1) in ('1', '2', '3') 
-----and g.cd_produto in (181,636)
) as tudo
group by  --cd_filial, 
          --nm_fantasia, 
		---          novo_eb, 
         (CASE grupo	WHEN  '1' THEN 'MEDICAMENTO' WHEN '2' THEN 'POPULAR' WHEN '3' THEN 'PERFUMARIA' ELSE grupo END), 
          --cd_classe,
          cd_produto,
          vl_custo_gerencial,
          de_produto,
          de_apresentacao_estoque
          
"  sort="cd_produto A " )
