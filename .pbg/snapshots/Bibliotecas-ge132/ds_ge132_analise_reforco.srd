table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_filial dbname="filial.id_rede_filial" )
 column=(type=long updatewhereclause=yes name=nr_pedido_filial dbname="pedido_filial.nr_pedido_filial" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_filial.dh_emissao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_filial_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=long updatewhereclause=yes name=qt_saldo_momento dbname="pedido_filial_produto.qt_saldo_momento" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_sugerida dbname="qt_sugerida" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_pedida dbname="qt_pedida" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_atendida dbname="qt_atendida" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="pedido_filial_produto.qt_faturada" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_gerencial dbname="produto_central.vl_custo_gerencial" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="pedido_filial_produto.qt_estoque_base" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo dbname="pedido_filial_produto.qt_estoque_minimo" )
 column=(type=long updatewhereclause=yes name=qt_dias_reforco dbname="pedido_filial_produto.qt_dias_reforco" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_reposicao dbname="pedido_filial_produto.cd_classe_reposicao" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_demanda_diaria dbname="pedido_filial_produto.qt_demanda_diaria" )
 column=(type=long updatewhereclause=yes name=qt_dias_cobertura dbname="pedido_filial_produto.qt_dias_cobertura" )
 column=(type=char(1) updatewhereclause=yes name=id_projeto_conexao dbname="pedido_filial_produto.id_projeto_conexao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_fil dbname="pedido_filial_produto.vl_preco_venda_filial" )
 retrieve="select p.cd_filial,   
		fi.nm_fantasia,
		fi.id_rede_filial,
         p.nr_pedido_filial,   
         p.dh_emissao,
		pp.cd_produto,   
		g.de_produto + ' : ' + g.de_apresentacao_estoque de_produto,
		g.vl_fator_conversao,
         pp.qt_saldo_momento,   
         pp.qt_sugerida * g.vl_fator_conversao qt_sugerida,   
         pp.qt_pedida * g.vl_fator_conversao qt_pedida,   
         pp.qt_atendida * g.vl_fator_conversao qt_atendida,   
         pp.qt_faturada,  
		c.vl_custo_gerencial, 
         pp.qt_estoque_base,   
         pp.qt_estoque_minimo,   
         pp.qt_dias_reforco,   
         pp.cd_classe_reposicao,   
         pp.qt_demanda_diaria,   
         pp.qt_dias_cobertura,   
         pp.id_projeto_conexao,   
         pp.vl_preco_venda_filial
from pedido_filial p
inner join pedido_filial_produto pp
	on pp.cd_filial  = p.cd_filial
	and pp.nr_pedido_filial = p.nr_pedido_filial
inner join filial fi
	on fi.cd_filial = p.cd_filial
inner join produto_central c
	on c.cd_produto = pp.cd_produto
inner join produto_geral g
	on g.cd_produto = pp.cd_produto
where p.dh_emissao between :inicio and :termino
  and pp.qt_pedida > pp.qt_sugerida
  and pp.nr_pedido_empurrado is null" arguments=(("inicio", date),("termino", date))  sort="nm_fantasia A de_produto A " )
