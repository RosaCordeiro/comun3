table(column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="codigo_barras_produto.de_codigo_barras" dbalias="c.de_codigo_barras" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="g.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" dbalias="g.id_situacao" )
 column=(type=char(3) updatewhereclause=yes name=id_principal dbname="id_principal" )
 column=(type=decimal(4) updatewhereclause=yes name=qtde dbname="qtde" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_venda dbname="cd_unidade_medida_venda" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao dbname="codigo_barras_produto.dh_atualizacao" dbalias="c.dh_atualizacao" )
 retrieve="Select	c.de_codigo_barras,
		g.cd_produto,
		g.de_produto + ' : ' + g.de_apresentacao_venda As de_produto,
		g.id_situacao,
		(Case c.id_principal
			When 'S' Then 'SIM'
			When 'N' Then 'N$$HEX1$$c300$$ENDHEX$$O'
			Else c.id_principal
		End) As id_principal,
		(CASE WHEN c.cd_unidade_medida_venda = 'CXU' THEN g.vl_fator_conversao ELSE 1 END) qtde,
		coalesce(c.cd_unidade_medida_venda,'UN') as cd_unidade_medida_venda,
		c.dh_atualizacao
From produto_geral As g
	Left Outer Join codigo_barras_produto As c
		On c.cd_produto = g.cd_produto" )
