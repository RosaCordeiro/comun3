table(column=(type=date updatewhereclause=yes name=dh_consulta dbname="dh_consulta" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="resumo_eb.cd_filial" dbalias="r.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="g.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(1) updatewhereclause=yes name=produto_geral_id_situacao dbname="produto_geral.id_situacao" dbalias="g.id_situacao" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="grupo.de_grupo" dbalias="gru.de_grupo" )
 column=(type=long updatewhereclause=yes name=qt_eb_calculado_dia dbname="qt_eb_calculado_dia" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_demanda_diaria_dia dbname="qt_demanda_diaria_dia" )
 column=(type=long updatewhereclause=yes name=qt_dias_cobertura dbname="qt_dias_cobertura" )
 column=(type=long updatewhereclause=yes name=qt_eb_dia dbname="qt_eb_dia" )
 column=(type=long updatewhereclause=yes name=qt_min_dia dbname="qt_min_dia" )
 column=(type=char(1) updatewhereclause=yes name=nr_matric_alteracao dbname="nr_matric_alteracao" )
 column=(type=char(1) updatewhereclause=yes name=nm_alteracao dbname="nm_alteracao" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao dbname="dh_alteracao" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="g.vl_fator_conversao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario_dia dbname="vl_custo_unitario_dia" )
 column=(type=long updatewhereclause=yes name=qt_saldo_dia dbname="qt_saldo_dia" )
 retrieve="Select	Cast('1900/01/01' As Date) dh_consulta,
		r.cd_filial,
		f.nm_fantasia,
		g.cd_produto,
		g.de_produto + ' : ' + g.de_apresentacao_venda As de_produto,
		g.id_situacao,
		gru.de_grupo,
		0 As qt_eb_calculado_dia,
		0.0000 As qt_demanda_diaria_dia,
		0 As qt_dias_cobertura,
		0 As qt_eb_dia,
		0 As qt_min_dia,
		'' As nr_matric_alteracao,
		'' As nm_alteracao,
		Cast('1900/01/01 00:00:00' As DateTime) dh_alteracao,
		g.vl_fator_conversao,
		(Select vl_custo_gerencial from saldo_produto s where s.cd_filial = r.cd_filial and s.cd_produto = r.cd_produto and s.dh_saldo = :resumo) As vl_custo_unitario_dia,
		dbo.saldo_produto_parcial(r.cd_filial, r.dh_resumo, :inicio, :mes_anterior, r.cd_produto) As qt_saldo_dia
From resumo_eb As r
	Inner Join produto_geral As g
		On g.cd_produto = r.cd_produto
	Inner Join grupo As gru
		On gru.cd_grupo = substring(g.cd_subcategoria, 1, 1)
	Inner Join filial As f
		On f.cd_filial = r.cd_filial
Where r.dh_resumo = :resumo
	And substring(g.cd_subcategoria, 1, 1) <> '5'" arguments=(("resumo", date),("inicio", date),("mes_anterior", date))  sort="cd_filial A cd_produto A " )
