table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=char(20) updatewhereclause=yes name=nr_cnj dbname="nr_cnj" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="nr_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_pedido dbname="dh_pedido" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_entrada dbname="dh_entrada" )
 column=(type=datetime updatewhereclause=yes name=pgto_dh_vencimento dbname="titulo_pagar.dh_vencimento" )
 column=(type=long updatewhereclause=yes name=qt_dias_pgto dbname="qt_dias_pgto" )
 column=(type=char(40) updatewhereclause=yes name=cond_pgto_nota dbname="condicao_pagamento.condicao_nota" )
 column=(type=char(40) updatewhereclause=yes name=cond_pgto_forn dbname="condicao_pagamento.condicao_forn" )
 column=(type=char(6) updatewhereclause=yes name=cd_origem dbname="cd_origem" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pedido dbname="vl_pedido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_parcela dbname="vl_parcela" )
 retrieve="select 	n.cd_fornecedor, 
			f.nm_fantasia, 
			dbo.formata_cgc_cpf(f.nr_cgc) nr_cnj,
			coalesce(n.nr_pedido_central, n.nr_pedido_distribuidora ) as nr_pedido,
			coalesce(pc.dh_pedido, pd.dh_emissao) dh_pedido,
			n.nr_nf,
			n.dh_emissao,
			n.dh_movimentacao_caixa as dh_entrada,
			t.dh_vencimento,
			datediff(dd, cast(n.dh_emissao as date), cast( t.dh_vencimento as date)) as qt_dias_pgto,
			co.de_condicao condicao_nota,
			cof.de_condicao condicao_forn,
			(CASE WHEN n.cd_filial = 534 THEN 'CD' ELSE 'FILIAL' END) as cd_origem,
			coalesce(pc.vl_total_pedido, pd.vl_total_pedido) vl_pedido,
			n.vl_total_nf, 
			coalesce(t.vl_pagar, 0) as vl_parcela			
from nf_compra n (index idx_filial_data_movimento )
inner join fornecedor f on f.cd_fornecedor = n.cd_fornecedor
left outer join pedido_central pc  on pc.nr_pedido = n.nr_pedido_central
left outer join pedido_distribuidora pd on pd.cd_filial = n.cd_filial and pd.nr_pedido_distribuidora = n.nr_pedido_distribuidora
left outer join titulo_pagar t on t.cd_filial = n.cd_filial and t.nr_nf	= n.nr_nf and t.cd_fornecedor = n.cd_fornecedor and t.de_especie = n.de_especie and t.de_serie = n.de_serie
left outer join condicao_pagamento co on co.cd_condicao = n.cd_condicao_pagamento
left outer join condicao_pagamento cof on cof.cd_condicao = f.cd_condicao_pagamento
where n.cd_filial > 0
  and n.dh_movimentacao_caixa between :dh_inicio  and :dh_termino
order by f.nm_fantasia, n.dh_movimentacao_caixa
  











" arguments=(("dh_inicio", date),("dh_termino", date)) )
