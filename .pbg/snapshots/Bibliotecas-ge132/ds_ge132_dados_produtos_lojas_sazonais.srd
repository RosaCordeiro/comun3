table(column=(type=long updatewhereclause=yes name=cd_filial dbname="resumo_reposicao_estoque.cd_filial" dbalias="r.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="grupo.de_grupo" dbalias="gp.de_grupo" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="resumo_reposicao_estoque.cd_produto" dbalias="r.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="g.vl_fator_conversao" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_reposicao dbname="resumo_reposicao_estoque.cd_classe_reposicao" dbalias="r.cd_classe_reposicao" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_demanda_diaria dbname="resumo_reposicao_estoque.qt_demanda_diaria" dbalias="r.qt_demanda_diaria" )
 column=(type=long updatewhereclause=yes name=qt_dias_cobertura dbname="resumo_reposicao_estoque.qt_dias_cobertura" dbalias="r.qt_dias_cobertura" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_gerencial dbname="saldo_produto.vl_custo_gerencial" dbalias="s.vl_custo_gerencial" )
 column=(type=long updatewhereclause=yes name=qt_estoque_calculado dbname="resumo_reposicao_estoque.qt_estoque_calculado" dbalias="r.qt_estoque_calculado" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="resumo_reposicao_estoque.qt_estoque_base" dbalias="r.qt_estoque_base" )
 retrieve="Select	r.cd_filial,
		f.nm_fantasia,
		gp.de_grupo,
		r.cd_produto,
		g.de_produto + ' : ' + g.de_apresentacao_venda As de_produto,
		g.vl_fator_conversao,
		r.cd_classe_reposicao,
		r.qt_demanda_diaria,
		r.qt_dias_cobertura,
		s.vl_custo_gerencial,
		r.qt_estoque_calculado,
		r.qt_estoque_base
From resumo_reposicao_estoque As r
	Inner Join produto_geral g
		On g.cd_produto = r.cd_produto
	Inner Join filial f
		On f.cd_filial = r.cd_filial
	Inner Join grupo gp
		On gp.cd_grupo = substring(g.cd_subcategoria, 1, 1)
	Inner Join saldo_produto s
		On s.cd_filial = r.cd_filial
		And s.cd_produto = r.cd_produto
		And s.dh_saldo = f.dh_ultimo_saldo" )
