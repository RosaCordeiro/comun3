table(column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="pg.cd_produto" )
 column=(type=char(60) update=yes updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="pg.de_produto" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" dbalias="pg.de_apresentacao_estoque" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" dbalias="pg.id_situacao" )
 column=(type=decimal(2) updatewhereclause=yes name=produto_geral_largura_eco dbname="produto_geral.largura_eco" dbalias="pg.largura_eco" )
