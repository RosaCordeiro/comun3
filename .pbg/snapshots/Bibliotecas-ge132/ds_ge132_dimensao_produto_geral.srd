 column=(type=decimal(2) updatewhereclause=yes name=produto_central_largura_forn dbname="produto_central.largura_forn" dbalias="pc.largura_forn" )
 column=(type=decimal(2) updatewhereclause=yes name=produto_central_altura_forn dbname="produto_central.altura_forn" dbalias="pc.altura_forn" )
 column=(type=decimal(2) updatewhereclause=yes name=produto_central_profund_forn dbname="produto_central.profund_forn" dbalias="pc.profund_forn" )
 column=(type=decimal(2) updatewhereclause=yes name=produto_central_largura_estoque dbname="produto_central.largura_estoque" dbalias="pc.largura_estoque" )
 column=(type=decimal(2) updatewhereclause=yes name=produto_central_altura_estoque dbname="produto_central.altura_estoque" dbalias="pc.altura_estoque" )
 column=(type=decimal(2) updatewhereclause=yes name=produto_central_profund_estoque dbname="produto_central.profund_estoque" dbalias="pc.profund_estoque" )
 column=(type=decimal(3) updatewhereclause=yes name=produto_central_peso_estoque dbname="produto_central.peso_estoque" dbalias="pc.peso_estoque" )
 column=(type=long updatewhereclause=yes name=cd_planograma dbname="produto_geral.cd_planograma" dbalias="pg.cd_planograma" )
 column=(type=char(50) updatewhereclause=yes name=de_planograma dbname="categoria_planograma.de_planograma" dbalias="c.de_planograma" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_liberado_ecommerce dbname="produto_geral.id_liberado_ecommerce" dbalias="pg.id_liberado_ecommerce" )
 column=(type=char(100) update=yes updatewhereclause=yes name=de_descricao_internet dbname="produto_geral.de_descricao_internet" dbalias="pg.de_descricao_internet" )
 column=(type=char(32768) update=yes updatewhereclause=no name=de_principal_internet dbname="produto_geral.de_principal_internet" dbalias="pg.de_principal_internet" )
 retrieve="SELECT pg.cd_produto,   
         pg.de_produto,   
         pg.de_apresentacao_estoque,   
         pg.id_situacao,   
         pg.qt_largura_cm largura_eco,   
         pg.qt_altura_cm altura_eco,   
         pg.qt_profundidade_cm profundidade_eco,   
         pg.qt_peso_grama peso_eco,
		pc.qt_largura_cm_caixa_forn largura_forn,   
         pc.qt_altura_cm_caixa_forn altura_forn,   
         pc.qt_profundidade_cm_caixa_forn profund_forn,   
         pc.qt_largura_cm_caixa_estoque largura_estoque,   
         pc.qt_altura_cm_caixa_estoque altura_estoque,   
         pc.qt_profund_cm_caixa_estoque profund_estoque ,
		pc.qt_peso_kg_estoque peso_estoque,
		pg.cd_planograma,
		c.de_planograma,     
         pg.id_liberado_ecommerce,   
         pg.de_descricao_internet,   
         pg.de_principal_internet
    FROM produto_geral as pg
		left outer join categoria_planograma as c
		on pg.cd_planograma = c.cd_planograma  
inner join produto_central pc
	on pc.cd_produto = pg.cd_produto
where pg.id_situacao <> 'I'
"  sort="de_produto A " )
