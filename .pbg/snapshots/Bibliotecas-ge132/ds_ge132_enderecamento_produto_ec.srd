table(column=(type=char(20) updatewhereclause=yes name=nm_bairro dbname="wms_bairro.nm_bairro" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_localizacao.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="wms_localizacao.cd_endereco" )
 column=(type=char(8) updatewhereclause=yes name=de_endereco_pulmao dbname="vw_wms_endereco.de_endereco_pulmao" )
 column=(type=char(6) updatewhereclause=yes name=de_endereco_flow_rack dbname="vw_wms_endereco.de_endereco_flow_rack" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="wms_localizacao.nr_lote" )
 column=(type=long updatewhereclause=yes name=qt_saldo dbname="qt_saldo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_medio dbname="saldo_produto.vl_custo_medio" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total dbname="vl_total" )
 retrieve="select c.nm_bairro,
		a.cd_produto,
		d.de_produto+' : '+d.de_apresentacao_estoque as de_produto,
		a.cd_endereco,
		e.de_endereco_pulmao,
		e.de_endereco_flow_rack,
		a.nr_lote,
		a.qt_caixa_padrao * a.qt_saldo as qt_saldo,
		f.vl_custo_medio,
		(a.qt_caixa_padrao * a.qt_saldo) * f.vl_custo_medio as vl_total
from wms_localizacao a
	inner join wms_endereco b on b.cd_endereco = a.cd_endereco
	inner join wms_bairro c on c.cd_bairro = b.cd_bairro
	inner join produto_geral d on d.cd_produto = a.cd_produto
	inner join vw_wms_endereco e on e.cd_endereco = a.cd_endereco
	left join saldo_produto f on f.cd_produto = a.cd_produto and f.cd_filial = 534 and f.dh_saldo = :saldo
order by c.nm_bairro,
			d.de_produto + ' : ' + d.de_apresentacao_estoque" arguments=(("saldo", date)) )
