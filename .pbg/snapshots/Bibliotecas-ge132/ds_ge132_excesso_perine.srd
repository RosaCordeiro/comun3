table(column=(type=long updatewhereclause=yes name=cd_produto dbname="saldo_produto.cd_produto" dbalias="s.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="vw_classificacao_produto.de_grupo" dbalias="v.de_grupo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_estoque dbname="vl_estoque" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_excesso dbname="vl_excesso" )
 column=(type=datetime updatewhereclause=yes name=saldo_produto_dh_saldo dbname="saldo_produto.dh_saldo" dbalias="s.dh_saldo" )
 retrieve="select s.cd_produto, 
		g.de_produto + ' : ' + g.de_apresentacao_venda de_produto,  
          v.de_grupo, 
		round(s.qt_saldo_final * s.vl_custo_gerencial, 2) vl_estoque,
		round((CASE WHEN (  s.qt_saldo_final - r.qt_estoque_base) > 0 
				THEN (s.qt_saldo_final - r.qt_estoque_base)  
				ELSE 0 
		END) * s.vl_custo_gerencial, 2) vl_excesso, 
		s.dh_saldo
from saldo_produto s
inner join produto_geral g
on g.cd_produto = s.cd_produto
inner join filial f
on f.cd_filial = s.cd_filial
inner join vw_classificacao_produto v
on v.cd_subcategoria = g.cd_subcategoria
left outer join resumo_estoque_base_filiais r
on r.cd_produto	= s.cd_produto
where s.cd_filial = 534
and s.dh_saldo = f.dh_ultimo_saldo
and s.qt_saldo_final > 0
and  substring(g.cd_subcategoria, 1,1) in ('1', '2', '3')
and round((CASE WHEN (  s.qt_saldo_final - r.qt_estoque_base) > 0 
    			THEN (s.qt_saldo_final - r.qt_estoque_base)  
	ELSE 0 
	END) * s.vl_custo_gerencial, 2) > 0
"  sort="de_grupo A " )
