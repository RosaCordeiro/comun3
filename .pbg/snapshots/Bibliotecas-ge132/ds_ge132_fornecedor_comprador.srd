table(column=(type=char(9) updatewhereclause=yes name=fornecedor_cd_fornecedor dbname="fornecedor.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=fornecedor_nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=char(6) updatewhereclause=yes name=usuario_nr_matricula dbname="usuario.nr_matricula" )
 column=(type=char(40) updatewhereclause=yes name=usuario_nm_usuario dbname="usuario.nm_usuario" )
 retrieve="select 	f.cd_fornecedor, 
			f.nm_fantasia, 
			u.nr_matricula, 
			u.nm_usuario
from fornecedor f, usuario u
where f.nr_matricula_comprador = u.nr_matricula"  sort="usuario_nm_usuario A fornecedor_nm_fantasia A " )
