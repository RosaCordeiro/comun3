table(column=(type=datetime updatewhereclause=yes name=dh_consulta dbname="dh_consulta" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="resumo_reposicao_estoque_hist.cd_filial" dbalias="r.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="resumo_reposicao_estoque_hist.cd_produto" dbalias="r.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="grupo.de_grupo" dbalias="g.de_grupo" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_reposicao_atual dbname="resumo_reposicao_estoque_hist.cd_classe_reposicao_atual" dbalias="r.cd_classe_reposicao_atual" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_demanda_diaria dbname="resumo_reposicao_estoque_hist.qt_demanda_diaria" dbalias="r.qt_demanda_diaria" )
 column=(type=long updatewhereclause=yes name=qt_saldo_dia dbname="qt_saldo_dia" )
 column=(type=long updatewhereclause=yes name=qt_dias_cobertura dbname="resumo_reposicao_estoque_hist.qt_dias_cobertura" dbalias="r.qt_dias_cobertura" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_anterior dbname="resumo_reposicao_estoque_hist.qt_estoque_base_anterior" dbalias="r.qt_estoque_base_anterior" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_atual dbname="resumo_reposicao_estoque_hist.qt_estoque_base_atual" dbalias="r.qt_estoque_base_atual" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_definido dbname="qt_estoque_base_definido" )
 column=(type=long updatewhereclause=yes name=qt_bloq_dias dbname="qt_bloq_dias" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_bloqueio_atual dbname="resumo_reposicao_estoque_hist.dh_termino_bloqueio_atual" dbalias="r.dh_termino_bloqueio_atual" )
 column=(type=datetime updatewhereclause=yes name=dh_historico dbname="resumo_reposicao_estoque_hist.dh_historico" dbalias="r.dh_historico" )
 column=(type=char(50) updatewhereclause=yes name=usuario_alteracao dbname="usuario_alteracao" )
 column=(type=char(9) updatewhereclause=yes name=id_alteracao_atual dbname="id_alteracao_atual" )
 column=(type=char(60) updatewhereclause=yes name=de_motivo_alteracao dbname="resumo_reposicao_estoque_hist.de_motivo_alteracao" dbalias="r.de_motivo_alteracao" )
 retrieve="select getdate() as dh_consulta, 
		r.cd_filial, 
		f.nm_fantasia, 
		r.cd_produto, 
		pg.de_produto + ' : ' + pg.de_apresentacao_venda as de_produto,
		g.de_grupo,
		r.cd_classe_reposicao_atual,
		r.qt_demanda_diaria,
		dbo.saldo_produto_parcial(r.cd_filial, :primeiro_dia_mes, cast(r.dh_historico as date), :mes_anterior, r.cd_produto) As qt_saldo_dia,
		r.qt_dias_cobertura,
		r.qt_estoque_base_anterior,
		r.qt_estoque_base_atual,

		coalesce((select x.qt_estoque_base_atual
					 from resumo_reposicao_estoque_hist x
						where x.cd_filial = r.cd_filial
							and x.cd_produto = r.cd_produto
							and x.dh_historico = r.dh_historico
							and x.nr_matricula_alteracao_atual is null
							and x.id_alteracao_atual = 'N'), (select x.qt_estoque_base_atual
																		from resumo_reposicao_estoque_hist x
																			where x.cd_filial = r.cd_filial
																				and x.cd_produto = r.cd_produto
																				and x.dh_historico = (select max(x1.dh_historico) from resumo_reposicao_estoque_hist x1 where x1.cd_filial = x.cd_filial and x1.cd_produto = x.cd_produto and x1.nr_matricula_alteracao_atual is null and x1.id_alteracao_atual = 'N')
																				and x.nr_matricula_alteracao_atual is null
																				and x.id_alteracao_atual = 'N')) as qt_estoque_base_definido,

		DATEDIFF(dd, cast(r.dh_historico as DATE), r.dh_termino_bloqueio_atual) as qt_bloq_dias,
		r.dh_termino_bloqueio_atual,
		r.dh_historico,
		COALESCE( NULL, r.nr_matricula_alteracao_atual, 'RECALCULO'  ) + '-' + u.nm_usuario as usuario_alteracao,
		(case r.id_alteracao_atual
			when 'N' then 'RECALCULO'
			when 'M' then 'MATRIZ'
			when 'F' then 'FILIAL'
		else r.id_alteracao_atual
		end) as id_alteracao_atual,
		r.de_motivo_alteracao
from resumo_reposicao_estoque_hist as r
	inner join produto_geral as pg
		on pg.cd_produto = r.cd_produto
	inner join filial as f
		on r.cd_filial = f.cd_filial
	inner join grupo as g
		on g.cd_grupo = substring(pg.cd_subcategoria, 1,1)
	left outer join usuario as u
		on u.nr_matricula = r.nr_matricula_alteracao_atual
	where r.dh_historico >= :inicio
	and r.dh_historico <= :termino
	and r.cd_filial = :filial" arguments=(("inicio", datetime),("termino", datetime),("mes_anterior", datetime),("primeiro_dia_mes", datetime),("filial", number))  sort="nm_fantasia A de_produto A dh_historico D " )
