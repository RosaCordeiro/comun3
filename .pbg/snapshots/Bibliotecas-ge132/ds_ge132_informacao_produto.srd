 column=(type=decimal(2) updatewhereclause=yes name=altura_caixa_forn dbname="altura_caixa_forn" )
 column=(type=decimal(2) updatewhereclause=yes name=largura_caixa_forn dbname="largura_caixa_forn" )
 column=(type=decimal(2) updatewhereclause=yes name=profundidade_caixa_forn dbname="profundidade_caixa_forn" )
 column=(type=decimal(3) updatewhereclause=yes name=peso_grama dbname="peso_grama" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="pg.vl_fator_conversao" )
 column=(type=long updatewhereclause=yes name=nr_embalagem_padrao dbname="produto_geral.nr_embalagem_padrao" dbalias="pg.nr_embalagem_padrao" )
 column=(type=char(8) updatewhereclause=yes name=situacao dbname="SITUACAO" )
 column=(type=char(3) updatewhereclause=yes name=psico dbname="PSICO" )
 column=(type=char(19) updatewhereclause=yes name=liberado dbname="Liberado" )
 column=(type=char(1) updatewhereclause=yes name=id_geladeira dbname="id_geladeira" )
 column=(type=char(40) updatewhereclause=yes name=de_mix_produto dbname="mix_produto.de_mix_produto" dbalias="m.de_mix_produto" )
 column=(type=char(7) updatewhereclause=yes name=demanda dbname="demanda" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="fornecedor.cd_fornecedor" dbalias="f1.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_fornecedor dbname="fornecedor.nm_fornecedor" dbalias="f1.nm_fornecedor" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" dbalias="pg.de_codigo_barras" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras_abcfarma dbname="de_codigo_barras_abcfarma" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_venda dbname="produto_geral.cd_unidade_medida_venda" dbalias="pg.cd_unidade_medida_venda" )
 column=(type=char(30) updatewhereclause=yes name=tipo_apresentacao_produto dbname="tipo_apresentacao_produto.tipo" dbalias="t.tipo" )
