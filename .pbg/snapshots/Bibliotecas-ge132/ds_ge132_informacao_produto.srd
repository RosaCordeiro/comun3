 column=(type=char(40) updatewhereclause=yes name=unidade_medida_un_venda_descricao dbname="unidade_medida.un_Venda_Descricao" dbalias="t1.un_Venda_Descricao" )
 column=(type=char(3) updatewhereclause=yes name=unidade_medida_un_compra dbname="unidade_medida.un_Compra" dbalias="t2.un_Compra" )
 column=(type=char(40) updatewhereclause=yes name=unidade_medida_un_compra_descricao dbname="unidade_medida.un_Compra_Descricao" dbalias="t2.un_Compra_Descricao" )
 column=(type=char(13) updatewhereclause=yes name=de_registro_ms dbname="produto_geral.de_registro_ms" dbalias="pg.de_registro_ms" )
 column=(type=char(100) updatewhereclause=yes name=motivo_registro_ms_isento dbname="motivo_registro_ms_isento" )
 column=(type=char(11) updatewhereclause=yes name=lei_generico dbname="lei_generico" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo_psico dbname="grupo_psico.de_grupo_psico" dbalias="gp.de_grupo_psico" )
 column=(type=char(1) updatewhereclause=yes name=contem_acucar dbname="contem_acucar" )
 column=(type=char(1) updatewhereclause=yes name=contem_lactose dbname="contem_lactose" )
 column=(type=char(1) updatewhereclause=yes name=contem_gluten dbname="contem_gluten" )
 column=(type=long updatewhereclause=yes name=dias_max_tratamento dbname="Dias_Max_Tratamento" )
 column=(type=decimal(2) updatewhereclause=yes name=volume dbname="Volume" )
 column=(type=decimal(3) updatewhereclause=yes name=peso dbname="Peso" )
 column=(type=decimal(5) updatewhereclause=yes name=concentracao dbname="Concentracao" )
 column=(type=char(40) updatewhereclause=yes name=de_unidade_medida_padrao dbname="de_unidade_medida_padrao" )
 column=(type=char(50) updatewhereclause=yes name=tipo_prescricao dbname="tipo_prescricao" )
 column=(type=char(200) updatewhereclause=yes name=tipo_alerta_restricao dbname="tipo_alerta_restricao" )
 column=(type=date updatewhereclause=yes name=dh_inclusao_produto dbname="dh_inclusao_produto" )
 column=(type=char(40) updatewhereclause=yes name=usuario_nm_comprador dbname="usuario.nm_comprador" dbalias="u.nm_comprador" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_preco_venda_atual dbname="vl_preco_venda_atual" )
 column=(type=char(3) updatewhereclause=yes name=id_pbm dbname="id_pbm" )
 column=(type=char(3) updatewhereclause=yes name=id_farmacia_popular dbname="id_farmacia_popular" )
 column=(type=char(3) updatewhereclause=yes name=id_gratis_farm_popular dbname="id_gratis_farm_popular" )
 retrieve=" select distinct pg.cd_produto,
    pg.cd_produto_sap,
    pg.de_produto,
    pg.de_apresentacao_venda,
    pg.de_apresentacao_estoque,
    cp.de_grupo as de_grupo,
    cp.de_subgrupo as de_subgrupo,
    cp.de_categoria as de_categoria,
    cp.de_subcategoria as de_subcategoria,
    coalesce(pg.qt_unidades_embalagem,0) as unidade_embalagem,
    coalesce(mp.cd_marca,0) as cd_marca,
    coalesce(mp.de_marca,'') as de_marca,
    coalesce(pl.de_planograma,'') as planograma,
    coalesce(pg.qt_largura_cm,0) as largura_cm,
    coalesce(pg.qt_altura_cm,0)  as altura_cm,
    coalesce(pg.qt_profundidade_cm,0) as profundidade_cm,
    coalesce(pc.qt_altura_cm_caixa_forn,0) as altura_caixa_forn,
    coalesce(pc.qt_largura_cm_caixa_forn,0) as largura_caixa_forn,
    coalesce(pc.qt_profundidade_cm_caixa_forn,0) as profundidade_caixa_forn,
    coalesce( pg.qt_peso_grama,0) as peso_grama,
    pg.vl_fator_conversao,    
    pg.nr_embalagem_padrao,
    case pg.id_situacao
             when 'A' then 'ATIVO'
             when 'P' then 'PENDENTE' 
             when 'I' then 'INATIVO' end as SITUACAO,
        case pg.cd_grupo_psico 
                when null then 'N$$HEX1$$c300$$ENDHEX$$O' 
            else 'SIM' end as PSICO, 
            j.Liberado, 
       coalesce(pg.id_geladeira, 'N') as id_geladeira,
       m.de_mix_produto,
       (case pc.id_tipo_reposicao_estoque
      when 'E' then 'ESTAVEL'
      when 'S' then 'SAZONAL'
      end) as demanda,
            f1.cd_fornecedor ,            
            f1.nm_razao_social as nm_fornecedor, 
            pg.de_codigo_barras, 
            j.de_codigo_barras as de_codigo_barras_abcfarma,
            pg.cd_unidade_medida_venda, 
            t.de_apresentacao as tipo,
            t1.cd_unidade_medida as un_Venda,
            t1.de_unidade_medida as un_Venda_Descricao,
            t2.cd_unidade_medida as un_Compra,
            t2.de_unidade_medida as un_Compra_Descricao,
            pg.de_registro_ms,
	 		coalesce (pg.de_motivo_registro_ms_isento, 'SEM INFORMACAO NO CADASTRO') as motivo_registro_ms_isento,
            case pg.id_lei_generico            
            when  'E' then  'EQUIVALENTE' 
            when  'G' then  'GEN$$HEX1$$c900$$ENDHEX$$RICO' 
            when  'O'  then 'OUTROS' 
            when  'R'  then 'REFER$$HEX1$$ca00$$ENDHEX$$NCIA' 
            when  'S'  then 'SIMILAR' end as lei_generico,
           gp.de_grupo_psico,
           coalesce(pg.id_contem_acucar,'N') as contem_acucar,
           coalesce(pg.id_contem_lactose,'N') as contem_lactose,
           coalesce(pg.id_contem_gluten,'N') as contem_gluten,
           coalesce(pg.qt_dias_maximo_tratamento,0)  as Dias_Max_Tratamento,
           coalesce(pg.vl_volume,0) as Volume,
           coalesce(pc.qt_peso_apresentacao,0) as Peso,
           coalesce(pg.qt_concentracao,0) as Concentracao,
      coalesce(un.de_unidade_medida, 'SEM INFORMACAO NO CADASTRO') as de_unidade_medida_padrao, 
      coalesce (tp.de_tipo_prescricao, 'SEM INFORMACAO NO CADASTRO')  as tipo_prescricao,
      coalesce (tpr.de_tipo_alerta, 'SEM INFORMACAO NO CADASTRO') as tipo_alerta_restricao,
      cast(pg.dh_inclusao_produto as date) as dh_inclusao_produto,
      u.nm_usuario as nm_comprador,
      pg.vl_preco_venda_atual / pg.vl_fator_conversao as vl_preco_venda_atual,
     Case When (Select Count(pp.cd_pbm) From pbm As p Inner Join pbm_produto As pp On pp.cd_pbm = p.cd_pbm Where pp.cd_produto = pg.cd_produto) > 0 then 'SIM' else 'N$$HEX1$$c300$$ENDHEX$$O' end as id_pbm,
     Case When pg.id_farmacia_popular = 'S' then 'SIM' else 'N$$HEX1$$c300$$ENDHEX$$O' end as id_farmacia_popular,
	 Case When pg.id_gratis_farm_popular = 'S' then 'SIM' else 'N$$HEX1$$c300$$ENDHEX$$O' end as id_gratis_farm_popular
from produto_geral pg
                Inner join produto_central pc
                               on pc.cd_produto = pg.cd_produto
                left join ( select                a.cd_produto, b.de_codigo_barras, 
                        case pab.id_controle_preco  
                                when 'M' then 'MONITORADO'
                                when 'X' then 'LIBER. PR$$HEX1$$c700$$ENDHEX$$O F$$HEX1$$c100$$ENDHEX$$BRICA'
                                when 'L' then 'LIBERADO'
                                when 'T' then 'HOSPITALAR' else pab.id_controle_preco end as Liberado
                  from produto_geral a
                  inner   join codigo_barras_produto b on a.cd_produto   = b.cd_produto and b.id_principal = 'S'
                  inner   join produto_abcfarma pab  on pab.de_codigo_barras = b.de_codigo_barras ) 
        j  on pg.cd_produto = j.cd_produto
                left outer join vw_classificacao_produto cp
                               on cp.cd_subcategoria = pg.cd_subcategoria
                left outer join fornecedor f1
                               on f1.cd_fornecedor = pg.cd_fornecedor_usual
                left outer join fabricante fa
                               on fa.cd_fabricante = pg.cd_fabricante
                left join  tipo_apresentacao_produto t
                               on t.id_apresentacao=pg.id_apresentacao
                left join unidade_medida t1
                               on t1.cd_unidade_medida = pg.cd_unidade_medida_venda
                left  join unidade_medida t2
                               on t2.cd_unidade_medida = pg.cd_unidade_medida_compra
                left join grupo_psico gp
                               on gp.cd_grupo_psico = pg.cd_grupo_psico
                left join categoria_planograma pl
                               on pl.cd_planograma = pg.cd_planograma
                left outer join marca_produto mp
                               on mp.cd_marca = pg.cd_marca
                left outer join unidade_medida un
                               on un.cd_unidade_medida = pg.cd_unidade_medida_padrao
         left join   tipo_prescricao tp on tp.cd_tipo_prescricao = pg.cd_tipo_prescricao
              left join    tipo_alerta_restricao  tpr on tpr.cd_tipo_alerta = pg.cd_tipo_alerta_restricao
         left outer join mix_produto m on m.cd_mix_produto = pc.cd_mix_produto
         left outer join usuario u on u.nr_matricula = pc.nr_matricula_comprador" )
