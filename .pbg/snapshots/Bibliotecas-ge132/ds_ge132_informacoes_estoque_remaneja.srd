table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="de_apresentacao_estoque" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_reposicao dbname="cd_classe_reposicao" )
 column=(type=long updatewhereclause=yes name=saldo_produto_qt_estoque_filial dbname="qt_estoque_filial" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="qt_estoque_base" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_definido dbname="qt_estoque_base_definido" )
 column=(type=long updatewhereclause=yes name=qt_estoq_minimo dbname="qt_estoq_minimo" )
 retrieve="Select	r.cd_filial,
		fi.nm_fantasia,
		r.cd_produto,
		f.de_produto,
		f.de_apresentacao_estoque,
		r.cd_classe_reposicao,
		s1.qt_saldo_final as qt_estoque_filial,
		r.qt_estoque_base,
		r.qt_estoque_base_definido,
		isnull(r1.qt_estoque_minimo,0) qt_estoq_minimo
From resumo_reposicao_estoque r
Left Outer Join resumo_estoque_minimo_filial r1
	On r1.cd_produto = r.cd_produto
	and r1.cd_filial = r.cd_filial
Inner Join saldo_produto s1 
	On s1.cd_filial  = r.cd_filial
	and s1.cd_produto = r.cd_produto
Inner Join produto_geral f 
	On f.cd_produto = r.cd_produto
Inner Join filial fi 
	On fi.cd_filial = r.cd_filial
Left Outer Join vw_divisao_fornecedor_produto p 
	On p.cd_produto = r.cd_produto
	and p.cd_fornecedor = f.cd_fornecedor_usual
Inner Join fornecedor fo 
	On fo.cd_fornecedor = f.cd_fornecedor_usual
Where s1.qt_saldo_final > 0 
	and s1.dh_saldo  =:dh_saldo_filial" arguments=(("dh_saldo_filial", date))  sort="cd_filial A " )
