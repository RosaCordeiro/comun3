table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" dbalias="f.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=usuario_de_gerente dbname="usuario.de_gerente" dbalias="ger.de_gerente" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="filial.nr_cgc" dbalias="f.nr_cgc" )
 column=(type=char(15) updatewhereclause=yes name=nr_inscricao_estadual dbname="filial.nr_inscricao_estadual" dbalias="f.nr_inscricao_estadual" )
 column=(type=char(40) updatewhereclause=yes name=de_endereco dbname="filial.de_endereco" dbalias="f.de_endereco" )
 column=(type=long updatewhereclause=yes name=nr_endereco dbname="filial.nr_endereco" dbalias="f.nr_endereco" )
 column=(type=char(20) updatewhereclause=yes name=de_bairro dbname="filial.de_bairro" dbalias="f.de_bairro" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep dbname="filial.nr_cep" dbalias="f.nr_cep" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_filial dbname="id_rede_filial" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf dbname="cidade.cd_uf" dbalias="cid.cd_uf" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" dbalias="cid.nm_cidade" )
 column=(type=long updatewhereclause=yes name=cd_regiao dbname="filial.cd_regiao" dbalias="f.cd_regiao" )
 column=(type=char(40) updatewhereclause=yes name=de_regiao dbname="regiao.de_regiao" dbalias="r.de_regiao" )
 column=(type=char(40) updatewhereclause=yes name=nm_gerente_regional dbname="usuario.nm_gerente_regional" dbalias="reg.nm_gerente_regional" )
 column=(type=char(100) updatewhereclause=yes name=de_email_regional dbname="usuario.de_email_regional" dbalias="reg.de_email_regional" )
 column=(type=long updatewhereclause=yes name=cd_porte dbname="filial.cd_porte" dbalias="f.cd_porte" )
 column=(type=char(40) updatewhereclause=yes name=loja_de_porte dbname="tipo_porte_loja.de_porte" dbalias="t.de_porte" )
 column=(type=char(7) updatewhereclause=yes name=status_loja dbname="Status_Loja" )
 column=(type=char(3) updatewhereclause=yes name=nr_ddd dbname="filial.nr_ddd_telefone" dbalias="f.nr_ddd_telefone" )
 column=(type=char(8) updatewhereclause=yes name=nr_telefone dbname="filial.nr_telefone" dbalias="f.nr_telefone" )
 column=(type=char(3) updatewhereclause=yes name=nr_ddd_fax dbname="filial.nr_ddd_fax" dbalias="f.nr_ddd_fax" )
 column=(type=char(8) updatewhereclause=yes name=nr_fax dbname="filial.nr_fax" dbalias="f.nr_fax" )
 column=(type=datetime updatewhereclause=yes name=dh_reinauguracao dbname="filial.dh_reinauguracao" dbalias="f.dh_reinauguracao" )
 column=(type=char(3) updatewhereclause=yes name=abredomingo dbname="AbreDomingo" )
 column=(type=char(3) updatewhereclause=yes name=beauty dbname="beauty" values="SIM	1/N$$HEX1$$c300$$ENDHEX$$O	0/" )
 column=(type=char(129) updatewhereclause=yes name=horarioloja dbname="horarioLoja" )
 column=(type=char(3) updatewhereclause=yes name=recebetransferencia dbname="RecebeTransferencia" )
 retrieve="  SELECT	f.cd_filial,  
			ger.nm_usuario as de_gerente, 
			f.nm_fantasia,      
			f.nr_cgc,   
			f.nr_inscricao_estadual,   
			f.de_endereco,  
			f.nr_endereco, 
			f.de_bairro,   
			f.nr_cep, 
			Coalesce(f.id_rede_filial,'') as id_rede_filial,  
			cid.cd_unidade_federacao as cd_uf, 
			cid.nm_cidade as nm_cidade,
			f.cd_regiao,
			r.de_regiao,
			reg.nm_usuario as nm_gerente_regional,
			reg.de_endereco_email as de_email_regional,
			f.cd_porte,
			t.de_porte,
			case f.id_situacao when 'A' Then 'Ativa' else 'Inativa' end Status_Loja, 
		   f.nr_ddd_telefone,
            f.nr_telefone,
            f.nr_ddd_fax,
            f.nr_fax,
            f.dh_reinauguracao,            
            case f.id_abre_domingo when 'N' then 'N$$HEX1$$c300$$ENDHEX$$O' else 'SIM' end AbreDomingo,
		   case b.cd_filial when null then 'N$$HEX1$$c300$$ENDHEX$$O' else 'SIM' end as beauty ,
		   '                                                                                                                                 '  horarioLoja,
		  case f.id_recebe_nf_transferencia when 'S' then 'SIM' Else 'N$$HEX1$$c200$$ENDHEX$$O' end RecebeTransferencia  
FROM filial 		f
left join cidade 		cid		on cid.cd_cidade		= f.cd_cidade
inner join regiao 	r		on r.cd_regiao			= f.cd_regiao
left join usuario 	ger	on ger.nr_matricula	= f.nr_matricula_gerente and ger.id_situacao = 'A'
left join usuario 	reg	on reg.nr_matricula	= r.nr_matricula_regional
left join ( select cd_filial from parametro_loja 
            where cd_parametro = 'ID_LOJA_BEAUTY_CLUB' 
            and vl_parametro = 'S' ) b on b.cd_filial = f.cd_filial
left outer join tipo_porte_loja t
    on t.cd_porte = f.cd_porte
where f.cd_filial > 0
order by cd_filial" )
