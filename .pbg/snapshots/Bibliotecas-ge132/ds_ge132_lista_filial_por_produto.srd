table(column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="de_codigo_barras" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=descricao_apresentacao dbname="descricao_apresentacao" )
 column=(type=char(40) updatewhereclause=yes name=fornecedor dbname="fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=comprador dbname="comprador" )
 column=(type=long updatewhereclause=yes name=pp dbname="PP" )
 column=(type=decimal(2) updatewhereclause=yes name=percent_pp dbname="percent_pp" )
 column=(type=long updatewhereclause=yes name=dc dbname="DC" )
 column=(type=decimal(2) updatewhereclause=yes name=percent_dc dbname="percent_dc" )
 column=(type=long updatewhereclause=yes name=qt_filiais dbname="qt_filiais" )
 column=(type=decimal(2) updatewhereclause=yes name=percent_tot dbname="percent_tot" )
 retrieve="select	g.de_codigo_barras,
        	tudo.cd_produto,
        	g.de_produto + ' : ' + g.de_apresentacao_venda descricao_apresentacao,
        	f.nm_razao_social fornecedor,
        	u.nm_usuario comprador,
        	0 PP,
		0.00 As percent_pp,
		(select count(distinct cd_filial) 
         from vw_promocao_estoque_minimo vd
         where vd.cd_filial in (select cd_filial from parametro_loja where cd_parametro =  'ID_REDE_FILIAL' and vl_parametro <> 'PP')
           and  vd.cd_produto = tudo.cd_produto
           and  vd.id_tipo_promocao = 'P') DC,
		0.00 As percent_dc,
        	tudo.qt_filiais,
		0.00 As percent_tot
from (
    select v.cd_produto, count(distinct cd_filial) qt_filiais
    from vw_promocao_estoque_minimo v
    where v.id_tipo_promocao = 'P'
    group by v.cd_produto
) as tudo
inner join produto_geral g
    on g.cd_produto = tudo.cd_produto
inner join fornecedor f
    on f.cd_fornecedor = g.cd_fornecedor_usual
inner join produto_central c
    on c.cd_produto = tudo.cd_produto
left outer join usuario u
    on u.nr_matricula = c.nr_matricula_comprador"  sort="qt_filiais D " )
