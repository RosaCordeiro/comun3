 column=(type=decimal(2) updatewhereclause=yes name=vl_ipi dbname="vl_ipi" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto dbname="vl_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=long updatewhereclause=yes name=ncm dbname="NCM" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="cd_produto_sap" )
 column=(type=char(8) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=char(120) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="de_codigo_barras" )
 column=(type=char(1) updatewhereclause=yes name=cd_cst_origem dbname="cd_cst_origem" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_tributacao dbname="cd_cst_tributacao" )
 column=(type=char(1) updatewhereclause=yes name=id_lista_pis_confins dbname="id_lista_pis_confins" )
 column=(type=char(6) updatewhereclause=yes name=cd_unidade_medida dbname="cd_unidade_medida" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_preco_unitario dbname="vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_desconto dbname="vl_desconto" )
 column=(type=decimal(4) updatewhereclause=yes name=bc_icms dbname="bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_reducao_icms dbname="pc_reducao_icms" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_icms dbname="vl_icms" )
 column=(type=decimal(4) updatewhereclause=yes name=bc_icms_st dbname="bc_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_st dbname="pc_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_reducao_icms_st dbname="pc_reducao_icms_st" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_icms_st dbname="vl_icms_st" )
 column=(type=decimal(4) updatewhereclause=yes name=bc_ipi dbname="bc_ipi" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_ipi dbname="pc_ipi" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_ipi dbname="vl_ipi" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_outras_despesas dbname="vl_outras_despesas" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_frete dbname="vl_frete" )
 retrieve="select	a.dh_emissao,
  			a.cd_filial, 
  			fi.nm_fantasia,
			(CASE a.cd_fornecedor WHEN  '053406202' THEN '9806' 	WHEN '053402899' THEN '9802' ELSE coalesce(cli.cd_cliente_sap, f.cd_fornecedor_sap) END) cd_fornecedor_sap ,
  			a.cd_fornecedor,
  			a.nr_nf, 
			f.nr_cgc,
			f.nm_fantasia,
			a.de_chave_acesso,
			a.vl_bc_icms,
			a.vl_icms,
			a.vl_bc_icms_st,
			a.vl_icms_st,
			a.vl_frete,
			a.vl_ipi,
			a.vl_desconto,
			a.vl_total_nf,
			p.nr_classificacao_fiscal NCM,
			p.cd_produto,
			g.cd_produto_sap,
			(CASE g.id_situacao WHEN  'A' THEN 'ATIVO' WHEN 'I' THEN 'INATIVO' WHEN 'P' THEN 'PENDENTE' ELSE g.id_situacao END) id_situacao,
			p.de_produto,
			p.de_codigo_barras,
			p.cd_cst_origem,
			p.cd_cst_tributacao,
			p.id_lista_pis_confins,
			p.cd_unidade_medida,
			p.qt_faturada,
			p.vl_preco_unitario,
			p.pc_desconto,
			p.vl_desconto,
			p.bc_icms,
			p.pc_icms,
			p.pc_reducao_icms,
			p.vl_icms,
			p.bc_icms_st,
			p.pc_icms_st,
			p.pc_reducao_icms_st,
			p.vl_icms_st,
			p.bc_ipi,
			p.pc_ipi,
			p.vl_ipi,
			p.vl_outras_despesas,
			p.vl_frete
from dbo.nfe_compra_pendente a
inner join dbo.nfe_compra_pendente_prd p on p.cd_filial = a.cd_filial and p.cd_fornecedor = a.cd_fornecedor  and p.nr_nf 	= a.nr_nf and p.de_especie = a.de_especie 
inner join fornecedor f on f.cd_fornecedor = a.cd_fornecedor
inner join filial fi on fi.cd_filial = a.cd_filial
left outer join produto_geral g on g.cd_produto  = p.cd_produto 
left outer join cliente cli on cli.nr_cpf_cgc = f.nr_cgc
where a.dh_emissao >= :dh_inicio
    and a.dh_emissao <= :dh_termino
order by a.dh_emissao" arguments=(("dh_inicio", date),("dh_termino", date)) )
