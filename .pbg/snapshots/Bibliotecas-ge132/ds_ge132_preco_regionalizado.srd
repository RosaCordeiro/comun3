table(column=(type=char(2) updatewhereclause=yes name=id_rede_filial dbname="filial.id_rede_filial" )
 column=(type=long updatewhereclause=yes name=cd_cidade dbname="cidade.cd_cidade" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="preco_regionalizado.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_atual dbname="preco_regionalizado.vl_preco_venda_atual" )
 column=(type=datetime updatewhereclause=yes name=dh_preco_venda_atual dbname="preco_regionalizado.dh_preco_venda_atual" )
 retrieve="select 	distinct 
			f.id_rede_filial, 
			c.cd_cidade, 
			c.nm_cidade, 
			p.cd_produto,
			g.de_produto + ' : ' + g.de_apresentacao_estoque de_produto,
			g.vl_fator_conversao,
			p.vl_preco_venda_atual,
			p.dh_preco_venda_atual	
from preco_regionalizado p
inner join filial f
	on f.cd_filial = p.cd_filial
inner join cidade c
	on c.cd_cidade = f.cd_cidade
inner join produto_geral g
	on g.cd_produto = p.cd_produto
order by f.id_rede_filial,
			c.nm_cidade,
			g.de_produto,
			g.de_apresentacao_estoque" )
