table(column=(type=long updatewhereclause=yes name=cd_filial dbname="saldo_produto.cd_filial" dbalias="s.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="g.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="qt_estoque_base" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo dbname="qt_estoque_minimo" )
 column=(type=long updatewhereclause=yes name=qt_saldo dbname="saldo_produto.qt_saldo" dbalias="s.qt_saldo" )
 retrieve="Select s.cd_filial,
		f.nm_fantasia,
		g.cd_produto,
		g.de_produto || ' : ' || g.de_apresentacao_venda As de_produto,
		Coalesce(r.qt_estoque_base, 0) As qt_estoque_base,
		(select coalesce(qt_estoque_minimo, 0) from resumo_estoque_minimo_filial where cd_produto = g.cd_produto and cd_filial = s.cd_filial) as qt_estoque_minimo,
		s.qt_saldo_final As qt_saldo
From produto_geral As g
	Inner Join saldo_produto As s
		On s.cd_produto = g.cd_produto
		And s.dh_saldo = :saldo
	Inner Join filial As f
		On f.cd_filial = s.cd_filial
	Left Outer Join resumo_reposicao_estoque As r
		On r.cd_filial = s.cd_filial
	   And r.cd_produto = s.cd_produto
Where g.id_situacao = 'A'
	and f.id_situacao = 'A'
	And r.cd_filial Not In (1, 2, 534)
	And s.qt_saldo_final > 0
	And exists (select * from movimento_estoque me
					where me.cd_filial_movimento = r.cd_filial
					and me.cd_produto = r.cd_produto
					and me.dh_movimento < dateadd(day, -360,getdate() as date))
	And not exists (select * from resumo_movto_estq_prd x
              where x.cd_filial = s.cd_filial 
                and x.cd_produto = s.cd_produto 
                and x.qt_venda > 0
                and x.dh_resumo >= dateadd(day, -360,getdate() as date))" arguments=(("saldo", date)) )
