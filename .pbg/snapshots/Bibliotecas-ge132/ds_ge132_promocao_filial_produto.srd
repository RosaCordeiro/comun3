table(column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="promocao_sos.cd_promocao_sos" dbalias="ps.cd_promocao_sos" )
 column=(type=char(40) updatewhereclause=yes name=nm_promocao_sos dbname="promocao_sos.nm_promocao_sos" dbalias="ps.nm_promocao_sos" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="promocao_sos_filial.cd_filial" dbalias="psf.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="pg.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 retrieve="SELECT
		ps.cd_promocao_sos,
		ps.nm_promocao_sos,
		psf.cd_filial,
		f.nm_fantasia,
		pg.cd_produto,
		pg.de_produto || ' : ' || pg.de_apresentacao_estoque AS de_produto
  FROM promocao_sos AS ps
  INNER JOIN promocao_sos_filial AS psf
		  ON psf.cd_promocao_sos = ps.cd_promocao_sos
  INNER JOIN filial AS f
		  ON f.cd_filial = psf.cd_filial
  INNER JOIN promocao_sos_produto AS psp
		  ON psp.cd_promocao_sos = ps.cd_promocao_sos
  INNER JOIN produto_geral AS pg
		  ON pg.cd_produto = psp.cd_produto
  INNER JOIN parametro AS p
		  ON ps.dh_inicio <= p.dh_movimentacao
       AND (ps.dh_termino IS NULL OR ps.dh_termino >= p.dh_movimentacao)" )
