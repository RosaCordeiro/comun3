table(column=(type=long updatewhereclause=yes name=cd_produto dbname="composicao_produto.cd_produto" dbalias="c.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=cd_substancia dbname="composicao_produto.cd_substancia" dbalias="c.cd_substancia" )
 column=(type=char(40) updatewhereclause=yes name=de_substancia dbname="substancia_produto.de_substancia" dbalias="s.de_substancia" )
 column=(type=decimal(5) updatewhereclause=yes name=qt_concentracao dbname="composicao_produto.qt_concentracao" dbalias="c.qt_concentracao" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida dbname="composicao_produto.cd_unidade_medida" dbalias="c.cd_unidade_medida" )
 column=(type=char(40) updatewhereclause=yes name=de_unidade_medida dbname="de_unidade_medida" )
 column=(type=char(3) updatewhereclause=yes name=cd_tipo_apresentacao dbname="composicao_produto.cd_tipo_apresentacao" dbalias="c.cd_tipo_apresentacao" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_apresentacao dbname="tipo_concentracao.de_tipo_apresentacao" dbalias="tc.de_tipo_apresentacao" )
 retrieve="Select	c.cd_produto,
		g.de_produto + ' : ' + g.de_apresentacao_estoque As de_produto,
		c.cd_substancia,
		s.de_substancia,
		c.qt_concentracao, 
 		c.cd_unidade_medida,
		upper(um.de_unidade_medida) as de_unidade_medida,
		c.cd_tipo_concentracao as cd_tipo_apresentacao,
		tc.de_tipo_concentracao as de_tipo_apresentacao
From composicao_produto As c
	Inner Join substancia_produto As s
		On s.cd_substancia = c.cd_substancia
	Inner Join produto_geral As g
		On g.cd_produto = c.cd_produto
     inner join tipo_concentracao tc 
         On (tc.cd_tipo_concentracao = c.cd_tipo_concentracao)
		inner join unidade_medida um on (um.cd_unidade_medida = c.cd_unidade_medida)"  sort="de_produto A de_substancia A " )
