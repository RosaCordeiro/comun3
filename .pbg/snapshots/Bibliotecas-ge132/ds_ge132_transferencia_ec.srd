table(column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="cd_filial_origem" )
 column=(type=char(40) updatewhereclause=yes name=filial_origem dbname="filial.filial_origem" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="cd_filial_destino" )
 column=(type=char(40) updatewhereclause=yes name=filial_destino dbname="filial.filial_destino" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_recebimento dbname="dh_recebimento" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_transferencia.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_transferida dbname="item_nf_transferencia.qt_transferida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="item_nf_transferencia.vl_custo_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_produto dbname="vl_total_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="item_nf_transferencia.vl_icms_st" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="item_nf_transferencia.cd_natureza_operacao" )
 column=(type=char(17) updatewhereclause=yes name=de_tipo_transferencia dbname="de_tipo_transferencia" )
 retrieve="SELECT n.cd_filial_origem,
		fo.nm_fantasia filial_origem,
		n.cd_filial_destino,
		 fd.nm_fantasia filial_destino,
		 n.nr_nf,
		 n.de_especie,
		 n.de_serie,
		 n.dh_movimentacao_caixa,
		n.dh_recebimento,
		i.cd_produto,
		g.de_produto + ' : ' + g.de_apresentacao_venda as de_produto,
		i.qt_transferida,
		vl_custo_unitario,
		vl_custo_unitario * i.qt_transferida as vl_total_produto,
		i.vl_icms_st,
		i.cd_natureza_operacao,
		Case When n.id_almoxarifado = 'S' then 'ALMOXARIFADO' 
			Else Case When n.id_produto_vencido = 'S' Then 'PROD. VENCIDO' 
			Else Case When n.id_retirada_excesso = 'S' Then 'REMANEJAMENTO'
			Else Case When n.nr_retirada_estoque is not null then 'RETIRADA ESTOQUE'
			Else Case When n.id_devolucao = 'S' Then 'DEVOLU$$HEX2$$c700c300$$ENDHEX$$O'
			Else Case When n.cd_filial_origem <> 534 and n.cd_filial_destino <> 1 and n.cd_filial_destino <> 534  then 'ENTRE FILIAIS'
			Else Case When n.cd_filial_origem = 534 then Case when n.nr_pedido_distribuidora is null then 'EC - FAT. URGENTE' else 'EC - FAT. NORMAL' end
			Else 'NORMAL' end end end end end end end as de_tipo_transferencia
FROM nf_transferencia n (index idx_data_filial_origem )
	inner join item_nf_transferencia i
		on i.cd_filial_origem = n.cd_filial_origem
		and i.nr_nf = n.nr_nf
		and i.de_especie = n.de_especie
		and i.de_serie = n.de_serie
	inner join produto_geral g
		on g.cd_produto = i.cd_produto
	inner join filial fo
		on fo.cd_filial = n.cd_filial_origem
	inner join cidade co 
		on co.cd_cidade = fo.cd_cidade
	inner join filial fd
		on fd.cd_filial = n.cd_filial_destino
	inner join cidade cd 
		on cd.cd_cidade = fd.cd_cidade
where n.dh_movimentacao_caixa >= :inicio
	and n.dh_movimentacao_caixa <= :termino
	and n.cd_filial_origem = 534
	and n.dh_cancelamento is null" arguments=(("inicio", date),("termino", date)) )
