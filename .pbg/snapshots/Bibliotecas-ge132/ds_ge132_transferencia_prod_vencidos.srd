table(column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="nf_transferencia.cd_filial_origem" dbalias="nf.cd_filial_origem" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_transferencia.nr_nf" dbalias="nf.nr_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_transferencia.dh_emissao" dbalias="nf.dh_emissao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_transferencia.cd_produto" dbalias="inf.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_transferida dbname="item_nf_transferencia.qt_transferida" dbalias="inf.qt_transferida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="item_nf_transferencia.vl_custo_unitario" dbalias="inf.vl_custo_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=custo_total dbname="custo_total" )
 retrieve="select nf.cd_filial_origem,
		 nf.nr_nf,
		 nf.dh_emissao,
		 inf.cd_produto,
		 pg.de_produto + ' : ' + pg.de_apresentacao_venda as de_produto,
       inf.qt_transferida,
       inf.vl_custo_unitario,
       (inf.qt_transferida * inf.vl_custo_unitario) as custo_total
	from nf_transferencia nf
	inner join item_nf_transferencia inf 
		on  inf.cd_filial_origem = nf.cd_filial_origem
		and inf.nr_nf 				 = nf.nr_nf
		and inf.de_especie 		 = nf.de_especie
		and inf.de_serie   		 = nf.de_serie 
	inner join produto_geral pg
 		on inf.cd_produto = pg.cd_produto
where nf.cd_filial_destino in (1,534)
	and coalesce(nf.id_produto_vencido,'N')='S'
	and nf.dh_cancelamento is null
order by nf.dh_emissao
" )
