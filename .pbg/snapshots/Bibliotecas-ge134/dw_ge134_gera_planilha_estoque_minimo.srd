table(column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="promocao_sos_produto.cd_promocao_sos" dbalias="p.cd_promocao_sos" )
 column=(type=char(40) updatewhereclause=yes name=nm_promocao_sos dbname="promocao_sos.nm_promocao_sos" dbalias="s.nm_promocao_sos" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="promocao_sos_produto.cd_produto" dbalias="p.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" dbalias="g.id_situacao" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="vw_classificacao_produto.de_grupo" dbalias="vw.de_grupo" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="promocao_sos_filial.cd_filial" dbalias="a.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="l.nm_fantasia" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="g.vl_fator_conversao" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="resumo_reposicao_estoque.qt_estoque_base" dbalias="r.qt_estoque_base" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo dbname="promocao_sos_estoque_minimo.qt_estoque_minimo" dbalias="e.qt_estoque_minimo" )
 retrieve="Select Distinct p.cd_promocao_sos,
		s.nm_promocao_sos,
		p.cd_produto,
		g.de_produto + ' : ' + g.de_apresentacao_venda de_produto,
		g.id_situacao,
		vw.de_grupo,
		a.cd_filial,
		l.nm_fantasia,
		g.vl_fator_conversao,
		r.qt_estoque_base,
		e.qt_estoque_minimo
From promocao_sos As s
	Inner Join promocao_sos_produto As p
		On p.cd_promocao_sos = s.cd_promocao_sos
	Inner Join promocao_sos_filial As a
		On a.cd_promocao_sos = p.cd_promocao_sos
	Inner Join produto_geral As g
		On g.cd_produto = p.cd_produto
	Inner Join vw_classificacao_produto As vw
		On vw.cd_subcategoria = g.cd_subcategoria
	Inner Join filial As l
		On l.cd_filial = a.cd_filial
	Left Outer Join promocao_sos_estoque_minimo As e
		On e.cd_promocao_sos = p.cd_promocao_sos
		And e.cd_filial = a.cd_filial
		And e.cd_produto = p.cd_produto
	Left Outer Join resumo_reposicao_estoque As r
		On r.cd_filial = a.cd_filial
	And r.cd_produto = p.cd_produto
Where p.cd_promocao_sos = :promocao" arguments=(("promocao", number))  sort="de_produto A nm_fantasia A " )
