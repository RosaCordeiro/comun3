table(column=(type=datetime updatewhereclause=yes name=dh_alteracao dbname="historico_promocao_estoque_min.dh_alteracao" dbalias="h.dh_alteracao" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo_anterior dbname="qt_estoque_minimo_anterior" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo_atual dbname="qt_estoque_minimo_atual" )
 column=(type=char(6) updatewhereclause=yes name=id_filial_matriz dbname="id_filial_matriz" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="nm_usuario" )
 column=(type=char(9) updatewhereclause=yes name=id_tipo_alteracao dbname="id_tipo_alteracao" )
 column=(type=long updatewhereclause=yes name=cd_motivo_alteracao dbname="historico_promocao_estoque_min.cd_motivo_alteracao" dbalias="h.cd_motivo_alteracao" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo dbname="motivo_alteracao_estq_minimo.de_motivo" dbalias="m.de_motivo" )
 retrieve="Select	h.dh_alteracao,
		coalesce(h.qt_estoque_minimo_anterior, 0) As qt_estoque_minimo_anterior,
		coalesce(h.qt_estoque_minimo_atual, 0) As qt_estoque_minimo_atual,
		(Case coalesce(h.id_alterado_filial_atual, 'N')
			When 'S' Then 'FILIAL'
			When 'N' Then 'MATRIZ'
			Else coalesce(h.id_alterado_filial_atual, 'N')
		End) id_filial_matriz,		
		coalesce(u.nm_usuario, 'N$$HEX1$$c300$$ENDHEX$$O IDENTIFICADO') As nm_usuario,
		(Case h.id_tipo_alteracao
			When 'A' Then 'ALTERA$$HEX2$$c700c300$$ENDHEX$$O'
			When 'I' Then 'INCLUS$$HEX1$$c300$$ENDHEX$$O'
			When 'D' Then 'EXCLUS$$HEX1$$c300$$ENDHEX$$O'
		End) As id_tipo_alteracao,
		h.cd_motivo_alteracao,
		m.de_motivo
From historico_promocao_estoque_min As h
	Left Outer Join motivo_alteracao_estq_minimo As m
		On m.cd_motivo = h.cd_motivo_alteracao
	Left Join usuario As u
		On u.nr_matricula = h.nr_matricula_alteracao
Where h.cd_promocao = :promocao
	And h.cd_filial = :filial
	And h.cd_produto = :produto
	And coalesce(h.qt_estoque_minimo_anterior, 0) <> coalesce(h.qt_estoque_minimo_atual, 0)
Order By h.dh_alteracao Desc" arguments=(("promocao", number),("filial", number),("produto", number)) )
