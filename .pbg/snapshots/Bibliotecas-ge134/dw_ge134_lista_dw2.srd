table(column=(type=long update=yes updatewhereclause=yes name=cd_promocao_sos dbname="promocao_sos_produto.cd_promocao_sos" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="promocao_sos_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="produto_geral.cd_fornecedor_usual" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=long updatewhereclause=yes name=cd_grupo_meta dbname="cd_grupo_meta" )
 column=(type=char(1) updatewhereclause=yes name=de_grupo_meta dbname="de_grupo_meta" )
 column=(type=long updatewhereclause=yes name=qt_meta_grupo dbname="qt_meta_grupo" )
 column=(type=long updatewhereclause=yes name=qt_meta_produto dbname="qt_meta_produto" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="qt_estoque_base" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo dbname="qt_estoque_minimo" )
 column=(type=long updatewhereclause=yes name=qt_estoque_matriz dbname="qt_estoque_matriz" )
 column=(type=long updatewhereclause=yes name=qt_estoque_filiais dbname="qt_estoque_filiais" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_pedido dbname="qt_estoque_base_pedido" )
 column=(type=long updatewhereclause=yes name=qt_pedido_filial dbname="qt_pedido_filial" )
 column=(type=long updatewhereclause=yes name=qt_compra dbname="qt_compra" )
 retrieve="select p.cd_promocao_sos,
       p.cd_produto,   
       g.de_produto + ' : ' + g.de_apresentacao_venda de_produto,   
       g.vl_fator_conversao,
       g.cd_fornecedor_usual,
       f.nm_razao_social,       
       0 cd_grupo_meta,
       '' de_grupo_meta,
		 0 qt_meta_grupo,
       0 qt_meta_produto,
       0 qt_estoque_base,
       0 qt_estoque_minimo,
       0 qt_estoque_matriz, 
       0 qt_estoque_filiais,
       0 qt_estoque_base_pedido,
       0 qt_pedido_filial,
       0 qt_compra
from promocao_sos_produto p,   
     produto_geral g,
     fornecedor f
where p.cd_promocao_sos = :promocao
  and g.cd_produto    = p.cd_produto
  and f.cd_fornecedor = g.cd_fornecedor_usual
" arguments=(("promocao", number))  sort="de_grupo_meta A de_produto A " )
