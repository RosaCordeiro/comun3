table(column=(type=char(1) updatewhereclause=yes name=id_agrupamento dbname="filial.id_agrupamento" dbalias="f.id_agrupamento" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="resumo_reposicao_estoque.cd_filial" dbalias="r.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="resumo_reposicao_estoque.cd_produto" dbalias="r.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_venda_periodo_1 dbname="resumo_reposicao_estoque.qt_venda_periodo_1" dbalias="r.qt_venda_periodo_1" )
 column=(type=long updatewhereclause=yes name=qt_venda_periodo_2 dbname="resumo_reposicao_estoque.qt_venda_periodo_2" dbalias="r.qt_venda_periodo_2" )
 column=(type=long updatewhereclause=yes name=qt_venda_periodo_3 dbname="resumo_reposicao_estoque.qt_venda_periodo_3" dbalias="r.qt_venda_periodo_3" )
 column=(type=long updatewhereclause=yes name=qt_venda_periodo_4 dbname="resumo_reposicao_estoque.qt_venda_periodo_4" dbalias="r.qt_venda_periodo_4" )
 column=(type=long updatewhereclause=yes name=qt_venda_periodo_5 dbname="resumo_reposicao_estoque.qt_venda_periodo_5" dbalias="r.qt_venda_periodo_5" )
 column=(type=long updatewhereclause=yes name=qt_venda_periodo_6 dbname="resumo_reposicao_estoque.qt_venda_periodo_6" dbalias="r.qt_venda_periodo_6" )
 column=(type=long updatewhereclause=yes name=qt_estoque_calculado dbname="resumo_reposicao_estoque.qt_estoque_calculado" dbalias="r.qt_estoque_calculado" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo dbname="resumo_reposicao_estoque.qt_estoque_minimo" dbalias="r.qt_estoque_minimo" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="resumo_reposicao_estoque.qt_estoque_base" dbalias="r.qt_estoque_base" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao dbname="resumo_reposicao_estoque.id_alteracao" dbalias="r.id_alteracao" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo_promocao dbname="qt_estoque_minimo_promocao" initial="0" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo_promocao_ant dbname="qt_estoque_minimo_promocao_ant" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo_matriz dbname="qt_estoque_minimo_matriz" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo_matriz_ant dbname="qt_estoque_minimo_matriz_ant" )
 retrieve="select		f.id_agrupamento,
       r.cd_filial,   
       f.nm_fantasia, 
       r.cd_produto,  
		 r.qt_venda_periodo_1,   
		 r.qt_venda_periodo_2,   
		 r.qt_venda_periodo_3,   
		 r.qt_venda_periodo_4,   
		 r.qt_venda_periodo_5,   
		 r.qt_venda_periodo_6,
       r.qt_estoque_calculado,
       r.qt_estoque_minimo,   
		 r.qt_estoque_base,
       r.id_alteracao,
       	0 qt_estoque_minimo_promocao,
		0 qt_estoque_minimo_promocao_ant,
	 	0 qt_estoque_minimo_matriz,
		0 qt_estoque_minimo_matriz_ant
from resumo_reposicao_estoque As r
	Inner Join filial As f
		On f.cd_filial = r.cd_filial
where r.cd_filial in (select cd_filial from promocao_sos_filial where cd_promocao_sos = :promocao)
  and r.cd_produto = :produto" arguments=(("produto", number),("promocao", number))  sort="id_agrupamento A nm_fantasia A " )
