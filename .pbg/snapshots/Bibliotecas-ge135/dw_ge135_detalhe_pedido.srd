table(column=(type=char(40) updatewhereclause=yes name=id_novo_calculo dbname="id_novo_calculo" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="pedido_filial_produto.qt_estoque_base" dbalias="p.qt_estoque_base" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo dbname="qt_estoque_minimo" )
 column=(type=long updatewhereclause=yes name=qt_dias_reforco dbname="pedido_filial_produto.qt_dias_reforco" dbalias="p.qt_dias_reforco" )
 column=(type=long updatewhereclause=yes name=qt_dias_reforco_estoque dbname="pedido_filial_produto.qt_dias_reforco_estoque" dbalias="p.qt_dias_reforco_estoque" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_cobertura_extra dbname="pedido_filial_produto.qt_cobertura_extra" dbalias="p.qt_cobertura_extra" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_reposicao dbname="pedido_filial_produto.cd_classe_reposicao" dbalias="p.cd_classe_reposicao" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_demanda_diaria dbname="pedido_filial_produto.qt_demanda_diaria" dbalias="p.qt_demanda_diaria" )
 column=(type=long updatewhereclause=yes name=qt_dias_cobertura dbname="pedido_filial_produto.qt_dias_cobertura" dbalias="p.qt_dias_cobertura" )
 column=(type=char(1) updatewhereclause=yes name=id_projeto_conexao dbname="id_projeto_conexao" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=long updatewhereclause=yes name=qt_sugerida dbname="pedido_filial_produto.qt_sugerida" dbalias="p.qt_sugerida" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_filial_produto.qt_pedida" dbalias="p.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_saldo_momento dbname="pedido_filial_produto.qt_saldo_momento" dbalias="p.qt_saldo_momento" )
 column=(type=long updatewhereclause=yes name=qt_rateada dbname="pedido_filial_produto.qt_rateada" dbalias="p.qt_rateada" )
 column=(type=long updatewhereclause=yes name=qt_eb_utilizado dbname="qt_eb_utilizado" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="g.vl_fator_conversao" )
 column=(type=long updatewhereclause=yes name=qt_saldo_cd dbname="pedido_filial_produto.qt_saldo_cd" dbalias="p.qt_saldo_cd" )
 column=(type=long updatewhereclause=yes name=qt_saldo_agendamento dbname="pedido_filial_produto.qt_saldo_agendamento" dbalias="p.qt_saldo_agendamento" )
 retrieve="SELECT	(select vl_parametro 
			 from parametro_loja 
			where cd_parametro = 'ID_UTILIZA_NOVO_CALCULO_ESTOQUE_BASE'
				and cd_filial = p.cd_filial) id_novo_calculo,
			p.qt_estoque_base,   
			(CASE WHEN p.qt_estoque_minimo > p.qt_estoque_base THEN p.qt_estoque_minimo ELSE 0 END) qt_estoque_minimo,
			p.qt_dias_reforco,   
			p.qt_dias_reforco_estoque,   
			p.qt_cobertura_extra,   
			p.cd_classe_reposicao,   
			p.qt_demanda_diaria,   
			p.qt_dias_cobertura,   
			coalesce(p.id_projeto_conexao , 'N') as id_projeto_conexao,
			p.qt_sugerida,
			p.qt_pedida,
			p.qt_saldo_momento,
			p.qt_rateada,
			0 qt_eb_utilizado,
			g.vl_fator_conversao,
			p.qt_saldo_cd,
			p.qt_saldo_agendamento
FROM pedido_filial_produto   p
inner join produto_geral g 
	on g.cd_produto = p.cd_produto
Where p.cd_filial 			= :filial
	and p.nr_pedido_filial	= :pedido
	and p.cd_produto 		= :produto

" arguments=(("filial", number),("pedido", number),("produto", number)) )
