table(column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="pedido_filial_distribuicao.cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_compra dbname="pedido_filial_distribuicao.vl_preco_compra" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_ordem dbname="pedido_filial_distribuicao.vl_preco_ordem" )
 column=(type=long updatewhereclause=yes name=nr_prioridade dbname="pedido_filial_distribuicao.nr_prioridade" )
 column=(type=long updatewhereclause=yes name=nr_prioridade_original dbname="pedido_filial_distribuicao.nr_prioridade_original" )
 column=(type=long updatewhereclause=yes name=qt_estoque_disponivel_distrib dbname="pedido_filial_distribuicao.qt_estoque_disponivel_distrib" )
 column=(type=long updatewhereclause=yes name=nr_rodada_pedido_eletronico dbname="nr_rodada_pedido_eletronico" )
 retrieve="SELECT	p.cd_distribuidora,
			f.nm_fantasia,
         	p.vl_preco_compra,   
         	p.vl_preco_ordem,   
         	p.nr_prioridade,   
         	p.nr_prioridade_original,   
         	p.qt_estoque_disponivel_distrib,
			coalesce(f.nr_rodada_pedido_eletronico, 8) nr_rodada_pedido_eletronico
FROM pedido_filial_distribuicao   p
inner join fornecedor f
	on f.cd_fornecedor = p.cd_distribuidora
Where p.cd_filial = :filial
	and p.nr_pedido_filial = :pedido
	and p.cd_produto		= :produto


" arguments=(("filial", number),("pedido", number),("produto", number))  sort="nr_prioridade A " )
