table(column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_distribuidora.dh_emissao" dbalias="a.dh_emissao" )
 column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="pedido_distribuidora.cd_distribuidora" dbalias="a.cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="pedido_distribuidora.nr_pedido_distribuidora" dbalias="a.nr_pedido_distribuidora" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_distribuidora_produto.qt_pedida" dbalias="b.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_atendida dbname="pedido_distribuidora_produto.qt_atendida" dbalias="b.qt_atendida" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="pedido_distribuidora_produto.qt_faturada" dbalias="b.qt_faturada" )
 column=(type=long updatewhereclause=yes name=nr_pedido_empurrado dbname="pedido_distribuidora_produto.nr_pedido_empurrado" dbalias="b.nr_pedido_empurrado" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="pedido_distribuidora.id_situacao" dbalias="a.id_situacao" )
 column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="pedido_filial_produto.cd_promocao_sos" dbalias="p.cd_promocao_sos" )
 column=(type=long updatewhereclause=yes name=nr_prioridade dbname="nr_prioridade" )
 column=(type=char(65) updatewhereclause=yes name=de_situacao dbname="de_situacao" )
 column=(type=char(60) updatewhereclause=yes name=de_motivo_rejeicao dbname="pedido_distribuidora_produto.de_motivo_rejeicao" dbalias="b.de_motivo_rejeicao" )
 column=(type=long updatewhereclause=yes name=qt_estoque_disponivel_distrib dbname="qt_estoque_disponivel_distrib" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_promocao dbname="promocao_sos.id_tipo_promocao" dbalias="s.id_tipo_promocao" )
 column=(type=datetime updatewhereclause=yes name=dh_arquivo_estoque dbname="dh_arquivo_estoque" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao_distribuidora dbname="pedido_distribuidora_produto.dh_atualizacao_distribuidora" dbalias="b.dh_atualizacao_distribuidora" )
 retrieve="select a.dh_emissao,   
       a.cd_distribuidora,   
       f.nm_fantasia,   
       a.nr_pedido_distribuidora,   
       b.qt_pedida,   
       b.qt_atendida,
       b.qt_faturada,   
       b.nr_pedido_empurrado,
       a.id_situacao,
	   p.cd_promocao_sos,
		coalesce(a.nr_rodada, 0) as nr_prioridade,
		'' de_situacao,
		b.de_motivo_rejeicao,
		coalesce(b.qt_estoque_disponivel_distrib , 0) as qt_estoque_disponivel_distrib,
		s.id_tipo_promocao,
		coalesce(b.dh_arquivo_estoque, dh_atualizacao_distribuidora) dh_arquivo_estoque,
		b.dh_atualizacao_distribuidora 
from pedido_distribuidora a
inner join pedido_distribuidora_produto b
	on b.cd_filial               			= a.cd_filial
	and b.nr_pedido_distribuidora 	= a.nr_pedido_distribuidora
inner join fornecedor f
	on f.cd_fornecedor 				= a.cd_distribuidora
inner join pedido_filial_produto p  
	on p.cd_filial = a.cd_filial	
	and p.nr_pedido_filial = a.nr_pedido_filial
	and p.cd_produto = b.cd_produto
left outer join promocao_sos s
	on s.cd_promocao_sos = p.cd_promocao_sos
where a.cd_filial 						= :filial
  and a.nr_pedido_filial 				= :pedido
  and b.cd_produto    					= :produto
  and not exists (select * from pedido_distribuidora x
						where x.cd_filial = a.cd_filial
						  and x.nr_pedido_distribuidora = a.nr_pedido_distribuidora
						  and x.de_motivo_rejeicao = 'DISTRIBUICAO'
						  and x.id_situacao = 'J')

union all

select pf.dh_emissao,   
       a.cd_distribuidora,   
       f.nm_fantasia,   
       0 nr_pedido_distribuidora,   
       a.qt_pedido as qt_pedida,   
       0 qt_atendida,
       0 qt_faturada,   
       p.nr_pedido_empurrado,
       'B' id_situacao,
	   p.cd_promocao_sos,
		pfd.nr_prioridade,
		 '[COMPRA BLOQUEADA] - PRE$$HEX1$$c700$$ENDHEX$$O DE COMPRA $$HEX1$$c900$$ENDHEX$$ MAIOR QUE O PRE$$HEX1$$c700$$ENDHEX$$O DE VENDA' de_situacao,
		'' de_motivo_rejeicao,
		0 qt_estoque_disponivel_distrib,
		s.id_tipo_promocao,
		coalesce(pfd.dh_arquivo_estoque, pfd.dh_atualizacao_distribuidora) dh_arquivo_estoque,
		pfd.dh_atualizacao_distribuidora 
from pedido_filial_prd_compra_bloq  a
inner join fornecedor f
	on f.cd_fornecedor = a.cd_distribuidora
inner join pedido_filial pf
	on pf.cd_filial = a.cd_filial
	and pf.nr_pedido_filial = a.nr_pedido_filial
inner join pedido_filial_produto p  
	on p.cd_filial = a.cd_filial	
	and p.nr_pedido_filial = a.nr_pedido_filial
	and p.cd_produto = a.cd_produto
inner join pedido_filial_distribuicao pfd
	on pfd.cd_filial 				= a.cd_filial
	and pfd.nr_pedido_filial 	= a.nr_pedido_filial
	and pfd.cd_distribuidora	= a.cd_distribuidora
	and pfd.cd_produto		= a.cd_produto
left outer join promocao_sos s
	on s.cd_promocao_sos = p.cd_promocao_sos
where a.cd_filial 						= :filial
  and a.nr_pedido_filial 				= :pedido
  and a.cd_produto    					= :produto

union all

select pf.dh_emissao,
'XXXX-XXXX' cd_distribuidora ,
'' nm_fantasia,
0 nr_pedido_distribuidora,
pfp.qt_pedida,
0 qt_atendida,
0 qt_faturada,
0 nr_pedido_empurrado,
'B' id_situacao,
0 cd_promocao_sos,
0 nr_prioridade,
'[COMPRA BLOQUEADA] - PRODUTO NA LISTA DE BLOQUEIO DE COMPRAS' de_situacao,
pfp.de_compra_bloqueada as de_motivo_rejeicao,
0 qt_estoque_disponivel_distrib,
'' id_tipo_promocao,
convert(datetime, '1900-01-01') dh_arquivo_estoque,
convert(datetime, '1900-01-01') dh_atualizacao_distribuidora
from  pedido_filial_produto pfp  
inner join pedido_filial pf
	on pf.cd_filial			= pfp.cd_filial
	and pf.nr_pedido_filial = pfp.nr_pedido_filial
left outer join promocao_sos s
	on s.cd_promocao_sos = pfp.cd_promocao_sos
where pf.cd_filial 						=	:filial
  and pf.nr_pedido_filial 				=	:pedido
  and pfp.cd_produto    				=	:produto
  and pfp.id_compra_bloqueada = 'S'" arguments=(("filial", number),("pedido", number),("produto", number))  sort="nr_prioridade A nr_pedido_distribuidora A " )
