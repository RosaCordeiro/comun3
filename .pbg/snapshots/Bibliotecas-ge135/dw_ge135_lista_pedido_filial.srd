table(column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_filial.dh_emissao" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_pedido_filial dbname="pedido_filial.nr_pedido_filial" )
 column=(type=long updatewhereclause=yes name=qt_saldo_momento dbname="pedido_filial_produto.qt_saldo_momento" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_filial_produto.qt_pedida" )
 column=(type=datetime updatewhereclause=yes name=dh_geracao dbname="pedido_filial.dh_geracao" )
 column=(type=long updatewhereclause=yes name=nr_prioridade_distribuidora dbname="nr_prioridade_distribuidora" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_reposicao dbname="cd_classe_reposicao" )
 retrieve="select	a.dh_emissao,
		a.cd_filial,
		f.nm_fantasia,
		a.nr_pedido_filial,
		b.qt_saldo_momento,
		b.qt_pedida,
		a.dh_geracao,
		(Case
			When a.nr_prioridade_distribuidora <= 0 Then 0
			Else a.nr_prioridade_distribuidora - 1
		End) As nr_prioridade_distribuidora,
		c.cd_unidade_federacao,
		coalesce(r.cd_classe_reposicao, 'X') cd_classe_reposicao
from pedido_filial As a
	inner join pedido_filial_produto b
		on b.cd_filial        = a.cd_filial
		and b.nr_pedido_filial = a.nr_pedido_filial
	left outer Join resumo_reposicao_estoque As r
		On r.cd_filial = b.cd_filial
		And r.cd_produto = b.cd_produto
	inner join filial As f
		on f.cd_filial  = a.cd_filial
	inner join cidade As c
		on c.cd_cidade = f.cd_cidade
where a.dh_emissao between :adt_inicio and :adt_fim
	and b.cd_produto = :al_produto" arguments=(("adt_inicio", date),("adt_fim", date),("al_produto", number))  sort="dh_emissao A nm_fantasia A nr_pedido_filial A " )
