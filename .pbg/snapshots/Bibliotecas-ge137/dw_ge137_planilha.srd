 retrieve="Select   pg.de_codigo_barras,
            pg.cd_produto,
            pg.de_produto,
            pg.de_apresentacao_venda,
		   cast(pg.dh_inclusao_produto as date) as dh_inclusao_produto,
  		   ta.de_apresentacao,
		   pg.cd_grupo_psico,
		   pg.cd_produto_sap,
		   unVenda.de_unidade_medida as Unidade_Venda,
            unCompra.de_unidade_medida as Unidade_Compra,
            case pg.id_situacao
                when 'A' then 'ATIVO'
                when 'P' then 'PENDENTE' 
                when 'I' then 'INATIVO'
		   end as id_situacao,
	   	   cp.cd_grupo,
            cp.de_grupo,
            cp.de_subgrupo,
            cp.de_categoria,
            cp.de_subcategoria,
            pc.cd_mix_produto,
            mx.de_mix_produto,
            pg.vl_preco_venda_atual / pg.vl_fator_conversao vl_preco_venda_atual,
		   pg.dh_preco_venda_atual, 
            pg.pc_desconto_atual,
            pg.id_tipo_desconto_atual,
            0.00 pc_desconto_sos,
            pc.vl_custo_gerencial vl_custo_medio,
            pc.vl_custo_gerencial_geral vl_custo_gerencial,
            0 qt_saldo_matriz,
            0 qt_saldo_filiais,
	   	   0 qt_saldo_transito,  
            isnull (qt_estoque_base, 0 )    qt_estoque_base_filiais, 
            convert(char(10), pc.dh_ultima_compra, 103) dt_ultima_entrada,
            0 qt_venda_mes_1,
            0 qt_venda_mes_2,
            0 qt_venda_mes_3,
            0 qt_venda_mes_4,
            0 qt_venda_mes_5,
            0 qt_venda_mes_6,
            0 qt_venda_mes_base,
            Case pc.id_tipo_reposicao_estoque
              when 'S' then 'SAZONAL'
              when 'E' then 'ESTAVEL'
            End as demanda,
            pg.cd_fornecedor_usual,
		  coalesce(fo.cd_fornecedor_sap,'') as cd_fornecedor_sap,
            fo.nm_razao_social,
            vw.nr_divisao,
		   vw.nm_divisao,
		   u.nm_usuario as nm_comprador,
            pg.id_situacao_pis_cofins,
            pc.id_pagamento_apos_venda,
            pg.id_lei_generico,
            pc.vl_preco_reposicao,
		   pc.dh_preco_reposicao,
            pg.vl_fator_conversao,
            pg.id_superfluo,
            pg.nr_embalagem_padrao caixa_embarque,
            pc.pc_desconto_fornecedor,
            pc.cd_produto_fornecedor,
            pg.cd_marca,
            c.de_marca,
            pg.nr_classificacao_fiscal,
            pg.pc_ipi,
            pg.cd_st_origem,
            op.de_origem_produto,
            0.00 as pc_comissao_normal,
            0.00 as pc_comissao_seletiva,
		   pg.qt_largura_cm largura,   
            pg.qt_altura_cm altura,   
            pg.qt_profundidade_cm profundidade,   
		   pg.cd_planograma,		
            plano.de_planograma,
		   pc.cd_curva_abc_perini as classe_cd,
		   pc.cd_curva_abc_filiais as classe_empresa,
		   '' as de_substancia,
		   case when cm.cd_categ_mercadologica > 0 then rtrim(ltrim(cast(cm.cd_categ_mercadologica as char)))||' - '||cm.de_categoria_mercadologica else null end as de_categoria_mercadologica,
			pg.cd_grupo_mercadoria_sap as cd_grupo_mercadoria,
			gm.de_grupo as de_grupo_mercadoria,
		   pg.cd_arvore_mercadologica_sap,
		   am.de_arvore_mercadologica ,
		   pg.qt_prazo_reposicao,
			c.id_marca_propria,
			pc.cd_segmento_ims,
			si.de_segmento,
			pg.cd_area_farmacia,
			af.de_area_farmacia,
			pg.cd_tarja,
			tj.de_tarja,
			pg.cd_cronicidade,
			cr.de_cronicidade,
			pg.cd_cest, 
	         0 as segreg_merc_trans,
	         0 as segreg_devolucao,
	         0 as segreg_recebimento
From produto_geral As pg
    Inner Join produto_central As pc
        On pc.cd_produto = pg.cd_produto 
    Inner Join vw_classificacao_produto As cp
        On cp.cd_subcategoria = pg.cd_subcategoria
    Inner Join fornecedor As fo
        On fo.cd_fornecedor = pg.cd_fornecedor_usual
    Inner Join mix_produto As mx
        On pc.cd_mix_produto = mx.cd_mix_produto
    Left Outer Join marca_produto As c
        On c.cd_marca = pg.cd_marca
    Left Outer Join origem_produto As op
        On op.cd_origem_produto = pg.cd_st_origem
	Left Outer Join vw_divisao_fornecedor_produto as vw
		On vw.cd_produto = pg.cd_produto
		and vw.cd_fornecedor = pg.cd_fornecedor_usual
	Left Outer Join usuario As u
        On u.nr_matricula = vw.nr_matricula_comprador	
	Left Outer Join unidade_medida as unVenda
        On unVenda.cd_unidade_medida = pg.cd_unidade_medida_venda 
    Left Outer Join unidade_medida as unCompra
        On unCompra.cd_unidade_medida = pg.cd_unidade_medida_compra 
	left outer join categoria_planograma as plano
		on pg.cd_planograma = plano.cd_planograma  
   	left join resumo_estoque_base_filiais as re
		on re.cd_produto = pg.cd_produto
	left outer join tipo_apresentacao_produto as ta
		on ta.id_apresentacao = pg.id_apresentacao
	left outer join categoria_mercadologica as cm
		on cm.cd_categ_mercadologica = pc.cd_categ_mercadologica
	Left Outer Join segmento_ims As si
		On si.cd_segmento = pc.cd_segmento_ims 
	Left Outer Join area_farmacia As af
		On af.cd_area_farmacia = pg.cd_area_farmacia 
	Left Outer Join tarja As tj 
		On tj.cd_tarja = pg.cd_tarja 
	Left Outer Join cronicidade As cr 
		On cr.cd_cronicidade = pg.cd_cronicidade 
	Left Outer join arvore_mercadologica am 
		On am.cd_arvore_mercadologica = pg.cd_arvore_mercadologica_sap 
	Left Outer join dbo.grupo_mercadorias gm 
		On gm.cd_grupo = pg.cd_grupo_mercadoria_sap "  sort="cd_produto A " )
