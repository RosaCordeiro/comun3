table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_planograma dbname="categoria_planograma.cd_planograma" )
 column=(type=char(50) update=yes updatewhereclause=yes name=de_planograma dbname="categoria_planograma.de_planograma" )
 column=(type=char(1) updatewhereclause=yes name=id_selecao dbname="id_selecao" initial="N" values="	S/	N" )
 retrieve="  SELECT c.cd_planograma,   
         c.de_planograma ,
		(Case (select p.cd_planograma
				from analise_spaceman_planograma p 	
				   where p.cd_planograma = c.cd_planograma
							and p.nr_analise = :analise) when null then 'N' else 'S' End) as id_selecao
    FROM categoria_planograma c
	
" update="categoria_planograma" updatewhere=1 updatekeyinplace=no arguments=(("analise", number))  sort="de_planograma A " )
