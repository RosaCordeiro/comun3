table(column=(type=long updatewhereclause=yes name=cd_produto dbname="resumo_produto.cd_produto" dbalias=".cd_produto" )
 column=(type=datetime updatewhereclause=yes name=dh_resumo dbname="resumo_produto.dh_resumo" dbalias=".dh_resumo" )
 column=(type=long updatewhereclause=yes name=qt_saldo dbname="qt_saldo" )
 column=(type=long updatewhereclause=yes name=qt_venda dbname="qt_venda" )
 column=(type=long updatewhereclause=yes name=qt_devolucao_venda dbname="qt_devolucao_venda" )
 retrieve="SELECT  cd_produto,
	   dh_resumo,
       sum(qt_saldo) qt_saldo,
       sum(qt_venda) qt_venda, 
	sum(qt_devolucao_venda) qt_devolucao_venda	
FROM resumo_produto   (INDEX idx_dh_resumo  )    
WHERE  (qt_saldo>0 OR 	qt_venda>0 OR qt_devolucao_venda>0)
AND        dh_resumo = :mes
GROUP BY  cd_produto, dh_resumo
" arguments=(("mes", date))  sort="dh_resumo D cd_produto A " )
