table(column=(type=long updatewhereclause=yes name=cd_filial dbname="resumo_reposicao_estoque.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_perfil_filial dbname="filial.cd_perfil_filial" )
 column=(type=char(40) updatewhereclause=yes name=de_perfil_filial dbname="perfil_filial.de_perfil_filial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="resumo_reposicao_estoque.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_venda_periodo_1 dbname="resumo_reposicao_estoque.qt_venda_periodo_1" )
 column=(type=long updatewhereclause=yes name=qt_venda_periodo_2 dbname="resumo_reposicao_estoque.qt_venda_periodo_2" )
 column=(type=long updatewhereclause=yes name=qt_venda_periodo_3 dbname="resumo_reposicao_estoque.qt_venda_periodo_3" )
 column=(type=long updatewhereclause=yes name=qt_venda_periodo_4 dbname="resumo_reposicao_estoque.qt_venda_periodo_4" )
 column=(type=long updatewhereclause=yes name=qt_venda_periodo_5 dbname="resumo_reposicao_estoque.qt_venda_periodo_5" )
 column=(type=long updatewhereclause=yes name=qt_venda_periodo_6 dbname="resumo_reposicao_estoque.qt_venda_periodo_6" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_definido dbname="resumo_reposicao_estoque.qt_estoque_base_definido" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="resumo_reposicao_estoque.qt_estoque_base" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao dbname="resumo_reposicao_estoque.id_alteracao" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_novo dbname="resumo_reposicao_estoque.qt_estoque_base_novo" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao dbname="resumo_reposicao_estoque.dh_alteracao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_alteracao dbname="resumo_reposicao_estoque.nr_matricula_alteracao" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_bloqueio dbname="resumo_reposicao_estoque.dh_termino_bloqueio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_bloqueio_novo dbname="resumo_reposicao_estoque.dh_termino_bloqueio_novo" )
 column=(type=long updatewhereclause=yes name=qt_dias_bloqueio dbname="qt_dias_bloqueio" )
 column=(type=char(1) updatewhereclause=yes name=nm_alteracao dbname="nm_alteracao" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao dbname="parametro.dh_movimentacao" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_reposicao dbname="resumo_reposicao_estoque.cd_classe_reposicao" )
 retrieve="select r.cd_filial,   
       f.nm_fantasia, 
       f.cd_perfil_filial,
       p.de_perfil_filial,
       r.cd_produto,  
		 r.qt_venda_periodo_1,   
		 r.qt_venda_periodo_2,   
		 r.qt_venda_periodo_3,   
		 r.qt_venda_periodo_4,   
		 r.qt_venda_periodo_5,   
		 r.qt_venda_periodo_6,
       r.qt_estoque_base_definido,
		 r.qt_estoque_base,
       r.id_alteracao,
       r.qt_estoque_base qt_estoque_base_novo,
       r.dh_alteracao,
       r.nr_matricula_alteracao,
       r.dh_termino_bloqueio,
       r.dh_termino_bloqueio dh_termino_bloqueio_novo,
       0 qt_dias_bloqueio,
       '' nm_alteracao,
       a.dh_movimentacao,
		r.cd_classe_reposicao
from resumo_reposicao_estoque r,   
     filial f,
     perfil_filial p,
     produto_central c,
     parametro a
where r.cd_produto 		= :produto
  and f.id_situacao			= 'A'
  and f.cd_filial        		= r.cd_filial
  and p.cd_perfil_filial 	= f.cd_perfil_filial
  and c.cd_produto 		= r.cd_produto
  and c.cd_mix_produto in (select m.cd_mix_produto
                           from mix_produto_filial m
                           where m.cd_filial = r.cd_filial)

union

select r.cd_filial,   
       f.nm_fantasia, 
       f.cd_perfil_filial,
       p.de_perfil_filial,
       r.cd_produto,  
		 r.qt_venda_periodo_1,   
		 r.qt_venda_periodo_2,   
		 r.qt_venda_periodo_3,   
		 r.qt_venda_periodo_4,   
		 r.qt_venda_periodo_5,   
		 r.qt_venda_periodo_6,
       r.qt_estoque_base_definido,
		 r.qt_estoque_base,
       r.id_alteracao,
       r.qt_estoque_base qt_estoque_base_novo,
       r.dh_alteracao,
       r.nr_matricula_alteracao,
       r.dh_termino_bloqueio,
       r.dh_termino_bloqueio dh_termino_bloqueio_novo,
       0 qt_dias_bloqueio,
       '' nm_alteracao,
       a.dh_movimentacao,
		r.cd_classe_reposicao
from resumo_reposicao_estoque r,   
     filial f,
     perfil_filial p,
     produto_central c,
     parametro a,
	 produto_geral g
where r.cd_produto 		 = :produto
  and f.id_situacao			= 'A'
  and f.cd_filial        = r.cd_filial
  and p.cd_perfil_filial = f.cd_perfil_filial
  and c.cd_produto 		 = r.cd_produto
  and g.cd_produto		 = r.cd_produto
  and f.id_pedido_centralizado 			= 'N'	
  and substring(g.cd_subcategoria, 1,1) = '5'
  

 
" arguments=(("produto", number))  sort="cd_perfil_filial A nm_fantasia A " )
