table(column=(type=long updatewhereclause=yes name=cd_filial dbname="saldo_produto.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="saldo_produto.qt_saldo_final" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_total dbname="vl_custo_total" )
 retrieve="select s.cd_filial,
		f.nm_fantasia,
		s.qt_saldo_final,
		s.qt_saldo_final * s.vl_custo_medio as  vl_custo_total
from saldo_produto s
Inner Join filial f
	On f.cd_filial = s.cd_filial
where  s.dh_saldo  = f.dh_ultimo_saldo
  and s.cd_produto = :produto
  and (f.id_situacao = 'A' or s.qt_saldo_final > 0)
  " arguments=(("produto", number))  sort="qt_saldo_final D " )
