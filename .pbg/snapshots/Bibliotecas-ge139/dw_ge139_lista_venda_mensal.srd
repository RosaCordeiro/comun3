table(column=(type=char(3) updatewhereclause=yes name=id_rede dbname="resumo_produto.id_rede" )
 column=(type=datetime updatewhereclause=yes name=dh_resumo dbname="resumo_produto.dh_resumo" )
 column=(type=long updatewhereclause=yes name=qt_venda dbname="qt_venda" )
 column=(type=long updatewhereclause=yes name=qt_resgate_clube dbname="qt_resgate_clube" )
 retrieve="select	id_rede,
	   		dh_resumo,
       		qt_venda - qt_devolucao_venda qt_venda,
			0 qt_resgate_clube
from resumo_produto
where cd_produto = :produto
  and dh_resumo between :inicio and :termino" arguments=(("produto", number),("inicio", date),("termino", date))  sort="dh_resumo D id_rede A " )
