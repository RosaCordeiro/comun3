table(column=(type=long updatewhereclause=yes name=cd_filial dbname="saldo_produto.cd_filial" dbalias="s.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="saldo_produto.qt_saldo_final" dbalias="s.qt_saldo_final" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_total dbname="vl_custo_total" )
 retrieve="select s.cd_filial,
		f.nm_fantasia,
		s.qt_saldo_final,
		s.qt_saldo_final * s.vl_custo_medio as  vl_custo_total
from filial f,
	 saldo_produto s
where s.cd_filial = f.cd_filial
  and s.dh_saldo  = f.dh_ultimo_saldo
  and s.cd_produto = :produto
  and (f.id_situacao = 'A' or s.qt_saldo_final > 0)
  " arguments=(("produto", number))  sort="qt_saldo_final D " )
