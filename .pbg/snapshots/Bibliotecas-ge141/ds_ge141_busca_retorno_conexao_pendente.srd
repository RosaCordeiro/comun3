table(column=(type=char(27) updatewhereclause=yes name=nm_arquivo dbname="nm_arquivo" )
 retrieve="SELECT
	CASE WHEN p.id_pedido_individual = 'S' 
		THEN p.de_prefixo_pedido + f.nr_cgc + '_' + RIGHT('00000' + CONVERT(VARCHAR, p.nr_pedido_individual), 5) + '.ped'
		ELSE p.de_prefixo_pedido + f.nr_cgc + '_' + RIGHT('00000' + CONVERT(VARCHAR, p.nr_pedido_filial), 5) + '.ped'
	END AS nm_arquivo
FROM pedido_conexao_controle As p
	INNER JOIN filial As f
		ON f.cd_filial = p.cd_filial
	INNER JOIN conexao c
		ON c.cd_fornecedor_envio = p.cd_fornecedor
WHERE CAST(dh_envio As Date) Between :data_inicio And :data_fim
	AND	p.dh_retorno is null
	AND	p.cd_fornecedor = :cd_fornecedor_conexao
ORDER BY CAST(p.dh_envio As Date), c.de_projeto_conexao, p.de_prefixo_pedido, p.cd_filial, p.nr_pedido_filial" arguments=(("data_inicio", date),("data_fim", date),("cd_fornecedor_conexao", string)) )
