table(column=(type=date updatewhereclause=yes name=dh_envio dbname="dh_envio" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="nr_cgc" )
 column=(type=long updatewhereclause=yes name=nr_pedido_filial dbname="nr_pedido_filial" )
 column=(type=char(20) updatewhereclause=yes name=de_projeto_conexao dbname="de_projeto_conexao" )
 column=(type=char(3) updatewhereclause=yes name=de_prefixo_pedido dbname="de_prefixo_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_retorno dbname="dh_retorno" )
 column=(type=char(30) updatewhereclause=yes name=de_rejeicao dbname="de_rejeicao" )
 column=(type=long updatewhereclause=yes name=nr_pedido_individual dbname="nr_pedido_individual" )
 column=(type=char(27) updatewhereclause=yes name=nm_arquivo dbname="nm_arquivo" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" values="	S/	N" )
 retrieve="Select	Cast(p.dh_envio As Date) As dh_envio,
		p.cd_filial,
		f.nm_fantasia,
		f.nr_cgc,
		p.nr_pedido_filial,
		c.de_projeto_conexao,
		p.de_prefixo_pedido,
		p.dh_retorno,
		p.de_rejeicao,
		p.nr_pedido_individual,
		CASE WHEN p.id_pedido_individual = 'S' 
			THEN p.de_prefixo_pedido + f.nr_cgc + '_' + RIGHT('00000' + CONVERT(VARCHAR, p.nr_pedido_individual), 5) + '.ped'
			ELSE p.de_prefixo_pedido + f.nr_cgc + '_' + RIGHT('00000' + CONVERT(VARCHAR, p.nr_pedido_filial), 5) + '.ped'
		END AS nm_arquivo,
		'N' As id_selecionar
From pedido_conexao_controle As p
	Inner Join filial As f
		On f.cd_filial = p.cd_filial
	Inner Join conexao c
		On c.cd_fornecedor_envio = p.cd_fornecedor
Where Cast(dh_envio As Date) Between :inicio And :termino
Order By Cast(p.dh_envio As Date), c.de_projeto_conexao, p.de_prefixo_pedido, p.cd_filial, p.nr_pedido_filial" arguments=(("inicio", datetime),("termino", datetime)) )
