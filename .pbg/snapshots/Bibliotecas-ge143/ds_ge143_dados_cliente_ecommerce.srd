table(column=(type=char(60) updatewhereclause=yes name=de_endereco_entrega dbname="pedido_drogaexpress.de_endereco_entrega" )
 column=(type=char(20) updatewhereclause=yes name=de_bairro_entrega dbname="pedido_drogaexpress.de_bairro_entrega" )
 column=(type=char(20) updatewhereclause=yes name=nr_telefone_entrega dbname="pedido_drogaexpress.nr_telefone_entrega" )
 column=(type=char(60) updatewhereclause=yes name=nm_cliente_entrega dbname="pedido_drogaexpress.nm_cliente_entrega" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep_entrega dbname="pedido_drogaexpress.nr_cep_entrega" )
 column=(type=char(30) updatewhereclause=yes name=nm_cidade_entrega dbname="pedido_drogaexpress.nm_cidade_entrega" )
 column=(type=char(11) updatewhereclause=yes name=nr_cpf_cheque dbname="pedido_drogaexpress.nr_cpf_cheque" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf_entrega dbname="pedido_drogaexpress.cd_uf_entrega" )
 column=(type=char(6) updatewhereclause=yes name=nr_endereco_entrega dbname="pedido_drogaexpress.nr_endereco_entrega" )
 retrieve="  SELECT p.de_endereco_entrega,   
         p.de_bairro_entrega,   
         p.nr_telefone_entrega,   
         p.nm_cliente_entrega,   
         p.nr_cep_entrega,   
         p.nm_cidade_entrega,   
         p.nr_cpf_cheque,
		 p.cd_uf_entrega,
		p.nr_endereco_entrega
    FROM pedido_drogaexpress   p, nf_venda n
where n.nr_pedido_drogaexpress	= p.nr_pedido_drogaexpress
  and n.nr_pedido_ecommerce		is not null
  and p.id_situacao				<> 'X'
  and n.cd_filial				= :filial
  and n.nr_nf					= :nota
  and n.de_especie 				= :especie
  and n.de_serie				= :serie
  

" arguments=(("filial", number),("nota", number),("especie", string),("serie", string)) )
