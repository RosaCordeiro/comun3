table(column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="distribuidora_produto.cd_distribuidora" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_repasse_icms dbname="pc_repasse_icms" )
 column=(type=decimal(28) updatewhereclause=yes name=vl_melhor_compra_dist dbname="vl_melhor_compra_dist" )
 retrieve="select	d.cd_distribuidora,
		isnull(vl_preco_novo, vl_preco_atual) vl_preco_unitario,
		isnull(pc_desconto_novo, pc_desconto_atual) pc_desconto, 
		isnull(vl_icms_st, 0) vl_icms_st,	
		isnull(pc_repasse_icms, 0) pc_repasse_icms,	
		sum(round(round(isnull(vl_preco_novo, vl_preco_atual) * ((100 - isnull(pc_desconto_novo, pc_desconto_atual)) / 100), 2) * ((100 - isnull(pc_repasse_icms, 0)) / 100), 2) + isnull(vl_icms_st, 0)) vl_melhor_compra_dist
from distribuidora_produto d
where d.cd_unidade_federacao in (select cd_unidade_federacao from cidade c, filial f
											 where f.cd_cidade	= c.cd_cidade
												and f.cd_filial		= :filial)
  and d.id_situacao = 'A'
  and d.cd_distribuidora in (select cd_distribuidora from filial_distribuidora
									where cd_filial = :filial
								  	   and id_situacao = 'A')
  and d.cd_produto = :produto
group by d.cd_distribuidora,
		isnull(vl_preco_novo, vl_preco_atual),
		isnull(pc_desconto_novo, pc_desconto_atual), 
		isnull(vl_icms_st, 0),	
		isnull(pc_repasse_icms, 0)" arguments=(("filial", number),("produto", number))  sort="vl_melhor_compra_dist A " )
