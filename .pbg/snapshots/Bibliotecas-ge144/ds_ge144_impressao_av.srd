 retrieve="SELECT	pde.nr_pedido_drogaexpress,   
			pde.cd_tipo_venda,   
			pde.nr_matricula_vendedor,   
			pde.nr_matricula_operador,   
			pde.dh_atualizacao_pedido,   
			pde.vl_total_pedido,
			pde.vl_total_produtos,
			pde.vl_taxa_entrega,
			pde.vl_pago,
			pde.de_especie_doc_fiscal,
			pde.dh_entrega_marcada,
			coalesce( pde.de_observacao, '' ) as de_observacao,
			pde.cd_forma_pagamento,
			pde.nr_cartao_credito,
			pde.cd_seguranca_cartao,
			pde.dh_validade_cartao,
			pde.cd_cliente_drogaexpress,   
			pde.pc_desconto_unimed,
			pde.pc_desconto_unimed_drogaria,
			pde.pc_desconto,
			pde.vl_cobrar,
			cl.nm_cliente,   
			pde.de_endereco_entrega,
			pde.nr_endereco_entrega as nr_endereco_entrega,
			pde.de_complemento_endereco as de_complemento_entrega,
			pde.de_referencia_entrega,
			pde.de_bairro_entrega,
			pde.nr_telefone_entrega,
			clde.nr_cep,
			pde.cd_cliente,
			isnull(pde.nm_cliente_entrega, clde.nm_cliente) as nm_cliente,
			usuario_a.nm_usuario usuario_a,
			usuario_b.nm_usuario usuario_b,
			ppde.cd_produto,
			ppde.qt_pedida,
			ppde.id_alteracao_preco,
			ppde.vl_preco_tabela,
			ppde.pc_desconto_tabela,
			ppde.vl_preco_praticado,
			pg.de_produto,
			pg.de_apresentacao_venda,
			pde.nm_cartao_credito,
			pde.nm_cliente_cartao,
			pde.nm_cliente_cheque,
			pde.nr_cpf_cheque,
			clde.nr_telefone_principal,
			clde.nr_telefone_adicional,
			coalesce( clde.de_observacao, '' ) as cliente_de_observacao,
			pde.id_tipo_pedido
    FROM cliente_drogaexpress clde
			INNER JOIN pedido_drogaexpress pde
			    ON pde.cd_cliente_drogaexpress = clde.cd_cliente_drogaexpress
			INNER JOIN produto_pedido_drogaexpress ppde
			   ON pde.nr_pedido_drogaexpress  = ppde.nr_pedido_drogaexpress
			LEFT OUTER JOIN cliente cl
			   ON pde.cd_cliente = cl.cd_cliente
			INNER JOIN usuario usuario_a
			    ON pde.nr_matricula_vendedor = usuario_a.nr_matricula
			INNER JOIN usuario usuario_b
			    ON pde.nr_matricula_operador = usuario_b.nr_matricula
			INNER JOIN produto_geral pg
			    ON ppde.cd_produto = pg.cd_produto
   WHERE pde.nr_pedido_drogaexpress  = :pedido" retrieve.asneeded=yes arguments=(("pedido", string))  sort="de_produto A " )
