 column=(type=char(2) updatewhereclause=yes name=cd_uf_filial dbname="cidade.cd_uf_filial" )
 column=(type=long updatewhereclause=yes name=cd_filial_retirada dbname="cd_filial_retirada" )
 column=(type=datetime updatewhereclause=yes name=dh_estimativa_entrega dbname="pedido_drogaexpress.dh_estimativa_entrega" )
 column=(type=char(255) updatewhereclause=yes name=de_descricao_filial_retirada dbname="de_descricao_filial_retirada" )
 retrieve="SELECT	pde.nr_pedido_drogaexpress,   
			pde.cd_tipo_venda,   
			pde.nr_matricula_vendedor,   
			pde.nr_matricula_operador,   
			pde.dh_emissao,   
			pde.vl_total_pedido,
			pde.vl_total_produtos,
			pde.vl_taxa_entrega,
			pde.vl_pago,
			pde.de_especie_doc_fiscal,
			pde.dh_entrega_marcada, 
			pde.de_observacao,
			pde.cd_forma_pagamento,
			pde.nr_cartao_credito,
			pde.cd_seguranca_cartao,
			pde.dh_validade_cartao,
			pde.cd_cliente_drogaexpress,   
			pde.pc_desconto_unimed,
			pde.pc_desconto_unimed_drogaria,
			pde.pc_desconto,
			pde.vl_cobrar,
			pde.nm_cliente_entrega, 
			pde.de_endereco_entrega || ', N$$HEX1$$ba00$$ENDHEX$$: ' || pde.nr_endereco_entrega as de_endereco_entrega,
			pde.de_complemento_endereco,
			pde.de_bairro_entrega,
			pde.de_referencia_entrega,
			pde.nr_telefone_entrega,
			pde.nr_telefone_contato,
			clde.nr_cep,
			pde.cd_cliente,
			usuario_a.nm_usuario usuario_a,
			usuario_b.nm_usuario usuario_b,
			ppde.cd_produto,
			(Select Right(cb.de_codigo_barras,6) From codigo_barras_produto cb Where ppde.cd_produto = cb.cd_produto and cb.id_principal = 'S') As de_codigo_barras,
			ppde.qt_pedida,
			ppde.id_alteracao_preco,
			ppde.vl_preco_tabela,
			ppde.pc_desconto_tabela,
			ppde.vl_preco_praticado,
			pg.de_produto,
			pg.de_apresentacao_venda,
			pde.nm_cartao_credito,
			pde.nm_cliente_cartao,
			pde.nr_pedido_ecommerce,
			pde.nm_transportadora,
			pde.nm_cidade_entrega,
			pde.cd_uf_entrega,
			pde.cd_filial_ecommerce,
			ppde.nr_sequencial,
			ppde.nr_requisicao_manip,
			ppde.de_produto,
			pde.nr_cep_entrega,
			LEFT(pde.nr_cpf_cheque, 3) || '******' || RIGHT(pde.nr_cpf_cheque, 2) as nr_cpf,
			coalesce(pde.nr_pedido_ecommerce_site, cast(pde.nr_pedido_ecommerce as varchar)) as nr_pedido_ecommerce_site,
			pde.id_plataforma_ecommerce,
			pde.id_rede_ecommerce,
			pde.nr_vending_machine,
			Cast( '' as varchar(40)) as de_local_vmpay,
			pde.nm_cliente_cheque,
			pde.id_tipo_pedido,
			fi.cd_filial,
			fi.nm_fantasia as nm_fantasia_filial,
			fi.de_endereco as de_endereco_filial,
			fi.de_bairro as de_bairro_filial,
			fi.nr_cep as nr_cep_filial,
			COALESCE(fi.nr_endereco, 0) as nr_endereco_filial,
			ci.nm_cidade as nm_cidade_filial,
			ci.cd_unidade_federacao as cd_uf_filial,
			coalesce(pde.cd_filial_retirada,0) as cd_filial_retirada,
			pde.dh_estimativa_entrega,
			CAse When pde.de_descricao_filial_retirada is null then (select fx.nm_fantasia from filial fx where fx.cd_filial = pde.cd_filial_retirada) Else pde.de_descricao_filial_retirada end as de_descricao_filial_retirada
    FROM cliente_drogaexpress clde
			INNER JOIN pedido_drogaexpress pde
				ON pde.cd_cliente_drogaexpress = clde.cd_cliente_drogaexpress
			LEFT OUTER JOIN cliente cl
			  ON pde.cd_cliente = cl.cd_cliente
			INNER JOIN usuario usuario_a
				ON pde.nr_matricula_vendedor = usuario_a.nr_matricula
			INNER JOIN usuario usuario_b
				ON pde.nr_matricula_operador = usuario_b.nr_matricula
			INNER JOIN produto_pedido_drogaexpress ppde
				ON pde.nr_pedido_drogaexpress  = ppde.nr_pedido_drogaexpress
			INNER JOIN produto_geral pg
				ON ppde.cd_produto = pg.cd_produto
			INNER JOIN filial fi
				ON fi.cd_filial = pde.cd_filial
			INNER JOIN cidade ci
				ON ci.cd_cidade = fi.cd_cidade
   WHERE pde.nr_pedido_drogaexpress  = :pedido
" retrieve.asneeded=yes arguments=(("pedido", string))  sort="de_produto A " )
