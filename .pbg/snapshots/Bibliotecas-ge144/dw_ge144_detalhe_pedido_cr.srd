table(column=(type=char(11) updatewhereclause=yes name=nr_pedido_drogaexpress dbname="pedido_drogaexpress.nr_pedido_drogaexpress" )
 column=(type=decimal(2) updatewhereclause=yes name=pedido_drogaexpress_vl_total_pedido dbname="pedido_drogaexpress.vl_total_pedido" )
 column=(type=char(2) updatewhereclause=yes name=pedido_drogaexpress_cd_tipo_venda dbname="pedido_drogaexpress.cd_tipo_venda" values="$$HEX1$$c000$$ENDHEX$$ VISTA	AV/CONV$$HEX1$$ca00$$ENDHEX$$NIO	CV/CONTA-CORRENTE	CC/CREDI$$HEX1$$c100$$ENDHEX$$RIO	CR/" )
 column=(type=char(2) updatewhereclause=yes name=pedido_drogaexpress_cd_forma_pagamento dbname="pedido_drogaexpress.cd_forma_pagamento" values="DINHEIRO	DI/CHEQUE	HA/CHEQUE PR$$HEX1$$c900$$ENDHEX$$-DATADO	HP/CART$$HEX1$$c300$$ENDHEX$$O CR$$HEX1$$c900$$ENDHEX$$DITO	CA/CART$$HEX1$$c300$$ENDHEX$$O CR$$HEX1$$c900$$ENDHEX$$DITO	CP/CONTA-CORRENTE	CC/CREDI$$HEX1$$c100$$ENDHEX$$RIO	CR/CONV$$HEX1$$ca00$$ENDHEX$$NIO	CV/CART$$HEX1$$c300$$ENDHEX$$O POO CR$$HEX1$$c900$$ENDHEX$$DITO	PC/CART$$HEX1$$c300$$ENDHEX$$O POO D$$HEX1$$c900$$ENDHEX$$BITO	PD/M$$HEX1$$da00$$ENDHEX$$LTIPLAS FORMAS	MF/" )
 column=(type=char(6) updatewhereclause=yes name=pedido_drogaexpress_nr_matricula_operado dbname="pedido_drogaexpress.nr_matricula_operador" )
 column=(type=datetime updatewhereclause=yes name=pedido_drogaexpress_dh_emissao dbname="pedido_drogaexpress.dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=pedido_drogaexpress_vl_taxa_entrega dbname="pedido_drogaexpress.vl_taxa_entrega" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="pedido_drogaexpress.id_situacao" values="ABERTO	A/FATURADO	F/CANCELADO	X/EM ROTEIRO	R/ENTREGUE	E/FATURANDO	P/" )
 column=(type=char(2) updatewhereclause=yes name=pedido_drogaexpress_de_especie_doc_fisca dbname="pedido_drogaexpress.de_especie_doc_fiscal" )
 column=(type=char(19) updatewhereclause=yes name=pedido_drogaexpress_nr_cartao_credito dbname="pedido_drogaexpress.nr_cartao_credito" )
 column=(type=char(4) updatewhereclause=yes name=pedido_drogaexpress_cd_seguranca_cartao dbname="pedido_drogaexpress.cd_seguranca_cartao" )
 column=(type=datetime updatewhereclause=yes name=pedido_drogaexpress_dh_entrega_marcada dbname="pedido_drogaexpress.dh_entrega_marcada" )
 column=(type=decimal(2) updatewhereclause=yes name=pedido_drogaexpress_vl_cobrar dbname="pedido_drogaexpress.vl_cobrar" )
 column=(type=decimal(2) updatewhereclause=yes name=pedido_drogaexpress_vl_pago dbname="pedido_drogaexpress.vl_pago" )
 column=(type=decimal(2) updatewhereclause=yes name=pedido_drogaexpress_pc_desconto dbname="pedido_drogaexpress.pc_desconto" )
 column=(type=char(10) updatewhereclause=yes name=pedido_drogaexpress_cd_cliente_drogaexpr dbname="pedido_drogaexpress.cd_cliente_drogaexpress" )
 column=(type=long updatewhereclause=yes name=condicao_venda_crediario_cd_condicao_cre dbname="condicao_venda_crediario.cd_condicao_crediario" )
 column=(type=char(40) updatewhereclause=yes name=condicao_venda_crediario_de_condicao_cre dbname="condicao_venda_crediario.de_condicao_crediario" )
 column=(type=char(11) updatewhereclause=yes name=cliente_cd_cliente dbname="cliente.cd_cliente" )
 column=(type=char(8190) updatewhereclause=yes name=cliente_nm_cliente dbname="nm_cliente" )
 column=(type=char(60) updatewhereclause=yes name=nm_cliente_entrega dbname="pedido_drogaexpress.nm_cliente_entrega" )
 column=(type=char(40) updatewhereclause=yes name=usuario_nm_usuario dbname="usuario.nm_usuario" )
 column=(type=char(255) updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(255) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(255) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=long updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_drogaexpress.nr_pedido_ecommerce" )
 column=(type=char(10) updatewhereclause=yes name=nr_telefone_principal dbname="cliente_drogaexpress.nr_telefone_principal" )
 column=(type=char(60) updatewhereclause=yes name=de_endereco_entrega dbname="pedido_drogaexpress.de_endereco_entrega" )
 column=(type=char(20) updatewhereclause=yes name=de_bairro_entrega dbname="pedido_drogaexpress.de_bairro_entrega" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_drogaexpress.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_drogaexpress.nr_pedido_ecommerce" )
 column=(type=char(20) updatewhereclause=yes name=nr_pedido_ecommerce_site dbname="pedido_drogaexpress.nr_pedido_ecommerce_site" )
 retrieve="SELECT	pde.nr_pedido_drogaexpress,   
			pde.vl_total_pedido,   
			pde.cd_tipo_venda,   
			pde.cd_forma_pagamento,   
			pde.nr_matricula_operador,   
			pde.dh_emissao,   
			pde.vl_taxa_entrega,
			pde.id_situacao,
			pde.de_especie_doc_fiscal,
			pde.nr_cartao_credito,
			pde.cd_seguranca_cartao,
			pde.dh_entrega_marcada,
			pde.vl_cobrar,
			pde.vl_pago,
			pde.pc_desconto,
			pde.cd_cliente_drogaexpress,
			cdcre.cd_condicao_crediario,
			cdcre.de_condicao_crediario,
			cl.cd_cliente, 
			isnull(pde.nm_cliente_entrega, cl.nm_cliente) as nm_cliente,     
			pde.nm_cliente_entrega,   
			us.nm_usuario,
			'' nr_nf,
			'' de_especie,
			'' de_serie,
			pde.nr_pedido_ecommerce,
			clde.nr_telefone_principal,
			pde.de_endereco_entrega,
			pde.de_bairro_entrega,
			pde.cd_filial,
			pde.nr_pedido_ecommerce,
			pde.nr_pedido_ecommerce_site
	FROM cliente_drogaexpress clde
			INNER JOIN pedido_drogaexpress pde
				ON pde.cd_cliente_drogaexpress = clde.cd_cliente_drogaexpress
			LEFT OUTER JOIN cliente cl
			   ON pde.cd_cliente = cl.cd_cliente
			INNER JOIN usuario us
				ON pde.nr_matricula_operador = us.nr_matricula
			LEFT OUTER JOIN condicao_venda_crediario cdcre
			   ON pde.cd_condicao_crediario = cdcre.cd_condicao_crediario
  WHERE pde.nr_pedido_drogaexpress   = :pedido" arguments=(("pedido", string)) )
