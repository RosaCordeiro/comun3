 column=(type=decimal(2) updatewhereclause=yes name=pedido_drogaexpress_pc_desconto dbname="pedido_drogaexpress.pc_desconto" )
 column=(type=char(2) updatewhereclause=yes name=pedido_drogaexpress_cd_forma_pagamento dbname="pedido_drogaexpress.cd_forma_pagamento" values="DINHEIRO	DI/CHEQUE	HA/CHEQUE PR$$HEX1$$c900$$ENDHEX$$-DATADO	HP/CART$$HEX1$$c300$$ENDHEX$$O CR$$HEX1$$c900$$ENDHEX$$DITO	CA/CART$$HEX1$$c300$$ENDHEX$$O CR$$HEX1$$c900$$ENDHEX$$DITO	CP/CONV$$HEX1$$ca00$$ENDHEX$$NIO	CV/CREDI$$HEX1$$c100$$ENDHEX$$RIO	CR/CONTA CORRENTE	CC/" )
 column=(type=long updatewhereclause=yes name=condicao_venda_convenio_cd_condicao_conv dbname="condicao_venda_convenio.cd_condicao_convenio" )
 column=(type=char(40) updatewhereclause=yes name=condicao_venda_convenio_de_condicao_conv dbname="condicao_venda_convenio.de_condicao_convenio" )
 column=(type=char(15) updatewhereclause=yes name=conveniado_cd_conveniado dbname="conveniado.cd_conveniado" )
 column=(type=char(40) updatewhereclause=yes name=conveniado_nm_conveniado dbname="conveniado.nm_conveniado" )
 column=(type=char(60) updatewhereclause=yes name=convenio_nm_fantasia dbname="convenio.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=convenio_cd_convenio dbname="convenio.cd_convenio" )
 column=(type=char(40) updatewhereclause=yes name=usuario_nm_usuario dbname="usuario.nm_usuario" )
 column=(type=char(255) updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(255) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(255) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=char(60) updatewhereclause=yes name=de_endereco_entrega dbname="pedido_drogaexpress.de_endereco_entrega" )
 column=(type=char(20) updatewhereclause=yes name=de_bairro_entrega dbname="pedido_drogaexpress.de_bairro_entrega" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_drogaexpress.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_drogaexpress.nr_pedido_ecommerce" )
 column=(type=char(20) updatewhereclause=yes name=nr_pedido_ecommerce_site dbname="pedido_drogaexpress.nr_pedido_ecommerce_site" )
 retrieve="  SELECT pde.nr_pedido_drogaexpress,   
         pde.vl_total_pedido,   
         pde.cd_tipo_venda,   
         pde.cd_forma_pagamento,   
         pde.nr_matricula_operador,   
         pde.dh_emissao,   
         pde.nr_cartao_credito,
         pde.dh_validade_cartao,
         pde.vl_taxa_entrega,
         pde.id_situacao,
         pde.de_especie_doc_fiscal,
         pde.dh_entrega_marcada,
         pde.vl_cobrar,
         pde.vl_pago,
         pde.pc_desconto,
         pde.cd_forma_pagamento,
         cdconv.cd_condicao_convenio,
         cdconv.de_condicao_convenio,
         conv.cd_conveniado,   
         conv.nm_conveniado,   
		 cv.nm_fantasia,
         cv.cd_convenio,   
         us.nm_usuario,
         '' nr_nf,
         '' de_especie,
         '' de_serie,
			pde.de_endereco_entrega,
			pde.de_bairro_entrega,
			pde.cd_filial as cd_filial,
			pde.nr_pedido_ecommerce,
			pde.nr_pedido_ecommerce_site
    FROM cliente_drogaexpress clde,   
         conveniado conv,   
         convenio cv,   
         pedido_drogaexpress pde,   
         usuario us,
         condicao_venda_convenio cdconv
   WHERE pde.nr_pedido_drogaexpress  = :pedido
     and pde.cd_cliente_drogaexpress = clde.cd_cliente_drogaexpress
     and pde.cd_convenio             = cv.cd_convenio
     and pde.cd_convenio             = conv.cd_convenio
     and pde.cd_conveniado           = conv.cd_conveniado
     and pde.nr_matricula_operador   = us.nr_matricula
     and pde.cd_condicao_convenio    = cdconv.cd_condicao_convenio

" retrieve.asneeded=yes arguments=(("pedido", string)) )
