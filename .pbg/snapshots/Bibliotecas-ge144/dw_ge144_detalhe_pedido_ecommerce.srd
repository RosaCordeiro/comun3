 column=(type=char(255) updatewhereclause=yes name=de_serie_cf dbname="de_serie_cf" )
 column=(type=long updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_drogaexpress.nr_pedido_ecommerce" )
 column=(type=decimal(2) updatewhereclause=yes name=pedido_drogaexpress_vl_vale_compra dbname="pedido_drogaexpress.vl_vale_compra" )
 column=(type=decimal(2) updatewhereclause=yes name=pedido_drogaexpress_vl_total_produtos dbname="pedido_drogaexpress.vl_total_produtos" )
 column=(type=char(10) updatewhereclause=yes name=nr_telefone_principal dbname="cliente_drogaexpress.nr_telefone_principal" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_drogaexpress.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_drogaexpress.nr_pedido_ecommerce" )
 column=(type=char(30) updatewhereclause=yes name=nm_transportadora dbname="pedido_drogaexpress.nm_transportadora" )
 column=(type=char(100) updatewhereclause=yes name=de_endereco_email dbname="pedido_drogaexpress.de_endereco_email" )
 column=(type=char(20) updatewhereclause=yes name=nr_telefone_entrega dbname="pedido_drogaexpress.nr_telefone_entrega" )
 column=(type=char(20) updatewhereclause=yes name=nr_telefone_contato dbname="pedido_drogaexpress.nr_telefone_contato" )
 column=(type=char(20) updatewhereclause=yes name=nr_pedido_ecommerce_site dbname="pedido_drogaexpress.nr_pedido_ecommerce_site" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente_cheque dbname="pedido_drogaexpress.nm_cliente_cheque" )
 retrieve="Select	pde.nr_pedido_drogaexpress,
		pde.vl_total_pedido,
		pde.cd_tipo_venda,
		pde.cd_forma_pagamento,
		pde.nr_cartao_credito,
		pde.cd_seguranca_cartao,
		pde.nr_matricula_operador,
		pde.dh_emissao,
		pde.vl_taxa_entrega,
		pde.id_situacao,
		pde.de_especie_doc_fiscal,
		pde.nr_cartao_credito,
		pde.dh_validade_cartao,
		pde.dh_entrega_marcada,
		pde.vl_cobrar,
		pde.vl_pago,
		pde.pc_desconto,
		pde.cd_cliente_drogaexpress,
		pde.nm_cliente_entrega,
		us.nm_usuario,
		'' nr_nf,
		'' nr_nf_cf,
		Space(3) de_especie,
		Space(3) de_serie,
		Space(3) de_especie_cf,
		Space(3) de_serie_cf,
		pde.nr_pedido_ecommerce,
		pde.vl_vale_compra,
		pde.vl_total_produtos,
		clde.nr_telefone_principal,
		pde.cd_filial as cd_filial,
		pde.nr_pedido_ecommerce,
		pde.nm_transportadora,
		pde.de_endereco_email,
		pde.nr_telefone_entrega,
		pde.nr_telefone_contato,
		pde.nr_pedido_ecommerce_site,
		pde.nm_cliente_cheque
From cliente_drogaexpress As clde
	Left Outer Join pedido_drogaexpress As pde
		On pde.cd_cliente_drogaexpress = clde.cd_cliente_drogaexpress
	Inner Join usuario As us
		On pde.nr_matricula_operador = us.nr_matricula
Where pde.nr_pedido_drogaexpress = :pedido" arguments=(("pedido", string)) )
