table(column=(type=char(11) update=yes updatewhereclause=yes name=nr_pedido_drogaexpress dbname="produto_pedido_droga_receita.nr_pedido_drogaexpress" dbalias="pr.nr_pedido_drogaexpress" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="produto_pedido_droga_receita.cd_produto" dbalias="pr.cd_produto" )
 column=(type=long update=yes updatewhereclause=yes name=nr_sequencial dbname="produto_pedido_droga_receita.nr_sequencial" dbalias="pr.nr_sequencial" )
 column=(type=char(60) update=yes updatewhereclause=yes name=nm_cliente dbname="produto_pedido_droga_receita.nm_cliente" dbalias="pr.nm_cliente" )
 column=(type=date update=yes updatewhereclause=yes name=dh_nascimento dbname="produto_pedido_droga_receita.dh_nascimento" dbalias="pr.dh_nascimento" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_sexo dbname="produto_pedido_droga_receita.id_sexo" dbalias="pr.id_sexo" )
 column=(type=char(100) update=yes updatewhereclause=yes name=de_endereco dbname="produto_pedido_droga_receita.de_endereco" dbalias="pr.de_endereco" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_endereco dbname="produto_pedido_droga_receita.nr_endereco" dbalias="pr.nr_endereco" )
 column=(type=char(20) update=yes updatewhereclause=yes name=de_bairro dbname="produto_pedido_droga_receita.de_bairro" dbalias="pr.de_bairro" )
 column=(type=char(30) update=yes updatewhereclause=yes name=nm_cidade dbname="produto_pedido_droga_receita.nm_cidade" dbalias="pr.nm_cidade" )
 column=(type=char(2) update=yes updatewhereclause=yes name=cd_unidade_federacao dbname="produto_pedido_droga_receita.cd_unidade_federacao" dbalias="pr.cd_unidade_federacao" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_doc_identificacao dbname="produto_pedido_droga_receita.nr_doc_identificacao" dbalias="pr.nr_doc_identificacao" )
 column=(type=char(10) update=yes updatewhereclause=yes name=de_orgao_emissor_rg dbname="produto_pedido_droga_receita.de_orgao_emissor_rg" dbalias="pr.de_orgao_emissor_rg" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_fone dbname="produto_pedido_droga_receita.nr_fone" dbalias="pr.nr_fone" )
 column=(type=char(30) update=yes updatewhereclause=yes name=nr_token dbname="produto_pedido_droga_receita.nr_token" dbalias="pr.nr_token" )
 column=(type=char(8190) updatewhereclause=no name=de_tipo dbname="de_tipo" )
 column=(type=char(14) updatewhereclause=yes name=nr_cpf dbname="pedido_drogaexpress.nr_cpf" dbalias="pd.nr_cpf" )
 retrieve="  SELECT pr.nr_pedido_drogaexpress,   
         pr.cd_produto,   
         pr.nr_sequencial,   
         pr.nm_cliente,   
         pr.dh_nascimento,   
         pr.id_sexo,   
         pr.de_endereco,   
         pr.nr_endereco,   
         pr.de_bairro,   
         pr.nm_cidade,   
         pr.cd_unidade_federacao,   
         pr.nr_doc_identificacao,   
         pr.de_orgao_emissor_rg,   
         pr.nr_fone,   
         pr.nr_token  ,
		Case When pr.id_sexo is null then 'COMPRADOR' else 'PACIENTE' end as de_tipo,
		pd.nr_cpf_cheque as nr_cpf
    FROM produto_pedido_droga_receita pr 
			inner join pedido_drogaexpress pd on pd.nr_pedido_drogaexpress = pr.nr_pedido_drogaexpress
WHere pr.nr_pedido_drogaexpress = :ps_nr_pedido
" arguments=(("ps_nr_pedido", string)) )
