table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=produto_geral_de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=produto_geral_de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="produto_pedido_drogaexpress.qt_pedida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_tabela dbname="produto_pedido_drogaexpress.vl_preco_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_tabela dbname="produto_pedido_drogaexpress.pc_desconto_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_praticado dbname="produto_pedido_drogaexpress.vl_preco_praticado" )
 column=(type=char(1) updatewhereclause=yes name=produto_pedido_drogaexpress_id_alteracao dbname="produto_pedido_drogaexpress.id_alteracao_preco" )
 column=(type=long updatewhereclause=yes name=nr_requisicao_manip dbname="produto_pedido_drogaexpress.nr_requisicao_manip" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="produto_pedido_drogaexpress.nr_sequencial" )
 column=(type=char(500) updatewhereclause=no name=de_produto dbname="produto_pedido_drogaexpress.de_produto" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 retrieve="  SELECT	g.cd_produto,   
			g.de_produto,   
			g.de_apresentacao_venda,   
			p.qt_pedida,   
			p.vl_preco_tabela,   
			p.pc_desconto_tabela,   
			p.vl_preco_praticado,
			p.id_alteracao_preco,
			p.nr_requisicao_manip,  
			p.nr_sequencial,
			p.de_produto,
			CAST( 0 AS integer) as nr_nf,
			CAST('' AS VARCHAR(3)) as de_especie,
			CAST('' AS VARCHAR(3)) as de_serie
    FROM produto_pedido_drogaexpress p
		INNER JOIN produto_geral g
		ON g.cd_produto = p.cd_produto
   WHERE p.nr_pedido_drogaexpress = :pedido" arguments=(("pedido", string)) )
