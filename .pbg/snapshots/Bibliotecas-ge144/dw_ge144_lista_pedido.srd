table(column=(type=char(11) update=yes updatewhereclause=yes name=nr_pedido_drogaexpress dbname="pedido_drogaexpress.nr_pedido_drogaexpress" dbalias="p.nr_pedido_drogaexpress" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_emissao dbname="pedido_drogaexpress.dh_emissao" dbalias="p.dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_entrega_marcada dbname="pedido_drogaexpress.dh_entrega_marcada" dbalias="p.dh_entrega_marcada" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_total_pedido dbname="pedido_drogaexpress.vl_total_pedido" dbalias="p.vl_total_pedido" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="pedido_drogaexpress.id_situacao" dbalias="p.id_situacao" values="ABERTO	A/FATURADO	F/CANCELADO	X/EM ROTEIRO	R/ENTREGUE	E/REMETIDO	M/FATURANDO	P/DISPON$$HEX1$$cd00$$ENDHEX$$VEL	D/FAT. PARCIAL	L/COM TRANSP.	C/PAG. PENDENTE	G/" )
 column=(type=char(2) update=yes updatewhereclause=yes name=cd_tipo_venda dbname="pedido_drogaexpress.cd_tipo_venda" dbalias="p.cd_tipo_venda" values="$$HEX1$$c000$$ENDHEX$$ VISTA	AV/CONV$$HEX1$$ca00$$ENDHEX$$NIO	CV/CONTA-CORRENTE	CC/CREDI$$HEX1$$c100$$ENDHEX$$RIO	CR/" )
 column=(type=char(10) updatewhereclause=yes name=cd_cliente_drogaexpress dbname="pedido_drogaexpress.cd_cliente_drogaexpress" dbalias="p.cd_cliente_drogaexpress" )
 column=(type=char(20) updatewhereclause=yes name=pedido_drogaexpress_nr_telefone_entrega dbname="pedido_drogaexpress.nr_telefone_entrega" dbalias="p.nr_telefone_entrega" )
 column=(type=long updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_drogaexpress.nr_pedido_ecommerce" dbalias="p.nr_pedido_ecommerce" )
 column=(type=char(30) updatewhereclause=yes name=nm_transportadora dbname="pedido_drogaexpress.nm_transportadora" dbalias="p.nm_transportadora" )
 column=(type=char(60) updatewhereclause=yes name=pedido_drogaexpress_nm_cliente_entrega dbname="pedido_drogaexpress.nm_cliente_entrega" dbalias="p.nm_cliente_entrega" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente_cheque dbname="pedido_drogaexpress.nm_cliente_cheque" dbalias="p.nm_cliente_cheque" )
 column=(type=char(40) updatewhereclause=yes name=cliente_drogaexpress_nm_cliente dbname="cliente_drogaexpress.nm_cliente" dbalias="c.nm_cliente" )
 column=(type=char(10) updatewhereclause=yes name=nr_telefone_principal dbname="cliente_drogaexpress.nr_telefone_principal" dbalias="c.nr_telefone_principal" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_drogaexpress.cd_filial" dbalias="p.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_impressao dbname="pedido_drogaexpress.dh_impressao" dbalias="p.dh_impressao" )
 column=(type=char(1) updatewhereclause=yes name=id_refaturado dbname="pedido_drogaexpress.id_refaturado" dbalias="p.id_refaturado" )
 column=(type=long updatewhereclause=yes name=cd_filial_ecommerce dbname="pedido_drogaexpress.cd_filial_ecommerce" dbalias="p.cd_filial_ecommerce" )
 column=(type=datetime updatewhereclause=yes name=dh_compra dbname="dh_compra" )
 column=(type=char(255) updatewhereclause=yes name=id_rede_ecommerce dbname="id_rede_ecommerce" )
 column=(type=char(20) updatewhereclause=yes name=nr_pedido_vtex dbname="pedido_drogaexpress.nr_pedido_vtex" dbalias="p.nr_pedido_vtex" )
 column=(type=char(255) updatewhereclause=yes name=id_plataforma_ecommerce dbname="id_plataforma_ecommerce" )
 column=(type=datetime updatewhereclause=yes name=dh_pausa_alerta dbname="pedido_drogaexpress.dh_pausa_alerta" dbalias="p.dh_pausa_alerta" )
 column=(type=char(255) updatewhereclause=yes name=id_selecionado dbname="id_selecionado" values="	S/	N" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_pedido dbname="pedido_drogaexpress.id_tipo_pedido" dbalias="p.id_tipo_pedido" )
 retrieve="select	p.nr_pedido_drogaexpress,   
		p.dh_emissao,
		p.dh_entrega_marcada,
		p.vl_total_pedido,   
		p.id_situacao,   
		p.cd_tipo_venda,
		p.cd_cliente_drogaexpress,
		p.nr_telefone_entrega,
		p.nr_pedido_ecommerce,
		p.nm_transportadora,
		p.nm_cliente_entrega, 
		p.nm_cliente_cheque,
		c.nm_cliente,
		c.nr_telefone_principal,
		p.cd_filial,
		f.nm_fantasia,
		p.dh_impressao,
		p.id_refaturado,
		p.cd_filial_ecommerce,
		Coalesce(p.dh_compra, p.dh_emissao) as dh_compra,
		Coalesce( p.id_rede_ecommerce, 'FA') as id_rede_ecommerce,
		p.nr_pedido_ecommerce_site nr_pedido_vtex,
		case when p.nr_pedido_ecommerce_site is null Then '1'
				when p.nr_pedido_ecommerce_site is not null and  ( (p.id_plataforma_ecommerce <> '3' and p.id_plataforma_ecommerce <> '4' and p.id_plataforma_ecommerce <> '5') or p.id_plataforma_ecommerce is null ) Then '2'
				Else p.id_plataforma_ecommerce End as id_plataforma_ecommerce,
		p.dh_pausa_alerta,
		'N' as id_selecionado,
		p.id_tipo_pedido		
from	pedido_drogaexpress  p
	inner join cliente_drogaexpress c
		on c.cd_cliente_drogaexpress = p.cd_cliente_drogaexpress
	inner join filial f
		on f.cd_filial = p.cd_Filial
where p.nr_pedido_ecommerce is not null"  sort="nr_pedido_drogaexpress D " )
