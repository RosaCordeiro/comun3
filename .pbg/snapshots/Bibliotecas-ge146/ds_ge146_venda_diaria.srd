table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_venda.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=date updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_venda dbname="nf_venda.id_tipo_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_venda dbname="vl_total_venda" )
 column=(type=long updatewhereclause=yes name=qt_clientes dbname="qt_clientes" )
 retrieve="Select a.cd_filial,
		 f.nm_fantasia,
		 cast(a.dh_movimentacao_caixa as date) as dh_movimentacao_caixa,
		 a.id_tipo_venda,
		 sum(a.vl_total_nf) vl_total_venda,
		 count(*) qt_clientes
From nf_venda a
	Inner Join cliente_caixa c
	     On c.cd_filial_venda = a.cd_filial
   		 And c.nr_nf_venda = a.nr_nf
    		 And c.de_especie_venda = a.de_especie
		 And c.de_serie_venda = a.de_serie
	Inner Join filial f
		On f.cd_filial = a.cd_filial
Where c.id_situacao  = 'C'
	And c.id_tipo = 'D'
	And a.nr_nf_anexa is null
	And a.dh_movimentacao_caixa between :inicio and :termino
	----and a.nr_pedido_drogaexpress is not null and a.nr_pedido_ecommerce 	is null
	And a.dh_cancelamento is null
	And a.cd_filial in ( select cd_filial from parametro_loja where cd_parametro = 'ID_DISQUE_ENTREGA' and  vl_parametro = 'S' )
	Group by a.cd_filial,
				f.nm_fantasia,
				a.dh_movimentacao_caixa,
				a.id_tipo_venda" arguments=(("inicio", date),("termino", date))  sort="cd_filial A dh_movimentacao_caixa A " )
