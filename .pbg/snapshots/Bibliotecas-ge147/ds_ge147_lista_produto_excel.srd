table(column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_central_produto.cd_produto" dbalias="p.cd_produto" )
 column=(type=char(15) updatewhereclause=yes name=cd_produto_fornecedor dbname="produto_central.cd_produto_fornecedor" dbalias="pc.cd_produto_fornecedor" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="g.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" dbalias="g.de_apresentacao_estoque" )
 column=(type=char(20) updatewhereclause=yes name=codigo_barras_produto_de_codigo_barras dbname="codigo_barras_produto.de_codigo_barras" dbalias="c.de_codigo_barras" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_central_produto.qt_pedida" dbalias="p.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="pedido_central_produto.qt_recebida" dbalias="p.qt_recebida" )
 column=(type=long updatewhereclause=yes name=qt_devolvida dbname="qt_devolvida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="pedido_central_produto.vl_preco_unitario" dbalias="p.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=char(40) updatewhereclause=yes name=condicao_pagamento_de_condicao dbname="condicao_pagamento.de_condicao" dbalias="cp.de_condicao" )
 retrieve="select p.cd_produto,   
		pc.cd_produto_fornecedor,
	   g.de_produto,   
	   g.de_apresentacao_estoque, 
       c.de_codigo_barras,  
	   p.qt_pedida,   
       p.qt_recebida,
	  coalesce(p.qt_devolvida, 0) qt_devolvida, 
	   p.vl_preco_unitario, 
		(CASE WHEN (select 1 
						 from parametro_geral 
						where cd_parametro like 'DH_INICIO_OPERACAO_SAP' 
						  and cast(right(vl_parametro, 4) + left(right(vl_parametro, 7), 2) + left(vl_parametro, 2) as date) <= getdate()) = 1
			THEN
				p.pc_repasse_icms
			ELSE
				0
		END) + p.pc_desconto as pc_desconto ,  
	   --p.pc_desconto + pc_repasse_icms as pc_desconto,
       cp.de_condicao
from pedido_central p2,
	 pedido_central_produto p,   
	 codigo_barras_produto c,
	 produto_geral g,
	 condicao_pagamento cp,
     fornecedor f,
     produto_central pc
where p2.nr_pedido    = :pedido
  and p.nr_pedido     = p2.nr_pedido
  and c.cd_produto    =* p.cd_produto
  and c.id_principal  = ~"S~"
  and g.cd_produto    = p.cd_produto
  and f.cd_fornecedor = g.cd_fornecedor_usual
  and cp.cd_condicao  = p2.cd_condicao_pagamento
  and pc.cd_produto = g.cd_produto
" arguments=(("pedido", number)) )
