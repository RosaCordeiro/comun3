table(column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_distribuidora_produto.cd_produto" dbalias="p.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_distribuidora_produto.qt_pedida" dbalias="p.qt_pedida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="pedido_distribuidora_produto.vl_preco_unitario" dbalias="p.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pedido_distribuidora_produto.pc_desconto" dbalias="p.pc_desconto" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="codigo_barras_produto.de_codigo_barras" dbalias="c.de_codigo_barras" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_pedido dbname="pc_desconto_pedido" )
 retrieve="SELECT 	p.cd_produto,   
			p.qt_pedida,   
			p.vl_preco_unitario,   
			p.pc_desconto,
			c.de_codigo_barras,
			0.00 pc_desconto_pedido
    FROM pedido_distribuidora_produto p
		left outer join codigo_barras_produto c
			on c.cd_produto = p.cd_produto
		inner join pedido_distribuidora pc
			on pc.cd_filial = p.cd_filial
			and pc.nr_pedido_distribuidora = p.nr_pedido_distribuidora
   WHERE p.cd_filial = :filial
		and p.nr_pedido_distribuidora	= :pedido
		and c.id_principal					= 'S'" arguments=(("filial", number),("pedido", number)) )
