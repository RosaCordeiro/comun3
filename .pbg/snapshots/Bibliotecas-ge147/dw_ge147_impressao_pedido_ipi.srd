table(column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_central.nr_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_pedido dbname="pedido_central.dh_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_previsao_entrega dbname="pedido_central.dh_previsao_entrega" )
 column=(type=long updatewhereclause=yes name=qt_dias_suprimento dbname="pedido_central.qt_dias_suprimento" )
 column=(type=char(9) updatewhereclause=yes name=pedido_central_cd_fornecedor dbname="pedido_central.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=fornecedor_nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=char(40) updatewhereclause=yes name=fornecedor_de_endereco dbname="fornecedor.de_endereco" )
 column=(type=char(20) updatewhereclause=yes name=fornecedor_de_bairro dbname="fornecedor.de_bairro" )
 column=(type=char(8) updatewhereclause=yes name=fornecedor_nr_cep dbname="fornecedor.nr_cep" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade_fornecedor dbname="cidade.nm_cidade_fornecedor" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf_fornecedor dbname="cidade.cd_uf_fornecedor" )
 column=(type=char(3) updatewhereclause=yes name=fornecedor_nr_ddd_fax_compras dbname="fornecedor.nr_ddd_fax_compras" )
 column=(type=char(20) updatewhereclause=yes name=fornecedor_nr_fax_compras dbname="fornecedor.nr_fax_compras" )
 column=(type=char(15) updatewhereclause=yes name=fornecedor_nr_inscricao_estadual dbname="fornecedor.nr_inscricao_estadual" )
 column=(type=char(14) updatewhereclause=yes name=fornecedor_nr_cgc dbname="fornecedor.nr_cgc" )
 column=(type=long updatewhereclause=yes name=cd_condicao_pagamento dbname="pedido_central.cd_condicao_pagamento" )
 column=(type=char(40) updatewhereclause=yes name=de_condicao dbname="condicao_pagamento.de_condicao" )
 column=(type=decimal(2) updatewhereclause=yes name=pedido_central_pc_desconto dbname="pedido_central.pc_desconto" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_central_produto.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_compra dbname="produto_geral.cd_unidade_medida_compra" )
 column=(type=char(15) updatewhereclause=yes name=cd_produto_fornecedor dbname="produto_central.cd_produto_fornecedor" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_central_produto.qt_pedida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="pedido_central_produto.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pedido_central_produto.pc_desconto" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_razao_social dbname="filial.nm_razao_social" )
 column=(type=char(40) updatewhereclause=yes name=filial_de_endereco dbname="filial.de_endereco" )
 column=(type=char(20) updatewhereclause=yes name=filial_de_bairro dbname="filial.de_bairro" )
 column=(type=char(8) updatewhereclause=yes name=filial_nr_cep dbname="filial.nr_cep" )
 column=(type=char(14) updatewhereclause=yes name=filial_nr_cgc dbname="filial.nr_cgc" )
 column=(type=char(15) updatewhereclause=yes name=filial_nr_inscricao_estadual dbname="filial.nr_inscricao_estadual" )
 column=(type=char(3) updatewhereclause=yes name=nr_ddd_entrega dbname="filial.nr_ddd_entrega" )
 column=(type=char(9) updatewhereclause=yes name=nr_telefone_entrega dbname="nr_telefone_entrega" )
 column=(type=char(40) updatewhereclause=yes name=de_transportadora dbname="pedido_central.de_transportadora" )
 column=(type=char(100) updatewhereclause=yes name=de_observacao dbname="pedido_central.de_observacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_pedido dbname="pedido_central.vl_total_pedido" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_central.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_cidade dbname="cidade.filial_nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=filial_uf dbname="cidade.filial_uf" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_frete dbname="pedido_central.id_tipo_frete" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" )
 column=(type=long updatewhereclause=yes name=nr_embalagem_padrao dbname="pedido_central_produto.nr_embalagem_padrao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_ipi dbname="pc_ipi" )
 retrieve="select a.nr_pedido,   
       a.dh_pedido,   
       a.dh_previsao_entrega,   
       a.qt_dias_suprimento,  
       a.cd_fornecedor,   
       f.nm_razao_social,   
       f.de_endereco,   
       f.de_bairro,   
       f.nr_cep,   
       c.nm_cidade nm_cidade_fornecedor,   
       c.cd_unidade_federacao cd_uf_fornecedor,   
       f.nr_ddd_fax_compras,   
       f.nr_fax_compras,   
       f.nr_inscricao_estadual,   
       f.nr_cgc,  
       a.cd_condicao_pagamento,   
       p.de_condicao,   
       a.pc_desconto,   
       b.cd_produto,   
       g.de_produto,
       g.de_apresentacao_estoque,   
       g.cd_unidade_medida_compra,   
       t.cd_produto_fornecedor,
       b.qt_pedida,   
       b.vl_preco_unitario,   
       b.pc_desconto,
       i.nm_razao_social,
       i.de_endereco,
       i.de_bairro,
       i.nr_cep,
       i.nr_cgc,
       i.nr_inscricao_estadual,
       i.nr_ddd_telefone nr_ddd_entrega,
       substring(convert(char(8), i.nr_telefone), 1, 4) + '-' + substring(convert(char(8), i.nr_telefone), 5, 4) nr_telefone_entrega,
       a.de_transportadora,
       a.de_observacao,
       a.vl_total_pedido,
	   a.cd_filial,
	   x.nm_cidade filial_nm_cidade,
	   x.cd_unidade_federacao filial_uf,
		a.id_tipo_frete,
		g.de_codigo_barras,
		b.nr_embalagem_padrao,
		coalesce(b.pc_ipi, 0) pc_ipi
from pedido_central a,   
     pedido_central_produto b,   
	 fornecedor f,  
     cidade c, 
     condicao_pagamento p,   
     produto_geral g,
     produto_central t,
     filial i,
     cidade x
where a.nr_pedido = :pedido
  and b.nr_pedido     = a.nr_pedido
  and f.cd_fornecedor = a.cd_fornecedor
  and c.cd_cidade     = f.cd_cidade
  and p.cd_condicao   = a.cd_condicao_pagamento
  and g.cd_produto    = b.cd_produto
  and t.cd_produto    = b.cd_produto
  and i.cd_filial     = a.cd_filial
  and i.cd_cidade	  = x.cd_cidade" arguments=(("pedido", number))  sort="de_produto A de_apresentacao_estoque A " )
