table(column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_central_prd_msg_logist.nr_pedido" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_central_prd_msg_logist.cd_produto" )
 column=(type=long updatewhereclause=yes name=cd_mensagem dbname="pedido_central_prd_msg_logist.cd_mensagem" )
 column=(type=char(73) updatewhereclause=yes name=de_mensagem dbname="de_mensagem" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(73) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=char(49) updatewhereclause=yes name=nm_usuario_avisar dbname="nm_usuario_avisar" )
 column=(type=long updatewhereclause=yes name=qt_meses_aceite_validade dbname="pedido_central_prd_msg_logist.qt_meses_aceite_validade" )
 column=(type=long updatewhereclause=yes name=qt_devolver dbname="pedido_central_prd_msg_logist.qt_devolver" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="pedido_central_prd_msg_logist.dh_inclusao" )
 column=(type=char(49) updatewhereclause=yes name=nm_usuario_inclusao dbname="nm_usuario_inclusao" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao dbname="pedido_central_prd_msg_logist.dh_alteracao" )
 column=(type=char(49) updatewhereclause=yes name=nm_usuario_alteracao dbname="nm_usuario_alteracao" )
 column=(type=datetime updatewhereclause=yes name=dh_exclusao dbname="pedido_central_prd_msg_logist.dh_exclusao" )
 column=(type=char(49) updatewhereclause=yes name=nm_usuario_exclusao dbname="nm_usuario_exclusao" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="pedido_central_prd_msg_logist.nr_sequencial" )
 column=(type=datetime updatewhereclause=yes name=dh_limite_validade dbname="pedido_central_prd_msg_logist.dh_limite_validade" )
 column=(type=long updatewhereclause=yes name=cd_filial_envio dbname="pedido_central_prd_msg_logist.cd_filial_envio" )
 retrieve="  SELECT 	a.nr_pedido,   
				a.cd_produto,
				a.cd_mensagem,
				cast(a.cd_mensagem as varchar)+' - '+ e.de_mensagem as de_mensagem,  
				b.de_produto +' : '+b.de_apresentacao_estoque de_produto,   
				cast(a.cd_filial_envio as varchar)+' - '+c.nm_fantasia as nm_fantasia,
				a.nr_matricula_avisar+' - '+	d.nm_usuario as nm_usuario_avisar,  
				a.qt_meses_aceite_validade,   
				a.qt_devolver,   
				a.dh_inclusao,   
				a.nr_matricula_inclusao+' - '+f.nm_usuario as nm_usuario_inclusao,
				a.dh_alteracao,   
				a.nr_matricula_alteracao+' - '+g.nm_usuario as nm_usuario_alteracao,
				a.dh_exclusao,   
				a.nr_matricula_exclusao+' - '+h.nm_usuario as nm_usuario_exclusao,
				a.nr_sequencial,
				a.dh_limite_validade,
				a.cd_filial_envio
    FROM pedido_central_prd_msg_logist a  
    INNER JOIN produto_geral	    		b on b.cd_produto = a.cd_produto
	LEFT JOIN filial 			    				c on c.cd_filial = a.cd_filial_envio
	LEFT JOIN usuario 			    		d on d.nr_matricula = a.nr_matricula_avisar
    INNER JOIN mensagem_logistica   	e on e.cd_mensagem = a.cd_mensagem
    LEFT JOIN usuario 			    			f on f.nr_matricula = a.nr_matricula_inclusao
    LEFT JOIN usuario 			    			g on g.nr_matricula = a.nr_matricula_alteracao
    LEFT JOIN usuario 			    			h on h.nr_matricula = a.nr_matricula_exclusao
	WHERE a.nr_pedido 	= :nr_pedido
   ORDER BY a.cd_produto,
				a.cd_mensagem,
				a.cd_filial_envio" arguments=(("nr_pedido", number)) )
