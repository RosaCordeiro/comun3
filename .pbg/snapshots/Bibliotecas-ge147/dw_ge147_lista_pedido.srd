table(column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_central.nr_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_pedido dbname="pedido_central.dh_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_previsao_entrega dbname="pedido_central.dh_previsao_entrega" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="pedido_central.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_pedido dbname="pedido_central.vl_total_pedido" )
 column=(type=char(1) updatewhereclause=yes name=id_programado dbname="pedido_central.id_programado" values="PRG	S/ 	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="pedido_central.id_situacao" values="COLOCADO	C/ATENDIDO	A/CANCELADO	X/PENDENTE	P/RASCUNHO	R/" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_central.dh_emissao" )
 column=(type=long updatewhereclause=yes name=qt_dias_suprimento dbname="pedido_central.qt_dias_suprimento" )
 column=(type=long updatewhereclause=yes name=cd_condicao_pagamento dbname="pedido_central.cd_condicao_pagamento" )
 column=(type=char(40) updatewhereclause=yes name=de_condicao dbname="condicao_pagamento.de_condicao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pedido_central.pc_desconto" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_cadastramento dbname="pedido_central.nr_matricula_cadastramento" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="pedido_central.dh_cancelamento" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_cancelamento dbname="pedido_central.nr_matricula_cancelamento" )
 column=(type=char(40) updatewhereclause=yes name=de_transportadora dbname="pedido_central.de_transportadora" )
 column=(type=char(100) updatewhereclause=yes name=de_observacao dbname="pedido_central.de_observacao" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_central.cd_filial" )
 column=(type=char(1) updatewhereclause=yes name=id_pbm dbname="pbm" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_frete dbname="pedido_central.id_tipo_frete" )
 column=(type=char(1) updatewhereclause=yes name=id_farmacia_governo dbname="id_farmacia_governo" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_ped_atendido dbname="pc_ped_atendido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_atendido dbname="vl_atendido" )
 column=(type=char(2) updatewhereclause=yes name=id_atende_falta_pedido_uf dbname="id_atende_falta_pedido_uf" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_anterior dbname="pedido_central.id_situacao_anterior" )
 column=(type=char(100) updatewhereclause=yes name=de_motivo_cancelamento dbname="pedido_central.de_motivo_cancelamento" )
 column=(type=char(1) updatewhereclause=yes name=id_retira_qtde_pendente_meta dbname="id_retira_qtde_pendente_meta" )
 column=(type=char(10) updatewhereclause=yes name=nr_pedido_sap dbname="nr_pedido_sap" )
 column=(type=long updatewhereclause=yes name=qt_total_devolvida dbname="qt_total_devolvida" )
 retrieve="Select	Distinct p.nr_pedido,
		p.dh_pedido,
		p.dh_previsao_entrega,
		p.cd_fornecedor,
		f.nm_razao_social,
		p.vl_total_pedido,
		p.id_programado,
		p.id_situacao,
		p.dh_emissao,
		p.qt_dias_suprimento,
		p.cd_condicao_pagamento,
		c.de_condicao,
		p.pc_desconto,
		p.nr_matricula_cadastramento,
		p.dh_cancelamento,
		p.nr_matricula_cancelamento,
		p.de_transportadora,
		p.de_observacao,
		p.cd_filial,
		coalesce(p.id_pbm, 'N') As pbm,
		p.id_tipo_frete,
		coalesce(p.id_farmacia_governo, 'N') As id_farmacia_governo,
		0.00 pc_ped_atendido,
		0.00 vl_atendido,
		Coalesce(p.id_atende_falta_pedido_uf, 'N') As id_atende_falta_pedido_uf,
		p.id_situacao_anterior,
		p.de_motivo_cancelamento,
		coalesce(p.id_retira_qtde_pendente_meta, 'N') as id_retira_qtde_pendente_meta,
		coalesce(p.nr_pedido_sap,'') as nr_pedido_sap,
		coalesce(sum(pp.qt_devolvida), 0) as qt_total_devolvida
From pedido_central As p
	Inner Join pedido_central_produto As pp
		On pp.nr_pedido = p.nr_pedido
	Inner Join fornecedor As f
		On f.cd_fornecedor = p.cd_fornecedor
	Inner Join condicao_pagamento As c
		On c.cd_condicao = p.cd_condicao_pagamento
Group By p.nr_pedido,
		p.dh_pedido,
		p.dh_previsao_entrega,
		p.cd_fornecedor,
		f.nm_razao_social,
		p.vl_total_pedido,
		p.id_programado,
		p.id_situacao,
		p.dh_emissao,
		p.qt_dias_suprimento,
		p.cd_condicao_pagamento,
		c.de_condicao,
		p.pc_desconto,
		p.nr_matricula_cadastramento,
		p.dh_cancelamento,
		p.nr_matricula_cancelamento,
		p.de_transportadora,
		p.de_observacao,
		p.cd_filial,
		coalesce(p.id_pbm, 'N'),
		p.id_tipo_frete,
		coalesce(p.id_farmacia_governo, 'N'),
		Coalesce(p.id_atende_falta_pedido_uf, 'N'),
		p.id_situacao_anterior,
		p.de_motivo_cancelamento,
		coalesce(p.id_retira_qtde_pendente_meta, 'N'),
		coalesce(p.nr_pedido_sap,'')"  sort="nr_pedido D " )
