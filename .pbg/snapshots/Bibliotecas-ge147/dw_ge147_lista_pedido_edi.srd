table(column=(type=long update=yes updatewhereclause=yes name=nr_pedido dbname="pedido_central.nr_pedido" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_pedido dbname="pedido_central.dh_pedido" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_total_pedido dbname="pedido_central.vl_total_pedido" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="pedido_central.id_situacao" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="pedido_central.cd_filial" )
 column=(type=char(9) update=yes updatewhereclause=yes name=cd_fornecedor dbname="pedido_central.cd_fornecedor" )
 column=(type=char(1) updatewhereclause=yes name=id_gerar dbname="id_gerar" values="	S/	N" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc_filial dbname="filial.nr_cgc" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc_fornecedor dbname="fornecedor.nr_cgc" )
 column=(type=datetime updatewhereclause=yes name=dh_envio_edi dbname="pedido_central.dh_envio_edi" )
 column=(type=char(1) updatewhereclause=yes name=nr_cgc_envio dbname="nr_cgc_envio" )
 column=(type=char(1) updatewhereclause=yes name=id_pbm dbname="id_pbm" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_pedido_edi dbname="fornecedor.id_pedido_edi" )
 column=(type=char(20) updatewhereclause=yes name=de_pedido_edi dbname="tipo_pedido_edi.de_pedido_edi" )
 column=(type=long updatewhereclause=yes name=usa_sftp dbname="usa_sftp" )
 retrieve="Select	p.nr_pedido,
		p.dh_pedido,
		p.vl_total_pedido,
		u.nm_usuario,
		p.id_situacao,
		p.cd_filial,
		p.cd_fornecedor,
		'N' id_gerar,
		i.nr_cgc,
		f.nr_cgc,
		p.dh_envio_edi,
		'' nr_cgc_envio,
		isnull(p.id_pbm, 'N') id_pbm,
		f.id_pedido_edi,
		t.de_pedido_edi,
		case when f.id_pedido_edi  = 'O' and f.cd_fornecedor in ('053405640')  then 1 else 0 end as usa_sftp
From pedido_central As p
	Inner Join fornecedor As f
		On f.cd_fornecedor = p.cd_fornecedor
	Inner Join tipo_pedido_edi As t
		On t.id_pedido_edi = f.id_pedido_edi
	Inner Join filial As i
		On i.cd_filial = p.cd_filial
	Inner Join usuario As u
		On u.nr_matricula = p.nr_matricula_cadastramento
Where p.cd_filial = 534
	And p.id_situacao = 'C'
	And (p.dh_pedido >= :inicio And p.dh_pedido <= :termino)" arguments=(("inicio", date),("termino", date))  sort="nr_pedido A " )
