table(column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_distribuidora.nr_pedido" dbalias="p.nr_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_pedido dbname="pedido_distribuidora.dh_pedido" dbalias="p.dh_pedido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_pedido dbname="pedido_distribuidora.vl_total_pedido" dbalias="p.vl_total_pedido" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="nm_usuario" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="pedido_distribuidora.id_situacao" dbalias="p.id_situacao" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_distribuidora.cd_filial" dbalias="p.cd_filial" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="pedido_distribuidora.cd_fornecedor" dbalias="p.cd_fornecedor" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc_filial dbname="filial.nr_cgc" dbalias="f.nr_cgc" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc_forn dbname="fornecedor.nr_cgc_forn" dbalias="o.nr_cgc_forn" )
 column=(type=datetime updatewhereclause=yes name=dh_envio_edi dbname="dh_envio_edi" )
 column=(type=char(1) updatewhereclause=yes name=nr_cgc_envio dbname="nr_cgc_envio" )
 column=(type=char(1) updatewhereclause=yes name=id_pbm dbname="id_pbm" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_pedido_edi dbname="fornecedor.id_pedido_edi" dbalias="o.id_pedido_edi" )
 column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="pedido_distribuidora.cd_distribuidora" dbalias="p.cd_distribuidora" )
 retrieve="Select p.nr_pedido_distribuidora As nr_pedido,
		 p.dh_emissao As dh_pedido,
		 p.vl_total_pedido,
		 (Select nm_usuario From usuario Where nr_matricula = '14330') As nm_usuario,
		 p.id_situacao,
		 p.cd_filial,
		 p.cd_distribuidora As cd_fornecedor,
		 f.nr_cgc,
		 o.nr_cgc As nr_cgc_forn,
		 getdate() As dh_envio_edi,
		 '' nr_cgc_envio,
		 'N' As id_pbm,
		 o.id_pedido_edi,
		 p.cd_distribuidora
From pedido_distribuidora p
	Inner Join filial f
		On f.cd_filial = p.cd_filial
	Inner Join fornecedor o
		On o.cd_fornecedor = p.cd_distribuidora
Where p.cd_filial = :filial
	And p.nr_pedido_distribuidora = :pedido
	And p.id_situacao = 'E'
	And p.id_tipo_pedido = '3'" arguments=(("filial", number),("pedido", number)) )
