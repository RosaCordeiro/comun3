table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="produto_geral.cd_fornecedor_usual" dbalias="g.cd_fornecedor_usual" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" dbalias="f.nm_razao_social" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_central_produto.cd_produto" dbalias="p.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="g.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" dbalias="g.de_apresentacao_estoque" )
 column=(type=long updatewhereclause=yes name=qt_estoque_momento dbname="pedido_central_produto.qt_estoque_momento" dbalias="p.qt_estoque_momento" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_central_produto.qt_pedida" dbalias="p.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="qt_recebida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="pedido_central_produto.vl_preco_unitario" dbalias="p.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pedido_central_produto.pc_desconto" dbalias="p.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_repasse_icms dbname="pc_repasse_icms" )
 column=(type=long updatewhereclause=yes name=qt_est_transito dbname="qt_est_transito" )
 column=(type=char(1) updatewhereclause=yes name=id_retira_qtde_pendente_meta dbname="id_retira_qtde_pendente_meta" )
 column=(type=long updatewhereclause=yes name=nr_embalagem_padrao dbname="pedido_central_produto.nr_embalagem_padrao" dbalias="p.nr_embalagem_padrao" )
 column=(type=long updatewhereclause=yes name=qt_devolvida dbname="qt_devolvida" )
 retrieve="Select	g.cd_fornecedor_usual,
		f.nm_razao_social,
		p.cd_produto,
		g.de_produto,
		g.de_apresentacao_estoque,
		p.qt_estoque_momento,
		p.qt_pedida,
		p.qt_recebida - coalesce(p.qt_devolvida, 0) qt_recebida,
		p.vl_preco_unitario,
		p.pc_desconto pc_desconto,
		CASE WHEN (select 1 
						 from parametro_geral 
						where cd_parametro like 'DH_INICIO_OPERACAO_SAP' 
						  and cast(right(vl_parametro, 4) + left(right(vl_parametro, 7), 2) + left(vl_parametro, 2) as date) <= getdate()) = 1
			THEN
				p.pc_repasse_icms
			ELSE
				0
		END pc_repasse_icms,
		0 qt_est_transito,
		coalesce(p.id_retira_qtde_pendente_meta, 'N') As id_retira_qtde_pendente_meta,
		p.nr_embalagem_padrao,

		(Select coalesce(sum(c.qt_devolvida), 0) As qt_devolvida
			From	nf_compra As n
				Inner Join item_nf_compra As i
				 On i.cd_filial			= n.cd_filial
				And i.cd_fornecedor	= n.cd_fornecedor
				And i.nr_nf				= n.nr_nf
				And i.de_especie		= n.de_especie
				And i.de_serie			= n.de_serie
			Left Outer Join nf_devolucao_compra As d
				On d.cd_filial = n.cd_filial
				And d.cd_fornecedor = n.cd_fornecedor
				And d.nr_nf_compra = n.nr_nf
				And d.de_especie_compra = n.de_especie
				And d.de_serie_compra = n.de_serie
			Left Outer Join nf_devolucao_compra_produto As c
				 On c.cd_filial			= d.cd_filial
				And c.nr_nf				= d.nr_nf
				And c.de_especie		= d.de_especie
				And c.de_serie			= d.de_serie
				And c.cd_produto		= i.cd_produto
		Where n.nr_pedido_central = p.nr_pedido
			And i.cd_produto = p.cd_produto
			And d.dh_cancelamento Is Null) As qt_devolvida

From	pedido_central_produto As p
	Inner Join produto_geral As g
		On g.cd_produto = p.cd_produto
	Inner Join fornecedor As f
		On f.cd_fornecedor = g.cd_fornecedor_usual
Where p.nr_pedido = :pedido
  and p.id_situacao	<> 'X'" arguments=(("pedido", number))  sort="nm_razao_social A de_produto A " )
