table(column=(type=char(40) updatewhereclause=yes name=de_subgrupo_produto dbname="subgrupo_produto.de_subgrupo_produto" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=compute_0003 dbname="compute_0003" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_venda_atual dbname="produto_geral.vl_preco_venda_atual" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto_atual dbname="produto_geral.pc_desconto_atual" )
 column=(type=decimal(15) update=yes updatewhereclause=yes name=vl_preco_liquido dbname="vl_preco_liquido" )
 retrieve="  SELECT subgrupo_produto.de_subgrupo_produto,
			produto_geral.cd_produto,   
         produto_geral.de_produto + ~" : ~" + produto_geral.de_apresentacao_estoque,   
         produto_geral.vl_preco_venda_atual,   
         produto_geral.pc_desconto_atual,   
         produto_geral.vl_preco_venda_atual * ( 1- (produto_geral.pc_desconto_atual/100) ) vl_preco_liquido
    FROM produto_geral, 
		   subgrupo_produto  
   WHERE subgrupo_produto.cd_grupo_produto    = produto_geral.cd_grupo_produto 
     AND subgrupo_produto.cd_subgrupo_produto = produto_geral.cd_subgrupo_produto 
     AND produto_geral.id_situacao            = 'A' 
     AND produto_geral.id_preco_bloqueado  	 = 'S'

UNION

  SELECT subgrupo_produto.de_subgrupo_produto,
			produto_geral.cd_produto,   
         produto_geral.de_produto + ~" : ~" + produto_geral.de_apresentacao_estoque,
         produto_geral.vl_preco_venda_atual,   
         produto_geral.pc_desconto_atual,   
         produto_geral.vl_preco_venda_atual * ( 1- (produto_geral.pc_desconto_atual/100) ) vl_preco_liquido
    FROM produto_geral, 
  			subgrupo_produto
   WHERE subgrupo_produto.cd_grupo_produto    = produto_geral.cd_grupo_produto 
     AND subgrupo_produto.cd_subgrupo_produto = produto_geral.cd_subgrupo_produto 
     AND produto_geral.id_situacao            = 'A' 
     AND produto_geral.id_preco_bloqueado  	 = 'N'
     AND produto_geral.cd_produto in (select p2.cd_produto 
														From promocao_sos p1, promocao_sos_produto p2
														Where p2.cd_promocao_sos    = p1.cd_promocao_sos
														  and p1.dh_inicio 		   <= :dt_movimento
														  and (p1.dh_termino is null or p1.dh_termino >= :dt_movimento)
														  and p1.id_preco_bloqueado = 'S'
														  and p1.id_situacao 		 = 'L')


" arguments=(("dt_movimento", date)) )
