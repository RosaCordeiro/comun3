 column=(type=char(10) updatewhereclause=yes name=nr_telefone_principal dbname="cliente_drogaexpress.nr_telefone_principal" )
 column=(type=char(10) updatewhereclause=yes name=nr_telefone_adicional dbname="cliente_drogaexpress.nr_telefone_adicional" )
 retrieve="  SELECT cliente_drogaexpress.de_endereco,   
         cliente_drogaexpress.de_referencia,   
         cliente_drogaexpress.de_bairro,   
         cliente_drogaexpress.nr_cep,   
         cliente_drogaexpress.nr_inscricao_estadual,   
         cliente_drogaexpress.nr_cgc_cpf,
         cliente_drogaexpress.id_fisica_juridica,
			cliente_drogaexpress.nr_telefone_principal,
			cliente_drogaexpress.nr_telefone_adicional
    FROM cliente_drogaexpress 
   WHERE cliente_drogaexpress.cd_cliente_drogaexpress = :ps_cliente
" arguments=(("ps_cliente", string)) )
