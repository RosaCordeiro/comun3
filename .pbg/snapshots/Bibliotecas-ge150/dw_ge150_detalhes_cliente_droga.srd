table(column=(type=char(40) updatewhereclause=yes name=de_endereco dbname="cliente_drogaexpress.de_endereco" )
 column=(type=char(40) updatewhereclause=yes name=de_referencia dbname="cliente_drogaexpress.de_referencia" )
