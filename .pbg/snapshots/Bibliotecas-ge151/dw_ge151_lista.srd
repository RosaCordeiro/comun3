table(column=(type=long updatewhereclause=yes name=cd_filial dbname="parametro_loja.cd_filial" dbalias="p.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=dt_geracao_estoque dbname="dt_geracao_estoque" )
 column=(type=char(40) updatewhereclause=yes name=dt_geracao_distribuidoras dbname="dt_geracao_distribuidoras" )
 column=(type=char(26) updatewhereclause=yes name=id_bloqueia_pedido_psico dbname="id_bloqueia_pedido_psico" )
 retrieve="Select	p.cd_filial,
		f.nm_fantasia,
		(select x.vl_parametro from parametro_loja x where x.cd_parametro = 'DT_INICIO_GERACAO_PEDIDO_ESTOQUE' and x.cd_filial = p.cd_filial) as dt_geracao_estoque,
		(select y.vl_parametro from parametro_loja y where y.cd_parametro = 'DT_INICIO_GERACAO_PEDIDO_DISTRIBUIDORAS' and y.cd_filial = p.cd_filial) as dt_geracao_distribuidoras,
		(CASE f.id_bloqueia_pedido_psico			
			WHEN '1' THEN 'BLOQUEIA PSICO'
			WHEN '2' THEN 'BLOQUEIA ANTIBIOTICO'
			WHEN '3' THEN 'BLOQUEIA PSICO/ANTIBIOTICO'
			WHEN '0' THEN 'N$$HEX1$$c300$$ENDHEX$$O BLOQUEIA'
		ELSE
			'N$$HEX1$$c300$$ENDHEX$$O BLOQUEIA'
		END) As id_bloqueia_pedido_psico
 From parametro_loja As p
	Inner Join filial As f
		On f.cd_filial = p.cd_filial
Where p.cd_parametro = 'DT_INICIO_GERACAO_PEDIDO_ESTOQUE'
	And p.vl_parametro <> '31/12/2099'
	And f.id_situacao = 'A'
	And f.id_pedido_centralizado = 'S'"  sort="nm_fantasia A " )
