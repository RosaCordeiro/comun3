table(column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=total_despesas dbname="total_despesas" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_produtos dbname="vl_total_produtos" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_recuperar_devolucao dbname="vl_recuperar_devolucao" )
 retrieve="Select	sum(d.vl_total_nf) As vl_total_nf,
		sum(d.vl_icms_st + vl_outras_despesas) As total_despesas,
		sum(d.vl_total_produtos) As vl_total_produtos,
		round(sum(d.vl_total_produtos)*0.01*0.83,2) As vl_recuperar_devolucao
From nf_devolucao_compra d
Where d.cd_fornecedor In ('053400519','053403312','053405354','053405356','053405404','053405539','053405860','053406093')
	And d.dh_movimentacao_caixa Between :inicio_mov And :termino_mov
	And d.dh_cancelamento Is Null" arguments=(("inicio_mov", datetime),("termino_mov", datetime)) )
