table(column=(type=long updatewhereclause=yes name=cd_pbm dbname="pbm.cd_pbm" dbalias="pb1.cd_pbm" )
 column=(type=char(40) updatewhereclause=yes name=nm_pbm dbname="pbm.nm_pbm" dbalias="pb1.nm_pbm" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 retrieve="select pb1.cd_pbm, pb1.nm_pbm, p1.cd_produto 
from pbm pb1
inner join pbm_produto p1 (index pk_pbm_produto)
	on p1.cd_pbm = pb1.cd_pbm
where p1.cd_pbm = pb1.cd_pbm
	and pb1.cd_convenio  in (52575,53724,53725)
	and pb1.cd_pbm = (	select max(p2.cd_pbm) 
								from pbm pb2	
								inner join pbm_produto p2 (index pk_pbm_produto) on p1.cd_pbm = pb1.cd_pbm
								where pb2.cd_convenio = pb1.cd_convenio 
								and p2.cd_produto = p1.cd_produto)
group by pb1.cd_pbm, pb1.nm_pbm, p1.cd_produto" )
