table(column=(type=char(8) updatewhereclause=yes name=nm_autorizadora dbname="nm_autorizadora" )
 column=(type=char(12) updatewhereclause=yes name=cd_convenio dbname="cd_convenio" )
 column=(type=char(40) updatewhereclause=yes name=nm_convenio dbname="nm_convenio" )
 column=(type=long updatewhereclause=yes name=cd_pbm dbname="cd_pbm" )
 column=(type=char(40) updatewhereclause=yes name=nm_pbm dbname="nm_pbm" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_atual dbname="pc_desconto_atual" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_sos dbname="pc_desconto_sos" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pmc dbname="vl_pmc" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo dbname="vl_custo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_melhor_venda dbname="vl_melhor_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pago_avista dbname="vl_pago_avista" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_reposicao_previsto dbname="vl_reposicao_previsto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pagto_previsto dbname="vl_pagto_previsto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pagto_realizado dbname="vl_pagto_realizado" )
 column=(type=long updatewhereclause=yes name=qt_venda dbname="qt_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda dbname="vl_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_previsto dbname="vl_previsto" )
 retrieve="  select 	'Vidalink' as nm_autorizadora,
			k.nr_comprovante_venda as cd_convenio,
			coalesce(cv.nm_conveniado,'N$$HEX1$$c300$$ENDHEX$$O IDENTIFICADO') as nm_convenio,
			cast(null as integer) as cd_pbm,
			cast(null as varchar(40)) as nm_pbm,
        		k.cd_filial,
         	x.cd_produto,
         	p.de_produto||' - '||p.de_apresentacao_estoque as de_produto,
			coalesce(p.pc_desconto_atual,0) as pc_desconto_atual,
			cast(0.00 as decimal(18,2)) as pc_desconto_sos,
			//Ordem PMC:  1 - PMC na venda_pbm_produto, 2- PMC do estado, 3- Pre$$HEX1$$e700$$ENDHEX$$o Venda Atual
			sum(x.qt_vendida * cast(round(case when x.vl_preco_maximo>0 then x.vl_preco_maximo else CASE WHEN coalesce(pu.vl_preco_venda_maximo,0) = 0 then pu.vl_preco_venda_atual else pu.vl_preco_venda_maximo end end / p.vl_fator_conversao, 2) as numeric(18,2))) as vl_pmc,
			sum(x.qt_vendida * coalesce(me.vl_custo_unitario,pc.vl_preco_reposicao)) as vl_custo,
         	sum(cast(0.00 as decimal(18,2))) as vl_melhor_venda,
			sum(x.qt_vendida * x.vl_pago_avista) as vl_pago_avista,
			sum(case  when cpp.id_tipo_reembolso in ('3','4') Then x.qt_vendida * (x.vl_praticado - coalesce(x.vl_pago_avista,0.00)) else 0.00 end) as vl_reposicao_previsto,
			sum(case  when cpp.id_tipo_reembolso in ('1','2') Then x.qt_vendida * (x.vl_praticado - coalesce(x.vl_pago_avista,0.00)) else 0.00 end) as vl_pagto_previsto,
			sum(cpp.vl_total_reembolso) as vl_pagto_realizado,
        		sum(x.qt_vendida) as qt_venda,
         	sum(x.qt_vendida * inf.vl_preco_praticado) as vl_venda,
         	sum(x.qt_vendida * inf.vl_preco_praticado)-sum(x.qt_vendida * x.vl_pago_avista) as vl_previsto
    from venda_pbm k (index idx_data_convenio)
inner join venda_pbm_produto x (index PK_VENDA_PBM_PRODUTO)
	on x.cd_filial = k.cd_filial 			and
		x.nr_nf = k.nr_nf 					and
		x.nr_sequencial_pbm = k.nr_sequencial_pbm and
		x.de_especie = k.de_especie 	and
		x.de_serie = k.de_serie
inner join nf_venda v (index pk_nf_venda)
	on v.cd_filial = k.cd_filial 			and
		v.nr_nf = k.nr_nf 					and
		v.de_especie = k.de_especie 	and
		v.de_serie = k.de_serie 
inner join item_nf_venda inf (index pk_item_nf_venda)
	on inf.cd_filial = x.cd_filial 			and
		inf.nr_nf = x.nr_nf 				and
		inf.de_especie = x.de_especie 	and
		inf.de_serie = x.de_serie 		and 
		inf.cd_produto = x.cd_produto  and 
		inf.nr_sequencial = x.nr_sequencial
inner join produto_geral p (index pk_produto_geral)
	on p.cd_produto = x.cd_produto
inner join produto_central pc
	on pc.cd_produto = x.cd_produto
inner join filial f (index pk_filial)
	on f.cd_filial = k.cd_filial
inner join cidade c  (index pk_cidade)
	on c.cd_cidade = f.cd_cidade
inner join produto_uf pu (index pk_produto_uf)
	on pu.cd_produto = x.cd_produto and
		pu.cd_unidade_federacao = c.cd_unidade_federacao
left outer join movimento_estoque me (index idx_nota)
	on	me.cd_filial_movimento = k.cd_filial 	and
		me.nr_nf = k.nr_nf 						and
		me.de_especie = k.de_especie			and
		me.de_serie = k.de_serie 				and
		me.cd_produto = x.cd_produto 		and
		me.dh_movimento = k.dh_venda		and 
		coalesce(me.nr_sequencial,1) = x.nr_sequencial
left outer join conveniado cv (index idx_convenio_pbm)
	on	cv.cd_convenio = k.cd_convenio and
		cv.cd_convenio_pbm = k.nr_comprovante_venda
left outer join conciliacao_pbm_produto cpp (index idx_conciliacao_pbm_produt_ak1)
	on	cpp.cd_filial_venda = k.cd_filial 			and
		cpp.nr_nf_venda = k.nr_nf 					and
		cpp.de_especie_venda = k.de_especie 	and
		cpp.de_serie_venda = k.de_serie 			and
		cpp.cd_produto = x.cd_produto				and
		cpp.cd_convenio_pbm = k.cd_convenio
where k.dh_venda between :dt_inicio and :dt_fim and
			k.cd_convenio in (52575,53724,53725) and //Vidalink
			v.dh_cancelamento is null and
			v.nr_nf_anexa is null	
group by k.nr_comprovante_venda,
			coalesce(cv.nm_conveniado,'N$$HEX1$$c300$$ENDHEX$$O IDENTIFICADO'),
        		k.cd_filial,
         	x.cd_produto,
         	p.de_produto||' - '||p.de_apresentacao_estoque,
			coalesce(p.pc_desconto_atual,0)" arguments=(("dt_inicio", date),("dt_fim", date)) )
