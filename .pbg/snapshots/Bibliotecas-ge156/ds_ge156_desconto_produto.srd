table(column=(type=long updatewhereclause=yes name=cd_filial dbname="promocao_sos_filial.cd_filial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="promocao_sos_produto.cd_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_sos dbname="pc_desconto_sos" )
 retrieve="select f1.cd_filial,
		p1.cd_produto,
		max(p1.pc_desconto) as pc_desconto_sos
 from promocao_sos x1
inner join promocao_sos_produto p1
	on p1.cd_promocao_sos = x1.cd_promocao_sos
inner join promocao_sos_filial f1
	on f1.cd_promocao_sos = x1.cd_promocao_sos
where x1.id_tipo_promocao = 'N' and
		x1.id_situacao = 'L'  and
		x1.dh_termino >= :dt_inicio and
		x1.dh_inicio <= :dt_inicio and
		f1.cd_filial = :cd_filial and
		p1.cd_produto = :cd_prod
group by f1.cd_filial,
			p1.cd_produto" arguments=(("dt_inicio", date),("cd_prod", number),("cd_filial", number))  sort="pc_desconto_sos D " )
