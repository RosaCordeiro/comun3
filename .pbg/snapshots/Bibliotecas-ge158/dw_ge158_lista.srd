table(column=(type=long updatewhereclause=yes key=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_boleto dbname="vl_boleto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_transf_eletr dbname="vl_transf_eletr" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_visa dbname="vl_visa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_master_card dbname="vl_master_card" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_dinners dbname="vl_dinners" )
 retrieve="SELECT distinct f.cd_filial,   
       f.nm_fantasia,
	   0.00 vl_boleto,
       0.00 vl_transf_eletr,
	   0.00 vl_visa,
	   0.00 vl_master_card,
	   0.00 vl_dinners
from filial f
where exists (	select nf1.cd_filial 
					from nf_venda nf1 (index idx_data_ped_ecommerce)
					where nf1.dh_movimentacao_caixa between :inicio and :termino
						and Coalesce( nf1.cd_filial_ecommerce, 809 ) = :filial_ecommerce
						and nf1.cd_filial = f.cd_filial
						and nf1.nr_pedido_ecommerce 	is not null
						and nf1.nr_nf_anexa					is null
						and nf1.dh_cancelamento	  		is null)
   



" update="filial" updatewhere=0 updatekeyinplace=no arguments=(("inicio", date),("termino", date),("filial_ecommerce", number))  sort="vl_venda_total D " )
