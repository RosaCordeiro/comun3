table(column=(type=char(40) updatewhereclause=yes name=de_mix_produto dbname="mix_produto.de_mix_produto" dbalias="m.de_mix_produto" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="pg.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="pg.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="pg.de_apresentacao_venda" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" dbalias="pg.id_situacao" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="vw_classificacao_produto.de_grupo" dbalias="v.de_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo dbname="vw_classificacao_produto.de_subgrupo" dbalias="v.de_subgrupo" )
 column=(type=char(40) updatewhereclause=yes name=de_categoria dbname="vw_classificacao_produto.de_categoria" dbalias="v.de_categoria" )
 column=(type=char(40) updatewhereclause=yes name=subcategoria dbname="vw_classificacao_produto.de_subcategoria" dbalias="v.de_subcategoria" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" dbalias="pg.de_codigo_barras" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="pg.vl_fator_conversao" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_preco_venda_atual dbname="vl_preco_venda_atual" )
 column=(type=date updatewhereclause=yes name=dh_inclusao_produto dbname="dh_inclusao_produto" )
 column=(type=long updatewhereclause=yes name=qt_saldo_ec dbname="qt_saldo_ec" )
 column=(type=long updatewhereclause=yes name=qt_saldo_fil dbname="qt_saldo_fil" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_filiais dbname="qt_estoque_base_filiais" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="produto_geral.cd_fornecedor_usual" dbalias="pg.cd_fornecedor_usual" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" dbalias="f.nm_razao_social" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_comprador dbname="produto_central.nr_matricula_comprador" dbalias="pc.nr_matricula_comprador" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="u.nm_usuario" )
 column=(type=datetime updatewhereclause=yes name=dt_ultima_entrada dbname="dt_ultima_entrada" )
 column=(type=long updatewhereclause=yes name=qt_venda_6_meses dbname="qt_venda_6_meses" )
 column=(type=long updatewhereclause=yes name=qt_venda_mes_atual dbname="qt_venda_mes_atual" )
 retrieve="Select	m.de_mix_produto,
		pg.cd_produto,
		pg.de_produto,
		pg.de_apresentacao_venda,
		pg.id_situacao,
		v.de_grupo,
		v.de_subgrupo,
		v.de_categoria,
		v.de_subcategoria,
		pg.de_codigo_barras,
		pg.vl_fator_conversao,
		round(pg.vl_preco_venda_atual / pg.vl_fator_conversao, 2) As vl_preco_venda_atual,
		Cast(pg.dh_inclusao_produto As Date) dh_inclusao_produto,
		0 qt_saldo_ec,
		0 qt_saldo_fil,
		(Select coalesce(r.qt_estoque_base, 0)
			From resumo_estoque_base_filiais As r
		Where r.cd_produto = pg.cd_produto) As qt_estoque_base_filiais,
		pg.cd_fornecedor_usual,
		f.nm_razao_social,
		pc.nr_matricula_comprador,
		u.nm_usuario,
		(Select max(x.dh_resumo)
		From resumo_movto_estq_prd As x
		Where x.dh_resumo >= pg.dh_inclusao_produto
		   And x.cd_produto = pg.cd_produto
		   And x.cd_filial <> 1
		   And x.qt_compra > 0) As dt_ultima_entrada,
		0 qt_venda_6_meses,
		0 qt_venda_mes_atual
From produto_geral As pg
	Left Outer Join produto_central As pc
		On pc.cd_produto = pg.cd_produto
	Inner Join mix_produto As m
		On m.cd_mix_produto = pc.cd_mix_produto
	Inner Join vw_classificacao_produto As v
		On v.cd_subcategoria = pg.cd_subcategoria
	Left Outer Join fornecedor As f
		On f.cd_fornecedor = pg.cd_fornecedor_usual
	Left Outer Join usuario As u
		On u.nr_matricula = pc.nr_matricula_comprador
Where pg.dh_inclusao_produto >= :dt_inicio
	And pg.dh_inclusao_produto <= :dt_termino" arguments=(("dt_inicio", date),("dt_termino", date)) )
