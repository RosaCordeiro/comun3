table(column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="vw_classificacao_produto.de_grupo" dbalias="v.de_grupo" )
 column=(type=char(50) updatewhereclause=yes name=de_planograma dbname="categoria_planograma.de_planograma" dbalias="cp.de_planograma" )
 column=(type=char(40) updatewhereclause=yes name=de_mix_produto dbname="mix_produto.de_mix_produto" dbalias="m.de_mix_produto" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="pg.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="pg.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="pg.de_apresentacao_venda" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" dbalias="pg.id_situacao" )
 column=(type=date updatewhereclause=yes name=dh_inclusao_produto dbname="dh_inclusao_produto" )
 column=(type=date updatewhereclause=yes name=dh_termino_avaliacao dbname="dh_termino_avaliacao" )
 column=(type=date updatewhereclause=yes name=dh_revisao_fiscal dbname="dh_revisao_fiscal" )
 column=(type=long updatewhereclause=yes name=qt_dias_sem_entrada dbname="qt_dias_sem_entrada" )
 column=(type=long updatewhereclause=yes name=nr_pedido_ec dbname="nr_pedido_ec" )
 column=(type=long updatewhereclause=yes name=qt_pedida_ec dbname="qt_pedida_ec" )
 column=(type=date updatewhereclause=yes name=dh_pedido_ec dbname="dh_pedido_ec" )
 column=(type=date updatewhereclause=yes name=dh_primeira_compra_cd dbname="dh_primeira_compra_cd" )
 column=(type=long updatewhereclause=yes name=qt_primeira_entrada_cd dbname="qt_primeira_entrada_cd" )
 column=(type=date updatewhereclause=yes name=dh_primeira_compra_distrib dbname="dh_primeira_compra_distrib" )
 column=(type=date updatewhereclause=yes name=dh_estoque_base_inicial dbname="dh_estoque_base_inicial" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_cad_eb dbname="usuario.nm_usuario_cad_eb" dbalias="ueb.nm_usuario_cad_eb" )
 column=(type=long updatewhereclause=yes name=qt_filial_estoque_base_inicial dbname="produto_central.qt_filial_estoque_base_inicial" dbalias="pc.qt_filial_estoque_base_inicial" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_inicial dbname="produto_central.qt_estoque_base_inicial" dbalias="pc.qt_estoque_base_inicial" )
 column=(type=long updatewhereclause=yes name=qt_filial_possui_eb_atual dbname="qt_filial_possui_eb_atual" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_atual dbname="qt_estoque_base_atual" )
 column=(type=long updatewhereclause=yes name=dif_primeira_ent_primeiro_fac dbname="dif_primeira_ent_primeiro_fac" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="pg.vl_fator_conversao" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_preco_venda_atual dbname="vl_preco_venda_atual" )
 column=(type=char(40) updatewhereclause=yes name=nm_comprador dbname="usuario.nm_comprador" dbalias="u.nm_comprador" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_cadastro dbname="usuario.nm_usuario_cadastro" dbalias="uc.nm_usuario_cadastro" )
 retrieve="Select	v.de_grupo,
		cp.de_planograma,
		m.de_mix_produto,
		pg.cd_produto,
		pg.de_produto,
		pg.de_apresentacao_venda,
		pg.id_situacao,
		Cast(pg.dh_inclusao_produto As Date) As dh_inclusao_produto,
		Cast(pg.dh_termino_avaliacao As Date) dh_termino_avaliacao,
		Cast(pc.dh_revisao_fiscal As Date) As dh_revisao_fiscal,
		0 qt_dias_sem_entrada,
		0 As nr_pedido_ec,
		0 As qt_pedida_ec,
		Cast('1900/01/01' As Date) dh_pedido_ec,
		Cast(pc.dh_primeira_compra_cd As Date) As dh_primeira_compra_cd,
		0 As qt_primeira_entrada_cd,
		Cast(pc.dh_primeira_compra_distrib As Date) As dh_primeira_compra_distrib,
		Cast(pc.dh_estoque_base_inicial As Date) As dh_estoque_base_inicial,
		ueb.nm_usuario As nm_usuario_cad_eb,
		pc.qt_filial_estoque_base_inicial,
		pc.qt_estoque_base_inicial,
		(Select Coalesce(Count(cd_filial), 0)
			From resumo_reposicao_estoque
			Where cd_produto = pg.cd_produto
			And qt_estoque_base > 0) As qt_filial_possui_eb_atual,
		(Select Coalesce(Sum(qt_estoque_base), 0)
			From resumo_reposicao_estoque
		Where cd_produto = pg.cd_produto) As qt_estoque_base_atual,
		0 dif_primeira_ent_primeiro_fac,
		pg.vl_fator_conversao,
		round(pg.vl_preco_venda_atual / pg.vl_fator_conversao, 2) As vl_preco_venda_atual,
		u.nm_usuario As nm_comprador,
		uc.nm_usuario As nm_usuario_cadastro
From produto_geral As pg
	Left Outer Join produto_central As pc
		On pc.cd_produto = pg.cd_produto
	Inner Join mix_produto As m
		On m.cd_mix_produto = pc.cd_mix_produto
	Inner Join vw_classificacao_produto As v
		On v.cd_subcategoria = pg.cd_subcategoria
	Left Outer Join fornecedor As f
		On f.cd_fornecedor = pg.cd_fornecedor_usual
	Left Outer Join usuario As u
		On u.nr_matricula = pc.nr_matricula_comprador
	Left Outer Join usuario As ueb
		On ueb.nr_matricula = pc.nr_matric_estoque_base_inicial
	Left Outer Join usuario As uc
		On uc.nr_matricula = pg.nr_matricula_inclusao
	Left Outer Join categoria_planograma As cp
		On cp.cd_planograma = pg.cd_planograma
Where pg.dh_inclusao_produto >= :dt_inicio
	And pg.dh_inclusao_produto <= :dt_termino" arguments=(("dt_inicio", date),("dt_termino", date)) )
