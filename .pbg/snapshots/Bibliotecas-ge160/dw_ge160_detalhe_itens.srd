table(column=(type=char(102) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_devolvida dbname="item_nf_devolucao_venda.qt_devolvida" dbalias="i.qt_devolvida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_devolucao_venda.vl_preco_unitario" dbalias="i.vl_preco_unitario" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_preco_praticado dbname="vl_preco_praticado" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="item_nf_devolucao_venda.pc_desconto" dbalias="i.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="item_nf_devolucao_venda.pc_icms" dbalias="i.pc_icms" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_devolucao_venda.cd_produto" dbalias="i.cd_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao_preco dbname="item_nf_venda.id_alteracao_preco" dbalias="iv.id_alteracao_preco" values="N$$HEX1$$c300$$ENDHEX$$O	N/SIM	S/" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_maximo dbname="venda_pbm_produto.vl_preco_maximo" dbalias="pp.vl_preco_maximo" )
 column=(type=datetime updatewhereclause=yes name=dh_pagamento dbname="conciliacao_pbm_produto.dh_pagamento" dbalias="cpp.dh_pagamento" )
 column=(type=char(1) updatewhereclause=yes name=id_conciliada dbname="venda_pbm_produto.id_conciliada" dbalias="pp.id_conciliada" values="	S/	N" )
 retrieve="SELECT 	p.de_produto||': '||p.de_apresentacao_venda as de_produto,
			i.qt_devolvida ,
			i.vl_preco_unitario , 
			(i.qt_devolvida * Round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2)) as vl_preco_praticado, 
			i.pc_desconto,  
			i.pc_icms , 
			i.cd_produto ,
			iv.id_alteracao_preco,
			pp.vl_preco_maximo,
			cpp.dh_pagamento as dh_pagamento,
			pp.id_conciliada
  FROM nf_devolucao_venda n
Inner Join item_nf_devolucao_venda i
   On 	i.cd_filial			= n.cd_filial 			and 
		i.nr_nf			= n.nr_nf   			and 
		i.de_especie		= n.de_especie 	and 
		i.de_serie		= n.de_serie 	
Inner Join produto_geral p
	On p.cd_produto 	= i.cd_produto
Inner Join venda_pbm vp
   On 	vp.cd_filial		= n.cd_filial_venda 		and 
		vp.nr_nf			= n.nr_nf_venda   			and 
		vp.de_especie	= n.de_especie_venda 	and 
		vp.de_serie		= n.de_serie_venda 	
Inner Join item_nf_venda iv
   On 	iv.cd_filial		= vp.cd_filial 		and 
		iv.nr_nf			= vp.nr_nf   		and 
		iv.de_especie	= vp.de_especie	and 
		iv.de_serie		= vp.de_serie 		and 
		iv.cd_produto	= i.cd_produto
Left Outer Join venda_pbm_produto pp
   On 	pp.cd_filial		= iv.cd_filial 		and 
		pp.nr_nf			= iv.nr_nf   			and 
		pp.de_especie	= iv.de_especie 	and 
		pp.de_serie		= iv.de_serie 		and 
		pp.cd_produto	= iv.cd_produto	and 
		pp.nr_sequencial = iv.nr_sequencial and
		pp.nr_sequencial_pbm = vp.nr_sequencial_pbm
left outer join conciliacao_pbm_produto cpp
	on	cpp.cd_filial_venda 		= iv.cd_filial 		and
		cpp.nr_nf_venda 			= iv.nr_nf 			and
		cpp.de_especie_venda 	= iv.de_especie 	and
		cpp.de_serie_venda 		= iv.de_serie 		and
		cpp.cd_produto 			= iv.cd_produto	and
		cpp.cd_convenio_pbm 	= vp.cd_convenio
 WHERE 	n.cd_filial		= :pl_filial 
	and 	n.nr_nf      		= :pl_nr_nf 
	and 	n.de_especie	= :ps_especie
	and 	n.de_serie   	= :ps_serie
" arguments=(("pl_filial", number),("pl_nr_nf", number),("ps_especie", string),("ps_serie", string)) )
