table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_devolucao_venda.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_devolucao_venda.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_devolucao_venda.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_devolucao_venda.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_devolucao_venda.dh_movimentacao_caixa" )
 column=(type=char(20) updatewhereclause=yes name=vp_nr_autorizacao dbname="nr_autorizacao" )
 column=(type=char(12) updatewhereclause=yes name=vp_nr_comprovante_venda dbname="nr_comprovante_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="nf_devolucao_venda.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_devolucao_venda.vl_total_nf" )
 column=(type=long updatewhereclause=yes name=nr_lote_convenio dbname="nr_lote_convenio" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="cd_convenio" )
 column=(type=char(60) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="nf_devolucao_venda.dh_cancelamento" )
 column=(type=char(60) updatewhereclause=yes name=cd_convenio_pbm dbname="cd_convenio_pbm" )
 column=(type=datetime updatewhereclause=yes name=dh_pagamento dbname="dh_pagamento" )
 column=(type=char(1) updatewhereclause=yes name=id_conciliada dbname="id_conciliada" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_status_sitef dbname="id_status_sitef" )
 column=(type=long updatewhereclause=yes name=nr_sequencial_pbm dbname="nr_sequencial_pbm" )
 retrieve="SELECT	nf.cd_filial,   
			nf.nr_nf,   
			nf.de_especie,   
			nf.de_serie,   
			nf.dh_movimentacao_caixa,   
			vp.nr_autorizacao, 
			vp.nr_comprovante_venda,
			nf.pc_desconto,      
			nf.vl_total_nf as vl_total_nf,
			coalesce(v.nr_lote_convenio,0) as nr_lote_convenio,
			cv.cd_convenio,
			cv.nm_fantasia,   
			nf.dh_cancelamento,   
			case when vp.cd_convenio = 52718 then ceb.nm_cliente else coalesce(coalesce(fun.nm_conveniado,pg.nm_conveniado),case when vp.cd_convenio  in (52575,53724,53725) then vp.nr_comprovante_venda else vp.cd_convenio_pbm end) end as cd_convenio_pbm,  
			max(cpp.dh_pagamento) as dh_pagamento, 
			vp.id_conciliada,
			coalesce(vp.id_status_sitef, '') as id_status_sitef,
			vp.nr_sequencial_pbm
    FROM nf_devolucao_venda nf
Inner Join venda_pbm vp (index pk_venda_pbm)
	On 	vp.cd_filial 	= nf.cd_filial_venda
	and 	vp.nr_nf 		= nf.nr_nf_venda
	and	vp.de_especie	= nf.de_especie_venda
	and	vp.de_serie 	= nf.de_serie_venda
inner join  venda_pbm_produto vpp (index PK_VENDA_PBM_PRODUTO)
	on 	vpp.cd_filial 	= vp.cd_filial 
	and 	vpp.nr_nf 		= vp.nr_nf 
	and	vpp.de_especie	= vp.de_especie 
	and	vpp.de_serie 	= vp.de_serie
	and 	vpp.nr_sequencial_pbm = vp.nr_sequencial_pbm
INNER JOIN nf_venda v (index pk_nf_venda)
	on 	v.cd_filial 	= vp.cd_filial+0
	and 	v.nr_nf 			= vp.nr_nf+0
	and	v.de_especie 	= vp.de_especie 
	and	v.de_serie 		= vp.de_serie 
INNER JOIN convenio cv (index pk_convenio)
	on cv.cd_convenio 	= vp.cd_convenio 
left outer join conveniado pg (index idx_convenio_pbm)
	on pg.cd_convenio = vp.cd_convenio
	and pg.cd_convenio_pbm = case when vp.cd_convenio in (52575,53724,53725) then vp.nr_comprovante_venda else vp.cd_convenio_pbm end
left outer join conveniado fun (index pk_conveniado)
	on fun.cd_convenio = vp.cd_convenio
	and fun.cd_conveniado = (case when vp.cd_convenio = 52349 then vp.cd_convenio_pbm else null end)
left outer join conciliacao_pbm_produto cpp (index idx_conciliacao_pbm_produt_ak1)
	on	cpp.cd_filial_venda = vpp.cd_filial 			and
		cpp.nr_nf_venda = vpp.nr_nf 				and
		cpp.de_especie_venda = vp.de_especie 	and
		cpp.de_serie_venda = vpp.de_serie 		and
		cpp.cd_produto = vpp.cd_produto			and
		cpp.cd_convenio_pbm = vp.cd_convenio
left outer join convenio_epharma_beneficio ceb
  on ceb.cd_convenio_epharma = cpp.cd_convenio_epharma
	and ceb.cd_cliente      			= cpp.cd_cliente
	and ceb.cd_beneficio 				= cpp.cd_beneficio
WHERE nf.dh_movimentacao_caixa between :dt_inicio and :dt_fim
    and nf.dh_cancelamento 	is null
    and v.nr_nf_anexa is null
GROUP by 	nf.cd_filial,   
				nf.nr_nf,   
				nf.de_especie,   
				nf.de_serie,   
				nf.dh_movimentacao_caixa,   
				vp.nr_autorizacao, 
				vp.nr_comprovante_venda,
				nf.pc_desconto,      
				nf.vl_total_nf,
				coalesce(v.nr_lote_convenio,0),
				cv.cd_convenio,
				cv.nm_fantasia,   
				nf.dh_cancelamento,   
				case when vp.cd_convenio = 52718 then ceb.nm_cliente else coalesce(coalesce(fun.nm_conveniado,pg.nm_conveniado),case when vp.cd_convenio in (52575,53724,53725) then vp.nr_comprovante_venda else vp.cd_convenio_pbm end) end,  
				vp.id_conciliada,
				coalesce(vp.id_status_sitef, ''),
				vp.nr_sequencial_pbm" arguments=(("dt_inicio", date),("dt_fim", date))  sort="dh_movimentacao_caixa A cd_filial A " )
