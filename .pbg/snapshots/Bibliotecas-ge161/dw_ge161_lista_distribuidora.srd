table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="filial_distribuidora.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia_filial dbname="filial.nm_fantasia" )
 column=(type=char(9) update=yes updatewhereclause=yes key=yes name=cd_distribuidora dbname="filial_distribuidora.cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=char(20) update=yes updatewhereclause=yes name=cd_filial_distribuidora dbname="filial_distribuidora.cd_filial_distribuidora" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="filial_distribuidora.id_situacao" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matric_alteracao_situacao dbname="filial_distribuidora.nr_matric_alteracao_situacao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_alteracao_situacao dbname="filial_distribuidora.dh_alteracao_situacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=long updatewhereclause=yes name=qt_homologacao dbname="qt_homologacao" )
 column=(type=char(14) update=yes updatewhereclause=yes name=nr_gln dbname="filial_distribuidora.nr_gln" )
 column=(type=long updatewhereclause=yes name=id_conveniencia dbname="id_conveniencia" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_minimo_pedido dbname="filial_distribuidora.vl_minimo_pedido" )
 column=(type=long update=yes updatewhereclause=yes name=nr_prazo_entrega dbname="filial_distribuidora.nr_prazo_entrega" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_horario_corte dbname="filial_distribuidora.dh_horario_corte" )
 retrieve="Select	fd.cd_filial,
		fi.nm_fantasia,
		fd.cd_distribuidora,
		fo.nm_fantasia,
		fd.cd_filial_distribuidora,
		fd.id_situacao,
		fd.nr_matric_alteracao_situacao,
		fd.dh_alteracao_situacao,
		us.nm_usuario,

		(select count(*) from distribuidora_uf d
		  where d.cd_distribuidora = fd.cd_distribuidora
			 and d.cd_unidade_federacao = c.cd_unidade_federacao
			and d.id_homologando_pedido = 'S') qt_homologacao,

		fd.nr_gln,

		(select count(*)
		 from distribuidora_forn_conexao d
			inner join fornecedor f1
				on f1.cd_fornecedor = d.cd_distribuidora
			inner join fornecedor f2
				on f2.cd_fornecedor = d.cd_fornecedor
		 where f1.cd_fornecedor = fd.cd_distribuidora
			and (f1.id_situacao = 'A' or f1.id_situacao is null)
			and (f2.id_situacao = 'A' or f2.id_situacao is null)
			and f2.id_projeto_conexao = '6') as id_conveniencia,
		 fd.vl_minimo_pedido,
		 fd.nr_prazo_entrega,
		 fd.dh_horario_corte
From filial_distribuidora As fd
	Inner Join filial As fi
		On fi.cd_filial = fd.cd_filial
	Inner Join cidade c
		on c.cd_cidade	= fi.cd_cidade
	Inner Join fornecedor As fo
		On fo.cd_fornecedor = fd.cd_distribuidora
	Left Outer Join usuario As us
		On us.nr_matricula = fd.nr_matric_alteracao_situacao
Where fo.id_distribuidora = 'S'" update="filial_distribuidora" updatewhere=0 updatekeyinplace=no  sort="cd_filial A nm_fantasia_filial A " )
