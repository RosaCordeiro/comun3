table(column=(type=decimal(0) updatewhereclause=yes identity=yes name=nr_bloqueio dbname="pedido_filial_bloqueio.nr_bloqueio" )
 column=(type=char(9) update=yes updatewhereclause=yes name=cd_distribuidora dbname="pedido_filial_bloqueio.cd_distribuidora" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="pedido_filial_bloqueio.cd_filial" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_pedido dbname="pedido_filial_bloqueio.dh_pedido" )
 column=(type=long update=yes updatewhereclause=yes name=nr_dia_semana dbname="pedido_filial_bloqueio.nr_dia_semana" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inclusao dbname="pedido_filial_bloqueio.dh_inclusao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_envio_email dbname="pedido_filial_bloqueio.dh_envio_email" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=char(200) update=yes updatewhereclause=yes name=de_motivo_bloqueio dbname="pedido_filial_bloqueio.de_motivo_bloqueio" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_inclusao dbname="pedido_filial_bloqueio.nr_matricula_inclusao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_tipo_bloqueio dbname="pedido_filial_bloqueio.id_tipo_bloqueio" )
 column=(type=char(5) update=yes updatewhereclause=yes name=cd_uf dbname="cd_uf" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inicio_bloqueio dbname="dh_inicio_bloqueio" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_termino_bloqueio dbname="dh_termino_bloqueio" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao dbname="dh_movimentacao" )
 retrieve="Select	
		p.nr_bloqueio,
		p.cd_distribuidora,
		p.cd_filial,
		p.dh_pedido,
		p.nr_dia_semana,
		p.dh_inclusao,
		p.dh_envio_email,
		fo.nm_fantasia,
		p.de_motivo_bloqueio,
		p.nr_matricula_inclusao,
		u.nm_usuario,
		p.id_tipo_bloqueio,
		COALESCE(p.cd_uf, 'GERAL') cd_uf,
		COALESCE(p.dh_inicio_bloqueio, p.dh_pedido) dh_inicio_bloqueio,
		COALESCE(p.dh_termino_bloqueio, p.dh_pedido) dh_termino_bloqueio,
		(select dh_movimentacao from dbo.parametro) dh_movimentacao
From pedido_filial_bloqueio As p
	Inner Join fornecedor As fo
		On fo.cd_fornecedor = p.cd_distribuidora
	Left Outer Join usuario As u
		On u.nr_matricula = p.nr_matricula_inclusao
Where p.cd_filial Is Null
And p.nr_dia_semana Is Null
And p.id_tipo_bloqueio = 'D'
and p.cd_distribuidora is not null
and fo.id_distribuidora = 'S'"  sort="nm_fantasia A dh_inicio_bloqueio A dh_termino_bloqueio A cd_uf A " )
