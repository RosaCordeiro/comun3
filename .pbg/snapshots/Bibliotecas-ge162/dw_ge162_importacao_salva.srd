 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_atual dbname="distribuidora_produto.vl_preco_atual" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto_atual dbname="distribuidora_produto.pc_desconto_atual" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="distribuidora_produto.id_situacao" )
 column=(type=long updatewhereclause=yes name=nr_linha dbname="nr_linha" )
 column=(type=char(1) updatewhereclause=yes name=id_incluir dbname="id_incluir" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_erro dbname="id_erro" )
 column=(type=char(1) updatewhereclause=yes name=de_msg dbname="de_msg" )
 retrieve="select cd_produto, 
       '' de_produto,
       cd_produto_distribuidora,
       vl_preco_atual,   
       pc_desconto_atual,   
       id_situacao,
	   0 nr_linha,
	   'N' id_incluir,
       'N' id_erro,
       ''  de_msg
from distribuidora_produto"  sort="de_produto A " )
