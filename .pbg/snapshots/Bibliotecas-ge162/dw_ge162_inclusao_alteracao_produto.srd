 column=(type=decimal(2) updatewhereclause=yes name=pc_reducao_base_icms dbname="distribuidora_produto.pc_reducao_base_icms" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao_preco dbname="distribuidora_produto.dh_alteracao_preco_desconto" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_alteracao_preco dbname="distribuidora_produto.nr_matric_alteracao_preco" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="distribuidora_produto.dh_inclusao" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="distribuidora_produto.id_situacao" initial="A" values="ATIVO	A/INATIVO	I/BLOQUEADO	B/PENDENTE	P/EM ANALISE	E/" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_alteracao dbname="distribuidora_produto.id_situacao_alteracao" initial="A" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao_situacao dbname="distribuidora_produto.dh_alteracao_situacao" )
