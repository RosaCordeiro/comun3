 column=(type=char(6) updatewhereclause=yes name=nr_matric_alteracao_situacao dbname="distribuidora_produto.nr_matric_alteracao_situacao" )
 column=(type=char(40) updatewhereclause=yes name=de_alteracao_situacao dbname="distribuidora_produto.de_alteracao_situacao" )
 column=(type=char(40) updatewhereclause=yes name=de_alteracao_situacao_atual dbname="distribuidora_produto.de_alteracao_situacao_atual" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao_distribuidora dbname="distribuidora_produto.dh_atualizacao_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_alteracao_preco dbname="usuario.nm_alteracao_preco" )
 column=(type=char(40) updatewhereclause=yes name=nm_alteracao_situacao dbname="usuario.nm_alteracao_situacao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_financeiro dbname="pc_desconto_financeiro" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="distribuidora_produto.vl_icms_st" )
 column=(type=long updatewhereclause=yes name=nr_dias_pagamento dbname="distribuidora_produto.nr_dias_pagamento" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_juros dbname="pc_juros1" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_juros_mensal dbname="pc_juros_mensal" )
 column=(type=char(1) updatewhereclause=yes name=cd_tributacao_icms dbname="produto_geral.cd_tributacao_icms" )
 column=(type=long updatewhereclause=yes name=qt_embalagem_padrao_distrib dbname="qt_embalagem_padrao_distrib" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_anterior dbname="distribuidora_produto.id_situacao_anterior" values="ATIVO	A/INATIVO	I/BLOQUEADO	B/PENDENTE	P/EM ANALISE	E/" )
 column=(type=char(40) updatewhereclause=yes name=de_alteracao_situacao_anterior dbname="distribuidora_produto.de_alteracao_situacao_anterior" )
 retrieve="select d.cd_distribuidora,
       d.cd_produto,
       d.cd_unidade_federacao,
       g.de_produto + ' : ' + g.de_apresentacao_estoque de_produto,
       g.cd_fornecedor_usual,
       fu.nm_razao_social,
       d.cd_produto_distribuidora,
	   d.cd_produto_distribuidora cd_produto_alteracao,
       d.vl_preco_atual,
       d.pc_desconto_atual,
       d.vl_preco_atual vl_preco_alteracao,
       d.pc_desconto_atual pc_desconto_alteracao,
       d.vl_preco_anterior,
       d.pc_desconto_anterior,
       d.vl_preco_novo,
       d.pc_desconto_novo,
       d.pc_repasse_icms,
       d.pc_icms,
       d.pc_reducao_base_icms,
       d.dh_alteracao_preco_desconto,
       d.nr_matric_alteracao_preco,
       d.dh_inclusao, 
       d.id_situacao,
       d.id_situacao id_situacao_alteracao,
       d.dh_alteracao_situacao,
       d.dh_alteracao_situacao_termino,
       d.nr_matric_alteracao_situacao,
       d.de_alteracao_situacao,
	   d.de_alteracao_situacao as de_alteracao_situacao_atual,
       d.dh_atualizacao_distribuidora,
       up.nm_usuario nm_alteracao_preco,
	   us.nm_usuario nm_alteracao_situacao,
		// chamado 902727 - a partir da data definida em fornecedor.dh_vigencia_midia, passa a buscar o percentual de midia de distribuidora_produto.pc_comissao_midia
       isnull(case when convert(varchar,coalesce(fd.dh_vigencia_midia, '2099-01-01'),102)<= convert(varchar,getdate(),102) then d.pc_comissao_midia else fd.pc_desconto_financeiro end, 0) as pc_desconto_financeiro,
	   d.vl_icms_st,
	   d.nr_dias_pagamento,
	   round(isnull(p.pc_juros_diario_ped_eletronico, 0) * isnull(d.nr_dias_pagamento, 0), 2) pc_juros1,
       round(p.pc_juros_diario_ped_eletronico * 30, 2) as pc_juros_mensal,
	  g.cd_tributacao_icms,
	  coalesce(d.qt_embalagem_padrao_distrib, 1) as qt_embalagem_padrao_distrib,
	  d.id_situacao_anterior,
	  d.de_alteracao_situacao_anterior
from distribuidora_produto d,
     fornecedor fd,
     produto_geral g,
     fornecedor fu,
     usuario up,
     usuario us,
	 parametro p
where d.cd_distribuidora     = :distribuidora
  and d.cd_produto           = :produto
  and d.cd_unidade_federacao = :uf
  and fd.cd_fornecedor = d.cd_distribuidora
  and g.cd_produto     = d.cd_produto
  and fu.cd_fornecedor = g.cd_fornecedor_usual
  and up.nr_matricula =* d.nr_matric_alteracao_preco
  and us.nr_matricula =* d.nr_matric_alteracao_situacao
  and p.id_parametro = '1'" arguments=(("distribuidora", string),("produto", number),("uf", string)) )
