table(column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(101) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="nm_razao_social" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cd_unidade_federacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_inicial dbname="vl_preco_inicial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_final dbname="vl_preco_final" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_menor_preco dbname="vl_menor_preco" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_maior_preco dbname="vl_maior_preco" )
 column=(type=real updatewhereclause=yes name=vl_preco_distribuidora_produto dbname="vl_preco_distribuidora_produto" )
 column=(type=datetime updatewhereclause=yes name=dt_inicial dbname="dt_inicial" )
 column=(type=datetime updatewhereclause=yes name=dt_final dbname="dt_final" )
 column=(type=char(43) updatewhereclause=yes name=de_produto_chave dbname="de_produto_chave" )
 retrieve="select cd_produto, 
	    de_produto, 
	    cd_distribuidora, 
	    nm_razao_social,
	    cd_unidade_federacao , 
		(select dph.vl_preco_compra 
			from distribuidora_produto_hist dph
		  where dph.dh_data_posicao = (select max(dph2.dh_data_posicao) 
			                              from distribuidora_produto_hist dph2 
			                             where dph2.cd_distribuidora = d.cd_distribuidora 
			                               and dph2.cd_produto = d.cd_produto 
			                               and dph2.cd_unidade_federacao = d.cd_unidade_federacao  
			                               and dph2.dh_data_posicao <= :arg_dt_inicial)
			 and dph.cd_distribuidora = d.cd_distribuidora
			 and dph.cd_produto = d.cd_produto
			 and dph.cd_unidade_federacao = d.cd_unidade_federacao) as vl_preco_inicial,
		(select dph.vl_preco_compra
			from distribuidora_produto_hist dph
		  where dph.cd_distribuidora = d.cd_distribuidora 
			 and dph.cd_produto = d.cd_produto 
			 and dph.cd_unidade_federacao = d.cd_unidade_federacao
			 and dph.dh_data_posicao = d.dt_final) as vl_preco_final,
	    vl_menor_preco,
	    vl_maior_preco,
		(select dbo.f_calc_preco_compra(dp.cd_produto, dp.cd_distribuidora, dp.vl_preco_novo, dp.vl_preco_atual, dp.pc_desconto_conexao, dp.pc_desconto_novo, dp.pc_desconto_atual, dp.pc_repasse_icms, dp.vl_icms_st, dp.qt_embalagem_padrao_distrib)
			from distribuidora_produto dp
		  where dp.cd_distribuidora = d.cd_distribuidora 
			 and dp.cd_produto = d.cd_produto 
			 and dp.cd_unidade_federacao = d.cd_unidade_federacao) as vl_preco_distribuidora_produto,
		 dt_inicial,
		 dt_final,
		 de_produto_chave
  from (
			select d.cd_distribuidora, 
					f.nm_razao_social,
					d.cd_produto, 
					p.de_produto + ' ' + p.de_apresentacao_estoque as de_produto, 
					convert(varchar, d.cd_produto) + '|' + d.cd_distribuidora + '|' + d.cd_unidade_federacao as de_produto_chave,
					d.cd_unidade_federacao , 
					min(d.dh_data_posicao) as dt_inicial,
					max(d.dh_data_posicao) as dt_final,
					min(d.vl_preco_compra) as vl_menor_preco,
					max(d.vl_preco_compra) as vl_maior_preco
			  from distribuidora_produto_hist d
			 inner join produto_geral p on p.cd_produto = d.cd_produto
			 inner join fornecedor f    on f.cd_fornecedor = d.cd_distribuidora
   		 where d.dh_data_posicao between :arg_dt_inicial and :arg_dt_final
			 group by d.cd_distribuidora, 
					f.nm_razao_social,
					d.cd_produto, 
					p.de_produto + ' ' + p.de_apresentacao_estoque, 
					convert(varchar, d.cd_produto) + '|' + d.cd_distribuidora + '|' + d.cd_unidade_federacao,
					d.cd_unidade_federacao 
			) d
order by 1,2,3,4,5" arguments=(("arg_dt_inicial", date),("arg_dt_final", date)) )
