table(column=(type=number updatewhereclause=yes name=nr_movimento_estoque dbname="movimento_estoque.nr_movimento_estoque" dbalias=".nr_movimento_estoque" )
 column=(type=datetime updatewhereclause=yes name=dh_movimento dbname="movimento_estoque.dh_movimento" dbalias=".dh_movimento" )
 column=(type=long updatewhereclause=yes name=cd_tipo_movimento dbname="movimento_estoque.cd_tipo_movimento" dbalias=".cd_tipo_movimento" )
 column=(type=long updatewhereclause=yes name=qt_movimento dbname="movimento_estoque.qt_movimento" dbalias=".qt_movimento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="movimento_estoque.vl_custo_unitario" dbalias=".vl_custo_unitario" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="movimento_estoque.nr_nf" dbalias=".nr_nf" )
 column=(type=char(1) updatewhereclause=yes name=id_entrada_saida dbname="tipo_movimento_estoque.id_entrada_saida" dbalias=".id_entrada_saida" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_movimento dbname="tipo_movimento_estoque.de_tipo_movimento" dbalias=".de_tipo_movimento" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias=".de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias=".de_apresentacao_venda" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_venda dbname="produto_geral.cd_unidade_medida_venda" dbalias=".cd_unidade_medida_venda" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="movimento_estoque.de_especie" dbalias=".de_especie" )
 column=(type=char(3) updatewhereclause=yes name=serie dbname="movimento_estoque.de_serie" dbalias=".de_serie" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="movimento_estoque.cd_cliente" dbalias=".cd_cliente" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="movimento_estoque.cd_filial" dbalias=".cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" dbalias=".nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_filial_movimento dbname="movimento_estoque.cd_filial_movimento" dbalias=".cd_filial_movimento" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="movimento_estoque.cd_fornecedor" dbalias=".cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=fornecedor_nm_fantasia dbname="fornecedor.nm_fantasia" dbalias=".nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_movimento dbname="tipo_movimento_estoque.id_tipo_movimento" dbalias=".id_tipo_movimento" )
 retrieve="select movimento_estoque.nr_movimento_estoque,
		 movimento_estoque.dh_movimento,   
		 movimento_estoque.cd_tipo_movimento,   
		 movimento_estoque.qt_movimento,   
		 movimento_estoque.vl_custo_unitario,   
		 movimento_estoque.nr_nf,   
		 tipo_movimento_estoque.id_entrada_saida,   
          tipo_movimento_estoque.de_tipo_movimento,
		 produto_geral.de_produto,   
		 produto_geral.de_apresentacao_venda,   
		 produto_geral.cd_unidade_medida_venda,   
		 movimento_estoque.de_especie,   
		 movimento_estoque.de_serie,   
		 movimento_estoque.cd_cliente,   
		 movimento_estoque.cd_filial,   
		 filial.nm_fantasia, 
		 movimento_estoque.cd_filial_movimento,
		 movimento_estoque.cd_fornecedor,
		 fornecedor.nm_fantasia, 
		 tipo_movimento_estoque.id_tipo_movimento  
from movimento_estoque,   
	  tipo_movimento_estoque,   
	  produto_geral,   
	  filial,   
	  fornecedor
where movimento_estoque.cd_filial_movimento    = filial.cd_filial
  and movimento_estoque.cd_fornecedor          = fornecedor.cd_fornecedor
  and movimento_estoque.cd_produto             =  produto_geral.cd_produto
  and movimento_estoque.cd_produto	 	        = :a_produto
  and movimento_estoque.cd_tipo_movimento      =  tipo_movimento_estoque.cd_tipo_movimento
  and tipo_movimento_estoque.id_tipo_movimento =  'C'
  and movimento_estoque.dh_movimento between :a_data_ini and :a_data_fim
" arguments=(("a_produto", number),("a_data_ini", date),("a_data_fim", date))  sort="dh_movimento A cd_filial A nr_nf A " )
