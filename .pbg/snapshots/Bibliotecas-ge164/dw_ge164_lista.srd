table(column=(type=datetime updatewhereclause=yes name=dh_movimento dbname="dh_movimento" )
 column=(type=char(63) updatewhereclause=yes name=de_tipo_movimento dbname="de_tipo_movimento" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco_localizacao dbname="cd_endereco_localizacao" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="nr_lote" )
 column=(type=long updatewhereclause=yes name=qt_movimento dbname="qt_movimento" )
 column=(type=long updatewhereclause=yes name=qt_caixa_padrao dbname="qt_caixa_padrao" )
 column=(type=long updatewhereclause=yes name=qt_total_movimento dbname="qt_total_movimento" )
 column=(type=char(1) updatewhereclause=yes name=de_origem_destino dbname="de_origem_destino" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=char(1) updatewhereclause=yes name=id_entrada_saida dbname="wms_tipo_movimento_estoque.id_entrada_saida" )
 column=(type=char(1) updatewhereclause=yes name=id_cancelamento dbname="wms_tipo_movimento_estoque.id_cancelamento" )
 column=(type=long updatewhereclause=yes name=qt_saldo dbname="qt_saldo" )
 column=(type=long updatewhereclause=yes name=qt_saldo_inicial dbname="qt_saldo_inicial" )
 column=(type=long updatewhereclause=yes name=qt_saldo_movimento dbname="qt_saldo_movimento" )
 column=(type=char(49) updatewhereclause=yes name=nm_usuario dbname="nm_usuario" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao_movimento dbname="dh_inclusao_movimento" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="dh_validade" )
 column=(type=long updatewhereclause=yes name=nr_agrup dbname="nr_agrup" )
 column=(type=char(250) updatewhereclause=yes name=de_dados_adicionais dbname="wms_int_sap.de_dados_adicionais" )
 column=(type=long updatewhereclause=yes name=cd_tipo_movimento dbname="cd_tipo_movimento" )
 column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="nf_transferencia.cd_filial_origem" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="nf_transferencia.cd_filial_destino" )
 retrieve="SELECT
	w.dh_movimento, 
	(CASE isnull(v.de_endereco, 'X')
		WHEN 'X' THEN 
			t.de_tipo_movimento
		ELSE 
			t.de_tipo_movimento + ' \ ' + v.de_endereco
	END) as de_tipo_movimento,
	w.cd_endereco_localizacao,
	w.nr_lote,
	w.qt_movimento,
	w.qt_caixa_padrao,
	w.qt_movimento * w.qt_caixa_padrao as qt_total_movimento,
	'' as de_origem_destino,
	w.cd_filial,   
	w.cd_fornecedor,
	t.id_entrada_saida,
	t.id_cancelamento,
	(SELECT
		sum(l.qt_caixa_padrao * l.qt_saldo) 
	 FROM
		wms_localizacao l
	WHERE
		l.cd_produto = w.cd_produto) as qt_saldo,
	:qt_saldo_inicial qt_saldo_inicial,
	:qt_saldo_movimento qt_saldo_movimento,
	u.nr_matricula+' - '+u.nm_usuario as nm_usuario,
	w.dh_inclusao_movimento,
	w.dh_validade,
	CASE
		WHEN s.nr_agrupamento_dev_compra IS NULL AND w.de_especie = 'AGP' THEN 
			w.nr_nf
		WHEN s.nr_agrupamento_dev_compra > 0 THEN
			s.nr_agrupamento_dev_compra
		WHEN nd.nr_agrupamento_dev_compra_wms > 0 THEN
			nd.nr_agrupamento_dev_compra_wms
	END AS nr_agrup,
	s.de_dados_adicionais,
	w.cd_tipo_movimento,
	nt.cd_filial_origem,
	nt.cd_filial_destino
	FROM
		(SELECT
			*,
			cast(dateadd(day, CASE 
										WHEN datepart(hour, dh_inclusao_movimento) > 18 THEN
											1 
										ELSE
											0 
										END, wme.dh_inclusao_movimento) as date) as dh_ajustada
		FROM
			wms_movimento_estoque wme
		WHERE
			wme.dh_movimento 						BETWEEN DateAdd(day, -1, :dh_inicio) and :dh_termino
			AND wme.cd_produto 					= :cd_produto
			AND wme.cd_endereco_localizacao 	= coalesce(:cd_endereco, wme.cd_endereco_localizacao)
			AND wme.nr_matricula_inclusao 		= coalesce(:nr_matricula, wme.nr_matricula_inclusao)) as w
	LEFT JOIN
		wms_endereco v 
		ON v.cd_endereco = w.cd_endereco_localizacao
	INNER JOIN
		wms_bairro wb 
		ON wb.cd_bairro = v.cd_bairro
  	INNER JOIN
		wms_tipo_movimento_estoque t 
		ON w.cd_tipo_movimento = t.cd_tipo_movimento
	LEFT JOIN
		usuario u 
		ON u.nr_matricula = w.nr_matricula_inclusao
	LEFT JOIN
		wms_int_sap_detalhe wisd 
		ON wisd.cd_chave_movimento_estoque_wms = w.cd_chave_movimento
		AND wisd.cd_produto = w.cd_produto
		AND wisd.nr_lote = w.nr_lote
		AND wisd.dh_validade = w.dh_validade
	LEFT JOIN
		wms_int_sap s 
		ON s.nr_integracao = wisd.nr_integracao 
	LEFT JOIN
		nf_diversa nd
		ON nd.nr_nf = w.nr_nf
		AND nd.cd_filial_origem = w.cd_filial
		AND nd.de_especie = w.de_especie
		AND nd.de_serie = w.de_serie
	LEFT JOIN
		nf_transferencia nt
		ON nt.nr_nf = w.nr_nf
		AND nt.cd_filial_origem = w.cd_filial
		AND nt.de_especie = w.de_especie
		AND nt.de_serie = w.de_serie
 WHERE
		w.dh_ajustada 	BETWEEN :dh_inicio AND :dh_termino
		AND (wb.id_utiliza_saldo = :id_tipo_saldo OR :id_tipo_saldo = 'T')
		AND (t.id_entrada_saida = :id_saida_entrada OR :id_saida_entrada = 'T')
	 ORDER BY
		w.dh_inclusao_movimento, 
		w.nr_movimento" arguments=(("cd_produto", number),("dh_inicio", date),("dh_termino", date),("qt_saldo_inicial", number),("qt_saldo_movimento", number),("cd_endereco", string),("nr_matricula", string),("id_tipo_saldo", string),("id_saida_entrada", string)) )
