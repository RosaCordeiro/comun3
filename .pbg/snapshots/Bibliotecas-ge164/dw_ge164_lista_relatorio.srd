table(column=(type=datetime updatewhereclause=yes name=dh_movimento dbname="wms_movimento_estoque.dh_movimento" dbalias="w.dh_movimento" )
 column=(type=char(63) updatewhereclause=yes name=de_tipo_movimento dbname="de_tipo_movimento" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco_localizacao dbname="wms_movimento_estoque.cd_endereco_localizacao" dbalias="w.cd_endereco_localizacao" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="wms_movimento_estoque.nr_lote" dbalias="w.nr_lote" )
 column=(type=long updatewhereclause=yes name=qt_movimento dbname="wms_movimento_estoque.qt_movimento" dbalias="w.qt_movimento" )
 column=(type=long updatewhereclause=yes name=qt_caixa_padrao dbname="wms_movimento_estoque.qt_caixa_padrao" dbalias="w.qt_caixa_padrao" )
 column=(type=long updatewhereclause=yes name=qt_total_movimento dbname="qt_total_movimento" )
 column=(type=char(1) updatewhereclause=yes name=de_origem_destino dbname="de_origem_destino" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="wms_movimento_estoque.cd_filial" dbalias="w.cd_filial" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="wms_movimento_estoque.cd_fornecedor" dbalias="w.cd_fornecedor" )
 column=(type=char(1) updatewhereclause=yes name=id_entrada_saida dbname="wms_tipo_movimento_estoque.id_entrada_saida" dbalias="t.id_entrada_saida" )
 column=(type=char(1) updatewhereclause=yes name=id_cancelamento dbname="wms_tipo_movimento_estoque.id_cancelamento" dbalias="t.id_cancelamento" )
 column=(type=long updatewhereclause=yes name=qt_saldo dbname="qt_saldo" )
 column=(type=long updatewhereclause=yes name=qt_saldo_inicial dbname="qt_saldo_inicial" )
 column=(type=long updatewhereclause=yes name=qt_saldo_movimento dbname="qt_saldo_movimento" )
 column=(type=char(49) updatewhereclause=yes name=nm_usuario dbname="nm_usuario" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao_movimento dbname="wms_movimento_estoque.dh_inclusao_movimento" dbalias="w.dh_inclusao_movimento" )
 retrieve="select    w.dh_movimento, 
            ( CASE isnull(v.de_endereco, 'X')
						WHEN 'X' then t.de_tipo_movimento
						ELSE t.de_tipo_movimento + ' \ ' + v.de_endereco
				END ) as de_tipo_movimento,
            w.cd_endereco_localizacao,
            w.nr_lote,
            w.qt_movimento,
            w.qt_caixa_padrao,
            w.qt_movimento * w.qt_caixa_padrao as qt_total_movimento,
            '' as de_origem_destino,
		   w.cd_filial,   
		   w.cd_fornecedor,
			t.id_entrada_saida,
			t.id_cancelamento,
			(select sum(l.qt_caixa_padrao * l.qt_saldo) from wms_localizacao l
			where l.cd_produto = w.cd_produto) as qt_saldo,
			:saldo_inicial qt_saldo_inicial,
			:saldo_movimento qt_saldo_movimento,
			u.nr_matricula+' - '+u.nm_usuario as nm_usuario,
			w.dh_inclusao_movimento
from wms_movimento_estoque w
left join wms_endereco v on v.cd_endereco = w.cd_endereco_localizacao
inner join wms_tipo_movimento_estoque t on w.cd_tipo_movimento = t.cd_tipo_movimento
left join usuario u on u.nr_matricula = w.nr_matricula_inclusao
where w.cd_produto =:produto
and w.dh_movimento between :inicio and :termino
order by w.dh_movimento, w.nr_movimento" arguments=(("produto", number),("inicio", date),("termino", date),("saldo_inicial", number),("saldo_movimento", number)) )
