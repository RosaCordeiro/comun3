table(column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nf_transferencia_cd_filial_origem dbname="nf_transferencia.cd_filial_origem" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nf_transferencia_cd_filial_destino dbname="nf_transferencia.cd_filial_destino" )
 column=(type=long updatewhereclause=yes name=nf_transferencia_nr_nf dbname="nf_transferencia.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=nf_transferencia_de_especie dbname="nf_transferencia.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=nf_transferencia_de_serie dbname="nf_transferencia.de_serie" )
 column=(type=datetime updatewhereclause=yes name=nf_transferencia_dh_emissao dbname="nf_transferencia.dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_transferencia_vl_bc_icms dbname="nf_transferencia.vl_bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_transferencia_vl_icms dbname="nf_transferencia.vl_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_transferencia_vl_bc_icms_st dbname="nf_transferencia.vl_bc_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_transferencia_vl_icms_st dbname="nf_transferencia.vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_transferencia_vl_total_produtos dbname="nf_transferencia.vl_total_produtos" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_transferencia_vl_total_nf dbname="nf_transferencia.vl_total_nf" )
 column=(type=datetime updatewhereclause=yes name=nf_transferencia_dh_cancelamento dbname="nf_transferencia.dh_cancelamento" )
 column=(type=long updatewhereclause=yes name=nf_transferencia_nr_pedido_distribuidora dbname="nf_transferencia.nr_pedido_distribuidora" )
 column=(type=datetime updatewhereclause=yes name=nf_transferencia_dh_movimentacao_caixa dbname="nf_transferencia.dh_movimentacao_caixa" )
 column=(type=char(6) updatewhereclause=yes name=nf_transferencia_nr_matricula_operador dbname="nf_transferencia.nr_matricula_operador" )
 column=(type=char(40) updatewhereclause=yes name=usuario_nm_usuario dbname="usuario.nm_usuario" )
 column=(type=datetime updatewhereclause=yes name=dh_solicitacao_canc dbname="nf_transferencia.dh_solicitacao_canc" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_solic_canc dbname="nf_transferencia.nr_matricula_solic_canc" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_solic_canc dbname="nm_usuario_solic_canc" )
 retrieve="  SELECT   filial_origem.nm_fantasia ,
          n.cd_filial_origem,
           filial_destino.nm_fantasia ,
          n.cd_filial_destino,
          n.nr_nf ,
          n.de_especie ,
          n.de_serie , 
          n.dh_emissao ,
          n.vl_bc_icms ,
          n.vl_icms , 
          n.vl_bc_icms_st ,
          n.vl_icms_st ,
          n.vl_total_produtos , 
          n.vl_total_nf ,  
          n.dh_cancelamento ,
          n.nr_pedido_distribuidora,
          n.dh_movimentacao_caixa,
		 n.nr_matricula_operador,
           usuario.nm_usuario,
		n.dh_solicitacao_canc,
		n.nr_matricula_solic_canc,
		(select u.nm_usuario from usuario u where u.nr_matricula = n.nr_matricula_solic_canc) as nm_usuario_solic_canc
  FROM filial filial_origem,    
       filial filial_destino,     
       nf_transferencia n,
       usuario      
 WHERE n.cd_filial_origem 	= filial_origem.cd_filial
 and   n.cd_filial_destino 		= filial_destino.cd_filial
 and   n.cd_filial_origem 		= :cd_filial_origem
 and   n.nr_nf 						= :nr_nf
 and   n.de_especie 			= :de_especie
 and   n.de_serie 				= :de_serie
 and   usuario.nr_matricula 	= n.nr_matricula_operador" arguments=(("cd_filial_origem", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
