table(column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia_origem dbname="filial.nm_fantasia_origem" dbalias="filial_origem.nm_fantasia_origem" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia_destino dbname="nm_fantasia_destino" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_transferencia.nr_nf" dbalias="a.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_transferencia.de_especie" dbalias="a.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_transferencia.de_serie" dbalias="a.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_transferencia.dh_movimentacao_caixa" dbalias="a.dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="nf_transferencia.cd_filial_origem" dbalias="a.cd_filial_origem" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_cancelamento dbname="nf_transferencia.dh_cancelamento" dbalias="a.dh_cancelamento" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_cancelamento dbname="nf_transferencia.nr_matricula_cancelamento" dbalias="a.nr_matricula_cancelamento" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_transferencia_vl_total_nf dbname="nf_transferencia.vl_total_nf" dbalias="a.vl_total_nf" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_entrada_cd dbname="nf_transferencia.nr_matricula_entrada_cd" dbalias="a.nr_matricula_entrada_cd" )
 column=(type=datetime updatewhereclause=yes name=dh_entrada_cd dbname="nf_transferencia.dh_entrada_cd" dbalias="a.dh_entrada_cd" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="u.nm_usuario" )
 column=(type=char(14) updatewhereclause=yes name=de_tipo_nota dbname="de_tipo_nota" )
 column=(type=long updatewhereclause=yes name=qtd_itens dbname="qtd_itens" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="nf_transferencia.cd_filial_destino" dbalias="a.cd_filial_destino" )
 column=(type=datetime updatewhereclause=yes name=dh_solicitacao_canc dbname="nf_transferencia.dh_solicitacao_canc" dbalias="a.dh_solicitacao_canc" )
 column=(type=char(1) updatewhereclause=yes name=id_retirada_excesso dbname="id_retirada_excesso" )
 retrieve="  SELECT  filial_origem.nm_fantasia as nm_fantasia_origem,   
         case when c.de_centro_custo is not null then
         		c.de_centro_custo
			else
				filial_destino.nm_fantasia
		end as nm_fantasia_destino,   
         a.nr_nf,   
         a.de_especie,   
         a.de_serie,   
         a.dh_movimentacao_caixa,   
         a.cd_filial_origem,   
         a.dh_cancelamento,   
         a.nr_matricula_cancelamento,   
         a.vl_total_nf,
		a.nr_matricula_entrada_cd,
		a.dh_entrada_cd,
		u.nm_usuario,
		case	when a.nr_pedido_distribuidora is null and coalesce(id_almoxarifado, 'N') <> 'S' Then 'URGENTE'
				when a.nr_pedido_distribuidora is not null and coalesce(id_almoxarifado, 'N') <> 'S' Then 'NORMAL'
				when a.nr_pedido_distribuidora is not null and coalesce(id_almoxarifado, 'N') = 'S' Then 'ALMOXARIFADO'
				when a.nr_pedido_distribuidora is null and coalesce(id_almoxarifado, 'N') = 'S' Then 'ALMOX. URGENTE'
		end as de_tipo_nota,		
		0   as qtd_itens,
		a.cd_filial_destino,
		a.dh_solicitacao_canc,
		COALESCE (a.id_retirada_excesso, 'N') AS id_retirada_excesso
    FROM nf_transferencia a 
    INNER JOIN filial filial_origem on filial_origem.cd_filial = a.cd_filial_origem
    INNER JOIN filial filial_destino on filial_destino.cd_filial = a.cd_filial_destino
	LEFT JOIN usuario u  on u.nr_matricula =a.nr_matricula_entrada_cd
	LEFT JOIN centro_custo c on c.cd_centro_custo = a.cd_centro_custo

"  sort="nr_nf A de_especie A de_serie A " )
