table(column=(type=char(21) updatewhereclause=yes name=codigo_barras dbname="codigo_barras" )
 column=(type=char(66) updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(73) updatewhereclause=yes name=filial_nm_filial_origem dbname="nm_filial_origem" )
 column=(type=char(40) updatewhereclause=yes name=filial_de_endereco_origem dbname="filial.de_endereco_origem" )
 column=(type=char(79) updatewhereclause=yes name=de_endereco_origem_2 dbname="de_endereco_origem_2" )
 column=(type=char(73) updatewhereclause=yes name=nm_filial_destino dbname="nm_filial_destino" )
 column=(type=char(40) updatewhereclause=yes name=de_endereco_destino dbname="filial.de_endereco_destino" )
 column=(type=char(79) updatewhereclause=yes name=de_endereco_destino_2 dbname="de_endereco_destino_2" )
 column=(type=long updatewhereclause=yes name=nr_rota_entrega dbname="filial.nr_rota_entrega" )
 retrieve="select 	'*'+RIGHT('0000'+Cast(b.cd_filial as varchar), 4) + RIGHT('000000000'+Cast(a.nr_nf as varchar), 9) + a.de_especie + RTrim(a.de_serie)+'*'  codigo_barras,
			'Nr. NF: '+Cast(a.nr_nf as varchar)+'  Data: '+convert ( char(20) ,  getdate() , 103 ) nr_nf,
			'('+cast(b.cd_filial as varchar)+') '+ b.nm_fantasia nm_filial_origem,
			b.de_endereco de_endereco_origem,
			b.nr_cep+' - '+b.de_bairro+' - '+c.nm_cidade+' / '+c.cd_unidade_federacao de_endereco_origem_2,
			'('+Cast(d.cd_filial as varchar)+') '+	d.nm_fantasia nm_filial_destino,
			d.de_endereco de_endereco_destino,
			d.nr_cep+' - '+d.de_bairro+' - '+e.nm_cidade+' / '+e.cd_unidade_federacao de_endereco_destino_2,
			d.nr_rota_entrega
from nf_transferencia a
inner join filial b on b.cd_filial = a.cd_filial_origem
inner join cidade c on c.cd_cidade = b.cd_cidade
inner join filial d on d.cd_filial = a.cd_filial_destino
inner join cidade e on e.cd_cidade = d.cd_cidade
where a.cd_filial_origem = :cd_filial
and a.nr_nf = :nr_nf
and a.de_especie = :de_especie
and a.de_serie = :de_serie
" arguments=(("cd_filial", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
