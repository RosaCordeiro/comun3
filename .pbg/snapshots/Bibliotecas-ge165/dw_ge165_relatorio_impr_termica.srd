HA$PBExportHeader$dw_ge165_relatorio_impr_termica.srd
release 12;
datawindow(units=3 timer_interval=0 color=134217748 brushmode=0 transparency=0 gradient.angle=0 gradient.color=8421504 gradient.focus=0 gradient.repetition.count=0 gradient.repetition.length=100 gradient.repetition.mode=0 gradient.scale=100 gradient.spread=100 gradient.transparency=0 picture.blur=0 picture.clip.bottom=0 picture.clip.left=0 picture.clip.right=0 picture.clip.top=0 picture.mode=0 picture.scale.x=100 picture.scale.y=100 picture.transparency=0 processing=2 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 0 print.margin.right = 0 print.margin.top = 0 print.margin.bottom = 0 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.background=no print.preview.background=no print.preview.outline=yes hidegrayline=no showbackcoloronxp=no picture.file="" label.name="Laser Address 0.50 x 1.75 5267" label.width=7500 label.height=9150 label.rows=1 label.rows.spacing=0 label.columns=1 label.columns.spacing=0 label.topdown=yes label.sheet=no label.shape=roundrectangle label.ellipse_height=0 label.ellipse_width=0 )
detail(height=9154 color="536870912" transparency="0" gradient.color="8421504" gradient.transparency="0" gradient.angle="0" brushmode="0" gradient.repetition.mode="0" gradient.repetition.count="0" gradient.repetition.length="100" gradient.focus="0" gradient.scale="100" gradient.spread="100" )
table(column=(type=char(1) updatewhereclause=yes name=codigo_barras dbname="codigo_barras" )
 column=(type=char(19) updatewhereclause=yes name=de_codigo_barras dbname="de_codigo_barras" )
 column=(type=char(66) updatewhereclause=yes name=setor_origem dbname="nr_nf" )
 column=(type=char(73) updatewhereclause=yes name=nm_filial_origem dbname="nm_filial_origem" )
 column=(type=char(124) updatewhereclause=yes name=filial_de_endereco_origem dbname="de_endereco_origem" )
 column=(type=char(73) updatewhereclause=yes name=nm_filial_destino dbname="nm_filial_destino" )
 column=(type=char(124) updatewhereclause=yes name=de_endereco_destino dbname="de_endereco_destino" )
 column=(type=char(20) updatewhereclause=yes name=de_origem dbname="de_origem" )
 column=(type=long updatewhereclause=yes name=nr_rota_entrega dbname="filial.nr_rota_entrega" )
 retrieve="select 	'' codigo_barras,
			RIGHT('0000'+Cast(b.cd_filial as varchar), 4) + RIGHT('000000000'+Cast(a.nr_nf as varchar), 9) + a.de_especie + RTrim(a.de_serie) as de_codigo_barras,
			'Nr. NF: '+Cast(a.nr_nf as varchar)+'  Data: '+convert ( char(20) ,  getdate() , 103 ) nr_nf,
			'('+cast(b.cd_filial as varchar)+') '+ b.nm_fantasia nm_filial_origem,
			b.de_endereco +' CEP:'+b.nr_cep+' - '+b.de_bairro+' - '+c.nm_cidade+' / '+c.cd_unidade_federacao de_endereco_origem,
			'('+Cast(d.cd_filial as varchar)+') '+	case when a.cd_centro_custo is null then d.nm_fantasia else f.de_centro_custo end as nm_filial_destino,
			d.de_endereco+' CEP:'+d.nr_cep+' - '+d.de_bairro+' - '+e.nm_cidade+' / '+e.cd_unidade_federacao de_endereco_destino,
			case when coalesce(a.id_devolucao, 'N') = 'S' then
					'URGENTE DEVOLU$$HEX2$$c700c300$$ENDHEX$$O'
				else
					case when coalesce(a.id_almoxarifado, 'N') = 'S' then
							'URGENTE ALMOXARIFADO'
						else
							'PEDIDO URGENTE'
					end
			end as de_origem,
			d.nr_rota_entrega
from nf_transferencia a
inner join filial 			b on b.cd_filial 				= a.cd_filial_origem
inner join cidade 		c on c.cd_cidade 			= b.cd_cidade
inner join filial 			d on d.cd_filial 				= a.cd_filial_destino
inner join cidade 		e on e.cd_cidade 			= d.cd_cidade
left join centro_custo 	f on f.cd_centro_custo	= a.cd_centro_custo
where a.cd_filial_origem	= :cd_filial
and a.nr_nf 					= :nr_nf
and a.de_especie 			= :de_especie
and a.de_serie 				= :de_serie
" arguments=(("cd_filial", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
