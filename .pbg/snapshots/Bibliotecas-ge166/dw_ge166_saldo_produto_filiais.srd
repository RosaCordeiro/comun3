table(column=(type=char(40) updatewhereclause=yes name=nm_filial dbname="filial.nm_fantasia" dbalias=".nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" dbalias=".cd_filial" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="vw_saldo_atual_produto.qt_saldo_final" dbalias=".qt_saldo_final" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_medio dbname="vw_saldo_atual_produto.vl_custo_medio" dbalias=".vl_custo_medio" )
 column=(type=long updatewhereclause=yes name=filial_cd_filial_centralizadora dbname="filial.cd_filial_centralizadora" dbalias=".cd_filial_centralizadora" )
 column=(type=long updatewhereclause=yes name=cd_filial_matriz dbname="parametro.cd_filial_matriz" dbalias=".cd_filial_matriz" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total dbname="vl_total" )
 column=(type=char(1) updatewhereclause=yes name=id_centro_distribuicao dbname="filial.id_centro_distribuicao" dbalias=".id_centro_distribuicao" )
 retrieve="  SELECT filial.nm_fantasia,   
         filial.cd_filial,   
         vw_saldo_atual_produto.qt_saldo_final,   
         vw_saldo_atual_produto.vl_custo_medio,   
         filial.cd_filial_centralizadora,   
         parametro.cd_filial_matriz,
		round(vw_saldo_atual_produto.vl_custo_medio *  vw_saldo_atual_produto.qt_saldo_final, 2) vl_total,
		filial.id_centro_distribuicao
    FROM vw_saldo_atual_produto,   
         filial,   
         parametro  
   WHERE ( vw_saldo_atual_produto.cd_filial = filial.cd_filial ) and  
         ( ( vw_saldo_atual_produto.cd_produto = :pl_produto ) AND  
         ( filial.id_situacao = 'A' ) )    
" arguments=(("pl_produto", number))  sort="qt_saldo_final D " )
