table(column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_transferencia.cd_produto" dbalias="i.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=descricao dbname="descricao" )
 column=(type=long updatewhereclause=yes name=qtde dbname="qtde" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo dbname="vl_custo" )
 retrieve="  SELECT i.cd_produto,
	     p.de_produto + ' : ' +  p.de_apresentacao_estoque as descricao,   
         sum(i.qt_transferida) as qtde,
		sum(i.qt_transferida * i.vl_custo_unitario) as vl_custo
    FROM nf_transferencia n
INNER JOIN item_nf_transferencia i
	ON i.cd_filial_origem = n.cd_filial_origem
	 and i.nr_nf 		      = n.nr_nf
	 and i.de_especie 	  = n.de_especie 
	 and i.de_serie 		  = n.de_serie
INNER JOIN produto_geral p     
     ON p.cd_produto		  = i.cd_produto
WHERE n.cd_filial_destino  in (1,534)
	 and n.id_produto_vencido = 'S'
     and n.dh_movimentacao_caixa between :dt_inicio and :dt_termino
	and n.dh_cancelamento is null
group by i.cd_produto,
	     p.de_produto + ' : ' +  p.de_apresentacao_estoque

    
" arguments=(("dt_inicio", date),("dt_termino", date))  sort="descricao A qtde A " )
