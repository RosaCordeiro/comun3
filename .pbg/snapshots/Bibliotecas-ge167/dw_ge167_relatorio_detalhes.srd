table(column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="nf_transferencia.cd_filial_origem" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_transferencia.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_transferencia.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_transferencia.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_transferencia.dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=qtde dbname="qtde" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="item_nf_transferencia.vl_custo_unitario" )
 retrieve="  SELECT n.cd_filial_origem,
         f.nm_fantasia,
         n.nr_nf,
         n.de_especie,
		 n.de_serie,
		 n.dh_movimentacao_caixa,
		 sum(i.qt_transferida) qtde,   
         i.vl_custo_unitario   
    FROM nf_transferencia n,
		 item_nf_transferencia i,
		 produto_geral p,
		 filial f
   WHERE n.cd_filial_origem   = i.cd_filial_origem 
	 and n.nr_nf 		      = i.nr_nf
	 and n.de_especie 		  = i.de_especie 
	 and n.de_serie 		  = i.de_serie
     and p.cd_produto		  = i.cd_produto
     and f.cd_filial		  = i.cd_filial_origem
     and n.cd_filial_destino  in (1,534)
     and n.id_produto_vencido = 'S'
     and n.dh_movimentacao_caixa between :dt_inicio and :dt_termino
     and i.cd_produto		  = :cd_produto
group by n.cd_filial_origem,
		 f.nm_fantasia,
         n.nr_nf,
 		 n.de_especie,
		 n.de_serie,
		 n.dh_movimentacao_caixa,
         i.vl_custo_unitario   


    
" arguments=(("dt_inicio", date),("dt_termino", date),("cd_produto", number)) )
