table(column=(type=long updatewhereclause=yes name=cd_filial dbname="resumo_reposicao_estoque.cd_filial" dbalias="r.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(2) updatewhereclause=yes name=id_agrupamento dbname="id_agrupamento" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="resumo_reposicao_estoque.cd_produto" dbalias="r.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_definido dbname="resumo_reposicao_estoque.qt_estoque_base_definido" dbalias="r.qt_estoque_base_definido" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="resumo_reposicao_estoque.qt_estoque_base" dbalias="r.qt_estoque_base" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao dbname="resumo_reposicao_estoque.id_alteracao" dbalias="r.id_alteracao" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_novo dbname="resumo_reposicao_estoque.qt_estoque_base_novo" dbalias="r.qt_estoque_base_novo" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao dbname="resumo_reposicao_estoque.dh_alteracao" dbalias="r.dh_alteracao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_alteracao dbname="resumo_reposicao_estoque.nr_matricula_alteracao" dbalias="r.nr_matricula_alteracao" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_bloqueio dbname="resumo_reposicao_estoque.dh_termino_bloqueio" dbalias="r.dh_termino_bloqueio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_bloqueio_novo dbname="resumo_reposicao_estoque.dh_termino_bloqueio_novo" dbalias="r.dh_termino_bloqueio_novo" )
 column=(type=long updatewhereclause=yes name=qt_dias_bloqueio dbname="qt_dias_bloqueio" )
 column=(type=char(1) updatewhereclause=yes name=nm_alteracao dbname="nm_alteracao" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao dbname="dh_movimentacao" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_reposicao dbname="resumo_reposicao_estoque.cd_classe_reposicao" dbalias="r.cd_classe_reposicao" )
 column=(type=long updatewhereclause=yes name=qt_dias_venda dbname="qt_dias_venda" )
 column=(type=long updatewhereclause=yes name=qt_venda_periodo dbname="qt_venda_periodo" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_demanda_diaria dbname="resumo_reposicao_estoque.qt_demanda_diaria" dbalias="r.qt_demanda_diaria" )
 column=(type=long updatewhereclause=yes name=qt_dias_cobertura dbname="resumo_reposicao_estoque.qt_dias_cobertura" dbalias="r.qt_dias_cobertura" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="vw_saldo_atual_produto.qt_saldo_final" dbalias="s.qt_saldo_final" )
 column=(type=char(60) updatewhereclause=yes name=de_motivo_alteracao dbname="resumo_reposicao_estoque.de_motivo_alteracao" dbalias="r.de_motivo_alteracao" )
 retrieve="select	r.cd_filial,   
       	f.nm_fantasia, 
		coalesce(f.id_agrupamento, '99') as id_agrupamento,
      	r.cd_produto,  
       	r.qt_estoque_base_definido,
		r.qt_estoque_base,
       	r.id_alteracao,
       	r.qt_estoque_base qt_estoque_base_novo,
      	r.dh_alteracao,
      	r.nr_matricula_alteracao,
     	r.dh_termino_bloqueio,
      	r.dh_termino_bloqueio dh_termino_bloqueio_novo,
      	0 qt_dias_bloqueio,
      	'' nm_alteracao,
      	 (select dh_movimentacao from parametro where id_parametro = '1') dh_movimentacao,
		r.cd_classe_reposicao,
		coalesce(r.qt_dias_venda, 0) as qt_dias_venda,
		coalesce(r.qt_venda_periodo, 0) as qt_venda_periodo,
		r.qt_demanda_diaria,
		r.qt_dias_cobertura,
		s.qt_saldo_final,
		r.de_motivo_alteracao
from resumo_reposicao_estoque r
inner join filial f 					on f.cd_filial  = r.cd_filial
inner join produto_central c 	on c.cd_produto = r.cd_produto
inner join vw_saldo_atual_produto s on r.cd_filial = s.cd_filial and r.cd_produto = s.cd_produto
where r.cd_produto 		= :produto
  and f.id_situacao			= 'A'
  and c.cd_mix_produto in (select m.cd_mix_produto
                           from mix_produto_filial m
                           where m.cd_filial = r.cd_filial)

union

select	r.cd_filial,   
       	f.nm_fantasia, 
		coalesce(f.id_agrupamento, '99') as id_agrupamento,
      	r.cd_produto,  
	   	r.qt_estoque_base_definido,
		r.qt_estoque_base,
       	r.id_alteracao,
       	r.qt_estoque_base qt_estoque_base_novo,
       	r.dh_alteracao,
       	r.nr_matricula_alteracao,
       	r.dh_termino_bloqueio,
       	r.dh_termino_bloqueio dh_termino_bloqueio_novo,
       	0 qt_dias_bloqueio,
       	'' nm_alteracao,
       	(select dh_movimentacao from parametro where id_parametro = '1') dh_movimentacao,
		r.cd_classe_reposicao,
		coalesce(r.qt_dias_venda, 0) as qt_dias_venda,
		coalesce(r.qt_venda_periodo, 0) as qt_venda_periodo,
		r.qt_demanda_diaria,
		r.qt_dias_cobertura,
		0 as qt_saldo_final,
		r.de_motivo_alteracao
from resumo_reposicao_estoque r
inner join filial f 					on f.cd_filial  = r.cd_filial
inner join produto_central c 	on c.cd_produto = r.cd_produto
inner join produto_geral g	on g.cd_produto = r.cd_produto
where r.cd_produto 		= :produto
  and f.id_situacao			= 'A'
 and f.id_pedido_centralizado 			= 'N'	
  and substring(g.cd_subcategoria, 1,1) = '5'" arguments=(("produto", number))  sort="id_agrupamento A nm_fantasia A " )
