table(column=(type=datetime updatewhereclause=yes name=dh_alteracao dbname="historico_alteracao_tabela.dh_alteracao" )
 column=(type=date updatewhereclause=yes name=de_alteracao_de dbname="de_alteracao_de" )
 column=(type=date updatewhereclause=yes name=de_alteracao_para dbname="de_alteracao_para" )
 column=(type=char(9) updatewhereclause=yes name=descricao_alteracao dbname="descricao_alteracao" values="A	ALTERA$$HEX2$$c700c200$$ENDHEX$$O/I	INSER$$HEX2$$c700c300$$ENDHEX$$O/D	DELETADO/" )
 column=(type=char(7) updatewhereclause=yes name=tipo_reposicao dbname="tipo_reposicao" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=dias_diferenca dbname="dias_diferenca" )
 column=(type=char(30) updatewhereclause=yes name=de_host_log dbname="historico_alteracao_tabela.de_host_log" )
 column=(type=char(30) updatewhereclause=yes name=de_ip dbname="historico_alteracao_tabela.de_ip" )
 column=(type=char(30) updatewhereclause=yes name=de_programa dbname="historico_alteracao_tabela.de_programa" )
 column=(type=char(6) updatewhereclause=yes name=historico_alteracao_tabela_nr_matric_alteracao dbname="historico_alteracao_tabela.nr_matric_alteracao" )
 retrieve="Select  
    dh_alteracao, 
    Case 
	    when ISNULL(de_alteracao_de, '') = '' or LEN(de_alteracao_de) <> 10 
	    Then null
	Else Convert(DATE, Right(de_alteracao_de, 4) + '-' + SUBSTRING(de_alteracao_de, 4, 2) + '-' + Left(de_alteracao_de, 2)) 
	End as de_alteracao_de,
	Convert(DATE, Right(de_alteracao_para, 4) + '-' + SUBSTRING(de_alteracao_para, 4, 2) + '-' + Left(de_alteracao_para, 2)) as de_alteracao_para, 
	Case 
		when id_alteracao = 'A' then 'ALTERACAO'
		when id_alteracao = 'I' then 'INSERIDO'
		when id_alteracao = 'E' then 'EXCLUIDO'
	else ''
	End as descricao_alteracao, 
	Case 
    	when right(h.de_chave, 1) = 'E' then 'ENTRADA'
    	when right(h.de_chave, 1) = 'S' then 'SAIDA'
    	else ''
	End as tipo_reposicao,
	f.cd_filial, 
	f.nm_fantasia,
	Case 
		When ISNULL(de_alteracao_para, '') = ''
	    Then 0
	Else DATEDIFF(
	    Day,
	    (Select Cast(dh_termino_calculo As Date) From parametro_reposicao_estoque Where cd_filial =  Convert(INT, left(h.de_chave,4)) And id_tipo_reposicao = 'E'),
		Convert(DATE, Right(de_alteracao_para, 4) + '-' + SUBSTRING(de_alteracao_para, 4, 2) + '-' + Left(de_alteracao_para, 2))
	    )
	End as dias_diferenca,
	h.de_host_log,
	h.de_ip,
	h.de_programa,
	h.nr_matric_alteracao
From historico_alteracao_tabela h
Left Join filial f on f.cd_filial = Convert(INT, left(h.de_chave,4))
Where nm_tabela = 'PARAMETRO_REPOSICAO_ESTOQUE'
And h.dh_alteracao Between :inicio And :termino" arguments=(("inicio", datetime),("termino", datetime)) )
