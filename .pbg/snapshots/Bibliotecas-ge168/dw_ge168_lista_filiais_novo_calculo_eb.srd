table(column=(type=long updatewhereclause=yes key=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf dbname="cidade.cd_uf" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_filial dbname="filial.id_rede_filial" )
 column=(type=long updatewhereclause=yes name=cd_porte dbname="cd_porte" )
 column=(type=long updatewhereclause=yes name=cd_regiao dbname="filial.cd_regiao" )
 column=(type=char(40) updatewhereclause=yes name=nm_gerente_regional dbname="usuario.nm_gerente_regional" )
 column=(type=char(1) updatewhereclause=yes name=id_24horas dbname="filial.id_24horas" values="SIM	S/NAO	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_abre_domingo dbname="filial.id_abre_domingo" values="SIM	S/NAO	N/" )
 column=(type=char(40) updatewhereclause=yes name=dh_inicio_calculo dbname="dh_inicio_calculo" )
 column=(type=date updatewhereclause=yes name=dh_termino_calculo dbname="dh_termino_calculo" )
 column=(type=date updatewhereclause=yes name=dh_proximo_calculo dbname="dh_proximo_calculo" )
 column=(type=date updatewhereclause=yes name=dh_proximo_calculo_ant dbname="dh_proximo_calculo_ant" )
 column=(type=char(40) updatewhereclause=yes name=qtd_dias_movto dbname="qtd_dias_movto" values="120	120/180	180/" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inicio_movimento_calculo_eb dbname="filial.dh_inicio_movimento_calculo_eb" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio_mov_calculo_eb_ant dbname="filial.dh_inicio_mov_calculo_eb_ant" )
 column=(type=char(60) update=yes updatewhereclause=yes name=de_motivo_inicio_movto_calc_eb dbname="de_motivo_inicio_movto_calc_eb" )
 column=(type=long update=yes updatewhereclause=yes name=cd_perfil_estoque dbname="filial.cd_perfil_estoque" )
 column=(type=long updatewhereclause=yes name=qt_dias_movto dbname="qt_dias_movto" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_receb_remanejto dbname="filial.id_receb_remanejto" values="N$$HEX1$$c300$$ENDHEX$$O	N/SIM	S/" )
 column=(type=char(3) updatewhereclause=yes name=id_utiliza_hub dbname="id_utiliza_hub" )
 retrieve="Select	 fi.cd_filial as cd_filial,
		fi.nm_fantasia as nm_fantasia,
		ci.cd_unidade_federacao cd_uf,
		fi.id_rede_filial,
		coalesce(fi.cd_porte, 1) as cd_porte,
		fi.cd_regiao,
		ur.nm_usuario nm_gerente_regional,
		fi.id_24horas,
		fi.id_abre_domingo,
		(Select vl_parametro
		 From parametro_loja
		 Where cd_parametro = 'DH_INICIO_NOVO_CALCULO_EB'
		 And cd_filial = fi.cd_filial) As dh_inicio_calculo,
		(Select Cast(dh_termino_calculo As Date)
		 From parametro_reposicao_estoque
		 Where cd_filial = fi.cd_filial
		 And id_tipo_reposicao = 'E') As dh_termino_calculo,
		(Select Cast(dh_proximo_calculo As Date)
		 From parametro_reposicao_estoque
		 Where cd_filial = fi.cd_filial
		 And id_tipo_reposicao = 'E') As dh_proximo_calculo,
		(Select Cast(dh_proximo_calculo As Date)
		 From parametro_reposicao_estoque
		 Where cd_filial = fi.cd_filial
		 And id_tipo_reposicao = 'E') As dh_proximo_calculo_ant,
		(select vl_parametro from parametro_loja
		where cd_filial = p.cd_filial
		  and cd_parametro = 'QT_DIAS_MOVIMENTO_CALCULO_ESTOQUE_BASE') as qtd_dias_movto,
		dh_inicio_movimento_calculo_eb,
		dh_inicio_movimento_calculo_eb As dh_inicio_mov_calculo_eb_ant,
		coalesce(fi.de_motivo_inicio_movto_calc_eb, '') de_motivo_inicio_movto_calc_eb,
		fi.cd_perfil_estoque,
		0 qt_dias_movto,
		fi.id_receb_remanejto,
		case when h.cd_filial_hub>0 then 'SIM'  else 'NAO'  end   as id_utiliza_hub
From parametro_loja As p
inner join filial fi
	on fi.cd_filial = p.cd_filial
inner join cidade ci
	on ci.cd_cidade = fi.cd_cidade
inner join regiao r
    on r.cd_regiao           = fi.cd_regiao
left outer join usuario ur
    on ur.nr_matricula       = r.nr_matricula_regional
left join ecommerce_hub h on h.cd_filial_hub = fi.cd_filial and h.id_ecommerce = '2'
Where p.cd_parametro = 'ID_UTILIZA_NOVO_CALCULO_ESTOQUE_BASE'
    And p.vl_parametro = 'S'

" update="filial" updatewhere=0 updatekeyinplace=no  sort="nm_fantasia A " )
