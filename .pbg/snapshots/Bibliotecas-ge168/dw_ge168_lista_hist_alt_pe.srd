table(column=(type=datetime updatewhereclause=yes name=historico_alteracao_tabela_dataalteracao dbname="DataAlteracao" )
 column=(type=char(60) updatewhereclause=yes name=historico_alteracao_tabela_cd_filial dbname="historico_alteracao_tabela.cd_filial" dbalias="h.cd_filial" )
 column=(type=char(32768) updatewhereclause=no name=historico_alteracao_tabela_valor_anterior dbname="historico_alteracao_tabela.Valor_Anterior" dbalias="h.Valor_Anterior" )
 column=(type=char(32768) updatewhereclause=no name=historico_alteracao_tabela_valor_atual dbname="historico_alteracao_tabela.Valor_Atual" dbalias="h.Valor_Atual" )
 column=(type=char(6) updatewhereclause=yes name=historico_alteracao_tabela_nr_matric_alteracao dbname="historico_alteracao_tabela.nr_matric_alteracao" dbalias="h.nr_matric_alteracao" )
 column=(type=char(40) updatewhereclause=yes name=usuario_nm_resposavel dbname="usuario.nm_resposavel" dbalias="u.nm_resposavel" )
 retrieve="SELECT top 10 h.dh_alteracao as DataAlteracao, 
       h.de_chave as cd_filial, 
       h.de_alteracao_de as Valor_Anterior, 
       h.de_alteracao_para as Valor_Atual, 
       h.nr_matric_alteracao, 
       u.nm_usuario As nm_resposavel
  FROM historico_alteracao_tabela As h
       Left Outer Join usuario As u
       On u.nr_matricula = h.nr_matric_alteracao
       Left Outer Join usuario As c
       On c.nr_matricula = substring(h.de_chave, 14, 6)
 WHERE h.nm_tabela = 'FILIAL'  
   and h.nm_coluna  = 'CD_PERFIL_ESTOQUE'
   and h.de_chave = :ps_filial
order by dh_alteracao desc" arguments=(("ps_filial", string)) )
