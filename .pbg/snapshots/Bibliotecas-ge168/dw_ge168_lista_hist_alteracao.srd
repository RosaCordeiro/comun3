table(column=(type=datetime updatewhereclause=yes name=dh_historico dbname="resumo_reposicao_estoque_hist.dh_historico" dbalias="r.dh_historico" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_anterior dbname="resumo_reposicao_estoque_hist.qt_estoque_base_anterior" dbalias="r.qt_estoque_base_anterior" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_atual dbname="resumo_reposicao_estoque_hist.qt_estoque_base_atual" dbalias="r.qt_estoque_base_atual" )
 column=(type=char(50) updatewhereclause=yes name=usuario_alteracao dbname="usuario_alteracao" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao_anterior dbname="resumo_reposicao_estoque_hist.id_alteracao_anterior" dbalias="r.id_alteracao_anterior" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao_atual dbname="resumo_reposicao_estoque_hist.id_alteracao_atual" dbalias="r.id_alteracao_atual" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_bloqueio_atual dbname="resumo_reposicao_estoque_hist.dh_termino_bloqueio_atual" dbalias="r.dh_termino_bloqueio_atual" )
 column=(type=char(60) updatewhereclause=yes name=de_motivo_alteracao dbname="resumo_reposicao_estoque_hist.de_motivo_alteracao" dbalias="r.de_motivo_alteracao" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_demanda_diaria dbname="resumo_reposicao_estoque_hist.qt_demanda_diaria" dbalias="r.qt_demanda_diaria" )
 column=(type=long updatewhereclause=yes name=qt_dias_cobertura dbname="resumo_reposicao_estoque_hist.qt_dias_cobertura" dbalias="r.qt_dias_cobertura" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_demanda_diaria_ant dbname="resumo_reposicao_estoque_hist.qt_demanda_diaria_ant" dbalias="r.qt_demanda_diaria_ant" )
 column=(type=long updatewhereclause=yes name=qt_dias_cobertura_ant dbname="resumo_reposicao_estoque_hist.qt_dias_cobertura_ant" dbalias="r.qt_dias_cobertura_ant" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_reposicao_anterior dbname="resumo_reposicao_estoque_hist.cd_classe_reposicao_anterior" dbalias="r.cd_classe_reposicao_anterior" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_reposicao_atual dbname="resumo_reposicao_estoque_hist.cd_classe_reposicao_atual" dbalias="r.cd_classe_reposicao_atual" )
 column=(type=char(1) updatewhereclause=yes name=id_excluido dbname="id_excluido" )
 retrieve="  SELECT	r.dh_historico,
			r.qt_estoque_base_anterior,   
			r.qt_estoque_base_atual,   
			case when r.id_excluido  = 'S'  then 'EXCLUSAO MIX PRODUTO'
				else  COALESCE( NULL, r.nr_matricula_alteracao_atual, 'RECALCULO'  ) + ~"-~" + u.nm_usuario end as usuario_alteracao,   
			r.id_alteracao_anterior,   
			r.id_alteracao_atual,   
			r.dh_termino_bloqueio_atual,
			r.de_motivo_alteracao,
			r.qt_demanda_diaria,
			r.qt_dias_cobertura,
			r.qt_demanda_diaria_ant,
			r.qt_dias_cobertura_ant,
			r.cd_classe_reposicao_anterior,
			r.cd_classe_reposicao_atual,
			Coalesce(r.id_excluido,'N') as id_excluido
    FROM resumo_reposicao_estoque_hist r
left outer join usuario u
	on u.nr_matricula = r.nr_matricula_alteracao_atual
Where r.cd_filial = :filial
and   r.cd_produto = :produto  " arguments=(("filial", number),("produto", number))  sort="dh_historico D dh_termino_bloqueio_atual A " )
