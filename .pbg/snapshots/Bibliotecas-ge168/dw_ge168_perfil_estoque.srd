table(column=(type=long updatewhereclause=yes name=cd_perfil_estoque dbname="cobertura_estoque_filial.cd_perfil_estoque" dbalias="c.cd_perfil_estoque" )
 column=(type=char(1) update=yes updatewhereclause=yes name=cd_classe dbname="cobertura_estoque_filial.cd_classe" dbalias="c.cd_classe" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="grupo.de_grupo" dbalias="g.de_grupo" )
 column=(type=long update=yes updatewhereclause=yes name=nr_dias_estoque dbname="cobertura_estoque_filial.nr_dias_estoque" dbalias="c.nr_dias_estoque" )
 retrieve="  SELECT c.cd_perfil_estoque,
			c.cd_classe,   
         	g.de_grupo,   
         	c.nr_dias_estoque  
    FROM cobertura_estoque_filial   c
inner join grupo g
	on g.cd_grupo = c.cd_grupo
where c.cd_perfil_estoque = :perfil
    and c.cd_grupo in ('1', '2', '3', '4')" arguments=(("perfil", number))  sort="de_grupo A cd_classe A " )
