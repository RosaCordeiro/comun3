table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=char(102) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="cd_grupo_psico" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_fornecedor dbname="nm_fornecedor" )
 column=(type=long updatewhereclause=yes name=cd_mix_produto dbname="cd_mix_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="vl_fator_conversao" )
 column=(type=char(9) updatewhereclause=yes name=cd_subcategoria dbname="cd_subcategoria" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="vw_classificacao_produto.de_subcategoria" dbalias="cp.de_subcategoria" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="qt_estoque_base" )
 column=(type=date updatewhereclause=yes name=dt_movimento dbname="dt_movimento" )
 column=(type=long updatewhereclause=yes name=qt_saldo dbname="qt_saldo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_medio dbname="vl_custo_medio" )
 column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="vw_classificacao_produto.cd_grupo" dbalias="cp.cd_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="vw_classificacao_produto.de_grupo" dbalias="cp.de_grupo" )
 column=(type=datetime updatewhereclause=yes name=dh_ultimo_movimento dbname="dh_ultimo_movimento" )
 retrieve="select 	s.cd_filial, 
			s.cd_produto, 
			g.id_situacao,	
			g.de_produto||': '||g.de_apresentacao_venda as de_produto,
			g.cd_grupo_psico,
			fo.cd_fornecedor,
			fo.nm_razao_social as nm_fornecedor,
			c.cd_mix_produto,
			g.vl_fator_conversao,
			g.cd_subcategoria,
			cp.de_subcategoria,
			coalesce(r.qt_estoque_base,0) as qt_estoque_base,
			cast(null as date) as dt_movimento,
			coalesce(s.qt_saldo_final,0) as qt_saldo,
			case when coalesce(s.vl_custo_medio,0) > 0 then s.vl_custo_medio else c.vl_custo_gerencial end vl_custo_medio,
			cp.cd_grupo,
			cp.de_grupo,
		 	s.dh_ultimo_movimento
from saldo_produto s (index saldo_prod_5850531202)  
Inner join produto_geral g (index pk_produto_geral)   
	on g.cd_produto = s.cd_produto+0
Inner join produto_central c (index pk_produto_central)   
	on c.cd_produto = g.cd_produto+0
inner join vw_classificacao_produto cp
	on cp.cd_subcategoria = g.cd_subcategoria+''
inner join fornecedor fo (index pk_fornecedor)
	on fo.cd_fornecedor = g.cd_fornecedor_usual+''
left outer join resumo_reposicao_estoque r (index pk_resumo_reposicao_estoque)   
	on r.cd_filial = s.cd_filial
	and r.cd_produto = s.cd_produto 
where s.dh_saldo = :dt_saldo
and s.qt_saldo_final > 0
and s.cd_filial = :filial
and s.cd_filial <> 1
and substring(g.cd_subcategoria,1,1) not in ('5','6')
//at isolation read uncommitted" arguments=(("dt_saldo", date),("filial", number)) )
