table(column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="g.cd_produto" )
 column=(type=char(60) update=yes updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="g.de_produto" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="g.de_apresentacao_venda" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto_atual dbname="produto_geral.pc_desconto_atual" dbalias="g.pc_desconto_atual" )
 column=(type=decimal(13) update=yes updatewhereclause=yes name=preco_unitario_bruto dbname="preco_unitario_bruto" )
 column=(type=decimal(26) update=yes updatewhereclause=yes name=preco_unitario_liquido dbname="preco_unitario_liquido" )
 retrieve="  SELECT g.cd_produto,   
         g.de_produto,   
         g.de_apresentacao_venda,   
         g.pc_desconto_atual,   
         g.vl_preco_venda_atual / g.vl_fator_conversao as preco_unitario_bruto,   
         Round((g.vl_preco_venda_atual / g.vl_fator_conversao) - (g.vl_preco_venda_atual / g.vl_fator_conversao * g.pc_desconto_atual / 100 ),2) as preco_unitario_liquido  
    FROM produto_geral g
Inner Join vw_classificacao_produto cp
	on cp.cd_subcategoria = g.cd_subcategoria
"  sort="de_produto A de_apresentacao_venda A " )
