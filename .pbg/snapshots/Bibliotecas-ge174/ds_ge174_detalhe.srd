table(column=(type=char(1) updatewhereclause=yes name=fornecedor dbname="fornecedor" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="produto_geral.cd_fornecedor_usual" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=decimal(27) updatewhereclause=yes name=vl_custo dbname="vl_custo" )
 retrieve="  SELECT ~"~" fornecedor,
		 p.cd_fornecedor_usual,
	     f.nm_razao_social,
		sum( round(i.qt_faturada * (
		(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) 
		- round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_desconto / n.vl_total_produtos), 2)) 
		 + round(i.vl_preco_unitario * (i.pc_ipi / 100), 2)
		 + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_frete           / n.vl_total_produtos), 2)
		 + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_seguro          / n.vl_total_produtos), 2)
		 + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_outras_despesas / n.vl_total_produtos), 2)), 2) + coalesce(i.vl_icms_st_total,0)) vl_custo		 
    FROM item_nf_compra i,   
         nf_compra n,   
         produto_geral p,   
         fornecedor f
   WHERE n.cd_filial     	     = i.cd_filial 
	 and n.cd_fornecedor 	     = i.cd_fornecedor 
	 and n.nr_nf 		 	     = i.nr_nf 
	 and n.de_especie 	 	     = i.de_especie 
	 and n.de_serie 	 	     = i.de_serie 
 	 and p.cd_produto 	 	     = i.cd_produto 
	 and p.cd_fornecedor_usual   = f.cd_fornecedor
     and n.cd_fornecedor 	     = :cd_fornecedor
     and n.dh_movimentacao_caixa between :dt_inicio and :dt_fim
     and n.cd_filial 			 = 534
group by p.cd_fornecedor_usual, f.nm_razao_social
    


" arguments=(("dt_inicio", date),("dt_fim", date),("cd_fornecedor", string))  sort="vl_custo D " )
