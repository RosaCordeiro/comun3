table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="fornecedor.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=decimal(2) updatewhereclause=yes name=valor dbname="compute_0003" )
 retrieve="select f.cd_fornecedor,
       f.nm_razao_social,
       sum(n.vl_total_nf)
  from nf_compra n,
       fornecedor f
 where f.cd_fornecedor = n.cd_fornecedor
   and n.dh_movimentacao_caixa between :inicio and :fim
   and n.cd_filial = 534
 group by f.cd_fornecedor,
          f.nm_razao_social
" arguments=(("inicio", date),("fim", date))  sort="valor D " )
