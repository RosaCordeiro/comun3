table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="cd_fornecedor_usual" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="nm_razao_social" )
 column=(type=decimal(27) updatewhereclause=yes name=vl_custo dbname="vl_custo" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_ec dbname="vl_custo_ec" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bruto_fil dbname="vl_bruto_fil" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bruto_ec dbname="vl_bruto_ec" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_fil dbname="vl_desconto_fil" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_ec dbname="vl_desconto_ec" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_fil dbname="pc_desconto_fil" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_ec dbname="pc_desconto_ec" )
 retrieve="select 	cd_fornecedor_usual,
			nm_razao_social,	
			sum(vl_custo) vl_custo,
			0.00 vl_custo_ec,
			0.00 vl_bruto_fil,
			0.00 vl_bruto_ec,
			0.00 vl_desconto_fil,
			0.00 vl_desconto_ec,
			0.00 pc_desconto_fil,
			0.00 pc_desconto_ec
 from (
  SELECT p.cd_fornecedor_usual,
	     f.nm_razao_social,
sum( round(i.qt_faturada * (
		(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) 
	   - round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_desconto / n.vl_total_produtos), 2)) 
       + round(i.vl_preco_unitario * (i.pc_ipi / 100), 2)
       + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_frete           / n.vl_total_produtos), 2)
       + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_seguro          / n.vl_total_produtos), 2)
       + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_outras_despesas / n.vl_total_produtos), 2)), 2) + coalesce(i.vl_icms_st_total, 0)) vl_custo		 
    FROM item_nf_compra i,   
         nf_compra n,   
         produto_geral p,   
         fornecedor f
   WHERE n.cd_filial     	     = i.cd_filial 
	 and n.cd_fornecedor 	     = i.cd_fornecedor 
	 and n.nr_nf 		 	     = i.nr_nf 
	 and n.de_especie 	 	     = i.de_especie 
	 and n.de_serie 	 	     = i.de_serie 
 	 and p.cd_produto 	 	     = i.cd_produto 
	 and p.cd_fornecedor_usual   = f.cd_fornecedor
     and n.cd_fornecedor 	     = :cd_fornecedor
     and n.dh_movimentacao_caixa  between :dt_inicio and :dt_fim
	 and n.cd_filial 			 <> 534
   group by p.cd_fornecedor_usual, f.nm_razao_social
 
union all

  SELECT p.cd_fornecedor_usual,
	     f.nm_razao_social,
		sum( round(i.qt_faturada * (
		(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) 
	   - round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_desconto / n.vl_total_produtos), 2)) 
       + round(i.vl_preco_unitario * (i.pc_ipi / 100), 2)
       + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_frete           / n.vl_total_produtos), 2)
       + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_seguro          / n.vl_total_produtos), 2)
       + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_outras_despesas / n.vl_total_produtos), 2)), 2) + coalesce(i.vl_icms_st_total,0)) vl_custo		 
    FROM nf_compra_pendente_produto i,   
         nf_compra_pendente n,   
         produto_geral p,   
         fornecedor f
   WHERE n.cd_filial     	     = i.cd_filial 
	 and n.cd_fornecedor 	     = i.cd_fornecedor 
	 and n.nr_nf 		 	     = i.nr_nf 
	 and n.de_especie 	 	     = i.de_especie 
	 and n.de_serie 	 	     = i.de_serie 
 	 and p.cd_produto 	 	     = i.cd_produto 
	 and p.cd_fornecedor_usual   = f.cd_fornecedor
     and n.cd_fornecedor 	     = :cd_fornecedor
     and cast(n.dh_movimentacao_caixa as date)  between :dt_inicio and :dt_fim
	 and n.cd_filial 			 <> 534
   group by p.cd_fornecedor_usual, f.nm_razao_social
) as tudo
group by cd_fornecedor_usual, nm_razao_social


" arguments=(("dt_inicio", date),("dt_fim", date),("cd_fornecedor", string))  sort="valor_total D " )
