table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="produto_geral.cd_fornecedor_usual" dbalias="p.cd_fornecedor_usual" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" dbalias="f.nm_razao_social" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo dbname="vl_custo" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_ec dbname="vl_custo_ec" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bruto_fil dbname="vl_bruto_fil" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bruto_ec dbname="vl_bruto_ec" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_fil dbname="vl_desconto_fil" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_ec dbname="vl_desconto_ec" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_fil dbname="pc_desconto_fil" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_ec dbname="pc_desconto_ec" )
 retrieve="  SELECT p.cd_fornecedor_usual,
	     f.nm_razao_social,
		 sum(round(i.qt_transferida * i.vl_custo_unitario, 2) + coalesce(i.vl_icms_st, 0)) vl_custo,
		 0.00 vl_custo_ec,
			0.00 vl_bruto_fil,
			0.00 vl_bruto_ec,
			0.00 vl_desconto_fil,
			0.00 vl_desconto_ec,
			0.00 pc_desconto_fil,
			0.00 pc_desconto_ec
    FROM item_nf_transferencia i,   
         nf_transferencia n,   
         produto_geral p,   
         fornecedor f
   WHERE n.cd_filial_origem	     = i.cd_filial_origem 
	 and n.nr_nf 		 	     = i.nr_nf 
	 and n.de_especie 	 	     = i.de_especie 
	 and n.de_serie 	 	     = i.de_serie 
 	 and p.cd_produto 	 	     = i.cd_produto 
	 and p.cd_fornecedor_usual   = f.cd_fornecedor
     and n.dh_cancelamento is null
     and n.dh_movimentacao_caixa between :dt_inicio and :dt_fim
	 and n.cd_filial_origem 			 = 534
group by p.cd_fornecedor_usual, f.nm_razao_social
    


" arguments=(("dt_inicio", date),("dt_fim", date))  sort="valor_total D " )
