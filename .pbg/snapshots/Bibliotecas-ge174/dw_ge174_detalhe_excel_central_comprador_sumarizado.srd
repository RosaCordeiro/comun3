table(column=(type=date updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=char(9) updatewhereclause=yes name=codigo dbname="codigo" )
 column=(type=char(15) updatewhereclause=yes name=nome dbname="nome" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="produto_geral.cd_fornecedor_usual" dbalias="p.cd_fornecedor_usual" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" dbalias="f.nm_razao_social" )
 column=(type=char(40) updatewhereclause=yes name=nm_comprador dbname="nm_comprador" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="grupo.de_grupo" dbalias="g.de_grupo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo dbname="vl_custo" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="fornecedor.nr_cgc" dbalias="f.nr_cgc" )
 retrieve="  SELECT cast(substring(CONVERT( CHAR(10), n.dh_movimentacao_caixa, 111 ), 1, 7) + '/01' as date) as dh_movimentacao_caixa,
      '053404705' as codigo,
         'ESTOQUE CENTRAL' as nome,
          p.cd_fornecedor_usual,
	  f.nm_razao_social,
        coalesce(u.nm_usuario, '') nm_comprador,
		g.de_grupo, 
          sum(round(i.qt_transferida * i.vl_custo_unitario, 2) + i.vl_icms_st ) vl_custo,
		f.nr_cgc
    FROM nf_transferencia n
inner join item_nf_transferencia i
	on i.cd_filial_origem	  = n.cd_filial_origem 
	and i.nr_nf 		 	          = n.nr_nf 
	and i.de_especie 	 	      = n.de_especie 
	and i.de_serie 	 	        = n.de_serie 
inner join produto_geral p
	on p.cd_produto           = i.cd_produto 
inner join fornecedor f
	on p.cd_fornecedor_usual  = f.cd_fornecedor
inner join produto_central c
	on c.cd_produto           = p.cd_produto
inner join grupo g
	on g.cd_grupo = substring(p.cd_subcategoria,1,1)
left outer join usuario u
	on c.nr_matricula_comprador = u.nr_matricula
WHERE n.dh_movimentacao_caixa between :dt_inicio and :dt_fim
	 and n.dh_cancelamento is null
   and n.cd_filial_origem = 534
group by cast(substring(CONVERT( CHAR(10), n.dh_movimentacao_caixa, 111 ), 1, 7) + '/01' as date), f.nm_razao_social, p.cd_fornecedor_usual, f.nm_razao_social, u.nm_usuario, g.de_grupo, f.nr_cgc" arguments=(("dt_inicio", date),("dt_fim", date))  sort="vl_custo D " )
