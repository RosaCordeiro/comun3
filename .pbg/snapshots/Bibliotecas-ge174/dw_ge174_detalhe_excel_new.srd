table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="nm_razao_social" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="cd_fornecedor_usual" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social_usual dbname="nm_razao_social_usual" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="id_lei_generico" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="de_grupo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_valor dbname="vl_custo" )
 column=(type=decimal(27) updatewhereclause=yes name=vl_valor_fil dbname="vl_custo_fil" )
 column=(type=decimal(27) updatewhereclause=yes name=vl_valor_ec dbname="vl_custo_ec" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="nr_cgc" )
 retrieve="select 	cd_fornecedor,
			nm_razao_social,
			cd_fornecedor_usual,
			nm_razao_social_usual,
			id_lei_generico,
			de_grupo,
			0.00 vl_custo,
			sum(vl_custo_fil) vl_custo_fil,
			0.00 vl_custo_ec,
			nr_cgc
from (  
SELECT n.cd_fornecedor,
         f1.nm_razao_social,
		 p.cd_fornecedor_usual,
	     f.nm_razao_social nm_razao_social_usual,
		p.id_lei_generico,
		cp.de_grupo,
		sum( round(i.qt_faturada * (
		(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) 
	   - round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_desconto / n.vl_total_produtos), 2)) 
       + coalesce(i.vl_ipi, round(i.vl_preco_unitario * (i.pc_ipi / 100), 2))
       + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_frete           / n.vl_total_produtos), 2)
       + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_seguro          / n.vl_total_produtos), 2)
       + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_outras_despesas / n.vl_total_produtos), 2)), 2) 
	  + coalesce(i.vl_icms_st_total, 0)) vl_custo_fil,
		0.00 vl_custo_ec, 
		f.nr_cgc
    FROM item_nf_compra i,   
         nf_compra n,   
         produto_geral p,   
         fornecedor f,
		 fornecedor f1,
		 vw_classificacao_produto cp
   WHERE n.cd_filial     	     = i.cd_filial 
	 and n.cd_fornecedor 	     = i.cd_fornecedor 
	 and n.nr_nf 		 	     = i.nr_nf 
	 and n.de_especie 	 	     = i.de_especie 
	 and n.de_serie 	 	     = i.de_serie 
 	 and p.cd_produto 	 	     = i.cd_produto 
	 and p.cd_fornecedor_usual   = f.cd_fornecedor
     and n.cd_fornecedor		 = f1.cd_fornecedor
     and cp.cd_subcategoria		 = p.cd_subcategoria
     and n.dh_movimentacao_caixa between :dt_inicio and :dt_fim
     and n.cd_filial					<> 534
group by n.cd_fornecedor, f1.nm_razao_social, p.cd_fornecedor_usual, f.nm_razao_social, p.id_lei_generico, cp.de_grupo, f.nr_cgc

union all

SELECT n.cd_fornecedor,
         f1.nm_razao_social,
		 p.cd_fornecedor_usual,
	     f.nm_razao_social nm_razao_social_usual,
		p.id_lei_generico,
		cp.de_grupo,
		sum( round(i.qt_faturada * (
		(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) 
	   - round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_desconto / n.vl_total_produtos), 2)) 
        + coalesce(i.vl_ipi, round(i.vl_preco_unitario * (i.pc_ipi / 100), 2))
       + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_frete           / n.vl_total_produtos), 2)
       + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_seguro          / n.vl_total_produtos), 2)
       + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_outras_despesas / n.vl_total_produtos), 2)), 2) 
	  + coalesce(i.vl_icms_st_total, 0)) vl_custo_fil,
		0.00 vl_custo_ec,
		f.nr_cgc
    FROM nf_compra_pendente_produto i,   
         nf_compra_pendente n,   
         produto_geral p,   
         fornecedor f,
		 fornecedor f1,
		 vw_classificacao_produto cp
   WHERE n.cd_filial     	     = i.cd_filial 
	 and n.cd_fornecedor 	     = i.cd_fornecedor 
	 and n.nr_nf 		 	     = i.nr_nf 
	 and n.de_especie 	 	     = i.de_especie 
	 and n.de_serie 	 	     = i.de_serie 
 	 and p.cd_produto 	 	     = i.cd_produto 
	 and p.cd_fornecedor_usual   = f.cd_fornecedor
     and n.cd_fornecedor		 = f1.cd_fornecedor
     and cp.cd_subcategoria		 = p.cd_subcategoria
     and cast(n.dh_movimentacao_caixa as date) between :dt_inicio and :dt_fim
     and n.cd_filial					<> 534
group by n.cd_fornecedor, f1.nm_razao_social, p.cd_fornecedor_usual, f.nm_razao_social, p.id_lei_generico, cp.de_grupo, f.nr_cgc
) as tudo
group by cd_fornecedor, nm_razao_social, cd_fornecedor_usual, nm_razao_social_usual, id_lei_generico, de_grupo, nr_cgc
    
union

 SELECT n.cd_fornecedor,
         f1.nm_razao_social,
		 p.cd_fornecedor_usual,
	     f.nm_razao_social,
		p.id_lei_generico,
		cp.de_grupo,
		0.00 vl_custo,
		0.00 vl_custo_fil,
		 sum( round(i.qt_faturada * (
		(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) 
	   - round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_desconto / n.vl_total_produtos), 2)) 
       + coalesce(i.vl_ipi, round(i.vl_preco_unitario * (i.pc_ipi / 100), 2))
       + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_frete           / n.vl_total_produtos), 2)
       + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_seguro          / n.vl_total_produtos), 2)
       + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_outras_despesas / n.vl_total_produtos), 2)), 2) 
		+ coalesce(i.vl_icms_st_total, 0)) vl_custo_ec,
		f.nr_cgc
    FROM item_nf_compra i,   
         nf_compra n,   
         produto_geral p,   
         fornecedor f,
		 fornecedor f1,
		 vw_classificacao_produto cp
   WHERE n.cd_filial     	     = i.cd_filial 
	 and n.cd_fornecedor 	     = i.cd_fornecedor 
	 and n.nr_nf 		 	     = i.nr_nf 
	 and n.de_especie 	 	     = i.de_especie 
	 and n.de_serie 	 	     = i.de_serie 
 	 and p.cd_produto 	 	     = i.cd_produto 
	 and p.cd_fornecedor_usual   = f.cd_fornecedor
     and n.cd_fornecedor		 = f1.cd_fornecedor
     and cp.cd_subcategoria		 = p.cd_subcategoria
     and n.dh_movimentacao_caixa between :dt_inicio and :dt_fim
     and n.cd_filial					= 534
group by n.cd_fornecedor, f1.nm_razao_social, p.cd_fornecedor_usual, f.nm_razao_social, p.id_lei_generico, cp.de_grupo, f.nr_cgc" arguments=(("dt_inicio", date),("dt_fim", date))  sort="vl_valor D " )
