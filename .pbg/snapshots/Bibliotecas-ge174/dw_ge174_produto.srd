table(column=(type=char(1) updatewhereclause=yes name=grupo dbname="grupo" values="FILIAIS	1/ESTOQUE CENTRAL	2/" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="nm_razao_social" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=descricao dbname="descricao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=long updatewhereclause=yes name=qtde dbname="qtde" )
 column=(type=decimal(27) updatewhereclause=yes name=vlr_custo dbname="vlr_custo" )
 retrieve="SELECT  	~"1~" grupo,
			cd_fornecedor,
			nm_razao_social,
			cd_produto,
			descricao,
			pc_desconto,
			sum(qt_faturada) qtde,
			vlr_custo
FROM (   
	SELECT
			 f.cd_fornecedor,
			 f.nm_razao_social,
			 i.cd_produto,
			 p.de_produto + ~" : ~" + p.de_apresentacao_estoque descricao,
			 i.pc_desconto,
			 sum(i.qt_faturada) qt_faturada, 
			 round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) 
			- round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_desconto / n.vl_total_produtos), 2) 
			 + round(i.vl_preco_unitario * (i.pc_ipi / 100), 2)
			 + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_frete           / n.vl_total_produtos), 2)
			 + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_seguro          / n.vl_total_produtos), 2)
			 + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_outras_despesas / n.vl_total_produtos), 2)
			+ coalesce(i.vl_icms_st, 0) vlr_custo
		 FROM item_nf_compra i,   
				nf_compra n,   
				produto_geral p,   
				fornecedor f  
		WHERE n.cd_filial     	     = i.cd_filial 
		 and n.cd_fornecedor 	     = i.cd_fornecedor 
		 and n.nr_nf 		 	     = i.nr_nf 
		 and n.de_especie 	 	     = i.de_especie 
		 and n.de_serie 	 	     = i.de_serie 
		 and p.cd_produto 	 	     = i.cd_produto 
		 and p.cd_fornecedor_usual   = f.cd_fornecedor
		  and n.cd_fornecedor 	     = :as_fornecedor
		  and p.cd_fornecedor_usual   = :as_fornecedor_usual
		  and n.dh_movimentacao_caixa between :dt_inicio and :dt_termino
		  and n.cd_filial 			 <> 534
	group by  f.cd_fornecedor,
				 f.nm_razao_social,
				 i.cd_produto,
				 p.de_produto,
				 p.de_apresentacao_estoque,
				 i.pc_desconto,
				 round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) 
				- round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_desconto / n.vl_total_produtos), 2) 
				 + round(i.vl_preco_unitario * (i.pc_ipi / 100), 2)
				 + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_frete           / n.vl_total_produtos), 2)
				 + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_seguro          / n.vl_total_produtos), 2)
				 + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_outras_despesas / n.vl_total_produtos), 2)
				+ coalesce(i.vl_icms_st, 0)
	
	union all
	
	SELECT  f.cd_fornecedor,
			  	f.nm_razao_social,
			 	i.cd_produto,
				p.de_produto + ~" : ~" + p.de_apresentacao_estoque descricao,
				i.pc_desconto,
				sum(i.qt_faturada) qt_faturada,  
				round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) 
				- round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_desconto / n.vl_total_produtos), 2) 
				 + round(i.vl_preco_unitario * (i.pc_ipi / 100), 2)
				 + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_frete           / n.vl_total_produtos), 2)
				 + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_seguro          / n.vl_total_produtos), 2)
				 + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_outras_despesas / n.vl_total_produtos), 2)
				+ coalesce(i.vl_icms_st, 0) vlr_custo
		 FROM nf_compra_pendente_produto i,   
				nf_compra_pendente n,   
				produto_geral p,   
				fornecedor f  
		WHERE n.cd_filial     	     = i.cd_filial 
		 and n.cd_fornecedor 	     = i.cd_fornecedor 
		 and n.nr_nf 		 	     = i.nr_nf 
		 and n.de_especie 	 	     = i.de_especie 
		 and n.de_serie 	 	     = i.de_serie 
		 and p.cd_produto 	 	     = i.cd_produto 
		 and p.cd_fornecedor_usual   = f.cd_fornecedor
		  and n.cd_fornecedor 	     = :as_fornecedor
		  and p.cd_fornecedor_usual   = :as_fornecedor_usual
		  and cast(n.dh_movimentacao_caixa as date) between :dt_inicio and :dt_termino
		  and n.cd_filial 			 <> 534
	group by  f.cd_fornecedor,
				 f.nm_razao_social,
				 i.cd_produto,
				 p.de_produto,
				 p.de_apresentacao_estoque,
				 i.pc_desconto,	
				round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) 
				- round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_desconto / n.vl_total_produtos), 2) 
				 + round(i.vl_preco_unitario * (i.pc_ipi / 100), 2)
				 + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_frete           / n.vl_total_produtos), 2)
				 + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_seguro          / n.vl_total_produtos), 2)
				 + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_outras_despesas / n.vl_total_produtos), 2)
				+ coalesce(i.vl_icms_st, 0)
	) tudo
group by cd_fornecedor,
	     nm_razao_social,
		 cd_produto,
		 descricao,
		 pc_desconto,
       	 vlr_custo



union
    
   SELECT ~"2~" grupo,
		 f.cd_fornecedor,
	     f.nm_razao_social,
		 i.cd_produto,
         p.de_produto + ~" : ~" + p.de_apresentacao_estoque descricao,
		i.pc_desconto,
		 sum(i.qt_faturada) qtde,
		  round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) 
	   - round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_desconto / n.vl_total_produtos), 2) 
       + round(i.vl_preco_unitario * (i.pc_ipi / 100), 2)
       + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_frete           / n.vl_total_produtos), 2)
       + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_seguro          / n.vl_total_produtos), 2)
       + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_outras_despesas / n.vl_total_produtos), 2)
	   + coalesce(i.vl_icms_st, 0) vlr_custo
    FROM item_nf_compra i,   
         nf_compra n,   
         produto_geral p,   
         fornecedor f  
   WHERE n.cd_filial     	     = i.cd_filial 
	 and n.cd_fornecedor 	     = i.cd_fornecedor 
	 and n.nr_nf 		 	     = i.nr_nf 
	 and n.de_especie 	 	     = i.de_especie 
	 and n.de_serie 	 	     = i.de_serie 
 	 and p.cd_produto 	 	     = i.cd_produto 
	 and p.cd_fornecedor_usual   = f.cd_fornecedor
     and n.cd_fornecedor 	     = :as_fornecedor
     and p.cd_fornecedor_usual   = :as_fornecedor_usual
     and n.dh_movimentacao_caixa between :dt_inicio and :dt_termino
     and n.cd_filial 			 = 534
group by f.cd_fornecedor,
	     f.nm_razao_social,
		 i.cd_produto,
		 p.de_produto,
		 p.de_apresentacao_estoque,
		 i.pc_desconto,
		round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) 
			- round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_desconto / n.vl_total_produtos), 2) 
			 + round(i.vl_preco_unitario * (i.pc_ipi / 100), 2)
			 + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_frete           / n.vl_total_produtos), 2)
			 + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_seguro          / n.vl_total_produtos), 2)
			 + round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * (n.vl_outras_despesas / n.vl_total_produtos), 2)
			+ coalesce(i.vl_icms_st, 0)

" arguments=(("dt_inicio", date),("dt_termino", date),("as_fornecedor_usual", string),("as_fornecedor", string))  sort="cd_fornecedor A nm_razao_social A grupo A descricao A " )
