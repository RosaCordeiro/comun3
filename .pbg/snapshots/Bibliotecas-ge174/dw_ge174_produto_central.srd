table(column=(type=char(1) updatewhereclause=yes name=grupo dbname="grupo" values="FILIAIS	1/ESTOQUE CENTRAL	2/" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="fornecedor.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_transferencia.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=descricao dbname="descricao" )
 column=(type=long updatewhereclause=yes name=qtde dbname="qtde" )
 column=(type=decimal(8) updatewhereclause=yes name=vlr_custo dbname="vlr_custo" )
 retrieve="   SELECT ~"1~" grupo,
		 f.cd_fornecedor,
	     f.nm_razao_social,
		 i.cd_produto,
         p.de_produto + ~" : ~" + p.de_apresentacao_estoque descricao,
		 sum(i.qt_transferida) qtde, 
		 i.vl_custo_unitario + round(i.vl_icms_st / i.qt_transferida, 2) vlr_custo
    FROM item_nf_transferencia i,   
         nf_transferencia n,   
         produto_geral p,   
         fornecedor f  
   WHERE n.cd_filial_origem	     = i.cd_filial_origem
	 and n.nr_nf 		 	     = i.nr_nf 
	 and n.de_especie 	 	     = i.de_especie 
	 and n.de_serie 	 	     = i.de_serie 
 	 and p.cd_produto 	 	     = i.cd_produto 
	 and p.cd_fornecedor_usual   = f.cd_fornecedor
     and p.cd_fornecedor_usual   = :as_fornecedor_usual
     and n.dh_movimentacao_caixa between :dt_inicio and :dt_termino
     and n.cd_filial_origem		 = 534
group by f.cd_fornecedor,
	     f.nm_razao_social,
		 i.cd_produto,
		 p.de_produto,
		 p.de_apresentacao_estoque,
        i.vl_custo_unitario + round(i.vl_icms_st / i.qt_transferida, 2)


" arguments=(("dt_inicio", date),("dt_termino", date),("as_fornecedor_usual", string))  sort="cd_fornecedor A nm_razao_social A grupo A descricao A " )
