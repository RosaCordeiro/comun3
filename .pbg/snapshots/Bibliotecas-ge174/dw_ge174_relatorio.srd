table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="nm_razao_social" )
 column=(type=decimal(2) updatewhereclause=yes name=valor dbname="valor" )
 column=(type=decimal(2) updatewhereclause=yes name=valor_ec dbname="valor_ec" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bruto_fil dbname="vl_bruto_fil" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bruto_ec dbname="vl_bruto_ec" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_fil dbname="vl_desconto_fil" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_ec dbname="vl_desconto_ec" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_fil dbname="pc_desconto_fil" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_ec dbname="pc_desconto_ec" )
 retrieve="select cd_fornecedor,
       	nm_razao_social,
       	sum(vl_total_nf) valor,
	   	0.00 valor_ec,
		0.00 vl_bruto_fil,
		0.00 vl_bruto_ec,
		0.00 vl_desconto_fil,
		0.00 vl_desconto_ec,
		0.00 pc_desconto_fil,
		0.00 pc_desconto_ec
				from(
				select f.cd_fornecedor,
					   f.nm_razao_social,
					   sum(n.vl_total_nf) vl_total_nf
				  from nf_compra n,
					   fornecedor f
				 where f.cd_fornecedor = n.cd_fornecedor
				   and n.dh_movimentacao_caixa between :inicio and :fim
				   and n.cd_filial <> 534
				 group by f.cd_fornecedor,
						  f.nm_razao_social

				union all

				select f.cd_fornecedor,
					   f.nm_razao_social,
					   sum(n.vl_total_nf) vl_total_nf
				  from nf_compra_pendente n,
					   fornecedor f
				 where f.cd_fornecedor = n.cd_fornecedor
				   and cast(n.dh_movimentacao_caixa as date) between :inicio and :fim
				   and n.cd_filial <> 534
				 group by f.cd_fornecedor,
						  f.nm_razao_social
			) as tudo
			group by cd_fornecedor, nm_razao_social
" arguments=(("inicio", date),("fim", date)) )
