table(column=(type=char(40) updatewhereclause=yes name=cliente_nm_cliente dbname="cliente.nm_cliente" )
 column=(type=char(11) updatewhereclause=yes name=cliente_cd_cliente dbname="cliente.cd_cliente" )
 column=(type=char(11) updatewhereclause=yes name=nf_venda_cd_cliente dbname="nf_venda.cd_cliente" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_venda.nr_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_venda.dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=item_nf_venda_cd_produto dbname="item_nf_venda.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=produto_geral_de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=produto_geral_de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=long updatewhereclause=yes name=item_nf_venda_qt_vendida dbname="item_nf_venda.qt_vendida" )
 column=(type=decimal(15) updatewhereclause=yes name=preco dbname="preco" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_venda.cd_filial" )
 retrieve="select cliente.nm_cliente, 
       cliente.cd_cliente,
       nf_venda.cd_cliente,  
       nf_venda.nr_nf,   
       nf_venda.dh_movimentacao_caixa,   
		 item_nf_venda.cd_produto,
		 produto_geral.de_produto,
		 produto_geral.de_apresentacao_venda,
		 item_nf_venda.qt_vendida,
		 item_nf_venda.vl_preco_praticado-round(item_nf_venda.vl_preco_praticado*(nf_venda.pc_desconto/100),2) preco,
		nf_venda.cd_filial
from 
     cliente,   
     nf_venda,
	  item_nf_venda,
	  produto_geral
where cliente.cd_cliente       = nf_venda.cd_cliente
  and nf_venda.dh_cancelamento is null
  and nf_venda.nr_nf_anexa     is null
  and item_nf_venda.cd_filial  = nf_venda.cd_filial
  and item_nf_venda.nr_nf      = nf_venda.nr_nf
  and item_nf_venda.de_especie = nf_venda.de_especie
  and item_nf_venda.de_serie   = nf_venda.de_serie
  and produto_geral.cd_produto = item_nf_venda.cd_produto
  "  sort="dh_movimentacao_caixa A nr_nf A " )
