table(column=(type=long updatewhereclause=yes name=cd_filial dbname="resumo_reposicao_estoque.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="vw_filial.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="vw_classificacao_produto.de_grupo" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="resumo_reposicao_estoque.cd_produto" )
 column=(type=char(100) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" )
 column=(type=long updatewhereclause=yes name=eb dbname="resumo_reposicao_estoque.eb" )
 column=(type=long updatewhereclause=yes name=qt_minimo_promocao dbname="qt_minimo_promocao" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="vw_saldo_atual_produto.qt_saldo_final" )
 column=(type=long updatewhereclause=yes name=qt_excesso dbname="qt_excesso" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="vw_saldo_atual_produto.vl_custo_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_total dbname="vl_custo_total" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_reposicao dbname="resumo_reposicao_estoque.cd_classe_reposicao" )
 retrieve="Select	r.cd_filial,
		fi.nm_fantasia,
		cl.de_grupo,
		r.cd_produto,
		g.de_produto + g.de_apresentacao_venda As de_produto,
		g.vl_fator_conversao,
		g.cd_grupo_psico,
		r.qt_estoque_base As eb,
		coalesce(mi.qt_estoque_minimo, 0) qt_minimo_promocao,
		v.qt_saldo_final,
		(v.qt_saldo_final - (Case when coalesce(mi.qt_estoque_minimo, 0) >  r.qt_estoque_base Then coalesce(mi.qt_estoque_minimo, 0) else  r.qt_estoque_base END)) As qt_excesso,
		v.vl_custo_medio As vl_custo_unitario,
		round((v.qt_saldo_final - (Case when coalesce(mi.qt_estoque_minimo, 0) >  r.qt_estoque_base Then coalesce(mi.qt_estoque_minimo, 0) else  r.qt_estoque_base END)) * v.vl_custo_medio, 2) As vl_custo_total,
		r.cd_classe_reposicao
From resumo_reposicao_estoque As r
	Inner Join vw_saldo_atual_produto As v
		On v.cd_produto = r.cd_produto
		And v.cd_filial = r.cd_filial
	Inner Join produto_geral As g 
		On g.cd_produto = r.cd_produto
	Inner Join vw_classificacao_produto As cl 
		On cl.cd_subcategoria = g.cd_subcategoria
	Inner Join vw_filial As fi 
		On fi.cd_filial = r.cd_filial
	Inner Join produto_central As c
		On c.cd_produto = r.cd_produto
	left outer join resumo_estoque_minimo_filial mi
		on mi.cd_filial = r.cd_filial
		and mi.cd_produto = r.cd_produto
Where v.qt_saldo_final > (Case when coalesce(mi.qt_estoque_minimo, 0) >  r.qt_estoque_base Then coalesce(mi.qt_estoque_minimo, 0) else  r.qt_estoque_base END)
  And cl.cd_grupo <> '5'
Order By r.cd_filial, cl.de_grupo, g.de_produto" )
