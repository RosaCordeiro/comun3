 column=(type=char(40) updatewhereclause=yes name=de_arvore_mercadologica dbname="arvore_mercadologica.de_arvore_mercadologica" dbalias="am.de_arvore_mercadologica" )
 column=(type=char(9) updatewhereclause=yes name=cd_grupo_mercadoria dbname="produto_geral.cd_grupo_mercadoria" dbalias="pg.cd_grupo_mercadoria" )
