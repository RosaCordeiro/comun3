 retrieve="Select	pg.de_codigo_barras,
		pg.cd_produto,
		pg.de_produto,
		pg.de_apresentacao_venda,
		pg.cd_grupo_psico,
		pg.cd_produto_sap,
		cast(pg.dh_inclusao_produto as date) as dh_inclusao_produto,
		pg.id_situacao,
		cp.de_grupo,
		cp.de_subgrupo,
		cp.de_categoria,
		cp.de_subcategoria,
		mx.de_mix_produto,
		pg.vl_preco_venda_atual / pg.vl_fator_conversao As vl_preco_venda_atual,
		0.00 As pc_desconto_sos,
		pc.vl_custo_gerencial As vl_custo_medio,
		pc.vl_custo_gerencial_geral As vl_custo_gerencial,
		0 qt_saldo_transito,
		0 qt_saldo_matriz,
		0.00 As vl_saldo_matriz,
		0 As qt_dias_estoque_matriz,
		0 qt_saldo_filiais,
		0.00 As vl_saldo_filiais,
		0 As qt_dias_estoque_filiais,
		0 As qt_saldo_total,
		0.00 As vl_saldo_total,
		0 As qt_dias_estoque_geral,
		convert(char(10), pc.dh_ultima_compra, 103) As dt_ultima_entrada,
		0 qt_venda_mes_1,
		0 qt_venda_mes_2,
		0 qt_venda_mes_3,
		0 qt_venda_mes_4,
		0 qt_venda_mes_5,
		0 qt_venda_mes_6,
		0 qt_venda_mes_base,
		0.00 As vl_venda_mes_1,
		0.00 As vl_venda_mes_2,
		0.00 As vl_venda_mes_3,
		0.00 As vl_venda_mes_4,
		0.00 As vl_venda_mes_5,
		0.00 As vl_venda_mes_6,
		0.00 As vl_venda_mes_base,
		0.00 As vl_rent_mes_1,
		0.00 As vl_rent_mes_2,
		0.00 As vl_rent_mes_3,
		0.00 As vl_rent_mes_4,
		0.00 As vl_rent_mes_5,
		0.00 As vl_rent_mes_6,
		0.00 As vl_rent_mes_base,
		0.00 As vl_percent_rent_mes_1,
		0.00 As vl_percent_rent_mes_2,
		0.00 As vl_percent_rent_mes_3,
		0.00 As vl_percent_rent_mes_4,
		0.00 As vl_percent_rent_mes_5,
		0.00 As vl_percent_rent_mes_6,
		0.00 As vl_percent_rent_mes_base,
		(Case pc.id_tipo_reposicao_estoque
			When 'S' Then 'SAZONAL'
			When 'E' Then 'ESTAVEL'
		End) As demanda,
		pg.cd_fornecedor_usual,
		fo.nm_razao_social,
		vw.nr_divisao,
         vw.nm_divisao,
		u.nm_usuario As nm_comprador,
		pg.id_situacao_pis_cofins,
		pg.id_lei_generico,
		pc.vl_preco_reposicao,
		(Case pg.id_caderno_abcfarma
			When 'S' Then 'SIM'
			Else 'N'
		End) As id_caderno_abcfarma,
		pg.vl_fator_conversao,
		pg.nr_embalagem_padrao As caixa_embarque,
		pg.nr_classificacao_fiscal,
		pg.pc_ipi,
		pg.cd_st_origem,
		op.de_origem_produto,
		0.00 As pc_comissao_normal,
		0.00 As pc_comissao_seletiva,
		t.de_tributacao_icms,
		pc.cd_curva_abc_perini as classe_cd,
		pc.cd_curva_abc_filiais as classe_empresa,
		pg.cd_arvore_mercadologica_sap as cd_arvore_mercadologica ,
		am.de_arvore_mercadologica ,
		pg.cd_grupo_mercadoria_sap as cd_grupo_mercadoria,
		gm.de_grupo as de_grupo_mercadoria
From produto_geral As pg
	Inner Join produto_central As pc
		On pc.cd_produto = pg.cd_produto
	Inner Join vw_classificacao_produto As cp
		On cp.cd_subcategoria = pg.cd_subcategoria
	Inner Join fornecedor As fo
		On fo.cd_fornecedor = pg.cd_fornecedor_usual
	Inner Join mix_produto As mx
		On mx.cd_mix_produto = pc.cd_mix_produto
	Left Outer Join marca_produto As c
		On c.cd_marca = pg.cd_marca
	Left Outer Join origem_produto As op
		On op.cd_origem_produto = pg.cd_st_origem
	Inner Join tributacao_icms As t
		On t.cd_tributacao_icms	= pg.cd_tributacao_icms
	Left Outer Join vw_divisao_fornecedor_produto As vw
		On vw.cd_produto = pg.cd_produto
		And vw.cd_fornecedor = pg.cd_fornecedor_usual
	Left Outer Join usuario As u
		On u.nr_matricula = vw.nr_matricula_comprador
	left outer JOIN dbo.arvore_mercadologica am 
		On am.cd_arvore_mercadologica = pg.cd_arvore_mercadologica_sap 
	left outer join grupo_mercadorias gm 
		On gm.cd_grupo = pg.cd_grupo_mercadoria_sap "  sort="cd_produto A " )
