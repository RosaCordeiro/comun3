table(column=(type=long updatewhereclause=yes name=cd_produto dbname="resumo_produto_filial.cd_produto" dbalias="r.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_venda dbname="qt_venda" )
 column=(type=long updatewhereclause=yes name=qt_devolucao_venda dbname="qt_devolucao_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda dbname="vl_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cmv dbname="vl_cmv" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_comissao dbname="vl_comissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="vl_icms" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_pis_cofins dbname="vl_pis_cofins" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_percent_rent dbname="vl_percent_rent" )
 retrieve="select r.cd_produto,
		sum(r.qt_venda - r.qt_devolucao_venda) as qt_venda,
		sum(r.qt_devolucao_venda) qt_devolucao_venda,
		sum(r.vl_venda) as vl_venda,
		sum(r.vl_cmv) as vl_cmv,
		sum(r.vl_comissao) as vl_comissao,
		sum(r.vl_cmv_gerencial - r.vl_cmv) as vl_icms,
		sum(case g.id_situacao_pis_cofins
				 when 'T' then round(r.vl_venda * (cast(p.vl_parametro as numeric(5,2)) / 100), 2)
				 else 0
			  end) as vl_pis_cofins,
		0.00 vl_percent_rent
from resumo_produto_filial r
inner join produto_geral g
	on g.cd_produto = r.cd_produto
left outer join parametro_geral p
	on p.cd_parametro 	        = 'PC_PIS_COFINS_RENTABILIDADE'
where r.dh_resumo  = :mes
group by r.cd_produto" arguments=(("mes", date)) )
