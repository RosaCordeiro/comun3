table(column=(type=datetime updatewhereclause=yes name=pedido_filial_dh_emissao dbname="dh_emissao" )
 column=(type=char(1) updatewhereclause=yes name=id_bloq_compra_maior_limite dbname="id_bloq_compra_maior_limite" )
 column=(type=long updatewhereclause=yes name=pedido_filial_produto_cd_produto dbname="cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="vl_fator_conversao" )
 column=(type=long updatewhereclause=yes name=pedido_filial_cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_filial_ref_preco_venda dbname="cd_filial_ref_preco_venda" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=pedido_filial_produto_qt_pedida dbname="qt_pedida" )
 column=(type=long updatewhereclause=yes name=pedido_filial_produto_qt_faturada dbname="qt_faturada" )
 column=(type=long updatewhereclause=yes name=pedido_filial_distribuicao_nr_prioridade dbname="nr_prioridade" )
 column=(type=char(9) updatewhereclause=yes name=pedido_filial_distribuicao_cd_distribuidora dbname="cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=fornecedor_nm_fantasia dbname="nm_fantasia" )
 column=(type=decimal(2) updatewhereclause=yes name=pedido_filial_distribuicao_vl_preco dbname="vl_preco" )
 column=(type=decimal(2) updatewhereclause=yes name=pedido_filial_distribuicao_pc_desconto dbname="pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=pedido_filial_distribuicao_pc_repasse_icms dbname="pc_repasse_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pedido_filial_distribuicao_vl_icms_st dbname="vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_compra dbname="vl_preco_compra" )
 column=(type=decimal(2) updatewhereclause=yes name=pedido_filial_produto_vl_preco_venda_filial dbname="vl_preco_venda_filial" )
 column=(type=decimal(23) updatewhereclause=yes name=pc_diferenca dbname="pc_diferenca" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_icms_venda dbname="vl_icms_venda" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_pis dbname="vl_pis" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_cofins dbname="vl_cofins" )
 retrieve="select * from
(
 select 	p.dh_emissao,
			p.id_bloq_compra_maior_limite,
			pp.cd_produto,
			g.de_produto + ' : ' + g.de_apresentacao_estoque as de_produto,
			g.vl_fator_conversao,
			p.cd_filial, 
			fi.nm_fantasia,
			p.cd_filial_ref_preco_venda,
			f.nm_fantasia,
         pp.qt_pedida,   
         pp.qt_faturada,   
			pfd.nr_prioridade, 
			pfd.cd_distribuidora,   
			fo.nm_fantasia,
         pfd.vl_preco,   
         pfd.pc_desconto,   
         pfd.pc_repasse_icms,   
         pfd.vl_icms_st,  
			pfd.vl_preco_compra,
         pp.vl_preco_venda_filial,
			(round((pfd.vl_preco_compra
						+ CASE WHEN u.cd_tributacao_icms <> '1' and t.id_icms_normal = 'S'
								THEN round(pp.vl_preco_venda_filial * ti.pc_icms / 100, 2)
								ELSE 0 END) / pp.vl_preco_venda_filial
			, 5) * 100) pc_diferenca,
			(CASE WHEN u.cd_tributacao_icms <> '1' and t.id_icms_normal = 'S'
						THEN round(pp.vl_preco_venda_filial * ti.pc_icms / 100, 2)
						ELSE 0 END) vl_icms_venda,		
			(CASE WHEN g.id_situacao_pis_cofins = 'T'
						THEN ROUND(CAST(pp.vl_preco_venda_filial AS DECIMAL(10, 2)) * :idc_pis / 100, 2)
						ELSE 0 END) vl_pis,
			(CASE WHEN g.id_situacao_pis_cofins = 'T'
						THEN ROUND(CAST(pp.vl_preco_venda_filial AS DECIMAL(10, 2)) * :idc_cofins / 100, 2)
						ELSE 0 END) vl_cofins
from pedido_filial p
inner join filial fi on fi.cd_filial = p.cd_filial 
inner join filial f on f.cd_filial = p.cd_filial_ref_preco_venda 
inner join pedido_filial_produto pp 
	on pp.cd_filial = p.cd_filial
	and pp.nr_pedido_filial = p.nr_pedido_filial
inner join pedido_filial_distribuicao pfd 
	on pfd.cd_filial = p.cd_filial
	and pfd.nr_pedido_filial = p.nr_pedido_filial
	and pfd.cd_produto = pp.cd_produto
	and (Select sum(Coalesce(d.qt_estoque_disponivel, 0))
               					 from distribuidora_produto d
                					where  d.cd_produto     = pp.cd_produto
                					and d.cd_distribuidora  = pfd.cd_distribuidora 
                               group by d.cd_produto,d.cd_distribuidora  ) > 0  /* Val$$HEX1$$e900$$ENDHEX$$ria - chamado 556946 */
inner join produto_geral g on g.cd_produto = pp.cd_produto
inner join fornecedor fo on fo.cd_fornecedor = pfd.cd_distribuidora
inner join cidade c
	on c.cd_cidade = fi.cd_cidade
inner join distribuidora_produto dp
	on dp.cd_distribuidora = pfd.cd_distribuidora
  and dp.cd_produto       = pfd.cd_produto
  and dp.cd_unidade_federacao = c.cd_unidade_federacao
inner join produto_uf u	    on u.cd_unidade_federacao = dp.cd_unidade_federacao and u.cd_produto = dp.cd_produto
inner join tributacao_icms t   on t.cd_tributacao_icms = u.cd_tributacao_icms
Inner Join tipo_icms ti (index pk_tipo_icms) on ti.cd_tipo_icms = u.cd_tipo_icms
where p.dh_emissao between :inicio and :termino
  and p.id_gerado_logistica = 'N'
  and p.id_bloq_compra_maior_limite = 'N'
  and g.id_situacao = 'A'
  and pp.vl_preco_venda_filial > 0
  and (pp.qt_pedida - pp.qt_faturada) > 0
  and pfd.nr_prioridade < p.nr_prioridade_distribuidora
  and pfd.cd_desbloqueio_preco is null
  and (round((pfd.vl_preco_compra 
				+ CASE WHEN u.cd_tributacao_icms <> '1' and t.id_icms_normal = 'S' 
						THEN round(pp.vl_preco_venda_filial * ti.pc_icms / 100, 2)
						ELSE 0
				END
				+ CASE WHEN g.id_situacao_pis_cofins = 'T' 
						THEN ROUND(CAST(pp.vl_preco_venda_filial AS DECIMAL(10, 2)) * :idc_pis / 100, 2)
						ELSE 0
				END
				+	CASE WHEN g.id_situacao_pis_cofins = 'T' 
						THEN ROUND(CAST(pp.vl_preco_venda_filial AS DECIMAL(10, 2)) * :idc_cofins / 100, 2)
						ELSE 0
				END
			)
			/ pp.vl_preco_venda_filial, 5
	) * 100) > coalesce(coalesce(pp.pc_limite_aceite_preco_distrib, p.pc_limite_aceite_preco_distrib), 99)  
 and exists (	select * 
					from pedido_distribuidora pd
					inner join pedido_distribuidora_produto pdp 
						on pdp.cd_filial		= pd.cd_filial
						and pdp.nr_pedido_distribuidora = pd.nr_pedido_distribuidora
						and pdp.cd_produto				= pp.cd_produto
					where pd.cd_filial 			= p.cd_filial
					  and pd.nr_pedido_filial 	= p.nr_pedido_filial
					  and pd.cd_distribuidora	= pfd.cd_distribuidora)

union all

 select 	p.dh_emissao,
			p.id_bloq_compra_maior_limite,
			pp.cd_produto,
			g.de_produto + ' : ' + g.de_apresentacao_estoque as de_produto,
			g.vl_fator_conversao,
			p.cd_filial, 
			fi.nm_fantasia,
			p.cd_filial_ref_preco_venda,
			f.nm_fantasia,
         pp.qt_pedida,   
         pp.qt_faturada,   
			pfd.nr_prioridade, 
			pfd.cd_distribuidora,   
			fo.nm_fantasia,
         pfd.vl_preco,   
         pfd.pc_desconto,   
         pfd.pc_repasse_icms,   
         pfd.vl_icms_st,  
			pfd.vl_preco_compra,
         pp.vl_preco_venda_filial,
			(round((pfd.vl_preco_compra
						+ CASE WHEN u.cd_tributacao_icms <> '1' and t.id_icms_normal = 'S'
								THEN round(pp.vl_preco_venda_filial * ti.pc_icms / 100, 2)
								ELSE 0 END) / pp.vl_preco_venda_filial
			, 5) * 100) pc_diferenca,
			(CASE WHEN u.cd_tributacao_icms <> '1' and t.id_icms_normal = 'S'
						THEN round(pp.vl_preco_venda_filial * ti.pc_icms / 100, 2)
						ELSE 0 END) vl_icms_venda,		
			(CASE WHEN g.id_situacao_pis_cofins = 'T'
						THEN ROUND(CAST(pp.vl_preco_venda_filial AS DECIMAL(10, 2)) * :idc_pis / 100, 2)
						ELSE 0 END) vl_pis,
			(CASE WHEN g.id_situacao_pis_cofins = 'T'
						THEN ROUND(CAST(pp.vl_preco_venda_filial AS DECIMAL(10, 2)) * :idc_cofins / 100, 2)
						ELSE 0 END) vl_cofins
from pedido_filial p
inner join filial fi on fi.cd_filial = p.cd_filial 
inner join filial f on f.cd_filial = p.cd_filial_ref_preco_venda 
inner join pedido_filial_produto pp 
	on pp.cd_filial = p.cd_filial
	and pp.nr_pedido_filial = p.nr_pedido_filial
inner join pedido_filial_distribuicao pfd 
	on pfd.cd_filial = p.cd_filial
	and pfd.nr_pedido_filial = p.nr_pedido_filial
	and pfd.cd_produto = pp.cd_produto
	and (Select sum(Coalesce(d.qt_estoque_disponivel, 0))
               	 from distribuidora_produto d
                			where  d.cd_produto     = pp.cd_produto
                			and d.cd_distribuidora  = pfd.cd_distribuidora 
                   group by d.cd_produto,d.cd_distribuidora  ) > 0  /* Val$$HEX1$$e900$$ENDHEX$$ria - chamado 556946 */
inner join produto_geral g on g.cd_produto = pp.cd_produto
inner join fornecedor fo on fo.cd_fornecedor = pfd.cd_distribuidora
inner join cidade c
	on c.cd_cidade = fi.cd_cidade
inner join distribuidora_produto dp
	on dp.cd_distribuidora = pfd.cd_distribuidora
  and dp.cd_produto       = pfd.cd_produto
  and dp.cd_unidade_federacao = c.cd_unidade_federacao
inner join produto_uf u	    on u.cd_unidade_federacao = dp.cd_unidade_federacao and u.cd_produto = dp.cd_produto
inner join tributacao_icms t   on t.cd_tributacao_icms = u.cd_tributacao_icms
Inner Join tipo_icms ti (index pk_tipo_icms) on ti.cd_tipo_icms = u.cd_tipo_icms
where p.dh_emissao between :inicio and :termino
  and p.id_gerado_logistica = 'N'
  and p.id_bloq_compra_maior_limite = 'S'
  and (pp.qt_pedida - pp.qt_faturada) > 0
  and g.id_situacao = 'A'
  and pp.vl_preco_venda_filial > 0
  and pfd.nr_prioridade < p.nr_prioridade_distribuidora
  and pfd.cd_desbloqueio_preco is null
  and (round((pfd.vl_preco_compra 
				+ CASE WHEN u.cd_tributacao_icms <> '1' and t.id_icms_normal = 'S' 
						THEN round(pp.vl_preco_venda_filial * ti.pc_icms / 100, 2)
						ELSE 0
				END
				+ CASE WHEN g.id_situacao_pis_cofins = 'T' 
						THEN ROUND(CAST(pp.vl_preco_venda_filial AS DECIMAL(10, 2)) * :idc_pis / 100, 2)
						ELSE 0
				END
				+	CASE WHEN g.id_situacao_pis_cofins = 'T' 
						THEN ROUND(CAST(pp.vl_preco_venda_filial AS DECIMAL(10, 2)) * :idc_cofins / 100, 2)
						ELSE 0
				END
			)
			/ pp.vl_preco_venda_filial, 5
	) * 100) > coalesce(coalesce(pp.pc_limite_aceite_preco_distrib, p.pc_limite_aceite_preco_distrib), 99) 
  and exists (select * from pedido_filial_prd_compra_bloq x
					where x.cd_filial= pfd.cd_filial
						and x.nr_pedido_filial = pfd.nr_pedido_filial
						and x.cd_produto	= pfd.cd_produto
						and x.cd_distribuidora = pfd.cd_distribuidora)
) as tudo
where tudo.id_bloq_compra_maior_limite is not null
order by tudo.dh_emissao, tudo.cd_filial, tudo.de_produto, tudo.nr_prioridade" arguments=(("inicio", date),("termino", date),("idc_pis", decimal),("idc_cofins", decimal)) )
