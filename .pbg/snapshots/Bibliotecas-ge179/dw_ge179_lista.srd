table(column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_custo_gerencial_geral dbname="vl_custo_gerencial_geral" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="vl_fator_conversao" )
 column=(type=char(1) updatewhereclause=yes name=id_bloq_compra_maior_limite dbname="id_bloq_compra_maior_limite" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_limite_aceite_preco_distrib dbname="pc_limite_aceite_preco_distrib" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_falta dbname="qt_falta" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_falta dbname="vl_falta" )
 retrieve="select tudo.cd_produto, 
		de_produto, 
		round(pc.vl_custo_gerencial_geral * vl_fator_conversao, 2)  vl_custo_gerencial_geral, 
		vl_fator_conversao, 
		id_bloq_compra_maior_limite,  
		pc_limite_aceite_preco_distrib, 
		qt_pedida, 
		qt_faturada,
		(qt_pedida - qt_faturada) as qt_falta,
		round((qt_pedida - qt_faturada) * round(pc.vl_custo_gerencial_geral * vl_fator_conversao, 2), 2) vl_falta
from
(
select 	p2.cd_produto, 
			g.de_produto + ' : ' + g.de_apresentacao_venda as de_produto, 
			g.vl_fator_conversao, 
			p1.id_bloq_compra_maior_limite,
			coalesce(p2.pc_limite_aceite_preco_distrib, p1.pc_limite_aceite_preco_distrib) as pc_limite_aceite_preco_distrib,
			sum(p2.qt_pedida) qt_pedida, 
			sum(p2.qt_faturada) qt_faturada,
			pfdi.cd_fornecedor_conexao
from pedido_filial p1
inner join pedido_filial_produto p2 
	on p2.cd_filial = p1.cd_filial
	and p2.nr_pedido_filial = p1.nr_pedido_filial
inner join produto_geral g 
	on g.cd_produto = p2.cd_produto
inner join filial f 
	on f.cd_filial = p1.cd_filial
inner join pedido_filial_distribuicao pfdi
	on pfdi.cd_filial = p1.cd_filial
	and pfdi.nr_pedido_filial	= p1.nr_pedido_filial
	and pfdi.cd_produto			= p2.cd_produto
where p1.dh_emissao between :inicio and :termino
  and p1.id_gerado_logistica = 'N'
  and g.id_situacao = 'A'
  and p1.id_bloq_compra_maior_limite = 'N'
  and (qt_pedida - qt_faturada) > 0
  and exists (select 	*
					from pedido_filial p
					inner join pedido_filial_produto pp 
						on pp.cd_filial = p.cd_filial
						and pp.nr_pedido_filial = p.nr_pedido_filial
					inner join pedido_filial_distribuicao pfd 
						on pfd.cd_filial = p.cd_filial
						and pfd.nr_pedido_filial = p.nr_pedido_filial
						and pfd.cd_produto = pp.cd_produto
					    and (Select sum(Coalesce(d.qt_estoque_disponivel, 0))
               					 from distribuidora_produto d
                					where  d.cd_produto     = pp.cd_produto
                					and d.cd_distribuidora  = pfd.cd_distribuidora 
                               group by d.cd_produto,d.cd_distribuidora  ) > 0  /* Val$$HEX1$$e900$$ENDHEX$$ria - chamado 556946 */
					inner join fornecedor fo
						on fo.cd_fornecedor = pfd.cd_distribuidora
               inner join cidade c
                  on c.cd_cidade = f.cd_cidade
               inner join distribuidora_produto dp
                  on dp.cd_distribuidora = pfd.cd_distribuidora
                 and dp.cd_produto       = pfd.cd_produto
                 and dp.cd_unidade_federacao = c.cd_unidade_federacao
					inner join produto_uf u	    on u.cd_unidade_federacao = dp.cd_unidade_federacao and u.cd_produto = dp.cd_produto
					inner join tributacao_icms t   on t.cd_tributacao_icms = u.cd_tributacao_icms
					Inner Join tipo_icms ti (index pk_tipo_icms) on ti.cd_tipo_icms = u.cd_tipo_icms
					where p.dh_emissao = p1.dh_emissao
					  and p.id_gerado_logistica = 'N'
					  and pfd.nr_prioridade < p.nr_prioridade_distribuidora
					  and pp.vl_preco_venda_filial > 0.00
					  and pfd.cd_desbloqueio_preco is null
					  and (round((pfd.vl_preco_compra 
									+ CASE WHEN u.cd_tributacao_icms <> '1' and t.id_icms_normal = 'S' 
											THEN round(pp.vl_preco_venda_filial * ti.pc_icms / 100, 2)
											ELSE 0
									END
									+ CASE	WHEN g.id_situacao_pis_cofins = 'T' 
											THEN ROUND(CAST(pp.vl_preco_venda_filial AS DECIMAL(10, 2)) * :idc_pis / 100, 2)
											ELSE 0
									END
									+	CASE	WHEN g.id_situacao_pis_cofins = 'T' 
											THEN ROUND(CAST(pp.vl_preco_venda_filial AS DECIMAL(10, 2)) * :idc_cofins / 100, 2)
											ELSE 0
									END
								)
								/ pp.vl_preco_venda_filial, 5
						) * 100) > coalesce(coalesce(pp.pc_limite_aceite_preco_distrib, p.pc_limite_aceite_preco_distrib), 99) 
					  and pp.cd_filial	= p2.cd_filial
					  and pp.nr_pedido_filial	= p2.nr_pedido_filial
					  and pp.cd_produto			= p2.cd_produto
					  and exists (	select * 
										from pedido_distribuidora pd
										inner join pedido_distribuidora_produto pdp 
											on pdp.cd_filial		= pd.cd_filial
											and pdp.nr_pedido_distribuidora = pd.nr_pedido_distribuidora
											and pdp.cd_produto				= pp.cd_produto
										where pd.cd_filial 			= p.cd_filial
										  and pd.nr_pedido_filial 	= p.nr_pedido_filial
										  and pd.cd_distribuidora	= pfd.cd_distribuidora)
					)
group by pfdi.cd_fornecedor_conexao, p2.cd_produto, g.de_produto + ' : ' + g.de_apresentacao_venda, g.vl_fator_conversao, p1.id_bloq_compra_maior_limite, coalesce(p2.pc_limite_aceite_preco_distrib, p1.pc_limite_aceite_preco_distrib)

union all

select 	p2.cd_produto, 
			g.de_produto + ' : ' + g.de_apresentacao_venda as de_produto, 
			g.vl_fator_conversao, 
			p1.id_bloq_compra_maior_limite,
			coalesce(p2.pc_limite_aceite_preco_distrib, p1.pc_limite_aceite_preco_distrib),
			sum(p2.qt_pedida) qt_pedida, 
			sum(p2.qt_faturada) qt_faturada,
			pfdi.cd_fornecedor_conexao
from pedido_filial p1
inner join pedido_filial_produto p2 
	on p2.cd_filial = p1.cd_filial
	and p2.nr_pedido_filial = p1.nr_pedido_filial
inner join produto_geral g 
	on g.cd_produto = p2.cd_produto
inner join filial f 
	on f.cd_filial = p1.cd_filial
inner join pedido_filial_distribuicao pfdi
	on pfdi.cd_filial = p1.cd_filial
	and pfdi.nr_pedido_filial	= p1.nr_pedido_filial
	and pfdi.cd_produto			= p2.cd_produto
where p1.dh_emissao between :inicio and :termino
  and p1.id_gerado_logistica = 'N'
  and g.id_situacao = 'A'
  and p1.id_bloq_compra_maior_limite = 'S'
  and (qt_pedida - qt_faturada) > 0
  and exists (select 	*
					from pedido_filial p
					inner join pedido_filial_produto pp 
						on pp.cd_filial = p.cd_filial
						and pp.nr_pedido_filial = p.nr_pedido_filial
					inner join pedido_filial_distribuicao pfd 
						on pfd.cd_filial = p.cd_filial
						and pfd.nr_pedido_filial = p.nr_pedido_filial
						and pfd.cd_produto = pp.cd_produto
					    and (Select sum(Coalesce(d.qt_estoque_disponivel, 0))
               					 from distribuidora_produto d
                					where  d.cd_produto     = pp.cd_produto
                					and d.cd_distribuidora  = pfd.cd_distribuidora 
                               group by d.cd_produto,d.cd_distribuidora  ) > 0  /* Val$$HEX1$$e900$$ENDHEX$$ria - chamado 556946 */
					inner join fornecedor fo
						on fo.cd_fornecedor = pfd.cd_distribuidora
               inner join cidade c
                  on c.cd_cidade = f.cd_cidade
               inner join distribuidora_produto dp
                  on dp.cd_distribuidora = pfd.cd_distribuidora
                 and dp.cd_produto       = pfd.cd_produto
                 and dp.cd_unidade_federacao = c.cd_unidade_federacao
					inner join produto_uf u	    on u.cd_unidade_federacao = dp.cd_unidade_federacao and u.cd_produto = dp.cd_produto
					inner join tributacao_icms t   on t.cd_tributacao_icms = u.cd_tributacao_icms
					Inner Join tipo_icms ti (index pk_tipo_icms) on ti.cd_tipo_icms = u.cd_tipo_icms
					where p.dh_emissao = p1.dh_emissao
					  and p.id_gerado_logistica = 'N'
					  and pfd.nr_prioridade < p.nr_prioridade_distribuidora
					  and pp.vl_preco_venda_filial > 0.00
					  and pfd.cd_desbloqueio_preco is null
					  and (round((pfd.vl_preco_compra 
									+ CASE WHEN u.cd_tributacao_icms <> '1' and t.id_icms_normal = 'S' 
											THEN round(pp.vl_preco_venda_filial * ti.pc_icms / 100, 2)
											ELSE 0
									END
									+ CASE	WHEN g.id_situacao_pis_cofins = 'T' 
											THEN ROUND(CAST(pp.vl_preco_venda_filial AS DECIMAL(10, 2)) * :idc_pis / 100, 2)
											ELSE 0
									END
									+	CASE	WHEN g.id_situacao_pis_cofins = 'T' 
											THEN ROUND(CAST(pp.vl_preco_venda_filial AS DECIMAL(10, 2)) * :idc_cofins / 100, 2)
											ELSE 0
									END
								)
								/ pp.vl_preco_venda_filial, 5
						) * 100) > coalesce(coalesce(pp.pc_limite_aceite_preco_distrib, p.pc_limite_aceite_preco_distrib), 99) 
					  and pp.cd_filial	= p2.cd_filial
					  and pp.nr_pedido_filial	= p2.nr_pedido_filial
					  and pp.cd_produto			= p2.cd_produto
					)
	and exists (select * from pedido_filial_prd_compra_bloq x
					where x.cd_filial= p1.cd_filial
						and x.nr_pedido_filial = p1.nr_pedido_filial
						and x.cd_produto	= p2.cd_produto)
group by pfdi.cd_fornecedor_conexao,p2.cd_produto, g.de_produto + ' : ' + g.de_apresentacao_venda, g.vl_fator_conversao, p1.id_bloq_compra_maior_limite, coalesce(p2.pc_limite_aceite_preco_distrib, p1.pc_limite_aceite_preco_distrib)
) as tudo
inner join produto_central pc on pc.cd_produto = tudo.cd_produto
where tudo.id_bloq_compra_maior_limite is not null
group by tudo.cd_produto, 
			de_produto, 
			round(pc.vl_custo_gerencial_geral * vl_fator_conversao, 2), 
			vl_fator_conversao, 
			id_bloq_compra_maior_limite,  
			pc_limite_aceite_preco_distrib, 
			qt_pedida, 
			qt_faturada
" arguments=(("inicio", date),("termino", date),("idc_pis", decimal),("idc_cofins", decimal))  sort="de_produto A " )
