table(column=(type=datetime updatewhereclause=yes name=dh_saldo dbname="saldo_produto.dh_saldo" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="saldo_produto.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="vw_filial.nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="vw_classificacao_produto.cd_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="vw_classificacao_produto.de_grupo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_estoque dbname="vl_estoque" )
 retrieve="Select	s.dh_saldo,
		s.cd_filial,
		f.nm_fantasia,
		c.cd_grupo,
		c.de_grupo,
		sum(round(s.qt_saldo_final * s.vl_custo_gerencial, 2)) As vl_estoque
From saldo_produto As s
	Inner Join produto_geral As g
		On g.cd_produto = s.cd_produto
	Inner Join vw_classificacao_produto As c
		On c.cd_subcategoria = g.cd_subcategoria
	Inner Join vw_filial As f
		On f.cd_filial = s.cd_filial
Where s.dh_saldo Between :inicio And :termino
    And s.qt_saldo_final > 0
Group By	s.dh_saldo,
			s.cd_filial,
			f.nm_fantasia,
			c.cd_grupo,
			c.de_grupo" arguments=(("inicio", date),("termino", date))  sort="cd_filial A dh_saldo A cd_grupo A " )
