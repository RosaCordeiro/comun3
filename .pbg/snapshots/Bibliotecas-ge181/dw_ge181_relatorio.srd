table(column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="controle_caixa.cd_caixa" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="controle_caixa.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_lancamento dbname="lancamento_caixa.vl_lancamento" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_liquido dbname="vl_liquido" )
 column=(type=char(1) updatewhereclause=yes name=id_estorno dbname="lancamento_caixa.id_estorno" values="ESTORNO	S/---	N/ESTORNADO	X/" )
 column=(type=char(91) updatewhereclause=yes name=de_historico dbname="de_historico" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="controle_caixa.nr_controle_caixa" )
 column=(type=char(50) updatewhereclause=yes name=nsu_ecommerce dbname="nsu_ecommerce" )
 column=(type=char(20) updatewhereclause=yes name=nr_docto dbname="lancamento_caixa.nr_docto" )
 column=(type=long updatewhereclause=yes name=nr_lancamento dbname="lancamento_caixa.nr_lancamento" )
 column=(type=long updatewhereclause=yes name=cd_conta_fluxo_caixa dbname="lancamento_caixa.cd_conta_fluxo_caixa" )
 retrieve="Select c.cd_caixa,
		f.cd_filial,
		f.nm_fantasia,   
		c.dh_movimentacao_caixa,   
		l.vl_lancamento,
		round(vl_lancamento - (sum(	dbo.retorna_valor_comissao_cartao	( 	c.dh_movimentacao_caixa, l.cd_conta_fluxo_caixa, cco.qt_parcelas, cco.vl_parcela, cco.vl_comissao, 		COALESCE( cco.id_tipo_uso_cd, SUBSTRING( cco.id_tipo_operacao, 2, 1)),cco.nr_pedido_ecommerce)								)),2) as vl_liquido,
		/*round(vl_lancamento - (sum(dbo.retorna_comissao_cartao(				c.dh_movimentacao_caixa, l.cd_conta_fluxo_caixa, cco.qt_parcelas, 													COALESCE( cco.id_tipo_uso_cd, SUBSTRING( cco.id_tipo_operacao, 2, 1)),cco.nr_pedido_ecommerce) / 100 * cco.vl_parcela )),2) as vl_liquido,*/
		/*round(vl_lancamento - (sum(Case When cftc.cd_conta_fluxo_caixa is not null
											Then Case When cco.id_tipo_operacao = 'VD' Then cftc.pc_comissao_debito
											else Case When cco.qt_parcelas= 1 Then cftc.pc_comissao_credito_avista
											else cftc.pc_comissao_credito_parcelado end end / 100 * cco.vl_parcela
											else cco.vl_comissao end)),2) as vl_liquido,*/
		l.id_estorno,
		Case When pe.cd_tipo_pagamento = 'PIX ECOMMERCE' and l.cd_conta_fluxo_caixa = 288 Then substring(l.de_historico,1, charindex('NSU:', l.de_historico) + 3) || pea.cd_autorizacao_cd || '*' Else Case coalesce(l.de_historico, 'nulo') When 'nulo' then l.nr_documento else l.de_historico end end as de_historico,
		c.nr_controle_caixa,
		Case When pe.cd_tipo_pagamento = 'PIX ECOMMERCE' and l.cd_conta_fluxo_caixa = 288 Then pea.cd_autorizacao_cd Else pea.nr_nsu_host End as nsu_ecommerce,
		l.nr_documento  as nr_docto ,
		l.nr_lancamento,
		l.cd_conta_fluxo_caixa  
From controle_caixa c
Inner Join lancamento_caixa l
	On l.cd_caixa = c.cd_caixa
	and l.nr_controle_caixa = c.nr_controle_caixa
Inner Join caixa x
	On x.cd_caixa = l.cd_caixa
Inner Join filial f 
	On f.cd_filial = x.cd_filial
Left Outer Join cartao_comprovante_operacao cco
	On cco.cd_caixa 					= l.cd_caixa
	and cco.nr_controle_caixa 		= l.nr_controle_caixa
	and cco.nr_comprovante_caixa = l.nr_lancamento 
Left Outer Join conta_fluxo_taxa_cartao cftc
	On cftc.cd_conta_fluxo_caixa = l.cd_conta_fluxo_caixa
	and cftc.dh_inicio = (Select max(cftc1.dh_inicio) From conta_fluxo_taxa_cartao cftc1 Where cftc1.cd_conta_fluxo_caixa = l.cd_conta_fluxo_caixa and cftc1.dh_inicio <= cco.dh_operacao)
Left join pedido_ecommerce pe on pe.cd_filial = f.cd_filial and pe.nr_pedido = Cast( dbo.retorna_so_numeros(l.nr_documento) as decimal(21))
Left Outer Join pedido_ecommerce_auxiliar pea 
    On pea.nr_pedido = pe.nr_pedido and pea.cd_filial_ecommerce = pe.cd_filial_ecommerce
Where c.dh_movimentacao_caixa between :dt_inicial and :dt_final
Group by c.cd_caixa,
			f.cd_filial,
			f.nm_fantasia,   
			c.dh_movimentacao_caixa,   
			l.vl_lancamento,   
			l.id_estorno,
			Case When pe.cd_tipo_pagamento = 'PIX ECOMMERCE' and l.cd_conta_fluxo_caixa = 288 Then substring(l.de_historico,1, charindex('NSU:', l.de_historico) + 3) || pea.cd_autorizacao_cd || '*' Else Case coalesce(l.de_historico, 'nulo') When 'nulo' then l.nr_documento else l.de_historico end end ,
			c.nr_controle_caixa,
 			Case When pe.cd_tipo_pagamento = 'PIX ECOMMERCE' and l.cd_conta_fluxo_caixa = 288 Then pea.cd_autorizacao_cd Else pea.nr_nsu_host End,
			l.nr_documento,
			l.nr_lancamento,
			l.cd_conta_fluxo_caixa" arguments=(("dt_inicial", date),("dt_final", date))  sort="dh_movimentacao_caixa A cd_filial A " )
