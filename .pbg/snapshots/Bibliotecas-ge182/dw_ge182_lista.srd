table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" dbalias="fi.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="fi.nm_fantasia" )
 column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="cd_caixa" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="nr_controle_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_saldo_final dbname="vl_saldo_final" )
 column=(type=datetime updatewhereclause=yes name=dh_conferencia dbname="dh_conferencia" )
 column=(type=datetime updatewhereclause=yes name=dh_exportacao dbname="dh_exportacao" )
 column=(type=datetime updatewhereclause=yes name=dh_revisao dbname="dh_revisao" )
 column=(type=datetime updatewhereclause=yes name=dh_importacao dbname="dh_importacao" )
 column=(type=long updatewhereclause=yes name=nro_lacto dbname="nro_lacto" )
 retrieve="select fi.cd_filial,   
		fi.nm_fantasia,   
		cc.cd_caixa,
		cc.nr_controle_caixa,   
		cc.dh_movimentacao_caixa,   
		cc.vl_saldo_final,
 		cc.dh_conferencia,
		case when DATEDIFF( day, cc.dh_movimentacao_caixa, getdate() ) > 30 then cc.dh_movimentacao_caixa else lo.dh_exportacao  end as dh_exportacao,
		cc.dh_revisao as dh_revisao,
		case when DATEDIFF( day, cc.dh_movimentacao_caixa, getdate() ) > 30 then cc.dh_movimentacao_caixa else lo.dh_importacao  end as dh_importacao,
		count(*) as nro_lacto
from controle_caixa cc (index idx_data_movimentacao)
inner join caixa cx
	on cx.cd_caixa  = cc.cd_caixa 
inner join filial fi
	on fi.cd_filial = cx.cd_filial
inner join lancamento_caixa l (index pk_lancamento_caixa)
	on l.cd_caixa = cc.cd_caixa
  and l.nr_controle_caixa = cc.nr_controle_caixa
left outer join log_exportacao_mult lo (index idx_log_mult_tipo_nf)
	on lo.id_tipo_nf = 'LC'
	and lo.cd_filial = cx.cd_filial
	and lo.nr_nf = cc.nr_controle_caixa
	and lo.cd_fornecedor = cc.cd_caixa
	and lo.de_especie = 'CX'
	and lo.de_serie = 'C'
where cc.dh_movimentacao_caixa between  :dt_inicio and :dt_fim
  and datepart(dw,cc.dh_movimentacao_caixa)<>1
  and cx.id_caixa_geral = 'S'
  and fi.id_situacao = 'A'
group by 	fi.cd_filial,   
				fi.nm_fantasia,   
				cc.cd_caixa,
				cc.nr_controle_caixa,   
				cc.dh_movimentacao_caixa,   
				cc.vl_saldo_final,
				cc.dh_conferencia,
				case when DATEDIFF( day, cc.dh_movimentacao_caixa, getdate() ) > 30 then cc.dh_movimentacao_caixa else lo.dh_exportacao  end,
				cc.dh_revisao,
				case when DATEDIFF( day, cc.dh_movimentacao_caixa, getdate() ) > 30 then cc.dh_movimentacao_caixa else lo.dh_importacao  end
union

/**** Domingos ****/ 
select  fi.cd_filial,   
		fi.nm_fantasia,   
		cc.cd_caixa,
		cc.nr_controle_caixa,   
		cc.dh_movimentacao_caixa,   
		cc.vl_saldo_final,
 		cc.dh_conferencia,
		case when DATEDIFF( day, cc.dh_movimentacao_caixa, getdate() ) > 30 then cc.dh_movimentacao_caixa else lo.dh_exportacao  end as dh_exportacao,
		cc.dh_revisao as dh_revisao,
		case when DATEDIFF( day, cc.dh_movimentacao_caixa, getdate() ) > 30 then cc.dh_movimentacao_caixa else lo.dh_importacao  end as dh_importacao,
		count(*) as nro_lacto
from controle_caixa cc (index idx_data_movimentacao)
inner join caixa cx
	on cx.cd_caixa  = cc.cd_caixa 
inner join filial fi
	on fi.cd_filial = cx.cd_filial
inner join lancamento_caixa l (index pk_lancamento_caixa)
	on l.cd_caixa = cc.cd_caixa
  and l.nr_controle_caixa = cc.nr_controle_caixa
left outer join log_exportacao_mult lo (index idx_log_mult_tipo_nf)
	on lo.id_tipo_nf = 'LC'
	and lo.cd_filial = cx.cd_filial
	and lo.nr_nf = cc.nr_controle_caixa
	and lo.cd_fornecedor = cc.cd_caixa
	and lo.de_especie = 'CX'
	and lo.de_serie = 'C'
where cc.dh_movimentacao_caixa between :dt_inicio and :dt_fim
  and datepart(dw,cc.dh_movimentacao_caixa)=1
  and cx.id_caixa_geral = 'S'
  and fi.id_situacao = 'A'
  and fi.id_abre_domingo = 'S'
group by 	fi.cd_filial,   
				fi.nm_fantasia,   
				cc.cd_caixa,
				cc.nr_controle_caixa,   
				cc.dh_movimentacao_caixa,   
				cc.vl_saldo_final,
				cc.dh_conferencia,
				case when DATEDIFF( day, cc.dh_movimentacao_caixa, getdate() ) > 30 then cc.dh_movimentacao_caixa else lo.dh_exportacao  end,
				cc.dh_revisao,
				case when DATEDIFF( day, cc.dh_movimentacao_caixa, getdate() ) > 30 then cc.dh_movimentacao_caixa else lo.dh_importacao  end" arguments=(("dt_inicio", date),("dt_fim", date))  sort="dh_movimentacao_caixa A cd_filial A " )
