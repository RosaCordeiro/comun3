table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="cd_caixa" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="nr_controle_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_saldo_final dbname="vl_saldo_final" )
 column=(type=datetime updatewhereclause=yes name=dh_conferencia dbname="dh_conferencia" )
 column=(type=datetime updatewhereclause=yes name=dh_exportacao dbname="dh_exportacao" )
 column=(type=datetime updatewhereclause=yes name=dh_revisao dbname="dh_revisao" )
 column=(type=long updatewhereclause=yes name=nro_lacto dbname="nro_lacto" )
 column=(type=long updatewhereclause=yes name=qt_lanctos_sap dbname="qt_lanctos_sap" )
 retrieve="select fi.cd_filial,   
		fi.nm_fantasia,   
		cc.cd_caixa,
		cc.nr_controle_caixa,   
		cc.dh_movimentacao_caixa,   
		cc.vl_saldo_final,
 		cc.dh_conferencia,
		max(case when DATEDIFF( day, cc.dh_movimentacao_caixa, getdate() ) > 30 then cc.dh_movimentacao_caixa else le.dh_exportacao end) as dh_exportacao,
		cc.dh_revisao as dh_revisao,
		count(*) as nro_lacto,
		SUM(CASE WHEN cfc.cd_tipo_numerario_sap is not null or l.cd_conta_fluxo_caixa in (84,85) THEN 1 ELSE 0 END) as qt_lanctos_sap
from controle_caixa cc (index idx_data_movimentacao)
inner join caixa cx
	on cx.cd_caixa  = cc.cd_caixa 
inner join filial fi
	on fi.cd_filial = cx.cd_filial
inner join lancamento_caixa l (index pk_lancamento_caixa)
	on l.cd_caixa = cc.cd_caixa
  and l.nr_controle_caixa = cc.nr_controle_caixa
inner join conta_fluxo_caixa cfc
	on cfc.cd_conta_fluxo_caixa = l.cd_conta_fluxo_caixa
left outer join log_exportacao_docto le
	on le.cd_filial = cx.cd_filial
	and le.id_tipo_docto = 'CX'
	and le.id_situacao_log = 'P'
	and le.cd_ambiente_sap = 'PRD'
	and le.dh_documento  = cc.dh_movimentacao_caixa
where cc.dh_movimentacao_caixa between  :dt_inicio and :dt_fim
  and datepart(dw,cc.dh_movimentacao_caixa)<>1
  and cx.id_caixa_geral = 'S'
  and fi.id_situacao = 'A'
group by 	fi.cd_filial,   
				fi.nm_fantasia,   
				cc.cd_caixa,
				cc.nr_controle_caixa,   
				cc.dh_movimentacao_caixa,   
				cc.vl_saldo_final,
				cc.dh_conferencia,
				cc.dh_revisao

union

/**** Domingos ****/ 
select  fi.cd_filial,   
		fi.nm_fantasia,   
		cc.cd_caixa,
		cc.nr_controle_caixa,   
		cc.dh_movimentacao_caixa,   
		cc.vl_saldo_final,
 		cc.dh_conferencia,
		max(case when DATEDIFF( day, cc.dh_movimentacao_caixa, getdate() ) > 30 then cc.dh_movimentacao_caixa else le.dh_exportacao  end) as dh_exportacao,
		cc.dh_revisao as dh_revisao,
		count(*) as nro_lacto,
		SUM(CASE WHEN cfc.cd_tipo_numerario_sap is not null or l.cd_conta_fluxo_caixa in (84,85) THEN 1 ELSE 0 END) as qt_lanctos_sap
from controle_caixa cc (index idx_data_movimentacao)
inner join caixa cx
	on cx.cd_caixa  = cc.cd_caixa 
inner join filial fi
	on fi.cd_filial = cx.cd_filial
inner join lancamento_caixa l (index pk_lancamento_caixa)
	on l.cd_caixa = cc.cd_caixa
  and l.nr_controle_caixa = cc.nr_controle_caixa
inner join conta_fluxo_caixa cfc
	on cfc.cd_conta_fluxo_caixa = l.cd_conta_fluxo_caixa
left outer join log_exportacao_docto le
	on le.cd_filial = cx.cd_filial
	and le.id_tipo_docto = 'CX'
	and le.id_situacao_log = 'P'
	and le.cd_ambiente_sap = 'PRD'
	and le.dh_documento  = cc.dh_movimentacao_caixa

where cc.dh_movimentacao_caixa between :dt_inicio and :dt_fim
  and datepart(dw,cc.dh_movimentacao_caixa)=1
  and cx.id_caixa_geral = 'S'
  and fi.id_situacao = 'A'
  and fi.id_abre_domingo = 'S'
group by 	fi.cd_filial,   
				fi.nm_fantasia,   
				cc.cd_caixa,
				cc.nr_controle_caixa,   
				cc.dh_movimentacao_caixa,   
				cc.vl_saldo_final,
				cc.dh_conferencia,
				cc.dh_revisao" arguments=(("dt_inicio", date),("dt_fim", date))  sort="dh_movimentacao_caixa A cd_filial A " )
