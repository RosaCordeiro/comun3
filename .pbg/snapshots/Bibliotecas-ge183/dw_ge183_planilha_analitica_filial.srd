table(column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo_produto dbname="grupo_produto.de_grupo_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo_produto dbname="subgrupo_produto.de_subgrupo_produto" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(60) update=yes updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_preco_venda_atual dbname="vl_preco_venda_atual" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_atual dbname="produto_geral.pc_desconto_atual" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_desconto_atual dbname="produto_geral.id_tipo_desconto_atual" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_sos dbname="pc_desconto_sos" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_medio dbname="vl_custo_medio" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_gerencial dbname="vl_custo_gerencial" )
 column=(type=long updatewhereclause=yes name=qt_saldo_filial dbname="qt_saldo_filial" )
 column=(type=long updatewhereclause=yes name=qt_venda_mes dbname="qt_venda_mes" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="produto_geral.cd_fornecedor_usual" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_pis_cofins dbname="produto_geral.id_situacao_pis_cofins" )
 column=(type=char(1) updatewhereclause=yes name=cd_tributacao_icms dbname="produto_geral.cd_tributacao_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="produto_geral.pc_icms" )
 column=(type=long updatewhereclause=yes name=cd_tipo_icms dbname="produto_geral.cd_tipo_icms" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_icms dbname="tipo_icms.de_tipo_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_praticado dbname="vl_venda_praticado" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_praticado dbname="vl_custo_praticado" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_comissao dbname="vl_comissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_imposto dbname="vl_imposto" )
 retrieve="select pg.id_situacao,
       gp.de_grupo_produto,
       sp.de_subgrupo_produto,
       pg.cd_produto,
       pg.de_produto,
       pg.de_apresentacao_venda,
       round(pg.vl_preco_venda_atual / pg.vl_fator_conversao, 2) vl_preco_venda_atual,
       pg.pc_desconto_atual,
       pg.id_tipo_desconto_atual,
       0.00 pc_desconto_sos,
       0.00 vl_custo_medio,
		 0.00 vl_custo_gerencial,
       0 qt_saldo_filial,
       0 qt_venda_mes,
       pg.cd_fornecedor_usual,
       fo.nm_razao_social,
       pg.id_situacao_pis_cofins,
       pg.cd_tributacao_icms,
       pg.pc_imposto pc_icms,
       pg.cd_tipo_icms,
       ti.de_tipo_icms,
		 0.00 vl_venda_praticado,
		 0.00 vl_custo_praticado,
       0.00 vl_comissao,
       0.00 vl_imposto
from produto_geral pg,
     produto_central pc,
     grupo_produto gp,
     subgrupo_produto sp,
     fornecedor fo,
     tipo_icms ti,
     parametro pa
where pc.cd_produto          = pg.cd_produto
  and gp.cd_grupo_produto    = pg.cd_grupo_produto
  and sp.cd_grupo_produto    = pg.cd_grupo_produto
  and sp.cd_subgrupo_produto = pg.cd_subgrupo_produto
  and fo.cd_fornecedor       = pg.cd_fornecedor_usual
  and ti.cd_tipo_icms        =* pg.cd_tipo_icms"  sort="cd_produto A " )
