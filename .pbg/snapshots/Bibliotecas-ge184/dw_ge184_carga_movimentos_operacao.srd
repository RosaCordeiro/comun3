table(column=(type=char(1) updatewhereclause=yes name=id_status_sitef dbname="id_status_sitef" )
 column=(type=long updatewhereclause=yes name=cd_administradora dbname="cd_administradora" )
 column=(type=char(10) updatewhereclause=yes name=cd_estabelecimento dbname="cd_estabelecimento" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_operacao dbname="id_tipo_operacao" )
 column=(type=datetime updatewhereclause=yes name=dh_operacao dbname="dh_operacao" )
 column=(type=datetime updatewhereclause=yes name=dh_credito dbname="dh_credito" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_operacao dbname="vl_operacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_parcela dbname="vl_parcela" )
 column=(type=long updatewhereclause=yes name=nr_parcela dbname="nr_parcela" )
 column=(type=long updatewhereclause=yes name=qt_parcelas dbname="qt_parcelas" )
 column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="cd_caixa" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="nr_controle_caixa" )
 column=(type=char(20) updatewhereclause=yes name=nr_nsu dbname="nr_nsu" )
 column=(type=char(6) updatewhereclause=yes name=nr_autorizacao dbname="nr_autorizacao" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_comissao dbname="vl_comissao" )
 column=(type=char(7) updatewhereclause=yes name=nr_lote dbname="nr_lote" )
 column=(type=char(1) updatewhereclause=yes name=id_conciliada dbname="id_conciliada" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_liquido dbname="vl_liquido" )
 retrieve="select coalesce(cco.id_status_sitef, '') id_status_sitef,
       cco.cd_administradora, 
       cco.cd_estabelecimento,
       cco.id_tipo_operacao,   
       cco.dh_operacao, 
       cco.dh_credito,   
       cco.vl_operacao,  
       cco.vl_parcela, 
       cco.nr_parcela,  
       cco.qt_parcelas, 
       cco.cd_caixa, 
       cco.nr_controle_caixa, 
       cco.nr_nsu,
       cco.nr_autorizacao,
       cco.nr_nf, 
       cco.cd_filial,
 	  cco.vl_comissao,
       cco.nr_lote,
	  isnull(cco.id_conciliada, 'N') id_conciliada,
       (cco.vl_parcela - cco.vl_comissao) vl_liquido    
  from cartao_comprovante_operacao  cco
 where cco.cd_administradora   = :cd_administradora
   and cco.cd_estabelecimento >= :cd_estabelecimento
   and cco.cd_estabelecimento <= :cd_estabelecimento_f 
   and cco.dh_operacao >= :dt_inicio 
   and cco.dh_operacao < :dt_termino
   and cco.id_situacao in ('A','D','T','C') 
   and isnull(cco.id_cancelado_filial,'N')  <> 'S'  " arguments=(("cd_administradora", number),("cd_estabelecimento", string),("cd_estabelecimento_f", string),("dt_inicio", date),("dt_termino", date))  sort="dh_operacao A cd_estabelecimento A nr_nsu A nr_parcela A " )
