table(column=(type=date updatewhereclause=yes name=dh_operacao dbname="dh_operacao" )
 column=(type=char(20) updatewhereclause=yes name=dia_semana dbname="dia_semana" )
 column=(type=decimal(0) updatewhereclause=yes name=vl_operacao dbname="vl_operacao" )
 retrieve="select 	case when cc.id_tipo_operacao = 'VC' then 'CR$$HEX1$$c900$$ENDHEX$$DITO' else 'D$$HEX1$$c900$$ENDHEX$$BITO' end as tipo_operacao, 
				ca.nm_administradora, 
				cast(cc.dh_operacao as date) as dh_operacao, 
				case datepart(weekday, cc.dh_operacao)
					when 1 Then 'DOMINGO'
					when 2 then 'SEGUNDA-FEIRA'
					when 3 then 'TER$$HEX1$$c700$$ENDHEX$$A-FEIRA'
					when 4 then 'QUARTA-FEIRA'
					when 5 then 'QUINTA-FEIRA'
					when 6 then 'SEXTA-FEIRA'
					when 7 then 'S$$HEX1$$c100$$ENDHEX$$BADO'
				else '' end dia_semana,
				sum(coalesce(cc.vl_parcela,0) - case when :tipo_valor = 'L' then coalesce(cc.vl_comissao,0) else 0.00 end) as vl_operacao, 
				sum(cc.vl_comissao) as vl_comissao
	  from cartao_comprovante_operacao cc (index idx_operacao_adm)
	inner join cartao_administradora ca
		on ca.cd_administradora = cc.cd_administradora
	 where cc.cd_filial   >= :filial_de
		and cc.cd_filial 	  <= :filial_ate
		and cc.dh_operacao   >= :dt_inicio
		and cc.dh_operacao   <  :dt_termino
		and cc.id_situacao in ('A','D','T','C') 
		and isnull(cc.id_cancelado_filial,'N')  <> 'S'
group by case when cc.id_tipo_operacao = 'VC' then 'CR$$HEX1$$c900$$ENDHEX$$DITO' else 'D$$HEX1$$c900$$ENDHEX$$BITO' end, 
			ca.nm_administradora, 
			cast(cc.dh_operacao as date), 
				case datepart(weekday, cc.dh_operacao)
					when 1 Then 'DOMINGO'
					when 2 then 'SEGUNDA-FEIRA'
					when 3 then 'TER$$HEX1$$c700$$ENDHEX$$A-FEIRA'
					when 4 then 'QUARTA-FEIRA'
					when 5 then 'QUINTA-FEIRA'
					when 6 then 'SEXTA-FEIRA'
					when 7 then 'S$$HEX1$$c100$$ENDHEX$$BADO'
				else '' end" arguments=(("filial_de", number),("filial_ate", number),("dt_inicio", date),("dt_termino", date),("tipo_valor", string))  sort="dh_operacao A dia_semana A " )
