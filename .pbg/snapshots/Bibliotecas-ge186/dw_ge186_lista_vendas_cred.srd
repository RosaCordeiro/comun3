 retrieve="  SELECT   ''  condicao_venda,
					0.00 Venda_1 ,         
					0.00 Venda_2 , 
					0.00 Venda_3 , 
					0.00 Venda_4 , 
					0.00 Venda_5 , 
					0.00 Venda_6 , 
					0.00 Venda_7 , 
					0.00 Venda_8 , 
					0.00 Venda_9 ,		
					0.00 Venda_10 ,
					0.00 Venda_11 ,
					0.00 Venda_12 ,
					0.00 Venda_13 ,
					0.00 Venda_14 ,
					0.00 Venda_15 ,
			          0.00 Venda_16,
				     0.00 Venda_17,
					0.00 Venda_18,
					0.00 total   ,
					'' Adm_1 , '' Adm_2 ,'' Adm_3 ,'' Adm_4 ,'' Adm_5 ,'' Adm_6 ,'' Adm_7 ,'' Adm_8 ,'' Adm_9 ,	'' Adm_10 ,'' Adm_11 ,'' Adm_12 ,'' Adm_13 ,'' Adm_14 , '' Adm_15 , 
					'' Adm_16 , '' Adm_17 ,'' Adm_18 ,
					'' Adm_total            
    FROM cartao_comprovante_operacao c
   WHERE c.dh_credito    >= :pdt_inicio
     and c.dh_credito    <  :pdt_final 
     and c.cd_filial      >= :lvl_filial
     and c.cd_filial      <= :lvl_filial_ate
     and c.qt_parcelas    >= :lvl_qt_parc_1
     and c.qt_parcelas    <  :lvl_qt_parc_2 
group by c.qt_parcelas
 
 " arguments=(("lvl_filial", number),("lvl_filial_ate", number),("pdt_inicio", date),("pdt_final", date),("lvl_qt_parc_1", number),("lvl_qt_parc_2", number)) )
