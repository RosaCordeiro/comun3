 retrieve="  SELECT 	cd_conta_fluxo_caixa,   
				cd_canal_venda,
				dh_inicio,   
				pc_comissao_debito,   
				pc_comissao_credito_avista,   
				pc_comissao_credito_parcelado ,
				pc_comissao_credito_2, 
				pc_comissao_credito_3,
				pc_comissao_credito_4, 
				pc_comissao_credito_5, 
				pc_comissao_credito_6,
				pc_comissao_fundo_emerg,
				id_tipo_taxa
    FROM conta_fluxo_taxa_cartao   
Where cd_conta_fluxo_caixa = :pl_conta_fluxo
" update="conta_fluxo_taxa_cartao" updatewhere=1 updatekeyinplace=no arguments=(("pl_conta_fluxo", number))  sort="dh_inicio A " )
