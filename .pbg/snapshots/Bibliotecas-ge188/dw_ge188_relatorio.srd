table(column=(type=long updatewhereclause=yes key=yes name=cd_tarefa dbname="tarefa.cd_tarefa" dbalias=".cd_tarefa" )
 column=(type=char(50) updatewhereclause=yes name=de_tarefa dbname="tarefa.de_tarefa" dbalias=".de_tarefa" )
 column=(type=char(2) updatewhereclause=yes name=cd_sistema dbname="tarefa.cd_sistema" dbalias=".cd_sistema" )
 column=(type=datetime updatewhereclause=yes name=dh_ultima_exec dbname="tarefa.dh_ultima_exec" dbalias=".dh_ultima_exec" )
 column=(type=datetime updatewhereclause=yes name=dh_prox_exec dbname="tarefa.dh_prox_exec" dbalias=".dh_prox_exec" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="tarefa.id_situacao" dbalias=".id_situacao" values="ATIVO	A/INATIVO	I/" )
 column=(type=long updatewhereclause=yes name=nr_tolerancia dbname="tarefa.nr_tolerancia" dbalias=".nr_tolerancia" )
 column=(type=char(1) updatewhereclause=yes name=id_envia_sms dbname="tarefa.id_envia_sms" dbalias=".id_envia_sms" )
 column=(type=char(50) updatewhereclause=yes name=de_telefone_sms dbname="tarefa.de_telefone_sms" dbalias=".de_telefone_sms" )
 column=(type=long updatewhereclause=yes name=cd_mensagem_email dbname="tarefa.cd_mensagem_email" dbalias=".cd_mensagem_email" )
 column=(type=char(50) updatewhereclause=yes name=de_observacao dbname="tarefa.de_observacao" dbalias=".de_observacao" )
 column=(type=datetime updatewhereclause=yes name=dh_limite dbname="dh_limite" )
 column=(type=char(8) updatewhereclause=yes name=status dbname="status" )
 retrieve="  SELECT cd_tarefa,   
			de_tarefa,   
			cd_sistema,   
			dh_ultima_exec,   
			dh_prox_exec,   
			id_situacao,
			nr_tolerancia,
			id_envia_sms,
			de_telefone_sms,
			cd_mensagem_email,
			de_observacao,
			case when coalesce(nr_tolerancia,0) > 0 then dateadd(ss,nr_tolerancia, case when (dh_ultima_exec is null) or (dh_ultima_exec < coalesce(dh_prox_exec,dh_ultima_exec)) then coalesce(dh_prox_exec,coalesce(dh_ultima_exec,dh_cadastro)) else coalesce(dh_ultima_exec,dh_cadastro) end) else cast(null as datetime) end as dh_limite,
			case when coalesce(nr_tolerancia,0) > 0 then 
				case when dateadd(ss,nr_tolerancia, case when (dh_ultima_exec is null) or (dh_ultima_exec < coalesce(dh_prox_exec,dh_ultima_exec)) then coalesce(dh_prox_exec,coalesce(dh_ultima_exec,dh_cadastro)) else coalesce(dh_ultima_exec,dh_cadastro) end) > getDate() then 'OK' 
				else 
					case when dateadd(ss,nr_tolerancia, coalesce(dh_ultima_exec,dh_cadastro)) > getdate() then 'OK' 
					else 'PROBLEMA' end 
				end 
			else '' end as status
    FROM tarefa   
" update="tarefa" updatewhere=0 updatekeyinplace=no  sort="dh_limite A " )
