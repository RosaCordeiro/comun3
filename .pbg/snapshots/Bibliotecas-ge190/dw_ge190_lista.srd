table(column=(type=char(9) updatewhereclause=yes key=yes name=cd_distribuidora dbname="distribuidora_uf.cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=nm_unidade_federacao dbname="unidade_federacao.nm_unidade_federacao" )
 column=(type=char(2) updatewhereclause=yes key=yes name=cd_unidade_federacao dbname="distribuidora_uf.cd_unidade_federacao" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_homologando_pedido dbname="distribuidora_uf.id_homologando_pedido" values="PEDIDO ELETR$$HEX1$$d400$$ENDHEX$$NICO EM HOMOLOGA$$HEX2$$c700c300$$ENDHEX$$O	S/FATURAMENTO LIBERADO	N/" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_minimo_pedido dbname="distribuidora_uf.vl_minimo_pedido" )
 column=(type=long update=yes updatewhereclause=yes name=nr_prazo_entrega dbname="distribuidora_uf.nr_prazo_entrega" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_horario_corte dbname="distribuidora_uf.dh_horario_corte" )
 retrieve="Select	d.cd_distribuidora,
		f.nm_fantasia,
		u.nm_unidade_federacao,
		d.cd_unidade_federacao,
		d.id_homologando_pedido,
		d.vl_minimo_pedido,
		d.nr_prazo_entrega,
		d.dh_horario_corte
From fornecedor As f
	Inner Join distribuidora_uf As d
		On d.cd_distribuidora = f.cd_fornecedor
	Inner Join unidade_federacao As u
		On u.cd_unidade_federacao = d.cd_unidade_federacao
Where f.id_distribuidora = 'S'
	And f.cd_fornecedor <> '053404705'" update="distribuidora_uf" updatewhere=0 updatekeyinplace=no  sort="cd_unidade_federacao A nm_fantasia A " )
