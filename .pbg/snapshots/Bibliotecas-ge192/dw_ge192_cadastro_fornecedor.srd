table(column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="fornecedor.cd_filial" )
 column=(type=char(9) update=yes updatewhereclause=yes key=yes name=cd_fornecedor dbname="fornecedor.cd_fornecedor" )
 column=(type=long update=yes updatewhereclause=yes name=cd_cidade dbname="fornecedor.cd_cidade" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_fisica_juridica dbname="fornecedor.id_fisica_juridica" initial="J" values="F$$HEX1$$cd00$$ENDHEX$$SICA	F/JUR$$HEX1$$cd00$$ENDHEX$$DICA	J/" )
 column=(type=char(14) update=yes updatewhereclause=yes name=nr_cgc dbname="fornecedor.nr_cgc" )
 column=(type=char(11) update=yes updatewhereclause=yes name=nr_cpf dbname="fornecedor.nr_cpf" )
 column=(type=char(15) update=yes updatewhereclause=yes name=nr_inscricao_estadual dbname="fornecedor.nr_inscricao_estadual" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_endereco dbname="fornecedor.de_endereco" )
 column=(type=char(20) update=yes updatewhereclause=yes name=de_bairro dbname="fornecedor.de_bairro" )
 column=(type=char(8) update=yes updatewhereclause=yes name=nr_cep dbname="fornecedor.nr_cep" )
 column=(type=char(10) update=yes updatewhereclause=yes name=nr_telefone dbname="fornecedor.nr_telefone" )
 column=(type=char(10) update=yes updatewhereclause=yes name=nr_fax dbname="fornecedor.nr_fax" )
 column=(type=char(3) update=yes updatewhereclause=yes name=nr_ddd_telefone dbname="fornecedor.nr_ddd_telefone" )
 column=(type=char(3) update=yes updatewhereclause=yes name=nr_ddd_fax dbname="fornecedor.nr_ddd_fax" )
 column=(type=char(3) update=yes updatewhereclause=yes name=nr_ddd_fax_compras dbname="fornecedor.nr_ddd_fax_compras" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto_usual dbname="fornecedor.pc_desconto_usual" initial="0.00" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_contato dbname="fornecedor.nm_contato" )
 column=(type=char(3) update=yes updatewhereclause=yes name=nr_ddd_telefone_compras dbname="fornecedor.nr_ddd_telefone_compras" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_telefone_compras dbname="fornecedor.nr_telefone_compras" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_fax_compras dbname="fornecedor.nr_fax_compras" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_fornecedor_transportadora dbname="fornecedor.id_fornecedor_transportadora" initial="F" values="FORNECEDOR	F/TRANSPORTADORA	T/" )
 column=(type=char(60) update=yes updatewhereclause=yes name=de_email dbname="fornecedor.de_email" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_recebe_email_xml dbname="fornecedor.id_recebe_email_xml" values="Enviar XML por E-mail?	S/Enviar XML por E-mail?	N" )
 column=(type=char(100) update=yes updatewhereclause=yes name=de_endereco_email_envio_xml dbname="fornecedor.de_endereco_email_envio_xml" )
 column=(type=long update=yes updatewhereclause=yes name=cd_condicao_pagamento dbname="fornecedor.cd_condicao_pagamento" )
 column=(type=char(40) updatewhereclause=yes name=nm_localiza dbname="nm_localiza" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="nm_cidade" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade_anterior dbname="nm_cidade_anterior" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_regime_especial dbname="fornecedor.id_regime_especial" initial="N" values="Utiliza Regime Especial de ICMS?	S/Utiliza Regime Especial de ICMS?	N" )
 column=(type=char(40) updatewhereclause=yes name=de_condicao_pagamento dbname="de_condicao_pagamento" )
 column=(type=char(40) updatewhereclause=yes name=de_condicao_pagamento_ant dbname="de_condicao_pagamento_ant" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="id_situacao" initial="A" values="ATIVO	A/INATIVO	I/" )
 column=(type=char(40) updatewhereclause=yes name=nm_comprador dbname="nm_comprador" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_comprador dbname="fornecedor.nr_matricula_comprador" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_regime_tributario dbname="fornecedor.id_regime_tributario" initial="2" values="SIMPLES	1/OUTROS	2/" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cd_unidade_federacao" )
 column=(type=long update=yes updatewhereclause=yes name=nr_endereco dbname="fornecedor.nr_endereco" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_considera_ipi_pedido dbname="fornecedor.id_considera_ipi_pedido" values="Considera o IPI no Pedido de Compra?	S/Considera o IPI no Pedido de Compra?	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_utiliza_agendamento_entrega dbname="fornecedor.id_utiliza_agendamento_entrega" initial="N" values="Utiliza Agendamento de Entrega?	S/Utiliza Agendamento de Entrega?	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_pedido_edi dbname="id_pedido_edi" initial="Z" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_atividade_economica dbname="fornecedor.id_atividade_economica" values="	/SIM	1/N$$HEX1$$c300$$ENDHEX$$O	0/" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inclusao dbname="fornecedor.dh_inclusao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_atualizacao dbname="fornecedor.dh_atualizacao" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_atualizacao dbname="fornecedor.nr_matricula_atualizacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="nm_usuario" )
 column=(type=char(20) updatewhereclause=yes name=cd_fornecedor_sap dbname="fornecedor.cd_fornecedor_sap" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_minimo_pedido dbname="fornecedor.vl_minimo_pedido" initial="0" )
 retrieve="  SELECT cd_filial,   
         cd_fornecedor,   
         cd_cidade,
         nm_fantasia,   
         nm_razao_social,   
         id_fisica_juridica,   
         nr_cgc,   
         nr_cpf,   
         nr_inscricao_estadual,   
         de_endereco,   
         de_bairro,   
         nr_cep,   
         nr_telefone,   
         nr_fax,   
         nr_ddd_telefone,   
         nr_ddd_fax,   
         nr_ddd_fax_compras,   
         pc_desconto_usual,   
         nm_contato,   
         nr_ddd_telefone_compras,   
         nr_telefone_compras,   
         nr_fax_compras,   
         id_fornecedor_transportadora,
         de_email,
		id_recebe_email_xml,
		de_endereco_email_envio_xml,
		cd_condicao_pagamento,
         space(40) nm_localiza,
         space(40) nm_cidade,
		space(40) nm_cidade_anterior,
         id_regime_especial,
		 space(40) de_condicao_pagamento,
		space(40) de_condicao_pagamento_ant,
		 isnull(id_situacao, 'A') as id_situacao,
		space(40)  nm_comprador,
		nr_matricula_comprador,
		id_regime_tributario,
		space(2) cd_unidade_federacao,
		nr_endereco,
		id_considera_ipi_pedido,
		id_utiliza_agendamento_entrega,
		Coalesce(id_pedido_edi, 'Z') As id_pedido_edi,
		id_atividade_economica,
		dh_inclusao,
		dh_atualizacao,
		nr_matricula_atualizacao,
		space(40) nm_usuario, 
		cd_fornecedor_sap,
		vl_minimo_pedido
    FROM fornecedor
   WHERE cd_fornecedor = :cd_fornecedor" update="fornecedor" updatewhere=0 updatekeyinplace=no arguments=(("cd_fornecedor", string)) )
