table(column=(type=char(9) update=yes updatewhereclause=yes key=yes name=cd_fornecedor dbname="fornecedor_contato.cd_fornecedor" dbalias=".cd_fornecedor" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_contato dbname="fornecedor_contato.nr_contato" dbalias=".nr_contato" )
