 column=(type=char(60) update=yes updatewhereclause=yes name=nm_contato dbname="fornecedor_contato.nm_contato" dbalias=".nm_contato" )
 column=(type=char(3) update=yes updatewhereclause=yes name=nr_ddd_telefone dbname="fornecedor_contato.nr_ddd_telefone" dbalias=".nr_ddd_telefone" )
 column=(type=char(10) update=yes updatewhereclause=yes name=nr_telefone dbname="fornecedor_contato.nr_telefone" dbalias=".nr_telefone" )
 column=(type=char(60) update=yes updatewhereclause=yes name=de_email dbname="fornecedor_contato.de_email" dbalias=".de_email" )
 column=(type=long update=yes updatewhereclause=yes name=nr_divisao_fornecedor dbname="fornecedor_contato.nr_divisao_fornecedor" dbalias=".nr_divisao_fornecedor" )
 retrieve="select cd_fornecedor,
		nr_contato,
		cd_contato,
		nm_contato,
		nr_ddd_telefone,
		nr_telefone,
		de_email,
		nr_divisao_fornecedor
from fornecedor_contato
where cd_fornecedor = :cd_fornecedor	
and nr_divisao_fornecedor = :nr_divisao
and cd_contato in (select cd_contato from contato_fornecedor
							 where coalesce(id_exclusivo_pedido_eletronico, 'N') = 'N')
order by cd_contato" update="fornecedor_contato" updatewhere=1 updatekeyinplace=no arguments=(("cd_fornecedor", string),("nr_divisao", number)) )
