table(column=(type=char(40) updatewhereclause=yes name=nm_operadora dbname="operadora_telefonia.nm_operadora" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_operadora dbname="operadora_telefonia.cd_operadora" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inicio dbname="recarga_receita.dh_inicio" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_receita dbname="recarga_receita.pc_receita" )
 column=(type=char(1) updatewhereclause=yes name=id_altera dbname="id_altera" )
 column=(type=char(2) update=yes updatewhereclause=yes name=id_tipo_recarga dbname="recarga_receita.id_tipo_recarga" values="REDE	1/E-PAY	2/" )
 retrieve="  SELECT o.nm_operadora,   
         	o.cd_operadora,   
         	r.dh_inicio as dh_inicio,
         	r.pc_receita,
			case when r.pc_receita is null then 'S' else case when r.dh_inicio >=GetDate() then 'S' else 'N' end end as id_altera,
			r.id_tipo_recarga as id_tipo_recarga
    FROM operadora_telefonia o
Inner Join recarga_receita r
	on r.cd_operadora = o.cd_operadora
Where r.dh_inicio =  :dt_inicio
" update="recarga_receita" updatewhere=0 updatekeyinplace=no arguments=(("dt_inicio", date))  sort="id_tipo_recarga A cd_operadora A " )
