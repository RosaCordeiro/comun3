table(column=(type=long updatewhereclause=yes name=cd_operadora dbname="recarga_receita.cd_operadora" )
 column=(type=char(40) updatewhereclause=yes name=nm_operadora dbname="operadora_telefonia.nm_operadora" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="recarga_receita.dh_inicio" )
 column=(type=date updatewhereclause=yes name=dh_termino dbname="dh_termino" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_receita dbname="recarga_receita.pc_receita" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_recarga dbname="recarga_receita.id_tipo_recarga" values="REDE	1/E-PAY	2/" )
 retrieve="select r.cd_operadora, 
		t.nm_operadora, 
		r.dh_inicio, 
		coalesce((	select dateadd(dd,-1, min(r1.dh_inicio)) as dh_termino
						From recarga_receita r1
						Where r1.dh_inicio > r.dh_inicio and r1.cd_operadora = r.cd_operadora),cast('2999/12/31' as date)) as dh_termino,
		r.pc_receita,
		r.id_tipo_recarga
from recarga_receita r
inner join operadora_telefonia t
	on t.cd_operadora = r.cd_operadora
Where t.cd_operadora = r.cd_operadora"  sort="dh_inicio D id_tipo_recarga A cd_operadora A " )
