table(column=(type=long updatewhereclause=yes name=cd_produto dbname="nf_compra_pendente_produto.cd_produto" dbalias="p.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_saldo_pend dbname="qt_saldo_pend" )
 retrieve="select p.cd_produto, sum(qt_faturada) as qt_saldo_pend 
from nf_compra_pendente n
inner join nf_compra_pendente_produto p
	on p.cd_filial = n.cd_filial
	and p.nr_nf		= n.nr_nf
	and p.cd_fornecedor = n.cd_fornecedor
	and p.de_especie		= n.de_especie
	and p.de_serie		= n.de_serie
where n.cd_filial = :cd_filial
group by p.cd_produto" arguments=(("cd_filial", number)) )
