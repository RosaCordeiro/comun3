table(column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="vw_classificacao_produto.de_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo dbname="vw_classificacao_produto.de_subgrupo" )
 column=(type=char(40) updatewhereclause=yes name=de_categoria dbname="vw_classificacao_produto.de_categoria" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="vw_classificacao_produto.de_subcategoria" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="resumo_reposicao_estoque.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=char(8) updatewhereclause=yes name=situacao dbname="SITUACAO" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=char(7) updatewhereclause=yes name=tipo_reposicao dbname="TIPO_REPOSICAO" )
 column=(type=char(1) updatewhereclause=yes name=curva dbname="resumo_reposicao_estoque.CURVA" )
 column=(type=char(3) updatewhereclause=yes name=id_farm_popular dbname="id_farm_popular" )
 column=(type=char(3) updatewhereclause=yes name=id_gratis_farm_popular dbname="id_gratis_farm_popular" )
 column=(type=char(3) updatewhereclause=yes name=id_psico dbname="id_psico" )
 column=(type=char(3) updatewhereclause=yes name=id_antibiotico dbname="id_antibiotico" )
 column=(type=char(3) updatewhereclause=yes name=id_pbm dbname="id_pbm" )
 column=(type=char(40) updatewhereclause=yes name=nm_comprador dbname="usuario.nm_comprador" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="resumo_reposicao_estoque.qt_estoque_base" )
 column=(type=char(40) updatewhereclause=yes name=nm_resp_alteracao dbname="usuario.nm_resp_alteracao" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao dbname="resumo_reposicao_estoque.dh_alteracao" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_bloqueio dbname="resumo_reposicao_estoque.dh_termino_bloqueio" )
 column=(type=long updatewhereclause=yes name=qt_venda dbname="qt_venda" )
 column=(type=long updatewhereclause=yes name=qt_saldo_filial dbname="saldo_produto.qt_saldo_filial" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo dbname="qt_estoque_minimo" )
 column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="cd_promocao_sos" )
 column=(type=long updatewhereclause=yes name=qt_saldo_pend dbname="qt_saldo_pend" )
 column=(type=long updatewhereclause=yes name=qt_saldo_matriz dbname="qt_saldo_matriz" )
 column=(type=datetime updatewhereclause=yes name=qt_ultima_entrada dbname="qt_ultima_entrada" )
 column=(type=char(3) updatewhereclause=yes name=id_atendido_distribuidora dbname="id_atendido_distribuidora" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo dbname="saldo_produto.vl_custo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_estoque_filial dbname="vl_estoque_filial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_estoque_base dbname="vl_estoque_base" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_estoque_transito dbname="vl_estoque_transito" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda dbname="vl_venda" )
 retrieve="select 	v.de_grupo,
			v.de_subgrupo,
			v.de_categoria,
			v.de_subcategoria,
			r.cd_produto,
			g.de_produto + ' : ' + g.de_apresentacao_estoque as de_produto,
			fo.nm_razao_social,
			(CASE g.id_situacao
				WHEN  'A' THEN 'ATIVO'
				WHEN 'I' THEN 'INATIVO'
				WHEN 'P' THEN 'PENDENTE'
				ELSE g.id_situacao
			END) as SITUACAO,
			g.vl_fator_conversao, 
         	(CASE WHEN r.id_tipo_reposicao = 'E' THEN 'ESTAVEL' ELSE 'SAZONAL' END) AS TIPO_REPOSICAO,  
         	r.cd_classe_reposicao CURVA,   
			(CASE WHEN coalesce(id_farmacia_popular, 'N') = 'S' THEN 'SIM' ELSE 'N$$HEX1$$c300$$ENDHEX$$O' END) id_farm_popular,
			(CASE WHEN coalesce(id_gratis_farm_popular, 'N') = 'S' THEN 'SIM' ELSE 'N$$HEX1$$c300$$ENDHEX$$O' END) id_gratis_farm_popular,
	    		(Case when g.cd_grupo_psico is not null and substring(g.cd_grupo_psico,1,1) <> 'W' Then 'SIM' else 'N$$HEX1$$c300$$ENDHEX$$O' END) as id_psico,
			(Case when g.cd_grupo_psico is not null and substring(g.cd_grupo_psico,1,1) = 'W' Then 'SIM' else 'N$$HEX1$$c300$$ENDHEX$$O' END) as id_antibiotico,
			(CASE WHEN (select count(*) from pbm_produto where cd_produto = r.cd_produto) > 0 THEN 'SIM' ELSE 'N$$HEX1$$c300$$ENDHEX$$O' END) id_pbm,
			u.nm_usuario nm_comprador,
         	r.qt_estoque_base,   
         	ua.nm_usuario nm_resp_alteracao,
			r.dh_alteracao,
         	r.dh_termino_bloqueio,
			0 qt_venda,
			s.qt_saldo_final as qt_saldo_filial,
			0 as qt_estoque_minimo,
			0 as cd_promocao_sos,
			0 qt_saldo_pend,
			(select qt_saldo_final from saldo_produto where cd_filial = 534  and dh_saldo = :dt_saldo and cd_produto = r.cd_produto) as qt_saldo_matriz,
			(select max(dh_resumo) from resumo_movto_estq_prd
			  where dh_resumo >= (select dateadd(day, -365, dh_movimentacao) from parametro where id_parametro = '1')
			  and cd_filial = r.cd_filial
			  and cd_produto = r.cd_produto
			  and (qt_compra > 0 or qt_transf_entrada > 0)) as qt_ultima_entrada,
			(Case when (select count(*) from distribuidora_produto d
			inner join filial_distribuidora fi
				on fi.cd_distribuidora = d.cd_distribuidora
			inner join fornecedor f
				on f.cd_fornecedor = d.cd_distribuidora
			where d.cd_produto = r.cd_produto
			  and d.cd_unidade_federacao = 'SC'
			  and f.id_distribuidora = 'S'
			  and fi.cd_filial = r.cd_filial
			  and fi.id_situacao = 'A'
			and d.id_situacao = 'A') > 0 Then 'SIM' else 'N$$HEX1$$c300$$ENDHEX$$O' END) as id_atendido_distribuidora,
			s.vl_custo_medio vl_custo,
			round(s.qt_saldo_final * s.vl_custo_medio, 2) vl_estoque_filial,
			round(r.qt_estoque_base * s.vl_custo_medio, 2) vl_estoque_base,
			0.00 vl_estoque_transito,
			0.00 vl_venda
from resumo_reposicao_estoque r
inner join filial f
	on f.cd_filial = r.cd_filial
inner join cidade ci
	on ci.cd_cidade = f.cd_cidade
inner join produto_geral g 
	on g.cd_produto = r.cd_produto
inner join vw_classificacao_produto v
	on v.cd_subcategoria = g.cd_subcategoria
inner join produto_central c
	on c.cd_produto = g.cd_produto
inner join saldo_produto s
	on s.cd_produto = r.cd_produto
	and s.cd_filial	= r.cd_filial
inner join fornecedor fo
	on fo.cd_fornecedor = g.cd_fornecedor_usual
left outer join usuario u
	on u.nr_matricula = c.nr_matricula_comprador
left outer join usuario ua
	on ua.nr_matricula =  r.nr_matricula_alteracao
where r.cd_filial = :cd_filial
  and r.qt_estoque_base > 0
  and s.dh_saldo = :dt_saldo
  and substring(g.cd_subcategoria,1,1) <> '5'" arguments=(("cd_filial", number),("dt_saldo", date))  sort="de_grupo A de_subgrupo A de_categoria A de_subcategoria A de_produto A " )
