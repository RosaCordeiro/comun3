table(column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_compra_pendente.nr_nf" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_compra_pendente.dh_emissao" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 retrieve="select n.nr_nf,
		f.nm_razao_social,
		n.dh_emissao,
		sum(qt_faturada) as qt_faturada
from nf_compra_pendente n
inner join nf_compra_pendente_produto p
	on p.cd_filial = n.cd_filial
	and p.nr_nf		= n.nr_nf
	and p.cd_fornecedor = n.cd_fornecedor
	and p.de_especie		= n.de_especie
	and p.de_serie		= n.de_serie
inner join fornecedor f
	on f.cd_fornecedor = n.cd_fornecedor
where n.cd_filial = :cd_filial
and p.cd_produto = :cd_produto
group by n.nr_nf, f.nm_razao_social, n.dh_emissao
order by n.nr_nf" arguments=(("cd_filial", number),("cd_produto", number))  sort="nr_nf A nm_razao_social A dh_emissao A qt_faturada A " )
