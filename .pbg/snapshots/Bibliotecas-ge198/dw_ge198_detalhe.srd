table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_empurrado_produto.cd_filial" dbalias="p.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_pedido_empurrado dbname="pedido_empurrado_produto.nr_pedido_empurrado" dbalias="p.nr_pedido_empurrado" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_empurrado_produto.cd_produto" dbalias="p.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="g.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="g.de_apresentacao_venda" )
 column=(type=long updatewhereclause=yes name=qt_empurrada dbname="pedido_empurrado_produto.qt_empurrada" dbalias="p.qt_empurrada" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="pedido_empurrado_produto.qt_faturada" dbalias="p.qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_aprovada dbname="qt_aprovada" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="pedido_empurrado_produto.id_situacao" dbalias="p.id_situacao" values="COLOCADO	C/ATENDIDO	A/CANCELADO	X/REQUER APROV.	B/" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_aprovacao dbname="nm_usuario_aprovacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_cancelamento dbname="usuario.nm_usuario_cancelamento" dbalias="ui.nm_usuario_cancelamento" )
 column=(type=char(100) updatewhereclause=yes name=de_motivo dbname="pedido_empurrado_motivo.de_motivo" dbalias="m.de_motivo" )
 retrieve="select p.cd_filial,   
       p.nr_pedido_empurrado,   
       p.cd_produto,   
       g.de_produto,   
       g.de_apresentacao_venda,   
       p.qt_empurrada,   
       p.qt_faturada,   
       coalesce(p.qt_aprovada, 0) as qt_aprovada,
       p.id_situacao,  
       coalesce(u.nm_usuario,ue.nm_usuario) as nm_usuario_aprovacao,
		 ui.nm_usuario as nm_usuario_cancelamento,
       m.de_motivo_empurrado as de_motivo
from pedido_empurrado_produto p 
	inner join produto_geral g 
	 On g.cd_produto = p.cd_produto
	left join usuario u 
	 On u.nr_matricula = p.nr_matricula_inclusao
	left join usuario ui 
	 On ui.nr_matricula = p.nr_matricula_cancelamento
	left join usuario ue 
	 On ue.nr_matricula = p.nr_matricula_aprovacao
	left join pedido_empurrado_motivo m
	 On m.cd_motivo_empurrado = p.cd_motivo_empurrado
where p.cd_filial           = :filial
  	and p.nr_pedido_empurrado = :pedido
	and g.cd_produto = p.cd_produto
" arguments=(("filial", number),("pedido", number))  sort="descricao_produto A " )
