table(column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_ecommerce.nr_pedido" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_ecommerce dbname="pedido_ecommerce_auxiliar.id_rede_ecommerce" )
 column=(type=char(20) updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_ecommerce.nr_pedido_ecommerce" )
 column=(type=datetime updatewhereclause=yes name=dh_compra dbname="pedido_ecommerce.dh_compra" )
 column=(type=char(9) updatewhereclause=yes name=id_situacao dbname="pedido_ecommerce.id_situacao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_ecommerce_produto.cd_produto" )
 column=(type=char(100) updatewhereclause=yes name=de_descricao_internet dbname="produto_geral.de_descricao_internet" )
 column=(type=long updatewhereclause=yes name=qt_pedida_empurrada dbname="pedido_ecommerce_produto.qt_pedida_empurrada" )
 retrieve="select pe.nr_pedido, pa.id_rede_ecommerce, pe.nr_pedido_ecommerce, pe.dh_compra, pe.id_situacao, pp.cd_produto, pg.de_descricao_internet, pp.qt_pedida_empurrada
from pedido_ecommerce pe
	inner join pedido_ecommerce_produto pp on pp.cd_filial_ecommerce = pe.cd_filial_ecommerce and pp.nr_pedido = pe.nr_pedido 
	inner join pedido_ecommerce_auxiliar pa on pa.cd_filial_ecommerce = pe.cd_filial_ecommerce and pa.nr_pedido = pe.nr_pedido 
	inner join produto_geral pg on pg.cd_produto = pp.cd_produto
where pe.cd_filial = :pl_cd_filial
and pp.nr_pedido_empurrado = :pl_nr_pedido_empurrado" arguments=(("pl_cd_filial", number),("pl_nr_pedido_empurrado", number))  sort="dh_compra A " )
