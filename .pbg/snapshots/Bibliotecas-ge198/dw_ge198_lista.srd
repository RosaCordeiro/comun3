table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_empurrado.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_pedido_empurrado dbname="pedido_empurrado.nr_pedido_empurrado" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_empurrado.dh_emissao" )
 column=(type=char(1) updatewhereclause=yes name=id_processado dbname="pedido_empurrado.id_processado" values="	S/	N" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="pedido_empurrado.dh_inclusao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_inclusao dbname="pedido_empurrado.nr_matricula_inclusao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 retrieve="Select	p.cd_filial,
		f.nm_fantasia,
		p.nr_pedido_empurrado,
		p.dh_emissao,
		p.id_processado,
		p.dh_inclusao,
		p.nr_matricula_inclusao,
		u.nm_usuario
From pedido_empurrado As p
	Inner Join filial As f
		On f.cd_filial = p.cd_filial
	Left Outer Join usuario As u
		On u.nr_matricula = p.nr_matricula_inclusao
Where p.dh_emissao Between :inicio And :termino
	And (p.id_tipo_pedido Is Null Or p.id_tipo_pedido = 'E')" arguments=(("inicio", date),("termino", date))  sort="dh_emissao A nm_fantasia A " )
