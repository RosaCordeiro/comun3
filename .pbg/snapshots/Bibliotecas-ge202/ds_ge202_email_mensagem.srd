table(column=(type=char(100) update=yes updatewhereclause=yes name=de_email dbname="mensagem_email_sistema_usuario.de_email" dbalias="mu.de_email" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula dbname="mensagem_email_sistema_usuario.nr_matricula" dbalias="mu.nr_matricula" )
 column=(type=long update=yes updatewhereclause=yes name=cd_mensagem dbname="mensagem_email_sistema_usuario.cd_mensagem" dbalias="mu.cd_mensagem" )
 column=(type=char(30) update=yes updatewhereclause=yes name=dh_inicio_envio dbname="dh_inicio_envio" )
 column=(type=char(30) update=yes updatewhereclause=yes name=dh_termino_envio dbname="dh_termino_envio" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_envio dbname="mensagem_email_sistema_usuario.id_tipo_envio" dbalias="mu.id_tipo_envio" )
 column=(type=char(6) updatewhereclause=yes name=usuario_nr_matricula dbname="usuario.nr_matricula" dbalias="u.nr_matricula" )
 retrieve="  SELECT mu.de_email,   
         mu.nr_matricula,   
         mu.cd_mensagem,   
		dbo.tochar( mu.dh_inicio_envio, 'dd/mm/yyyy' ) AS dh_inicio_envio,
		dbo.tochar( mu.dh_termino_envio, 'dd/mm/yyyy' ) AS dh_termino_envio,
		mu.id_tipo_envio,
		u.nr_matricula
    FROM mensagem_email_sistema_usuario mu
inner join usuario u
	on u.nr_matricula = mu.nr_matricula
WHERE mu.cd_mensagem = :cd_msg
	AND coalesce(mu.dh_inicio_envio,GetDate()) <= GetDate()
	AND coalesce(mu.dh_termino_envio,GetDate()) >= GetDate()
	AND u.id_situacao <> 'I'" arguments=(("cd_msg", number))  sort="id_tipo_envio A de_email A " )
