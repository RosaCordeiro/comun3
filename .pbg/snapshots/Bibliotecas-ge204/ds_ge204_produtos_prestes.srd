table(column=(type=long updatewhereclause=yes name=filial_origem dbname="produto_preste_a_vencer.filial_origem" dbalias="ppv.filial_origem" )
 column=(type=long updatewhereclause=yes name=produto dbname="produto_preste_a_vencer.produto" dbalias="ppv.produto" )
 column=(type=long updatewhereclause=yes name=qtd_etiquetas dbname="qtd_etiquetas" )
 retrieve="SELECT
		 ppv.cd_filial_inclusao   AS filial_origem
	  , ppv.cd_produto           AS produto
	  , COUNT (*)                AS qtd_etiquetas
  FROM
		 produto_preste_a_vencer ppv
  INNER JOIN filial f
			 ON f.cd_filial            = ppv.cd_filial_inclusao
  INNER JOIN parametro_loja pl
			 ON pl.cd_filial           = f.cd_filial
  INNER JOIN cidade c
			 ON c.cd_cidade            = f.cd_cidade
  INNER JOIN (SELECT DISTINCT (cr.cd_unidade_federacao) AS uf_remanejamento
					 FROM remanejamento_filial rf
					 INNER JOIN filial fr
								ON fr.cd_filial = rf.cd_filial
					 INNER JOIN cidade cr
								ON cr.cd_cidade = fr.cd_cidade
					WHERE rf.cd_remanejamento = :al_cd_remanejamento) uf
			 ON uf.uf_remanejamento    = c.cd_unidade_federacao
  INNER JOIN produto_geral pg
			 ON pg.cd_produto          = ppv.cd_produto
  INNER JOIN usuario u
			 ON u.nr_matricula         = ppv.nr_matricula_inclusao
  INNER JOIN vw_classificacao_produto cp
			 ON cp.cd_subcategoria     = pg.cd_subcategoria
  INNER JOIN grupo g
			 ON g.cd_grupo             = cp.cd_grupo
 WHERE ppv.id_situacao                   =      'A'
   AND ppv.dh_validade                   >=     :adt_data_ini
   AND ppv.dh_validade                   <=     :adt_data_fim
   AND ppv.dh_inclusao                   >=     :adt_ini_prestes
   AND f.id_receb_remanejto              =      'S'
   AND COALESCE (f.id_sistema_novo, 'N') =      'S'
   AND pl.cd_parametro                   = 'FILIAL_REMANEJ_PRESTES'
   AND pl.vl_parametro                   = 'S'
	AND g.id_remaneja_prestes             =      'S'
   AND COALESCE (pg.id_geladeira, 'N')   =      'N'
   AND pg.vl_fator_conversao             =      1
   AND pg.cd_grupo_psico                 IS NULL
   AND ppv.id_concede_desconto = 'S'
 GROUP BY
	ppv.cd_filial_inclusao,
	ppv.cd_produto
 ORDER BY
	ppv.cd_filial_inclusao" arguments=(("adt_data_ini", date),("adt_data_fim", date),("al_cd_remanejamento", number),("adt_ini_prestes", date)) )
