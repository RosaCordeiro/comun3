table(column=(type=long updatewhereclause=yes name=remanejamento dbname="remanejamento_processamento.REMANEJAMENTO" dbalias=".REMANEJAMENTO" )
 column=(type=long updatewhereclause=yes name=filial_destino dbname="remanejamento_processamento.FILIAL_DESTINO" dbalias=".FILIAL_DESTINO" )
 column=(type=long updatewhereclause=yes name=produto dbname="remanejamento_processamento.PRODUTO" dbalias=".PRODUTO" )
 column=(type=long updatewhereclause=yes name=saldo dbname="remanejamento_processamento.SALDO" dbalias=".SALDO" )
 column=(type=char(30) updatewhereclause=yes name=ultimo_movimento dbname="ULTIMO_MOVIMENTO" )
 column=(type=long updatewhereclause=yes name=saldo_na_filial_destino dbname="remanejamento_processamento.SALDO_NA_FILIAL_DESTINO" dbalias=".SALDO_NA_FILIAL_DESTINO" )
 column=(type=char(30) updatewhereclause=yes name=media_venda dbname="MEDIA_VENDA" )
 column=(type=decimal(0) updatewhereclause=yes name=media_considerada dbname="MEDIA_CONSIDERADA" )
 retrieve="  SELECT cd_remanejamento                        AS REMANEJAMENTO,
         cd_filial                               AS FILIAL_DESTINO,
         cd_produto                              AS PRODUTO,
         qt_saldo                                AS SALDO,
         CONVERT (NVARCHAR, dh_ultimo_mvto, 121) AS ULTIMO_MOVIMENTO,
         qt_saldo_filial_destino                 AS SALDO_NA_FILIAL_DESTINO,
         CONVERT (NVARCHAR, qt_media_venda)      AS MEDIA_VENDA,
         CASE
				WHEN qt_media_venda <  1                        THEN 0
				WHEN qt_media_venda <> CEILING (qt_media_venda) THEN CEILING (qt_media_venda)
				ELSE CAST (qt_media_venda AS INTEGER)
			END                                     AS MEDIA_CONSIDERADA
    FROM remanejamento_processamento  
   WHERE cd_remanejamento = :al_cd_remanejamento    
" arguments=(("al_cd_remanejamento", number)) )
