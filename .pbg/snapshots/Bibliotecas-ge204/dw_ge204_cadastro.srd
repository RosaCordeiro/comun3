table(column=(type=char(60) updatewhereclause=yes name=localizacao dbname="localizacao" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_remanejamento dbname="remanejamento.cd_remanejamento" )
 column=(type=char(60) update=yes updatewhereclause=yes name=de_remanejamento dbname="remanejamento.de_remanejamento" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_calculo dbname="remanejamento.dh_calculo" )
 column=(type=long update=yes updatewhereclause=yes name=qt_dias_retirada dbname="remanejamento.qt_dias_retirada" initial="180" )
 column=(type=long update=yes updatewhereclause=yes name=qt_dias_remanejamento dbname="remanejamento.qt_dias_remanejamento" initial="60" )
 column=(type=long update=yes updatewhereclause=yes name=id_selecao_produto dbname="remanejamento.id_selecao_produto" )
 column=(type=long updatewhereclause=yes name=id_selecao_produto2 dbname="remanejamento.id_selecao_produto2" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_psico dbname="remanejamento.id_psico" initial="S" values="Psico? 	S/Psico? 	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_geladeira dbname="remanejamento.id_geladeira" initial="N" values="Geladeira? 	S/Geladeira? 	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_planograma dbname="remanejamento.id_planograma" initial="N" values="M$$HEX1$$ed00$$ENDHEX$$nimo Planograma?	S/M$$HEX1$$ed00$$ENDHEX$$nimo Planograma?	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_tratamento_estoque_base dbname="remanejamento.id_tratamento_estoque_base" initial="0" values="Somente produtos com estoque base zero?	0/Zera estoque base?	1/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_beauty_club dbname="remanejamento.id_beauty_club" initial="S" values="Beauty Club?	S/Beauty Club?	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_promocao_estoque_minimo dbname="remanejamento.id_promocao_estoque_minimo" initial="N" values="Produtos em promo$$HEX2$$e700e300$$ENDHEX$$o de estoque m$$HEX1$$ed00$$ENDHEX$$nimo?	S/Produtos em promo$$HEX2$$e700e300$$ENDHEX$$o de estoque m$$HEX1$$ed00$$ENDHEX$$nimo?	N" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_responsavel dbname="remanejamento.nr_matricula_responsavel" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_termino_vigencia dbname="remanejamento.dh_termino_vigencia" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_vig_ant dbname="remanejamento.dh_termino_vig_ant" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_montagem_filial dbname="remanejamento.id_montagem_filial" initial="N" values="	S/	N" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial_fechamento dbname="remanejamento.cd_filial_fechamento" )
 column=(type=char(1) updatewhereclause=yes name=id_filial_fechamento dbname="id_filial_fechamento" values="	S/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_avulso dbname="remanejamento.id_avulso" initial="N" values="Avulsos ?	S/Avulsos ?	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_remanejamento_via_arquivo dbname="id_remanejamento_via_arquivo" values="	S/	N" )
 column=(type=char(10) updatewhereclause=yes name=cd_remanejamento_sap dbname="remanejamento.cd_remanejamento_sap" )
 column=(type=char(1) updatewhereclause=yes name=cd_status_sap dbname="remanejamento.cd_status_sap" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_remanejamento_via_prestes dbname="id_remanejamento_via_prestes" initial="N" values="Prestes a Vencer	S/Prestes a Vencer	N" )
 column=(type=long updatewhereclause=yes name=nr_dias_valid_remanejto_preste dbname="nr_dias_valid_remanejto_preste" )
 retrieve="SELECT	space(60)								as localizacao,
			r.cd_remanejamento					as cd_remanejamento,
			r.de_remanejamento					as  de_remanejamento,
			r.dh_calculo								as dh_calculo,   
			r.qt_dias_retirada						as qt_dias_retirada,   
			r.qt_dias_remanejamento			as qt_dias_remanejamento,   
			r.id_selecao_produto					as id_selecao_produto,   
			r.id_selecao_produto					as id_selecao_produto2,   
			r.id_psico								as id_psico,   
			r.id_geladeira							as id_geladeira,   
			r.id_planograma						as id_planograma,   
			r.id_tratamento_estoque_base		as id_tratamento_estoque_base, 
			r.id_beauty_club						as id_beauty_club,
			r.id_promocao_estoque_minimo	as id_promocao_estoque_minimo,
			r.nr_matricula_responsavel			as nr_matricula_responsavel,
			r.dh_termino_vigencia				as dh_termino_vigencia, 
			r.dh_termino_vigencia				as dh_termino_vig_ant,
			r.id_montagem_filial, 
			r.cd_filial_fechamento,
			Case  r.cd_filial_fechamento 
					when null Then 'N'
					Else 'S'
			End as id_filial_fechamento ,
			r.id_avulso,
			coalesce(id_remanejamento_via_arquivo, 'N') as id_remanejamento_via_arquivo,
			r.cd_remanejamento_sap,
			r.cd_status_sap,
			COALESCE (r.id_remanejamento_via_prestes, 'N') AS id_remanejamento_via_prestes,
			150 AS nr_dias_valid_remanejto_preste
	FROM remanejamento as r
  WHERE r.cd_remanejamento = :codigo" update="remanejamento" updatewhere=0 updatekeyinplace=yes arguments=(("codigo", number)) )
