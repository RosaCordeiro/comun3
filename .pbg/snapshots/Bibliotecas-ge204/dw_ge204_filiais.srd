table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_remanejamento dbname="remanejamento_filial.cd_remanejamento" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="remanejamento_filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uf_agrupamento dbname="remanejamento_filial.uf_agrupamento" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_retirada dbname="remanejamento_filial.id_retirada" values="	S/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_recebe dbname="remanejamento_filial.id_recebe" initial="S" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_sistema_novo dbname="id_sistema_novo" )
 retrieve="select	rf.cd_remanejamento	as cd_remanejamento,
		rf.cd_filial				as cd_filial,
		f.nm_fantasia			as nm_fantasia,
		rf.uf_agrupamento		as uf_agrupamento,
		id_retirada,
		id_recebe,
		COALESCE (f.id_sistema_novo, 'N') AS id_sistema_novo
		
from remanejamento_filial as rf
inner join filial as f on f.cd_filial = rf.cd_filial
where rf.cd_remanejamento = :codigo
and f.id_receb_remanejto = 'S'
" update="remanejamento_filial" updatewhere=0 updatekeyinplace=no arguments=(("codigo", number))  sort="nm_fantasia A " )
