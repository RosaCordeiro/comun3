table(column=(type=long updatewhereclause=yes key=yes name=cd_filial dbname="nf_venda_poo.cd_filial" dbalias=".cd_filial" )
 column=(type=long updatewhereclause=yes key=yes name=nr_nf dbname="nf_venda_poo.nr_nf" dbalias=".nr_nf" )
 column=(type=char(3) updatewhereclause=yes key=yes name=de_especie dbname="nf_venda_poo.de_especie" dbalias=".de_especie" )
 column=(type=char(3) updatewhereclause=yes key=yes name=de_serie dbname="nf_venda_poo.de_serie" dbalias=".de_serie" )
 column=(type=char(2) updatewhereclause=yes name=cd_forma_pagamento dbname="nf_venda_poo.cd_forma_pagamento" dbalias=".cd_forma_pagamento" )
 column=(type=long updatewhereclause=yes key=yes name=nr_sequencial dbname="nf_venda_poo.nr_sequencial" dbalias=".nr_sequencial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pagamento dbname="nf_venda_poo.vl_pagamento" dbalias=".vl_pagamento" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_pagamento dbname="nf_venda_poo.id_situacao_pagamento" dbalias=".id_situacao_pagamento" )
 column=(type=char(100) updatewhereclause=yes name=de_observacao dbname="nf_venda_poo.de_observacao" dbalias=".de_observacao" )
 column=(type=datetime updatewhereclause=yes name=dh_registro_pagamento dbname="nf_venda_poo.dh_registro_pagamento" dbalias=".dh_registro_pagamento" )
 retrieve="select cd_filial,   
       nr_nf,   
       de_especie,   
       de_serie,   
       cd_forma_pagamento,   
       nr_sequencial,   
       vl_pagamento,   
       id_situacao_pagamento,   
       de_observacao,
       dh_registro_pagamento
from nf_venda_poo
where cd_filial = :pl_filial
    and nr_nf = :pl_nota
	and de_especie = :ps_especie
    and de_serie = :ps_serie
	and id_situacao_pagamento = 'P'
" update="nf_venda_poo" updatewhere=0 updatekeyinplace=no arguments=(("pl_filial", number),("pl_nota", number),("ps_especie", string),("ps_serie", string))  sort="nr_nf A " )
