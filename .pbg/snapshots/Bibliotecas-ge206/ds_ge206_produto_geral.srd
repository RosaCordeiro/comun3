table(column=(type=char(255) updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=char(255) updatewhereclause=yes name=vl_preco_venda_atual dbname="vl_preco_venda_atual" )
 column=(type=char(255) updatewhereclause=yes name=cd_grupo_psico dbname="cd_grupo_psico" )
 column=(type=char(255) updatewhereclause=yes name=de_codigo_barras dbname="de_codigo_barras" )
 column=(type=char(255) updatewhereclause=yes name=qt_saldo_final dbname="qt_saldo_final" )
 column=(type=char(255) updatewhereclause=yes name=pc_desconto_atual dbname="pc_desconto_atual" )
 retrieve="SELECT	CAST( g.cd_produto AS VARCHAR ) AS cd_produto,
			g.de_produto,   
			g.de_apresentacao_venda,   
			CAST( g.vl_preco_venda_atual AS VARCHAR ) AS vl_preco_venda_atual,
			COALESCE( g.cd_grupo_psico, '' ) AS cd_grupo_psico,
			COALESCE( b.de_codigo_barras, CAST( g.cd_produto AS VARCHAR ) ) AS de_codigo_barras,
			CAST( s.qt_saldo_final AS VARCHAR ) AS qt_saldo_final,
			CAST( g.pc_desconto_atual AS VARCHAR ) AS pc_desconto_atual
    FROM produto_geral g
			INNER JOIN produto_loja l
				ON l.cd_produto = g.cd_produto
			INNER JOIN saldo_produto s
				ON s.cd_produto = g.cd_produto
			LEFT OUTER JOIN codigo_barras_produto b
				ON b.cd_produto = g.cd_produto
WHERE dh_saldo = make_date( Cast( date_part( 'year', uf_dh_parametro() ) as integer ), Cast( date_part( 'month', uf_dh_parametro() ) as integer ), 1)
	AND l.id_situacao = 'A' OR g.id_situacao = 'P'" )
