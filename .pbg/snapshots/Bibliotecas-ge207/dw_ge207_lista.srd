table(column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="vl_custo_unitario" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo dbname="subgrupo.de_subgrupo" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="dh_cancelamento" )
 retrieve="Select	tudo.dh_movimentacao_caixa,
		tudo.cd_filial,
		f.nm_fantasia,
		tudo.cd_produto,
		g.de_produto,
		tudo.qt_faturada,
		tudo.vl_custo_unitario,
		s.de_subgrupo,
		tudo.dh_cancelamento
From (

		Select	n.dh_movimentacao_caixa,
				n.cd_filial,
				i.cd_produto,
				i.qt_faturada,
				i.vl_custo_unitario,
				n.dh_cancelamento
		From nf_almoxarifado As n
			Inner Join item_nf_almoxarifado As i
				On i.nr_nf = n.nr_nf
		Where n.dh_movimentacao_caixa Between :inicio And :termino
			and n.dh_cancelamento is null
			and n.cd_filial is not null

		union all
	
		Select			n.dh_movimentacao_caixa,
						c.cd_filial,
						i.cd_produto,
						i.qt_faturada,
						i.vl_custo_unitario,
						n.dh_cancelamento
		From nf_almoxarifado As n
			Inner Join item_nf_almoxarifado As i
				On i.nr_nf = n.nr_nf
			inner join centro_custo c 
				on c.cd_centro_custo = n.cd_centro_custo
		Where n.dh_movimentacao_caixa Between :inicio And :termino
			and n.dh_cancelamento is null
			 and n.cd_filial is null
			 and n.cd_centro_custo is not null
	
		Union All
		
		Select	n.dh_movimentacao_caixa,
				n.cd_filial_destino As cd_filial,
				i.cd_produto,
				i.qt_transferida As qt_faturada,
				i.vl_custo_unitario,
				n.dh_cancelamento
		From nf_transferencia As n
			Inner Join item_nf_transferencia As i
				On i.cd_filial_origem	= n.cd_filial_origem
			   And i.nr_nf				= n.nr_nf
			   And i.de_especie		= n.de_especie
			   And i.de_serie			= n.de_serie
		Where n.dh_movimentacao_caixa Between :inicio And :termino
		    And n.id_almoxarifado = 'S'
		    And n.cd_filial_origem = 534
			and n.dh_cancelamento is null
	)
As tudo
	Inner Join filial As f
		On f.cd_filial = tudo.cd_filial
	Inner Join produto_geral as g
		On g.cd_produto = tudo.cd_produto
	Inner Join vw_classificacao_produto As v
		On v.cd_subcategoria = g.cd_subcategoria
	Inner Join subgrupo As s
		On s.cd_subgrupo = v.cd_subgrupo
Where f.cd_filial > 0" arguments=(("inicio", date),("termino", date))  sort="de_subgrupo A de_produto A " )
