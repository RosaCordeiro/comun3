table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_pbm dbname="pbm.cd_pbm" )
 column=(type=char(255) update=yes updatewhereclause=yes name=nm_pbm dbname="pbm.nm_pbm" )
 column=(type=long update=yes updatewhereclause=yes name=cd_convenio dbname="pbm.cd_convenio" )
 column=(type=char(255) update=yes updatewhereclause=yes name=de_observacao dbname="pbm.de_observacao" )
 column=(type=char(60) updatewhereclause=yes name=nm_fantasia dbname="convenio.nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo dbname="pbm.id_tipo" )
 retrieve="  SELECT p.cd_pbm,   
			p.nm_pbm,   
			p.cd_convenio,
			p.de_observacao,
			c.nm_fantasia as nm_fantasia,
			p.id_tipo
    FROM pbm p
Left Outer Join convenio c
	On c.cd_convenio = p.cd_convenio" update="pbm" updatewhere=1 updatekeyinplace=yes  sort="cd_pbm A " )
