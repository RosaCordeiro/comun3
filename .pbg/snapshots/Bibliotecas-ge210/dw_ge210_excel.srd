table(column=(type=long updatewhereclause=yes name=cd_convenio dbname="convenio.cd_convenio" dbalias="c.cd_convenio" )
 column=(type=char(60) updatewhereclause=yes name=nm_convenio dbname="convenio.nm_convenio" dbalias="c.nm_convenio" )
 column=(type=long updatewhereclause=yes name=cd_pbm dbname="pbm.cd_pbm" dbalias="p.cd_pbm" )
 column=(type=char(255) updatewhereclause=yes name=nm_pbm dbname="pbm.nm_pbm" dbalias="p.nm_pbm" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_reposicao dbname="pbm.id_tipo_reposicao" dbalias="p.id_tipo_reposicao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pbm_produto.cd_produto" dbalias="pp.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_preco_fixo dbname="pbm_produto.id_preco_fixo" dbalias="pp.id_preco_fixo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_fixo dbname="pbm_produto.vl_preco_fixo" dbalias="pp.vl_preco_fixo" )
 column=(type=char(1) updatewhereclause=yes name=id_desconto dbname="pbm_produto.id_desconto" dbalias="pp.id_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pbm_produto.pc_desconto" dbalias="pp.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto dbname="pbm_produto.vl_desconto" dbalias="pp.vl_desconto" )
 column=(type=char(1) updatewhereclause=yes name=id_gratis dbname="pbm_produto.id_gratis" dbalias="pp.id_gratis" )
 column=(type=char(1) updatewhereclause=yes name=id_caixa_bonus dbname="pbm_produto.id_caixa_bonus" dbalias="pp.id_caixa_bonus" )
 column=(type=char(255) updatewhereclause=yes name=de_observacao dbname="pbm_produto.de_observacao" dbalias="pp.de_observacao" )
 retrieve=" SELECT c.cd_convenio,
		c.nm_fantasia as nm_convenio, 
		p.cd_pbm,    
         p.nm_pbm,   
		p.id_tipo_reposicao,  
         pp.cd_produto,   
		g.de_produto + ~" : ~" + g.de_apresentacao_venda as de_produto,  
         pp.id_preco_fixo,    
         pp.vl_preco_fixo,    
         pp.id_desconto,    
         pp.pc_desconto,
		pp.vl_desconto,    
         pp.id_gratis,    
         pp.id_caixa_bonus,    
         pp.de_observacao   
    FROM pbm p
INNER JOIN pbm_produto pp 
	ON pp.cd_pbm = p.cd_pbm
INNER JOIN produto_geral g    
	ON g.cd_produto = pp.cd_produto
INNER JOIN convenio c
	ON c.cd_convenio = p.cd_convenio"  sort="nm_convenio A cd_convenio A nm_pbm A de_produto A " )
