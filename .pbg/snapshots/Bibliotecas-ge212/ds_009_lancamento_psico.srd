 retrieve="  SELECT cd_filial,   
         nr_nf,   
         de_especie,   
         de_serie,   
         nr_nsr,   
         dh_prescricao,   
         id_registro,   
         nr_registro,   
         nm_paciente,   
         nr_cid,   
         de_observacao,   
         nr_matricula,   
         id_tipo_receita,   
         nr_notificacao,   
         dh_dispensacao,   
         cd_uf_registro,   
         de_endereco_paciente,   
         de_bairro_paciente,   
         nm_comprador,   
         nr_rg_comprador,   
         cd_uf_rg_comprador,   
         nr_cpf_comprador,   
         dh_exportacao,
		de_orgao_emissor_rg_comprador  
    FROM lancamento_psico" update="lancamento_psico" updatewhere=1 updatekeyinplace=yes )
