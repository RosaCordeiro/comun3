 retrieve="  SELECT cd_banco,   
         nr_agencia,   
         nr_conta,   
         nr_cheque,   
         vl_cheque,   
         cd_filial_inclusao,   
         cd_filial_atualizacao,   
         cd_portador,   
         dh_emissao,   
         dh_vencimento,   
         pc_juros_diaria,   
         pc_multa,   
         vl_pago,   
         dh_devolucao,   
         de_motivo_devolucao,   
         dh_baixa,   
         nr_cpf_cliente,
		nr_cmc7  
    FROM cheque  " update="cheque" updatewhere=1 updatekeyinplace=yes )
