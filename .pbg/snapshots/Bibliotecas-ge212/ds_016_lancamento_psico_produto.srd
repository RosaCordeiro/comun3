 retrieve="  SELECT cd_filial,   
        nr_nf,   
        de_especie,   
        de_serie,   
        nr_nsr,   
        cd_produto,   
        qt_dispensada,   
        qt_prescrita,   
        qt_posologia,   
        id_apresentacao,   
        qt_frequencia,   
        id_frequencia,   
        id_situacao,   
        id_estorno  
