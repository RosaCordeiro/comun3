 retrieve="select cd_promocao_sos,
		cd_filial,
		cd_produto,   
		pc_desconto,
		dh_alteracao_desconto,
		pc_desconto_clube
from  promocao_sos_produto,
		parametro p
where p.id_parametro = '1'" update="promocao_sos_produto" updatewhere=1 updatekeyinplace=yes )
