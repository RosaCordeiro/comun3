 retrieve="  SELECT cd_filial,   
         nr_bloqueio,   
         id_tipo_bloqueio,   
         cd_motivo_bloqueio,   
         dh_bloqueio,   
         nr_matricula_bloqueio,   
         cd_cliente,   
         cd_clube_cliente,   
         cd_convenio,   
         cd_conveniado,   
         cd_dependente,   
         dh_liberacao,   
         nr_matricula_liberacao,
         cd_cliente_dependente,
		cd_filial_atualizacao,
		dh_atualizacao_filial
    FROM bloqueio
" update="bloqueio" updatewhere=1 updatekeyinplace=yes )
