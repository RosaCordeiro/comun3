 retrieve="select nr_titulo,   
       cd_filial,   
       id_tipo_titulo,   
       cd_portador,   
       dh_emissao,   
       dh_vencimento,   
       dh_vencimento as dh_calculo_juros,   
       vl_nominal,   
       0.00 as vl_juros_recebidos,   
       0.00 as vl_desconto_concedido,   
       vl_despesas_pagas,   
       0.00 as vl_despesas_recebidas,   
       0.00 as vl_recebido,   
       vl_nominal as vl_aberto,   
       'A' as id_situacao,   
       id_carne_bloqueto,   
       id_protesto,   
       nr_titulo_banco,   
       cd_convenio,   
       cd_cliente,   
       cd_filial_nf,   
       nr_nf,   
       de_especie,   
       de_serie,   
       nr_titulo_as400,   
       nr_remessa,   
       dh_controle_atualizacao_filial,   
       dh_venda_inicial,   
       dh_venda_final,
       cd_filial_atualizacao,
       dh_atualizacao_filial
from titulo_receber" update="titulo_receber" updatewhere=1 updatekeyinplace=yes  sort="nr_titulo A cd_filial_atualizacao A dh_atualizacao_filial A " )
