 retrieve="  SELECT p.cd_filial as cd_filial,
		 cd_cliente_drogaexpress,   
         nm_cliente,   
         de_endereco,   
         de_referencia,   
         de_bairro,   
         nr_cep,   
         nr_cgc_cpf,   
         nr_inscricao_estadual,   
         cd_conveniado,   
         cd_convenio,   
         cd_cliente,   
         id_fisica_juridica,   
         nr_telefone_principal,   
         nr_telefone_adicional,   
         nr_endereco,   
         de_complemento,   
         dh_atualizacao,   
         dh_ultima_compra  
    FROM cliente_drogaexpress,
			parametro p
 WHERE p.id_parametro = '1'" )
