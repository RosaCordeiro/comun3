 retrieve="  SELECT p.cd_filial as cd_filial_drogaexpress,
		nr_pedido_drogaexpress,   
         pd.cd_filial,   
         dh_emissao,   
         hr_emissao,   
         cd_cliente_drogaexpress,   
         vl_total_produtos,   
         pc_desconto,   
         vl_total_pedido,   
         vl_taxa_entrega,   
         vl_cobrar,   
         vl_pago,   
         id_situacao,   
         cd_tipo_venda,   
         cd_forma_pagamento,   
         nr_matricula_vendedor,   
         nr_matricula_operador,   
         de_especie_doc_fiscal,   
         cd_convenio,   
         cd_conveniado,   
         cd_dependente_conveniado,   
         cd_cliente,   
         cd_dependente_cliente,   
         cd_condicao_convenio,   
         cd_condicao_crediario,   
         dh_entrega_marcada,   
         nr_matric_alteracao_preco,   
         nr_matric_liberacao_bloqueio,   
         nr_matric_liberacao_restricao,   
         nr_matricula_cancelamento,   
         de_endereco_entrega,   
         de_referencia_entrega,   
         de_bairro_entrega,   
         nr_telefone_entrega,   
         dh_atualizacao_pedido,   
         vl_total_tabela,   
         nr_cartao_unimed,   
         pc_desconto_unimed_drogaria,   
         pc_desconto_unimed,   
         vl_base_calculo_unimed,   
         id_venda_clube,   
         cd_cliente_dependente,   
         nr_cartao_clube,   
         qt_pontos_clube,   
         nm_cartao_credito,   
         nm_cliente_cartao,   
         nm_cliente_cheque,   
         nr_cpf_cheque,   
         id_alteracao,   
         nr_pedido_ecommerce,   
         nm_cliente_entrega,   
         nr_cep_entrega,   
         nm_administradora_cartao,   
         nr_parcelas_pagamento,   
         nm_transportadora,   
         nm_cidade_entrega,   
         cd_uf_entrega,   
         vl_desconto,   
         nr_autorizacao_cartao_credito,   
         nr_comprovante_cartao_credito,   
         cd_estabelecimento_cartao_credito,   
         nr_boleto_bancario,   
         nr_vale_compra,   
         vl_vale_compra,   
         nr_telefone_contato,   
         de_complemento_endereco  
    FROM pedido_drogaexpress pd, 
			parametro p
 WHERE p.id_parametro = '1'" )
