table(column=(type=long updatewhereclause=yes name=cd_filial_lancamento dbname="parametro.cd_filial_lancamento" dbalias="p.cd_filial_lancamento" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="taxa_entrega_extra.nr_sequencial" dbalias="e.nr_sequencial" )
 column=(type=char(40) updatewhereclause=yes name=de_observacao dbname="taxa_entrega_extra.de_observacao" dbalias="e.de_observacao" )
 column=(type=char(11) updatewhereclause=yes name=nr_pedido_drogaexpress dbname="taxa_entrega_extra.nr_pedido_drogaexpress" dbalias="e.nr_pedido_drogaexpress" )
 column=(type=long updatewhereclause=yes name=cd_motivo_taxa_entrega dbname="taxa_entrega_extra.cd_motivo_taxa_entrega" dbalias="e.cd_motivo_taxa_entrega" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula dbname="taxa_entrega_extra.nr_matricula" dbalias="e.nr_matricula" )
