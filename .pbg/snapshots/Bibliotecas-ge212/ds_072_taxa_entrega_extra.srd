 column=(type=long updatewhereclause=yes name=cd_entregador dbname="taxa_entrega_extra.cd_entregador" dbalias="e.cd_entregador" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="taxa_entrega_extra.cd_filial" dbalias="e.cd_filial" )
 column=(type=long updatewhereclause=yes name=qt_taxa dbname="taxa_entrega_extra.qt_taxa" dbalias="e.qt_taxa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_taxa dbname="taxa_entrega_extra.vl_taxa" dbalias="e.vl_taxa" )
 retrieve="  SELECT p.cd_filial as cd_filial_lancamento,
		nr_sequencial,   
         de_observacao,   
         nr_pedido_drogaexpress,   
         cd_motivo_taxa_entrega,   
         nr_matricula,   
         dh_inclusao,   
         cd_entregador,   
         e.cd_filial,   
         qt_taxa,   
         vl_taxa  
    FROM taxa_entrega_extra e,
			parametro p
 WHERE p.id_parametro = '1'" )
