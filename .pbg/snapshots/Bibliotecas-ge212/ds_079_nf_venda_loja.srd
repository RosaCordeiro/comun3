         de_endereco,   
		nr_endereco,
         de_bairro,   
         nr_cep,   
         nr_telefone,   
         nr_inscricao_estadual,
         cd_cidade
    FROM nf_venda_loja
         
" update="nf_venda_loja" updatewhere=1 updatekeyinplace=yes )
