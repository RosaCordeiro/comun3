 retrieve="  SELECT f.cd_filial,
		nr_pedido,   
      	dh_emissao,
		id_situacao,
		nr_matricula_cadastramento,
		dh_cancelamento,
		nr_matricula_cancelamento,
		nr_matricula_conferencia,
		dh_faturamento
    FROM pedido_almoxarifado,
			parametro f 
	Where f.id_parametro = '1'" update="pedido_almoxarifado" updatewhere=1 updatekeyinplace=yes )
