 retrieve="  SELECT cd_filial,   
         nr_nf,   
         de_especie,   
         de_serie,   
         cd_natureza_operacao,   
         cd_produto,   
         cd_situacao_tributaria,   
         qt_vendida,   
         vl_preco_unitario,   
         pc_desconto_tabela,   
         vl_preco_praticado,   
         pc_icms,   
         pc_comissao_extra,   
         pc_comissao_normal,   
         id_alteracao_preco,   
         id_restricao_convenio,   
         id_comissionado,   
         qt_pontos_clube,
		cd_cst_origem,
		cd_cst_tributacao,
		cd_promocao_sos  
    FROM item_nf_venda" update="item_nf_venda" updatewhere=1 updatekeyinplace=yes )
