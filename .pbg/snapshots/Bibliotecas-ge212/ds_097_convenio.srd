 retrieve="SELECT 	cd_convenio,
			nm_fantasia,   
			nm_razao_social,   
			nr_cgc,   
			nr_inscricao_estadual,   
			cd_cidade,   
			de_endereco,   
			de_bairro,   
			nr_cep,   
			nr_telefone,   
			nr_fax,   
			nm_contato,   
			cd_filial_centralizadora,   
			id_ordem_compra,   
			id_paga_comissao,   
			cd_portador,   
			nr_dia_base,     
			qt_dias_vencimento,   
			nr_dias_lote,   
			pc_taxa_administracao,   
			pc_abatimento_titulo,   
			dh_atualizacao_conveniado,   
			de_comentario,   
			Coalesce( nr_ultimo_lote , 0 ) as nr_ultimo_lote,   
			pc_desconto_taxa_entrega,
			cd_convenio_edm,
			id_venda_disque_entrega,
			id_cartao_magnetico,
			id_matricula_cartao,
			id_senha_cartao,
			de_senha_padrao,
			id_clube_drogaria,
			de_endereco_email_envio_xml,
			vl_minimo_isencao_frete,
			vl_minimo_entrega,
			nr_endereco
    FROM convenio   
" update="convenio" updatewhere=0 updatekeyinplace=yes )
