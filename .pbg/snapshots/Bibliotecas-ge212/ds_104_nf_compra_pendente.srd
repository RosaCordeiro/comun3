 retrieve="select cd_filial,   
		cd_fornecedor,   
		nr_nf,   
		de_especie,   
		de_serie,   
		dh_emissao,   
		dh_movimentacao_caixa,   
		vl_bc_icms,   
		vl_icms,   
		vl_bc_icms_st,   
		vl_icms_st,  
		vl_icms_repassado,
		vl_total_produtos,   
		vl_ipi,
		vl_frete,
		vl_seguro,
		vl_outras_despesas,
		vl_desconto,
		vl_indenizacao,
		vl_total_nf,
		de_chave_acesso,
		id_bonificacao,
		coalesce( nr_pedido, 0 ) as nr_pedido,
		id_estoque_automatico,
		dh_atualizacao_estoque,
		nr_matric_atualizacao_estoque,
		'S' as id_entrada_matriz
from nf_compra_pendente" update="nf_compra_pendente" updatewhere=0 updatekeyinplace=yes )
