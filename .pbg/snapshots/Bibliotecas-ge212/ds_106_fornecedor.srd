 retrieve="  SELECT cd_fornecedor,  
			id_fornecedor_transportadora,   
			cd_filial,   
			nm_fantasia,   
			nm_razao_social,   
			id_fisica_juridica,   
			nr_cgc,   
			nr_cpf,   
			nr_inscricao_estadual,   
			cd_cidade,   
			de_endereco,   
			de_bairro,   
			nr_cep,   
			nr_ddd_telefone,   
			nr_telefone,   
			nr_ddd_fax,   
			nr_fax,   
			nr_ddd_telefone_compras,   
			nr_telefone_compras,   
			nr_ddd_fax_compras,   
			nr_fax_compras,   
			pc_desconto_usual,   
			nm_contato,   
			id_regime_especial,   
			cd_filial_atualizacao,   
			dh_atualizacao_filial,
			id_distribuidora,
			id_situacao,
			id_recebe_email_xml,
			de_endereco_email_envio_xml,
			nr_matricula_comprador,
			id_regime_tributario,
			nr_endereco
    FROM fornecedor" update="fornecedor" updatewhere=1 updatekeyinplace=yes )
