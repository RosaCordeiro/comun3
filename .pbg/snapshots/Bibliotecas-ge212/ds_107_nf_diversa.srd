 retrieve="  SELECT cd_filial_origem,   
         nr_nf,   
         de_especie,   
         de_serie,   
         cd_natureza_operacao,   
         de_natureza_operacao,   
         dh_emissao,   
         vl_bc_icms,   
         vl_icms,   
         vl_bc_icms_st,   
         vl_icms_st,   
         vl_frete,   
         vl_outras_despesas,   
         vl_seguro,   
         vl_total_produtos,   
         vl_total_nf,   
         nm_destinatario,   
         nr_cgc_cpf,   
         nr_inscricao_estadual,   
         nm_cidade,   
         nm_uf,   
         de_endereco,   
         de_bairro,   
         nr_cep,   
         nr_telefone,   
         dh_cancelamento,
		nr_nsu,
		dh_movimentacao_caixa,
		cd_cidade,
		de_email_envio_xml,
		id_patrimonio,
		cd_filial_destino,
		vl_ipi,
		nr_endereco,
		nr_nf_complementar,
		de_especie_complementar,
		de_serie_complementar,
		cd_tipo_documento,
		de_dados_adicionais,
		de_dados_adicionais_2,
		de_dados_adicionais_3,
		de_motivo_cancelamento,
		'000' as cd_filial_complementar
    FROM nf_diversa" update="nf_diversa" updatewhere=1 updatekeyinplace=yes )
