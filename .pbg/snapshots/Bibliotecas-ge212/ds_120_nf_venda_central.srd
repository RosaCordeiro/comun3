		vl_total_nf,   
		vl_pago_avista,   
		nr_matricula_vendedor,   
		cd_condicao_crediario,   
		cd_condicao_convenio,   
		cd_cliente,   
		cd_clube_cliente,   
		cd_convenio,   
		cd_conveniado,   
		cd_dependente_cliente,   
		cd_dependente_conveniado,   
		nr_matric_alteracao_preco,   
		nr_matric_liberacao_bloqueio,   
		nr_matric_liberacao_restricao,   
		dh_devolucao,   
		nr_ecf,   
		nr_coo_ecf,   
		nr_nf_anexa,   
		de_especie_anexa,   
		de_serie_anexa,   
		cd_caixa,   
		nr_controle_caixa,   
		dh_pagamento_conta,   
		cd_forma_pagamento,   
		nr_pedido_drogaexpress,
		vl_total_nf_bruto,
		vl_taxa_entrega,
		vl_total_nf_tabela,
		nr_cartao_edm,
		nr_cartao_clube,
		qt_pontos_clube,
		cd_cliente_dependente,
		id_venda_clube,
		nr_matric_liberacao_senha,
		nr_nsu,
		nr_pedido_ecommerce,
		nr_cpf_cgc,
		cd_filial_ecommerce,
		dh_cancelamento,   
		nr_matricula_cancelamento,
		de_dados_adicionais,
		vl_desconto_nf
from nf_venda" update="nf_venda" updatewhere=1 updatekeyinplace=yes  sort="cd_filial A de_especie A de_serie A nr_nf A " )
