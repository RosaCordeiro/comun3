 retrieve="select cd_filial_origem,   
		nr_nf,   
		de_especie,   
		de_serie,   
		cd_filial_destino,   
		dh_emissao,   
		dh_movimentacao_caixa,   
		vl_bc_icms,   
		vl_icms,   
		vl_bc_icms_st,   
		vl_icms_st,   
		vl_total_produtos,   
		vl_total_nf,   
		nr_matricula_operador,   
		Coalesce( id_produto_vencido , 'N' ) as id_produto_vencido,
		dh_recebimento,   
		nr_nsu,
		cd_filial_entrada,
		nr_nf_entrada,
		de_especie_entrada,
		de_serie_entrada,
		cd_distribuidora,
		nr_pedido_distribuidora,
		de_dados_adicionais,
		dh_cancelamento,   
		nr_matricula_cancelamento,
		nr_retirada_estoque
from nf_transferencia
" update="nf_transferencia" updatewhere=0 updatekeyinplace=yes )
