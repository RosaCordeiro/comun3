 column=(type=char(3) update=yes updatewhereclause=yes name=de_especie_venda dbname="cliente_caixa.de_especie" dbalias="c.de_especie" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_serie_venda dbname="cliente_caixa.de_serie" dbalias="c.de_serie" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_negociacao dbname="cliente_caixa.nr_matricula_negociacao" dbalias="c.nr_matricula_negociacao" )
 retrieve="  SELECT p.cd_filial,   
         c.nr_sequencial,   
         c.nr_ficha,   
         c.cd_cliente,   
         c.nm_cliente,   
         c.cd_dependente,   
         c.nr_matricula_vendedor,   
         c.id_situacao,   
         c.dh_movimentacao,   
         c.cd_filial,   
         c.nr_nf,
         c.de_especie,   
         c.de_serie,
		c.nr_matricula_negociacao   
    FROM cliente_caixa c,   
         parametro p  
   WHERE p.id_parametro = '1'    
" update="cliente_caixa" updatewhere=0 updatekeyinplace=yes )
