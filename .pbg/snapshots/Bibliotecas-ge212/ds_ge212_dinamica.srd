 retrieve="  SELECT cd_filial,  
			nm_fantasia,   
			nm_razao_social,   
			cd_empresa,   
			nr_cgc,   
			nr_inscricao_estadual,   
			cd_regiao,   
			cd_cidade,   
			de_endereco,   
			de_bairro,   
			nr_cep,   
			nr_ddd_telefone,   
			nr_telefone,   
			nr_ddd_fax,   
			nr_fax,   
			nr_funcionarios,   
			id_regional,   
			id_situacao,   
			cd_transportadora,   
			id_24horas,   
			id_auto_servico,   
			nr_matricula_gerente,   
			nr_matricula_subgerente,   
			nm_contato,   
			de_regiao_celos,   
			id_drugstore,   
			id_abre_domingo,
			cd_filial_centralizadora,
			cd_filial_sede_drogaexpress, 
			id_loja_polo,
			cd_portador,
			vl_maximo_caixa,
			cd_transportadora_entrada,
			cd_transportadora_saida,
			cd_filial_centro_distribuicao,
			id_centro_distribuicao,
			id_manipulacao,
			nr_endereco,
			nr_inscricao_junta_comercial,
			nr_licenca_vig_sanitaria,
			id_rede_filial
    FROM filial" update="filial" updatewhere=1 updatekeyinplace=no )
