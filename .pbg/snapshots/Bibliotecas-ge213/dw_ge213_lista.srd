table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_compra.cd_filial" dbalias="n.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_compra.nr_nf" dbalias="n.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_compra.de_especie" dbalias="n.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_compra.de_serie" dbalias="n.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_compra.dh_movimentacao_caixa" dbalias="n.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_compra.vl_total_nf" dbalias="n.vl_total_nf" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="nf_compra.nr_pedido_distribuidora" dbalias="n.nr_pedido_distribuidora" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="nf_compra.cd_fornecedor" dbalias="n.cd_fornecedor" )
 column=(type=char(1) updatewhereclause=yes name=id_excluir dbname="id_excluir" values="	S/	N" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_compra.de_chave_acesso" dbalias="n.de_chave_acesso" )
 column=(type=char(1) updatewhereclause=yes name=id_compra_pendente dbname="id_compra_pendente" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="cd_grupo_psico" )
 column=(type=datetime updatewhereclause=yes name=dh_recebido_sap dbname="nf_compra.dh_recebido_sap" dbalias="n.dh_recebido_sap" )
 retrieve="select n.cd_filial,   
       f.nm_fantasia,   
       n.nr_nf,   
       n.de_especie,   
       n.de_serie,   
       n.dh_movimentacao_caixa,   
       n.vl_total_nf,   
       n.nr_pedido_distribuidora,
       n.cd_fornecedor,
       'N' id_excluir,
	   n.de_chave_acesso,
	   'N' id_compra_pendente,
		(select max(g.cd_grupo_psico)
			from item_nf_compra i
				inner join produto_geral g
					on g.cd_produto = i.cd_produto
			where i.cd_filial = n.cd_filial
				and i.cd_fornecedor = n.cd_fornecedor
				and i.nr_nf = n.nr_nf
				and i.de_especie = n.de_especie
				and i.de_serie = n.de_serie) as cd_grupo_psico,
		n.dh_recebido_sap
from nf_compra n,   
        filial f
where f.cd_filial = n.cd_filial
  and n.cd_fornecedor = :fornecedor
  and n.dh_movimentacao_caixa between :inicio and :termino
  and f.id_situacao = 'A'

union all

select n.cd_filial,   
       f.nm_fantasia,   
       n.nr_nf,   
       n.de_especie,   
       n.de_serie,   
       n.dh_movimentacao_caixa,   
       n.vl_total_nf,   
       n.nr_pedido nr_pedido_distribuidora,
       n.cd_fornecedor,
       'S' id_excluir,
	    n.de_chave_acesso,
       'S' id_compra_pendente,
		(select max(g.cd_grupo_psico)
			from nf_compra_pendente_produto i
				inner join produto_geral g
					on g.cd_produto = i.cd_produto
			where i.cd_filial = n.cd_filial
				and i.cd_fornecedor = n.cd_fornecedor
				and i.nr_nf = n.nr_nf
				and i.de_especie = n.de_especie
				and i.de_serie = n.de_serie) as cd_grupo_psico,
		n.dh_recebido_sap
from nf_compra_pendente n,   
        filial f
where f.cd_filial = n.cd_filial
  and n.cd_fornecedor = :fornecedor
  and cast(n.dh_movimentacao_caixa as date) between :inicio and :termino
  and f.id_situacao = 'A'" arguments=(("fornecedor", string),("inicio", date),("termino", date))  sort="id_compra_pendente A cd_filial A dh_movimentacao_caixa A nr_nf A de_serie A " )
