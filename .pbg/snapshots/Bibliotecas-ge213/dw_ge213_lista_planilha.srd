 retrieve="select 0 as cd_filial,
       space(50) as nm_fantasia,
       0 as nr_nf,
       space(3) as de_especie,
       space(3) as de_serie,
       cast('1900/01/01 00:00:00' as datetime) as dh_movimentacao_caixa,
	   '' as id_permite_excluir,
	   space(200) as de_mensagem"  sort="cd_filial A dh_movimentacao_caixa A nr_nf A de_serie A " )
