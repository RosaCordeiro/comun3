table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_compra_pendente_produto.cd_filial" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="nf_compra_pendente_produto.cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_compra_pendente_produto.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_compra_pendente_produto.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_compra_pendente_produto.de_serie" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="nf_compra_pendente_produto.cd_natureza_operacao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="nf_compra_pendente_produto.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="nf_compra_pendente_produto.qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="nf_compra_pendente_produto.qt_recebida" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="produto_geral.cd_fornecedor_usual" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_filial.dh_emissao" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf dbname="vw_filial.cd_uf" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_pedido dbname="vl_custo_pedido" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_faturado_item dbname="vl_faturado_item" )
 column=(type=decimal(11) updatewhereclause=yes name=qt_faturada_item dbname="qt_faturada_item" )
 retrieve="select i.cd_filial,   
       	i.cd_fornecedor,   
       	i.nr_nf,   
       	i.de_especie,   
       	i.de_serie,   
       	i.cd_natureza_operacao,   
       	i.cd_produto,   
       	i.qt_faturada,
		i.qt_recebida,
		g.cd_fornecedor_usual,
		f.dh_emissao,
		v.cd_uf,
		g.vl_fator_conversao,
		coalesce(pf.vl_custo_unitario, 0) as vl_custo_pedido,
		sum(round(i.qt_faturada * (round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) + coalesce(i.vl_icms_st, 0)), 2)) vl_faturado_item, 
		sum(i.qt_faturada / g.vl_fator_conversao) qt_faturada_item
from nf_compra_pendente_produto   i
inner join nf_compra_pendente n on n.cd_filial		= i.cd_filial
							and n.cd_fornecedor	= i.cd_fornecedor
							and n.nr_nf				= i.nr_nf
							and n.de_especie		= i.de_especie
							and n.de_serie			= i.de_serie
inner join produto_geral g on g.cd_produto = i.cd_produto
left outer join pedido_distribuidora d on d.cd_filial = n.cd_filial and d.nr_pedido_distribuidora = n.nr_pedido
left outer join pedido_filial f on f.cd_filial		= d.cd_filial and f.nr_pedido_filial = d.nr_pedido_filial
left outer join pedido_filial_produto pf 
				on pf.cd_filial		= f.cd_filial 
				and pf.nr_pedido_filial = f.nr_pedido_filial
				and pf.cd_produto		= i.cd_produto
inner join vw_filial	v on v.cd_filial	= n.cd_filial
where i.cd_filial     = :filial
  and i.cd_fornecedor = :fornecedor
  and i.nr_nf         = :nf
  and i.de_especie    = :especie
  and i.de_serie      = :serie
group by i.cd_filial,   
       	i.cd_fornecedor,   
       	i.nr_nf,   
       	i.de_especie,   
       	i.de_serie,   
       	i.cd_natureza_operacao,   
       	i.cd_produto,   
       	i.qt_faturada,
		i.qt_recebida,
		g.cd_fornecedor_usual,
		f.dh_emissao,
		v.cd_uf,
		g.vl_fator_conversao,
		coalesce(pf.vl_custo_unitario, 0)
" arguments=(("filial", number),("fornecedor", string),("nf", number),("especie", string),("serie", string)) )
