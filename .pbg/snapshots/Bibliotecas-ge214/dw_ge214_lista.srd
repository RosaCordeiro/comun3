table(column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="promocao_sos.cd_promocao_sos" )
 column=(type=char(40) updatewhereclause=yes name=nm_promocao_sos dbname="promocao_sos.nm_promocao_sos" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_promocao dbname="promocao_sos.id_tipo_promocao" values="NORMAL	N/SOS	S/" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="promocao_sos.dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="promocao_sos.dh_termino" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="promocao_sos_produto.pc_desconto" )
 retrieve="Select	Distinct s.cd_promocao_sos,
			s.nm_promocao_sos,
			s.id_tipo_promocao,
			s.dh_inicio,
			s.dh_termino,
			p.pc_desconto
From promocao_sos As s
	Inner Join promocao_sos_produto As p
		On p.cd_promocao_sos = s.cd_promocao_sos
	Inner Join promocao_sos_filial As f
		On f.cd_promocao_sos = p.cd_promocao_sos
Where s.id_tipo_promocao In ('N', 'S')
	And p.cd_produto = :produto
	And s.dh_inicio >= :inicio" arguments=(("produto", number),("inicio", datetime))  sort="dh_inicio A dh_termino A " )
