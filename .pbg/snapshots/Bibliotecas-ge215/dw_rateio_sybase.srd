table(column=(type=long update=yes updatewhereclause=yes key=yes name=nr_folha dbname="rateio_folha_contabilidade.nr_folha" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_tipo_colaborador dbname="rateio_folha_contabilidade.cd_tipo_colaborador" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_matricula dbname="rateio_folha_contabilidade.nr_matricula" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_colaborador dbname="rateio_folha_contabilidade.nm_colaborador" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial_de dbname="rateio_folha_contabilidade.cd_filial_de" )
 column=(type=char(40) updatewhereclause=yes name=nm_filial_de dbname="nm_filial_de" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial_para dbname="rateio_folha_contabilidade.cd_filial_para" )
 column=(type=char(40) updatewhereclause=yes name=nm_filial_para dbname="nm_filial_para" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_total_proventos dbname="rateio_folha_contabilidade.vl_total_proventos" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_encargos dbname="rateio_folha_contabilidade.vl_encargos" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_pat dbname="rateio_folha_contabilidade.vl_pat" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_valetransp dbname="rateio_folha_contabilidade.vl_valetransp" )
 column=(type=char(40) updatewhereclause=yes name=nm_regional dbname="nm_regional" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_adm dbname="rateio_folha_contabilidade.id_adm" )
 column=(type=char(1) updatewhereclause=yes name=localiza dbname="localiza" )
 retrieve="select t.nr_folha, 
       t.cd_tipo_colaborador,
       t.nr_matricula,
       t.nm_colaborador,
       t.cd_filial_de,
	  Case cd_filial_de
		When 534 Then 'MATRIZ'
		When 100 Then 'ESTOQUE CENTRAL - PERINI'
		Else fd.nm_fantasia
	  End as nm_filial_de,
       t.cd_filial_para,
	  Case cd_filial_para
		When 534 Then 'MATRIZ'
		When 100 Then 'ESTOQUE CENTRAL - PERINI'
		Else fp.nm_fantasia
	  End as nm_filial_para,
       t.vl_total_proventos,
       t.vl_encargos,
       t.vl_pat,
       t.vl_valetransp,
       left(u.nm_usuario, charindex(' ', u.nm_usuario) -1) nm_regional,
       t.id_adm,
       char(14) localiza
  from rateio_folha_contabilidade t,
       filial fd,
       filial fp,
       regiao r,
       usuario u
 where fd.cd_filial = t.cd_filial_de
   and r.cd_regiao = fd.cd_regiao
   and u.nr_matricula = r.nr_matricula_regional
   and fp.cd_filial =* t.cd_filial_para
   and t.nr_folha = :nr_folha" update="rateio_folha_contabilidade" updatewhere=1 updatekeyinplace=no arguments=(("nr_folha", number))  sort="nm_regional A cd_tipo_colaborador A nr_matricula A nm_colaborador A nm_filial_de A nm_filial_para A " )
