HA$PBExportHeader$dw_total_proventos.srd
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=136 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=decimal(0) updatewhereclause=yes name=total_proventos dbname="compute_0001" )
 retrieve="select sum(r.valeve)
  from r046ffr r,
       r008evc e
where e.codtab = r.tabeve and
      e.codeve = r.codeve and
      e.tipeve in (1, 2)
  and r.numemp = 1 and
      r.tipcol = :tipcol and
      r.numcad = :numcad and
      r.codcal = :codcal    " arguments=(("tipcol", number),("numcad", number),("codcal", number)) )
column(band=detail id=1 alignment="1" tabsequence=32766 border="0" color="0" x="5" y="4" height="76" width="329" format="[general]"  name=total_proventos edit.limit=0 edit.case=any edit.autoselect=yes edit.autohscroll=yes  font.face="Arial" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
htmltable(border="1" cellpadding="0" cellspacing="0" generatecss="no" nowrap="yes")