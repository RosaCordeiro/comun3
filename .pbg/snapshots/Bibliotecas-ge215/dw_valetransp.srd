table(column=(type=decimal(2) updatewhereclause=yes name=valmov dbname="R044MOV.valmov" )
 column=(type=decimal(2) updatewhereclause=yes name=valrat dbname="R046FFR.valrat" )
 retrieve="select m.valeve valmov,
       r.valeve valrat
  from r044mov m,
       r046ffr r
 where m.numemp = r.numemp and
       m.tipcol = r.tipcol and
       m.numcad = r.numcad and
       m.codcal = r.codcal and
       m.tabeve = r.tabeve and
       m.codeve = r.codeve
   and r.numemp = 1 and
       r.tipcol = :tipcol and
       r.numcad = :numcad and
       r.codcal = :codcal and
       r.tabeve = 1 and
       r.codeve = 118" arguments=(("tipcol", number),("numcad", number),("codcal", number)) )
