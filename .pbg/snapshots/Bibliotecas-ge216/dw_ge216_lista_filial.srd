table(column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" dbalias="f.cd_filial" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" dbalias="c.nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_filial dbname="filial.id_rede_filial" dbalias="f.id_rede_filial" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" dbalias="c.cd_unidade_federacao" )
 column=(type=char(255) updatewhereclause=yes name=cd_filial_sap dbname="cd_filial_sap" )
 column=(type=char(255) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" values="	S/	N" )
 retrieve="  SELECT f.cd_filial,   
         	f.nm_fantasia ,
			c.nm_cidade,
			f.id_rede_filial,
			c.cd_unidade_federacao,
			'' as cd_filial_sap,
			'S' id_selecionar
    FROM filial f
inner join cidade c 
	on f.cd_cidade	= c.cd_cidade
Where f.id_situacao 	= 'A'
   // and f.cd_filial not in (2,534)
 
"  sort="cd_filial A " )
