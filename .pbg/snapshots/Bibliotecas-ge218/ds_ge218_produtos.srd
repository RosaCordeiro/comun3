 column=(type=char(40) updatewhereclause=yes name=subcategory_spm dbname="vw_classificacao_produto.SUBCATEGORY_SPM" dbalias="vw.SUBCATEGORY_SPM" )
 column=(type=long updatewhereclause=yes name=cod_category dbname="produto_geral.COD_CATEGORY" dbalias="pg.COD_CATEGORY" )
 column=(type=char(50) updatewhereclause=yes name=desc_a dbname="categoria_planograma.DESC_A" dbalias="ct.DESC_A" )
 column=(type=long updatewhereclause=yes name=desc_c dbname="DESC_C" )
 column=(type=long updatewhereclause=yes name=desc_d dbname="DESC_D" )
 column=(type=long updatewhereclause=yes name=desc_e dbname="DESC_E" )
