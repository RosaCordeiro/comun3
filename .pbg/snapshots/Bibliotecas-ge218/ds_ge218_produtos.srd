table(column=(type=long updatewhereclause=yes name=product_id dbname="produto_geral.PRODUCT_ID" dbalias="pg.PRODUCT_ID" )
 column=(type=char(20) updatewhereclause=yes name=upc dbname="produto_geral.UPC" dbalias="pg.UPC" )
 column=(type=char(103) updatewhereclause=yes name=prod_name dbname="PROD_NAME" )
 column=(type=decimal(3) updatewhereclause=yes name=prod_size dbname="produto_geral.PROD_SIZE" dbalias="pg.PROD_SIZE" )
 column=(type=char(3) updatewhereclause=yes name=uom dbname="produto_geral.UOM" dbalias="pg.UOM" )
 column=(type=char(40) updatewhereclause=yes name=manufacturer dbname="fornecedor.MANUFACTURER" dbalias="fb.MANUFACTURER" )
 column=(type=char(40) updatewhereclause=yes name=brand_spm dbname="marca_produto.BRAND_SPM" dbalias="ma.BRAND_SPM" )
