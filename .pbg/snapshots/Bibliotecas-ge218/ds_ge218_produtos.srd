 column=(type=long updatewhereclause=yes name=desc_h dbname="DESC_H" )
 column=(type=long updatewhereclause=yes name=desc_i dbname="DESC_I" )
 column=(type=decimal(2) updatewhereclause=yes name=height dbname="produto_geral.HEIGHT" dbalias=".HEIGHT" )
 column=(type=decimal(2) updatewhereclause=yes name=width dbname="produto_geral.WIDTH" dbalias=".WIDTH" )
 column=(type=decimal(2) updatewhereclause=yes name=depth dbname="produto_geral.DEPTH" dbalias=".DEPTH" )
 column=(type=long updatewhereclause=yes name=tray_height dbname="TRAY_HEIGHT" )
 column=(type=long updatewhereclause=yes name=tray_width dbname="TRAY_WIDTH" )
 column=(type=long updatewhereclause=yes name=tray_depth dbname="TRAY_DEPTH" )
 column=(type=long updatewhereclause=yes name=units_case dbname="UNITS_CASE" )
 column=(type=long updatewhereclause=yes name=units_case dbname="UNITS_CASE" )
 column=(type=long updatewhereclause=yes name=units_tray dbname="UNITS_TRAY" )
 column=(type=long updatewhereclause=yes name=preferred_fixel dbname="PREFERRED_FIXEL" )
 column=(type=long updatewhereclause=yes name=case_height dbname="CASE_HEIGHT" )
 column=(type=long updatewhereclause=yes name=case_width dbname="CASE_WIDTH" )
 column=(type=long updatewhereclause=yes name=case_depth dbname="CASE_DEPTH" )
 column=(type=long updatewhereclause=yes name=display_height dbname="DISPLAY_HEIGHT" )
 column=(type=long updatewhereclause=yes name=display_width dbname="DISPLAY_WIDTH" )
 column=(type=long updatewhereclause=yes name=display_depth dbname="DISPLAY_DEPTH" )
 column=(type=long updatewhereclause=yes name=max_horiz_crush dbname="MAX_HORIZ_CRUSH" )
 column=(type=long updatewhereclause=yes name=max_vert_crush dbname="MAX_VERT_CRUSH" )
 column=(type=long updatewhereclause=yes name=max_depth_crush dbname="MAX_DEPTH_CRUSH" )
 column=(type=long updatewhereclause=yes name=model_sched dbname="MODEL_SCHED" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" dbalias="pg.id_situacao" )
 column=(type=char(50) updatewhereclause=yes name=planograma dbname="categoria_planograma.PLANOGRAMA" dbalias="ct.PLANOGRAMA" )
 retrieve="select 
pg.cd_produto as PRODUCT_ID,
pg.de_codigo_barras as UPC,
pg.de_produto +' : '+ pg.de_apresentacao_venda  as PROD_NAME,
pg.qt_peso_grama PROD_SIZE,
pg.cd_unidade_medida_venda UOM,
fb.nm_razao_social MANUFACTURER,					
ma.de_marca BRAND_SPM,
vw.de_categoria as CATEGORY,
vw.de_subcategoria as SUBCATEGORY_SPM,
pg.cd_planograma as COD_CATEGORY, 
ct.de_planograma as DESC_A,
null as DESC_C,   
null as DESC_D,
null as DESC_E,
null as DESC_F,
null as DESC_G,
null as DESC_H,
null as DESC_I,
qt_altura_cm HEIGHT,
qt_largura_cm WIDTH,
qt_profundidade_cm DEPTH,
null TRAY_HEIGHT, 
null TRAY_WIDTH, 
null TRAY_DEPTH, 
null UNITS_CASE, 
null UNITS_CASE, 
null UNITS_TRAY, 
null PREFERRED_FIXEL, 
null CASE_HEIGHT, 
null CASE_WIDTH, 
null CASE_DEPTH, 
null DISPLAY_HEIGHT, 
null DISPLAY_WIDTH, 
null DISPLAY_DEPTH,
null MAX_HORIZ_CRUSH, 
null MAX_VERT_CRUSH, 
null MAX_DEPTH_CRUSH, 
null MODEL_SCHED, 
pg.id_situacao,
ct.de_planograma as PLANOGRAMA
from produto_geral pg
 	left join subcategoria su on pg.cd_subcategoria = su.cd_subcategoria
	left join categoria_planograma ct on( ct.cd_planograma = pg.cd_planograma)	
	left join vw_classificacao_produto vw on(vw.cd_subcategoria = pg.cd_subcategoria)
	left join fornecedor fb on(fb.cd_fornecedor = pg.cd_fornecedor_usual)
	left join marca_produto ma on(ma.cd_marca = pg.cd_marca)
where substring(pg.cd_subcategoria,1,1)in ('1', '2', '3', '4')
" )
