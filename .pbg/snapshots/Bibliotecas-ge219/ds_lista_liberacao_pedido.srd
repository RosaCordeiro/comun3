table(column=(type=long updatewhereclause=yes name=nr_nivel dbname="nivel_liberacao_pedido.nr_nivel" dbalias="n.nr_nivel" )
 column=(type=char(40) updatewhereclause=yes name=de_nivel dbname="nivel_liberacao_pedido.de_nivel" dbalias="n.de_nivel" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_maximo_liberado_nivel dbname="nivel_liberacao_pedido.vl_maximo_liberado_nivel" dbalias="n.vl_maximo_liberado_nivel" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula dbname="nivel_liberacao_pedido_usuario.nr_matricula" dbalias="l.nr_matricula" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="u.nm_usuario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_maximo_liberado_usuario dbname="vl_maximo_liberado_usuario" )
 column=(type=char(100) updatewhereclause=yes name=de_endereco_email dbname="nivel_liberacao_pedido_usuario.de_endereco_email" dbalias="l.de_endereco_email" )
 column=(type=char(1) updatewhereclause=yes name=id_enviar_email dbname="id_enviar_email" initial="S" values="	S/	N" )
 retrieve="SELECT	n.nr_nivel,
			n.de_nivel,
			n.vl_maximo_liberado vl_maximo_liberado_nivel,
			l.nr_matricula,
			u.nm_usuario,
			isnull(l.vl_maximo_liberado, n.vl_maximo_liberado) vl_maximo_liberado_usuario,
			l.de_endereco_email,
			'' id_enviar_email
FROM nivel_liberacao_pedido AS n
	INNER JOIN nivel_liberacao_pedido_usuario AS l
		ON l.nr_nivel = n.nr_nivel
	INNER JOIN usuario AS u
		ON u.nr_matricula	= l.nr_matricula
   WHERE (l.vl_maximo_liberado > :valor_pedido OR l.vl_maximo_liberado = 0.00 OR l.vl_maximo_liberado IS NULL)
	  AND n.nr_nivel > 1
	  AND exists (select u.nm_usuario
						from procedimento_perfil_usuario p
						inner join perfil_usuario pu
							on pu.cd_sistema = p.cd_sistema
							and pu.cd_perfil_usuario = p.cd_perfil_usuario
						inner join usuario_sistema us
							on us.cd_sistema = pu.cd_sistema
							and us.cd_perfil_usuario = pu.cd_perfil_usuario
						inner join usuario u
							on u.nr_matricula = us.nr_matricula
						where p.cd_procedimento = 'W_GE222_CONSULTA_APROVA_PEDIDO_FORN'	
							and us.nr_matricula = l.nr_matricula)" arguments=(("valor_pedido", decimal))  sort="nr_nivel A nm_usuario A " )
