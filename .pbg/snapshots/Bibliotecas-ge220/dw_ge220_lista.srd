table(column=(type=long updatewhereclause=yes name=cd_tributacao_produto dbname="tributa_produtos_farmaceuticos.cd_tributacao_produto" )
 column=(type=char(50) updatewhereclause=yes name=de_tributacao_produto dbname="tributa_produtos_farmaceuticos.de_tributacao_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_st_estadual dbname="pc_st_estadual" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="tributa_produtos_farmaceuticos.cd_unidade_federacao" )
 column=(type=long updatewhereclause=yes name=cd_ncm_inicial dbname="tributa_produtos_farmaceuticos.cd_ncm_inicial" )
 column=(type=long updatewhereclause=yes name=cd_ncm_final dbname="tributa_produtos_farmaceuticos.cd_ncm_final" )
 retrieve="  SELECT cd_tributacao_produto,   
         	 de_tributacao_produto,   
          	 case when pc_st_estadual > 0.00 then pc_st_estadual - 1 else pc_st_estadual end as pc_st_estadual,
			 cd_unidade_federacao,
         	 cd_ncm_inicial,
			 cd_ncm_final  
    FROM tributa_produtos_farmaceuticos
where cd_tributacao_produto = cd_tributacao_produto 
Order By de_tributacao_produto"  sort="cd_tributacao_produto A " )
