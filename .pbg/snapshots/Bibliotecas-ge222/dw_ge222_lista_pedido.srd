table(column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_central.nr_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_pedido dbname="pedido_central.dh_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_previsao_entrega dbname="pedido_central.dh_previsao_entrega" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="pedido_central.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_pedido dbname="pedido_central.vl_total_pedido" )
 column=(type=char(1) updatewhereclause=yes name=id_programado dbname="pedido_central.id_programado" values="PRG	S/ 	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="pedido_central.id_situacao" values="COLOCADO	C/ATENDIDO	A/CANCELADO	X/PENDENTE	P/RASCUNHO	R/" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_central.dh_emissao" )
 column=(type=long updatewhereclause=yes name=qt_dias_suprimento dbname="pedido_central.qt_dias_suprimento" )
 column=(type=long updatewhereclause=yes name=cd_condicao_pagamento dbname="pedido_central.cd_condicao_pagamento" )
 column=(type=char(40) updatewhereclause=yes name=de_condicao dbname="condicao_pagamento.de_condicao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pedido_central.pc_desconto" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_cadastramento dbname="pedido_central.nr_matricula_cadastramento" )
 column=(type=char(40) updatewhereclause=yes name=nm_cadastramento dbname="usuario.nm_cadastramento" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="pedido_central.dh_cancelamento" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_cancelamento dbname="pedido_central.nr_matricula_cancelamento" )
 column=(type=char(40) updatewhereclause=yes name=nm_responsavel_cancelamento dbname="usuario.nm_responsavel_cancelamento" )
 column=(type=char(40) updatewhereclause=yes name=de_transportadora dbname="pedido_central.de_transportadora" )
 column=(type=char(100) updatewhereclause=yes name=de_observacao dbname="pedido_central.de_observacao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_liberacao dbname="pedido_central.nr_matricula_liberacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_responsavel_liberacao dbname="usuario.nm_responsavel_liberacao" )
 column=(type=datetime updatewhereclause=yes name=dh_liberacao dbname="pedido_central.dh_liberacao" )
 column=(type=char(1) updatewhereclause=yes name=id_liberar dbname="id_liberar" values="	S/	N" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf_fornecedor dbname="cidade.cd_uf_fornecedor" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf_filial dbname="cidade.cd_uf_filial" )
 column=(type=char(100) updatewhereclause=yes name=de_endereco_email dbname="nivel_liberacao_pedido_usuario.de_endereco_email" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_compra_distribuidora dbname="simulacao_pedido_central.vl_compra_distribuidora" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_compra_fornecedor dbname="simulacao_pedido_central.vl_compra_fornecedor" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_central.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=id_ipi dbname="pedido_central.id_ipi" )
 retrieve="select p.nr_pedido,   
       	p.dh_pedido,   
       	p.dh_previsao_entrega,   
       	p.cd_fornecedor,   
       	f.nm_razao_social,   
       	p.vl_total_pedido,
       	p.id_programado,
       	p.id_situacao,
       	p.dh_emissao,
       	p.qt_dias_suprimento,
       	p.cd_condicao_pagamento,
       	c.de_condicao,
       	p.pc_desconto,
       	p.nr_matricula_cadastramento,
		a.nm_usuario nm_cadastramento, 
       	p.dh_cancelamento,
       	p.nr_matricula_cancelamento,
		x.nm_usuario nm_responsavel_cancelamento,
       	p.de_transportadora,
       	p.de_observacao,
	  	p.nr_matricula_liberacao,
		u.nm_usuario nm_responsavel_liberacao,
		p.dh_liberacao,
		'' id_liberar,
		cf.cd_unidade_federacao cd_uf_fornecedor,
		d.cd_unidade_federacao cd_uf_filial,
		n.de_endereco_email,
		s.vl_compra_distribuidora,
		s.vl_compra_fornecedor,
		p.cd_filial,
		i.nm_fantasia,
		p.id_ipi
from	pedido_central p,   
     	fornecedor f,
     	condicao_pagamento c,
		usuario u,
		usuario x,
		usuario a,
		nivel_liberacao_pedido_usuario n,
		cidade cf,
		filial i,
		cidade d,
		simulacao_pedido_central s
where f.cd_fornecedor 	= p.cd_fornecedor
  	and c.cd_condicao   	= p.cd_condicao_pagamento
	and u.nr_matricula	=* p.nr_matricula_liberacao
	and x.nr_matricula		=* p.nr_matricula_cancelamento
	and a.nr_matricula	=* p.nr_matricula_cadastramento
	and n.nr_matricula	=* p.nr_matricula_cadastramento
	and cf.cd_cidade		= f.cd_cidade
	and i.cd_filial			= p.cd_filial
	and d.cd_cidade		= i.cd_cidade
	and s.nr_pedido		=* p.nr_pedido
    
	
"  sort="nr_pedido D " )
