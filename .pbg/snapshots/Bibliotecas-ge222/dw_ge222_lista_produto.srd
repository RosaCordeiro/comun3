table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="produto_geral.cd_fornecedor_usual" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_central_produto.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" )
 column=(type=long updatewhereclause=yes name=qt_estoque_momento dbname="pedido_central_produto.qt_estoque_momento" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_central_produto.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="pedido_central_produto.qt_recebida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="pedido_central_produto.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pedido_central_produto.pc_desconto" )
 column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="vw_classificacao_produto.cd_grupo" )
 column=(type=char(1) updatewhereclause=yes name=id_icms_normal dbname="tributacao_icms.id_icms_normal" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="tipo_icms.pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_ipi dbname="produto_geral.pc_ipi" )
 column=(type=char(1) updatewhereclause=yes name=cd_tributacao_icms dbname="produto_uf.cd_tributacao_icms" )
 column=(type=long updatewhereclause=yes name=cd_tributacao_produto dbname="produto_uf.cd_tributacao_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_caderno_abcfarma dbname="produto_geral.id_caderno_abcfarma" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="produto_geral.id_lei_generico" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_pis_cofins dbname="produto_geral.id_situacao_pis_cofins" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_maximo dbname="produto_uf.vl_preco_venda_maximo" )
 column=(type=char(1) updatewhereclause=yes name=id_considera_ipi_pedido dbname="id_considera_ipi_pedido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_pedido dbname="vl_custo_pedido" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_custo_gerencial dbname="vl_custo_gerencial" )
 retrieve="select	 g.cd_fornecedor_usual,
       	 f.nm_razao_social,
       	 p.cd_produto,   
		 g.de_produto,   
		 g.de_apresentacao_estoque,   
		 p.qt_estoque_momento,   
		 p.qt_pedida,   
		 p.qt_recebida,   
		 p.vl_preco_unitario,   
		 p.pc_desconto,
		 v.cd_grupo,
		 t.id_icms_normal,
		 ti.pc_icms,
		 g.pc_ipi,
		 u.cd_tributacao_icms,
		 u.cd_tributacao_produto,
		 g.id_caderno_abcfarma,
		 g.id_lei_generico,
		 g.id_situacao_pis_cofins,
		 u.vl_preco_venda_maximo,
		 isnull(f.id_considera_ipi_pedido, 'N') id_considera_ipi_pedido,
		0.00 vl_custo_pedido,
		round(pc.vl_custo_gerencial * g.vl_fator_conversao, 2) as vl_custo_gerencial
from	pedido_central_produto p,   
     	produto_geral g,
     	fornecedor f,
		vw_classificacao_produto v,
		pedido_central c,
		filial l,
		cidade i,
		produto_uf u,
		tributacao_icms t,
		tipo_icms ti,
		produto_central pc
where p.nr_pedido 				= :pedido
   and g.cd_produto    			= p.cd_produto
   and f.cd_fornecedor 			= g.cd_fornecedor_usual
   and v.cd_subcategoria			= g.cd_subcategoria
   and c.nr_pedido					= p.nr_pedido
   and l.cd_filial						= c.cd_filial
   and i.cd_cidade					= l.cd_cidade
   and u.cd_produto				= p.cd_produto
   and u.cd_unidade_federacao = i.cd_unidade_federacao
   and t.cd_tributacao_icms		= u.cd_tributacao_icms
   and ti.cd_tipo_icms				= u.cd_tipo_icms
   and pc.cd_produto				= p.cd_produto


  
" arguments=(("pedido", number))  sort="nm_razao_social A de_produto A " )
