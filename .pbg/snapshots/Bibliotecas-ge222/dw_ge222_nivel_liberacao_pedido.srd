table(column=(type=long updatewhereclause=yes name=nr_nivel dbname="nivel_liberacao_pedido.nr_nivel" )
 column=(type=char(40) updatewhereclause=yes name=de_nivel dbname="nivel_liberacao_pedido.de_nivel" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_maximo_liberado dbname="nivel_liberacao_pedido.vl_maximo_liberado" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula dbname="nivel_liberacao_pedido_usuario.nr_matricula" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_maximo_liberado_responsavel dbname="nivel_liberacao_pedido_usuario.vl_maximo_liberado" )
 retrieve="  SELECT n.nr_nivel,   
				n.de_nivel,   
				n.vl_maximo_liberado,   
				nu.nr_matricula,   
				u.nm_usuario,   
				nu.vl_maximo_liberado  
    FROM nivel_liberacao_pedido n,   
         nivel_liberacao_pedido_usuario nu,   
         usuario u
   WHERE nu.nr_nivel 		= n.nr_nivel 
		and u.nr_matricula 	= nu.nr_matricula    "  sort="nr_nivel A nm_usuario A " )
