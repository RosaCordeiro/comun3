table(column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="nf_devolucao_venda.cd_filial" )
 column=(type=long update=yes updatewhereclause=yes name=nr_nf dbname="nf_devolucao_venda.nr_nf" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_especie dbname="nf_devolucao_venda.de_especie" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_serie dbname="nf_devolucao_venda.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_devolucao_venda.dh_movimentacao_caixa" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_origem_nf dbname="nf_devolucao_venda.id_origem_nf" values="CLIENTE	C/FILIAL	F/" )
