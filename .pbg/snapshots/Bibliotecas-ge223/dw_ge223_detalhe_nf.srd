 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_total_produtos dbname="nf_devolucao_venda.vl_total_produtos" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_frete dbname="nf_devolucao_venda.vl_frete" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_outras_despesas dbname="nf_devolucao_venda.vl_outras_despesas" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto dbname="nf_devolucao_venda.pc_desconto" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_total_nf dbname="nf_devolucao_venda.vl_total_nf" )
 column=(type=char(11) update=yes updatewhereclause=yes name=cd_cliente dbname="nf_devolucao_venda.cd_cliente" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="cliente.nm_cliente" )
 column=(type=long update=yes updatewhereclause=yes name=cd_convenio dbname="nf_devolucao_venda.cd_convenio" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="nf_devolucao_venda.dh_cancelamento" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_operador dbname="nf_devolucao_venda.nr_matricula_operador" )
 column=(type=char(40) updatewhereclause=yes name=nm_operador dbname="usuario.nm_operador" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_cancelamento dbname="nf_devolucao_venda.nr_matricula_cancelamento" )
 column=(type=char(40) updatewhereclause=yes name=nm_operador_cancel dbname="usuario.nm_operador_cancel" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_devolucao_venda_nfe.de_chave_acesso" )
 column=(type=char(100) updatewhereclause=yes name=de_justificativa dbname="nf_devolucao_venda.de_justificativa" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial_venda dbname="nf_devolucao_venda.cd_filial_venda" )
 column=(type=char(40) updatewhereclause=yes name=nm_filial_venda dbname="filial.nm_filial_venda" )
 column=(type=long update=yes updatewhereclause=yes name=nr_nf_venda dbname="nf_devolucao_venda.nr_nf_venda" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_especie_venda dbname="nf_devolucao_venda.de_especie_venda" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_serie_venda dbname="nf_devolucao_venda.de_serie_venda" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_venda dbname="nf_devolucao_venda.id_tipo_venda" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao_nf_venda dbname="nf_devolucao_venda.dh_emissao_nf_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf_venda dbname="nf_devolucao_venda.vl_total_nf_venda" )
 column=(type=char(40) updatewhereclause=yes name=nm_destino dbname="nm_destino" )
 column=(type=char(15) updatewhereclause=yes name=nr_cgc_cpf_destino dbname="nr_cgc_cpf_destino" )
 retrieve="SELECT n.cd_filial ,
		 n.nr_nf , 
		 n.de_especie ,  
		 n.de_serie ,  
		 n.dh_movimentacao_caixa ,  
		 n.id_origem_nf ,
		 n.dh_recebimento ,   
		 n.vl_bc_icms ,
		 n.vl_icms , 
		 n.vl_bc_icms_st , 
		 n.vl_icms_st ,   
		 n.vl_total_produtos , 
		 n.vl_frete ,        
		 n.vl_outras_despesas , 
		 n.pc_desconto , 
		 n.vl_total_nf ,  
		 n.cd_cliente , 
		 c.nm_cliente,
		 n.cd_convenio ,   
		 n.dh_cancelamento , 
		 n.nr_matricula_operador,
		 uop.nm_usuario as nm_operador,
		 n.nr_matricula_cancelamento,
		 uc.nm_usuario as nm_operador_cancel,
		 ndev.de_chave_acesso ,  
		 n.de_justificativa,
		 n.cd_filial_venda , 
		 fv.nm_fantasia as nm_filial_venda,
		 n.nr_nf_venda ,  
		 n.de_especie_venda , 
		 n.de_serie_venda,
		 n.id_tipo_venda,
		 n.dh_emissao_nf_venda,
		 n.vl_total_nf_venda,
		coalesce(nl.nm_cliente, c.nm_cliente) as nm_destino,
		coalesce(nl.nr_cgc_cpf, c.nr_cpf_cgc) as nr_cgc_cpf_destino
  FROM nf_devolucao_venda n
INNER JOIN filial fv
	on fv.cd_filial = n.cd_filial_venda
LEFT OUTER JOIN nf_devolucao_venda_nfe  ndev
  ON   (ndev.nr_nf 			= n.nr_nf)
  AND (ndev.de_especie	= n.de_especie)
  AND (ndev.de_serie 		= n.de_serie)
  AND (ndev.cd_filial 		= n.cd_filial)
LEFT OUTER JOIN cliente c
	ON c.cd_cliente 		= n.cd_cliente
LEFT OUTER JOIN usuario uop
	ON uop.nr_matricula	= n.nr_matricula_operador
Left Outer Join nf_devolucao_venda_loja nl
	on nl.cd_filial			= n.cd_filial
	and nl.nr_nf				= n.nr_nf
	and nl.de_serie			= n.de_serie
	and nl.de_especie		= n.de_especie
Left Outer Join usuario uc
	on uc.nr_matricula		=  n.nr_matricula_cancelamento
WHERE n.cd_filial   		= :cd_filial 
  AND ( n.cd_cliente  		= :cd_cliente )
  AND ( n.nr_nf        		= :nr_nf ) 
  AND ( n.de_especie   	= :de_especie )
  AND ( n.de_serie     		= :de_serie )
  AND ( n.id_origem_nf 	= :id_origem_nf )
" arguments=(("cd_filial", number),("cd_cliente", string),("nr_nf", number),("de_especie", string),("de_serie", string),("id_origem_nf", string)) )
