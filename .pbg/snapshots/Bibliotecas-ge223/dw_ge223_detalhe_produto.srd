table(column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=long updatewhereclause=yes name=qt_devolvida dbname="item_nf_devolucao_venda.qt_devolvida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_devolucao_venda.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="item_nf_devolucao_venda.pc_desconto" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_devolucao_venda.cd_produto" )
 column=(type=char(3) updatewhereclause=yes name=cst dbname="cst" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms dbname="item_nf_devolucao_venda.vl_bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="item_nf_devolucao_venda.pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="item_nf_devolucao_venda.vl_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_efetivo dbname="item_nf_devolucao_venda.vl_bc_icms_efetivo" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_icms_efetivo dbname="item_nf_devolucao_venda.pc_icms_efetivo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_efetivo dbname="item_nf_devolucao_venda.vl_icms_efetivo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_total dbname="item_nf_devolucao_venda.vl_desconto_total" )
 retrieve="  SELECT		p.de_produto,
				p.de_apresentacao_venda,
				i.qt_devolvida,   
				i.vl_preco_unitario,   
				i.pc_desconto,   
				i.cd_produto ,
				coalesce(i.cd_cst_origem, substring(i.cd_situacao_tributaria,1,1))||coalesce(i.cd_cst_tributacao,substring(i.cd_situacao_tributaria,2,1)||'0') as cst,
				i.vl_bc_icms,
				i.pc_icms,   
				i.vl_icms,
				i.vl_bc_icms_efetivo,
				i.pc_icms_efetivo,
				i.vl_icms_efetivo,
				i.vl_desconto_total
    FROM item_nf_devolucao_venda i
INNER JOIN produto_geral p
	ON  p.cd_produto = i.cd_produto 
   WHERE ( i.cd_filial		= :cd_filial )
     AND ( i.nr_nf			= :nr_nf )
     AND ( i.de_especie	= :de_especie )
     AND ( i.de_serie		= :de_serie )
     AND ( i.id_origem_nf	= :id_origem_nf )
" arguments=(("cd_filial", number),("nr_nf", number),("de_especie", string),("de_serie", string),("id_origem_nf", string)) )
