table(column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_devolucao_venda.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_devolucao_venda.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_devolucao_venda.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_devolucao_venda.dh_movimentacao_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_recebimento dbname="nf_devolucao_venda.dh_recebimento" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_devolucao_venda.cd_filial" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="nf_devolucao_venda.cd_cliente" )
 column=(type=char(1) updatewhereclause=yes name=id_origem_nf dbname="nf_devolucao_venda.id_origem_nf" values="CLIENTE	C/FILIAL	F/" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_devolucao_venda.vl_total_nf" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_operador dbname="nf_devolucao_venda.nr_matricula_operador" )
 column=(type=char(40) updatewhereclause=yes name=nm_operador dbname="usuario.nm_operador" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="nf_devolucao_venda.cd_convenio" )
 column=(type=char(60) updatewhereclause=yes name=nm_convenio dbname="convenio.nm_convenio" )
 column=(type=char(15) updatewhereclause=yes name=cd_conveniado dbname="nf_devolucao_venda.cd_conveniado" )
 column=(type=char(40) updatewhereclause=yes name=nm_conveniado dbname="conveniado.nm_conveniado" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="nf_devolucao_venda.cd_cliente" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="nm_cliente" )
 column=(type=char(15) updatewhereclause=yes name=nr_cgc_cpf dbname="nr_cgc_cpf" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="nf_devolucao_venda.dh_cancelamento" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_cancelamento dbname="nf_devolucao_venda.nr_matricula_cancelamento" )
 column=(type=char(40) updatewhereclause=yes name=nm_operador_cancel dbname="usuario.nm_operador_cancel" )
 column=(type=char(100) updatewhereclause=yes name=de_justificativa dbname="nf_devolucao_venda.de_justificativa" )
 column=(type=long updatewhereclause=yes name=cd_filial_venda dbname="nf_devolucao_venda.cd_filial_venda" )
 column=(type=long updatewhereclause=yes name=nr_nf_venda dbname="nf_devolucao_venda.nr_nf_venda" )
 column=(type=char(3) updatewhereclause=yes name=de_especie_venda dbname="nf_devolucao_venda.de_especie_venda" )
 column=(type=char(3) updatewhereclause=yes name=de_serie_venda dbname="nf_devolucao_venda.de_serie_venda" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_venda dbname="nf_devolucao_venda.id_tipo_venda" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao_nf_venda dbname="nf_devolucao_venda.dh_emissao_nf_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf_venda dbname="nf_devolucao_venda.vl_total_nf_venda" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_vendedor dbname="nf_devolucao_venda.nr_matricula_vendedor" )
 retrieve="  SELECT  
			n.nr_nf,
			n.de_especie,
			n.de_serie,
			n.dh_movimentacao_caixa,
			n.dh_recebimento,
			n.cd_filial,
			n.cd_cliente,
			n.id_origem_nf,
			n.vl_total_nf,
			n.nr_matricula_operador,
			uo.nm_usuario as nm_operador,
			n.cd_convenio,
			cv.nm_fantasia as nm_convenio,
			n.cd_conveniado,
			cvo.nm_conveniado,
			n.cd_cliente,
			coalesce(nl.nm_cliente, c.nm_cliente) as nm_cliente,
			coalesce(nl.nr_cgc_cpf, c.nr_cpf_cgc) as nr_cgc_cpf,
			n.dh_cancelamento,
			n.nr_matricula_cancelamento,
			uc.nm_usuario as nm_operador_cancel,
			n.de_justificativa,
			n.cd_filial_venda,
			n.nr_nf_venda,
			n.de_especie_venda,
			n.de_serie_venda,
			n.id_tipo_venda,
			n.dh_emissao_nf_venda,
			n.vl_total_nf_venda,
			n.nr_matricula_vendedor
FROM  nf_devolucao_venda n
Left Outer Join cliente c
	on c.cd_cliente			= n.cd_cliente
Left Outer Join nf_devolucao_venda_loja nl
	on nl.cd_filial			= n.cd_filial
	and nl.nr_nf				= n.nr_nf
	and nl.de_serie			= n.de_serie
	and nl.de_especie		= n.de_especie
Left Outer Join usuario uo
	on uo.nr_matricula	=  n.nr_matricula_operador
Left Outer Join usuario uc
	on uc.nr_matricula		=  n.nr_matricula_cancelamento
Left Outer Join convenio cv
	on cv.cd_convenio		= n.cd_convenio
Left Outer Join conveniado cvo
	on cvo.cd_conveniado	= n.cd_conveniado
	and cvo.cd_convenio	= n.cd_convenio
WHERE n.dh_movimentacao_caixa between :pdt_periodo_de and :pdt_periodo_ate" arguments=(("pdt_periodo_de", date),("pdt_periodo_ate", date))  sort="nr_nf A de_especie A de_serie A " )
