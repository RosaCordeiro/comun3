table(column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_compra.nr_nf" )
 retrieve="select	d.nm_fantasia,
		c.nr_nf
from nf_devolucao_compra a
inner join nf_devolucao_compra_entrada b   on b.cd_filial		= a.cd_filial
														and b.nr_nf			= a.nr_nf
														and b.de_especie	= a.de_especie
														and b.de_serie		= a.de_serie
inner join nf_compra c on c.de_chave_acesso = b.de_chave_acesso
inner join fornecedor d on d.cd_fornecedor = a.cd_fornecedor
where a.cd_filial		= :cd_filial
	and a.nr_nf 			= :nr_nf
	and a.de_especie	= :de_especie
	and a.de_serie		= :de_serie" arguments=(("cd_filial", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
