table(column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms dbname="vl_bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="vl_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_st dbname="vl_bc_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_produtos dbname="vl_total_produtos" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_ipi dbname="vl_ipi" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_frete dbname="vl_frete" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_seguro dbname="vl_seguro" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_outras_despesas dbname="vl_outras_despesas" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto dbname="vl_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_indenizacao dbname="vl_indenizacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_repassado dbname="vl_icms_repassado" )
 column=(type=char(13) updatewhereclause=yes name=nr_titulo_receber dbname="nr_titulo_receber" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo_devolucao dbname="de_motivo_devolucao" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="de_chave_acesso" )
 column=(type=long updatewhereclause=yes name=cd_motivo_devolucao dbname="cd_motivo_devolucao" )
 column=(type=long updatewhereclause=yes name=nf_devolucao_compra_cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia_filial dbname="nm_fantasia_filial" )
 column=(type=datetime updatewhereclause=yes name=dh_solicitacao_canc dbname="dh_solicitacao_canc" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_solic_canc dbname="nr_matricula_solic_canc" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_solic_canc dbname="nm_usuario_solic_canc" )
 column=(type=long updatewhereclause=yes name=nf_devolucao_compra_nr_agrupamento_dev_compra dbname="nr_agrupamento_dev_compra" )
 column=(type=char(100) updatewhereclause=yes name=de_dados_adicionais dbname="de_dados_adicionais" )
 retrieve="  SELECT
		fornecedor.nm_fantasia ,
		nf_devolucao_compra.cd_fornecedor,
		nf_devolucao_compra.nr_nf ,
		nf_devolucao_compra.de_especie ,
		nf_devolucao_compra.de_serie ,
		nf_devolucao_compra.dh_movimentacao_caixa,
		nf_devolucao_compra.vl_bc_icms ,
		nf_devolucao_compra.vl_icms ,
		nf_devolucao_compra.vl_bc_icms_st ,
		nf_devolucao_compra.vl_icms_st ,
		nf_devolucao_compra.vl_total_produtos ,
		nf_devolucao_compra.vl_ipi ,
		nf_devolucao_compra.vl_frete ,
		nf_devolucao_compra.vl_seguro ,
		nf_devolucao_compra.vl_outras_despesas ,
		nf_devolucao_compra.vl_desconto ,
		nf_devolucao_compra.vl_indenizacao ,
		nf_devolucao_compra.vl_total_nf ,
		nf_devolucao_compra.vl_icms_repassado ,
		nf_devolucao_compra.nr_titulo_receber,
		nf_devolucao_compra.de_motivo_devolucao,
		dev_cpr.de_chave_acesso,
		nf_devolucao_compra.cd_motivo_devolucao,
		nf_devolucao_compra.cd_filial cd_filial,
		f.nm_fantasia nm_fantasia_filial,
		nf_devolucao_compra.dh_solicitacao_canc,
		nf_devolucao_compra.nr_matricula_solic_canc,
		(select u.nm_usuario from usuario u where u.nr_matricula = nf_devolucao_compra.nr_matricula_solic_canc) as nm_usuario_solic_canc,
		nf_devolucao_compra.nr_agrupamento_dev_compra, 
         nf_devolucao_compra.de_dados_adicionais
   FROM nf_devolucao_compra,
	    nf_devolucao_compra_nfe dev_cpr,
        fornecedor, 
		filial f
   WHERE nf_devolucao_compra.cd_filial     = :cd_filial
     and nf_devolucao_compra.cd_fornecedor = :cd_fornecedor 
     and nf_devolucao_compra.nr_nf         = :nr_nf 
     and nf_devolucao_compra.de_especie    = :de_especie
     and nf_devolucao_compra.de_serie      = :de_serie 
     and fornecedor.cd_fornecedor = nf_devolucao_compra.cd_fornecedor
	and nf_devolucao_compra.nr_nf *=  dev_cpr.nr_nf
    and nf_devolucao_compra.de_especie *= dev_cpr.de_especie
    and nf_devolucao_compra.de_serie *= dev_cpr.de_serie
	and nf_devolucao_compra.cd_filial *= dev_cpr.cd_filial
	and nf_devolucao_compra.cd_filial = f.cd_filial" arguments=(("cd_filial", number),("cd_fornecedor", string),("nr_nf", number),("de_especie", string),("de_serie", string)) )
