table(column=(type=long updatewhereclause=yes name=nf_devolucao_compra_produto_cd_produto dbname="nf_devolucao_compra_produto.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=produto_geral_de_apresentacao_estoque dbname="de_apresentacao_estoque" )
 column=(type=char(1) updatewhereclause=yes name=cd_situacao_tributaria dbname="cd_situacao_tributaria" )
 column=(type=long updatewhereclause=yes name=qt_devolvida dbname="nf_devolucao_compra_produto.qt_devolvida" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_preco_unitario dbname="nf_devolucao_compra_produto.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="nf_devolucao_compra_produto.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="nf_devolucao_compra_produto.pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_ipi dbname="nf_devolucao_compra_produto.pc_ipi" )
 retrieve="  SELECT nf_devolucao_compra_produto.cd_produto,   
         produto_geral.de_produto,         
         // produto_geral.de_apresentacao_estoque, 
		case when nf_devolucao_compra_produto.cd_filial = 534 then
                produto_geral.de_apresentacao_estoque 
              else
                produto_geral.de_apresentacao_venda
         end as de_apresentacao_estoque,
         substring(nf_devolucao_compra_produto.cd_cst_tributacao,1,1) cd_situacao_tributaria ,   
         nf_devolucao_compra_produto.qt_devolvida,   
         nf_devolucao_compra_produto.vl_preco_unitario,   
         nf_devolucao_compra_produto.pc_desconto,   
         nf_devolucao_compra_produto.pc_icms,   
         nf_devolucao_compra_produto.pc_ipi  
    FROM nf_devolucao_compra_produto,   
         produto_geral  
   WHERE ( nf_devolucao_compra_produto.cd_produto  = produto_geral.cd_produto ) and  
         ( nf_devolucao_compra_produto.cd_filial   = :cd_filial ) AND  
         ( nf_devolucao_compra_produto.nr_nf       = :nr_nf ) AND  
         ( nf_devolucao_compra_produto.de_especie  = :de_especie ) AND  
         ( nf_devolucao_compra_produto.de_serie    = :de_serie )  
" arguments=(("cd_filial", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
