table(column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_devolucao_compra.dh_movimentacao_caixa" dbalias="n.dh_movimentacao_caixa" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" dbalias="f.nm_razao_social" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="fornecedor.cd_fornecedor" dbalias="f.cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_devolucao_compra.nr_nf" dbalias="n.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_devolucao_compra.de_especie" dbalias="n.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_devolucao_compra.de_serie" dbalias="n.de_serie" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_devolucao_compra.vl_total_nf" dbalias="n.vl_total_nf" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_devolucao_compra.cd_filial" dbalias="n.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="fl.nm_fantasia" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="filial.nr_cgc" dbalias="fl.nr_cgc" )
 column=(type=long updatewhereclause=yes name=nr_nf_compra dbname="nf_devolucao_compra.nr_nf_compra" dbalias="n.nr_nf_compra" )
 column=(type=char(3) updatewhereclause=yes name=de_especie_compra dbname="nf_devolucao_compra.de_especie_compra" dbalias="n.de_especie_compra" )
 column=(type=char(3) updatewhereclause=yes name=de_serie_compra dbname="nf_devolucao_compra.de_serie_compra" dbalias="n.de_serie_compra" )
 column=(type=datetime updatewhereclause=yes name=dh_entrada_compra dbname="nf_compra.dh_entrada_compra" dbalias="c.dh_entrada_compra" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf_compra dbname="nf_compra.vl_total_nf_compra" dbalias="c.vl_total_nf_compra" )
 column=(type=char(1) updatewhereclause=yes name=dh_vencimento dbname="dh_vencimento" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="nf_devolucao_compra.dh_cancelamento" dbalias="n.dh_cancelamento" )
 column=(type=long updatewhereclause=yes name=cd_motivo_devolucao dbname="nf_devolucao_compra.cd_motivo_devolucao" dbalias="n.cd_motivo_devolucao" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo_devolucao dbname="motivo_devolucao_compra.de_motivo_devolucao" dbalias="m.de_motivo_devolucao" )
 column=(type=char(40) updatewhereclause=yes name=de_observacao_devolucao dbname="nf_devolucao_compra.de_observacao_devolucao" dbalias="n.de_observacao_devolucao" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_devolucao_compra_nfe.de_chave_acesso" dbalias="e.de_chave_acesso" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_devolucao_compra.dh_emissao" dbalias="n.dh_emissao" )
 column=(type=char(49) updatewhereclause=yes name=usuario_nfd dbname="usuario_nfd" )
 column=(type=char(1) updatewhereclause=yes name=id_imprimir dbname="id_imprimir" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="nf_devolucao_compra_nfe.id_situacao" dbalias="e.id_situacao" )
 column=(type=long updatewhereclause=yes name=nr_nf_compra dbname="nf_devolucao_compra.nr_nf_compra" dbalias="n.nr_nf_compra" )
 column=(type=char(3) updatewhereclause=yes name=de_especie_compra dbname="nf_devolucao_compra.de_especie_compra" dbalias="n.de_especie_compra" )
 column=(type=char(3) updatewhereclause=yes name=de_serie_compra dbname="nf_devolucao_compra.de_serie_compra" dbalias="n.de_serie_compra" )
 column=(type=long updatewhereclause=yes name=nr_agrupamento_dev_compra dbname="nf_devolucao_compra.nr_agrupamento_dev_compra" dbalias="n.nr_agrupamento_dev_compra" )
 column=(type=char(1) updatewhereclause=yes name=id_cobrar_protocolo_nfd dbname="fornecedor.id_cobrar_protocolo_nfd" dbalias="f.id_cobrar_protocolo_nfd" )
 column=(type=char(1) updatewhereclause=yes name=id_protocolo_obrigatorio dbname="id_protocolo_obrigatorio" )
 column=(type=long updatewhereclause=yes identity=yes name=cd_protocolo dbname="nf_devolucao_compra_protocolo.cd_protocolo" dbalias="ndcp.cd_protocolo" )
 column=(type=char(100) updatewhereclause=yes name=id_protocolo_fornecedor dbname="nf_devolucao_compra_protocolo.id_protocolo_fornecedor" dbalias="ndcp.id_protocolo_fornecedor" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="nf_devolucao_compra_protocolo.dh_inclusao" dbalias="ndcp.dh_inclusao" )
 column=(type=long updatewhereclause=yes name=prazo_protocolo dbname="prazo_protocolo" )
 column=(type=datetime updatewhereclause=yes name=dh_situacao_coleta dbname="dh_situacao_coleta" )
 column=(type=char(255) updatewhereclause=yes name=nm_arquivo_comprovante dbname="nf_devolucao_compra_coleta.nm_arquivo_comprovante" dbalias="nc.nm_arquivo_comprovante" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_coleta dbname="nf_devolucao_compra_coleta.id_situacao_coleta" dbalias="nc.id_situacao_coleta" )
 retrieve="SELECT DISTINCT	n.dh_movimentacao_caixa,
			f.nm_razao_social,
			f.cd_fornecedor,
			n.nr_nf ,
			n.de_especie ,
			n.de_serie ,
			n.vl_total_nf ,
			n.cd_filial ,
			fl.nm_fantasia,
		 	fl.nr_cgc,
			n.nr_nf_compra,
			n.de_especie_compra,
			n.de_serie_compra,
			c.dh_movimentacao_caixa AS dh_entrada_compra,
			c.vl_total_nf AS vl_total_nf_compra,
			'' AS dh_vencimento,
			n.dh_cancelamento,
			n.cd_motivo_devolucao,
			m.de_motivo_devolucao AS de_motivo_devolucao,
			n.de_motivo_devolucao AS de_observacao_devolucao,
			e.de_chave_acesso AS de_chave_acesso,
			n.dh_emissao,
			(usr.nm_usuario + ' (' + usr.nr_matricula + ')') AS usuario_nfd,
			cast('N' as varchar(1)) as id_imprimir,
			e.id_situacao,
			n.nr_nf_compra, 
			n.de_especie_compra,
			n.de_serie_compra,
			n.nr_agrupamento_dev_compra,
			f.id_cobrar_protocolo_nfd,
			CASE
			    WHEN DATEADD(HOUR, :parametro, n.dh_emissao) < getdate() and coalesce(f.id_cobrar_protocolo_nfd, 'N') = 'S' THEN 'S' 
			END AS id_protocolo_obrigatorio,
			ndcp.cd_protocolo ,
			ndcp.id_protocolo_fornecedor,
			ndcp.dh_inclusao,
			COALESCE (CAST (vl_parametro AS INTEGER), 0) AS prazo_protocolo,
			Case When nc.id_situacao = 'C' Then nc.dh_situacao Else null End as dh_situacao_coleta,
			nc.nm_arquivo_comprovante,
			nc.id_situacao as id_situacao_coleta
FROM nf_devolucao_compra n
	INNER JOIN item_nf_devolucao_compra i
		ON	   i.cd_filial		= n.cd_filial
		AND i.nr_nf 			= n.nr_nf
		AND i.de_especie 	= n.de_especie
		AND i.de_serie 		= n.de_serie
	INNER JOIN fornecedor f
		ON		f.cd_fornecedor = n.cd_fornecedor
	INNER JOIN filial fl
		ON		fl.cd_filial = n.cd_filial
	LEFT JOIN motivo_devolucao_compra m
		ON		m.cd_motivo_devolucao = n.cd_motivo_devolucao
	LEFT JOIN nf_devolucao_compra_nfe e //tem notas antigas que n$$HEX1$$e300$$ENDHEX$$o possuem registro nessa tabela
		ON		e.cd_filial 		= n.cd_filial
		AND	e.nr_nf			= n.nr_nf
		AND	e.de_especie	= n.de_especie
		AND	e.de_serie		= n.de_serie	
	LEFT JOIN nf_compra  c //tem notas antigas que n$$HEX1$$e300$$ENDHEX$$o possuem registro nessa tabela
		ON		c.cd_filial = n.cd_filial
		AND	c.cd_fornecedor	= n.cd_fornecedor
		AND	c.nr_nf				= n.nr_nf_compra
		AND	c.de_especie		= n.de_especie_compra
		AND	c.de_serie			= n.de_serie_compra	
	LEFT JOIN wms_int_sap as wint  
			ON wint.cd_fornecedor  =  n.cd_fornecedor
			AND wint.nr_nf 			= n.nr_nf		
			AND wint.de_serie 		= n.de_serie
			AND wint.de_especie 	= n.de_especie 
	LEFT JOIN usuario usr
			ON		usr.nr_matricula = wint.nr_matricula_responsavel
	LEFT JOIN nf_devolucao_compra_protocolo ndcp
			ON		ndcp.cd_fornecedor  = f.cd_fornecedor 
			AND 	ndcp.nr_nf = n.nr_nf 
			AND 	ndcp.de_especie = n.de_especie 
			AND 	ndcp.de_serie = n.de_serie 
	LEFT JOIN wms_parametro p
			ON		p.cd_parametro = 'NR_DIAS_INFORME_PROTOCOLO_DEVOLUCAO'
	LEFT JOIN nf_devolucao_compra_coleta nc on nc.cd_filial = n.cd_filial and nc.nr_nf = n.nr_nf and nc.de_especie = n.de_especie and nc.de_serie = n.de_serie
WHERE n.cd_filial > 0

UNION

SELECT DISTINCT	n.dh_movimentacao_caixa,
			f.nm_razao_social,
			f.cd_fornecedor,
			n.nr_nf ,
			n.de_especie ,
			n.de_serie ,
			n.vl_total_nf ,
			n.cd_filial ,
			fl.nm_fantasia,
		 	fl.nr_cgc,
			n.nr_nf_compra,
			n.de_especie_compra,
			n.de_serie_compra,
			c.dh_movimentacao_caixa AS dh_entrada_compra,
			c.vl_total_nf AS vl_total_nf_compra,
			'' AS dh_vencimento,
			n.dh_cancelamento,
			n.cd_motivo_devolucao,
			m.de_motivo_devolucao AS de_motivo_devolucao,
			n.de_motivo_devolucao AS de_observacao_devolucao,
			e.de_chave_acesso AS de_chave_acesso,
			n.dh_emissao,
			(usr.nm_usuario + ' (' + usr.nr_matricula + ')') AS usuario_nfd,
			cast('N' as varchar(1)) as id_imprimir,
			e.id_situacao,
			n.nr_nf_compra, 
			n.de_especie_compra,
			n.de_serie_compra,
			n.nr_agrupamento_dev_compra,
			f.id_cobrar_protocolo_nfd,
			CASE
			    WHEN DATEADD(HOUR, :parametro, n.dh_emissao) < getdate() and coalesce(f.id_cobrar_protocolo_nfd, 'N') = 'S' THEN 'S' 
			END AS id_protocolo_obrigatorio,
			ndcp.cd_protocolo ,
			ndcp.id_protocolo_fornecedor,
			ndcp.dh_inclusao,
			COALESCE (CAST (vl_parametro AS INTEGER), 0) AS prazo_protocolo,
			Case When nc.id_situacao = 'C' Then nc.dh_situacao Else null End as dh_situacao_coleta,
			nc.nm_arquivo_comprovante,
			nc.id_situacao as id_situacao_coleta
FROM nf_devolucao_compra AS n
	INNER JOIN nf_devolucao_compra_produto AS i
		ON	   i.cd_filial		= n.cd_filial
		AND i.nr_nf 			= n.nr_nf
		AND i.de_especie 	= n.de_especie
		AND i.de_serie 		= n.de_serie
	INNER JOIN nf_devolucao_compra_nfe AS e
		ON		e.cd_filial 		= n.cd_filial
		AND	e.nr_nf			= n.nr_nf
		AND	e.de_especie	= n.de_especie
		AND	e.de_serie		= n.de_serie
	INNER JOIN fornecedor AS f
		ON		f.cd_fornecedor = n.cd_fornecedor
	INNER JOIN filial AS fl
		ON		fl.cd_filial = n.cd_filial
	INNER JOIN nf_compra AS c
		ON		c.cd_filial = n.cd_filial
		AND	c.cd_fornecedor	= n.cd_fornecedor
		AND	c.nr_nf				= n.nr_nf_compra
		AND	c.de_especie		= n.de_especie_compra
		AND	c.de_serie			= n.de_serie_compra
	LEFT JOIN motivo_devolucao_compra	AS m
		ON		m.cd_motivo_devolucao = n.cd_motivo_devolucao	
	LEFT JOIN wms_int_sap as wint  
			ON wint.cd_fornecedor  =  n.cd_fornecedor
			AND wint.nr_nf 			= n.nr_nf		
			AND wint.de_serie 		= n.de_serie
			AND wint.de_especie 	= n.de_especie 
	LEFT JOIN usuario usr
			ON		usr.nr_matricula = wint.nr_matricula_responsavel
	LEFT JOIN nf_devolucao_compra_protocolo ndcp
			ON		ndcp.cd_fornecedor  = f.cd_fornecedor 
			AND 	ndcp.nr_nf = n.nr_nf 
			AND 	ndcp.de_especie = n.de_especie 
			AND 	ndcp.de_serie = n.de_serie 
	LEFT JOIN wms_parametro p
			ON		p.cd_parametro = 'NR_DIAS_INFORME_PROTOCOLO_DEVOLUCAO'
	LEFT JOIN nf_devolucao_compra_coleta nc on nc.cd_filial = n.cd_filial and nc.nr_nf = n.nr_nf and nc.de_especie = n.de_especie and nc.de_serie = n.de_serie
WHERE n.cd_filial > 0" arguments=(("parametro", number))  sort="dh_movimentacao_caixa A nm_razao_social A " )
