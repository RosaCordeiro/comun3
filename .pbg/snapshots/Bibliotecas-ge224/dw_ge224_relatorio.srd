table(column=(type=long updatewhereclause=yes name=filial_cd_filial dbname="filial.cd_filial" dbalias="f.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(14) updatewhereclause=yes name=filial_nr_cgc dbname="filial.nr_cgc" dbalias="f.nr_cgc" )
 column=(type=datetime updatewhereclause=yes name=nf_devolucao_compra_dh_movimentacao_caix dbname="nf_devolucao_compra.dh_movimentacao_caixa" dbalias="n.dh_movimentacao_caixa" )
 column=(type=char(40) updatewhereclause=yes name=fornecedor_nm_razao_social dbname="fornecedor.nm_razao_social" dbalias="o.nm_razao_social" )
 column=(type=long updatewhereclause=yes name=nf_devolucao_compra_nr_nf dbname="nf_devolucao_compra.nr_nf" dbalias="n.nr_nf" )
 column=(type=long updatewhereclause=yes name=nf_devolucao_compra_nr_nf_compra dbname="nf_devolucao_compra.nr_nf_compra" dbalias="n.nr_nf_compra" )
 column=(type=datetime updatewhereclause=yes name=nf_compra_dh_movimentacao_caixa dbname="nf_compra.dh_movimentacao_caixa" dbalias="c.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_devolucao_compra_vl_total_nf dbname="nf_devolucao_compra.vl_total_nf" dbalias="n.vl_total_nf" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="nf_devolucao_compra.cd_fornecedor" dbalias="n.cd_fornecedor" )
 column=(type=char(3) updatewhereclause=yes name=de_especie_compra dbname="nf_devolucao_compra.de_especie_compra" dbalias="n.de_especie_compra" )
 column=(type=char(3) updatewhereclause=yes name=de_serie_compra dbname="nf_devolucao_compra.de_serie_compra" dbalias="n.de_serie_compra" )
 column=(type=char(1) updatewhereclause=yes name=dh_vencimento dbname="dh_vencimento" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo_devolucao dbname="motivo_devolucao_compra.de_motivo_devolucao" dbalias="m.de_motivo_devolucao" )
 column=(type=char(40) updatewhereclause=yes name=de_observacao_devolucao dbname="nf_devolucao_compra.de_observacao_devolucao" dbalias="n.de_observacao_devolucao" )
 retrieve="Select	f.cd_filial,
		f.nm_fantasia,
		f.nr_cgc,
		n.dh_movimentacao_caixa,
		o.nm_razao_social,
		n.nr_nf,
		n.nr_nf_compra,
		c.dh_movimentacao_caixa,
		n.vl_total_nf,
		n.cd_fornecedor,
		n.de_especie_compra,
		n.de_serie_compra,
		'' dh_vencimento,
		m.de_motivo_devolucao,
		n.de_motivo_devolucao as de_observacao_devolucao
From nf_devolucao_compra As n
	Inner Join nf_compra As c
		On c.cd_filial			= n.cd_filial
	   And c.cd_fornecedor	= n.cd_fornecedor
	   And c.nr_nf				= n.nr_nf_compra
	   And c.de_especie		= n.de_especie_compra
	   And c.de_serie			= n.de_serie_compra
	Left Outer Join motivo_devolucao_compra As m
		On m.cd_motivo_devolucao = n.cd_motivo_devolucao
	Inner Join filial As f
		On f.cd_filial = n.cd_filial
	Inner Join fornecedor As o
		On o.cd_fornecedor = n.cd_fornecedor
Where n.dh_movimentacao_caixa Between :inicio And :fim
	And n.dh_cancelamento Is Null" arguments=(("inicio", date),("fim", date))  sort="filial_cd_filial A nf_devolucao_compra_dh_movimentacao_caix A fornecedor_nm_razao_social A nf_devolucao_compra_nr_nf A " )
