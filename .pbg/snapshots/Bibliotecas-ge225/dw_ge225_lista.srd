table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="log_exclusao_nf_compra.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=fornecedor_nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="log_exclusao_nf_compra.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="log_exclusao_nf_compra.nr_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="log_exclusao_nf_compra.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="log_exclusao_nf_compra.vl_total_nf" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=datetime updatewhereclause=yes name=dh_exclusao dbname="log_exclusao_nf_compra.dh_exclusao" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo dbname="log_exclusao_nf_compra.de_motivo" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="log_exclusao_nf_compra.de_chave_acesso" )
 column=(type=char(1) updatewhereclause=yes name=id_reimportada dbname="id_reimportada" )
 column=(type=datetime updatewhereclause=yes name=dh_importacao dbname="dh_importacao" )
 column=(type=datetime updatewhereclause=yes name=dh_solicitacao dbname="dh_solicitacao" )
 column=(type=char(100) updatewhereclause=yes name=de_observacao dbname="de_observacao" )
 column=(type=char(40) updatewhereclause=yes name=de_usuario dbname="de_usuario" )
 column=(type=char(1) updatewhereclause=yes name=id_desconhecimento dbname="log_exclusao_nf_compra.id_desconhecimento" )
 retrieve="SELECT l.cd_fornecedor,   
			fo.nm_fantasia,   
			l.cd_filial,           	
			f.nm_fantasia,         	
         	l.nr_nf,   
         	l.dh_movimentacao_caixa,   
         	l.vl_total_nf,
			u.nm_usuario,
			l.dh_exclusao,
			l.de_motivo,
			l.de_chave_acesso,
             nf.id_reimportada,
             nf.dh_importacao,
             nf.dh_solicitacao,
             nf.de_observacao,
             nf.de_usuario, 
			l.id_desconhecimento   
FROM log_exclusao_nf_compra l
INNER JOIN filial f
		on l.cd_filial			 	= f.cd_filial  
INNER JOIN 	 fornecedor fo
		on l.cd_fornecedor 		= fo.cd_fornecedor
LEFT OUTER JOIN  usuario u 
		on u.nr_matricula		= l.nr_matricula_responsavel
LEFT JOIN (   Select a.dh_importacao ,
                     a.de_observacao, 
                     a.dh_solicitacao,
                     b.nm_usuario as de_usuario, 
                     a.de_chave_acesso, a.nr_sequencial , case when a.dh_importacao is not null then 'S' else 'N' end as id_reimportada 
              FROM   nf_compra_reimportacao   a
              INNER  JOIN usuario b on b.nr_matricula = a.nr_matricula_responsavel
              WHERE  a.de_chave_acesso is not null ) nf 
			on nf.de_chave_acesso =  l.de_chave_acesso  
              And nf.nr_sequencial  =  l.nr_sequencial 
WHERE l.dh_exclusao between :dh_inicio and :dh_termino	





  " arguments=(("dh_inicio", date),("dh_termino", date))  sort="dh_movimentacao_caixa A filial_nm_fantasia A " )
