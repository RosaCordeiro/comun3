table(column=(type=char(40) updatewhereclause=yes name=fornecedor_nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="log_exclusao_nf_compra.cd_filial" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="log_exclusao_nf_compra.cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="log_exclusao_nf_compra.nr_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="log_exclusao_nf_compra.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="log_exclusao_nf_compra.vl_total_nf" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=datetime updatewhereclause=yes name=dh_exclusao dbname="log_exclusao_nf_compra.dh_exclusao" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo dbname="log_exclusao_nf_compra.de_motivo" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="log_exclusao_nf_compra.de_chave_acesso" )
 retrieve="  SELECT fo.nm_fantasia,   
         	f.nm_fantasia,   
         	l.cd_filial,   
         	l.cd_fornecedor,   
         	l.nr_nf,   
         	l.dh_movimentacao_caixa,   
         	l.vl_total_nf,
			u.nm_usuario,
			l.dh_exclusao,
			l.de_motivo,
			l.de_chave_acesso
    FROM log_exclusao_nf_compra l
	inner join filial f
		on l.cd_filial			 	= f.cd_filial  
	inner join fornecedor fo
		on l.cd_fornecedor 		= fo.cd_fornecedor
     left outer join usuario u 
		on u.nr_matricula		= l.nr_matricula_responsavel
   WHERE l.dh_exclusao between :dh_inicio and :dh_termino	
  " arguments=(("dh_inicio", date),("dh_termino", date))  sort="dh_movimentacao_caixa A " )
