table(column=(type=decimal(0) updatewhereclause=yes name=nr_recibo_resgate dbname="recibo_resgate_clube.nr_recibo_resgate" dbalias=".nr_recibo_resgate" )
 column=(type=datetime updatewhereclause=yes name=dh_resgate dbname="recibo_resgate_clube.dh_resgate" dbalias=".dh_resgate" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_pontos dbname="recibo_resgate_clube.qt_pontos" dbalias=".qt_pontos" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_resgate dbname="recibo_resgate_clube.id_situacao_resgate" dbalias=".id_situacao_resgate" )
 column=(type=long updatewhereclause=yes name=nr_recibo_farmagora dbname="recibo_resgate_clube.nr_recibo_farmagora" dbalias=".nr_recibo_farmagora" )
 column=(type=char(14) updatewhereclause=yes name=nr_cpf_cgc dbname="cliente.nr_cpf_cgc" dbalias=".nr_cpf_cgc" )
 retrieve="   SELECT nr_recibo_resgate, dh_resgate, qt_pontos, id_situacao_resgate, nr_recibo_farmagora, nr_cpf_cgc
    FROM recibo_resgate_clube r, cliente c
   WHERE r.cd_filial 	= :filial_ecommerce       
     AND r.dh_resgate > '20130601'
	 AND r.id_situacao_resgate IN ('I', 'C') // 'I' = Erro, devolver pontos; 'C' = Conciliado, resgate realizado com sucesso.
      AND r.cd_cliente = c.cd_cliente
" arguments=(("filial_ecommerce", number)) )
