table(column=(type=long updatewhereclause=yes name=item_nf_compra_cd_filial dbname="item_nf_compra.cd_filial" dbalias=".cd_filial" )
 column=(type=long updatewhereclause=yes name=item_nf_compra_nr_nf dbname="item_nf_compra.nr_nf" dbalias=".nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=item_nf_compra_de_especie dbname="item_nf_compra.de_especie" dbalias=".de_especie" )
 column=(type=char(3) updatewhereclause=yes name=item_nf_compra_de_serie dbname="item_nf_compra.de_serie" dbalias=".de_serie" )
 column=(type=long updatewhereclause=yes name=item_nf_compra_cd_natureza_operacao dbname="item_nf_compra.cd_natureza_operacao" dbalias=".cd_natureza_operacao" )
 column=(type=long updatewhereclause=yes name=item_nf_compra_cd_produto dbname="item_nf_compra.cd_produto" dbalias=".cd_produto" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="item_nf_compra_lote.cd_filial" dbalias=".cd_filial" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_nf dbname="item_nf_compra_lote.nr_nf" dbalias=".nr_nf" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=de_especie dbname="item_nf_compra_lote.de_especie" dbalias=".de_especie" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=de_serie dbname="item_nf_compra_lote.de_serie" dbalias=".de_serie" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_natureza_operacao dbname="item_nf_compra_lote.cd_natureza_operacao" dbalias=".cd_natureza_operacao" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="item_nf_compra_lote.cd_produto" dbalias=".cd_produto" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=nr_lote dbname="item_nf_compra_lote.nr_lote" dbalias=".nr_lote" )
 column=(type=long update=yes updatewhereclause=yes name=qt_lote dbname="item_nf_compra_lote.qt_lote" dbalias=".qt_lote" )
 column=(type=char(9) update=yes updatewhereclause=yes key=yes name=cd_fornecedor dbname="item_nf_compra_lote.cd_fornecedor" dbalias=".cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=quantidade dbname="item_nf_compra.qt_faturada" dbalias=".qt_faturada" )
 column=(type=long updatewhereclause=yes name=cd_produto_nf_compra dbname="produto_geral.cd_produto" dbalias=".cd_produto" )
 column=(type=char(108) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=protege dbname="Protege" initial="L" )
 retrieve=" SELECT  item_nf_compra.cd_filial,   
         item_nf_compra.nr_nf,   
         item_nf_compra.de_especie,   
         item_nf_compra.de_serie,   
         item_nf_compra.cd_natureza_operacao,   
         item_nf_compra.cd_produto, 
         item_nf_compra_lote.cd_filial, 
         item_nf_compra_lote.nr_nf,   
         item_nf_compra_lote.de_especie,   
         item_nf_compra_lote.de_serie,   
         item_nf_compra_lote.cd_natureza_operacao,   
         item_nf_compra_lote.cd_produto, 
         item_nf_compra_lote.nr_lote,   
         item_nf_compra_lote.qt_lote,
         item_nf_compra_lote.cd_fornecedor,   
         item_nf_compra.qt_faturada,   
         produto_geral.cd_produto,  
         produto_geral.de_produto + ' : ' + produto_geral.de_apresentacao_estoque + ' (' + produto_geral.cd_grupo_psico + ')' de_produto,
         f.nm_fantasia,
			'L' as Protege
    FROM item_nf_compra,
         item_nf_compra_lote,
         produto_geral,
         filial f
   WHERE ( item_nf_compra.cd_filial                 = :pl_filial ) AND
         ( item_nf_compra.cd_fornecedor             = :ps_fornecedor ) AND       
         ( item_nf_compra.nr_nf                     = :pl_nr_nf ) AND  
         ( item_nf_compra.de_especie                = :ps_especie ) AND  
         ( item_nf_compra.de_serie                  = :ps_serie ) AND
  		   ( item_nf_compra_lote.cd_filial            = item_nf_compra.cd_filial ) AND  
			( item_nf_compra_lote.nr_nf                = item_nf_compra.nr_nf ) AND 
         ( item_nf_compra_lote.cd_fornecedor        = item_nf_compra.cd_fornecedor) AND 
			( item_nf_compra_lote.de_especie           = item_nf_compra.de_especie ) AND  
			( item_nf_compra_lote.de_serie             = item_nf_compra.de_serie ) AND  
			( item_nf_compra_lote.cd_natureza_operacao = item_nf_compra.cd_natureza_operacao ) AND  
			( item_nf_compra_lote.cd_produto           = item_nf_compra.cd_produto ) AND
         ( f.cd_filial                              = item_nf_compra.cd_filial ) AND
         ( produto_geral.cd_produto                 = item_nf_compra.cd_produto ) and
		(produto_geral.cd_grupo_psico is not null)

  
" update="item_nf_compra_lote" updatewhere=0 updatekeyinplace=no arguments=(("pl_filial", number),("ps_fornecedor", string),("pl_nr_nf", number),("ps_especie", string),("ps_serie", string))  sort="de_produto A nr_linha A " )
