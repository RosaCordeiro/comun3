table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="item_nf_devolucao_compra_lote.cd_filial" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_nf dbname="item_nf_devolucao_compra_lote.nr_nf" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=de_especie dbname="item_nf_devolucao_compra_lote.de_especie" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=de_serie dbname="item_nf_devolucao_compra_lote.de_serie" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_natureza_operacao dbname="item_nf_devolucao_compra_lote.cd_natureza_operacao" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="item_nf_devolucao_compra_lote.cd_produto" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=nr_lote dbname="item_nf_devolucao_compra_lote.nr_lote" )
 column=(type=long update=yes updatewhereclause=yes name=qt_lote dbname="item_nf_devolucao_compra_lote.qt_lote" )
 column=(type=long updatewhereclause=yes name=quantidade dbname="item_nf_devolucao_compra.qt_devolvida" )
 column=(type=char(108) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 retrieve="SELECT  l.cd_filial,    
			l.nr_nf,   
			l.de_especie,   
			l.de_serie,   
			l.cd_natureza_operacao,  
			l.cd_produto, 
			l.nr_lote,   
			l.qt_lote,   
			i.qt_devolvida,   
			g.de_produto || ' : ' || g.de_apresentacao_estoque || ' (' || g.cd_grupo_psico || ')' de_produto,
			f.nm_fantasia
    FROM item_nf_devolucao_compra			i,
			item_nf_devolucao_compra_lote	l,
			produto_geral							g,
			filial 										f
 WHERE  i.cd_filial                 		= :pl_filial
	  AND	i.nr_nf                     		= :pl_nr_nf
	  AND	i.de_especie                	= :ps_especie
	  AND	i.de_serie                  	= :ps_serie
	  AND	l.cd_filial            			= i.cd_filial
	  AND	l.nr_nf                			= i.nr_nf
	  AND	l.de_especie           		= i.de_especie
	  AND	l.de_serie             		= i.de_serie
	  AND	l.cd_natureza_operacao	= i.cd_natureza_operacao
	  AND	l.cd_produto           		= i.cd_produto
	  AND	f.cd_filial                       = i.cd_filial
	  AND	g.cd_produto                 = i.cd_produto" update="item_nf_devolucao_compra_lote" updatewhere=1 updatekeyinplace=no arguments=(("pl_filial", number),("pl_nr_nf", number),("ps_especie", string),("ps_serie", string))  sort="de_produto A nr_linha A " )
