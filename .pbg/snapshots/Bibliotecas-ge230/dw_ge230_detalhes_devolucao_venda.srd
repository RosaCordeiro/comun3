table(column=(type=long updatewhereclause=yes name=item_nf_devolucao_venda_cd_filial dbname="item_nf_devolucao_venda.cd_filial" )
 column=(type=long updatewhereclause=yes name=item_nf_devolucao_venda_nr_nf dbname="item_nf_devolucao_venda.nr_nf" )
