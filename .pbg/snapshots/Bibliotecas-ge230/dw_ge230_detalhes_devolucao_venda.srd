 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_nf dbname="item_nf_devolucao_venda_lote.nr_nf" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=de_especie dbname="item_nf_devolucao_venda_lote.de_especie" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=de_serie dbname="item_nf_devolucao_venda_lote.de_serie" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_natureza_operacao dbname="item_nf_devolucao_venda_lote.cd_natureza_operacao" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="item_nf_devolucao_venda_lote.cd_produto" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=nr_lote dbname="item_nf_devolucao_venda_lote.nr_lote" )
 column=(type=long update=yes updatewhereclause=yes name=qt_lote dbname="item_nf_devolucao_venda_lote.qt_lote" )
 column=(type=char(1) update=yes updatewhereclause=yes key=yes name=id_origem_nf dbname="item_nf_devolucao_venda_lote.id_origem_nf" )
 column=(type=long updatewhereclause=yes name=quantidade dbname="item_nf_devolucao_venda.qt_devolvida" )
 column=(type=long updatewhereclause=yes name=produto_geral_cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(108) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" )
 retrieve=" SELECT  item_nf_devolucao_venda.cd_filial,   
         item_nf_devolucao_venda.nr_nf,   
         item_nf_devolucao_venda.de_especie,   
         item_nf_devolucao_venda.de_serie,           
         item_nf_devolucao_venda.cd_natureza_operacao,   
         item_nf_devolucao_venda.cd_produto, 
         item_nf_devolucao_venda_lote.cd_filial,    
         item_nf_devolucao_venda_lote.nr_nf,   
         item_nf_devolucao_venda_lote.de_especie,   
         item_nf_devolucao_venda_lote.de_serie,          
         item_nf_devolucao_venda_lote.cd_natureza_operacao,  
    	 	item_nf_devolucao_venda_lote.cd_produto, 
         item_nf_devolucao_venda_lote.nr_lote,   
         item_nf_devolucao_venda_lote.qt_lote, 
         item_nf_devolucao_venda_lote.id_origem_nf,            
         item_nf_devolucao_venda.qt_devolvida,   
         produto_geral.cd_produto, 
         produto_geral.de_produto + ' : ' + produto_geral.de_apresentacao_estoque + ' (' + produto_geral.cd_grupo_psico + ')' de_produto, 
         f.nm_fantasia 
    FROM item_nf_devolucao_venda,
         item_nf_devolucao_venda_lote,
         produto_geral,
         filial f
   WHERE ( item_nf_devolucao_venda.cd_filial                 = :pl_filial ) AND            
         ( item_nf_devolucao_venda.nr_nf                     = :pl_nr_nf ) AND  
         ( item_nf_devolucao_venda.de_especie                = :ps_especie ) AND  
         ( item_nf_devolucao_venda.de_serie                  = :ps_serie ) AND
         ( item_nf_devolucao_venda.id_origem_nf              = :ps_id_origem_nf ) AND           
  		   ( item_nf_devolucao_venda_lote.cd_filial            = item_nf_devolucao_venda.cd_filial ) AND  
			( item_nf_devolucao_venda_lote.nr_nf                = item_nf_devolucao_venda.nr_nf ) AND  
			( item_nf_devolucao_venda_lote.de_especie           = item_nf_devolucao_venda.de_especie ) AND  
			( item_nf_devolucao_venda_lote.de_serie             = item_nf_devolucao_venda.de_serie ) AND  
			( item_nf_devolucao_venda_lote.cd_natureza_operacao = item_nf_devolucao_venda.cd_natureza_operacao ) AND  
			( item_nf_devolucao_venda_lote.cd_produto           = item_nf_devolucao_venda.cd_produto ) AND
         ( item_nf_devolucao_venda_lote.id_origem_nf         = item_nf_devolucao_venda.id_origem_nf ) AND
         ( f.cd_filial                                       = item_nf_devolucao_venda.cd_filial ) AND
         ( produto_geral.cd_produto                          = item_nf_devolucao_venda.cd_produto )

  
" update="item_nf_devolucao_venda_lote" updatewhere=0 updatekeyinplace=no arguments=(("pl_filial", number),("pl_nr_nf", number),("ps_especie", string),("ps_serie", string),("ps_id_origem_nf", string))  sort="de_produto A nr_linha A " )
