table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial_origem dbname="item_nf_transferencia_lote.cd_filial_origem" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_nf dbname="item_nf_transferencia_lote.nr_nf" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=de_especie dbname="item_nf_transferencia_lote.de_especie" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=de_serie dbname="item_nf_transferencia_lote.de_serie" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_natureza_operacao dbname="item_nf_transferencia_lote.cd_natureza_operacao" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="item_nf_transferencia_lote.cd_produto" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=nr_lote dbname="item_nf_transferencia_lote.nr_lote" )
 column=(type=long update=yes updatewhereclause=yes name=qt_lote dbname="item_nf_transferencia_lote.qt_lote" )
 column=(type=char(11) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="item_nf_transferencia.qt_faturada" )
 column=(type=char(108) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=protege dbname="protege" initial="L" )
 retrieve=" SELECT	l.cd_filial_origem	AS cd_filial_origem, 
			l.nr_nf				AS nr_nf,   
			l.de_especie			AS de_especie,   
			l.de_serie			AS de_serie,   
			l.cd_natureza_operacao	AS cd_natureza_operacao,   
			l.cd_produto					AS cd_produto, 
			l.nr_lote						AS nr_lote,   
			l.qt_lote						AS qt_lote,
			CAST( l.cd_filial_origem AS VARCHAR )	AS cd_fornecedor,   
			i.qt_transferida									AS qt_faturada,   
			g.de_produto + ' : ' + g.de_apresentacao_estoque + ' (' + g.cd_grupo_psico + ')' AS de_produto,
			f.nm_fantasia									AS nm_fantasia,
			'L'													AS Protege
    FROM nf_transferencia n
			INNER JOIN	item_nf_transferencia 	i
			  ON n.cd_filial_origem			= i.cd_filial_origem 
			AND n.nr_nf							= i.nr_nf
			AND n.de_especie					= i.de_especie
			AND n.de_serie						= i.de_serie
			LEFT OUTER JOIN	item_nf_transferencia_lote	l
			  ON l.cd_filial_origem			= i.cd_filial_origem 
			AND l.nr_nf							= i.nr_nf
			AND l.de_especie					= i.de_especie
			AND l.de_serie						= i.de_serie
			AND l.cd_natureza_operacao	= i.cd_natureza_operacao
		  INNER JOIN produto_geral	g
			  ON g.cd_produto	= i.cd_produto
			INNER JOIN	filial	f
				ON f.cd_filial = i.cd_filial_origem
  WHERE i.cd_filial_origem			= :pl_filial						AND
			i.nr_nf						= :pl_nr_nf						AND  
			i.de_especie					= :ps_especie					AND  
			i.de_serie					= :ps_serie
	  AND g.cd_grupo_psico IS NOT NULL
	  AND g.cd_grupo_psico NOT LIKE ( SELECT vl_parametro
													FROM parametro_loja as p
											  	  WHERE p.cd_parametro = 'CD_GRUPO_NAO_PSICO' )
	 AND n.dh_movimentacao_caixa >= '20130410'" update="item_nf_transferencia_lote" updatewhere=0 updatekeyinplace=no arguments=(("pl_filial", number),("pl_nr_nf", number),("ps_especie", string),("ps_serie", string))  sort="de_produto A nr_linha A " )
