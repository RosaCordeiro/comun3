table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_compra.cd_filial" dbalias="n.cd_filial" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="nf_compra.cd_fornecedor" dbalias="n.cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_compra.nr_nf" dbalias="n.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_compra.de_especie" dbalias="n.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_compra.de_serie" dbalias="n.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_compra.dh_movimentacao_caixa" dbalias="n.dh_movimentacao_caixa" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" dbalias="f.nm_razao_social" )
 column=(type=char(1) updatewhereclause=yes name=id_liberado dbname="id_liberado" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(6) updatewhereclause=yes name=de_tipo_mvto dbname="de_tipo_mvto" )
 retrieve="  SELECT n.cd_filial,   
         n.cd_fornecedor,   
         n.nr_nf,   
         n.de_especie,   
         n.de_serie,   
         n.dh_movimentacao_caixa,      
         f.nm_razao_social,
         ''id_liberado,
		'COMPRA' as de_tipo_mvto
    FROM fornecedor f,   
         nf_compra n         
   WHERE n.cd_filial in (select cd_filial from parametro where id_parametro = '1')
	and n.cd_fornecedor 		 	  = f.cd_fornecedor
     and n.dh_movimentacao_caixa between :inicio and :termino
     and n.dh_atualizacao_estoque is not null
     and n.id_estoque_automatico 		= 'N'
     and exists (select * from item_nf_compra i, produto_geral p, parametro_loja pl
				 where n.cd_filial     = i.cd_filial
				   and n.cd_fornecedor = i.cd_fornecedor
				   and n.nr_nf		     = i.nr_nf
				   and n.de_especie    = i.de_especie
				   and n.de_serie	     = i.de_serie
  				   and i.cd_produto    = p.cd_produto
				   and p.cd_grupo_psico is not null
					and pl.cd_parametro	  = 'CD_GRUPO_NAO_PSICO'
					and pl.vl_parametro not like '%'+ p.cd_grupo_psico + '%'
				)

union

  SELECT n.cd_filial,   
         n.cd_fornecedor,   
         n.nr_nf,   
         n.de_especie,   
         n.de_serie,   
         n.dh_movimentacao_caixa,      
         f.nm_razao_social,
         ''id_liberado,
		'COMPRA' as de_tipo_mvto
    FROM fornecedor f,   
         nf_compra n         
   WHERE n.cd_filial in (select cd_filial from parametro where id_parametro = '1')
     and n.cd_fornecedor 		 	  = f.cd_fornecedor
     and n.dh_movimentacao_caixa between :inicio and :termino
     and n.dh_atualizacao_estoque is null
     and (n.id_estoque_automatico <> 'N' or n.id_estoque_automatico is null)
     and exists (select * from item_nf_compra i, produto_geral p, parametro_loja pl
				 where n.cd_filial     = i.cd_filial
				   and n.cd_fornecedor = i.cd_fornecedor
				   and n.nr_nf		     = i.nr_nf
				   and n.de_especie    = i.de_especie
				   and n.de_serie	     = i.de_serie
  				   and i.cd_produto    = p.cd_produto
				   and p.cd_grupo_psico is not null
					and pl.cd_parametro	  = 'CD_GRUPO_NAO_PSICO'
					and pl.vl_parametro not like '%'+ p.cd_grupo_psico + '%')
" arguments=(("inicio", date),("termino", date)) )
