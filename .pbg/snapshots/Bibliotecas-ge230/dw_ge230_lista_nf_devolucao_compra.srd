table(column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="nf_devolucao_compra.cd_filial" dbalias="n.cd_filial" )
 column=(type=long update=yes updatewhereclause=yes name=nr_nf dbname="nf_devolucao_compra.nr_nf" dbalias="n.nr_nf" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_especie dbname="nf_devolucao_compra.de_especie" dbalias="n.de_especie" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_serie dbname="nf_devolucao_compra.de_serie" dbalias="n.de_serie" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_devolucao_compra.dh_movimentacao_caixa" dbalias="n.dh_movimentacao_caixa" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" dbalias="f.nm_razao_social" )
 column=(type=char(1) updatewhereclause=yes name=id_liberado dbname="id_liberado" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_nfe dbname="nf_devolucao_compra_nfe.id_situacao_nfe" dbalias="e.id_situacao_nfe" )
 retrieve="  SELECT n.cd_filial,  
         n.nr_nf,   
         n.de_especie, 
         n.de_serie,  
         n.dh_movimentacao_caixa,    
         f.nm_razao_social, 
         ''id_liberado,
		e.id_situacao id_situacao_nfe
    FROM fornecedor f,   
         		nf_devolucao_compra n,
			nf_devolucao_compra_nfe e		
   WHERE n.cd_filial in (select cd_filial from parametro where id_parametro = '1')
	and n.cd_fornecedor 		 = f.cd_fornecedor
     and e.cd_filial					= n.cd_filial
     and e.nr_nf						= n.nr_nf
     and e.de_especie				= n.de_especie
     and e.de_serie					= n.de_serie
     and n.dh_movimentacao_caixa between :inicio and :termino
     AND n.dh_cancelamento is null
     and exists (select * from item_nf_devolucao_compra_lote i
				 where n.cd_filial     = i.cd_filial
				   and n.nr_nf		   = i.nr_nf
				   and n.de_especie    = i.de_especie
				   and n.de_serie	   = i.de_serie)
  				    
				   
" arguments=(("inicio", date),("termino", date)) )
