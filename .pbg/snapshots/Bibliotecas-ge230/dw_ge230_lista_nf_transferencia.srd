table(column=(type=char(40) updatewhereclause=yes name=nm_fantasia_destino dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="nf_transferencia.cd_filial_origem" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="nf_transferencia.cd_filial_destino" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_transferencia.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_transferencia.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_transferencia.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_transferencia.dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="nf_transferencia.cd_filial_origem" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="nf_transferencia.dh_cancelamento" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_cancelamento dbname="nf_transferencia.nr_matricula_cancelamento" )
 column=(type=char(1) updatewhereclause=yes name=id_liberado dbname="id_liberado" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 retrieve="  SELECT f.nm_fantasia,   
         n.cd_filial_origem,   
         n.cd_filial_destino,
         n.nr_nf,   
         n.de_especie,   
         n.de_serie,   
         n.dh_movimentacao_caixa,   
         n.cd_filial_origem,   
         n.dh_cancelamento,   
         n.nr_matricula_cancelamento,
         space(1) id_liberado
    FROM nf_transferencia n,   
         filial f,
		 parametro p
   WHERE n.cd_filial_destino = f.cd_filial 
     AND n.dh_cancelamento is null
     AND n.dh_movimentacao_caixa between :inicio and :termino
     and exists (select * from item_nf_transferencia_lote i
				 where n.cd_filial_origem = i.cd_filial_origem
				   and n.nr_nf            = i.nr_nf
				   and n.de_especie		  = i.de_especie
    			   and n.de_serie		     = i.de_serie)
	and n.cd_filial_origem in (Select cd_filial from parametro
							   Where id_parametro = '1')	
							




" arguments=(("inicio", date),("termino", date))  sort="nr_nf A de_especie A de_serie A " )
