          ajuste_estoque.de_comentario_ajuste ,
          ajuste_estoque.vl_custo_unitario ,
          ''nm_produto,
          ajuste_estoque.nr_lote ,
          ajuste_estoque.nr_ajuste
       FROM ajuste_estoque    " update="ajuste_estoque" updatewhere=0 updatekeyinplace=no )
