table(column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="compute_0001" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_grupo dbname="compute_0002" )
 retrieve="select substring(p.cd_subcategoria, 1, 1),
       sum(r.vl_venda)
  from produto_geral p,
       resumo_produto_filial r
 where r.cd_produto = p.cd_produto and
       r.cd_filial in (:filial) and
       r.cd_filial > 0 and
       r.dh_resumo = :inicio
 group by substring(p.cd_subcategoria, 1, 1)
" arguments=(("filial", numberlist),("inicio", datetime))  sort="vl_venda_grupo D " )
