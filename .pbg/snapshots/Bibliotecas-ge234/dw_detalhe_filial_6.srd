table(column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="compute_0001" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_perda dbname="vl_perda" )
 retrieve="  SELECT substring(pg.cd_subcategoria, 1, 1),
         sum(ppc.qt_consultas * pg.vl_preco_venda_atual / pg.vl_fator_conversao) vl_perda
    FROM produto_procura_cliente ppc,   
         produto_geral pg
   WHERE ppc.cd_filial in (:filial) and
         ppc.dh_procura between :inicio and :termino
     and pg.cd_produto = ppc.cd_produto
GROUP BY substring(pg.cd_subcategoria, 1, 1)" arguments=(("inicio", datetime),("termino", datetime),("filial", numberlist)) )
