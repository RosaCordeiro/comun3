table(column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="cd_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="grupo.de_grupo" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_venda_bruta dbname="vl_venda_bruta" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda dbname="vl_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cmv dbname="vl_cmv" )
 column=(type=long updatewhereclause=yes name=qt_venda dbname="qt_venda" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_icms dbname="vl_icms" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_pis_cofins dbname="vl_pis_cofins" )
 retrieve="select	 substring(g.cd_subcategoria, 1, 1) as cd_grupo,
		 gp.de_grupo,
		 sum(round((r.qt_venda - r.qt_devolucao_venda) * g.vl_preco_venda_atual / g.vl_fator_conversao,2)) as vl_venda_bruta,
		 sum(r.vl_venda) as vl_venda,
		 sum(r.vl_cmv) as vl_cmv,
		 sum(r.qt_venda - r.qt_devolucao_venda) as qt_venda,
		 sum(case g.cd_tributacao_icms
				 when '1' then round((r.vl_cmv_gerencial - r.vl_cmv), 2)
				 else round(r.vl_venda * g.pc_imposto / 100, 2)
			  end) as vl_icms,
		 sum(case g.id_situacao_pis_cofins
				 when 'T' then round(r.vl_venda * (cast(p.vl_parametro as numeric(5,2)) / 100), 2)
				 else 0
			  end) as vl_pis_cofins	
from resumo_produto_filial r
Inner Join produto_geral g
	on g.cd_produto = r.cd_produto
Inner Join grupo gp
	on gp.cd_grupo = substring(g.cd_subcategoria, 1, 1)
Left outer Join parametro_geral p
  on p.cd_parametro	= 'PC_PIS_COFINS_RENTABILIDADE'
where r.dh_resumo	= :data_base
  and r.cd_filial       in (:filial)
  and r.cd_filial       > 0
group by substring(g.cd_subcategoria, 1, 1),  gp.de_grupo" arguments=(("data_base", datetime),("filial", numberlist)) )
