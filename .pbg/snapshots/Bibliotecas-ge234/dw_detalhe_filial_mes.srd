table(column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="grupo.de_grupo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_vendas dbname="vl_vendas" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_estoque dbname="vl_estoque" )
 column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="grupo.cd_grupo" )
 column=(type=decimal(2) updatewhereclause=yes name=nr_dias dbname="nr_dias" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_faltas dbname="pc_faltas" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_rentab dbname="pc_rentab" )
 column=(type=decimal(2) updatewhereclause=yes name=tot_rentab dbname="tot_rentab" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_total_perda dbname="pc_total_perda" )
 column=(type=decimal(2) updatewhereclause=yes name=nr_dias_total dbname="nr_dias_total" )
 retrieve="  SELECT grupo.de_grupo,   
         0.00 vl_vendas,   
         0.00 vl_estoque,   
         grupo.cd_grupo,   
         0.00 nr_dias,   
         0.00 pc_faltas,   
         0.00 pc_rentab,   
         0.00 tot_rentab,
         0.00 pc_total_perda,
         0.00 nr_dias_total
    FROM grupo   
"  sort="vl_vendas D " )
