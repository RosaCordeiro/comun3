table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_porte dbname="cd_porte" )
 column=(type=char(1) updatewhereclause=yes name=id_abre_domingo dbname="filial.id_abre_domingo" )
 column=(type=char(40) updatewhereclause=yes name=vl_parametro dbname="parametro_loja.vl_parametro" )
 column=(type=decimal(2) updatewhereclause=yes name=liquida_dia dbname="liquida_dia" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cota_dia dbname="vl_cota_dia" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_mes dbname="vl_venda_mes" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cota_mes dbname="vl_cota_mes" )
 column=(type=long updatewhereclause=yes name=num_cliente_mes dbname="num_cliente_mes" )
 column=(type=long updatewhereclause=yes name=num_cliente_dia dbname="num_cliente_dia" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_ano dbname="vl_venda_ano" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cota_ano dbname="vl_cota_ano" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_media_ano dbname="vl_media_ano" )
 column=(type=long updatewhereclause=yes name=nr_cliente dbname="nr_cliente" )
 column=(type=long updatewhereclause=yes name=nr_dias dbname="nr_dias" )
 column=(type=char(1) updatewhereclause=yes name=id_filial_disque_entrega dbname="id_filial_disque_entrega" )
 retrieve="select case r.cd_filial when 11 then 768 when 12 then 769 else r.cd_filial end cd_filial,
       case f.nm_fantasia when 'PF_PROFORMULA MATRIZ' then 'PROFORMULA JK' when 'PF_PROFORMULA FILIAL' then 'PROFORMULA  BL' else f.nm_fantasia end nm_fantasia,
      fp.cd_porte as cd_porte, 
		f.id_abre_domingo,
       p.vl_parametro,
       0.00 liquida_dia,
       0.00 vl_cota_dia,
       0.00 vl_venda_mes,
       0.00 vl_cota_mes,
       0 num_cliente_mes,
       0 num_cliente_dia,
       sum(r.vl_venda_avista + r.vl_venda_cartao_debito + r.vl_venda_cheque_avista + r.vl_venda_crediario + r.vl_venda_convenio + r.vl_venda_conta_corrente + r.vl_venda_cartao_credito + r.vl_venda_cheque_aprazo - r.vl_devolucao_venda) vl_venda_ano,
       0.00 vl_cota_ano,
       0.00 vl_media_ano,
       sum(r.qt_cliente_venda - r.qt_cliente_devolucao) nr_cliente,
       count(r.dh_resumo) nr_dias,
		'N' id_filial_disque_entrega
from resumo_movimento_estoque r
inner join  filial f
	on   f.cd_filial = r.cd_filial
Inner join parametro_loja p
	on p.cd_filial = r.cd_filial 
	and p.cd_parametro = 'ID_REDE_FILIAL'
INNER JOIN (SELECT fp1.cd_filial, fp1.cd_porte 
						FROM filial_porte fp1
						WHERE		  fp1.dh_porte = (SELECT max(fp2.dh_porte) 
														FROM filial_porte fp2
														WHERE fp2.cd_filial = fp1.cd_filial
														AND fp1.dh_porte <=  :fim)) fp
	on fp.cd_filial = f.cd_filial
where r.dh_resumo between :inicio and :fim 
and   r.cd_filial not in (1)
and ( f.nm_fantasia not like '%ECOMMERCE%'  and 
		 f.nm_fantasia not like '%E-COMM%' and 
		 f.nm_fantasia not like '%XX%' )
group by case r.cd_filial when 11 then 768 when 12 then 769 else r.cd_filial end,
         case f.nm_fantasia when 'PF_PROFORMULA MATRIZ' then 'PROFORMULA JK' when 'PF_PROFORMULA FILIAL' then 'PROFORMULA  BL' else f.nm_fantasia end,
	      fp.cd_porte,   
		f.id_abre_domingo,
         p.vl_parametro



//// ESTAVA COM LEFT OUTER JOIN  NA PARTE DA filial_porte
///and ( f.nm_fantasia not like '%ECOMMERCE%'  and 
//		 f.nm_fantasia not like '%E-COMM%' and 
//		 f.nm_fantasia not like '%XX%' )
" filter="vl_venda_ano>0 or vl_cota_ano>0"arguments=(("inicio", datetime),("fim", date))  sort="pc_cota_atingida D " )
