table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=decimal(2) updatewhereclause=yes name=venda dbname="venda" )
 column=(type=long updatewhereclause=yes name=nr_cliente dbname="nr_cliente" )
 retrieve="select case r.cd_filial when 11 then 768 when 12 then 769 else r.cd_filial end cd_filial,
       r.vl_venda_avista + r.vl_venda_cartao_debito + r.vl_venda_cheque_avista + r.vl_venda_crediario + r.vl_venda_convenio + r.vl_venda_conta_corrente + r.vl_venda_cartao_credito + r.vl_venda_cheque_aprazo - r.vl_devolucao_venda venda,
       r.qt_cliente_venda - r.qt_cliente_devolucao nr_cliente
from resumo_movimento_estoque r (index pk_resumo_movto_estoque)
inner join filial f
	on f.cd_filial = r.cd_filial
where r.dh_resumo = :inicio

" arguments=(("inicio", date))  sort="cd_filial A " )
