table(column=(type=long updatewhereclause=yes name=cd_produto dbname="resumo_transferencia_perini.cd_produto" )
 column=(type=char(104) updatewhereclause=yes name=ctem_nf_transferencia_cd_produto dbname="" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="vw_saldo_atual_produto.qt_saldo_final" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="wms_endereco_produto.cd_endereco" )
 column=(type=long updatewhereclause=yes name=qt_venda dbname="qt_venda" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_nova dbname="cd_classe_nova" )
 retrieve="select 	n.cd_produto, 
			g.de_produto + '  : ' + g.de_apresentacao_estoque, 
			g.cd_grupo_psico,
			g.de_codigo_barras, 
			v.qt_saldo_final,
			e.cd_endereco,
			sum(qt_transferida) qt_venda,
			 '' cd_classe_nova
from resumo_transferencia_perini n
inner join produto_geral g on g.cd_produto = n.cd_produto
inner join vw_saldo_atual_produto v on v.cd_filial	= 534 and v.cd_produto	= n.cd_produto
left join wms_endereco_produto e on e.cd_produto = n.cd_produto
where n.dh_resumo between :inicio and :termino
	and g.id_situacao = 'A'
group by n.cd_produto, g.de_produto, g.de_apresentacao_estoque, g.cd_grupo_psico, g.de_codigo_barras, v.qt_saldo_final, e.cd_endereco
order by qt_venda desc" arguments=(("inicio", date),("termino", date)) )
text(band=header alignment="2" text="Cd Produto" border="0" color="0" x="14" y="4" height="64" width="329" html.valueishtml="0"  name=cd_produto_t visible="1"  font.face="Arial" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" background.transparency="0" background.gradient.color="8421504" background.gradient.transparency="0" background.gradient.angle="0" background.brushmode="0" background.gradient.repetition.mode="0" background.gradient.repetition.count="0" background.gradient.repetition.length="100" background.gradient.focus="0" background.gradient.scale="100" background.gradient.spread="100" tooltip.backcolor="134217752" tooltip.delay.initial="0" tooltip.delay.visible="32000" tooltip.enabled="0" tooltip.hasclosebutton="0" tooltip.icon="0" tooltip.isbubble="0" tooltip.maxwidth="0" tooltip.textcolor="134217751" tooltip.transparency="0" transparency="0" )
