table(column=(type=long updatewhereclause=yes name=cd_produto dbname="resumo_reposicao_estoque.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="vw_classificacao_produto.de_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo dbname="vw_classificacao_produto.de_subgrupo" )
 column=(type=char(40) updatewhereclause=yes name=de_categoria dbname="vw_classificacao_produto.de_categoria" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="vw_classificacao_produto.de_subcategoria" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=char(4) updatewhereclause=yes name=tipo_reposicao dbname="TIPO_REPOSICAO" )
 column=(type=char(1) updatewhereclause=yes name=curva dbname="resumo_reposicao_estoque.CURVA" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="resumo_reposicao_estoque.qt_estoque_base" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="vw_saldo_atual_produto.qt_saldo_final" )
 column=(type=long updatewhereclause=yes name=qt_venda_perdida dbname="qt_venda_perdida" )
 column=(type=long updatewhereclause=yes name=qt_transf_receb dbname="qt_transf_receb" )
 column=(type=long updatewhereclause=yes name=qt_venda dbname="qt_venda" )
 column=(type=long updatewhereclause=yes name=med_venda dbname="med_venda" )
 column=(type=long updatewhereclause=yes name=eb_novo dbname="resumo_reposicao_estoque.eb_novo" )
 column=(type=long updatewhereclause=yes name=nr_dias_bloqueio dbname="nr_dias_bloqueio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_bloqueio dbname="resumo_reposicao_estoque.dh_termino_bloqueio" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao dbname="dh_movimentacao" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao dbname="resumo_reposicao_estoque.dh_alteracao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_alteracao dbname="resumo_reposicao_estoque.nr_matricula_alteracao" )
 column=(type=char(1) updatewhereclause=yes name=nm_alteracao dbname="nm_alteracao" )
 column=(type=char(3) updatewhereclause=yes name=id_psico dbname="id_psico" )
 column=(type=char(3) updatewhereclause=yes name=id_antibiotico dbname="id_antibiotico" )
 retrieve="select 	r.cd_produto,
			g.de_produto + ' : ' + g.de_apresentacao_estoque as de_produto,
			v.de_grupo, 
			v.de_subgrupo,
			v.de_categoria,
			v.de_subcategoria,
			g.vl_fator_conversao, 
         	(CASE WHEN r.id_tipo_reposicao = 'E' THEN 'EST.' ELSE 'SAZ.' END) AS TIPO_REPOSICAO,  
         	r.cd_classe_reposicao CURVA,   
         	r.qt_estoque_base,  
			s.qt_saldo_final,
			(select coalesce(sum(ppc.qt_consulta), 0)
			 from produto_procurado_zerado ppc (index idx_dt_fil_produto) 
			Where ppc.cd_filial = r.cd_filial
				 and ppc.cd_produto = r.cd_produto
				and ppc.dh_movimentacao  >= :movimentacao
				and ppc.id_tipo = 'F') qt_venda_perdida,
			0 qt_transf_receb,
			0 qt_venda,
			0 med_venda,
			r.qt_estoque_base eb_novo,
			0 nr_dias_bloqueio,
			r.dh_termino_bloqueio,
			(select dh_movimentacao from parametro where id_parametro = '1') dh_movimentacao,
			r.dh_alteracao,
			r.nr_matricula_alteracao,
			'' nm_alteracao,
	    		(Case when g.cd_grupo_psico is not null and substring(g.cd_grupo_psico,1,1) <> 'W' Then 'SIM' else 'N$$HEX1$$c300$$ENDHEX$$O' END) as id_psico,
			(Case when g.cd_grupo_psico is not null and substring(g.cd_grupo_psico,1,1) = 'W' Then 'SIM' else 'N$$HEX1$$c300$$ENDHEX$$O' END) as id_antibiotico 			

from resumo_reposicao_estoque r
inner join produto_geral g
	on g.cd_produto = r.cd_produto
inner join vw_classificacao_produto v
	on v.cd_subcategoria = g.cd_subcategoria
inner join vw_saldo_atual_produto s 
	on s.cd_filial = r.cd_filial
	and s.cd_produto = r.cd_produto
where r.cd_filial = :filial
  and s.qt_saldo_final = 0
  and g.id_situacao = 'A'




" arguments=(("filial", number),("movimentacao", datetime))  sort="de_produto A " )
