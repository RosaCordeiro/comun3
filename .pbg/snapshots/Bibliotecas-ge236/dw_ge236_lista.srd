table(column=(type=long updatewhereclause=yes name=cd_filial dbname="parametro_reposicao_estoque.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(30) updatewhereclause=yes name=nm_bloqueio dbname="de_bloqueio" )
 column=(type=long updatewhereclause=yes name=dias_movimento dbname="DIAS_MOVIMENTO" )
 retrieve="select p.cd_filial, 
		f.nm_fantasia,  
		case blo.de_bloqueio  when null then 'N$$HEX1$$c300$$ENDHEX$$O BLOQUEIA' else blo.de_bloqueio end as de_bloqueio,
		(	Select count(*)
			From resumo_movimento_estoque r
			where	r.vl_venda_avista 	> 0
			and 	r.dh_resumo 			>= (	select dateadd(day, -110, dh_movimentacao) 
														from parametro where id_parametro = '1') 
													  	and r.cd_filial = p.cd_filial) as  DIAS_MOVIMENTO
from parametro_reposicao_estoque p
inner join filial f
	on f.cd_filial = p.cd_filial
left join tipo_bloqueia_pedido_psico blo
	on blo.id_bloqueio = f.id_bloqueia_pedido_psico
where p.id_tipo_reposicao = 'E'
  and p.cd_filial in (Select cd_filial
						From resumo_movimento_estoque
						where	vl_venda_avista 	> 0
						 and 	dh_resumo 			>= (select dateadd(day, -110, dh_movimentacao) from parametro where id_parametro = '1') 
						group by cd_filial
						having count(*) < 90)
 and p.cd_filial in (select cd_filial from parametro_loja where cd_parametro = 'ID_UTILIZA_NOVO_CALCULO_ESTOQUE_BASE' and vl_parametro = 'S')"  sort="nm_fantasia A " )
