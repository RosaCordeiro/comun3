table(column=(type=long updatewhereclause=yes name=codigo_produto dbname="resumo_reposicao_estoque.codigo_produto" dbalias="r.codigo_produto" )
 column=(type=char(103) updatewhereclause=yes name=descricao_produto dbname="descricao_produto" )
 column=(type=char(40) updatewhereclause=yes name=grupo_produto dbname="vw_classificacao_produto.grupo_produto" dbalias="vw.grupo_produto" )
 column=(type=long updatewhereclause=yes name=eb_calculado dbname="resumo_reposicao_estoque.eb_calculado" dbalias="r.eb_calculado" )
 column=(type=long updatewhereclause=yes name=eb_alterado dbname="resumo_reposicao_estoque.eb_alterado" dbalias="r.eb_alterado" )
 column=(type=datetime updatewhereclause=yes name=dt_alteracao dbname="resumo_reposicao_estoque.dt_alteracao" dbalias="r.dt_alteracao" )
 column=(type=long updatewhereclause=yes name=qt_dias_bloqueio dbname="qt_dias_bloqueio" )
 column=(type=char(10) updatewhereclause=yes name=dh_termino_bloqueio dbname="dh_termino_bloqueio" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_alteracao dbname="resumo_reposicao_estoque.nr_matricula_alteracao" dbalias="r.nr_matricula_alteracao" )
 column=(type=char(40) updatewhereclause=yes name=usuario_alteracao dbname="usuario.usuario_alteracao" dbalias="u.usuario_alteracao" )
 retrieve="select 	  	r.cd_produto as codigo_produto, 
				p.de_produto + ' : ' + p.de_apresentacao_venda as descricao_produto,
				vw.de_grupo as grupo_produto,
				r.qt_estoque_base_definido as eb_calculado,
				r.qt_estoque_base as eb_alterado,
				r.dh_alteracao as dt_alteracao,
				datediff( day, x.dh_movimentacao, r.dh_termino_bloqueio ) as qt_dias_bloqueio,
				Convert (varchar(10), r.dh_termino_bloqueio, 103) as dh_termino_bloqueio,
				r.nr_matricula_alteracao,
				u.nm_usuario as usuario_alteracao 
from  resumo_reposicao_estoque r,
		produto_geral p,
         parametro x,
         usuario u,
		vw_classificacao_produto vw
where p.cd_produto                    	= r.cd_produto
and u.nr_matricula                        	= r.nr_matricula_alteracao
and r.dh_termino_bloqueio      		> x.dh_movimentacao
and vw.cd_subcategoria				= p.cd_subcategoria
and r.id_alteracao						= 'F'
and r.cd_filial                                 	= :filial
and vw.cd_grupo						in ( '1', '2', '3')" arguments=(("filial", number))  sort="descricao_produto A " )
