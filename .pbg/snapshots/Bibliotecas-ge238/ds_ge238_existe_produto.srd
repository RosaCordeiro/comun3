 retrieve="Select 	qt_faturada,
			qt_recebida,
			vl_outras_despesas,	
			vl_bc_icms_st_total,
			vl_icms_st_total,
			vl_bc_icms_st_retido,
			vl_icms_st_retido, 			
			vl_total_item,
			vl_desconto_total,
			cd_unidade_comercial,
			cd_unidade_tributavel	, 
			qt_comercial,					
			qt_tributavel,
			pc_st_retido,
			vl_icms_retido,
			vl_icms_desonerado,
			cd_cest,
			qt_faturada_original,
			vl_preco_unitario_original,
			vl_preco_base_st_original,
			vl_bc_icms_original,
			vl_icms_original,
			vl_bc_ipi_original,
			vl_ipi_original,
			vl_bc_pis_entrada,
			vl_pis_entrada,
			vl_bc_cofins_entrada,
			vl_cofins_entrada,
			vl_bc_pis_xml,
			vl_pis,
			vl_bc_cofins_xml,
			vl_cofins,
			vl_icms_dif
from nf_compra_pendente_produto
where  cd_filial   				= :cd_Filial
		and cd_fornecedor 	= :cd_Fornecedor
		 and nr_nf         		= :nr_Nf
		 and de_especie    	= :de_Especie
		 and de_serie      		= :de_Serie
		 and cd_produto 		= :Cd_Produto
" arguments=(("cd_filial", number),("cd_fornecedor", string),("nr_nf", number),("de_especie", string),("de_serie", string),("cd_produto", number)) )
