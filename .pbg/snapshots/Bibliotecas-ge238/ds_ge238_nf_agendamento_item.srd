 column=(type=long updatewhereclause=yes name=nr_item_xml_receb dbname="nr_item_xml_receb" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="nr_sequencial" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="recebimento_sap_item.qt_recebida" dbalias=".qt_recebida" )
 column=(type=datetime updatewhereclause=yes name=dh_recebido_sap dbname="nf_agendamento_ent.dh_recebido_sap" dbalias="nf.dh_recebido_sap" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_desonerado dbname="nf_agendamento_ent_item.vl_icms_desonerado" dbalias="n.vl_icms_desonerado" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_total dbname="nf_agendamento_ent_item.vl_desconto_total" dbalias="n.vl_desconto_total" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_item dbname="nf_agendamento_ent_item.vl_total_item" dbalias="n.vl_total_item" )
 retrieve="  SELECT 	n.nr_item,   
				n.cd_produto,   
				n.cd_cprod,   
				n.de_codigo_barras,   
				n.de_produto,   
				n.nr_classificacao_fiscal,   
				n.cd_natureza_operacao,   
				n.qt_faturada,   
				n.vl_preco_unitario,   
				n.pc_desconto,   
				n.vl_frete,   
				n.vl_seguro,   
				n.nr_item_pedido,   
				n.cd_cst_origem,   
				n.cd_cst_tributacao,   
				n.vl_bc_icms,   
				n.pc_reducao_bc_icms,   
				n.pc_icms,   
				n.vl_icms,   
				n.vl_bc_icms_st,   
				n.pc_reducao_bc_icms_st,   
				n.pc_icms_st,   
				n.vl_icms_st,   
				n.vl_bc_ipi,   
				n.pc_ipi,   
				n.vl_ipi,   
				n.vl_outras_despesas ,
				n.de_codigo_barras_trib,
				coalesce(n.qt_caixa_padrao, 1) qt_caixa_padrao,
				nf.dh_emissao,
				c.cd_unidade_federacao,
				n.cd_cest,
				coalesce(rpi.cd_produto, 0) cd_produto_reb,
				coalesce(rpi.nr_item_xml, 0) nr_item_xml_receb,
				coalesce(n.nr_sequencial, 0) nr_sequencial,
				qt_recebida,
				nf.dh_recebido_sap,
				n.vl_icms_desonerado,
				n.vl_desconto_total,
				n.vl_total_item
    FROM nf_agendamento_ent_item   n
inner join nf_agendamento_ent nf on nf.de_chave_acesso = n.de_chave_acesso
left join pedido_central p on p.nr_pedido = nf.nr_pedido_central
left join fornecedor f on f.cd_fornecedor = p.cd_fornecedor
left join cidade c on c.cd_cidade = f.cd_cidade
left outer join recebimento_sap rp on (rp.de_chave_acesso = nf.de_chave_acesso)
left outer join recebimento_sap_item rpi on (rpi.nr_recebimento = rp.nr_recebimento and coalesce(rpi.nr_item_xml, 0) = n.nr_sequencial)
where n.de_chave_acesso = :chave
and   rp.id_situacao not in ('X', 'P')
order by n.nr_item asc
" arguments=(("chave", string)) )
