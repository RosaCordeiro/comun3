 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras_trib dbname="nf_agendamento_ent_item.de_codigo_barras_trib" dbalias="n.de_codigo_barras_trib" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_caixa_padrao dbname="qt_caixa_padrao" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_agendamento_ent.dh_emissao" dbalias="nf.dh_emissao" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" dbalias="c.cd_unidade_federacao" )
