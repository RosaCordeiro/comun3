table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_gerencial dbname="vw_saldo_atual_produto.vl_custo_gerencial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_unitario dbname="vl_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=char(1) updatewhereclause=yes name=id_atualiza dbname="id_atualiza" initial="S" values="	S/	N" )
 retrieve="select f.cd_filial, 
		  f.nm_fantasia, 
		  v.vl_custo_gerencial,
		  0.00 as vl_unitario,
		  0.00 as pc_desconto,
		  'S'id_atualiza	
from vw_saldo_atual_produto v,
				 filial f
where f.cd_filial = v.cd_filial 
and  f.id_possui_estoque = 'S'
AND f.cd_filial not in (1,2)"  sort="cd_filial A " )
