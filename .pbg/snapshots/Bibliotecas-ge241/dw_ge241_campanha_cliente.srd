table(column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="cliente.nm_cliente" )
 column=(type=char(11) update=yes updatewhereclause=yes key=yes name=cd_cliente dbname="campanha_cliente.cd_cliente" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_campanha dbname="campanha_cliente.nr_campanha" )
 retrieve="  SELECT c.nm_cliente,   
         	x.cd_cliente,
			x.nr_campanha  
    FROM cliente c,   
         campanha_cliente x  
   WHERE x.cd_cliente = c.cd_cliente
and x.nr_campanha = :campanha
" update="campanha_cliente" updatewhere=0 updatekeyinplace=no arguments=(("campanha", number))  sort="nm_cliente A " )
