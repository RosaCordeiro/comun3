table(column=(type=long update=yes updatewhereclause=yes key=yes name=nr_campanha dbname="campanha_produto.nr_campanha" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="campanha_produto.cd_produto" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto dbname="campanha_produto.pc_desconto" initial="0,00" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_anterior dbname="campanha_produto.pc_desconto_anterior" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_alteracao dbname="campanha_produto.dh_alteracao" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 retrieve="  SELECT c.nr_campanha,
			c.cd_produto,   
         	c.pc_desconto,
			c.pc_desconto pc_desconto_anterior,   
			c.dh_alteracao,
         	g.de_produto + ' : ' + g.de_apresentacao_venda de_produto
    FROM campanha_produto c,   
         	produto_geral  g 
   WHERE c.cd_produto  = g.cd_produto
And c.nr_campanha 	    = :campanha	   
" update="campanha_produto" updatewhere=0 updatekeyinplace=no arguments=(("campanha", number)) )
