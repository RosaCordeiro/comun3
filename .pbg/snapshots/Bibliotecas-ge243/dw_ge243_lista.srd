table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_compra_pendente.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="nf_compra_pendente.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_compra_pendente.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_compra_pendente.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_compra_pendente.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_compra_pendente.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_compra_pendente.vl_total_nf" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="nf_compra_pendente.nr_pedido_distribuidora" )
 column=(type=datetime updatewhereclause=yes name=dh_vencimento dbname="titulo_pagar_pendente.dh_vencimento" )
 column=(type=char(1) updatewhereclause=yes name=id_estoque_atualizado_loja dbname="id_estoque_atualizado_loja" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao_estoque dbname="nf_compra_pendente.dh_atualizacao_estoque" )
 column=(type=long updatewhereclause=yes name=id_receb dbname="id_receb" )
 retrieve="select n.cd_filial,
       i.nm_fantasia,
       n.cd_fornecedor,
	    f.nm_razao_social,
       n.nr_nf,
       n.de_especie,
       n.de_serie,
       n.dh_movimentacao_caixa,
       n.vl_total_nf,
       n.nr_pedido nr_pedido_distribuidora,
	  t.dh_vencimento,
	  '' id_estoque_atualizado_loja,
		n.dh_atualizacao_estoque,
		case when nf.de_chave_acesso is not null then 1 else 0 end as id_receb       
from nf_compra_pendente n
 Join fornecedor f
	 on f.cd_fornecedor = n.cd_fornecedor
Join filial i
	 on i.cd_filial      		= n.cd_filial
Left outer Join titulo_pagar_pendente t
	 on t.cd_filial 			= n.cd_filial
   and t.cd_fornecedor = n.cd_fornecedor
   and t.nr_nf				= n.nr_nf
   and t.de_especie		= n.de_especie
   and t.de_serie			= n.de_serie 
left join  nf_compra_recebimento nf on nf.de_chave_acesso = n.de_chave_acesso 
where cast(n.dh_movimentacao_caixa as date) between :inicio and :termino
  	and n.cd_filial <> 534
	and not exists (select * from nf_compra x
						where x.cd_filial		= n.cd_filial
							and x.cd_fornecedor = n.cd_fornecedor
							and x.nr_nf			= n.nr_nf
							and x.de_especie	= n.de_especie
							and x.de_serie		= n.de_serie)" arguments=(("inicio", date),("termino", date))  sort="nm_razao_social A dh_movimentacao_caixa A cd_filial A " )
