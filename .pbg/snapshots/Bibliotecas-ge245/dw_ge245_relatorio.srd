 retrieve="Select matricula,
		 nome,
		 rpad(' ', 200) horario,
		 fil_sybase,
		 rpad(' ', 60) nm_fantasia
  From vdc_lista_confere_ficha
Where empresa = :empresa
    And tipo = :tipo
" arguments=(("empresa", number),("tipo", number)) )
