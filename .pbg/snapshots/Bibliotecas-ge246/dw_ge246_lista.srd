table(column=(type=long updatewhereclause=yes name=cd_regiao dbname="filial.cd_regiao" )
 column=(type=char(40) updatewhereclause=yes name=de_regiao dbname="regiao.de_regiao" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(6) updatewhereclause=yes name=hr_abertura dbname="hr_abertura" )
 column=(type=char(6) updatewhereclause=yes name=hr_fechamento dbname="hr_fechamento" )
 column=(type=char(3) updatewhereclause=yes name=id_aberta dbname="id_aberta" )
 column=(type=char(3) updatewhereclause=yes name=id_recebe_nf_transferencia dbname="id_recebe_nf_transferencia" )
 retrieve="select f.cd_regiao,  //DIAS SEMANA
		r.de_regiao,
		f.cd_filial,   
		f.nm_fantasia,
		space(6) as hr_abertura,
		space(6) as hr_fechamento,
		(Case when COALESCE(f.id_aberta, 'N') = 'N' 							THEN 'N$$HEX1$$c300$$ENDHEX$$O' ELSE 'SIM' END) as id_aberta,
		(Case when COALESCE(f.id_recebe_nf_transferencia, 'N') = 'N' 	THEN 'N$$HEX1$$c300$$ENDHEX$$O' ELSE 'SIM' END) as id_recebe_nf_transferencia		
from 	filial f,
		regiao r
where r.cd_regiao = f.cd_regiao
  and f.id_situacao = 'A'
  and datepart(dw,:data_movimentacao)<>1
  and f.cd_filial not in (1, 534)
  and (f.cd_filial in (select r.cd_filial
						from resumo_movimento_estoque r
						where r.dh_resumo = :data_movimentacao
						  and r.cd_filial not in (1, 534)
						group by r.cd_filial
						having  sum(r.vl_venda_avista + r.vl_venda_cartao_debito + r.vl_venda_cheque_avista) = 0)
  or not exists (	select r.cd_filial	
					from resumo_movimento_estoque r
					where	r.cd_filial		= f.cd_filial
						and	r.dh_resumo = :data_movimentacao))
  and f.cd_filial in (select cd_filial from parametro_odbc)

UNION //DOMINGOS

select f.cd_regiao,
		r.de_regiao,
		f.cd_filial,   
		f.nm_fantasia,
		space(6) as hr_abertura,
		space(6) as hr_fechamento,
		(Case when COALESCE(f.id_aberta, 'N') = 'N' 							THEN 'N$$HEX1$$c300$$ENDHEX$$O' ELSE 'SIM' END) as id_aberta,
		(Case when COALESCE(f.id_recebe_nf_transferencia, 'N') = 'N' 	THEN 'N$$HEX1$$c300$$ENDHEX$$O' ELSE 'SIM' END) as id_recebe_nf_transferencia
from 	filial f,
		regiao r
where r.cd_regiao = f.cd_regiao
  and f.id_situacao = 'A'
  and f.id_abre_domingo = 'S'
  and datepart(dw,:data_movimentacao)=1
  and f.cd_filial not in (1, 534)
  and (f.cd_filial in (select r.cd_filial
						from resumo_movimento_estoque r
						where r.dh_resumo = :data_movimentacao
						  and r.cd_filial not in (1, 534)
						group by r.cd_filial
						having  sum(r.vl_venda_avista + r.vl_venda_cartao_debito + r.vl_venda_cheque_avista) = 0)
   or not exists (select * from resumo_movimento_estoque r
					 where	r.cd_filial		= f.cd_filial
						and	r.dh_resumo = :data_movimentacao))
	and f.cd_filial in (select cd_filial from parametro_odbc)
order by f.cd_filial
" arguments=(("data_movimentacao", date))  sort="cd_regiao A cd_filial A " )
