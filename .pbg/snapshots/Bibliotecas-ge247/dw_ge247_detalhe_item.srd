 column=(type=decimal(4) updatewhereclause=yes name=pc_reducao_base_st dbname="item_nf_transferencia.pc_reducao_base_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_st dbname="item_nf_transferencia.vl_bc_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="item_nf_transferencia.vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_fcp dbname="item_nf_transferencia.pc_fcp" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_fcp dbname="item_nf_transferencia.vl_fcp" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_bc_icms_antecipacao dbname="item_nf_transferencia.vl_bc_icms_antecipacao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_mva_icms_antecipacao dbname="item_nf_transferencia.pc_mva_icms_antecipacao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_antecipacao dbname="item_nf_transferencia.pc_icms_antecipacao" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_icms_antecipacao dbname="item_nf_transferencia.vl_icms_antecipacao" )
 column=(type=char(200) updatewhereclause=yes name=de_mensagem_fiscal dbname="mensagem_fiscal.de_mensagem_fiscal" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_bc_icms_st_origem dbname="item_nf_transferencia.vl_bc_icms_st_origem" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_st_origem dbname="item_nf_transferencia.pc_icms_st_origem" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_icms_st_origem dbname="item_nf_transferencia.vl_icms_st_origem" )
 column=(type=char(50) updatewhereclause=yes name=de_motivo_transf_filial dbname="wms_motivo_transf_filial.de_motivo_transf_filial" )
 retrieve="  SELECT 	p.de_produto,
				p.de_apresentacao_venda,   
				i.cd_natureza_operacao,
				i.qt_transferida,   
				i.vl_custo_unitario,   
				i.pc_icms,   
				i.cd_produto,
				i.cd_situacao_tributaria,
				i.pc_reducao_base_icms,
				i.vl_bc_icms,
				i.vl_icms,
				i.vl_preco_venda_maximo,
				i.pc_mva,
				i.pc_reducao_base_st,
				i.vl_bc_icms_st,
				i.vl_icms_st,
				i.pc_fcp,
				i.vl_fcp,
				i.vl_bc_icms_antecipacao,
				i.pc_mva_icms_antecipacao,
				i.pc_icms_antecipacao,
				i.vl_icms_antecipacao,
				m.de_mensagem_fiscal,
				i.vl_bc_icms_st_origem,
				i.pc_icms_st_origem,
				i.vl_icms_st_origem,
				t.de_motivo_transf_filial
    FROM item_nf_transferencia i 
Inner Join produto_geral p
	On p.cd_produto = i.cd_produto
left outer join mensagem_fiscal m
	on m.cd_mensagem_fiscal = i.cd_mensagem_fiscal
left outer join wms_motivo_transf_filial t
	on t.cd_motivo_transf_filial = i.cd_motivo_transf_filial
   WHERE	( i.cd_filial_origem = :cd_filial ) 		AND  
				( i.nr_nf            = :nr_nf ) 				AND  
				( i.de_especie       = :de_especie ) 	AND  
				( i.de_serie         = :de_serie )   
" arguments=(("cd_filial", number),("nr_nf", number),("de_especie", string),("de_serie", string))  sort="de_produto A " )
