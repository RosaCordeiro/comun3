table(column=(type=char(40) updatewhereclause=yes name=filial_origem dbname="filial.filial_origem" )
 column=(type=char(40) updatewhereclause=yes name=filial_destino dbname="filial.filial_destino" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_transferencia.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_transferencia.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_transferencia.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_transferencia.dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms dbname="nf_transferencia.vl_bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="nf_transferencia.vl_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_st dbname="nf_transferencia.vl_bc_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="nf_transferencia.vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_produtos dbname="nf_transferencia.vl_total_produtos" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_transferencia.vl_total_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao_1 dbname="nf_transferencia.dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_transferencia.dh_movimentacao_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="nf_transferencia.dh_cancelamento" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="nf_transferencia.nr_pedido_distribuidora" )
 column=(type=long updatewhereclause=yes name=nr_pedido_compra dbname="nf_transferencia.nr_pedido_compra" )
 column=(type=long updatewhereclause=yes name=nr_ordem_faturamento dbname="nf_transferencia.nr_ordem_faturamento" )
 column=(type=datetime updatewhereclause=yes name=dh_recebimento dbname="nf_transferencia.dh_recebimento" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_transferencia_nfe.de_chave_acesso" )
 column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="nf_transferencia.cd_filial_origem" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="nf_transferencia.cd_filial_destino" )
 column=(type=char(1) updatewhereclause=yes name=id_almoxarifado dbname="nf_transferencia.id_almoxarifado" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=long updatewhereclause=yes name=nr_retirada_estoque dbname="nf_transferencia.nr_retirada_estoque" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_antecipacao dbname="vl_bc_antecipacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_antecipacao dbname="vl_antecipacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_st_origem dbname="vl_bc_st_origem" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_st_origem dbname="vl_st_origem" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_fcp dbname="vl_bc_fcp" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_fcp dbname="vl_fcp" )
 column=(type=char(51) updatewhereclause=yes name=de_centro_custo dbname="de_centro_custo" )
 column=(type=char(17) updatewhereclause=yes name=de_tipo_transferencia dbname="de_tipo_transferencia" )
 column=(type=datetime updatewhereclause=yes name=dh_solicitacao_canc dbname="nf_transferencia.dh_solicitacao_canc" )
 column=(type=char(6) updatewhereclause=yes name=nf_transferencia_nr_matricula_solic_canc dbname="nf_transferencia.nr_matricula_solic_canc" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_solic_canc dbname="nm_usuario_solic_canc" )
 column=(type=char(100) updatewhereclause=yes name=de_log_sap dbname="de_log_sap" )
 retrieve="SELECT	fo.nm_fantasia as filial_origem,   
			fd.nm_fantasia as filial_destino,    
			n.nr_nf,   
			n.de_especie,   
			n.de_serie,   
			n.dh_emissao,   
			n.vl_bc_icms,   
			n.vl_icms,   
			n.vl_bc_icms_st,   
			n.vl_icms_st,   
			n.vl_total_produtos,   
			n.vl_total_nf,   
			n.dh_emissao,  
			n.dh_movimentacao_caixa, 
			n.dh_cancelamento,   
			n.nr_pedido_distribuidora,   
			n.nr_pedido_compra,   
			n.nr_ordem_faturamento,   
			n.dh_recebimento,
			nfe.de_chave_acesso,
			n.cd_filial_origem,
			n.cd_filial_destino,
			n.id_almoxarifado,
			n.nr_retirada_estoque,
			0.00 as vl_bc_antecipacao,
			0.00 as vl_antecipacao,
			0.00 as vl_bc_st_origem,
			0.00 as vl_st_origem,
			0.00 as vl_bc_fcp,
			0.00 as vl_fcp,
			Case When n.cd_centro_custo is not null then cc.de_centro_custo || ' ('||cast(cc.cd_centro_custo as varchar(8))||')' else '' end as de_centro_custo,
			Case When n.id_almoxarifado = 'S' then 'ALMOXARIFADO' 
			Else Case When n.id_produto_vencido = 'S' Then 'PROD. VENCIDO' 
			Else Case When n.id_retirada_excesso = 'S' Then 'REMANEJAMENTO'
			Else Case When n.nr_retirada_estoque is not null then 'RETIRADA ESTOQUE'
			Else Case When n.id_devolucao = 'S' Then 'DEVOLU$$HEX2$$c700c300$$ENDHEX$$O'
			Else Case When n.cd_filial_origem <> 534 and n.cd_filial_destino <> 1 and n.cd_filial_destino <> 534  then 'ENTRE FILIAIS'
			Else Case When n.cd_filial_origem = 534 then Case when n.nr_pedido_distribuidora is null then 'EC - FAT. URGENTE' else 'EC - FAT. NORMAL' end
			Else 'NORMAL' end end end end end end end as de_tipo_transferencia,
			n.dh_solicitacao_canc,
			n.nr_matricula_solic_canc,
			(select u.nm_usuario from usuario u where u.nr_matricula = n.nr_matricula_solic_canc) as nm_usuario_solic_canc,
			(select lo.de_erro from log_exportacao_sap lo where lo.id_tipo_nf = 'WMV'  and lo.id_tipo_log = 77 and lo.cd_tipo_documento = 'WMV' and lo.id_status_integracao = 'E' and lo.cd_chave_interface = nfe.de_chave_acesso) de_log_sap
    FROM  nf_transferencia n
Inner Join filial fo
	On fo.cd_filial = n.cd_filial_origem
Inner Join filial fd
	On fd.cd_filial = n.cd_filial_destino
Left Outer Join nf_transferencia_nfe nfe
	On	nfe.nr_nf 				= n.nr_nf  			and  
		nfe.de_especie			= n.de_especie  	and  
		nfe.de_serie 			= n.de_serie 		and
		nfe.cd_filial_origem	= n.cd_filial_origem	
Left Outer Join centro_custo cc
	On cc.cd_centro_custo = n.cd_centro_custo
WHERE	( n.cd_filial_origem	= :cd_filial_origem )	and  
			( n.nr_nf					= :nr_nf )				and  
			( n.de_especie			= :de_especie )		and   
			( n.de_serie				= :de_serie )    " arguments=(("cd_filial_origem", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
