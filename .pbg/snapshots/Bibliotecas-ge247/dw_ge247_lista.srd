table(column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="cd_filial_origem" )
 column=(type=char(40) updatewhereclause=yes name=cd_filial_sap_origem dbname="integracao_sap.cd_filial_sap_origem" dbalias="fos.cd_filial_sap_origem" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="cd_filial_destino" )
 column=(type=char(40) updatewhereclause=yes name=cd_filial_sap_destino dbname="integracao_sap.cd_filial_sap_destino" dbalias="fds.cd_filial_sap_destino" )
 column=(type=char(40) updatewhereclause=yes name=filial_origem dbname="filial.filial_origem" dbalias="fo.filial_origem" )
 column=(type=char(40) updatewhereclause=yes name=filial_destino dbname="filial.filial_destino" dbalias="fd.filial_destino" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="cd_filial_origem" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="dh_cancelamento" )
 column=(type=datetime updatewhereclause=yes name=n_dh_recebimento dbname="dh_recebimento" )
 column=(type=datetime updatewhereclause=yes name=dh_entrada_cd dbname="dh_entrada_cd" )
 column=(type=char(21) updatewhereclause=yes name=de_tipo_retirada dbname="de_tipo_retirada" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="u.nm_usuario" )
 column=(type=long updatewhereclause=yes name=qt_total_transf_cd dbname="qt_total_transf_cd" )
 column=(type=datetime updatewhereclause=yes name=dh_solicitacao_canc dbname="dh_solicitacao_canc" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="nr_pedido_distribuidora" )
 column=(type=char(20) updatewhereclause=yes name=de_tipo dbname="tipo_pedido_distribuidora.de_tipo" dbalias="tpd.de_tipo" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_pedido dbname="pedido_distribuidora.id_tipo_pedido" dbalias="pd.id_tipo_pedido" )
 column=(type=long updatewhereclause=yes name=qt_dias_emissao dbname="qt_dias_emissao" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_transferencia_nfe.de_chave_acesso" dbalias="e.de_chave_acesso" )
 column=(type=long updatewhereclause=yes name=nr_rota_entrega_d dbname="filial.nr_rota_entrega_d" dbalias="fd.nr_rota_entrega_d" )
 retrieve="SELECT  n.cd_filial_origem,
		fos.cd_chave_sap cd_filial_sap_origem,
		n.cd_filial_destino,
		fds.cd_chave_sap cd_filial_sap_destino,
		fo.nm_fantasia filial_origem,
		 fd.nm_fantasia filial_destino,
		 n.nr_nf,
		 n.de_especie,
		 n.de_serie,
		 n.dh_movimentacao_caixa,
		 n.cd_filial_origem,
          n.vl_total_nf ,
		n.dh_cancelamento,
		n.dh_recebimento,
		n.dh_entrada_cd,
		Case r.id_tipo_retirada 
			When 'E' Then 'EXCESSO'
			When 'R' Then 'RECALL'
			When 'V' Then 'VENCIDOS'
			When 'P' Then 'PRODUTOS ESPECIAIS'
			When 'A' Then 'AVARIA'
			When 'D' Then 'DEFEITO DE FABRICA$$HEX2$$c700c300$$ENDHEX$$O'
			When 'F' Then 'TRANSF$$HEX1$$ca00$$ENDHEX$$RENCIA SAF'
			When 'S' Then 'AUTORIZADO SAF'
		End As de_tipo_retirada,
		 u.nm_usuario,
		 (Select Coalesce(Sum(i.qt_transferida), 0)
           	From item_nf_transferencia i
           	Where i.cd_filial_origem = n.cd_filial_origem
                And i.nr_nf = n.nr_nf
                And i.de_especie = n.de_especie
                And i.de_serie = n.de_serie
			  And i.cd_filial_destino in (1,534)) as qt_total_transf_cd,
		n.dh_solicitacao_canc,
		n.nr_pedido_distribuidora,
		tpd.de_tipo,
		pd.id_tipo_pedido,
		datediff(hh, n.dh_emissao, getdate()) qt_dias_emissao,
		e.de_chave_acesso,
		fd.nr_rota_entrega as nr_rota_entrega_d
FROM nf_transferencia n (index idx_data_filial_origem )
left join nf_transferencia_nfe e
	on e.cd_filial_origem = n.cd_filial_origem
	and e.nr_nf = n.nr_nf
	and e.de_especie = n.de_especie
	and e.de_serie = n.de_serie
inner join filial fo
	on fo.cd_filial = n.cd_filial_origem
inner join cidade co 
	on co.cd_cidade = fo.cd_cidade
inner join filial fd
	on fd.cd_filial = n.cd_filial_destino
inner join cidade cd 
	on cd.cd_cidade = fd.cd_cidade
left join retirada_estoque r 
	on r.cd_filial = n.cd_filial_origem
     and r.nr_retirada_estoque = n.nr_retirada_estoque
left join usuario u 
	on u.nr_matricula = n.nr_matricula_entrada_cd
left join pedido_distribuidora pd
   on pd.nr_pedido_distribuidora	= n.nr_pedido_distribuidora
  and pd.cd_filial					= n.cd_filial_destino
left join tipo_pedido_distribuidora tpd
	on tpd.id_tipo = pd.id_tipo_pedido
left join integracao_sap fds
	on fds.cd_empresa = 1000 
	and fds.cd_tabela = 'FILIAL' 
	and fds.cd_chave_legado = cast(n.cd_filial_destino as varchar)
left join integracao_sap fos
	on fos.cd_empresa = 1000 
	and fos.cd_tabela = 'FILIAL' 
	and fos.cd_chave_legado = cast(n.cd_filial_origem as varchar)
Where n.cd_filial_origem > 0"  sort="nr_nf A de_especie A de_serie A " )
