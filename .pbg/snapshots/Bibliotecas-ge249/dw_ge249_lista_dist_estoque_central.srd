table(column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="pedido_distribuidora.cd_distribuidora" dbalias="a.cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_falta dbname="qt_falta" )
 retrieve="select a.cd_distribuidora,
       f.nm_fantasia,
       sum(b.qt_atendida) qt_pedida,
       sum(b.qt_faturada) qt_faturada,
       sum(b.qt_atendida) - sum(b.qt_faturada) qt_falta 
from pedido_distribuidora a, 
     pedido_distribuidora_produto b,
     fornecedor f
where a.dh_emissao between 		:inicio and :termino
  and a.cd_distribuidora		= '053404705'
  and a.id_situacao				not in ('J', 'X')
  and b.cd_filial               = a.cd_filial
  and b.nr_pedido_distribuidora = a.nr_pedido_distribuidora
  and b.cd_produto 				= :produto
  and f.cd_fornecedor 			= a.cd_distribuidora
group by a.cd_distribuidora,
         f.nm_fantasia" arguments=(("inicio", date),("termino", date),("produto", number)) )
