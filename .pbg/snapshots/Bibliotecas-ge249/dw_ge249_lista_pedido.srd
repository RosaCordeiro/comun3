table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_distribuidora.cd_filial" dbalias="a.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="pedido_distribuidora.nr_pedido_distribuidora" dbalias="a.nr_pedido_distribuidora" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="pedido_distribuidora.id_situacao" dbalias="a.id_situacao" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="pedido_distribuidora_produto.qt_faturada" dbalias="b.qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_falta dbname="qt_falta" )
 retrieve="select	a.cd_filial,
		f.nm_fantasia,
		a.nr_pedido_distribuidora,
		a.id_situacao,
		case when a.cd_distribuidora =  '053404705' then
			b.qt_atendida
		else
			b.qt_pedida
		end as qt_pedida,
		 b.qt_faturada,
		case when a.cd_distribuidora =  '053404705' then
			b.qt_atendida - b.qt_faturada
		else
			b.qt_pedida - b.qt_faturada
		end as qt_falta
from pedido_distribuidora a, 
     pedido_distribuidora_produto b,
     filial f
where a.dh_emissao between :inicio and :termino
  and a.cd_distribuidora = :distribuidora
  and b.cd_filial               = a.cd_filial
  and b.nr_pedido_distribuidora = a.nr_pedido_distribuidora
  and b.cd_produto = :produto
  and f.cd_filial = a.cd_filial
  and a.id_situacao <> 'X'" arguments=(("inicio", date),("termino", date),("produto", number),("distribuidora", string))  sort="qt_falta D " )
