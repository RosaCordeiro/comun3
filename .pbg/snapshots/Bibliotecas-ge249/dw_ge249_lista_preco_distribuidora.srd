table(column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="distribuidora_produto.cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="distribuidora_produto.cd_unidade_federacao" )
 column=(type=char(20) update=yes updatewhereclause=yes name=cd_produto_distribuidora dbname="distribuidora_produto.cd_produto_distribuidora" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_atual dbname="distribuidora_produto.vl_preco_atual" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto_atual dbname="distribuidora_produto.pc_desconto_atual" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="distribuidora_produto.id_situacao" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_custo_final dbname="vl_custo_final" )
 column=(type=long updatewhereclause=yes name=nr_prioridade_distribuicao dbname="fornecedor.nr_prioridade_distribuicao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_repasse_icms dbname="pc_repasse_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_reducao_base_icms dbname="pc_reducao_base_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_promocao_desconto_finan dbname="pc_promocao_desconto_finan" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_comissao_midia dbname="pc_comissao_midia" )
 retrieve="select d.cd_distribuidora,
       f.nm_fantasia,
       d.cd_unidade_federacao,
       d.cd_produto_distribuidora,
       d.vl_preco_atual,   
       d.pc_desconto_atual,   
       d.id_situacao,
		 round(round(round(round(d.vl_preco_atual * ((100 - d.pc_desconto_atual) / 100), 2)
				 * ((100 - isnull(d.pc_repasse_icms, 0)) / 100), 2)
				 * ((100 - round(isnull(d.pc_icms, 0) * ((100 - isnull(d.pc_reducao_base_icms, 0)) / 100), 2)) / 100), 2)
             * ((100 - coalesce(d.pc_promocao_desconto_finan,0)) / 100)
				 * ((100 - isnull(case when convert(varchar,coalesce(f.dh_vigencia_midia, '2099-01-01'),102)<= convert(varchar,getdate(),102) then d.pc_comissao_midia else f.pc_desconto_financeiro end, 0)) / 100), 2) vl_custo_final,
       f.nr_prioridade_distribuicao,
		 isnull(d.pc_repasse_icms, 0) as pc_repasse_icms,
		 isnull(d.pc_icms, 0) as pc_icms,
		 isnull(d.pc_reducao_base_icms, 0) as pc_reducao_base_icms,
		 isnull(d.pc_promocao_desconto_finan,0) as pc_promocao_desconto_finan,
		 isnull(case when convert(varchar,coalesce(f.dh_vigencia_midia, '2099-01-01'),102)<= convert(varchar,getdate(),102) then d.pc_comissao_midia else f.pc_desconto_financeiro end, 0) as pc_comissao_midia
from distribuidora_produto d,   
     fornecedor f
where d.cd_produto 	  	 = :produto
  and f.cd_fornecedor 	 = d.cd_distribuidora
  and f.id_distribuidora = 'S'" arguments=(("produto", number))  sort="id_situacao A vl_custo_final A nr_prioridade_distribuicao A " )
