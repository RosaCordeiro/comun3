table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" dbalias="f.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia_filial dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="fornecedor.cd_fornecedor" dbalias="fr.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" dbalias="fr.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="recebimento_sap.dh_emissao" dbalias="rs.dh_emissao" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="recebimento_sap.de_chave_acesso" dbalias="rs.de_chave_acesso" )
 column=(type=char(9) updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(1) updatewhereclause=yes name=id_reimportacao dbname="id_reimportacao" )
 column=(type=char(1) updatewhereclause=yes name=id_distribuidora dbname="id_distribuidora" )
 column=(type=char(4) updatewhereclause=yes name=tipo dbname="tipo" )
 column=(type=char(1) updatewhereclause=yes name=id_verificado_divergencia_ped dbname="id_verificado_divergencia_ped" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="recebimento_sap.nr_pedido" dbalias="rs.nr_pedido" )
 column=(type=char(10) updatewhereclause=yes name=nr_recebimento dbname="recebimento_sap.nr_recebimento" dbalias="rs.nr_recebimento" )
 column=(type=datetime updatewhereclause=yes name=dh_solicitacao_estorno dbname="recebimento_sap.dh_solicitacao_estorno" dbalias="rs.dh_solicitacao_estorno" )
 column=(type=char(1) updatewhereclause=yes name=id_permite_nota_sem_pedido dbname="id_permite_nota_sem_pedido" )
 column=(type=char(1) updatewhereclause=yes name=id_sistema_java dbname="id_sistema_java" )
 retrieve="select distinct f.cd_filial,
		f.nm_fantasia,
		fr.cd_fornecedor,
		fr.nm_fantasia,
		rs.dh_nota as dh_emissao,
		rs.de_chave_acesso,
		substring(rs.de_chave_acesso, 26, 9) nr_nf,
		'N' id_reimportacao,
		coalesce(fr.id_distribuidora, 'N') id_distribuidora, 
		'LOJA' tipo,
		'N' as id_verificado_divergencia_ped, 
		rs.nr_pedido, 
		rs.nr_recebimento, 
		rs.dh_solicitacao_estorno,
		case when coalesce(f.id_sistema_novo, 'N') = 'S' and coalesce(fr.id_permite_nota_sem_pedido, 'N') = 'S' then 'S' else 'N' end as id_permite_nota_sem_pedido,
		coalesce(f.id_sistema_novo, 'N') as id_sistema_java
from recebimento_sap rs
inner join filial f on f.cd_filial = rs.cd_filial
inner join fornecedor fr on fr.cd_fornecedor = rs.cd_fornecedor
 where f.id_situacao = 'A'
	and (fr.id_situacao = 'A' or fr.id_situacao is null)
	and not exists (select 1 from nf_compra a  (index idx_chave_acesso) where a.de_chave_acesso = rs.de_chave_acesso)
	and not exists (select 1 from nf_compra_pendente p (index idx_chave_acesso) where p.de_chave_acesso = rs.de_chave_acesso)
	and not exists (select 1 from nfe_compra_pendente e (index idx_chave_acesso) where e.de_chave_acesso = rs.de_chave_acesso)
	and not exists (select 1 from nf_compra_reimportacao r (index idx_chave_acesso) where r.de_chave_acesso = rs.de_chave_acesso)
	and ((f.cd_filial <> 534 and fr.id_distribuidora = 'S') or (f.cd_filial = 534))
   and fr.cd_fornecedor <> '053404705'
	and f.cd_filial <> 1
	and not exists (select 1 from nfe_destinadas d (index pk_nfe_destinadas) where d.de_chave_acesso = rs.de_chave_acesso and d.id_situacao_nf in ('2', '3'))
	and rs.id_situacao = 'C'
	and ((rs.nr_pedido is not null
	and rs.nr_pedido > 0) 
	or 
	((rs.nr_pedido is null or rs.nr_pedido = 0)
	and fr.id_permite_nota_sem_pedido	= 'S'
	and exists (select 1 from parametro_odbc po where po.cd_filial = f.cd_filial and coalesce(po.id_pdv_java, 'N') = 'S')))"  sort="cd_fornecedor A cd_filial A id_reimportacao A tipo A id_verificado_divergencia_ped D " )
