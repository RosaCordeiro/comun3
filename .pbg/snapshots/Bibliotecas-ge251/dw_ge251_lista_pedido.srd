table(column=(type=long updatewhereclause=yes key=yes name=nr_pedido dbname="licitacao_pedido.nr_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_licitacao dbname="licitacao_pedido.dh_licitacao" )
 column=(type=long updatewhereclause=yes name=nr_orcamento dbname="licitacao_pedido.nr_orcamento" )
 column=(type=char(15) updatewhereclause=yes name=nr_pedido_cliente dbname="licitacao_pedido.nr_pedido_cliente" )
 column=(type=datetime updatewhereclause=yes name=dh_prazo_entrega dbname="licitacao_pedido.dh_prazo_entrega" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pedido dbname="licitacao_pedido.vl_pedido" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="licitacao_pedido.id_situacao" values="ABERTO	A/CANCELADO	X/PENDENTE	P/FATURADO	F/" )
 retrieve="select 	lp.nr_pedido,
         	lp.dh_licitacao, 
			lp.nr_orcamento,
			lp.nr_pedido_cliente,
			lp.dh_prazo_entrega,
			lp.vl_pedido,
              lp.id_situacao
from licitacao_pedido lp
where lp.id_situacao in ('A','P')
" update="licitacao_pedido" updatewhere=0 updatekeyinplace=no  sort="dh_licitacao A nr_pedido A " )
