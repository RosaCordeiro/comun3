table(column=(type=char(50) updatewhereclause=yes name=de_defeito dbname="protocolo_defeito_motivo.de_defeito" )
 column=(type=long updatewhereclause=yes name=qt_lote dbname="qt_lote" )
 column=(type=long updatewhereclause=yes name=qt_utilizado dbname="qt_utilizado" )
 column=(type=long updatewhereclause=yes name=cd_defeito dbname="protocolo_defeito_motivo.cd_defeito" )
 retrieve="SELECT
	pdm.de_motivo                AS de_defeito,
	COALESCE (p.qt_lote, 0)      AS qt_lote,
	COALESCE (p.qt_utilizado, 0) AS qt_utilizado,
	pdm.cd_motivo                AS cd_defeito
  FROM
		protocolo_defeito_motivo pdm
  LEFT OUTER JOIN wms_protocolo p 
		ON  p.cd_motivo_defeito = pdm.cd_motivo
		AND p.cd_produto        = :al_produto
		AND p.nr_lote           = :as_lote
		AND p.nr_protocolo      = :as_protocolo
 WHERE
	pdm.id_situacao = 'A'
 ORDER BY
	2 DESC,
	1 ASC
" arguments=(("al_produto", number),("as_lote", string),("as_protocolo", string)) )
