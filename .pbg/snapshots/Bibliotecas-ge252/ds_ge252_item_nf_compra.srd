 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_reducao_base_icms dbname="pc_reducao_base_icms" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_base_icms_st dbname="vl_preco_base_icms_st" )
