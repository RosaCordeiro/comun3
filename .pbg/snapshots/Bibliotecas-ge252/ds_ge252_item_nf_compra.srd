 column=(type=decimal(13) updatewhereclause=yes name=vl_icms_retido dbname="vl_icms_retido" )
 column=(type=char(10) updatewhereclause=yes name=cd_beneficio dbname="cd_beneficio" )
 column=(type=char(7) updatewhereclause=yes name=cd_cest dbname="item_nf_compra.cd_cest" dbalias="i.cd_cest" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_item dbname="item_nf_compra.vl_total_item" dbalias="i.vl_total_item" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_total dbname="item_nf_compra.vl_desconto_total" dbalias="i.vl_desconto_total" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_total dbname="item_nf_compra.vl_bc_icms_total" dbalias="i.vl_bc_icms_total" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_total dbname="item_nf_compra.vl_icms_total" dbalias="i.vl_icms_total" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_ipi_total dbname="item_nf_compra.vl_bc_ipi_total" dbalias="i.vl_bc_ipi_total" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_ipi_total dbname="item_nf_compra.vl_ipi_total" dbalias="i.vl_ipi_total" )
 column=(type=long updatewhereclause=yes name=id_motivo_desoneracao_icms dbname="item_nf_compra.id_motivo_desoneracao_icms" dbalias="i.id_motivo_desoneracao_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_desonerado dbname="item_nf_compra.vl_icms_desonerado" dbalias="i.vl_icms_desonerado" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_icms_operacao dbname="item_nf_compra.vl_icms_operacao" dbalias="i.vl_icms_operacao" )
 retrieve="  SELECT	i.cd_filial,   
			i.cd_fornecedor,   
			i.nr_nf,   
			i.de_especie,   
			i.de_serie,   
			i.cd_natureza_operacao,   
			i.cd_produto,   
			i.cd_situacao_tributaria,   
			coalesce(i.vl_preco_unitario, 0) as vl_preco_unitario,   
			coalesce(i.pc_desconto, 0) as pc_desconto,   
			coalesce(i.pc_icms, 0) as pc_icms,   
			coalesce(i.pc_ipi, 0) as pc_ipi,   
			i.id_lista_pis_cofins,   
			coalesce(i.pc_reducao_base_icms, 0) as pc_reducao_base_icms,   
			coalesce(i.vl_preco_base_icms_st, 0) as vl_preco_base_icms_st,   
			coalesce(i.vl_bc_icms_st_total, 0) as vl_bc_icms_st_total,  
			coalesce(i.vl_icms_st_total, 0) as vl_icms_st_total,
			coalesce(i.vl_bc_icms, 0) as vl_bc_icms,  
			coalesce(i.vl_icms, 0) as vl_icms,   
			coalesce(i.vl_bc_ipi, 0) as vl_bc_ipi,   
			coalesce(i.vl_ipi, 0) as vl_ipi,   
			round(coalesce(i.vl_outras_despesas, 0) / i.qt_faturada, 2) as vl_outras_despesas,   
			coalesce(i.pc_icms_st, 0) as pc_icms_st,   
			i.cd_cst_origem,   
			i.cd_cst_tributacao,
			i.nr_classificacao_fiscal,
			i.qt_faturada,
			coalesce(i.vl_bc_icms_st_retido, 0) as vl_bc_icms_st_retido,
			coalesce(i.vl_icms_st_retido, 0) as vl_icms_st_retido,
			coalesce(i.pc_st_retido, 0) as pc_st_retido,
			coalesce(i.vl_icms_retido, 0) /  i.qt_faturada as vl_icms_retido,
			coalesce(i.cd_beneficio, '') as cd_beneficio,
			i.cd_cest,
			i.vl_total_item,
			i.vl_desconto_total,
			i.vl_bc_icms_total as vl_bc_icms_total,
			i.vl_icms_total as vl_icms_total,
			i.vl_bc_ipi_total as vl_bc_ipi_total,
			i.vl_ipi_total as vl_ipi_total,
			i.id_motivo_desoneracao_icms,
			i.vl_icms_desonerado, 
			i.vl_icms_operacao
FROM nf_compra n
	inner join item_nf_compra i
		on i.cd_filial = n.cd_filial
		and i.cd_fornecedor = n.cd_fornecedor
		and i.nr_nf = n.nr_nf
		and i.de_especie = n.de_especie
		and i.de_serie = n.de_serie
where i.cd_filial 			=:filial
	and i.cd_fornecedor	=:fornecedor
	and i.nr_nf				=:nota
	and i.de_especie		=:especie
	and i.de_serie			=:serie
	and i.cd_produto		=:produto" arguments=(("filial", number),("fornecedor", string),("nota", number),("especie", string),("serie", string),("produto", number)) )
