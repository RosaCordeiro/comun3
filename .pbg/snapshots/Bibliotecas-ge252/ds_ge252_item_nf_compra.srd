 column=(type=decimal(4) update=yes updatewhereclause=yes name=vl_bc_ipi dbname="vl_bc_ipi" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=vl_ipi dbname="vl_ipi" )
 column=(type=decimal(13) update=yes updatewhereclause=yes name=vl_outras_despesas dbname="vl_outras_despesas" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_icms_st dbname="pc_icms_st" )
 column=(type=char(1) update=yes updatewhereclause=yes name=cd_cst_origem dbname="item_nf_compra.cd_cst_origem" dbalias="i.cd_cst_origem" )
