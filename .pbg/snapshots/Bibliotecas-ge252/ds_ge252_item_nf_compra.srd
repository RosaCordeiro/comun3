 column=(type=long updatewhereclause=yes name=nr_classificacao_fiscal dbname="item_nf_compra.nr_classificacao_fiscal" dbalias="i.nr_classificacao_fiscal" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="item_nf_compra.qt_faturada" dbalias="i.qt_faturada" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_bc_icms_st_retido dbname="vl_bc_icms_st_retido" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_icms_st_retido dbname="vl_icms_st_retido" )
