table(column=(type=long updatewhereclause=yes name=nr_agrupamento dbname="agrupamento_dev_compra_prd_nf.nr_agrupamento" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="agrupamento_dev_compra_prd_nf.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="agrupamento_dev_compra_prd_nf.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="agrupamento_dev_compra_prd.dh_validade" )
 column=(type=long updatewhereclause=yes name=qt_devolver dbname="qt_devolver" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_pis_cofins dbname="produto_geral.id_situacao_pis_cofins" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="agrupamento_dev_compra_prd_nf.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="agrupamento_dev_compra_prd_nf.vl_preco_unitario" )
 column=(type=char(52) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_compra.dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="agrupamento_dev_compra_prd_nf.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="agrupamento_dev_compra_prd_nf.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="agrupamento_dev_compra_prd_nf.de_serie" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="agrupamento_dev_compra_prd_nf.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=cd_endereco_localizacao dbname="cd_endereco_localizacao" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_kg dbname="qt_peso_kg" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote_nf dbname="agrupamento_dev_compra_prd_nf.nr_lote_nf" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="agrupamento_dev_compra_prd_nf.cd_natureza_operacao" )
 retrieve="SELECT 	a.nr_agrupamento,
			a.cd_produto,   
			b.de_produto,   
			b.de_apresentacao_estoque,
			b.de_codigo_barras,
			a.nr_lote, 
			e.dh_validade,
			sum(a.qt_devolver) as qt_devolver,           
			b.id_situacao_pis_cofins,   
			a.pc_desconto,   
			a.vl_preco_unitario,
			'('+a.cd_fornecedor+') '+c.nm_fantasia as nm_fantasia,
			d.dh_movimentacao_caixa,
			a.nr_nf,
			a.de_especie,
			a.de_serie,
			a.cd_fornecedor,
			(select vl_parametro from wms_parametro where cd_parametro = 'CD_ENDERECO_SEGREGADO_AGRUPAMENTO_DEV') as cd_endereco_localizacao,
			---a.cd_endereco_localizacao as cd_endereco_segregado,
			sum(a.qt_devolver) * e.qt_peso_kg as qt_peso_kg,
			a.nr_lote_nf,
			a.cd_natureza_operacao
FROM agrupamento_dev_compra_prd_nf a
INNER JOIN produto_geral 	b on b.cd_produto = a.cd_produto
INNER JOIN fornecedor 		c on c.cd_fornecedor = a.cd_fornecedor
INNER JOIN nf_compra			d on d.cd_filial 			= a.cd_filial
										and d.cd_fornecedor 	= a.cd_fornecedor
										and d.nr_nf 				= a.nr_nf
										and d.de_especie 		= a.de_especie
										and d.de_serie 			= a.de_serie
INNER JOIN agrupamento_dev_compra_prd e on e.nr_agrupamento 				= a.nr_agrupamento
														 and e.cd_produto 					= a.cd_produto
														 and e.cd_endereco_localizacao 	= a.cd_endereco_localizacao
														 and e.nr_lote 							= a.nr_lote
WHERE a.nr_agrupamento = :nr_agrupamento   
group by
	a.nr_agrupamento,
	a.cd_produto,   
	b.de_produto,   
	b.de_apresentacao_estoque,  
	b.de_codigo_barras, 
	a.nr_lote,
	b.id_situacao_pis_cofins,   
	a.pc_desconto,   
	a.vl_preco_unitario ,
	a.cd_fornecedor,
	c.nm_fantasia,
	d.dh_movimentacao_caixa,
	a.nr_nf,
	a.de_especie,
	a.de_serie,
	a.cd_fornecedor,
	e.dh_validade,
	---a.cd_endereco_localizacao,
	e.qt_peso_kg,
	a.nr_lote_nf,
	a.cd_natureza_operacao
order by c.nm_fantasia,
			a.cd_fornecedor,
			a.nr_nf,
			b.de_produto,   
			b.de_apresentacao_estoque" arguments=(("nr_agrupamento", number)) )
