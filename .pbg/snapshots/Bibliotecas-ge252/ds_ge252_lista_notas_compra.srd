table(column=(type=long updatewhereclause=yes name=cd_filial dbname="agrupamento_dev_compra_prd_nf.cd_filial" dbalias="b.cd_filial" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="agrupamento_dev_compra_prd_nf.cd_fornecedor" dbalias="b.cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="agrupamento_dev_compra_prd_nf.nr_nf" dbalias="b.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="agrupamento_dev_compra_prd_nf.de_especie" dbalias="b.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="agrupamento_dev_compra_prd_nf.de_serie" dbalias="b.de_serie" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="agrupamento_dev_compra_prd_nf.cd_natureza_operacao" dbalias="b.cd_natureza_operacao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="agrupamento_dev_compra_prd_nf.cd_produto" dbalias="b.cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="agrupamento_dev_compra_prd_nf.nr_lote" dbalias="b.nr_lote" )
 column=(type=long updatewhereclause=yes name=qt_devolver dbname="agrupamento_dev_compra_prd_nf.qt_devolver" dbalias="b.qt_devolver" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote_original dbname="agrupamento_dev_compra_prd_nf.nr_lote_original" dbalias="b.nr_lote_original" )
 retrieve="select 	b.cd_filial,
			b.cd_fornecedor,
			b.nr_nf,
			b.de_especie,
			b.de_serie,
			b.cd_natureza_operacao,
			b.cd_produto,
			b.nr_lote_nf nr_lote,
			b.qt_devolver,
			b.nr_lote as nr_lote_original
from agrupamento_dev_compra_prd a
inner join agrupamento_dev_compra_prd_nf b on b.nr_agrupamento = a.nr_agrupamento
															and b.cd_produto = a.cd_produto
															and b.cd_endereco_localizacao = a.cd_endereco_localizacao
															and b.nr_lote = a.nr_lote
where a.nr_agrupamento 			= :nr_agrupamento 
	and a.cd_produto 					= :cd_produto
	and a.cd_endereco_localizacao	= :cd_endereco_localizacao
	and a.nr_lote						= :nr_lote" arguments=(("nr_agrupamento", number),("cd_produto", number),("cd_endereco_localizacao", string),("nr_lote", string)) )
