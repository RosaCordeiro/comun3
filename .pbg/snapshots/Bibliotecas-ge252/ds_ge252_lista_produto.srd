table(column=(type=long updatewhereclause=yes name=nr_agrupamento dbname="nr_agrupamento" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_devolver dbname="qt_devolver" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="de_apresentacao_estoque" )
 column=(type=char(1) updatewhereclause=yes name=nm_produto dbname="nm_produto" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_compra dbname="cd_unidade_medida_compra" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco dbname="vl_preco" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_fornecedor dbname="pc_desconto_fornecedor" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco_localizacao dbname="cd_endereco_localizacao" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="dh_validade" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" )
 column=(type=long updatewhereclause=yes name=cd_motivo_ajuste dbname="cd_motivo_ajuste" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="cd_grupo_psico" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=long updatewhereclause=yes name=qt_nota dbname="qt_nota" )
 column=(type=long updatewhereclause=yes name=qt_sem_nota dbname="qt_sem_nota" )
 column=(type=char(1) updatewhereclause=yes name=id_destino_final dbname="id_destino_final" )
 retrieve="	SELECT distinct a.nr_agrupamento,   
          a.cd_produto,   
          coalesce(adcpn.qt_devolver, a.qt_devolver) as qt_devolver,  
          b.de_produto,   
          b.de_apresentacao_estoque,   
          ''nm_produto,   
          b.cd_unidade_medida_compra,   
          a.vl_preco,   
          a.pc_desconto_forn as pc_desconto_fornecedor,
			 a.cd_endereco_localizacao,
			 a.nr_lote,
			 a.dh_validade,
			 'N' id_selecionar,
			 c.cd_motivo_ajuste,
			 b.cd_grupo_psico,
			 d.cd_fornecedor,
			 adcpn.nr_nf,
			 adcpn.de_serie,
			 adcpn.de_especie,
			 adcpn.cd_filial,
			 d.id_situacao,
			 (select count(*) 
			 	from agrupamento_dev_compra_prd_nf n 
			   where n.nr_agrupamento = a.nr_agrupamento 
			   and n.cd_produto = a.cd_produto 
			   and n.cd_endereco_localizacao = a.cd_endereco_localizacao 
			   and n.nr_lote = a.nr_lote) as qt_nota,
			 a.qt_devolver - (select sum(qt_devolver)
									from agrupamento_dev_compra_prd_nf n 
									where n.nr_agrupamento = a.nr_agrupamento 
									and n.cd_produto = a.cd_produto 
									and n.cd_endereco_localizacao = a.cd_endereco_localizacao 
									and n.nr_lote = a.nr_lote) as qt_sem_nota,
			isnull(d.id_destino_final, '') as id_destino_final
     FROM agrupamento_dev_compra_prd a  
	 inner join agrupamento_dev_compra d on a.nr_agrupamento  = d.nr_agrupamento  
    left join agrupamento_dev_compra_prd_nf adcpn on a.nr_agrupamento 				= adcpn.nr_agrupamento 
																  and a.cd_produto 					= adcpn.cd_produto 
																  and a.nr_lote 						= adcpn.nr_lote
																  and a.cd_endereco_localizacao 	= adcpn.cd_endereco_localizacao 
    inner join produto_geral b on b.cd_produto = a.cd_produto
	  left Join tipo_nf_transferencia c on c.cd_endereco_wms = a.cd_endereco_localizacao
    WHERE a.nr_agrupamento = :nr_agrupamento
    ORDER BY adcpn.cd_filial,
   			 adcpn.cd_fornecedor,
   			 adcpn.nr_nf,
   			 adcpn.de_especie,
   			 adcpn.de_serie,
   			 adcpn.cd_produto,
   			 adcpn.nr_lote,
				 a.nr_agrupamento" arguments=(("nr_agrupamento", number)) )
