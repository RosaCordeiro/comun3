table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="produto_lote_nf_entrada.cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="produto_lote_nf_entrada.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="produto_lote_nf_entrada.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="produto_lote_nf_entrada.de_serie" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="produto_lote_nf_entrada.cd_natureza_operacao" )
 column=(type=long updatewhereclause=yes name=qt_lote dbname="qt_lote" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_compra.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="item_nf_compra.pc_desconto" )
 column=(type=char(10) updatewhereclause=yes name=nr_lote dbname="produto_lote_nf_entrada.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_compra.dh_emissao" )
 retrieve="select 	a.cd_fornecedor,
			a.nr_nf,
			a.de_especie,
			a.de_serie,
			a.cd_natureza_operacao,
			(b.qt_lote - (isnull(b.qt_devolvida, 0) + isnull(b.qt_reserva_devolucao, 0))) as qt_lote,
			c.vl_preco_unitario,
			c.pc_desconto,
			a.nr_lote,
			e.dh_emissao
from produto_lote_nf_entrada a
inner join item_nf_compra_lote b on b.cd_filial 						= a.cd_filial
											and b.cd_fornecedor 				= a.cd_fornecedor
											and b.nr_nf 							= a.nr_nf
											and b.de_especie 					= a.de_especie
											and b.de_serie 						= a.de_serie
											and b.cd_natureza_operacao 	= a.cd_natureza_operacao
											and b.cd_produto 					= a.cd_produto
											and b.nr_lote 						= a.nr_lote 
inner join item_nf_compra c on  c.cd_filial 						= b.cd_filial
									and c.cd_fornecedor 				= b.cd_fornecedor
									and c.nr_nf 							= b.nr_nf
									and c.de_especie 					= b.de_especie
									and c.de_serie 						= b.de_serie
									and c.cd_natureza_operacao	= b.cd_natureza_operacao
									and c.cd_produto 					= b.cd_produto	

inner join fornecedor d on d.cd_fornecedor = a.cd_fornecedor
inner join nf_compra e on e.cd_filial 						= a.cd_filial
							and e.cd_fornecedor 				= a.cd_fornecedor
							and e.nr_nf 							= a.nr_nf
							and e.de_especie 					= a.de_especie
							and e.de_serie 						= a.de_serie

where  a.cd_filial 			= 534
	and a.cd_fornecedor 	= :cd_fornecedor
	and a.cd_produto 		= :cd_produto
	and (d.id_situacao is null or d.id_situacao = 'A')
	and  a.dh_entrada >= dateadd(month, -20, cast(getDate() as date))
	and (b.qt_lote - (isnull(b.qt_devolvida, 0) + isnull(b.qt_reserva_devolucao, 0))) > 0" arguments=(("cd_fornecedor", string),("cd_produto", number))  sort="nr_nf A " )
