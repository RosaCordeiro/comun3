table(column=(type=long updatewhereclause=yes name=nr_agrupamento dbname="agrupamento_dev_compra_prd.nr_agrupamento" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="agrupamento_dev_compra_prd.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=produto dbname="produto" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="agrupamento_dev_compra_prd.nr_lote" )
 column=(type=char(7) updatewhereclause=yes name=situacao dbname="Situacao" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="agrupamento_dev_compra_prd.dh_validade" )
 column=(type=long updatewhereclause=yes name=qt_devolver dbname="agrupamento_dev_compra_prd.qt_devolver" )
 retrieve="select a.nr_agrupamento, 
	   a.cd_produto,
       (g.de_produto +' : '+g.de_apresentacao_estoque) as produto,   
	   a.nr_lote, 
	   case d.id_situacao  when 'A' Then 'ABERTO' else 'FECHADO' end as Situacao,
	   a.dh_validade,
	   a.qt_devolver  
FROM agrupamento_dev_compra_prd a 
inner join agrupamento_dev_compra d on d.nr_agrupamento = a.nr_agrupamento
inner join produto_geral g on g.cd_produto =a.cd_produto
inner join produto_central c on c.cd_produto = a.cd_produto
where  d.id_situacao  in ('A', 'F')
and a.cd_produto =:produto
and a.dh_validade = :validade
and a.nr_lote = :lote" arguments=(("produto", number),("validade", datetime),("lote", string)) )
