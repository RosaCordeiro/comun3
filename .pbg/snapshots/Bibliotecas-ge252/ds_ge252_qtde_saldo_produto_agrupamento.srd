table(column=(type=long updatewhereclause=yes name=cd_produto dbname="agrupamento_dev_compra_prd.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_devolver dbname="qt_devolver" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="saldo_produto.qt_saldo_final" )
 retrieve="select 	a.cd_produto,
			sum(a.qt_devolver) as qt_devolver,
			b.qt_saldo_final
from agrupamento_dev_compra_prd a
left join saldo_produto b on b.cd_produto = a.cd_produto and b.cd_filial = 1 and dh_saldo = :dh_saldo
where a.nr_agrupamento  = :nr_agrupamento 
group by a.cd_produto,
			b.qt_saldo_final
having sum(a.qt_devolver) > b.qt_saldo_final" arguments=(("nr_agrupamento", number),("dh_saldo", datetime)) )
