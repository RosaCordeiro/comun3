table(column=(type=long updatewhereclause=yes name=nr_agrupamento dbname="agrupamento_dev_compra.nr_agrupamento" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="agrupamento_dev_compra.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=char(48) updatewhereclause=yes name=nm_fornecedor dbname="nm_fornecedor" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="agrupamento_dev_compra.dh_inclusao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_inclusao dbname="agrupamento_dev_compra.nr_matricula_inclusao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_agrupamento dbname="agrupamento_dev_compra.vl_agrupamento" )
 column=(type=char(1) updatewhereclause=yes name=id_distribuidora dbname="fornecedor.id_distribuidora" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="agrupamento_dev_compra.id_situacao" values="ABERTO	A/FECHADO	F/RESOLV.	R/CANCEL.	X/PENDENTE	P/" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao_situacao dbname="agrupamento_dev_compra.dh_alteracao_situacao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_alteracao_situacao dbname="agrupamento_dev_compra.nr_matric_alteracao_situacao" )
 column=(type=char(255) updatewhereclause=yes name=de_observacao dbname="agrupamento_dev_compra.de_observacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_alteracao dbname="usuario.nm_usuario_alteracao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_comprador dbname="fornecedor.nr_matricula_comprador" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_comprador_agrup dbname="agrupamento_dev_compra.nr_matricula_comprador_agrup" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_comprador dbname="usuario.nm_usuario_comprador" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_comprador_agrup dbname="usuario.nm_usuario_comprador_agrup" )
 column=(type=long updatewhereclause=yes name=nr_volume dbname="agrupamento_dev_compra.nr_volume" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo_devolucao dbname="motivo_devolucao_compra.de_motivo_devolucao" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo dbname="agrupamento_dev_compra.id_tipo" values="SIM	1/N$$HEX1$$c300$$ENDHEX$$O	2/TODOS	3/" )
 column=(type=char(1) updatewhereclause=yes name=id_destino_final dbname="id_destino_final" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_kg dbname="qt_peso_kg" )
 column=(type=long updatewhereclause=yes name=cd_motivo_devolucao dbname="agrupamento_dev_compra.cd_motivo_devolucao" )
 column=(type=char(1) updatewhereclause=yes name=id_fechar dbname="id_fechar" values="	S/	N" )
 column=(type=decimal(5) updatewhereclause=yes name=vl_custo_insineracao dbname="vl_custo_insineracao" )
 column=(type=long updatewhereclause=yes name=nr_divisao_fornecedor dbname="agrupamento_dev_compra.nr_divisao_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_divisao dbname="fornecedor_divisao.nm_divisao" )
 column=(type=char(1) updatewhereclause=yes name=id_resolver dbname="id_resolver" values="	S/	N" )
 retrieve="   SELECT	a.nr_agrupamento,   
         		a.cd_fornecedor,
				b.nm_razao_social,
				'('+substring(a.cd_fornecedor, 5, 5)+') '+b.nm_razao_social as nm_fornecedor,
         		a.dh_inclusao,   
         		a.nr_matricula_inclusao,
				c.nm_usuario,
				a.vl_agrupamento,
				b.id_distribuidora,
				a.id_situacao,
				a.dh_alteracao_situacao,
				a.nr_matric_alteracao_situacao,
				a.de_observacao,
				d.nm_usuario nm_usuario_alteracao,
				b.nr_matricula_comprador,
				a.nr_matricula_comprador as nr_matricula_comprador_agrup,
				e.nm_usuario as nm_usuario_comprador,
				h.nm_usuario as nm_usuario_comprador_agrup,
				a.nr_volume,
				f.de_motivo_devolucao,
				a.id_tipo,
				isnull(a.id_destino_final, '') as id_destino_final,
				isnull(a.qt_peso_kg, 0)       as qt_peso_kg,
				a.cd_motivo_devolucao,
				'N' id_fechar,
  			    case when a.qt_peso_kg>0 then  
								((select cast(vl_parametro as decimal(10,2)) 
								  From wms_parametro  
								  where   cd_parametro ='VL_CUSTO_INSINERACAO' )  * a.qt_peso_kg) else 0 end as   vl_custo_insineracao,
				a.nr_divisao_fornecedor,
				i.nm_divisao,
				'N' id_resolver
FROM agrupamento_dev_compra			a  
INNER JOIN	fornecedor						b	ON b.cd_fornecedor 			= a.cd_fornecedor
INNER JOIN	usuario							c	ON c.nr_matricula				= a.nr_matricula_inclusao
LEFT JOIN	usuario							d	ON d.nr_matricula				= a.nr_matric_alteracao_situacao
LEFT JOIN	usuario							e	ON e.nr_matricula				= b.nr_matricula_comprador
LEFT JOIN	motivo_devolucao_compra	f	ON f.cd_motivo_devolucao	= a.cd_motivo_devolucao
LEFT JOIN	usuario							h	ON h.nr_matricula				= a.nr_matricula_comprador
LEFT JOIN	fornecedor_divisao			i	ON i.cd_fornecedor			= a.cd_fornecedor		and i.nr_divisao = a.nr_divisao_fornecedor
Where len(a.nr_matricula_inclusao)	>	0"  sort="nr_agrupamento A " )
