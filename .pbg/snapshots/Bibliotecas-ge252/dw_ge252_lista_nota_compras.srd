table(column=(type=long updatewhereclause=yes name=nr_agrupamento dbname="agrupamento_dev_compra_prd.nr_agrupamento" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="agrupamento_dev_compra_prd.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="agrupamento_dev_compra_prd.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="agrupamento_dev_compra_prd.dh_validade" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_pis_cofins dbname="produto_geral.id_situacao_pis_cofins" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_forn dbname="agrupamento_dev_compra_prd.pc_desconto_forn" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco dbname="agrupamento_dev_compra_prd.vl_preco" )
 column=(type=char(50) updatewhereclause=yes name=nr_protocolo dbname="nr_protocolo" )
 column=(type=char(50) updatewhereclause=yes name=de_motivo dbname="de_motivo" )
 column=(type=long updatewhereclause=yes name=qt_devolver dbname="qt_devolver" )
 retrieve="SELECT agrdev.nr_agrupamento
     , agrdev.cd_produto
     , prod.de_produto
     , prod.de_apresentacao_estoque
     , prod.de_codigo_barras
     , agrdev.nr_lote
     , agrdev.dh_validade
     , prod.id_situacao_pis_cofins
     , agrdev.pc_desconto_forn
     , agrdev.vl_preco
     , coalesce(prot.nr_protocolo,'') as nr_protocolo
     , coalesce(mot.de_motivo,'') as de_motivo	
     , sum(agrdev.qt_devolver) as qt_devolver
  FROM produto_geral  prod
       INNER JOIN agrupamento_dev_compra_prd  agrdev  on prod.cd_produto = agrdev.cd_produto
       LEFT OUTER JOIN agrupamento_dev_compra_prd_prt prot on prot.nr_agrupamento = agrdev.nr_agrupamento
                                                          AND prot.cd_produto = agrdev.cd_produto
                                                          AND prot.nr_lote = agrdev.nr_lote
                                                          AND prot.cd_endereco_localizacao = agrdev.cd_endereco_localizacao
       LEFT OUTER  JOIN wms_protocolo ptr on ptr.cd_produto = prot.cd_produto
                                                          AND ptr.nr_lote = prot.nr_lote
                                                          AND ptr.nr_protocolo = prot.nr_protocolo
       LEFT outer JOIN protocolo_defeito_motivo mot on mot.cd_motivo = ptr.cd_motivo_defeito
WHERE agrdev.nr_agrupamento = :nr_agrupamento
group by	agrdev.nr_agrupamento
       , agrdev.cd_produto
       ,	prod.de_produto
       , prod.de_apresentacao_estoque
       , prod.de_codigo_barras
       , agrdev.nr_lote
       , agrdev.dh_validade
       ,	prod.id_situacao_pis_cofins
       ,	agrdev.pc_desconto_forn
       ,	agrdev.vl_preco
       , coalesce(prot.nr_protocolo,'')
       , coalesce(mot.de_motivo,'')" arguments=(("nr_agrupamento", number))  sort="cd_produto A nr_lote A " )
