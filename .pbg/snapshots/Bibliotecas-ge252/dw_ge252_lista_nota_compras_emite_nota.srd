table(column=(type=long updatewhereclause=yes name=nr_agrupamento dbname="agrupamento_dev_compra_prd_nf.nr_agrupamento" dbalias="adcpn.nr_agrupamento" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="agrupamento_dev_compra_prd_nf.cd_produto" dbalias="adcpn.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="pg.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" dbalias="pg.de_apresentacao_estoque" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" dbalias="pg.de_codigo_barras" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="agrupamento_dev_compra_prd_nf.nr_lote" dbalias="adcpn.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="agrupamento_dev_compra_prd.dh_validade" dbalias="adcp.dh_validade" )
 column=(type=long updatewhereclause=yes name=qt_devolver dbname="qt_devolver" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_pis_cofins dbname="produto_geral.id_situacao_pis_cofins" dbalias="pg.id_situacao_pis_cofins" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="agrupamento_dev_compra_prd_nf.pc_desconto" dbalias="adcpn.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="agrupamento_dev_compra_prd_nf.vl_preco_unitario" dbalias="adcpn.vl_preco_unitario" )
 column=(type=char(52) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_compra.dh_movimentacao_caixa" dbalias="nc.dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="agrupamento_dev_compra_prd_nf.nr_nf" dbalias="adcpn.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="agrupamento_dev_compra_prd_nf.de_especie" dbalias="adcpn.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="agrupamento_dev_compra_prd_nf.de_serie" dbalias="adcpn.de_serie" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="agrupamento_dev_compra_prd_nf.cd_fornecedor" dbalias="adcpn.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=cd_endereco_localizacao dbname="cd_endereco_localizacao" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco_segregado dbname="agrupamento_dev_compra_prd_nf.cd_endereco_segregado" dbalias="adcpn.cd_endereco_segregado" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_kg dbname="qt_peso_kg" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote_nf dbname="agrupamento_dev_compra_prd_nf.nr_lote_nf" dbalias="adcpn.nr_lote_nf" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="agrupamento_dev_compra_prd_nf.cd_natureza_operacao" dbalias="adcpn.cd_natureza_operacao" )
 column=(type=char(50) updatewhereclause=yes name=nr_protocolo dbname="nr_protocolo" )
 column=(type=char(50) updatewhereclause=yes name=de_motivo dbname="de_motivo" )
 column=(type=datetime updatewhereclause=yes name=nf_compra_dh_emissao dbname="nf_compra.dh_emissao" dbalias="nc.dh_emissao" )
 retrieve="select 
	adcpn.nr_agrupamento,
	adcpn.cd_produto,
	pg.de_produto,   
	pg.de_apresentacao_estoque,
	pg.de_codigo_barras,
	adcpn.nr_lote,
	adcp.dh_validade,
	coalesce(adcppn.qt_lote, adcpn.qt_devolver) as qt_devolver, 
	pg.id_situacao_pis_cofins,
	adcpn.pc_desconto,
	adcpn.vl_preco_unitario,
	'('+f.cd_fornecedor+') '+f.nm_fantasia as nm_fantasia,
	nc.dh_movimentacao_caixa,
	adcpn.nr_nf,
	adcpn.de_especie,
	adcpn.de_serie,
	adcpn.cd_fornecedor,
	(Select vl_parametro From wms_parametro Where cd_parametro = 'CD_ENDERECO_SEGREGADO_AGRUPAMENTO_DEV') as cd_endereco_localizacao,
	adcpn.cd_endereco_localizacao as cd_endereco_segregado,
	coalesce(adcppn.qt_lote, adcpn.qt_devolver) * adcp.qt_peso_kg as qt_peso_kg,
	adcpn.nr_lote_nf,
	adcpn.cd_natureza_operacao,
    Coalesce(adcpp.nr_protocolo,'') as nr_protocolo,
	Coalesce(pdm.de_motivo,'' ) as de_motivo,
	nc.dh_emissao
from 
	agrupamento_dev_compra_prd_nf adcpn
inner join 
	agrupamento_dev_compra adc
	on adc.nr_agrupamento = adcpn.nr_agrupamento
Inner Join agrupamento_dev_compra_prd adcp 
	on adcp.nr_agrupamento = adcpn.nr_agrupamento
	and adcp.cd_produto 					= adcpn.cd_produto
	and adcp.cd_endereco_localizacao 	= adcpn.cd_endereco_localizacao
	and adcp.nr_lote 						= adcpn.nr_lote
inner join
	produto_geral pg
	on pg.cd_produto = adcpn.cd_produto
Inner Join 
	fornecedor f 
	on f.cd_fornecedor 	= adcpn.cd_fornecedor
Inner Join nf_compra nc 
	on nc.cd_filial 		= adcpn.cd_filial
	and nc.cd_fornecedor 	= adcpn.cd_fornecedor
	and nc.nr_nf 			= adcpn.nr_nf
	and nc.de_especie 		= adcpn.de_especie
	and nc.de_serie 		= adcpn.de_serie
Left Outer Join 
	agrupamento_dev_com_prd_prt_nf adcppn 
	on adcpn.nr_agrupamento 				= adcppn.nr_agrupamento 
	And adcpn.cd_filial 					= adcppn.cd_filial
	And adcpn.nr_lote 					= adcppn.nr_lote
	And adcpn.cd_produto 				= adcppn.cd_produto
	And adcpn.cd_endereco_localizacao 	= adcppn.cd_endereco_localizacao
	And adcpn.nr_nf = adcppn.nr_nf_origem 
	And adcpn.de_especie = adcppn.de_especie_origem 
	And adcpn.de_serie = adcppn.de_serie_origem 
	And adcpn.cd_natureza_operacao 		= adcppn.cd_natureza_operacao
Left Outer Join 
	agrupamento_dev_compra_prd_prt adcpp 
	on adcpp.nr_agrupamento 		= adcppn.nr_agrupamento
    And adcpp.cd_produto 	= adcppn.cd_produto
    And adcpp.nr_lote 		= adcppn.nr_lote
    And adcpp.nr_protocolo = adcppn.nr_protocolo
    And adcpp.cd_endereco_localizacao = adcppn.cd_endereco_localizacao
Left Outer Join wms_protocolo wp on wp.cd_produto 				= adcpp.cd_produto
                                        And wp.nr_lote 			= adcpp.nr_lote
                                        And wp.nr_protocolo 	= adcpp.nr_protocolo
Left Outer Join protocolo_defeito_motivo pdm on pdm.cd_motivo = adcppn.cd_motivo_defeito
where 
	((adcppn.cd_motivo_defeito = wp.cd_motivo_defeito) or adcpp.nr_protocolo is null)
	and adcpn.nr_agrupamento = :nr_agrupamento
" arguments=(("nr_agrupamento", number))  sort="nr_nf A " )
