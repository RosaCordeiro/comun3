table(column=(type=long updatewhereclause=yes name=nr_agrupamento dbname="agrupamento_dev_compra_prd_nf.nr_agrupamento" dbalias="a.nr_agrupamento" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="agrupamento_dev_compra_prd_nf.cd_produto" dbalias="a.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="b.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" dbalias="b.de_apresentacao_estoque" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" dbalias="b.de_codigo_barras" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="agrupamento_dev_compra_prd_nf.nr_lote" dbalias="a.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="agrupamento_dev_compra_prd.dh_validade" dbalias="e.dh_validade" )
 column=(type=long updatewhereclause=yes name=qt_devolver dbname="qt_devolver" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_pis_cofins dbname="produto_geral.id_situacao_pis_cofins" dbalias="b.id_situacao_pis_cofins" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="agrupamento_dev_compra_prd_nf.pc_desconto" dbalias="a.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="agrupamento_dev_compra_prd_nf.vl_preco_unitario" dbalias="a.vl_preco_unitario" )
 column=(type=char(52) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_compra.dh_movimentacao_caixa" dbalias="d.dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="agrupamento_dev_compra_prd_nf.nr_nf" dbalias="a.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="agrupamento_dev_compra_prd_nf.de_especie" dbalias="a.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="agrupamento_dev_compra_prd_nf.de_serie" dbalias="a.de_serie" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="agrupamento_dev_compra_prd_nf.cd_fornecedor" dbalias="a.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=cd_endereco_localizacao dbname="cd_endereco_localizacao" )
 column=(type=char(8) updatewhereclause=yes name=agrupamento_dev_compra_prd_nf_cd_endereco_segregado dbname="agrupamento_dev_compra_prd_nf.cd_endereco_segregado" dbalias="a.cd_endereco_segregado" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_kg dbname="qt_peso_kg" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote_nf dbname="agrupamento_dev_compra_prd_nf.nr_lote_nf" dbalias="a.nr_lote_nf" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="agrupamento_dev_compra_prd_nf.cd_natureza_operacao" dbalias="a.cd_natureza_operacao" )
 column=(type=char(50) updatewhereclause=yes name=nr_protocolo dbname="nr_protocolo" )
 column=(type=char(50) updatewhereclause=yes name=de_motivo dbname="de_motivo" )
 column=(type=datetime updatewhereclause=yes name=nf_compra_dh_emissao dbname="nf_compra.dh_emissao" dbalias="d.dh_emissao" )
 retrieve="Select 	a.nr_agrupamento,
		a.cd_produto,   
		b.de_produto,   
		b.de_apresentacao_estoque,
		b.de_codigo_barras,
		a.nr_lote, 
		e.dh_validade,
		Coalesce(adcp.qt_lote, SUM(a.qt_devolver)) as qt_devolver, ----ajustei para pega o valor
		b.id_situacao_pis_cofins,   
		a.pc_desconto,   
		a.vl_preco_unitario,
		'('+a.cd_fornecedor+') '+c.nm_fantasia as nm_fantasia,
		d.dh_movimentacao_caixa,
		a.nr_nf,
		a.de_especie,
		a.de_serie,
		a.cd_fornecedor,
		(Select vl_parametro From wms_parametro Where cd_parametro = 'CD_ENDERECO_SEGREGADO_AGRUPAMENTO_DEV') as cd_endereco_localizacao,
		a.cd_endereco_localizacao as cd_endereco_segregado,
		sum(a.qt_devolver) * e.qt_peso_kg as qt_peso_kg,
		a.nr_lote_nf,
		a.cd_natureza_operacao,
		Coalesce(prt.nr_protocolo,'') as nr_protocolo,
		Coalesce(mot.de_motivo,'' ) as de_motivo,
        d.dh_emissao
From agrupamento_dev_compra_prd_nf a
Inner Join produto_geral 	b on b.cd_produto 		= a.cd_produto
Inner Join fornecedor 		c on c.cd_fornecedor 	= a.cd_fornecedor
Inner Join nf_compra		d on d.cd_filial 		= a.cd_filial
								and d.cd_fornecedor	= a.cd_fornecedor
								and d.nr_nf 		= a.nr_nf
								and d.de_especie 	= a.de_especie
								and d.de_serie 		= a.de_serie
Inner Join agrupamento_dev_compra_prd e on e.nr_agrupamento 			= a.nr_agrupamento
										and e.cd_produto				= a.cd_produto
										and e.cd_endereco_localizacao 	= a.cd_endereco_localizacao
										and e.nr_lote					= a.nr_lote
Left Outer Join agrupamento_dev_compra_prd_prt prt on prt.nr_agrupamento 	= a.nr_agrupamento
                                                        And prt.cd_produto 	= a.cd_produto
                                                        And prt.nr_lote 	= a.nr_lote
                                                        And prt.cd_endereco_localizacao = a.cd_endereco_localizacao
Left Outer Join wms_protocolo prot on prt.cd_produto 			= prot.cd_produto
                                        And prt.nr_lote 		= prot.nr_lote
                                        And prt.nr_protocolo 	= prot.nr_protocolo
Left Outer Join agrupamento_dev_com_prd_prt_nf adcp on adcp.nr_agrupamento 				= a.nr_agrupamento 
													And adcp.cd_filial 					= a.cd_filial
													And adcp.nr_lote 					= a.nr_lote
													And adcp.cd_produto 				= a.cd_produto
													And adcp.cd_endereco_localizacao 	= a.cd_endereco_localizacao 
													And adcp.nr_protocolo 				= prt.nr_protocolo
													And adcp.nr_nf_origem 				= a.nr_nf 
													And adcp.de_especie_origem 			= a.de_especie
													And adcp.de_serie_origem 			= a.de_serie 
													And adcp.cd_natureza_operacao = a.cd_natureza_operacao
Left Outer Join protocolo_defeito_motivo mot on mot.cd_motivo = COALESCE(adcp.cd_motivo_defeito, prot.cd_motivo_defeito)
WHERE a.nr_agrupamento = :nr_agrupamento   
group by
	a.nr_agrupamento,
	a.cd_produto,   
	b.de_produto,   
	b.de_apresentacao_estoque,  
	b.de_codigo_barras, 
	a.nr_lote,
	b.id_situacao_pis_cofins,   
	a.pc_desconto,   
	a.vl_preco_unitario ,
	a.cd_fornecedor,
	c.nm_fantasia,
	d.dh_movimentacao_caixa,
	a.nr_nf,
	a.de_especie,
	a.de_serie,
	a.cd_fornecedor,
	e.dh_validade,
	a.cd_endereco_localizacao,
	e.qt_peso_kg,
	a.nr_lote_nf,
	a.cd_natureza_operacao,
	coalesce(prt.nr_protocolo,''),
	coalesce(mot.de_motivo, ''),
   d.dh_emissao,
   adcp.qt_lote
order by c.nm_fantasia,
			coalesce(mot.de_motivo, ''),
			a.cd_fornecedor,
			a.nr_nf,
			a.de_serie,
			a.de_especie,
			b.de_produto,   
			b.de_apresentacao_estoque,
         d.dh_emissao" arguments=(("nr_agrupamento", number))  sort="nr_nf A " )
