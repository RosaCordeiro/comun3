table(column=(type=long updatewhereclause=yes name=item_nf_compra_cd_produto dbname="item_nf_compra.cd_produto" dbalias="i.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="p.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" dbalias="p.de_apresentacao_estoque" )
 column=(type=long updatewhereclause=yes name=qt_devolver dbname="agrupamento_dev_compra_prd.qt_devolver" dbalias="l.qt_devolver" )
 column=(type=long updatewhereclause=yes name=nf_compra_cd_filial dbname="nf_compra.cd_filial" dbalias="n.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nf_compra_nr_nf dbname="nf_compra.nr_nf" dbalias="n.nr_nf" )
 column=(type=datetime updatewhereclause=yes name=nf_compra_dh_movimentacao_caixa dbname="nf_compra.dh_movimentacao_caixa" dbalias="n.dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=item_nf_compra_qt_faturada dbname="item_nf_compra.qt_faturada" dbalias="i.qt_faturada" )
 column=(type=decimal(2) updatewhereclause=yes name=item_nf_compra_vl_preco_unitario dbname="item_nf_compra.vl_preco_unitario" dbalias="i.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=item_nf_compra_pc_desconto dbname="item_nf_compra.pc_desconto" dbalias="i.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=item_nf_compra_pc_icms dbname="item_nf_compra.pc_icms" dbalias="i.pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=item_nf_compra_pc_ipi dbname="item_nf_compra.pc_ipi" dbalias="i.pc_ipi" )
 column=(type=decimal(2) updatewhereclause=yes name=item_nf_compra_vl_icms_repassado dbname="item_nf_compra.vl_icms_repassado" dbalias="i.vl_icms_repassado" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_compra_vl_icms_repassado dbname="nf_compra.vl_icms_repassado" dbalias="n.vl_icms_repassado" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_compra_vl_desconto dbname="nf_compra.vl_desconto" dbalias="n.vl_desconto" )
 retrieve="Select i.cd_produto,
		 p.de_produto,
       p.de_apresentacao_estoque,
       l.qt_devolver,
       n.cd_filial,
       f.nm_fantasia,
       n.nr_nf,
       n.dh_movimentacao_caixa,
       i.qt_faturada,
       i.vl_preco_unitario,
		 i.pc_desconto,
       i.pc_icms,
       i.pc_ipi,
       i.vl_icms_repassado,
		 n.vl_icms_repassado,
       n.vl_desconto
From nf_compra n,
	 item_nf_compra i,
	 produto_geral p, 
	 filial f,
	 agrupamento_dev_compra_prd l
Where n.cd_filial     		   = i.cd_filial
  and n.cd_fornecedor 		   = i.cd_fornecedor
  and n.nr_nf         		   = i.nr_nf
  and n.de_especie    		   = i.de_especie
  and n.de_serie      		   = i.de_serie
  and n.cd_filial     		   = f.cd_filial
  and n.dh_movimentacao_caixa <= :dt_devolucao
  and n.cd_fornecedor          = :cd_fornecedor
  and i.cd_produto    		   = p.cd_produto
  and i.cd_produto    		   = l.cd_produto
  and l.nr_agrupamento	   = :nr_agrupamento
  



" arguments=(("nr_agrupamento", number),("cd_fornecedor", string),("dt_devolucao", datetime))  sort="item_nf_compra_cd_produto A nf_compra_dh_movimentacao_caixa A " )
