table(column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="agrupamento_dev_compra_prd_nf.nr_nf" )
 column=(type=datetime updatewhereclause=yes name=entrada dbname="agrupamento_dev_compra.entrada" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="agrupamento_dev_compra_prd.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="agrupamento_dev_compra_prd.dh_validade" )
 column=(type=long updatewhereclause=yes name=qt_devolver dbname="agrupamento_dev_compra_prd_nf.qt_devolver" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="item_nf_transferencia.vl_custo_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="agrupamento_dev_compra_prd_nf.pc_desconto" )
 column=(type=decimal(15) updatewhereclause=yes name=total dbname="total" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="fornecedor.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=de_fornecedor dbname="fornecedor.de_fornecedor" )
 retrieve="select f.nm_fantasia as nm_fantasia,
		 f.cd_filial,
		 n.nr_nf,
		 a.dh_inclusao entrada,
		 g.cd_produto,
		 g.de_produto,
		 g.de_apresentacao_estoque,
		 p.nr_lote,
		 p.dh_validade,
		 n.qt_devolver,
		 t.vl_custo_unitario,
		 n.pc_desconto,
		 (n.qt_devolver * t.vl_custo_unitario) * ( 1 - (n.pc_desconto/100)) total,
		 fo.cd_fornecedor,
		 fo.nm_fantasia de_fornecedor
  from agrupamento_dev_compra a inner join agrupamento_dev_compra_prd p on a.nr_agrupamento = p.nr_agrupamento
  										  inner join agrupamento_dev_compra_prd_nf n on p.nr_agrupamento				= n.nr_agrupamento  and
																										p.cd_produto					= n.cd_produto and
																										p.cd_endereco_localizacao 	= n.cd_endereco_localizacao and
																										p.nr_lote						= n.nr_lote
										  inner join filial f on f.cd_filial = n.cd_filial
										  inner join produto_geral g on p.cd_produto	= g.cd_produto
										  inner join item_nf_transferencia t on t.nr_nf						= n.nr_nf and
																							 t.de_serie					= n.de_serie and
																							 t.de_especie				= n.de_especie and
																							 t.cd_filial_origem		= n.cd_filial and
																							 t.cd_produto				= n.cd_produto and
																							 t.cd_natureza_operacao	= n.cd_natureza_operacao
										  left outer join fornecedor fo on fo.cd_fornecedor = n.cd_fornecedor
 where a.nr_agrupamento	= :anr_agrupamento and
		 n.cd_fornecedor	= '053404705'

union

select f.nm_fantasia,
		 f.cd_filial,
		 n.nr_nf,
		 a.dh_inclusao entrada,
		 g.cd_produto,
		 g.de_produto,
		 g.de_apresentacao_estoque,
		 p.nr_lote,
		 p.dh_validade,
		 n.qt_devolver,
		 n.vl_preco_unitario,
		 n.pc_desconto,
		 (n.qt_devolver * n.vl_preco_unitario) * ( 1 - (n.pc_desconto/100)) total,
		 fo.cd_fornecedor,
		 fo.nm_fantasia de_fornecedor
  from agrupamento_dev_compra a inner join agrupamento_dev_compra_prd p on a.nr_agrupamento = p.nr_agrupamento
  										  inner join agrupamento_dev_compra_prd_nf n on p.nr_agrupamento				= n.nr_agrupamento  and
																										p.cd_produto					= n.cd_produto and
																										p.cd_endereco_localizacao 	= n.cd_endereco_localizacao and
																										p.nr_lote						= n.nr_lote
										  inner join filial f on f.cd_filial = n.cd_filial
										  inner join produto_geral g on p.cd_produto	= g.cd_produto
										  left outer join fornecedor fo on fo.cd_fornecedor = n.cd_fornecedor
 where a.nr_agrupamento	= :anr_agrupamento and
		 n.cd_fornecedor	<> '053404705'" arguments=(("anr_agrupamento", number))  sort="de_fornecedor A cd_fornecedor A cf_de_produto A cd_produto A " )
