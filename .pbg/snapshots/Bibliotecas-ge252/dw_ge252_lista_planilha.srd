table(column=(type=long updatewhereclause=yes name=nr_agrupamento dbname="agrupamento_dev_compra.nr_agrupamento" dbalias="a.nr_agrupamento" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="agrupamento_dev_compra.cd_fornecedor" dbalias="a.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" dbalias="b.nm_razao_social" )
 column=(type=char(48) updatewhereclause=yes name=nm_fornecedor dbname="nm_fornecedor" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="agrupamento_dev_compra.dh_inclusao" dbalias="a.dh_inclusao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_inclusao dbname="agrupamento_dev_compra.nr_matricula_inclusao" dbalias="a.nr_matricula_inclusao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="c.nm_usuario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_agrupamento dbname="agrupamento_dev_compra.vl_agrupamento" dbalias="a.vl_agrupamento" )
 column=(type=char(1) updatewhereclause=yes name=id_distribuidora dbname="fornecedor.id_distribuidora" dbalias="b.id_distribuidora" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="agrupamento_dev_compra.id_situacao" dbalias="a.id_situacao" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao_situacao dbname="agrupamento_dev_compra.dh_alteracao_situacao" dbalias="a.dh_alteracao_situacao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_alteracao_situacao dbname="agrupamento_dev_compra.nr_matric_alteracao_situacao" dbalias="a.nr_matric_alteracao_situacao" )
 column=(type=char(255) updatewhereclause=yes name=de_observacao dbname="agrupamento_dev_compra.de_observacao" dbalias="a.de_observacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_alteracao dbname="usuario.nm_usuario_alteracao" dbalias="d.nm_usuario_alteracao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_comprador dbname="fornecedor.nr_matricula_comprador" dbalias="b.nr_matricula_comprador" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_comprador_agrup dbname="agrupamento_dev_compra.nr_matricula_comprador_agrup" dbalias="a.nr_matricula_comprador_agrup" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_comprador dbname="usuario.nm_usuario_comprador" dbalias="e.nm_usuario_comprador" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_comprador_agrup dbname="usuario.nm_usuario_comprador_agrup" dbalias="h.nm_usuario_comprador_agrup" )
 column=(type=long updatewhereclause=yes name=nr_volume dbname="agrupamento_dev_compra.nr_volume" dbalias="a.nr_volume" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo_devolucao dbname="motivo_devolucao_compra.de_motivo_devolucao" dbalias="f.de_motivo_devolucao" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo dbname="agrupamento_dev_compra.id_tipo" dbalias="a.id_tipo" )
 column=(type=char(1) updatewhereclause=yes name=id_destino_final dbname="id_destino_final" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_kg dbname="qt_peso_kg" )
 column=(type=long updatewhereclause=yes name=cd_motivo_devolucao dbname="agrupamento_dev_compra.cd_motivo_devolucao" dbalias="a.cd_motivo_devolucao" )
 column=(type=char(1) updatewhereclause=yes name=id_marcar dbname="id_marcar" )
 column=(type=decimal(5) updatewhereclause=yes name=vl_custo_insineracao dbname="vl_custo_insineracao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="agrupamento_dev_compra_prd.cd_produto" dbalias="agr.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="prod.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" dbalias="prod.de_apresentacao_estoque" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" dbalias="prod.de_codigo_barras" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="agrupamento_dev_compra_prd.nr_lote" dbalias="agr.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="agrupamento_dev_compra_prd.dh_validade" dbalias="agr.dh_validade" )
 column=(type=long updatewhereclause=yes name=qt_devolver dbname="qt_devolver" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_pis_cofins dbname="produto_geral.id_situacao_pis_cofins" dbalias="prod.id_situacao_pis_cofins" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_forn dbname="pc_desconto_forn" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_reposicao dbname="vl_preco_reposicao" )
 column=(type=datetime updatewhereclause=yes name=dh_entrada dbname="nf_compra.dh_entrada" dbalias="j.dh_entrada" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="agrupamento_dev_compra_prd_nf.nr_nf" dbalias="i.nr_nf" )
 column=(type=char(20) updatewhereclause=yes name=motivo_ajuste dbname="tipo_nf_transferencia.motivo_ajuste" dbalias="t.motivo_ajuste" )
 column=(type=long updatewhereclause=yes name=qt_devolver_por_nf_origem dbname="agrupamento_dev_compra_prd_nf.qt_devolver_por_nf_origem" dbalias="i.qt_devolver_por_nf_origem" )
 retrieve=" SELECT	a.nr_agrupamento,
			a.cd_fornecedor,
			b.nm_razao_social,
			'('+substring(a.cd_fornecedor, 5, 5)+') '+b.nm_razao_social as nm_fornecedor,
			a.dh_inclusao,
			a.nr_matricula_inclusao,
			c.nm_usuario,
			a.vl_agrupamento,
			b.id_distribuidora,
			a.id_situacao,
			a.dh_alteracao_situacao,
			a.nr_matric_alteracao_situacao,
			a.de_observacao,
			d.nm_usuario nm_usuario_alteracao,
			b.nr_matricula_comprador,
			a.nr_matricula_comprador as nr_matricula_comprador_agrup,
			e.nm_usuario as nm_usuario_comprador,
			h.nm_usuario as nm_usuario_comprador_agrup,
			a.nr_volume,
			f.de_motivo_devolucao,
			a.id_tipo,
			isnull(a.id_destino_final, '') as id_destino_final,
			isnull(a.qt_peso_kg, 0)       as qt_peso_kg,
			a.cd_motivo_devolucao,
			'N' id_marcar,
			case when a.qt_peso_kg>0 then
				((select cast(vl_parametro as decimal(10,2))
				  From wms_parametro
				  where   cd_parametro ='VL_CUSTO_INSINERACAO' )  * a.qt_peso_kg)
			else
				0
			end as	vl_custo_insineracao,
			agr.cd_produto,
			prod.de_produto,
			prod.de_apresentacao_estoque,
			prod.de_codigo_barras,
			agr.nr_lote,
			agr.dh_validade,
			case when a.id_destino_final = 'D' then
					sum(agr.qt_devolver)
				else
					sum(i.qt_devolver)
			end as qt_devolver,
			prod.id_situacao_pis_cofins,
			case when a.id_destino_final = 'D' then
					agr.pc_desconto_forn
				else
					i.pc_desconto
			end as pc_desconto_forn,
			case when a.id_destino_final = 'D' then
					agr.vl_preco
				else
					i.vl_preco_unitario
			end as vl_preco_reposicao,
			j.dh_movimentacao_caixa as dh_entrada,
			i.nr_nf,
			t.de_tipo motivo_ajuste,
			i.qt_devolver qt_devolver_por_nf_origem
FROM agrupamento_dev_compra	a 	
INNER JOIN agrupamento_dev_compra_prd		agr	ON 	agr.nr_agrupamento			= a.nr_agrupamento
INNER JOIN produto_geral							prod	ON 	prod.cd_produto				= agr.cd_produto
INNER JOIN fornecedor								b		ON 	b.cd_fornecedor				= a.cd_fornecedor
INNER JOIN usuario									c		ON 	c.nr_matricula					= a.nr_matricula_inclusao
LEFT JOIN usuario										d		ON 	d.nr_matricula					= a.nr_matric_alteracao_situacao
LEFT JOIN usuario										e		ON 	e.nr_matricula					= b.nr_matricula_comprador
LEFT JOIN motivo_devolucao_compra				f		ON 	f.cd_motivo_devolucao		= a.cd_motivo_devolucao
LEFT JOIN usuario										h		ON		h.nr_matricula					= a.nr_matricula_comprador
LEFT JOIN agrupamento_dev_compra_prd_nf	i		ON 	i.nr_agrupamento 				= agr.nr_agrupamento
																	and	i.cd_produto 					= agr.cd_produto
																	and	i.cd_endereco_localizacao 	= agr.cd_endereco_localizacao
																	and	i.nr_lote 							= agr.nr_lote
LEFT JOIN nf_compra									j 		on 	j.cd_filial 						= i.cd_filial
																	and	j.cd_fornecedor 				= i.cd_fornecedor
																	and	j.nr_nf 							= i.nr_nf
																	and	j.de_especie 					= i.de_especie
																	and	j.de_serie 						= i.de_serie
left join tipo_nf_transferencia	t on t.cd_endereco_wms = agr.cd_endereco_localizacao
Where len(a.nr_matricula_inclusao) > 0
Group By	a.nr_agrupamento,
			a.cd_fornecedor,
			b.nm_razao_social,
			'('+substring(a.cd_fornecedor, 5, 5)+') '+b.nm_razao_social,
			a.dh_inclusao,
			a.nr_matricula_inclusao,
			c.nm_usuario,
			a.vl_agrupamento,
			b.id_distribuidora,
			a.id_situacao,
			a.dh_alteracao_situacao,
			a.nr_matric_alteracao_situacao,
			a.de_observacao,
			d.nm_usuario,
			b.nr_matricula_comprador,
			a.nr_matricula_comprador,
			e.nm_usuario,
			h.nm_usuario,
			a.nr_volume,
			f.de_motivo_devolucao,
			a.id_tipo,
			a.id_destino_final,
			a.qt_peso_kg,
			a.cd_motivo_devolucao,
			agr.cd_produto,
			prod.de_produto,
			prod.de_apresentacao_estoque,
			prod.de_codigo_barras,
			agr.nr_lote,
			agr.dh_validade,
			prod.id_situacao_pis_cofins,
			agr.pc_desconto_forn,
			i.pc_desconto,
			agr.vl_preco,
			i.vl_preco_unitario,
			j.dh_movimentacao_caixa,
			i.nr_nf,
			t.de_tipo,
			i.qt_devolver"  sort="nr_agrupamento A cd_produto A nr_lote A " )
