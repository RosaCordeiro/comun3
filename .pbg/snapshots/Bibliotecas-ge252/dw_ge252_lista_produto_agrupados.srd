table(column=(type=long updatewhereclause=yes key=yes name=nr_agrupamento dbname="agrupamento_dev_compra_prd.nr_agrupamento" dbalias="a.nr_agrupamento" values="	S/	N" )
 column=(type=long updatewhereclause=yes key=yes name=cd_produto dbname="agrupamento_dev_compra_prd.cd_produto" dbalias="a.cd_produto" values="	S/	N" )
 column=(type=long updatewhereclause=yes name=qt_devolver dbname="qt_devolver" )
 column=(type=char(8) updatewhereclause=yes key=yes name=cd_endereco_localizacao dbname="agrupamento_dev_compra_prd.cd_endereco_localizacao" dbalias="a.cd_endereco_localizacao" )
 column=(type=char(20) updatewhereclause=yes key=yes name=nr_lote dbname="agrupamento_dev_compra_prd.nr_lote" dbalias="a.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="agrupamento_dev_compra_prd.dh_validade" dbalias="a.dh_validade" )
 retrieve="SELECT a.nr_agrupamento,   
        	 a.cd_produto,   
			 sum(a.qt_devolver) as qt_devolver,   
           a.cd_endereco_localizacao,
			 a.nr_lote,
			 a.dh_validade
    from agrupamento_dev_compra_prd a 
   where a.nr_agrupamento = :nr_agrupamento
   group by a.nr_agrupamento,   
        	 a.cd_produto,   
           a.cd_endereco_localizacao,
			 a.nr_lote,
			 a.dh_validade
   order by a.cd_produto,
   			a.nr_lote" update="agrupamento_dev_compra_prd" updatewhere=0 updatekeyinplace=no arguments=(("nr_agrupamento", number))  sort="nr_lote A " )
