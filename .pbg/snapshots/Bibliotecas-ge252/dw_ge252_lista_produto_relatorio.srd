table(column=(type=long updatewhereclause=yes name=nr_agrupamento dbname="agrupamento_dev_compra_prd.nr_agrupamento" dbalias="a.nr_agrupamento" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="agrupamento_dev_compra_prd.cd_produto" dbalias="a.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_devolver dbname="agrupamento_dev_compra_prd.qt_devolver" dbalias="a.qt_devolver" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="g.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=produto_geral_de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" dbalias="g.de_apresentacao_estoque" )
 column=(type=char(1) updatewhereclause=yes name=nm_produto dbname="nm_produto" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_compra dbname="produto_geral.cd_unidade_medida_compra" dbalias="g.cd_unidade_medida_compra" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco dbname="agrupamento_dev_compra_prd.vl_preco" dbalias="a.vl_preco" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_fornecedor dbname="agrupamento_dev_compra_prd.pc_desconto_fornecedor" dbalias="a.pc_desconto_fornecedor" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco_localizacao dbname="agrupamento_dev_compra_prd.cd_endereco_localizacao" dbalias="a.cd_endereco_localizacao" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="agrupamento_dev_compra_prd.nr_lote" dbalias="a.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="agrupamento_dev_compra_prd.dh_validade" dbalias="a.dh_validade" )
 column=(type=char(20) updatewhereclause=yes name=de_tipo dbname="tipo_nf_transferencia.de_tipo" dbalias="t.de_tipo" )
 column=(type=long updatewhereclause=yes name=cd_tipo dbname="tipo_nf_transferencia.cd_tipo" dbalias="t.cd_tipo" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" dbalias="g.cd_grupo_psico" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="agrupamento_dev_compra.cd_fornecedor" dbalias="d.cd_fornecedor" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_kg_estoque dbname="qt_peso_kg_estoque" )
 column=(type=char(9) updatewhereclause=yes name=cd_subcategoria dbname="produto_geral.cd_subcategoria" dbalias="g.cd_subcategoria" )
 retrieve=" SELECT		a.nr_agrupamento,   
        			a.cd_produto,   
        			a.qt_devolver,  
         		g.de_produto,   
         		g.de_apresentacao_estoque,   
				'' nm_produto,
         		g.cd_unidade_medida_compra,   
        			
				a.vl_preco,   
        			a.pc_desconto_forn as pc_desconto_fornecedor,
				a.cd_endereco_localizacao,
				a.nr_lote,
				a.dh_validade,
				t.de_tipo,
				t.cd_tipo,
				'N' id_selecionar,
				g.cd_grupo_psico,
				d.cd_fornecedor,
				case when c.qt_peso_kg_estoque is not null then
						isnull(c.qt_peso_kg_estoque  * a.qt_devolver , 0)
					else
						isnull(g.qt_peso_grama * a.qt_devolver, 0)
				end qt_peso_kg_estoque,
			g.cd_subcategoria
    FROM agrupamento_dev_compra_prd a 
inner join agrupamento_dev_compra d on d.nr_agrupamento = a.nr_agrupamento
inner join produto_geral g on g.cd_produto =a.cd_produto
inner join produto_central c on c.cd_produto = a.cd_produto
left join tipo_nf_transferencia	t on t.cd_endereco_wms = a.cd_endereco_localizacao
WHERE a.nr_agrupamento = :nr_agrupamento    " arguments=(("nr_agrupamento", number))  sort="de_produto A " )
