table(column=(type=long updatewhereclause=yes name=qt_utilizado dbname="wms_protocolo.qt_utilizado" dbalias=".qt_utilizado" )
 column=(type=long updatewhereclause=yes name=qt_lote dbname="wms_protocolo.qt_lote" dbalias=".qt_lote" )
 column=(type=long updatewhereclause=yes name=cd_motivo_defeito dbname="wms_protocolo.cd_motivo_defeito" dbalias=".cd_motivo_defeito" )
 column=(type=char(50) updatewhereclause=yes name=nr_protocolo dbname="wms_protocolo.nr_protocolo" dbalias=".nr_protocolo" )
 column=(type=char(10) updatewhereclause=yes name=nr_lote dbname="wms_protocolo.nr_lote" dbalias=".nr_lote" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_protocolo.cd_produto" dbalias=".cd_produto" )
 column=(type=char(50) updatewhereclause=yes name=protocolo_old dbname="wms_protocolo.protocolo_old" dbalias=".protocolo_old" )
 column=(type=long updatewhereclause=yes name=defeito_old dbname="wms_protocolo.defeito_old" dbalias=".defeito_old" )
 retrieve="  SELECT wms_protocolo.qt_utilizado,   
         wms_protocolo.qt_lote,   
         wms_protocolo.cd_motivo_defeito,   
         wms_protocolo.nr_protocolo,   
         wms_protocolo.nr_lote,   
         wms_protocolo.cd_produto,  
         wms_protocolo.nr_protocolo as protocolo_old,   
         wms_protocolo.cd_motivo_defeito as defeito_old
    FROM item_nf_transferencia_lote_prt ,   
         wms_protocolo  
   WHERE ( item_nf_transferencia_lote_prt.cd_produto = wms_protocolo.cd_produto ) 
     and ( item_nf_transferencia_lote_prt.nr_lote = wms_protocolo.nr_lote ) 
     and ( item_nf_transferencia_lote_prt.nr_protocolo_defeito = wms_protocolo.nr_protocolo)
     and ( item_nf_transferencia_lote_prt.cd_filial_origem = :an_filial ) 
     AND ( item_nf_transferencia_lote_prt.nr_nf = :an_nf ) 
     AND ( item_nf_transferencia_lote_prt.de_especie = :as_especie ) 
     AND ( item_nf_transferencia_lote_prt.de_serie = :as_serie )    
" arguments=(("an_filial", number),("an_nf", number),("as_especie", string),("as_serie", string)) )
