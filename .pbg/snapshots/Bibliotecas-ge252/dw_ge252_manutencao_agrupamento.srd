table(column=(type=long update=yes updatewhereclause=yes key=yes name=nr_agrupamento dbname="agrupamento_dev_compra.nr_agrupamento" )
 column=(type=char(9) update=yes updatewhereclause=yes name=cd_fornecedor dbname="agrupamento_dev_compra.cd_fornecedor" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_inclusao dbname="agrupamento_dev_compra.nr_matricula_inclusao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inclusao dbname="agrupamento_dev_compra.dh_inclusao" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_agrupamento dbname="agrupamento_dev_compra.vl_agrupamento" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="agrupamento_dev_compra.id_situacao" )
 column=(type=long update=yes updatewhereclause=yes name=cd_motivo_devolucao dbname="agrupamento_dev_compra.cd_motivo_devolucao" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_tipo dbname="agrupamento_dev_compra.id_tipo" initial="3" values="CONTROLADO	1/N$$HEX1$$c200$$ENDHEX$$O CONTROLADO	2/TODOS	3/" )
 column=(type=long update=yes updatewhereclause=yes name=nr_volume dbname="agrupamento_dev_compra.nr_volume" initial="1" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_destino_final dbname="agrupamento_dev_compra.id_destino_final" initial="N" values="NOTA DE DEVOLU$$HEX2$$c700c300$$ENDHEX$$O DE COMPRA	N/DESCARTE	D/	X/" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_comprador dbname="agrupamento_dev_compra.nr_matricula_comprador" )
 column=(type=char(40) updatewhereclause=yes name=nm_comprador dbname="usuario.nm_comprador" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_pbm dbname="id_pbm" initial="N" values="Agrupamento PBM	S/Agrupamento PBM	N" )
 column=(type=long update=yes updatewhereclause=yes name=nr_divisao_fornecedor dbname="agrupamento_dev_compra.nr_divisao_fornecedor" )
 retrieve="SELECT	a.nr_agrupamento,   
			a.cd_fornecedor,   
			a.nr_matricula_inclusao,   
			a.dh_inclusao,   
			b.nm_razao_social,   
			a.vl_agrupamento,   
			a.id_situacao,   
			a.cd_motivo_devolucao,
			a.id_tipo,
			a.nr_volume,
			a.id_destino_final,
			a.nr_matricula_comprador,
			c.nm_usuario as nm_comprador,
			case when a.id_pbm is null then 'N' else 'S' end as id_pbm,
			a.nr_divisao_fornecedor
FROM agrupamento_dev_compra	a 
INNER JOIN fornecedor				b on b.cd_fornecedor		= a.cd_fornecedor
LEFT JOIN usuario						c on c.nr_matricula		= a.nr_matricula_comprador
WHERE a.nr_agrupamento = :nr_agrupamento 
" update="agrupamento_dev_compra" updatewhere=0 updatekeyinplace=no arguments=(("nr_agrupamento", number)) )
