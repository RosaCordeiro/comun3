table(column=(type=long updatewhereclause=yes name=tipo_nf_transferencia_cd_tipo dbname="tipo_nf_transferencia.cd_tipo" dbalias="b.cd_tipo" )
 column=(type=char(20) updatewhereclause=yes name=de_tipo dbname="de_tipo" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="wms_localizacao.cd_endereco" dbalias="a.cd_endereco" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="wms_localizacao.nr_lote" dbalias="a.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="wms_localizacao.dh_validade" dbalias="a.dh_validade" )
 column=(type=long updatewhereclause=yes name=qt_saldo dbname="qt_saldo" )
 retrieve="Select 	b.cd_tipo,
			Case when b.de_tipo is null then
					'VENCIDO/DANIFICADO'
				else
					b.de_tipo
			end de_tipo,
			a.cd_endereco,
			a.nr_lote,
			a.dh_validade,
			sum(a.qt_saldo) as qt_saldo
FROM wms_localizacao a
left join tipo_nf_transferencia b on b.cd_endereco_wms = a.cd_endereco
Where (a.cd_endereco in(select p.vl_parametro from wms_parametro p where p.cd_parametro in( 'CD_ENDERECO_SEGREGADO_VENCIDO_DANIFICADO'))
or a.cd_endereco in (select cd_endereco_wms from tipo_nf_transferencia))
and a.cd_produto = :cd_produto
and isnull(b.cd_tipo, -1) <> 9
group by b.cd_tipo,
			 b.de_tipo,
			a.cd_endereco,
			a.nr_lote,
			a.dh_validade" arguments=(("cd_produto", number)) )
