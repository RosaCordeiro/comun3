table(column=(type=long updatewhereclause=yes name=cd_filial dbname="lote_exportacao_item.cd_filial" dbalias="li.cd_filial" )
 column=(type=datetime updatewhereclause=yes name=dh_contabil dbname="lote_exportacao_item.dh_contabil" dbalias="li.dh_contabil" )
 column=(type=long updatewhereclause=yes name=cd_conta_debito dbname="cd_conta_debito" )
 column=(type=long updatewhereclause=yes name=cd_conta_credito dbname="cd_conta_credito" )
 column=(type=char(1) updatewhereclause=yes name=id_natureza dbname="lote_exportacao_item.id_natureza" dbalias="li.id_natureza" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_contabil dbname="lote_exportacao_item.vl_contabil" dbalias="li.vl_contabil" )
 column=(type=char(255) updatewhereclause=yes name=de_observacao dbname="lote_exportacao_item.de_observacao" dbalias="li.de_observacao" )
 column=(type=long updatewhereclause=yes name=cd_centro_custo dbname="lote_exportacao_item.cd_centro_custo" dbalias="li.cd_centro_custo" )
 retrieve="select 	li.cd_filial, 
			li.dh_contabil, 
			case when li.id_natureza = 'D' then li.cd_conta_contabil else 0 end as cd_conta_debito, 
			case when li.id_natureza = 'C' then li.cd_conta_contabil else 0 end as cd_conta_credito,
			li.id_natureza,
			li.vl_contabil,
			li.de_observacao,
			li.cd_centro_custo
from lote_exportacao_item li
Inner join lote_exportacao le
	on le.nr_exportacao = li.nr_exportacao
where le.nr_exportacao = :codigo" arguments=(("codigo", number)) )
