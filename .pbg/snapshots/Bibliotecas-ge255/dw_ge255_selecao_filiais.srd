table(column=(type=long updatewhereclause=yes name=cd_filial dbname="vw_filial.cd_filial" dbalias="v.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="vw_filial.nm_fantasia" dbalias="v.nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=id_marcado dbname="id_marcado" initial="S" values="	S/	N" )
 retrieve="  SELECT v.cd_filial,   
         v.nm_fantasia,
		'S' as id_marcado  
    FROM vw_filial v
		inner join parametro_odbc p 
				on p.cd_filial = v.cd_filial
where v.cd_filial <> 534 
and not exists (select * from parametro_loja x
					where x.cd_filial  = v.cd_filial
					and x.cd_parametro = 'DH_INICIA_PEDIDO_ALMOXARIFADO_NOVO'
					and cast(substring(vl_parametro, 7, 4) + substring(vl_parametro, 4, 2) + substring(vl_parametro, 1, 2) as date) <= (select dh_movimentacao from parametro where id_parametro = '1'))


  "  sort="cd_filial A " )
