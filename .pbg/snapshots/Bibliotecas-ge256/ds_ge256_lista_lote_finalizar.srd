table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="wms_lista_separacao_prd_lote.cd_filial" dbalias="a.cd_filial" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_pedido_distribuidora dbname="wms_lista_separacao_prd_lote.nr_pedido_distribuidora" dbalias="a.nr_pedido_distribuidora" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_volume dbname="wms_lista_separacao_prd_lote.nr_volume" dbalias="a.nr_volume" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="wms_lista_separacao_prd_lote.cd_produto" dbalias="a.cd_produto" )
 column=(type=char(8) update=yes updatewhereclause=yes key=yes name=cd_endereco_localizacao dbname="wms_lista_separacao_prd_lote.cd_endereco_localizacao" dbalias="a.cd_endereco_localizacao" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=nr_lote dbname="wms_lista_separacao_prd_lote.nr_lote" dbalias="a.nr_lote" )
 column=(type=long update=yes updatewhereclause=yes name=qt_lote dbname="wms_lista_separacao_prd_lote.qt_lote" dbalias="a.qt_lote" )
 retrieve="select 
	a.cd_filial,
	a.nr_pedido_distribuidora,
	a.nr_volume,
	a.cd_produto,
	a.cd_endereco_localizacao,
	a.nr_lote,
	a.qt_lote
    --isnull(b.nr_sequencial, 1) as nr_sequencial,
    --isnull(b.qt_caixa_padrao, 1) as qt_caixa_padrao,
    --b.dh_validade    
from wms_lista_separacao_prd_lote a
--left outer join wms_localizacao b on b.cd_endereco = a.cd_endereco_localizacao and a.cd_produto = b.cd_produto and a.nr_lote = b.nr_lote
where a.cd_filial 				= :cd_filial
and a.nr_pedido_distribuidora 	= :nr_pedido
and a.nr_volume 				= :nr_volume
order by a.cd_produto" update="wms_lista_separacao_prd_lote" updatewhere=0 updatekeyinplace=no arguments=(("cd_filial", number),("nr_pedido", number),("nr_volume", number)) )
