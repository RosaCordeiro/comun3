table(column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="wms_localizacao.cd_endereco" dbalias="a.cd_endereco" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="wms_localizacao.nr_sequencial" dbalias="a.nr_sequencial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_localizacao.cd_produto" dbalias="a.cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="wms_localizacao.nr_lote" dbalias="a.nr_lote" )
 column=(type=long updatewhereclause=yes name=qt_saldo dbname="wms_localizacao.qt_saldo" dbalias="a.qt_saldo" )
 column=(type=long updatewhereclause=yes name=qt_caixa_padrao dbname="wms_localizacao.qt_caixa_padrao" dbalias="a.qt_caixa_padrao" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="wms_localizacao.dh_validade" dbalias="a.dh_validade" )
 retrieve="select 
    	a.cd_endereco, 
    	a.nr_sequencial,
    	a.cd_produto, 
    	a.nr_lote, 
   	a.qt_saldo,
	a.qt_caixa_padrao,
	a.dh_validade
from wms_localizacao a 
inner join wms_endereco_produto b on b.cd_endereco = a.cd_endereco 
where a.cd_produto = :cd_produto
	and  a.cd_endereco = :cd_endereco
     and a.qt_saldo > 0
order by b.nr_prioridade, a.nr_sequencial" arguments=(("cd_produto", number),("cd_endereco", string)) )
