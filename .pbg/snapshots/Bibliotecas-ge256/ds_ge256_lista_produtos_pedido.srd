table(column=(type=long updatewhereclause=yes name=cd_filial dbname="wms_lista_separacao_produto.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_volume dbname="wms_lista_separacao_produto.nr_volume" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="wms_lista_separacao_produto.nr_pedido_distribuidora" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_lista_separacao_produto.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_separada dbname="wms_lista_separacao_produto.qt_separada" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="wms_lista_separacao_produto.qt_pedida" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="cd_endereco" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" )
 column=(type=char(136) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_controlado dbname="id_controlado" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" )
 column=(type=long updatewhereclause=yes name=qt_separada_anterior dbname="wms_lista_separacao_produto.qt_separada_anterior" )
 retrieve="SELECT 	a.cd_filial,
			a.nr_volume,
			a.nr_pedido_distribuidora,
			a.cd_produto,   
			a.qt_separada,   
			a.qt_pedida,   
			case when (select max(cd_endereco) from wms_endereco_produto where cd_produto = a.cd_produto) = null then
              		(select max(cd_endereco) from wms_localizacao where cd_produto = a.cd_produto)
           		 else
            			(select max(cd_endereco) from wms_endereco_produto where cd_produto = a.cd_produto)
        		end as cd_endereco,
			b.de_codigo_barras,
			'('+cast(b.cd_produto as varchar)+') '+b.de_produto + ~" : ~" + b.de_apresentacao_estoque de_produto ,
			'N' id_controlado,
			b.cd_grupo_psico,
			a.qt_separada qt_separada_anterior
 FROM wms_lista_separacao_produto a  
inner join  produto_geral b on b.cd_produto = a.cd_produto 
where  a.cd_filial 				= :pl_filial
	and a.nr_pedido_distribuidora 	= :pl_pedido
	and a.nr_volume 					= :pl_volume
	and a.qt_separada > 0

" arguments=(("pl_filial", number),("pl_pedido", number),("pl_volume", number))  sort="de_produto A " )
