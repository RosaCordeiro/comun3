table(column=(type=long updatewhereclause=yes name=centro_custo dbname="cd_centro_custo" )
 column=(type=char(40) updatewhereclause=yes name=departamento dbname="departamento" )
 column=(type=char(3) updatewhereclause=yes name=cd_subgrupo dbname="vw_classificacao_produto.cd_subgrupo" dbalias="cp.cd_subgrupo" )
 column=(type=decimal(2) updatewhereclause=yes name=valor dbname="Valor" initial="0.00" )
 retrieve="Select coalesce(cc.cd_centro_custo,fi.cd_filial) as cd_centro_custo,
      	coalesce(cc.de_centro_custo, fi.nm_fantasia) as departamento,
       	cp.cd_subgrupo,
       	Sum(it.qt_faturada * vl_custo_unitario) as Valor
from nf_almoxarifado nf
Inner Join item_nf_almoxarifado it
	On it.nr_nf = nf.nr_nf
Inner Join produto_geral pg
	On pg.cd_produto = it.cd_produto
Inner Join vw_classificacao_produto cp
	On cp.cd_subcategoria = pg.cd_subcategoria
left Join filial fi
	On fi.cd_filial = nf.cd_filial
Left Outer Join centro_custo cc
	On cc.cd_centro_custo  = nf.cd_centro_custo
where nf.dh_movimentacao_caixa between :inicio and :fim
  and nf.dh_cancelamento    is null
group by coalesce(cc.cd_centro_custo,fi.cd_filial),
			coalesce(cc.de_centro_custo, fi.nm_fantasia),
			cp.cd_subgrupo" arguments=(("inicio", date),("fim", date))  sort="centro_custo A " )
