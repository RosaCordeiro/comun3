table(column=(type=char(8) update=yes updatewhereclause=yes key=yes name=cd_endereco dbname="wms_localizacao.cd_endereco" dbalias="w.cd_endereco" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_sequencial dbname="wms_localizacao.nr_sequencial" dbalias="w.nr_sequencial" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="wms_localizacao.cd_produto" dbalias="w.cd_produto" )
 column=(type=long update=yes updatewhereclause=yes name=qt_caixa_padrao dbname="wms_localizacao.qt_caixa_padrao" dbalias="w.qt_caixa_padrao" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_lote dbname="wms_localizacao.nr_lote" dbalias="w.nr_lote" )
 column=(type=long update=yes updatewhereclause=yes name=qt_saldo dbname="wms_localizacao.qt_saldo" dbalias="w.qt_saldo" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_validade dbname="wms_localizacao.dh_validade" dbalias="w.dh_validade" )
 retrieve="  SELECT	w.cd_endereco,   
         		w.nr_sequencial,   
        			w.cd_produto,   
         		w.qt_caixa_padrao,   
         		w.nr_lote,   
         		w.qt_saldo,   
         		w.dh_validade  
    FROM wms_localizacao   w
where w.qt_saldo > 0
  	and w.nr_lote <> 'LOTE CONF'
  	and w.cd_produto = :produto
  	and w.cd_endereco = :endereco
 order by w.dh_validade asc" update="wms_localizacao" updatewhere=0 updatekeyinplace=no arguments=(("produto", number),("endereco", string)) )
