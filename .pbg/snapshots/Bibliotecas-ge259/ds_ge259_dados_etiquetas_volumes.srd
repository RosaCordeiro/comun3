table(column=(type=long updatewhereclause=yes name=cd_filial dbname="wms_lista_separacao.cd_filial" dbalias="a.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=de_filial dbname="filial.de_filial" dbalias="f.de_filial" )
 column=(type=char(62) updatewhereclause=yes name=de_endereco dbname="de_endereco" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep dbname="filial.nr_cep" dbalias="f.nr_cep" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" dbalias="c.nm_cidade" )
 column=(type=char(40) updatewhereclause=yes name=nm_unidade_federacao dbname="unidade_federacao.nm_unidade_federacao" dbalias="u.nm_unidade_federacao" )
 column=(type=long updatewhereclause=yes name=nr_volumes dbname="wms_lista_separacao.nr_volumes" dbalias="a.nr_volumes" )
 column=(type=long updatewhereclause=yes name=total_volumes dbname="total_volumes" )
 column=(type=char(40) updatewhereclause=yes name=id_rede dbname="id_rede" )
 column=(type=long updatewhereclause=yes name=nr_rota_entrega dbname="filial.nr_rota_entrega" dbalias="f.nr_rota_entrega" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="wms_lista_separacao.nr_pedido_distribuidora" dbalias="a.nr_pedido_distribuidora" )
 column=(type=char(1) updatewhereclause=yes name=id_volume_extra dbname="id_volume_extra" )
 column=(type=long updatewhereclause=yes name=qt_produtos_geladeira dbname="qt_produtos_geladeira" )
 column=(type=char(1) updatewhereclause=yes name=id_pedido_almoxarifado dbname="id_pedido_almoxarifado" )
 column=(type=long updatewhereclause=yes name=cd_esteira dbname="wms_lista_separacao.cd_esteira" dbalias="a.cd_esteira" )
 column=(type=long updatewhereclause=yes name=nr_ordem_bacia dbname="filial.nr_ordem_bacia" dbalias="f.nr_ordem_bacia" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_chave_volume dbname="nr_chave_volume" )
 retrieve="SELECT a.cd_filial,   
		 f.nm_fantasia as de_filial,
		 f.de_endereco + '  ' + f.de_bairro as de_endereco,		 	
		 f.nr_cep,
		 c.nm_cidade,
		 u.nm_unidade_federacao,
		  a.nr_volume as nr_volumes,
		 (select count(nr_volume) from wms_lista_separacao where cd_filial =  a.cd_filial and nr_pedido_distribuidora = a.nr_pedido_distribuidora) as total_volumes,
		 (select vl_parametro from parametro_loja x where  x.cd_filial = f.cd_filial and x.cd_parametro = 'ID_REDE_FILIAL') id_rede,
		f.nr_rota_entrega,
		a.nr_pedido_distribuidora,
		case when (coalesce(a.id_volume_extra, 'N') = 'S') or (a.cd_tipo_volume = 2) then
				'S'
			else
				'N'
		end as id_volume_extra,
        (select count(*) 
        	from wms_lista_separacao a1
        	inner join wms_lista_separacao_produto b1   	on  b1.cd_filial = a1.cd_filial
                                                    						and b1.nr_pedido_distribuidora = a1.nr_pedido_distribuidora
                                                    						and b1.nr_volume = a1.nr_volume
        	inner join produto_geral c1 on c1.cd_produto = b1.cd_produto
        	Where a1.cd_filial = a.cd_filial
        		and a1.nr_pedido_distribuidora = a.nr_pedido_distribuidora
        		and a1.nr_volume = a.nr_volume
           	and c1.id_geladeira = 'S') as qt_produtos_geladeira,
		coalesce(p.id_pedido_almoxarifado, 'N') as id_pedido_almoxarifado,
		a.cd_esteira,
		f.nr_ordem_bacia,
		coalesce(a.nr_chave_volume,0) as nr_chave_volume
FROM wms_lista_separacao a
inner join filial	f	on a.cd_filial	= f.cd_filial
inner join cidade	c	on c.cd_cidade	= f.cd_cidade
inner join unidade_federacao u	on u.cd_unidade_federacao	= c.cd_unidade_federacao
inner join pedido_distribuidora p on p.cd_filial = a.cd_filial and p.nr_pedido_distribuidora = a.nr_pedido_distribuidora
Where a.cd_filial = :filial
	and a.nr_pedido_distribuidora =	:pedido
	and a.nr_volume = :volume
" arguments=(("filial", number),("pedido", number),("volume", number)) )
