table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_almoxarifado.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_rota_entrega dbname="filial.nr_rota_entrega" )
 column=(type=long updatewhereclause=yes name=cd_centro_custo dbname="cd_centro_custo" )
 column=(type=long updatewhereclause=yes name=cd_centro_custo_entrega dbname="cd_centro_custo_entrega" )
 retrieve="SELECT
		a.cd_filial,
		b.nr_rota_entrega,
		CASE
			WHEN a.id_tipo_pedido IN (NULL, 'A', 'E', 'N') THEN COALESCE (a.cd_centro_custo, a.cd_filial)
			ELSE a.cd_centro_custo
		END AS cd_centro_custo,
		CASE
			WHEN a.id_tipo_pedido IN (NULL, 'A', 'E', 'N') THEN COALESCE (a.cd_centro_custo_entrega, a.cd_filial)
			ELSE a.cd_centro_custo_entrega
		END AS cd_centro_custo_entrega
  FROM pedido_almoxarifado a
		INNER JOIN filial b
					ON b.cd_filial = a.cd_filial
 WHERE a.id_situacao                  = 'C'
	AND a.id_rateio_estoque_central    = 'S'
	AND CAST (a.dh_importacao AS DATE) = (SELECT dh_movimentacao FROM parametro WHERE id_parametro = '1')
	AND not exists (SELECT *
							FROM pedido_distribuidora_almox aa
						  WHERE aa.cd_filial              = a.cd_filial
							 AND aa.nr_pedido_almoxarifado = a.nr_pedido)
	AND (SELECT COALESCE (SUM (aa.qt_atendida), 0)
			 FROM pedido_almoxarifado_produto aa
			WHERE aa.cd_filial = a.cd_filial
			  AND aa.nr_pedido = a.nr_pedido) > 0
 GROUP BY
			a.cd_filial,
			b.nr_rota_entrega,
			CASE
				WHEN a.id_tipo_pedido IN (NULL, 'A', 'E', 'N') THEN COALESCE (a.cd_centro_custo, a.cd_filial)
				ELSE a.cd_centro_custo
			END,
			CASE
				WHEN a.id_tipo_pedido IN (NULL, 'A', 'E', 'N') THEN COALESCE (a.cd_centro_custo_entrega, a.cd_filial)
				ELSE a.cd_centro_custo_entrega
			END
 ORDER BY
			b.nr_rota_entrega,
			a.cd_filial" )
