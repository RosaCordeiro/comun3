table(column=(type=long updatewhereclause=yes name=cd_filial dbname="wms_lista_separacao_produto.cd_filial" dbalias="b.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="wms_lista_separacao_produto.nr_pedido_distribuidora" dbalias="b.nr_pedido_distribuidora" )
 column=(type=long updatewhereclause=yes name=nr_volume dbname="wms_lista_separacao_produto.nr_volume" dbalias="b.nr_volume" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_lista_separacao_produto.cd_produto" dbalias="b.cd_produto" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco_localizacao dbname="wms_lista_separacao_produto.cd_endereco_localizacao" dbalias="b.cd_endereco_localizacao" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="wms_lista_separacao_produto.qt_pedida" dbalias="b.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_caixa_padrao dbname="wms_lista_separacao_produto.qt_caixa_padrao" dbalias="b.qt_caixa_padrao" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_kg dbname="wms_lista_separacao_produto.qt_peso_kg" dbalias="b.qt_peso_kg" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_capacidade_litros dbname="wms_lista_separacao_produto.qt_capacidade_litros" dbalias="b.qt_capacidade_litros" )
 column=(type=char(1) updatewhereclause=yes name=id_rateou dbname="id_rateou" )
 retrieve="Select 	b.cd_filial,
			b.nr_pedido_distribuidora,
			b.nr_volume,
			b.cd_produto,
			b.cd_endereco_localizacao,
			b.qt_pedida,
			b.qt_caixa_padrao,
			b.qt_peso_kg,
			b.qt_capacidade_litros,
			'N' id_rateou
From wms_lista_separacao a
inner join wms_lista_separacao_produto b 	on  b.cd_filial = a.cd_filial
														and b.nr_pedido_distribuidora = a.nr_pedido_distribuidora
														and b.nr_volume = a.nr_volume
Where a.cd_filial						= :cd_filial
	and a.nr_pedido_distribuidora 	= :nr_pedido_distribuidora
	and a.cd_esteira 					= :cd_esteira
	and a.cd_tipo_volume				= 1
	and a.dh_cancelamento			is null
	and a.id_estouro_volume		= 'S'
	and a.nr_volume 					= (select max(nr_volume) 
												from wms_lista_separacao 
												where cd_filial 							= a.cd_filial 
													and nr_pedido_distribuidora 	= a.nr_pedido_distribuidora
													and cd_esteira						= a.cd_esteira
													and id_estouro_volume			= 'S')
	and (SELECT dbo.wms_retorna_end_bloqueado(b.cd_endereco_localizacao)) = 'N'" arguments=(("cd_filial", number),("nr_pedido_distribuidora", number),("cd_esteira", number)) )
