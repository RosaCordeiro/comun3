table(column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_distribuidora_produto.cd_produto" dbalias="a.cd_produto" )
 column=(type=long updatewhereclause=yes name=cd_esteira dbname="wms_endereco.cd_esteira" dbalias="c.cd_esteira" )
 column=(type=long updatewhereclause=yes name=nr_prioridade dbname="wms_endereco_produto.nr_prioridade" dbalias="b.nr_prioridade" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="wms_endereco_produto.cd_endereco" dbalias="b.cd_endereco" )
 column=(type=long updatewhereclause=yes name=qt_lista_separacao dbname="qt_lista_separacao" )
 column=(type=long updatewhereclause=yes name=qt_atendida dbname="pedido_distribuidora_produto.qt_atendida" dbalias="a.qt_atendida" )
 column=(type=decimal(17) updatewhereclause=yes name=qt_capacidade_litro dbname="qt_capacidade_litro" )
 column=(type=decimal(17) updatewhereclause=yes name=qt_capacidade_litro_ecommerce dbname="qt_capacidade_litro_ecommerce" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_kg dbname="qt_peso_kg" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_kg_estoque dbname="qt_peso_kg_estoque" )
 column=(type=char(1) updatewhereclause=yes name=id_geladeira dbname="id_geladeira" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" dbalias="e.cd_grupo_psico" )
 retrieve="select	a.cd_produto ,
			c.cd_esteira,
			b.nr_prioridade,
			b.cd_endereco,
			isnull(a.qt_lista_separacao, 0) qt_lista_separacao,
			a.qt_atendida,
			((isnull(d.qt_largura_cm_caixa_estoque, 0) * isnull(d.qt_altura_cm_caixa_estoque,0) * isnull(d.qt_profund_cm_caixa_estoque, 0)) / 1000) as qt_capacidade_litro,
			((isnull(e.qt_largura_cm, 0) * isnull(e.qt_altura_cm,0) * isnull(e.qt_profundidade_cm, 0)) / 1000)  as qt_capacidade_litro_ecommerce,
			isnull(e.qt_peso_grama, 0) qt_peso_kg,
			isnull(d.qt_peso_kg_estoque, 0) qt_peso_kg_estoque,
			coalesce(e.id_geladeira, 'N') as id_geladeira,
			e.cd_grupo_psico
from pedido_distribuidora_produto a 
inner join wms_endereco_produto b on b.cd_produto = a.cd_produto
inner join wms_endereco c on c.cd_endereco = b.cd_endereco
inner join produto_central	d on d.cd_produto = a.cd_produto
inner join produto_geral e on e.cd_produto = a.cd_produto
where a.cd_filial = :cd_filial 
and a.nr_pedido_distribuidora = :nr_pedido_distribuidora
and c.cd_esteira = :cd_esteira
and a.qt_atendida > isnull(a.qt_lista_separacao , 0) 
and (SELECT dbo.wms_retorna_end_bloqueado(b.cd_endereco)) = 'N'
order by c.cd_rua desc,
			c.cd_predio asc, 
			c.cd_andar desc,
			c.nr_ordem_separacao_flow" arguments=(("cd_filial", number),("nr_pedido_distribuidora", number),("cd_esteira", number)) )
