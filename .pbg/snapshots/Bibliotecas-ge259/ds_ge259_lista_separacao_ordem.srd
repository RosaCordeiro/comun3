table(column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="wms_lista_separacao_ordem.cd_produto" dbalias="l.cd_produto" )
 column=(type=long update=yes updatewhereclause=yes name=cd_esteira dbname="wms_lista_separacao_ordem.cd_esteira" dbalias="l.cd_esteira" )
 column=(type=long updatewhereclause=yes name=nr_prioridade dbname="wms_endereco_produto.nr_prioridade" dbalias="e.nr_prioridade" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="wms_lista_separacao_ordem.cd_endereco" dbalias="l.cd_endereco" )
 column=(type=long updatewhereclause=yes name=qt_lista_separacao dbname="qt_lista_separacao" )
 column=(type=long updatewhereclause=yes name=qt_atendida dbname="pedido_distribuidora_produto.qt_atendida" dbalias="p.qt_atendida" )
 column=(type=decimal(17) updatewhereclause=yes name=qt_capacidade_litro dbname="qt_capacidade_litro" )
 column=(type=decimal(17) updatewhereclause=yes name=qt_capacidade_litro_ecommerce dbname="qt_capacidade_litro_ecommerce" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_kg dbname="qt_peso_kg" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_kg_estoque dbname="qt_peso_kg_estoque" )
 column=(type=char(1) updatewhereclause=yes name=id_geladeira dbname="id_geladeira" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" dbalias="g.cd_grupo_psico" )
 retrieve=" SELECT	l.cd_produto,   
        		l.cd_esteira,
			e.nr_prioridade, 
			l.cd_endereco,
			isnull(p.qt_lista_separacao, 0) qt_lista_separacao,
			p.qt_atendida,
			((isnull(c.qt_largura_cm_caixa_estoque, 0) * isnull(c.qt_altura_cm_caixa_estoque,0) * isnull(c.qt_profund_cm_caixa_estoque, 0)) / 1000) as qt_capacidade_litro,
			((isnull(g.qt_largura_cm, 0) * isnull(g.qt_altura_cm,0) * isnull(g.qt_profundidade_cm, 0)) / 1000)  as qt_capacidade_litro_ecommerce,
			isnull(qt_peso_grama, 0) qt_peso_kg,
			isnull(qt_peso_kg_estoque, 0) qt_peso_kg_estoque,
			coalesce(g.id_geladeira, 'N') as id_geladeira ,
			g.cd_grupo_psico
 FROM wms_lista_separacao_ordem l  
inner join produto_geral g on g.cd_produto = l.cd_produto
inner join produto_central	c on c.cd_produto = g.cd_produto
inner join pedido_distribuidora_produto p on p.cd_filial	= l.cd_filial and p.nr_pedido_distribuidora 	= l.nr_pedido_distribuidora  and p.cd_produto	= l.cd_produto
inner join wms_endereco_produto	e on e.cd_produto		= l.cd_produto and e.cd_endereco = l.cd_endereco
where	l.cd_filial							= :filial
	and 	l.nr_pedido_distribuidora = :pedido
	and 	l.cd_esteira					= :esteira
	and (SELECT dbo.wms_retorna_end_bloqueado(e.cd_endereco)) = 'N'
order by l.nr_ordem_separacao asc, e.nr_prioridade asc
" arguments=(("filial", number),("pedido", number),("esteira", number)) )
