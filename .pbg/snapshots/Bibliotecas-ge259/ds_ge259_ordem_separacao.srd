table(column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_endereco_produto.cd_produto" dbalias="e.cd_produto" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="wms_endereco_produto.cd_endereco" dbalias="e.cd_endereco" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" dbalias="g.cd_grupo_psico" )
 retrieve="Select		e.cd_produto , e.cd_endereco , g.cd_grupo_psico
From pedido_distribuidora_produto p
Inner join wms_endereco_produto e on e.cd_produto = p.cd_produto
Inner join wms_endereco v on v.cd_endereco = e.cd_endereco
inner join produto_geral g on g.cd_produto = p.cd_produto
Where p.cd_filial 						= :cd_filial
	and p.nr_pedido_distribuidora 	= :nr_pedido_distribuidora
	and v.cd_esteira 					= :cd_esteira
	and not exists (select * from wms_lista_separacao_ordem a
					where a.cd_filial = p.cd_filial
						and a.nr_pedido_distribuidora = p.nr_pedido_distribuidora
						and a.cd_esteira = :cd_esteira
						and a.cd_produto = p.cd_produto
						and a.cd_endereco = e.cd_endereco)
	and p.qt_atendida > isnull(p.qt_lista_separacao , 0 ) 
order by v.cd_rua, v.cd_predio asc, v.cd_andar desc, v.nr_ordem_separacao_flow" arguments=(("cd_filial", number),("nr_pedido_distribuidora", number),("cd_esteira", number)) )
