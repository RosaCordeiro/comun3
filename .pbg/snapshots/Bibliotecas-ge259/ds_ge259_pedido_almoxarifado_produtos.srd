table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_almoxarifado.cd_filial" dbalias="a.cd_filial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_almoxarifado_produto.cd_produto" dbalias="b.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_atendida dbname="qt_atendida" )
 column=(type=long updatewhereclause=yes name=qt_separada dbname="qt_separada" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="vl_custo_unitario" )
 column=(type=char(1) updatewhereclause=yes name=id_falta_cancelada dbname="pedido_almoxarifado_produto.id_falta_cancelada" dbalias="b.id_falta_cancelada" )
 column=(type=char(3) updatewhereclause=yes name=cd_subgrupo dbname="cd_subgrupo" )
 retrieve="SELECT
		a.cd_filial,   
		b.cd_produto,   
		SUM (b.qt_pedida)   AS qt_pedida,   
		SUM (b.qt_atendida) AS qt_atendida,   
		SUM (b.qt_separada) AS qt_separada,   
		SUM (b.qt_faturada) AS qt_faturada,   
		COALESCE (b.vl_custo_unitario, 0) AS vl_custo_unitario,
		b.id_falta_cancelada,
		SUBSTRING (c.cd_subcategoria, 1, 3) AS cd_subgrupo 
  FROM pedido_almoxarifado a
		INNER JOIN pedido_almoxarifado_produto b
					ON  b.cd_filial = a.cd_filial
					AND b.nr_pedido = a.nr_pedido  
		INNER JOIN produto_geral c
					ON  c.cd_produto = b.cd_produto
 WHERE a.cd_filial                 = :cd_filial
	AND a.id_situacao               = 'C'
	AND a.id_rateio_estoque_central = 'S'
	AND b.qt_atendida               > 0
	AND ((a.id_tipo_pedido     IN (NULL , 'A', 'E', 'N') AND :cd_centro_custo IS     NULL AND a.cd_centro_custo IS NULL) OR
		  (a.id_tipo_pedido     IN (NULL , 'A', 'E', 'N') AND :cd_centro_custo IS NOT NULL AND COALESCE (a.cd_centro_custo, a.cd_filial) = :cd_centro_custo) OR
		  (a.id_tipo_pedido NOT IN (NULL , 'A', 'E', 'N') AND :cd_centro_custo = a.cd_centro_custo))
	AND ((a.id_tipo_pedido     IN (NULL , 'A', 'E', 'N') AND :cd_centro_custo_entrega IS     NULL AND a.cd_centro_custo_entrega IS NULL) OR
		  (a.id_tipo_pedido     IN (NULL , 'A', 'E', 'N') AND :cd_centro_custo_entrega IS NOT NULL AND COALESCE (a.cd_centro_custo_entrega, a.cd_filial) = :cd_centro_custo_entrega) OR
		  (a.id_tipo_pedido NOT IN (NULL , 'A', 'E', 'N') AND :cd_centro_custo_entrega = a.cd_centro_custo_entrega))
	AND CASE
			WHEN a.id_tipo_pedido IN (NULL , 'A', 'E', 'N') THEN 'N'
			ELSE a.id_tipo_pedido
		 END = :id_tipo_pedido
	AND CAST (a.dh_importacao AS DATE) = (SELECT dh_movimentacao FROM parametro WHERE id_parametro = '1')
 GROUP BY
		a.cd_filial,   
		b.cd_produto,   
		b.vl_custo_unitario,   
		b.id_falta_cancelada,
		c.cd_subcategoria" arguments=(("cd_filial", number),("cd_centro_custo", number),("cd_centro_custo_entrega", number),("id_tipo_pedido", string)) )
