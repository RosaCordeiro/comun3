table(column=(type=long updatewhereclause=yes name=nr_pedido dbname="nr_pedido" )
 retrieve="select top 1 nr_pedido
from pedido_almoxarifado a
where cd_filial = :cd_filial
and a.id_situacao = 'C'
and a.id_rateio_estoque_central = 'S'
and cast(a.dh_importacao as date) = (select dh_movimentacao from parametro where id_parametro = '1')
and a.cd_centro_custo = :cd_centro_custo
and a.cd_centro_custo_entrega = :cd_centro_custo_entrega
and a.id_tipo_pedido = :id_tipo_pedido
and not exists (select * from pedido_distribuidora_almox aa
						where aa.cd_filial = a.cd_filial 
							and aa.nr_pedido_almoxarifado = a.nr_pedido)" arguments=(("cd_filial", number),("cd_centro_custo", number),("cd_centro_custo_entrega", number),("id_tipo_pedido", string)) )
