table(column=(type=long updatewhereclause=yes name=cd_filial dbname="wms_lista_separacao.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_volume dbname="wms_lista_separacao.nr_volume" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_lista_separacao_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(6) updatewhereclause=yes name=de_endereco_flow_rack dbname="vw_wms_endereco.de_endereco_flow_rack" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="wms_lista_separacao_produto.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_caixa_padrao dbname="wms_lista_separacao_produto.qt_caixa_padrao" )
 column=(type=char(2) updatewhereclause=yes name=cd_rua dbname="vw_wms_endereco.cd_rua" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" )
 column=(type=long updatewhereclause=yes name=nr_ordem_separacao dbname="wms_endereco.nr_ordem_separacao" )
 column=(type=char(3) updatewhereclause=yes name=cd_predio dbname="vw_wms_endereco.cd_predio" )
 column=(type=char(1) updatewhereclause=yes name=cd_andar dbname="vw_wms_endereco.cd_andar" )
 column=(type=char(1) updatewhereclause=yes name=id_geladeira dbname="produto_geral.id_geladeira" )
 column=(type=long updatewhereclause=yes name=cd_esteira dbname="wms_lista_separacao.cd_esteira" )
 column=(type=long updatewhereclause=yes name=nr_ordem_separacao_rua dbname="wms_rua.nr_ordem_separacao_rua" )
 column=(type=char(1) updatewhereclause=yes name=id_pedido_almoxarifado dbname="id_pedido_almoxarifado" )
 column=(type=char(1) updatewhereclause=yes name=nr_lote_produto_geladeira dbname="nr_lote_produto_geladeira" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="vw_wms_endereco.cd_endereco" )
 retrieve="  SELECT 	a.cd_filial,   
				a.nr_volume,    
				b.cd_produto,   
				g.de_produto + ' : ' + g.de_apresentacao_estoque as de_produto,
				de_endereco_flow_rack,   
				b.qt_pedida,   
				b.qt_caixa_padrao,
				e.cd_rua,
				g.de_codigo_barras,
				x.nr_ordem_separacao_flow as nr_ordem_separacao,
				e.cd_predio,
				e.cd_andar,
				g.id_geladeira,
				a.cd_esteira,
				r.nr_ordem_separacao_flow as nr_ordem_separacao_rua,
				coalesce(p.id_pedido_almoxarifado, 'N') as id_pedido_almoxarifado,
				'' as nr_lote_produto_geladeira,
			    e.cd_endereco
FROM wms_lista_separacao a
inner join wms_lista_separacao_produto b on a.cd_filial 							= b.cd_filial
															 and a.nr_pedido_distribuidora 	= b.nr_pedido_distribuidora
															 and a.nr_volume						= b.nr_volume
inner join vw_wms_endereco	e	on e.cd_endereco	= b.cd_endereco_localizacao
inner join produto_geral	g	on b.cd_produto	= g.cd_produto
inner join pedido_distribuidora	p on p.cd_filial = a.cd_filial and p.nr_pedido_distribuidora = a.nr_pedido_distribuidora
inner join wms_endereco_produto ep on ep.cd_produto = b.cd_produto and ep.cd_endereco =  b.cd_endereco_localizacao
inner join wms_endereco x on x.cd_endereco = b.cd_endereco_localizacao
inner join wms_rua r on r.cd_rua = x.cd_rua
Where  a.cd_filial							= 745
	and a.nr_pedido_distribuidora 		= 139546
	and a.cd_esteira						= 2
	and a.nr_volume						= 9
	and a.cd_tipo_volume = 1
		"  sort="cd_filial A nr_volume A nr_ordem_separacao_rua A cd_rua A nr_ordem_separacao A cd_predio A cd_andar A " )
