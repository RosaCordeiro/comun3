table(column=(type=long updatewhereclause=yes name=cd_filial dbname="wms_lista_separacao.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=de_filial dbname="filial.de_filial" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="wms_lista_separacao.nr_pedido_distribuidora" )
 column=(type=long updatewhereclause=yes name=nr_volume dbname="wms_lista_separacao.nr_volume" )
 column=(type=char(1) updatewhereclause=yes name=id_pedido_almoxarifado dbname="id_pedido_almoxarifado" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_lista_separacao_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(8) updatewhereclause=yes name=de_endereco_reduzido dbname="vw_wms_endereco.de_endereco_reduzido" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_etiqueta_caixa dbname="wms_lista_separacao_produto.nr_etiqueta_caixa" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="wms_lista_separacao_produto.qt_pedida" )
 column=(type=long updatewhereclause=yes name=total_volume dbname="total_volume" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="de_codigo_barras" )
 column=(type=char(20) updatewhereclause=yes name=ean_128 dbname="ean_128" )
 column=(type=long updatewhereclause=yes name=nr_rota_entrega dbname="filial.nr_rota_entrega" )
 column=(type=long updatewhereclause=yes name=total_volumes dbname="total_volumes" )
 column=(type=char(62) updatewhereclause=yes name=de_endereco dbname="de_endereco" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep dbname="filial.nr_cep" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" )
 column=(type=char(2) updatewhereclause=yes name=id_rede dbname="filial.id_rede" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_chave_volume dbname="wms_lista_separacao.nr_chave_volume" )
 column=(type=char(40) updatewhereclause=yes name=nm_requsitante dbname="nm_requsitante" )
 retrieve="  SELECT 	a.cd_filial,   
				f.nm_fantasia as de_filial,
				a.nr_pedido_distribuidora,   
				a.nr_volume,   
				coalesce(p.id_pedido_almoxarifado, 'N') as id_pedido_almoxarifado, 
				b.cd_produto,   
				g.de_produto + ' : ' + g.de_apresentacao_estoque as de_produto,
				e.de_endereco_pulmao de_endereco_reduzido,   
				nr_etiqueta_caixa,
				b.qt_pedida,   
				(select count(nr_volume) from wms_lista_separacao x
				where x.cd_filial = a.cd_filial
				  and x.nr_pedido_distribuidora = a.nr_pedido_distribuidora) as total_volume,
				space(20) de_codigo_barras,
				space(20) ean_128,
				nr_rota_entrega,
				(select count(nr_volume) from wms_lista_separacao where cd_filial =  a.cd_filial and nr_pedido_distribuidora = a.nr_pedido_distribuidora) as total_volumes,
				f.de_endereco+', '+f.de_bairro as de_endereco,
				f.nr_cep,
				c.nm_cidade,
				c.cd_unidade_federacao,
				f.id_rede_filial as id_rede,
				a.nr_chave_volume as nr_chave_volume,
				space(40) nm_requsitante
FROM wms_lista_separacao					a
inner join wms_lista_separacao_produto	b 	on a.cd_filial						= b.cd_filial
														and a.nr_pedido_distribuidora	= b.nr_pedido_distribuidora
														and a.nr_volume					= b.nr_volume
inner join vw_wms_endereco				e	on e.cd_endereco					= b.cd_endereco_localizacao
inner join filial									f	on a.cd_filial						= f.cd_filial
inner join produto_geral						g	on b.cd_produto					= g.cd_produto
inner join wms_tipo_volume					t	on t.cd_tipo_volume				= a.cd_tipo_volume
inner join pedido_distribuidora				p	on p.cd_filial						= a.cd_filial and p.nr_pedido_distribuidora = a.nr_pedido_distribuidora
left join cidade									c	on c.cd_cidade						= f.cd_cidade
Where a.cd_filial						=	:filial
	and a.nr_pedido_distribuidora	=	:pedido
	and a.cd_tipo_volume				= 2
" arguments=(("filial", number),("pedido", number)) )
