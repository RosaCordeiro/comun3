table(column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="wms_localizacao.cd_endereco" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="wms_localizacao.nr_sequencial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_localizacao.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_caixa_padrao dbname="wms_localizacao.qt_caixa_padrao" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="wms_localizacao.nr_lote" )
 column=(type=long updatewhereclause=yes name=qt_saldo dbname="wms_localizacao.qt_saldo" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="wms_localizacao.dh_validade" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_capacidade_litros dbname="wms_localizacao.qt_capacidade_litros" )
 column=(type=long updatewhereclause=yes name=qt_capacidade_unidades dbname="wms_localizacao.qt_capacidade_unidades" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_capacidade dbname="wms_localizacao.id_tipo_capacidade" )
 retrieve="  SELECT 	l.cd_endereco,   
         		l.nr_sequencial,   
				l.cd_produto,   
				l.qt_caixa_padrao,   
				l.nr_lote,   
				l.qt_saldo,   
				l.dh_validade,   
				l.qt_capacidade_litros,   
				l.qt_capacidade_unidades,   
				l.id_tipo_capacidade  
    FROM wms_localizacao l
inner join wms_endereco e on e.cd_endereco		= l.cd_endereco
inner join wms_bairro  b on b.cd_bairro				= e.cd_bairro
where	l.cd_produto		= :produto
	and  e.id_flow_rack 	= :flow_rack" arguments=(("produto", number),("flow_rack", string))  sort="dh_validade A " )
