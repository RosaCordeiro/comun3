table(column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="pedido_distribuidora_produto.cd_filial" dbalias="p.cd_filial" )
 column=(type=long update=yes updatewhereclause=yes name=nr_pedido_distribuidora dbname="pedido_distribuidora_produto.nr_pedido_distribuidora" dbalias="p.nr_pedido_distribuidora" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="pedido_distribuidora_produto.cd_produto" dbalias="p.cd_produto" )
 column=(type=long update=yes updatewhereclause=yes name=qt_pedida dbname="qt_pedida" )
 column=(type=long update=yes updatewhereclause=yes name=qt_atendida dbname="pedido_distribuidora_produto.qt_atendida" dbalias="p.qt_atendida" )
 column=(type=long update=yes updatewhereclause=yes name=qt_separada dbname="pedido_distribuidora_produto.qt_separada" dbalias="p.qt_separada" )
 column=(type=long update=yes updatewhereclause=yes name=qt_faturada dbname="pedido_distribuidora_produto.qt_faturada" dbalias="p.qt_faturada" )
 column=(type=decimal(17) updatewhereclause=yes name=qt_capacidade_litro dbname="qt_capacidade_litro" )
 column=(type=decimal(17) updatewhereclause=yes name=qt_capacidade_litro_ecommerce dbname="qt_capacidade_litro_ecommerce" )
 column=(type=char(1) updatewhereclause=yes name=id_geladeira dbname="id_geladeira" )
 column=(type=long updatewhereclause=yes name=qt_caixa_padrao_wms dbname="pedido_distribuidora_produto.qt_caixa_padrao_wms" dbalias="p.qt_caixa_padrao_wms" )
 column=(type=char(1) updatewhereclause=yes name=id_vacina dbname="id_vacina" )
 retrieve="  SELECT	p.cd_filial,   
         		p.nr_pedido_distribuidora,   
         		p.cd_produto,   
      			p.qt_atendida -  isnull(p.qt_lista_separacao , 0) qt_pedida, 
         		p.qt_atendida,   
         		p.qt_separada,   
         		p.qt_faturada,
				((isnull(c.qt_largura_cm_caixa_estoque, 0) * isnull(c.qt_altura_cm_caixa_estoque,0) * isnull(c.qt_profund_cm_caixa_estoque, 0)) / 1000) * (p.qt_atendida -  isnull(p.qt_lista_separacao , 0) )  as qt_capacidade_litro,
				((isnull(g.qt_largura_cm, 0) * isnull(g.qt_altura_cm,0) * isnull(g.qt_profundidade_cm, 0)) / 1000) * (p.qt_atendida -  isnull(p.qt_lista_separacao , 0) )  as qt_capacidade_litro_ecommerce,
				coalesce(g.id_geladeira, 'N') id_geladeira,
				p.qt_caixa_padrao_wms,
				case when b.cd_categoria = '102153' then 'S' else  'N' end as id_vacina
    FROM pedido_distribuidora_produto   p
inner join produto_central c on c.cd_produto = p.cd_produto
inner join produto_geral	g on g.cd_produto		= p.cd_produto
inner join vw_classificacao_produto b on g.cd_subcategoria = b.cd_subcategoria
where p.cd_filial							= :filial
	and p.nr_pedido_distribuidora	= :pedido
	and p.qt_atendida -  isnull(p.qt_lista_separacao , 0) > 0" arguments=(("filial", number),("pedido", number)) )
