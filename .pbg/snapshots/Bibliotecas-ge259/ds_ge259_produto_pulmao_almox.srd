table(column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="wms_localizacao.cd_endereco" dbalias="w.cd_endereco" )
 column=(type=long updatewhereclause=yes name=qt_caixa_padrao dbname="wms_localizacao.qt_caixa_padrao" dbalias="w.qt_caixa_padrao" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="wms_localizacao.nr_lote" dbalias="w.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="wms_localizacao.dh_validade" dbalias="w.dh_validade" )
 column=(type=long updatewhereclause=yes name=qt_saldo dbname="wms_localizacao.qt_saldo" dbalias="w.qt_saldo" )
 retrieve="Select w.cd_endereco, w.qt_caixa_padrao, w.nr_lote, w.dh_validade, w.qt_saldo
From wms_localizacao w
inner join vw_wms_endereco v on v.cd_endereco = w.cd_endereco
inner join produto_geral g on g.cd_produto = w.cd_produto
Where	w.cd_produto 			= :produto
	and 	w.qt_saldo 				> 0
	and 	v.id_flow_rack			= 'N'
	and 	v.id_flow_rack_bairro = 'N'
	and 	w.id_bloqueado = 'N'
	and 	v.id_utiliza_saldo		= 'S'
	and  not exists (select * from wms_endereco_produto e
							where e.cd_endereco	= w.cd_endereco)
	and w.cd_endereco not in (select vl_parametro from wms_parametro
									where cd_parametro = 'CD_ENDERECO_RECEBIMENTO_LIBERADO')
	and	exists (select 1 from wms_endereco we
						inner join wms_bairro wb
							on	wb.cd_bairro	= we.cd_bairro
						where	wb.cd_filial	= :filial_estoque
						and we.cd_endereco = w.cd_endereco)	
	and (SELECT dbo.wms_retorna_end_bloqueado(w.cd_endereco)) = 'N'
order by w.dh_validade
" arguments=(("produto", number),("filial_estoque", number)) )
