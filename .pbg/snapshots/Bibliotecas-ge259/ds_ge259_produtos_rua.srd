table(column=(type=long updatewhereclause=yes name=nr_prioridade dbname="wms_endereco_produto.nr_prioridade" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="wms_endereco_produto.cd_endereco" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_endereco_produto.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_distribuidora_produto.qt_pedida" )
 column=(type=decimal(17) updatewhereclause=yes name=qt_capacidade_litro dbname="qt_capacidade_litro" )
 column=(type=decimal(17) updatewhereclause=yes name=qt_capacidade_litro_ecommerce dbname="qt_capacidade_litro_ecommerce" )
 column=(type=long updatewhereclause=yes name=qt_lista_separacao dbname="qt_lista_separacao" )
 retrieve="select	e.nr_prioridade, 
			e.cd_endereco, 
			e.cd_produto, 
			p.qt_atendida as qt_pedida, 
			round(((isnull(c.qt_largura_cm_caixa_estoque, 0) * isnull(c.qt_altura_cm_caixa_estoque,0) * isnull(c.qt_profund_cm_caixa_estoque, 0)) / 1000),2) as qt_capacidade_litro,
			round(((isnull(g.qt_largura_cm, 0) * isnull(g.qt_altura_cm,0) * isnull(g.qt_profundidade_cm, 0)) / 1000), 2)  as qt_capacidade_litro_ecommerce,
			isnull(p.qt_lista_separacao, 0) qt_lista_separacao
from pedido_distribuidora_produto p
inner join wms_endereco_produto e on e.cd_produto = p.cd_produto
inner join wms_endereco v on v.cd_endereco = e.cd_endereco
inner join produto_geral	g on g.cd_produto = p.cd_produto
inner join produto_central c on c.cd_produto = p.cd_produto
where p.cd_filial = :filial
  and p.nr_pedido_distribuidora = :pedido 
  and v.cd_rua	= :rua
  and p.cd_produto in (select cd_produto from wms_endereco_produto
								  where cd_esteira = :esteira)
  and p.qt_atendida > isnull(p.qt_lista_separacao , 0) 
order by cd_produto, e.nr_prioridade			 " arguments=(("filial", number),("pedido", number),("rua", string),("esteira", number)) )
