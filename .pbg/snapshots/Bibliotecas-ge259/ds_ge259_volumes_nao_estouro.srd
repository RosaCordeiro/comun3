table(column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="wms_lista_separacao.cd_filial" dbalias="a.cd_filial" )
 column=(type=long update=yes updatewhereclause=yes name=nr_pedido_distribuidora dbname="wms_lista_separacao.nr_pedido_distribuidora" dbalias="a.nr_pedido_distribuidora" )
 column=(type=long update=yes updatewhereclause=yes name=nr_volume dbname="wms_lista_separacao.nr_volume" dbalias="a.nr_volume" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=qt_capacidade_utilizada dbname="wms_lista_separacao.qt_capacidade_utilizada" dbalias="a.qt_capacidade_utilizada" )
 column=(type=decimal(3) update=yes updatewhereclause=yes name=qt_peso_kg dbname="wms_lista_separacao.qt_peso_kg" dbalias="a.qt_peso_kg" )
 retrieve="select distinct  a.cd_filial,
				a.nr_pedido_distribuidora,
				a.nr_volume,
				a.qt_capacidade_utilizada,
				a.qt_peso_kg
from wms_lista_separacao a
inner join wms_lista_separacao_produto  b
	on a.cd_filial  = b.cd_filial
	and a.nr_pedido_distribuidora = b.nr_pedido_distribuidora
	and a.nr_volume  = b.nr_volume 
inner Join produto_geral p On p.cd_produto = b.cd_produto
Where a.cd_filial						= :cd_filial
	and a.nr_pedido_distribuidora = :nr_pedido_distribuidora
	and a.cd_tipo_volume			= 1
	and a.cd_esteira 					= :cd_esteira
	and a.dh_cancelamento			is null
	and coalesce(a.id_estouro_volume, 'N')	<> 'S'
	and (SELECT dbo.wms_retorna_end_bloqueado(b.cd_endereco_localizacao)) = 'N'
order by a.nr_volume" arguments=(("cd_filial", number),("nr_pedido_distribuidora", number),("cd_esteira", number)) )
