table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_distribuidora_produto.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_separada dbname="pedido_distribuidora_produto.qt_separada" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" )
 column=(type=char(8) updatewhereclause=yes name=cd_local_estocagem dbname="produto_central.cd_local_estocagem" )
 retrieve="  SELECT produto_geral.cd_produto,   
         pedido_distribuidora_produto.qt_pedida,   
         pedido_distribuidora_produto.qt_separada,
         de_produto + ~" : ~" + de_apresentacao_estoque de_produto,
			produto_geral.de_codigo_barras,
         produto_central.cd_local_estocagem   
    FROM pedido_distribuidora,   
         pedido_distribuidora_produto,   
         produto_geral,
         produto_central  
   WHERE ( pedido_distribuidora_produto.cd_filial = pedido_distribuidora.cd_filial ) 
     and ( pedido_distribuidora_produto.nr_pedido_distribuidora = pedido_distribuidora.nr_pedido_distribuidora )
     and ( produto_geral.cd_produto = pedido_distribuidora_produto.cd_produto )
     and ( produto_central.cd_produto = pedido_distribuidora_produto.cd_produto )
     and ( pedido_distribuidora.cd_filial = :pl_filial )
     and ( pedido_distribuidora.nr_pedido_distribuidora = :pl_pedido )
" arguments=(("pl_filial", number),("pl_pedido", number))  sort="de_produto A " )
