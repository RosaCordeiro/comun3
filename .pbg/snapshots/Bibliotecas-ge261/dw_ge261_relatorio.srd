table(column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_compra.nr_nf" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="nf_compra.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_compra.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_compra.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_compra.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="nf_compra.vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_compra.vl_total_nf" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="item_nf_compra.cd_natureza_operacao" )
 column=(type=char(40) updatewhereclause=yes name=de_natureza_operacao dbname="natureza_operacao.de_natureza_operacao" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_total_produtos dbname="vl_total_produtos" )
 retrieve="  SELECT nf.nr_nf,   
			nf.cd_fornecedor, 
			fo.nm_razao_social,
			nf.de_especie,
			nf.de_serie,    
         nf.dh_movimentacao_caixa,   
         nf.vl_icms_st, 
			nf.vl_total_nf,			
         it.cd_natureza_operacao,
         nt.de_natureza_operacao,          
			sum(it.qt_faturada * (it.vl_preco_unitario*((100 - it.pc_desconto)/100))) vl_total_produtos
         
    FROM nf_compra         nf,   
 			item_nf_compra    it,
         filial            fi,
			fornecedor        fo,
         produto_geral     pg,
         natureza_operacao  nt

   WHERE it.cd_filial     = nf.cd_filial
     and it.de_serie      = nf.de_serie
	  and it.de_especie    = nf.de_especie
	  and it.cd_fornecedor = nf.cd_fornecedor
	  and it.nr_nf         = nf.nr_nf
     
     and pg.cd_produto    = it.cd_produto
	  and nt.cd_natureza_operacao = it.cd_natureza_operacao

	  and nf.cd_filial   		= fi.cd_filial 
     and nf.cd_filial_pedido is null 
     and nf.cd_fornecedor    = fo.cd_fornecedor
	  and nf.dh_movimentacao_caixa between :dt_inicio and :dt_termino
	  and it.cd_natureza_operacao in(1556,2556)

group by nf.nr_nf,   
			nf.cd_fornecedor, 
			fo.nm_razao_social,
			nf.de_especie,
			nf.de_serie,    
         nf.dh_movimentacao_caixa,   
         nf.vl_icms_st,  
         nf.vl_total_nf,			
         it.cd_natureza_operacao,
         nt.de_natureza_operacao
order by it.cd_natureza_operacao


	  
" arguments=(("dt_inicio", date),("dt_termino", date)) )
