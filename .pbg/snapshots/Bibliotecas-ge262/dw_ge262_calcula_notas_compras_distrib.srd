table(column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_compra.nr_nf" )
 column=(type=datetime updatewhereclause=yes name=nf_compra_dh_emissao dbname="nf_compra.dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=nf_compra_dh_movimentacao_caixa dbname="nf_compra.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_compra_vl_icms_st dbname="nf_compra.vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_produtos dbname="vl_total_produtos" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_compra_vl_total_nf dbname="nf_compra.vl_total_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto dbname="nf_compra.vl_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_outras_despesas dbname="nf_compra.vl_outras_despesas" )
 column=(type=long updatewhereclause=yes name=cd_grupo_produto dbname="produto_geral.cd_grupo_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_compra.vl_preco_unitario" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="item_nf_compra.qt_recebida" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="item_nf_compra.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_repassado dbname="item_nf_compra.vl_icms_repassado" )
 retrieve="  SELECT nf_compra.nr_nf,   
         nf_compra.dh_emissao,   
         nf_compra.dh_movimentacao_caixa,   
         nf_compra.vl_icms_st,   
         nf_compra.vl_total_produtos - nf_compra.vl_desconto vl_total_produtos,   
         nf_compra.vl_total_nf,   
         nf_compra.vl_desconto,
			nf_compra.vl_outras_despesas,   
         produto_geral.cd_grupo_produto,   
         item_nf_compra.vl_preco_unitario,   
         item_nf_compra.qt_recebida,   
         item_nf_compra.pc_desconto,
			item_nf_compra.vl_icms_repassado  
    FROM nf_compra,   
         item_nf_compra,   
         produto_geral  
   WHERE item_nf_compra.cd_filial     = nf_compra.cd_filial 
     and item_nf_compra.cd_fornecedor = nf_compra.cd_fornecedor 
     and item_nf_compra.nr_nf         = nf_compra.nr_nf 
     and item_nf_compra.de_especie    = nf_compra.de_especie 
     and item_nf_compra.de_serie      = nf_compra.de_serie 
     and item_nf_compra.cd_produto    = produto_geral.cd_produto 
	 and nf_compra.nr_nf 		      = :pl_nr_nf 
     AND nf_compra.cd_filial 	      = :pl_cd_filial 
     AND nf_compra.cd_fornecedor      = :ps_cd_fornecedor 
	 AND nf_compra.de_especie 	      = :ps_de_especie
     AND nf_compra.de_serie           = :ps_de_serie
    " arguments=(("pl_cd_filial", number),("ps_cd_fornecedor", string),("pl_nr_nf", number),("ps_de_especie", string),("ps_de_serie", string)) )
