table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="nf_compra.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=fornecedor_nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_compra.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_produtos dbname="vl_total_produtos" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_medicamento dbname="vl_medicamento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_popular dbname="vl_popular" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_perfumaria dbname="vl_perfumaria" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_drugstore dbname="vl_drugstore" )
 retrieve="  SELECT nf_compra.cd_fornecedor, 
		   fornecedor.nm_razao_social,
   		nf_compra.dh_movimentacao_caixa,  
		   Sum(nf_compra.vl_icms_st) vl_icms_st,   
		   Sum(nf_compra.vl_total_produtos - nf_compra.vl_desconto) vl_total_produtos,   
		   Sum(nf_compra.vl_total_nf) vl_total_nf,
		   0.00 vl_medicamento,
		   0.00 vl_popular,
		   0.00 vl_perfumaria,
		   0.00 vl_drugstore  
    FROM nf_compra,   
         filial,
		   fornecedor,
         parametro_loja
   WHERE nf_compra.cd_filial   		 = filial.cd_filial 
	  and fornecedor.cd_fornecedor = nf_compra.cd_fornecedor
     and parametro_loja.cd_filial = filial.cd_filial
     and parametro_loja.cd_parametro = 'ID_REDE_FILIAL'
	and fornecedor.id_distribuidora = 'S'
Group by nf_compra.cd_fornecedor, 
		   fornecedor.nm_razao_social,
 		   nf_compra.dh_movimentacao_caixa
"  sort="cd_fornecedor A fornecedor_nm_razao_social A dh_movimentacao_caixa A " )
