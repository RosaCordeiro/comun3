table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_porte dbname="filial.cd_porte" dbalias="f.cd_porte" )
 column=(type=long updatewhereclause=yes name=cd_regiao dbname="filial.cd_regiao" dbalias="f.cd_regiao" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_falta dbname="vl_falta" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda dbname="vl_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_falta dbname="pc_falta" )
 retrieve="select ppc.cd_filial, 
		f.nm_fantasia,
		f.cd_porte,
		f.cd_regiao,
		round(sum(ppc.qt_consulta * (pg.vl_preco_venda_atual / pg.vl_fator_conversao)),2) as vl_falta,
		0.00 as vl_venda,
		0.00 as pc_falta
FROM produto_procurado_zerado ppc (index idx_dt_fil_produto) 
INNER JOIN produto_geral pg
	on pg.cd_produto = ppc.cd_produto
Inner join filial f
	on f.cd_filial = ppc.cd_filial
where ppc.dh_movimentacao between :dt_inicio and :dt_fim

group by ppc.cd_filial,
			f.nm_fantasia,
			f.cd_porte,
			f.cd_regiao" arguments=(("dt_inicio", date),("dt_fim", date))  sort="cd_filial A " )
