table(column=(type=long updatewhereclause=yes name=filial_cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nf_compra_nr_nf dbname="nf_compra.nr_nf" )
 column=(type=char(9) updatewhereclause=yes name=nf_compra_cd_fornecedor dbname="nf_compra.cd_fornecedor" )
 column=(type=char(3) updatewhereclause=yes name=nf_compra_de_especie dbname="nf_compra.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=nf_compra_de_serie dbname="nf_compra.de_serie" )
 column=(type=datetime updatewhereclause=yes name=nf_compra_dh_emissao dbname="nf_compra.nf_compra_dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=nf_compra_dh_movimentacao_caixa dbname="nf_compra.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_compra_vl_icms_st dbname="nf_compra.vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_compra_vl_total_produtos dbname="vl_total_produtos" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_compra_vl_total_nf dbname="nf_compra.vl_total_nf" )
 column=(type=char(40) updatewhereclause=yes name=fornecedor_nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_medicamento dbname="vl_medicamento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_popular dbname="vl_popular" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_perfumaria dbname="vl_perfumaria" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_drugstore dbname="vl_drugstore" )
 retrieve="  SELECT filial.cd_filial,   
         filial.nm_fantasia,   
         nf_compra.nr_nf,   
			nf_compra.cd_fornecedor, 
			nf_compra.de_especie,
			nf_compra.de_serie,  
         nf_compra.dh_emissao nf_compra_dh_emissao,   
         nf_compra.dh_movimentacao_caixa,   
         nf_compra.vl_icms_st,   
         nf_compra.vl_total_nf - nf_compra.vl_icms_st vl_total_produtos,   
         nf_compra.vl_total_nf,
			fornecedor.nm_fantasia,
			0.00 vl_medicamento,
			0.00 vl_popular,
			0.00 vl_perfumaria,
			0.00 vl_drugstore
    FROM nf_compra,   
         filial,
			fornecedor
   WHERE nf_compra.cd_filial   		= filial.cd_filial 
     and nf_compra.cd_filial_pedido is null 
     and nf_compra.cd_fornecedor    = fornecedor.cd_fornecedor
"  sort="nf_compra_dh_movimentacao_caixa A filial_nm_fantasia A nf_compra_nr_nf A " )
