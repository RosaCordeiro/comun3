table(column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_compra.dh_movimentacao_caixa" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="nf_compra.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_fornecedor dbname="fornecedor.nm_razao_social" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_compra.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_compra.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_compra.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_compra.de_serie" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="vw_item_nf_compra.qt_faturada" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="vw_item_nf_compra.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="vw_item_nf_compra.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_repassado dbname="vw_item_nf_compra.vl_icms_repassado" )
 column=(type=decimal(28) updatewhereclause=yes name=vl_custo_nf dbname="vw_item_nf_compra.vl_custo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="vw_item_nf_compra.vl_icms_st" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf_forn dbname="cidade.cd_uf_forn" )
 column=(type=char(102) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 retrieve="select n.dh_movimentacao_caixa,
		n.cd_fornecedor,
		f.nm_razao_social,
		n.cd_filial,
		l.nm_fantasia,
		n.nr_nf,
		n.de_especie,
		n.de_serie,
		i.qt_faturada,
		i.vl_preco_unitario,
		i.pc_desconto,
		i.vl_icms_repassado,
		i.vl_custo,
		i.vl_icms_st,
		cfo.cd_unidade_federacao as cd_uf_forn,
		g.de_produto||': '||g.de_apresentacao_venda as de_produto,
		g.cd_produto
from nf_compra n
inner join vw_item_nf_compra i
	on i.cd_filial			= n.cd_filial
	and i.cd_fornecedor = n.cd_fornecedor
	and i.nr_nf			= n.nr_nf
	and i.de_especie	= n.de_especie
	and i.de_serie		= n.de_serie
inner join fornecedor f
	on f.cd_fornecedor = n.cd_fornecedor
inner join filial l
	on l.cd_filial	= n.cd_filial
inner join cidade cf
	on cf.cd_cidade = l.cd_cidade
inner join cidade cfo
	on cfo.cd_cidade = f.cd_cidade
Inner join produto_geral g
	on g.cd_produto = i.cd_produto
where n.dh_movimentacao_caixa between :dt_inicio and :dt_termino" arguments=(("dt_inicio", date),("dt_termino", date))  sort="cd_fornecedor A " )
group(level=1 header.height=80 trailer.height=0 by=("cd_fornecedor" ) header.color="536870912" header.transparency="0" header.gradient.color="8421504" header.gradient.transparency="0" header.gradient.angle="0" header.brushmode="0" header.gradient.repetition.mode="0" header.gradient.repetition.count="0" header.gradient.repetition.length="100" header.gradient.focus="0" header.gradient.scale="100" header.gradient.spread="100" trailer.color="536870912" trailer.transparency="0" trailer.gradient.color="8421504" trailer.gradient.transparency="0" trailer.gradient.angle="0" trailer.brushmode="0" trailer.gradient.repetition.mode="0" trailer.gradient.repetition.count="0" trailer.gradient.repetition.length="100" trailer.gradient.focus="0" trailer.gradient.scale="100" trailer.gradient.spread="100"  sort="count(cd_fornecedor for group 1) A " )
