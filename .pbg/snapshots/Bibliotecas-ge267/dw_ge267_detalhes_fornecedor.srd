 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="fornecedor.dh_inclusao" dbalias="f.dh_inclusao" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao dbname="fornecedor.dh_atualizacao" dbalias="f.dh_atualizacao" )
