 column=(type=char(1) updatewhereclause=yes name=id_considera_ipi_pedido dbname="fornecedor.id_considera_ipi_pedido" dbalias="f.id_considera_ipi_pedido" values="Considera o IPI no Pedido de Compra?	S/Considera o IPI no Pedido de Compra?	N" )
 retrieve="  SELECT f.cd_filial,   
         f.cd_fornecedor,   
         f.cd_cidade,
         f.nm_fantasia,   
         f.nm_razao_social,   
         f.id_fisica_juridica,   
         f.nr_cgc,   
         f.nr_cpf,   
         f.nr_inscricao_estadual,   
         f.de_endereco,   
         f.de_bairro,   
         f.nr_cep,   
         f.nr_telefone,   
         f.nr_fax,   
         f.nr_ddd_telefone,   
         f.nr_ddd_fax,   
         f.nr_ddd_fax_compras,   
         f.pc_desconto_usual,   
         f.nm_contato,   
         f.nr_ddd_telefone_compras,   
         f.nr_telefone_compras,   
         f.nr_fax_compras,   
         f.id_fornecedor_transportadora,
        	f.de_email,
		f.id_recebe_email_xml,
		f.de_endereco_email_envio_xml,
		f.cd_condicao_pagamento,
         cast('' as varchar(40)) nm_localiza,
         c.nm_cidade as nm_cidade,   
         f.id_regime_especial,
		cp.de_condicao as de_condicao_pagamento,
		coalesce(f.id_situacao, 'A') as id_situacao,
		u.nm_usuario as nm_comprador,
		f.nr_matricula_comprador,
		f.id_regime_tributario,
		c.cd_unidade_federacao as cd_unidade_federacao,
		f.nr_endereco,
		f.id_utiliza_agendamento_entrega,
		Coalesce(f.id_pedido_edi, 'Z') As id_pedido_edi,
		f.id_atividade_economica,
		f.dh_inclusao,
		f.dh_atualizacao,
		f.nr_matricula_atualizacao,
		r.nm_usuario, 
		f.cd_fornecedor_sap,
		f.id_considera_ipi_pedido
    FROM fornecedor f
INNER JOIN cidade c
	on c.cd_cidade = f.cd_cidade
LEFT OUTER JOIN condicao_pagamento cp
	on cp.cd_condicao = f.cd_condicao_pagamento
LEFT OUTER JOIN usuario u
	on u.nr_matricula = f.nr_matricula_comprador
LEFT OUTER JOIN usuario r
	on r.nr_matricula = f.nr_matricula_atualizacao
WHERE f.cd_fornecedor = :cd_fornecedor" arguments=(("cd_fornecedor", string)) )
