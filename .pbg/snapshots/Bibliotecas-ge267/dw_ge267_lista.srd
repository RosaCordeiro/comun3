table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="fornecedor.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=char(18) updatewhereclause=yes name=nr_identificacao dbname="nr_identificacao" )
 column=(type=char(15) updatewhereclause=yes name=nr_inscricao_estadual dbname="fornecedor.nr_inscricao_estadual" )
 column=(type=char(16) updatewhereclause=yes name=nr_telefone dbname="nr_telefone" )
 column=(type=char(40) updatewhereclause=yes name=de_endereco dbname="fornecedor.de_endereco" )
 column=(type=long updatewhereclause=yes name=fornecedor_nr_endereco dbname="fornecedor.nr_endereco" )
 column=(type=char(20) updatewhereclause=yes name=fornecedor_de_bairro dbname="fornecedor.de_bairro" )
 column=(type=char(8) updatewhereclause=yes name=fornecedor_nr_cep dbname="fornecedor.nr_cep" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" )
 column=(type=datetime updatewhereclause=yes name=fornecedor_dh_inclusao dbname="fornecedor.dh_inclusao" )
 column=(type=datetime updatewhereclause=yes name=fornecedor_dh_atualizacao dbname="fornecedor.dh_atualizacao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_comprador dbname="fornecedor.nr_matricula_comprador" )
 column=(type=char(20) updatewhereclause=yes name=cd_fornecedor_sap dbname="fornecedor.cd_fornecedor_sap" )
 column=(type=char(3) updatewhereclause=yes name=id_fabricante dbname="id_fabricante" )
 column=(type=char(3) updatewhereclause=yes name=id_regime_especial dbname="id_regime_especial" )
 column=(type=char(3) updatewhereclause=yes name=id_simples_nacional dbname="id_simples_nacional" )
 column=(type=char(3) updatewhereclause=yes name=id_transportadora dbname="id_transportadora" )
 column=(type=char(3) updatewhereclause=yes name=id_distribuidora dbname="id_distribuidora" )
 retrieve="Select cd_fornecedor, 
		nm_razao_social, 
		nm_fantasia, 
		case 
  			when id_fisica_juridica = 'J' then case when len(nr_cgc)=14 then substring(nr_cgc,1,2)||'.'||substring(nr_cgc,3,3)||'.'||substring(nr_cgc,6,3)||'/'||substring(nr_cgc,9,4)||'-'||substring(nr_cgc,13,2) else '' end 
			else case when len(nr_cpf)=11 then substring(nr_cpf,1,3)||'.'||substring(nr_cpf,4,3)||'.'||substring(nr_cpf,7,3)||'-'||substring(nr_cpf,10,2) else '' end
		end as nr_identificacao, 
		nr_inscricao_estadual,
		case when len(nr_ddd_telefone)>1 then  '('||nr_ddd_telefone||') ' else '' end||nr_telefone as nr_telefone,
		f.de_endereco,   
		f.nr_endereco,
         f.de_bairro,   
         f.nr_cep, 
		c.nm_cidade,
		c.cd_unidade_federacao,
		f.dh_inclusao,
	 	f.dh_atualizacao,
		f.nr_matricula_comprador, 
		f.cd_fornecedor_sap,
		case when f.id_atividade_economica = '1' then 'SIM' else 'N$$HEX1$$c300$$ENDHEX$$O' end as id_fabricante,
		case when f.id_regime_especial = 'S' then 'SIM' else 'N$$HEX1$$c300$$ENDHEX$$O' end as id_regime_especial,
		case when f.id_regime_tributario = '1' then 'SIM' else 'N$$HEX1$$c300$$ENDHEX$$O' end as id_simples_nacional,
		case when f.id_fornecedor_transportadora = 'T' then 'SIM' else 'N$$HEX1$$c300$$ENDHEX$$O' end as id_transportadora,
		case when f.id_distribuidora = 'S' then 'SIM' else 'N$$HEX1$$c300$$ENDHEX$$O' end as id_distribuidora
from fornecedor f 
inner join cidade c
	on c.cd_cidade = f.cd_cidade"  sort="nm_razao_social A " )
