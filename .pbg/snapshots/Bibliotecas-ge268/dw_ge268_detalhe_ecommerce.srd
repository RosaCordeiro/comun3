 column=(type=char(1) updatewhereclause=yes name=id_controle_preco dbname="produto_abcfarma.id_controle_preco" dbalias="pab.id_controle_preco" )
 column=(type=char(1) updatewhereclause=yes name=nm_pbm dbname="nm_pbm" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo dbname="qt_estoque_minimo" )
 column=(type=long updatewhereclause=yes name=nr_divisao_fornecedor dbname="nr_divisao_fornecedor" )
 column=(type=char(1) updatewhereclause=yes name=id_contem_gluten dbname="id_contem_gluten" )
 column=(type=char(1) updatewhereclause=yes name=id_contem_acucar dbname="id_contem_acucar" )
 column=(type=char(1) updatewhereclause=yes name=id_contem_lactose dbname="id_contem_lactose" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_reembolso_fpb dbname="produto_geral.vl_reembolso_fpb" dbalias="pg.vl_reembolso_fpb" )
 column=(type=long updatewhereclause=yes name=cd_tipo_prescricao dbname="produto_geral.cd_tipo_prescricao" dbalias="pg.cd_tipo_prescricao" )
 column=(type=long updatewhereclause=yes name=cd_tipo_alerta_restricao dbname="produto_geral.cd_tipo_alerta_restricao" dbalias="pg.cd_tipo_alerta_restricao" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_comprimento dbname="produto_geral.qt_comprimento" dbalias="pg.qt_comprimento" )
 column=(type=char(1) updatewhereclause=yes name=id_farm_gov_bolsa_familia dbname="id_farm_gov_bolsa_familia" )
 retrieve="select pc.cd_produto,   
       pc.cd_mix_produto,
       pc.id_tipo_reposicao_estoque,
       pc.cd_produto_fornecedor,   
       pc.pc_desconto_fornecedor,   
       pc.vl_peso_liquido,   
       pc.dh_situacao,   
       pc.cd_local_estocagem,   
       pc.id_origem_produto_fornecedor,   
       pc.cd_produto_abcfarma,   
       pc.vl_fator_conversao_abcfarma,   
       pc.cd_divisao_estocagem,   
       pc.id_preco_informado,   
       pc.id_contrato_fornecedor,   
       pc.id_pagamento_apos_venda,
       pc.id_sugere_pedido_filial,
       pc.id_lei_generico,
	   pg.id_lei_generico,
       pg.de_produto,   
       pg.de_apresentacao_estoque,   
       pg.de_apresentacao_venda,   
       pg.nr_embalagem_padrao,   
       pg.nr_classificacao_fiscal,   
       pg.cd_unidade_medida_compra,   
       pg.cd_unidade_medida_venda,   
       pg.cd_grupo_produto,   
       pg.cd_subgrupo_produto,   
       pg.cd_linha_produto,   
       pg.cd_fornecedor_usual,   
       pg.id_situacao,
       pg.id_situacao as id_situacao_anterior,
	   pc.nr_matric_alteracao_situacao,
	   pc.de_alteracao_situacao,   
	   pc.de_alteracao_situacao as de_alteracao_situacao_anterior,
       pg.id_liberado_filial,   
       pg.de_codigo_barras,   
       pg.dh_alteracao_codigo_barras,   
       pg.vl_fator_conversao,   
       round(pc.vl_custo_gerencial * pg.vl_fator_conversao, 2) 'vl_custo_medio',   
       round(pc.vl_custo_gerencial_geral * pg.vl_fator_conversao, 2) 'vl_custo_gerencial',   
       pg.pc_desconto_atual,   
       pg.pc_desconto_futuro,   
       pg.id_preco_bloqueado,   
       pg.pc_ipi,   
       pg.cd_grupo_psico,   
       pg.cd_dcb,   
       pg.cd_origem_produto,   
       pg.id_caderno_abcfarma,   
       pg.pc_reducao_base_icms,   
       pg.cd_produto,   
       pg.nr_matricula_desconto_futuro,   
       pg.nr_matricula_desconto_atual,   
       pg.dh_desconto_atual,   
       pg.dh_desconto_futuro,   
       pg.dh_inclusao_produto,   
       pg.dh_termino_avaliacao,
       pg.id_tipo_desconto_atual,   
       pg.id_tipo_desconto_futuro,
       pg.id_proprio_consignado,
       pg.id_situacao_pis_cofins,
       pg.cd_subcategoria,
       pg.vl_ponto_clube,
       pg.qt_pontos_resgate,
		 pg.pc_desconto_clube_atual,
		 pg.dh_desconto_clube_atual,
		 pg.nr_matric_desc_clube_atual,
		 pg.pc_desconto_clube_futuro,
		 pg.dh_desconto_clube_futuro,
		 pg.nr_matric_desc_clube_futuro,
       pg.id_utiliza_vale_resgate,
       pg.qt_unidades_embalagem,
       pg.qt_concentracao,
       coalesce(pg.id_apresentacao, '00') id_apresentacao,
       pg.qt_dias_maximo_tratamento,
       pg.vl_volume,
       pg.cd_fabricante,
	   pg.de_registro_ms,
       coalesce(pc.id_projeto_conexao, '0') id_projeto_conexao,
	   pg.id_recuperacao_vencido,
	   pg.de_descricao_internet,
	   pg.qt_largura_cm,
	   pg.qt_altura_cm,
	   pg.qt_profundidade_cm,
	   pg.qt_peso_grama,
	   coalesce(pg.id_liberado_ecommerce, 'N') id_liberado_ecommerce,
	   pg.de_principal_internet,
	   cp.de_grupo as de_grupo,
       cp.de_subgrupo as de_subgrupo,
       cp.de_categoria as de_categoria,
       cp.de_subcategoria as de_subcategoria,
       pab.de_produto as de_produto_abcfarma,   
       pab.de_apresentacao as de_apresentacao_abcfarma, 
		 pab.nm_fabricante as nm_fabricante_abc_farma,
       f.nm_fantasia as nm_fornecedor,   
       fa.nm_razao_social as nm_fabricante,   
	   dcb.de_dcb as de_dcb,   
       space(40) de_produto_localizacao,
	   'N' as id_foto,
	   'N' as id_foto_categoria,
	   space(10) principal_internet,
		gap.de_grupo as de_grupo_alteracao_preco,
		pc.cd_grupo_alteracao_preco,
		pg.id_farmacia_popular id_farmacia_popular,
		pg.id_gratis_farm_popular,
		pg.cd_planograma,
		pc.id_revisao_fiscal,
		mp.de_marca,
		pg.cd_marca,
		pg.cd_st_origem,
		pg.id_geladeira,
		pg.cd_produto_sap,
		pc.qt_largura_cm_caixa_forn,   
         pc.qt_altura_cm_caixa_forn,    
         pc.qt_profundidade_cm_caixa_forn,    
         pc.qt_largura_cm_caixa_estoque,    
         pc.qt_altura_cm_caixa_estoque,    
         pc.qt_profund_cm_caixa_estoque,
		pc.cd_bairro_wms,
		pg.cd_unidade_medida_padrao,
		pg.vl_fator_conversao_padrao,
		pg.id_promover_venda,
		pg.id_permite_devolucao,
		pg.cd_marca_ecommerce,
		me.de_marca,
		pab.id_controle_preco,
		~"~" nm_pbm,
		Coalesce(pg.qt_estoque_minimo, 0) As qt_estoque_minimo,
		00 nr_divisao_fornecedor,
		Coalesce(pg.id_contem_gluten, 'N') As id_contem_gluten,
		Coalesce(pg.id_contem_acucar, 'N') As id_contem_acucar,
		Coalesce(pg.id_contem_lactose, 'N') As id_contem_lactose,
		pg.vl_reembolso_fpb, 
		pg.cd_tipo_prescricao, 
		pg.cd_tipo_alerta_restricao,
		pg.qt_comprimento,
		Coalesce(pg.id_farm_gov_bolsa_familia, 'N') As id_farm_gov_bolsa_familia
from produto_geral pg
Inner join produto_central pc
	on pc.cd_produto = pg.cd_produto
left outer join marca_produto mp 
	on mp.cd_marca = pg.cd_marca
left outer join marca_ecommerce me
	on me.cd_marca = pg.cd_marca_ecommerce
left outer join vw_classificacao_produto cp
	on cp.cd_subcategoria = pg.cd_subcategoria
left outer join fornecedor f
	on f.cd_fornecedor = pg.cd_fornecedor_usual
left outer join grupo_alteracao_preco gap
	on gap.cd_grupo = cd_grupo_alteracao_preco
left outer join dcb_produto dcb
	on dcb.cd_dcb = pg.cd_dcb
left outer join produto_abcfarma pab
	on pab.cd_produto_abcfarma = pc.cd_produto_abcfarma
left outer join fabricante fa
	on fa.cd_fabricante = pg.cd_fabricante
where pg.cd_produto = :produto" arguments=(("produto", number)) )
