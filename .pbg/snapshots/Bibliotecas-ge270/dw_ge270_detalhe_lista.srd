table(column=(type=long updatewhereclause=yes name=codigo_prod dbname="codigo_prod" )
 column=(type=char(102) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=custo_unitario dbname="custo_unitario" )
 column=(type=char(73) updatewhereclause=yes name=departamento dbname="departamento" )
 column=(type=long updatewhereclause=yes name=quantidade dbname="quantidade" )
 column=(type=decimal(2) updatewhereclause=yes name=total dbname="total" )
 retrieve="SELECT	tr.codigo_prod,
			tr.de_produto,
			tr.custo_unitario ,
			tr.departamento,
			sum(tr.quantidade) as quantidade,         
			sum(tr.total) as total
FROM (SELECT	it.cd_produto as codigo_prod,
					pg.de_produto +': '+ pg.de_apresentacao_venda as de_produto,
					it.vl_custo_unitario as custo_unitario ,
					Case When na.cd_centro_custo is null then fi.nm_fantasia + ' ('+ Cast(fi.cd_filial as varchar) +')' else cc.de_centro_custo end as departamento,
					sum(it.qt_faturada) as quantidade,         
					sum(it.vl_custo_unitario * it.qt_faturada) as total
		FROM nf_almoxarifado				na
		INNER JOIN item_nf_almoxarifado	it	on it.nr_nf = na.nr_nf
		INNER JOIN produto_geral			pg	on pg.cd_produto = it.cd_produto
		LEFT OUTER JOIN filial				fi	on fi.cd_filial = na.cd_filial
		LEFt OUTER JOIN centro_custo		cc	on cc.cd_centro_custo = na.cd_centro_custo
		WHERE  na.dh_movimentacao_caixa between :dt_inicio and :dt_termino   
			and na.dh_cancelamento is null
			and it.cd_produto        = :cd_produto
		  Group by	it.cd_produto,
						pg.de_produto +': '+ pg.de_apresentacao_venda,
						it.vl_custo_unitario,
						Case When na.cd_centro_custo is null then fi.nm_fantasia + ' ('+ Cast(fi.cd_filial as varchar) +')' else cc.de_centro_custo end
		
		UNION
		
		SELECT	it.cd_produto as codigo_prod,
					pg.de_produto +': '+ pg.de_apresentacao_venda as de_produto,
					it.vl_custo_unitario as custo_unitario ,
					Case When na.cd_centro_custo is null then fi.nm_fantasia + ' ('+ Cast(fi.cd_filial as varchar) +')' else cc.de_centro_custo end as departamento,
					sum(it.qt_transferida) as quantidade,         
					sum(it.vl_custo_unitario * it.qt_transferida) as total
		FROM nf_transferencia na 
		INNER JOIN item_nf_transferencia it (index pk_item_nf_transferencia)	on		it.cd_filial_origem = na.cd_filial_origem
																									and	it.nr_nf 			= na.nr_nf
																									and	it.de_especie	= na.de_especie
																									and	it.de_serie		= na.de_serie
		INNER JOIN produto_geral pg (index pk_produto_geral)	on	pg.cd_produto = it.cd_produto
		LEFT OUTER JOIN filial fi (index pk_filial)	on fi.cd_filial = na.cd_filial_destino
		LEFT OUTER JOIN centro_custo cc (index pk_centro_custo)	on cc.cd_centro_custo = na.cd_centro_custo

		left join pedido_distribuidora			b	on		b.cd_filial						= na.cd_filial_destino
															and	b.nr_pedido_distribuidora	= na.nr_pedido_distribuidora
		left join pedido_distribuidora_almox	c	on		c.cd_filial							= b.cd_filial
															and	c.nr_pedido_distribuidora	= b.nr_pedido_distribuidora
		left join pedido_almoxarifado			d	on		d.cd_filial						= c.cd_filial
															and 	d.nr_pedido						= c.nr_pedido_almoxarifado

		WHERE  na.dh_movimentacao_caixa between :dt_inicio and :dt_termino   
			and na.dh_cancelamento is null
			and it.cd_produto +0       = :cd_produto
			and na.id_almoxarifado	= 'S'
		  Group by	it.cd_produto,
						pg.de_produto +': '+ pg.de_apresentacao_venda,
						it.vl_custo_unitario,
						Case When na.cd_centro_custo is null then fi.nm_fantasia + ' ('+ Cast(fi.cd_filial as varchar) +')' else cc.de_centro_custo end) tr
GROUP BY	tr.codigo_prod,
				tr.de_produto,
				tr.custo_unitario ,
				tr.departamento" arguments=(("dt_inicio", datetime),("dt_termino", datetime),("cd_produto", number)) )
