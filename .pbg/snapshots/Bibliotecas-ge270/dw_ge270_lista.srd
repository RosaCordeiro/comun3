table(column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="g.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="g.de_apresentacao_venda" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 retrieve="SELECT	 t.cd_produto,
			g.de_produto,
			g.de_apresentacao_venda,   
			sum(t.qt_faturada) as qt_faturada
FROM (	SELECT 	i.cd_produto,
						sum(i.qt_faturada)  as qt_faturada
			FROM nf_almoxarifado n
			Inner Join item_nf_almoxarifado i On n.nr_nf	=	i.nr_nf
			WHERE n.dh_cancelamento 	is null
				 and n.dh_movimentacao_caixa between :inicio and :termino
			  Group by	i.cd_produto
						
			UNION
			
			SELECT i.cd_produto,
						sum(i.qt_transferida)  as qt_faturada
			FROM nf_transferencia					n
			Inner Join item_nf_transferencia		i	on		n.cd_filial_origem				= i.cd_filial_origem
																and	n.nr_nf 							= i.nr_nf
																and	n.de_especie					= i.de_especie
																and	n.de_serie 						= i.de_serie
			left join pedido_distribuidora			b	on		b.cd_filial						= n.cd_filial_destino
																and	b.nr_pedido_distribuidora	= n.nr_pedido_distribuidora
			left join pedido_distribuidora_almox	c	on		c.cd_filial							= b.cd_filial
																and	c.nr_pedido_distribuidora	= b.nr_pedido_distribuidora
			left join pedido_almoxarifado			d	on		d.cd_filial						= c.cd_filial
																and 	d.nr_pedido						= c.nr_pedido_almoxarifado
			WHERE n.dh_cancelamento 	is null
				 and n.dh_movimentacao_caixa between :inicio and :termino
				 and n.id_almoxarifado = 'S'
			  Group by	i.cd_produto) t
INNER JOIN produto_geral g
	On g.cd_produto = t.cd_produto
GROUP BY t.cd_produto,
			g.de_produto,
			g.de_apresentacao_venda
" arguments=(("inicio", datetime),("termino", datetime))  sort="de_produto A de_apresentacao_venda A " )
