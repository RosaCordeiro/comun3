table(column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="nf_transferencia.cd_filial_origem" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_transferencia.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_transferencia.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_transferencia.de_serie" )
 column=(type=long updatewhereclause=yes name=cd_centro_custo dbname="centro_custo.cd_centro_custo" )
 column=(type=char(40) updatewhereclause=yes name=de_centro_custo dbname="centro_custo.de_centro_custo" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_requisitante dbname="pedido_almoxarifado.nr_matricula_requisitante" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 retrieve="select
	distinct nt.cd_filial_origem,
	nt.nr_nf,
	nt.de_especie,
	nt.de_serie,
	cc.cd_centro_custo,
	cc.de_centro_custo,
	pa.nr_matricula_requisitante,
	u.nm_usuario
from
	nf_transferencia nt
inner join pedido_distribuidora_almox pda on
	pda.nr_pedido_distribuidora = nt.nr_pedido_distribuidora
inner join dbo.pedido_almoxarifado pa on
	pa.cd_filial = pda.cd_filial
	and pa.nr_pedido = pda.nr_pedido_almoxarifado
inner join dbo.centro_custo cc on
	pa.cd_centro_custo = cc.cd_centro_custo
inner join dbo.usuario u on
	u.nr_matricula = pa.nr_matricula_requisitante
where
	nt.cd_filial_origem = 534
	and nt.cd_filial_destino = 2
	and nt.dh_movimentacao_caixa between :adt_inicio and :adt_fim
	and nt.id_almoxarifado = 'S'
	and nt.de_serie = '3'
union
select
	distinct nt.cd_filial_origem,
	nt.nr_nf,
	nt.de_especie,
	nt.de_serie,
	cc.cd_centro_custo,
	cc.de_centro_custo,
	'N/E' ,
	'PEDIDO ALMOX. N$$HEX1$$c300$$ENDHEX$$O ENCONTRADO'
from
	nf_transferencia nt
inner join pedido_distribuidora pd on
	pd.nr_pedido_distribuidora = nt.nr_pedido_distribuidora
	and pd.cd_filial = nt.cd_filial_destino
inner join dbo.centro_custo cc on
	pd.cd_centro_custo = cc.cd_centro_custo
where
	nt.cd_filial_origem = 534
	and nt.cd_filial_destino = 2
	and nt.dh_movimentacao_caixa between :adt_inicio and :adt_fim
	and nt.id_almoxarifado = 'S'
	and nt.de_serie = '3'
	and not exists (
		select
			1
		from
			pedido_distribuidora_almox pda
		where
			pda.nr_pedido_distribuidora = nt.nr_pedido_distribuidora
			and pda.cd_filial = nt.cd_filial_destino
	)" arguments=(("adt_inicio", datetime),("adt_fim", datetime)) )
