table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=cd_filial_sap dbname="integracao_sap.cd_filial_sap" )
 column=(type=char(14) updatewhereclause=yes name=nr_cnpj dbname="nr_cnpj" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_porte dbname="cd_porte" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_filial dbname="id_rede_filial" )
 column=(type=long updatewhereclause=yes name=cd_regiao dbname="cd_regiao" )
 column=(type=long updatewhereclause=yes name=clientes dbname="clientes" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=avista dbname="avista" initial="0.00" )
 column=(type=decimal(2) updatewhereclause=yes name=devolucao dbname="devolucao" initial="0.00" )
 column=(type=decimal(2) updatewhereclause=yes name=aprazo dbname="aprazo" initial="0.00" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cota_mes dbname="vl_cota_mes" initial="0.00" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cota_periodo dbname="vl_cota_periodo" initial="0.00" )
 column=(type=char(1) updatewhereclause=yes name=id_ordem dbname="id_ordem" )
 retrieve="select f.cd_filial,
		isp.cd_chave_sap as cd_filial_sap,
		f.nr_cgc as nr_cnpj,
		f.nm_fantasia,
		fp.cd_porte,
		f.id_rede_filial,
		f.cd_regiao as cd_regiao,
		coalesce(sum(r.qt_cliente_venda) - sum(r.qt_cliente_devolucao),0) as clientes,   
		coalesce(sum(r.vl_venda_avista + r.vl_venda_cartao_debito + r.vl_venda_cheque_avista),0) as avista,   
		coalesce(sum(r.vl_devolucao_venda),0) as devolucao,
		coalesce(sum(r.vl_venda_crediario + r.vl_venda_convenio + r.vl_venda_conta_corrente + r.vl_venda_cartao_credito + r.vl_venda_cheque_aprazo),0) as aprazo,
		sum(0.00) as  vl_cota_mes,
		sum(0.00) as vl_cota_periodo,
		case f.cd_filial when 534 then '2' else '1' end as id_ordem
from resumo_movimento_estoque r (index pk_resumo_movto_estoque)
Inner Join filial f (index pk_filial)
	on f.cd_filial = r.cd_filial
Left Outer Join integracao_sap isp
	on isp.cd_empresa = 1000
	and isp.cd_tabela = 'FILIAL'
	and isp.cd_chave_legado = cast(f.cd_filial as varchar)
LEFT OUTER JOIN (SELECT fp1.cd_filial, fp1.cd_porte 
						FROM filial_porte fp1
						WHERE fp1.dh_porte = (SELECT max(fp2.dh_porte) 
														FROM filial_porte fp2
														WHERE fp2.cd_filial = fp1.cd_filial
														AND fp2.dh_porte <=  :termino)) fp
	on fp.cd_filial = f.cd_filial
where  f.cd_filial <> 1
	and r.dh_resumo between :inicio and :termino
group by f.cd_filial,
			isp.cd_chave_sap,
			f.nr_cgc,
         	f.nm_fantasia,
			fp.cd_porte,
			f.id_rede_filial,
			f.cd_regiao,
			case f.cd_filial when 534 then '2' else '1' end" arguments=(("inicio", date),("termino", date))  sort="id_ordem A nm_fantasia A " )
