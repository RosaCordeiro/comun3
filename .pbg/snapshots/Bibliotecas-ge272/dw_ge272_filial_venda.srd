table(column=(type=long updatewhereclause=yes name=classificacao_rede dbname="classificacao_rede" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" dbalias="f.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=de_filial dbname="filial.de_filial" dbalias="f.de_filial" )
 column=(type=char(2) updatewhereclause=yes name=id_rede dbname="filial.id_rede" dbalias="f.id_rede" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_liquida dbname="filial_porte.vl_venda_liquida" dbalias="fp.vl_venda_liquida" )
 column=(type=long updatewhereclause=yes name=cd_porte dbname="cd_porte" )
 column=(type=long updatewhereclause=yes name=cd_porte_calc dbname="cd_porte_calc" )
 column=(type=long updatewhereclause=yes name=cd_porte_ant dbname="cd_porte_ant" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_liquida_1 dbname="filial_porte.vl_venda_liquida_1" dbalias="fp1.vl_venda_liquida_1" )
 column=(type=long updatewhereclause=yes name=cd_porte_vig_1 dbname="cd_porte_vig_1" )
 column=(type=long updatewhereclause=yes name=cd_porte_1 dbname="cd_porte_1" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_liquida_2 dbname="filial_porte.vl_venda_liquida_2" dbalias="fp2.vl_venda_liquida_2" )
 column=(type=long updatewhereclause=yes name=cd_porte_vig_2 dbname="cd_porte_vig_2" )
 column=(type=long updatewhereclause=yes name=cd_porte_2 dbname="cd_porte_2" )
 column=(type=char(8) updatewhereclause=yes name=id_alterou_porte dbname="id_alterou_porte" )
 retrieve="select Case f.id_rede_filial
			When 'DC' Then 1
			When 'CP' Then 1
			When 'PP' Then 3
			When 'AL' Then 3
			When 'MP' Then 5
			When 'PF' Then 5
			When 'CD' Then 7
		Else 8 End as classificacao_rede,
		f.cd_filial, 
		f.nm_fantasia as de_filial, 
		f.id_rede_filial as id_rede, 
		fp.vl_venda_liquida as vl_venda_liquida,
		coalesce(fp.cd_porte,1) as cd_porte,
		coalesce(fp.cd_porte_calculado,1) as cd_porte_calc,
		coalesce(fp1.cd_porte,1) as cd_porte_ant,
		fp1.vl_venda_liquida as vl_venda_liquida_1,
		coalesce(fp1.cd_porte,1) as cd_porte_vig_1,
		coalesce(fp1.cd_porte_calculado,1) as cd_porte_1,
		fp2.vl_venda_liquida as vl_venda_liquida_2,
		coalesce(fp2.cd_porte,1) as cd_porte_vig_2,
		coalesce(fp2.cd_porte_calculado,1) as cd_porte_2,
		Case When coalesce(fp.cd_porte,1) > coalesce(fp1.cd_porte,1) then 'AUMENTOU' 
			    When coalesce(fp.cd_porte,1) < coalesce(fp1.cd_porte,1) then 'BAIXOU' 
		Else 'MANTEVE' End as id_alterou_porte
from filial f
inner join filial_porte fp
	on fp.cd_filial = f.cd_filial
left outer join filial_porte fp1
	on fp1.cd_filial = f.cd_filial
   and fp1.dh_porte = dateadd(Month,-1,fp.dh_porte)
left outer join filial_porte fp2
	on fp2.cd_filial = f.cd_filial
   and fp2.dh_porte = dateadd(Month,-2,fp.dh_porte)
where fp.dh_porte = :dh_porte1" arguments=(("dh_porte1", date))  sort="classificacao_rede A de_filial A " )
