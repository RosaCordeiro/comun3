table(column=(type=char(2) update=yes updatewhereclause=yes key=yes name=id_rede dbname="porte_loja_limite.id_rede" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_porte dbname="porte_loja_limite.cd_porte" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=dh_inicio_vigencia dbname="porte_loja_limite.dh_inicio_vigencia" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_limite_maximo dbname="porte_loja_limite.vl_limite_maximo" )
 retrieve="select p.id_rede, p.cd_porte, p.dh_inicio_vigencia, p.vl_limite_maximo
from porte_loja_limite p
where p.dh_inicio_vigencia = (select max(p1.dh_inicio_vigencia)
										from porte_loja_limite p1
										where p1.dh_inicio_vigencia <= :dt_inicio
										and p1.id_rede = p.id_rede	)" update="porte_loja_limite" updatewhere=1 updatekeyinplace=no arguments=(("dt_inicio", date))  sort="id_rede A cd_porte A vl_limite_maximo A " )
