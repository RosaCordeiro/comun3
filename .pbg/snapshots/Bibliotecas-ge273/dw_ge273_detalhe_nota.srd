 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pago_avista dbname="vl_pago_avista" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_venda dbname="id_tipo_venda" values="$$HEX1$$c000$$ENDHEX$$ VISTA	AV/CREDI$$HEX1$$c100$$ENDHEX$$RIO	CR/CONTA CORRENTE	CC/CONV$$HEX1$$ca00$$ENDHEX$$NIO	CV/" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_operador dbname="nr_matric_operador" )
 column=(type=char(40) updatewhereclause=yes name=usuario_operador dbname="operador" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_vendedor dbname="nr_matricula_vendedor" )
 column=(type=char(40) updatewhereclause=yes name=usuario_vendedor dbname="vendedor" )
 column=(type=char(2) updatewhereclause=yes name=cd_forma_pagamento dbname="cd_forma_pagamento" values="DINHEIRO	DI/CHEQUE $$HEX1$$c000$$ENDHEX$$ PRAZO	HP/CHEQUE $$HEX1$$c000$$ENDHEX$$ VISTA	HA/CREDI$$HEX1$$c100$$ENDHEX$$RIO	CR/CONTA CORRENTE	CC/CART$$HEX1$$c300$$ENDHEX$$O CR$$HEX1$$c900$$ENDHEX$$DITO	CP/CART$$HEX1$$c300$$ENDHEX$$O D$$HEX1$$c900$$ENDHEX$$BITO	CA/CONV$$HEX1$$ca00$$ENDHEX$$NIO	CV/M$$HEX1$$da00$$ENDHEX$$LTIPLAS FORMAS	MF/" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="cd_convenio" )
 column=(type=char(60) updatewhereclause=yes name=nm_convenio dbname="nm_convenio" )
 column=(type=char(15) updatewhereclause=yes name=cd_conveniado dbname="cd_conveniado" )
 column=(type=char(40) updatewhereclause=yes name=nm_conveniado dbname="nm_conveniado" )
 column=(type=char(20) updatewhereclause=yes name=cd_convenio_pbm dbname="cd_convenio_pbm" )
 column=(type=char(40) updatewhereclause=yes name=de_convenio_pbm dbname="de_convenio_pbm" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="cd_cliente" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="nm_cliente" )
 column=(type=char(40) updatewhereclause=yes name=nr_autorizacao dbname="nr_autorizacao" )
 column=(type=char(30) updatewhereclause=yes name=nr_autorizacao_datasus dbname="nr_autorizacao_datasus" )
 column=(type=char(6) updatewhereclause=yes name=nr_cupom dbname="nr_cupom" )
 column=(type=long updatewhereclause=yes name=nr_lote_convenio dbname="nr_lote_convenio" )
 column=(type=char(20) updatewhereclause=yes name=nr_cartao dbname="nr_cartao" )
 column=(type=char(1) updatewhereclause=yes name=id_status_sitef dbname="id_status_sitef" values="EFETUADA	E/CANCELADA	C/NEGADA	N/ESTORNADA	S/PENDENTE	P/AGUARDANDO HOST. CANCEL	A/" )
 column=(type=char(20) updatewhereclause=yes name=nr_comprovante_venda dbname="nr_comprovante_venda" )
 column=(type=long updatewhereclause=yes name=cd_convenio_venda dbname="cd_convenio_venda" )
 column=(type=char(14) updatewhereclause=yes name=filial_nr_cgc dbname="nr_cgc" )
 retrieve="  SELECT	n.cd_filial,   
			fi.nm_fantasia,
			n.nr_nf,   
			n.de_especie,   
			n.de_serie,
			n.id_tipo_venda,   
			n.dh_emissao,   
			n.dh_movimentacao_caixa,   
			n.cd_caixa,   
			n.nr_controle_caixa,   
			n.dh_cancelamento, 
			n.vl_bc_icms,   
			n.vl_icms,   
			n.pc_desconto,   
			n.vl_total_nf_bruto,  
			n.vl_total_produtos,   
			n.vl_bc_icms_st,    
			n.vl_icms_st,
			n.vl_total_nf, 
             n.vl_pago_avista, 
			n.id_tipo_venda,
			n.nr_matric_operador,
			uo.nm_usuario operador,
			n.nr_matricula_vendedor,
			uv.nm_usuario vendedor,
			n.cd_forma_pagamento,
			cv.cd_convenio,
			cv.nm_fantasia as nm_convenio,
			cva.cd_conveniado,
			cva.nm_conveniado,
			Case when vp.cd_convenio = 52575 then vp.nr_comprovante_venda else vp.cd_convenio_pbm end as cd_convenio_pbm,
			coalesce(coalesce(coalesce(eph.nm_convenio,fun.nm_conveniado),pg.nm_conveniado),'N$$HEX1$$c300$$ENDHEX$$O CADASTRADO') as de_convenio_pbm,
			n.cd_cliente,
			cli.nm_cliente,			
			vp.nr_autorizacao,
			vp.nr_autorizacao_datasus,
			vp.nr_cupom,
			vp.nr_lote_convenio,
			vp.nr_cartao,
			vp.id_status_sitef,
			vp.nr_comprovante_venda,
			n.cd_convenio as cd_convenio_venda,
			fi.nr_cgc
	FROM  venda_pbm vp (index pk_venda_pbm)
Inner Join nf_venda n   (index pk_nf_venda)
	On	n.cd_filial		= vp.cd_filial 		and 
		n.nr_nf			= vp.nr_nf 			and 
		n.de_especie 	= vp.de_especie 	and 
		n.de_serie		= vp.de_serie   
Inner Join usuario uo   (index pk_usuario)
	On uo.nr_matricula	= n.nr_matric_operador     
Inner Join usuario uv  (index pk_usuario)
	On	uv.nr_matricula		= n.nr_matricula_vendedor
Left Outer Join convenio cv  (index pk_convenio)
	On cv.cd_convenio 	= vp.cd_convenio 
Left Outer Join conveniado pg (index pk_conveniado)
	On	pg.cd_convenio = vp.cd_convenio	and 
		pg.cd_convenio_pbm = case when vp.cd_convenio = 52575 then vp.nr_comprovante_venda else vp.cd_convenio_pbm end
Left Outer Join convenio_epharma eph
	On eph.cd_convenio = cast((case when vp.cd_convenio = 52718 then vp.cd_convenio_pbm else null end) as integer)
Left Outer Join conveniado fun  (index pk_conveniado)
	On	fun.cd_convenio = vp.cd_convenio and 
		fun.cd_conveniado = (case when vp.cd_convenio = 52349 then vp.cd_convenio_pbm else null end)
Left Outer Join conveniado cva  (index pk_conveniado)
	On cva.cd_conveniado= n.cd_conveniado and
		cva.cd_convenio	= n.cd_convenio
Left Outer Join cliente cli (index pk_cliente)
	On cli.cd_cliente 		= n.cd_cliente
inner join filial fi
   on fi.cd_filial = n.cd_filial
WHERE vp.cd_filial		= :cd_filial 
	and vp.nr_nf		= :nr_nf 
	and vp.de_especie	= :de_especie 
	and vp.de_serie	= :de_serie   
	and vp.nr_sequencial_pbm = :nr_sequencial_pbm" arguments=(("cd_filial", number),("nr_nf", number),("de_especie", string),("de_serie", string),("nr_sequencial_pbm", number)) )
