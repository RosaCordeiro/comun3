table(column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="nm_fantasia" )
 column=(type=long update=yes updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=char(2) updatewhereclause=yes name=nf_venda_id_tipo_venda dbname="id_tipo_venda" values="$$HEX1$$c000$$ENDHEX$$ VISTA	AV/CREDI$$HEX1$$c100$$ENDHEX$$RIO	CR/CONTA CORRENTE	CC/CONV$$HEX1$$ca00$$ENDHEX$$NIO	CV/" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="cd_caixa" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="nr_controle_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="dh_cancelamento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms dbname="vl_bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="vl_icms" )
