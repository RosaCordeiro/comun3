table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=cd_convenio_venda dbname="cd_convenio_venda" )
 column=(type=char(40) updatewhereclause=yes name=nr_autorizacao dbname="nr_autorizacao" )
 column=(type=char(20) updatewhereclause=yes name=nr_comprovante_venda dbname="nr_comprovante_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pago_avista dbname="vl_pago_avista" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=long updatewhereclause=yes name=nr_lote_convenio dbname="nr_lote_convenio" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="cd_convenio" )
 column=(type=char(60) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="dh_cancelamento" )
 column=(type=char(60) updatewhereclause=yes name=cd_convenio_pbm dbname="cd_convenio_pbm" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_prev_pagto dbname="vl_prev_pagto" )
 column=(type=datetime updatewhereclause=yes name=dh_pagamento dbname="dh_pagamento" )
 column=(type=char(1) updatewhereclause=yes name=id_conciliada dbname="id_conciliada" values="	S/	N" )
 column=(type=char(30) updatewhereclause=yes name=nr_autorizacao_datasus dbname="nr_autorizacao_datasus" )
 column=(type=char(1) updatewhereclause=yes name=id_status_sitef dbname="id_status_sitef" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pagto dbname="vl_pagto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_subsidio dbname="vl_subsidio" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_taxa_administracao dbname="vl_taxa_administracao" )
 column=(type=long updatewhereclause=yes name=nr_sequencial_pbm dbname="nr_sequencial_pbm" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pago_avista_pbm dbname="vl_pago_avista_pbm" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_pbm dbname="vl_total_pbm" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_prev_pagto_pbm dbname="vl_prev_pagto_pbm" )
 column=(type=long updatewhereclause=yes name=qt_pbms dbname="qt_pbms" )
 retrieve="SELECT	nf.cd_filial,   
		nf.nr_nf,   
		nf.de_especie,   
		nf.de_serie,   
		nf.dh_movimentacao_caixa,   
		nf.cd_convenio as cd_convenio_venda,   
		vp.nr_autorizacao,
		vp.nr_comprovante_venda,
		nf.pc_desconto,     
		/* Vendas com apenas 1 PBM faz da forma antiga */
		CASE WHEN (select count(distinct vpc.nr_sequencial_pbm) from venda_pbm vpc where vpc.cd_filial = nf.cd_filial	and vpc.nr_nf = nf.nr_nf and vpc.de_especie = nf.de_especie	and vpc.de_serie = nf.de_serie) = 1
			THEN 
				CASE WHEN nf.id_tipo_venda = 'AV' 
					THEN nf.vl_total_nf /* Venda $$HEX1$$e000$$ENDHEX$$ vista deve mostrar o total da venda no $$HEX1$$e000$$ENDHEX$$ vista */ 
					ELSE nf.vl_pago_avista
				END
			ELSE /* M$$HEX1$$fa00$$ENDHEX$$ltiplos PBMS */
				CASE when nf.id_tipo_venda = 'AV' 
					THEN sum(inf.vl_preco_praticado*vpp.qt_vendida)
					ELSE /* A prazo */
						Case When nf.cd_convenio = vp.cd_convenio
							THEN nf.vl_pago_avista /* Para o conv$$HEX1$$ea00$$ENDHEX$$nio da venda, mostrar o pago a vista da nota */
							ELSE /* PBM de desconto mostra o valor total do PBM como pago a vista */
								sum(vpp.vl_praticado*vpp.qt_vendida)
						End
				END
		END AS vl_pago_avista,
		/* Vendas com apenas 1 PBM faz da forma antiga */
		CASE WHEN (select count(distinct vpc.nr_sequencial_pbm) from venda_pbm vpc where vpc.cd_filial = nf.cd_filial	and vpc.nr_nf = nf.nr_nf and vpc.de_especie = nf.de_especie	and vpc.de_serie = nf.de_serie) = 1
			THEN nf.vl_total_nf
			ELSE /* M$$HEX1$$fa00$$ENDHEX$$ltiplos PBMS */ 
				Case When nf.cd_convenio = vp.cd_convenio
					THEN nf.vl_total_nf /* Para o conv$$HEX1$$ea00$$ENDHEX$$nio da venda, mostra o total da nota, como sempre fez */
					ELSE /* PBM de desconto vai somar valores do PBM */
						CASE when nf.id_tipo_venda = 'AV' 
							THEN sum(inf.vl_preco_praticado*vpp.qt_vendida)
							ELSE sum(vpp.vl_praticado*vpp.qt_vendida)
						END
				END
		END AS vl_total_nf,
		coalesce(nf.nr_lote_convenio,0) nr_lote_convenio,
		cv.cd_convenio,
		cv.nm_fantasia,   
		nf.dh_cancelamento,   
		case when vp.cd_convenio = 52718 then ceb.nm_cliente else coalesce(coalesce(fun.nm_conveniado,pg.nm_conveniado),
		case when vp.cd_convenio in (52575,53725,53724) then vp.nr_comprovante_venda else vp.cd_convenio_pbm end) end as cd_convenio_pbm,
		/* Vendas com apenas 1 PBM faz da forma antiga */
		CASE WHEN (select count(distinct vpc.nr_sequencial_pbm) from venda_pbm vpc where vpc.cd_filial = nf.cd_filial	and vpc.nr_nf = nf.nr_nf and vpc.de_especie = nf.de_especie	and vpc.de_serie = nf.de_serie) = 1
			THEN 
				CASE WHEN nf.id_tipo_venda = 'AV' 
					THEN 0 /* Venda $$HEX1$$e000$$ENDHEX$$ vista n$$HEX1$$e300$$ENDHEX$$o deve mostrar valor previsto */
					ELSE nf.vl_total_nf - nf.vl_pago_avista
				END
			ELSE /* M$$HEX1$$fa00$$ENDHEX$$ltiplos PBMS */
				CASE WHEN nf.id_tipo_venda = 'AV' 
					THEN 0 /* Venda $$HEX1$$e000$$ENDHEX$$ vista n$$HEX1$$e300$$ENDHEX$$o deve mostrar valor previsto */
					ELSE 
						CASE When nf.cd_convenio = vp.cd_convenio /* Valor previsto apenas para o conv$$HEX1$$ea00$$ENDHEX$$nio da venda */
							THEN sum(vpp.vl_praticado*vpp.qt_vendida) - sum(case when vpp.vl_pago_avista = (vpp.vl_praticado*vpp.qt_vendida) and vpp.qt_vendida > 1
																								then vpp.vl_pago_avista	
																								else vpp.vl_pago_avista*vpp.qt_vendida -- (como j$$HEX1$$e100$$ENDHEX$$ fazia) /* Voltar a deixar desta forma ap$$HEX1$$f300$$ENDHEX$$s chamado 1728045 */ 
																							end)
							ELSE 0 /* PBM de desconto n$$HEX1$$e300$$ENDHEX$$o mostra valor previsto */
						END
				END
		END AS vl_prev_pagto,
		max(cpp.dh_pagamento) as dh_pagamento, 
		vp.id_conciliada,
		vp.nr_autorizacao_datasus,
		coalesce(vp.id_status_sitef, '') as id_status_sitef,
		sum(cpp.vl_total_reembolso)  as vl_pagto,
		sum(cpp.qt_vendida * cpp.vl_subsidio)  as vl_subsidio,
		sum(cpp.vl_taxa_administracao) as vl_taxa_administracao,
		vp.nr_sequencial_pbm,
		CASE when nf.id_tipo_venda = 'AV' 
			THEN sum(inf.vl_preco_praticado*vpp.qt_vendida)
			ELSE /* Para o conv$$HEX1$$ea00$$ENDHEX$$nio da venda, pegar o A vista do PBM */
				Case When nf.cd_convenio = vp.cd_convenio
						THEN sum(case when vpp.vl_pago_avista = (vpp.vl_praticado*vpp.qt_vendida) and vpp.qt_vendida > 1 /* n$$HEX1$$e300$$ENDHEX$$o multiplica se j$$HEX1$$e100$$ENDHEX$$ estiver multiplicado */
									then vpp.vl_pago_avista	
									else vpp.vl_pago_avista*vpp.qt_vendida -- (como j$$HEX1$$e100$$ENDHEX$$ fazia) /* Voltar a deixar desta forma ap$$HEX1$$f300$$ENDHEX$$s chamado 1728045 */ 
								end)
						When nf.cd_convenio = 53847 /*Devolucao de PBM venda CV muda o conv$$HEX1$$ea00$$ENDHEX$$nio da nota de venda*/
						THEN sum(case when vpp.vl_pago_avista = (vpp.vl_praticado*vpp.qt_vendida) and vpp.qt_vendida > 1 
									then vpp.vl_pago_avista	
									else vpp.vl_pago_avista*vpp.qt_vendida 
								end) 
					ELSE sum(vpp.vl_praticado*vpp.qt_vendida) /* PBM de desconto apresentar o valor total como pago a vistad */
				END
		END vl_pago_avista_pbm,
		CASE when nf.id_tipo_venda = 'AV' 
			THEN sum(inf.vl_preco_praticado*vpp.qt_vendida)
			ELSE sum(vpp.vl_praticado*vpp.qt_vendida)
		END vl_total_pbm,
		CASE WHEN nf.id_tipo_venda = 'AV' 
			THEN 0 /* Venda $$HEX1$$e000$$ENDHEX$$ vista n$$HEX1$$e300$$ENDHEX$$o deve mostrar valor previsto */
			ELSE 
				CASE When nf.cd_convenio = vp.cd_convenio /* Valor previsto apenas para o conv$$HEX1$$ea00$$ENDHEX$$nio da venda */
					THEN sum(vpp.vl_praticado*vpp.qt_vendida) - sum(case when vpp.vl_pago_avista = (vpp.vl_praticado*vpp.qt_vendida) and vpp.qt_vendida > 1
																						then vpp.vl_pago_avista	
																						else vpp.vl_pago_avista*vpp.qt_vendida -- (como j$$HEX1$$e100$$ENDHEX$$ fazia) /* Voltar a deixar desta forma ap$$HEX1$$f300$$ENDHEX$$s chamado 1728045 */ 
																					end)
					ELSE 0 /* PBM de desconto n$$HEX1$$e300$$ENDHEX$$o mostra valor previsto */
				END
		END as vl_prev_pagto_pbm,
		(select count(distinct vpc.nr_sequencial_pbm) from venda_pbm vpc where vpc.cd_filial = nf.cd_filial	and vpc.nr_nf = nf.nr_nf and vpc.de_especie = nf.de_especie	and vpc.de_serie = nf.de_serie) as qt_pbms
FROM venda_pbm vp (index idx_fil_dt_conv)
inner join  venda_pbm_produto vpp (index PK_VENDA_PBM_PRODUTO)
	on 	vpp.cd_filial 		= vp.cd_filial 
	and 	vpp.nr_nf 		= vp.nr_nf 
	and	vpp.de_especie	= vp.de_especie 
	and	vpp.de_serie 	= vp.de_serie
	and 	vpp.nr_sequencial_pbm = vp.nr_sequencial_pbm
INNER JOIN nf_venda nf (index pk_nf_venda)
	on 	nf.cd_filial 		= vp.cd_filial+0
	and 	nf.nr_nf 			= vp.nr_nf+0
	and	nf.de_especie 	= vp.de_especie 
	and	nf.de_serie 		= vp.de_serie 
inner join  item_nf_venda inf (index pk_item_nf_venda)
	on 	inf.cd_filial 		= vpp.cd_filial 
	and inf.nr_nf 		= vpp.nr_nf 
	and	inf.de_especie	= vpp.de_especie 
	and	inf.de_serie 	= vpp.de_serie
	and inf.nr_sequencial = vpp.nr_sequencial
INNER JOIN convenio cv (index pk_convenio)
	on cv.cd_convenio 	= vp.cd_convenio 
left outer join conveniado pg (index idx_convenio_pbm)
	on pg.cd_convenio = vp.cd_convenio
	and pg.cd_convenio_pbm = case when vp.cd_convenio in (52575,53725,53724) then vp.nr_comprovante_venda else vp.cd_convenio_pbm end
left outer join conveniado fun (index pk_conveniado)
	on fun.cd_convenio = vp.cd_convenio
	and fun.cd_conveniado = (case when vp.cd_convenio = 52349 then vp.cd_convenio_pbm else null end)
left outer join conciliacao_pbm_produto cpp (index idx_conciliacao_pbm_produt_ak1)
	on	cpp.cd_filial_venda = vpp.cd_filial 			and
		cpp.nr_nf_venda = vpp.nr_nf 				and
		cpp.de_especie_venda = vp.de_especie 	and
		cpp.de_serie_venda = vpp.de_serie 		and
		cpp.cd_produto = vpp.cd_produto			and
		cpp.cd_convenio_pbm = vp.cd_convenio
left outer join convenio_epharma_beneficio ceb
  on ceb.cd_convenio_epharma = cpp.cd_convenio_epharma
	and ceb.cd_cliente      			= cpp.cd_cliente
	and ceb.cd_beneficio 				= cpp.cd_beneficio
WHERE vp.dh_venda between :dt_inicio and :dt_fim
    and nf.nr_nf_anexa is null
GROUP by 	nf.cd_filial,   
				nf.nr_nf,   
				nf.de_especie,   
				nf.de_serie,   
				nf.dh_movimentacao_caixa,   
				nf.cd_convenio,   
		  	     vp.nr_autorizacao,
				vp.nr_comprovante_venda,
				nf.pc_desconto,     
				nf.vl_pago_avista,   
				nf.vl_total_nf,
				coalesce(nf.nr_lote_convenio,0),
				cv.cd_convenio,
				cv.nm_fantasia,   
				nf.dh_cancelamento,   
				case when vp.cd_convenio = 52718 then ceb.nm_cliente else coalesce(coalesce(fun.nm_conveniado,pg.nm_conveniado),
				case when vp.cd_convenio in (52575,53725,53724) then vp.nr_comprovante_venda else vp.cd_convenio_pbm end) end,
				vp.id_conciliada,
				vp.nr_autorizacao_datasus,
				coalesce(vp.id_status_sitef, ''),
				nf.id_tipo_venda,
				vp.nr_sequencial_pbm,
				vp.cd_convenio" arguments=(("dt_inicio", date),("dt_fim", date))  sort="dh_movimentacao_caixa A cd_filial A " )
