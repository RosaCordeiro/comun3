table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_devolucao_venda.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_devolucao_venda.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_devolucao_venda.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_devolucao_venda.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_recebimento dbname="nf_devolucao_venda.dh_recebimento" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_devolucao_venda.dh_movimentacao_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="nf_devolucao_venda.dh_cancelamento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_devolucao_venda.vl_total_nf" )
 column=(type=char(40) updatewhereclause=yes name=de_caixa dbname="caixa.de_caixa" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="nf_devolucao_venda.nr_controle_caixa" )
 column=(type=char(40) updatewhereclause=yes name=nm_operador dbname="usuario.nm_operador" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_operador dbname="nf_devolucao_venda.nr_matricula_operador" )
 retrieve="select n.cd_filial, n.nr_nf, n.de_especie, n.de_serie, n.dh_recebimento, n.dh_movimentacao_caixa, n.dh_cancelamento, n.vl_total_nf, c.de_caixa, n.nr_controle_caixa, op.nm_usuario as nm_operador, n.nr_matricula_operador
from nf_devolucao_venda n
left outer join caixa c
	on c.cd_caixa = n.cd_caixa
left outer join usuario op
	on op.nr_matricula = n.nr_matricula_operador
where n.cd_filial_venda		= :filial
	and n.nr_nf_venda			= :nf
	and n.de_especie_venda	= :especie
	and n.de_serie_venda	= :serie" arguments=(("filial", number),("nf", number),("especie", string),("serie", string)) )
