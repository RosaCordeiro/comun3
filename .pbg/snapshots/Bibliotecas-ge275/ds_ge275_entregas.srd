table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_ecommerce.cd_filial" dbalias="p.cd_filial" )
 column=(type=char(30) updatewhereclause=yes name=nm_transportadora dbname="pedido_ecommerce.nm_transportadora" dbalias="p.nm_transportadora" )
 column=(type=long updatewhereclause=yes name=qt_registro dbname="qt_registro" )
 retrieve="Select p.cd_filial, p.nm_transportadora, count(p.nr_pedido) as qt_registro

	From pedido_ecommerce p
		Inner join nf_venda n
			on Coalesce(n.cd_filial_ecommerce, 809) 	= p.cd_filial_ecommerce
		and n.nr_pedido_ecommerce 							= p.nr_pedido
		and n.cd_filial										= p.cd_filial

	Where p.cd_filial_ecommerce = :filial_ecommerce
	  and p.dh_inclusao 	> :inicio and p.dh_inclusao < :termino
	  and not exists (select * from nf_devolucao_venda d
					  where n.cd_filial		= d.cd_filial_venda
					    and n.nr_nf			= d.nr_nf_venda
					    and n.de_especie		= d.de_especie_venda
					    and n.de_serie		= d.de_serie_venda)
	
		group by p.cd_filial, p.nm_transportadora
	order by 1, 2" arguments=(("inicio", date),("termino", date),("filial_ecommerce", number)) )
