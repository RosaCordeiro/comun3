table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_ecommerce.cd_filial" dbalias="p.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=qt_retirada_loja dbname="qt_retirada_loja" )
 column=(type=long updatewhereclause=yes name=qt_total_express dbname="qt_total_express" )
 column=(type=long updatewhereclause=yes name=qt_pac dbname="qt_pac" )
 column=(type=long updatewhereclause=yes name=qt_sedex dbname="qt_sedex" )
 retrieve="  SELECT distinct p.cd_filial,   
         f.nm_fantasia,
		0 as qt_retirada_loja,
		 0 as qt_total_express,
		 0 as qt_pac,
		 0 as qt_sedex
    FROM pedido_ecommerce p
	INNER JOIN nf_venda n
		 ON Coalesce(n.cd_filial_ecommerce, 809) 		= p.cd_filial_ecommerce
      AND n.nr_pedido_ecommerce 						= p.nr_pedido

	INNER JOIN filial f
		ON f.cd_filial	= p.cd_filial

   WHERE p.cd_filial_ecommerce = :filial_ecommerce
	and p.id_situacao not in ('A', 'X')
     and not exists (select * from nf_devolucao_venda d
					 where n.cd_filial		= d.cd_filial_venda
					   and n.nr_nf				= d.nr_nf_venda
					   and n.de_especie		= d.de_especie_venda
					   and n.de_serie			= d.de_serie_venda)" arguments=(("filial_ecommerce", number))  sort="nm_fantasia A " )
