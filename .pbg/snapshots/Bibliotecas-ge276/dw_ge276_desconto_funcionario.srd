table(column=(type=char(6) updatewhereclause=yes name=nr_matricula dbname="nr_matricula" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="nm_usuario" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf_bruto dbname="vl_total_nf_bruto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf_tabela dbname="vl_total_nf_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_geral dbname="vl_desconto_geral" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_filial dbname="vl_desconto_filial" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_desconto_pve dbname="vl_desconto_pve" )
 column=(type=decimal(28) updatewhereclause=yes name=pc_desconto_filial dbname="pc_desconto_filial" )
 column=(type=long updatewhereclause=yes name=qtde dbname="qtde" )
 retrieve="select 	u.nr_matricula,
			u.nm_usuario,
			nf.cd_filial,
			sum(nf.vl_total_nf) as vl_total_nf, 
			sum(nf.vl_total_nf_bruto) as vl_total_nf_bruto, 
			sum(nf.vl_total_nf_tabela) as vl_total_nf_tabela, 
			sum(nf.vl_total_nf_bruto - nf.vl_total_nf) as vl_desconto_geral, 
			sum(nf.vl_total_nf_tabela - nf.vl_total_nf) as vl_desconto_filial,
			sum(coalesce((select sum(i1.qt_vendida * Round((i1.vl_preco_unitario * (id1.pc_desconto / 100)),2)) as vl_desconto
					from item_nf_venda_desconto id1 (index pk_item_nf_venda_desconto)
					inner join item_nf_venda i1 (index pk_item_nf_venda)
						on 	id1.cd_filial = i1.cd_filial
						and 	id1.nr_nf = i1.nr_nf
						and 	id1.de_especie = i1.de_especie
						and 	id1.de_serie = i1.de_serie
						and 	id1.cd_produto = i1.cd_produto
						and 	id1.nr_sequencial = i1.nr_sequencial
					Where id1.id_tipo_desconto = 'PVE'
						And 	i1.cd_filial = nf.cd_filial
						and 	i1.nr_nf = nf.nr_nf
						and 	i1.de_especie = nf.de_especie
						and 	i1.de_serie = nf.de_serie),0)) as vl_desconto_pve,
			Round((sum(nf.vl_total_nf_tabela - nf.vl_total_nf) / sum(nf.vl_total_nf_bruto)),4) *100 as pc_desconto_filial,
			count(nf.nr_nf) as qtde
from nf_venda nf (index idx_data_filial)
left outer join usuario u (index pk_usuario)
	on u.nr_matricula = nf.nr_matric_alteracao_preco
/*left outer join (select id1.cd_filial, id1.nr_nf, id1.de_especie,id1.de_serie, sum(i1.qt_vendida * Round((i1.vl_preco_unitario * (id1.pc_desconto / 100)),2)) as vl_desconto
					from item_nf_venda_desconto id1 (index pk_item_nf_venda_desconto)
					inner join item_nf_venda i1 (index pk_item_nf_venda)
						on 	id1.cd_filial = i1.cd_filial
						and 	id1.nr_nf = i1.nr_nf
						and 	id1.de_especie = i1.de_especie
						and 	id1.de_serie = i1.de_serie
						and 	id1.cd_produto = i1.cd_produto
					Where id1.id_tipo_desconto = 'PVE'
					Group By id1.cd_filial, id1.nr_nf, id1.de_especie,id1.de_serie) infd
	on infd.cd_filial = nf.cd_filial
	and infd.nr_nf = nf.nr_nf
	and infd.de_especie = nf.de_especie
	and infd.de_serie = nf.de_serie*/
where nf.cd_filial = :cd_filial
and nf.dh_movimentacao_caixa between :dt_inicio and :dt_fim
and nf.dh_cancelamento is null
and nf.nr_nf_anexa is null
and nf.vl_total_nf_tabela > nf.vl_total_nf
group by u.nr_matricula,
			u.nm_usuario,
			nf.cd_filial" arguments=(("dt_inicio", date),("dt_fim", date),("cd_filial", number))  sort="pc_desconto_filial D " )
