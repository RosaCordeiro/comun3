table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_venda dbname="id_tipo_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf_bruto dbname="vl_total_nf_bruto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf_tabela dbname="vl_total_nf_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_geral dbname="vl_desconto_geral" )
 column=(type=decimal(12) updatewhereclause=yes name=pc_desconto_geral dbname="pc_desconto_geral" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_filial dbname="vl_desconto_filial" )
 column=(type=decimal(12) updatewhereclause=yes name=pc_desconto_filial dbname="pc_desconto_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="nm_usuario" )
 retrieve="select 	nf.cd_filial,
			nf.nr_nf, 
			nf.dh_emissao, 
			nf.id_tipo_venda,
			nf.vl_total_nf, 
			nf.vl_total_nf_bruto, 
			nf.vl_total_nf_tabela, 
			nf.vl_total_nf_bruto - nf.vl_total_nf as vl_desconto_geral, 
			Round(((nf.vl_total_nf_bruto - nf.vl_total_nf) / nf.vl_total_nf_bruto) *100 ,2)as pc_desconto_geral,
			nf.vl_total_nf_tabela - nf.vl_total_nf as vl_desconto_filial,
			Round(((nf.vl_total_nf_tabela - nf.vl_total_nf) / nf.vl_total_nf_bruto) *100,2) as pc_desconto_filial,
			u.nm_usuario
from nf_venda nf (index idx_data_filial)
left outer join usuario u (index pk_usuario)
	on u.nr_matricula = nf.nr_matric_operador
where nf.cd_filial = :cd_filial
and nf.dh_movimentacao_caixa between :dt_inicio and :dt_fim
and nf.nr_matric_alteracao_preco = :nr_matricula
and nf.dh_cancelamento is null
and nf.nr_nf_anexa is null
and nf.vl_total_nf_tabela > nf.vl_total_nf" arguments=(("dt_inicio", date),("dt_fim", date),("cd_filial", number),("nr_matricula", string))  sort="pc_desconto_filial D " )
