table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_venda.cd_produto" dbalias="inf.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bruto dbname="vl_bruto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_liquido dbname="vl_liquido" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="item_nf_venda.qt_vendida" dbalias="inf.qt_vendida" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_tabela dbname="item_nf_venda.pc_desconto_tabela" dbalias="inf.pc_desconto_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_maior_desconto dbname="pc_maior_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_geral dbname="vl_desconto_geral" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_desconto_pve dbname="vl_desconto_pve" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_pve dbname="pc_desconto_pve" )
 retrieve="select 	nf.cd_filial,
			nf.nr_nf, 
			inf.cd_produto,
			p.de_produto ||  ' - ' || p.de_apresentacao_estoque as de_produto,
			(inf.qt_vendida * inf.vl_preco_unitario) as vl_bruto,
			inf.qt_vendida * inf.vl_preco_praticado as vl_liquido,
			inf.qt_vendida,
			inf.pc_desconto_tabela, 
			case when (coalesce(psp.pc_desconto,0 ) > coalesce(psc.pc_desconto_clube,0)) and (coalesce(psp.pc_desconto,0 ) > coalesce(rcc.pc_desconto,0)) and (coalesce(psp.pc_desconto,0 ) > coalesce(rcc.pc_desconto_minimo,0)) then coalesce(psp.pc_desconto,0 )
				   when (coalesce(psc.pc_desconto_clube,0) > coalesce(psp.pc_desconto,0 )) and (coalesce(psc.pc_desconto_clube,0) > coalesce(rcc.pc_desconto,0)) and (coalesce(psc.pc_desconto_clube,0) > coalesce(rcc.pc_desconto_minimo,0)) then coalesce(psc.pc_desconto_clube,0)
				   when (coalesce(rcc.pc_desconto,0) > coalesce(psp.pc_desconto,0 )) and (coalesce(rcc.pc_desconto,0) > coalesce(psc.pc_desconto_clube,0)) and (coalesce(rcc.pc_desconto,0) > coalesce(rcc.pc_desconto_minimo,0)) then coalesce(rcc.pc_desconto,0)
				   when (coalesce(rcc.pc_desconto_minimo,0) > coalesce(psp.pc_desconto,0 )) and (coalesce(rcc.pc_desconto_minimo,0) > coalesce(psc.pc_desconto_clube,0)) and (coalesce(rcc.pc_desconto_minimo,0) > coalesce(rcc.pc_desconto,0)) then coalesce(rcc.pc_desconto_minimo,0)
			else 0.00 end as pc_maior_desconto,
			inf.qt_vendida * (inf.vl_preco_unitario - inf.vl_preco_praticado) as vl_desconto_geral,
			(inf.qt_vendida * Round((inf.vl_preco_unitario * (infd.pc_desconto / 100)),2)) as vl_desconto_pve,
			infd.pc_desconto as pc_desconto_pve
from nf_venda nf (index pk_nf_venda)
inner join item_nf_venda inf
	on inf.cd_filial = nf.cd_filial
	and inf.nr_nf = nf.nr_nf
	and inf.de_serie = nf.de_serie
	and inf.de_especie = nf.de_especie
inner join produto_geral p
	on p.cd_produto = inf.cd_produto
left outer join usuario u
	on u.nr_matricula = nf.nr_matric_alteracao_preco
left outer join promocao_sos_produto psp
	on psp.cd_promocao_sos = inf.cd_promocao_sos
	and psp.cd_produto = inf.cd_produto
left outer join (	select psp1.cd_produto, psf1.cd_filial, ps1.dh_inicio, coalesce(ps1.dh_termino,GetDate()) as dh_termino, psp1.pc_desconto_clube
						from promocao_sos ps1
						inner join promocao_sos_filial psf1
							on psf1.cd_promocao_sos = ps1.cd_promocao_sos
						inner join promocao_sos_produto psp1
							on psp1.cd_promocao_sos = ps1.cd_promocao_sos
						Where ps1.id_tipo_promocao = 'N'
							AND psp1.pc_desconto_clube > 0) psc
	on psc.cd_filial = nf.cd_filial
	and psc.cd_produto = inf.cd_produto
	and psc.dh_inicio <= nf.dh_movimentacao_caixa
	and psc.dh_termino >= nf.dh_movimentacao_caixa
	and inf.pc_desconto_tabela > 0
	and inf.cd_promocao_sos is null
left outer join relacao_condicao_convenio rcc
	on rcc.cd_condicao_convenio = nf.cd_condicao_convenio
	and rcc.cd_convenio = nf.cd_convenio
left outer join item_nf_venda_desconto infd (index pk_item_nf_venda_desconto)
	on   infd.cd_filial = inf.cd_filial
	and infd.nr_nf = inf.nr_nf
	and infd.de_especie = inf.de_especie
	and infd.de_serie = inf.de_serie
	and infd.cd_produto = inf.cd_produto
	and infd.nr_sequencial = inf.nr_sequencial
	and infd.id_tipo_desconto = 'PVE'
where nf.cd_filial = :cd_filial
and nf.nr_nf = :nr_nf
and nf.de_serie = :de_serie
and nf.de_especie = :de_especie
and nf.dh_cancelamento is null
and nf.nr_nf_anexa is null
and nf.vl_total_nf_tabela > nf.vl_total_nf" arguments=(("cd_filial", number),("nr_nf", number),("de_serie", string),("de_especie", string))  sort="pc_desc_filial D " )
