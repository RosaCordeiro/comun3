table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_bruta dbname="vl_venda_bruta" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_liquida dbname="vl_venda_liquida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_tabela dbname="vl_venda_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_geral dbname="vl_desconto_geral" )
 column=(type=decimal(28) updatewhereclause=yes name=pc_desconto_geral dbname="pc_desconto_geral" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_filial dbname="vl_desconto_filial" )
 column=(type=decimal(28) updatewhereclause=yes name=pc_desconto_filial dbname="pc_desconto_filial" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_venda dbname="qt_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_desc_geral dbname="qt_desc_geral" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_desc_filial dbname="qt_desc_filial" )
 column=(type=decimal(28) updatewhereclause=yes name=pc_qt_geral dbname="pc_qt_geral" )
 column=(type=decimal(28) updatewhereclause=yes name=pc_qt_filial dbname="pc_qt_filial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_pve dbname="vl_desconto_pve" )
 retrieve="  select 	f.cd_filial,
			f.nm_fantasia,			
       		sum(r.vl_venda_bruta) as vl_venda_bruta,
			sum(r.vl_venda_avista+r.vl_venda_crediario+r.vl_venda_convenio+r.vl_venda_conta_corrente-r.vl_devolucao_venda+r.vl_venda_cartao_credito+r.vl_venda_cartao_debito+r.vl_venda_cheque_avista+r.vl_venda_cheque_aprazo) as vl_venda_liquida,
			sum(r.vl_venda_tabela) as vl_venda_tabela,
			sum(r.vl_venda_bruta - r.vl_devolucao_venda - (r.vl_venda_avista+r.vl_venda_crediario+r.vl_venda_convenio+r.vl_venda_conta_corrente-r.vl_devolucao_venda+r.vl_venda_cartao_credito+r.vl_venda_cartao_debito+r.vl_venda_cheque_avista+r.vl_venda_cheque_aprazo)) as vl_desconto_geral,
			round(sum(r.vl_venda_bruta - r.vl_devolucao_venda - (r.vl_venda_avista+r.vl_venda_crediario+r.vl_venda_convenio+r.vl_venda_conta_corrente-r.vl_devolucao_venda+r.vl_venda_cartao_credito+r.vl_venda_cartao_debito+r.vl_venda_cheque_avista+r.vl_venda_cheque_aprazo)) / sum(r.vl_venda_bruta),4) * 100 as pc_desconto_geral,
			sum(r.vl_venda_tabela - r.vl_devolucao_venda - (r.vl_venda_avista+r.vl_venda_crediario+r.vl_venda_convenio+r.vl_venda_conta_corrente-r.vl_devolucao_venda+r.vl_venda_cartao_credito+r.vl_venda_cartao_debito+r.vl_venda_cheque_avista+r.vl_venda_cheque_aprazo)) as vl_desconto_filial,
			round(sum(r.vl_venda_tabela - r.vl_devolucao_venda - (r.vl_venda_avista+r.vl_venda_crediario+r.vl_venda_convenio+r.vl_venda_conta_corrente-r.vl_devolucao_venda+r.vl_venda_cartao_credito+r.vl_venda_cartao_debito+r.vl_venda_cheque_avista+r.vl_venda_cheque_aprazo)) / sum(r.vl_venda_bruta),4) * 100 as pc_desconto_filial,
			sum(qt.qt_venda) as qt_venda,
			sum(qt.qt_desc_geral) as qt_desc_geral,
			sum(qt.qt_desc_comercial) as qt_desc_filial,
			Round((sum(qt.qt_desc_geral) / sum(qt.qt_venda)),4) * 100 as pc_qt_geral,
			Round((sum(qt.qt_desc_comercial) / sum(qt.qt_venda)),4) * 100 as pc_qt_filial,
			sum(0.00) as vl_desconto_pve
from resumo_movimento_estoque r (index pk_resumo_movto_estoque)
inner join filial f (index pk_filial)
	on f.cd_filial = r.cd_filial
left outer join (select 	nf1.cd_filial, 
							nf1.dh_movimentacao_caixa,
							cast(count(*) as numeric(18,2)) as qt_venda, 
							cast(sum(case when (nf1.vl_total_nf_bruto > nf1.vl_total_nf) then 1 else 0 end)  as numeric(18,2)) as qt_desc_geral,
							cast(sum(case when (nf1.vl_total_nf_tabela > nf1.vl_total_nf) then 1 else 0 end) as numeric(18,2)) as qt_desc_comercial
					from nf_venda nf1 (index idx_data_filial)
					inner join filial f1
						on f1.cd_filial = nf1.cd_filial
					where nf1.dh_movimentacao_caixa between :dt_inicio and :dt_fim
					and nf1.dh_cancelamento is null
					and nf1.nr_nf_anexa is null
					and nf1.cd_filial > 0
					group by nf1.cd_filial,nf1.dh_movimentacao_caixa) qt
	on qt.cd_filial = r.cd_filial
	and qt.dh_movimentacao_caixa = r.dh_resumo
where r.dh_resumo between :dt_inicio and :dt_fim
	and r.cd_filial <> 534
	and r.vl_venda_tabela > 0 
group by f.cd_filial,
			f.nm_fantasia
having sum(r.vl_venda_tabela - r.vl_devolucao_venda - (r.vl_venda_avista+r.vl_venda_crediario+r.vl_venda_convenio+r.vl_venda_conta_corrente-r.vl_devolucao_venda+r.vl_venda_cartao_credito+r.vl_venda_cartao_debito+r.vl_venda_cheque_avista+r.vl_venda_cheque_aprazo)) > 0" arguments=(("dt_inicio", date),("dt_fim", date))  sort="pc_desconto_filial D " )
