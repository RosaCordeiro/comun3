table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_desconto dbname="vl_desconto" )
 retrieve="select id.cd_filial, id.nr_nf, id.de_especie, id.de_serie, sum(i.qt_vendida * Round((i.vl_preco_unitario * (id.pc_desconto / 100)),2)) as vl_desconto
from item_nf_venda_desconto id (index pk_item_nf_venda_desconto)
inner join item_nf_venda i (index pk_item_nf_venda)
	on 	i.cd_filial = id.cd_filial
	and 	i.nr_nf = id.nr_nf
	and 	i.de_especie = id.de_especie
	and 	i.de_serie = id.de_serie 
	and 	i.cd_produto = id.cd_produto
	and 	i.nr_sequencial = id.nr_sequencial
Where id.id_tipo_desconto = 'PVE'
	and id.cd_filial = :cd_filial
	and id.nr_nf = :nr_nf
	and id.de_especie = :de_especie
	and id.de_serie = :de_serie 
Group By id.cd_filial, id.nr_nf, id.de_especie,id.de_serie
" arguments=(("cd_filial", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
