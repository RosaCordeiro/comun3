table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_venda.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_venda.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_venda.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_venda.de_serie" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_venda dbname="nf_venda.id_tipo_venda" values="CONV$$HEX1$$ca00$$ENDHEX$$NIO	CV/CONTA CORRENTE	CC/$$HEX1$$c000$$ENDHEX$$ VISTA	AV/CREDI$$HEX1$$c100$$ENDHEX$$RIO	CR/" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_venda.dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf_bruto dbname="nf_venda.vl_total_nf_bruto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_produtos dbname="nf_venda.vl_total_produtos" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf_tabela dbname="nf_venda.vl_total_nf_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_venda.vl_total_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="nf_venda.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_tabela dbname="vl_desconto_tabela" )
 column=(type=decimal(25) updatewhereclause=yes name=pc_desc_tabela dbname="pc_desc_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_filial dbname="vl_desconto_filial" )
 column=(type=decimal(12) updatewhereclause=yes name=pc_desc_filial dbname="pc_desc_filial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desc_geral dbname="vl_desc_geral" )
 column=(type=decimal(12) updatewhereclause=yes name=pc_desc_geral dbname="pc_desc_geral" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_alteracao dbname="usuario.nr_matric_alteracao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_alteracao dbname="usuario.nm_usuario_alteracao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_operador dbname="usuario.nr_matric_operador" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_operador dbname="usuario.nm_usuario_operador" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="convenio.cd_convenio" )
 column=(type=char(60) updatewhereclause=yes name=nm_convenio dbname="convenio.nm_convenio" )
 column=(type=char(15) updatewhereclause=yes name=cd_conveniado dbname="conveniado.cd_conveniado" )
 column=(type=char(40) updatewhereclause=yes name=nm_conveniado dbname="conveniado.nm_conveniado" )
 column=(type=datetime updatewhereclause=yes name=dh_devolucao dbname="nf_venda.dh_devolucao" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="cliente.cd_cliente" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="cliente.nm_cliente" )
 retrieve="select nf.cd_filial,
		f.nm_fantasia,
		nf.nr_nf,
		nf.de_especie,
		nf.de_serie,
		nf.id_tipo_venda,
		nf.dh_emissao,
		nf.vl_total_nf_bruto,
		nf.vl_total_produtos,
		nf.vl_total_nf_tabela,
		nf.vl_total_nf,
		nf.pc_desconto,
		(nf.vl_total_nf_bruto - nf.vl_total_nf_tabela) as vl_desconto_tabela,
		Round(((((nf.vl_total_nf_bruto * (1 - (nf.pc_desconto/100))) - nf.vl_total_nf_tabela) / nf.vl_total_nf_bruto) * 100),2) as pc_desc_tabela,
		(nf.vl_total_nf_tabela - nf.vl_total_nf) as vl_desconto_filial,
		Round((((nf.vl_total_nf_tabela - nf.vl_total_nf) / nf.vl_total_nf_bruto) * 100),2) as pc_desc_filial,
		(nf.vl_total_nf_bruto - nf.vl_total_nf) as vl_desc_geral,
		(((nf.vl_total_nf_bruto - nf.vl_total_nf) / nf.vl_total_nf_bruto) *100) as pc_desc_geral,
		u.nr_matricula as nr_matric_alteracao,	
		u.nm_usuario as nm_usuario_alteracao,
		op.nr_matricula as nr_matric_operador,	
		op.nm_usuario as nm_usuario_operador,
		cv.cd_convenio,
		cv.nm_fantasia as nm_convenio,
		cva.cd_conveniado,
		cva.nm_conveniado,
		nf.dh_devolucao,
		c.cd_cliente,
		c.nm_cliente
from nf_venda nf
inner join filial f
	on f.cd_filial = nf.cd_filial
left outer join usuario op
	on op.nr_matricula = nf.nr_matric_operador
left outer join usuario u
	on u.nr_matricula = nf.nr_matric_alteracao_preco
left outer join convenio cv
	on cv.cd_convenio = nf.cd_convenio
left outer join conveniado cva
	on cva.cd_convenio = nf.cd_convenio
	and cva.cd_conveniado = nf.cd_conveniado
left outer join cliente c
	on c.cd_cliente = nf.cd_cliente
where nf.cd_filial = :cd_filial
	and nf.nr_nf = :nr_nf
	and nf.de_especie = :de_especie
	and nf.de_serie = :de_serie" arguments=(("cd_filial", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
