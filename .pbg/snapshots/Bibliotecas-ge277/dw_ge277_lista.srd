table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_venda dbname="id_tipo_venda" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf_bruto dbname="vl_total_nf_bruto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf_tabela dbname="vl_total_nf_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_comercial dbname="vl_desconto_comercial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_pve dbname="vl_desconto_pve" )
 column=(type=decimal(12) updatewhereclause=yes name=pc_desc_valor dbname="pc_desc_valor" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="nm_usuario" )
 retrieve="select  nf.cd_filial,
		nf.nr_nf,
		nf.de_serie,
		nf.de_especie,
		nf.id_tipo_venda,
		nf.dh_emissao,
		nf.vl_total_nf_bruto,
		nf.vl_total_nf_tabela,
		nf.vl_total_nf,
		(nf.vl_total_nf_tabela - nf.vl_total_nf) as vl_desconto_comercial,
		0.00 as vl_desconto_pve,
		Round((((nf.vl_total_nf_tabela - nf.vl_total_nf) / nf.vl_total_nf_bruto) * 100),2) as pc_desc_valor,
		u.nm_usuario
from nf_venda nf (index idx_data_filial)
inner join filial f (index pk_filial)
	on f.cd_filial = nf.cd_filial
left outer join usuario u (index pk_usuario)
	on u.nr_matricula = nf.nr_matric_alteracao_preco
where nf.dh_movimentacao_caixa between :dt_inicio and :dt_fim
	and nf.vl_total_nf_tabela > nf.vl_total_nf
	and nf.dh_cancelamento is null
	and nf.nr_nf_anexa is null" arguments=(("dt_inicio", date),("dt_fim", date))  sort="pc_desc_valor D " )
