table(column=(type=long updatewhereclause=yes name=cd_regiao dbname="regiao.cd_regiao" )
 column=(type=char(40) updatewhereclause=yes name=de_regiao dbname="regiao.de_regiao" )
 column=(type=long updatewhereclause=yes name=qtde_entrada dbname="qtde_entrada" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_entradas dbname="vl_entradas" )
 column=(type=long updatewhereclause=yes name=qtde_saida dbname="qtde_saida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_saidas dbname="vl_saidas" )
 column=(type=long updatewhereclause=yes name=qtde_total dbname="qtde_total" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total dbname="vl_total" )
 retrieve="select 	r.cd_regiao,
			r.de_regiao,
			sum(case when m.id_entrada_saida = 'E' then m.qt_ajuste else 0 end) as qtde_entrada, 
			sum(m.qt_ajuste * (case when m.id_entrada_saida = 'E' then m.vl_custo_unitario else 0 end)) as vl_entradas,
			sum(case when m.id_entrada_saida = 'S' then m.qt_ajuste else 0 end) as qtde_saida, 
			sum(m.qt_ajuste * (case when m.id_entrada_saida = 'S' then m.vl_custo_unitario else 0 end)) as vl_saidas,
			sum(case when m.id_entrada_saida = 'S' then 0 - m.qt_ajuste else m.qt_ajuste end) as qtde_total, 
			sum(m.qt_ajuste * (case when m.id_entrada_saida = 'S' then m.vl_custo_unitario else 0 - m.vl_custo_unitario end)) as vl_total
from ajuste_estoque m (index idx_filial_data)
inner join motivo_ajuste ma 
	on ma.cd_motivo_ajuste = m.cd_motivo_ajuste
inner join filial f
	on f.cd_filial = m.cd_filial_ajuste
inner join regiao r
	on r.cd_regiao = f.cd_regiao
where m.dh_ajuste between :dt_inicio and :dt_fim
and m.cd_motivo_ajuste  not in (35,3) //resgate de pontos e uso ambulatorio
and m.cd_filial_ajuste <> 534
group by r.cd_regiao,
			r.de_regiao
having sum(m.qt_ajuste * (case when m.id_entrada_saida = 'S' then 0 - m.vl_custo_unitario else m.vl_custo_unitario end)) <> 0
" arguments=(("dt_inicio", datetime),("dt_fim", datetime))  sort="cd_regiao A " )
