table(column=(type=long updatewhereclause=yes name=cd_regiao dbname="cd_regiao" )
 column=(type=char(40) updatewhereclause=yes name=de_regiao dbname="de_regiao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_perdas dbname="vl_perdas" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_sobras dbname="vl_sobras" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_resultado dbname="vl_resultado" )
 retrieve="select r.cd_regiao,
         r.de_regiao,
         sum(case when l.cd_conta_fluxo_caixa=84 then case when coalesce(l.id_estorno,'N') <> 'S' then l.vl_lancamento else 0 - l.vl_lancamento end else 0 end)  as vl_perdas,
		sum(case when l.cd_conta_fluxo_caixa=85 then case when coalesce(l.id_estorno,'N') <> 'S' then l.vl_lancamento else 0 - l.vl_lancamento end else 0 end)  as vl_sobras,
		sum(case when l.cd_conta_fluxo_caixa=84 then case when coalesce(l.id_estorno,'N') <> 'S' then l.vl_lancamento else 0 - l.vl_lancamento end else 0 end)-sum(case when l.cd_conta_fluxo_caixa=85 then case when coalesce(l.id_estorno,'N') <> 'S' then l.vl_lancamento else 0 - l.vl_lancamento end else 0 end)  as vl_resultado
from filial f (index pk_filial)
inner join caixa c (index pk_caixa)
	on c.cd_filial = f.cd_filial
inner join controle_caixa cc (index idx_data_movimentacao)
	on cc.cd_caixa = c.cd_caixa
Inner join lancamento_caixa l (index pk_lancamento_caixa)
	on l.cd_caixa = cc.cd_caixa
	and l.nr_controle_caixa = cc.nr_controle_caixa
inner join regiao r (index pk_regiao)
	on r.cd_regiao = f.cd_regiao
inner join conta_fluxo_caixa cf (index pk_conta_fluxo_caixa)
	on cf.cd_conta_fluxo_caixa = l.cd_conta_fluxo_caixa
where cc.dh_movimentacao_caixa between :dt_inicio and :dt_fim
	and c.id_caixa_geral = 'S'
	and l.cd_conta_fluxo_caixa in (84,85)
group by r.cd_regiao, r.de_regiao" arguments=(("dt_inicio", datetime),("dt_fim", datetime)) )
