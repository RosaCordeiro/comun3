table(column=(type=long updatewhereclause=yes name=cd_regiao dbname="regiao.cd_regiao" )
 column=(type=char(40) updatewhereclause=yes name=de_regiao dbname="regiao.de_regiao" )
 column=(type=long updatewhereclause=yes name=qt_cliente_venda dbname="qt_cliente_venda" )
 column=(type=long updatewhereclause=yes name=qt_cliente_devolucao dbname="qt_cliente_devolucao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_devolucao_venda dbname="vl_devolucao_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_devolucao_compra dbname="vl_devolucao_compra" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_tabela dbname="vl_venda_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_desconto dbname="vl_venda_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_liquida dbname="vl_venda_liquida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_compra dbname="vl_compra" )
 retrieve="  select 	rg.cd_regiao,
			rg.de_regiao,
			sum(r.qt_cliente_venda) as qt_cliente_venda,		
			sum(r.qt_cliente_devolucao) as qt_cliente_devolucao,
			sum(r.vl_devolucao_venda) as vl_devolucao_venda,
			sum(r.vl_devolucao_compra) as vl_devolucao_compra,
			sum(r.vl_venda_tabela) as vl_venda_tabela,
			sum(r.vl_venda_tabela - (r.vl_venda_avista+r.vl_venda_crediario+r.vl_venda_convenio+r.vl_venda_conta_corrente-r.vl_devolucao_venda+r.vl_venda_cartao_credito+r.vl_venda_cartao_debito+r.vl_venda_cheque_avista+r.vl_venda_cheque_aprazo)) as vl_venda_desconto,
			sum(r.vl_venda_avista+r.vl_venda_crediario+r.vl_venda_convenio+r.vl_venda_conta_corrente-r.vl_devolucao_venda+r.vl_venda_cartao_credito+r.vl_venda_cartao_debito+r.vl_venda_cheque_avista+r.vl_venda_cheque_aprazo) as vl_venda_liquida,
			sum(r.vl_compra) as vl_compra
from resumo_movimento_estoque r
inner join filial f
	on f.cd_filial = r.cd_filial
inner join regiao rg
	on rg.cd_regiao = f.cd_regiao
where r.dh_resumo between :dt_inicio and :dt_fim
	and r.cd_filial <> 534
group by rg.cd_regiao, rg.de_regiao" arguments=(("dt_inicio", datetime),("dt_fim", datetime))  sort="cd_regiao A " )
