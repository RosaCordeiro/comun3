table(column=(type=long updatewhereclause=yes name=cd_regiao dbname="cd_regiao" )
 column=(type=long updatewhereclause=yes name=qt_desc dbname="qt_desc" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto dbname="vl_desconto" )
 column=(type=long updatewhereclause=yes name=qt_total dbname="qt_total" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total dbname="vl_total" )
 retrieve="select 	f.cd_regiao, 
			sum(case when nf.vl_total_nf_tabela > nf.vl_total_nf then 1 else 0 end) as qt_desc,
			sum(nf.vl_total_nf_tabela - nf.vl_total_nf) as vl_desconto,
			count(1) as qt_total, 
			sum(nf.vl_total_nf) as vl_total
from nf_venda nf (index idx_data_filial)
inner join filial f   (index pk_filial)
	on f.cd_filial = nf.cd_filial
where nf.dh_movimentacao_caixa between :dt_inicio and :dt_fim
	and nf.dh_cancelamento is null
	and nf.nr_nf_anexa is null
	and nf.cd_filial <> 534
group by f.cd_regiao" arguments=(("dt_inicio", datetime),("dt_fim", datetime))  sort="cd_regiao A " )
