table(column=(type=datetime updatewhereclause=yes name=dh_analise dbname="analise_filial.dh_analise" dbalias="a.dh_analise" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="analise_filial.cd_filial" dbalias="a.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="analise_filial.nr_nf" dbalias="a.nr_nf" )
 column=(type=char(40) updatewhereclause=yes name=de_metrica dbname="de_metrica" )
 column=(type=char(80) updatewhereclause=yes name=de_analise dbname="de_analise" )
 column=(type=char(1) updatewhereclause=yes name=id_revisado dbname="analise_filial.id_revisado" dbalias="a.id_revisado" values="	S/	N" )
 column=(type=char(80) updatewhereclause=yes name=de_revisao dbname="analise_filial.de_revisao" dbalias="a.de_revisao" )
 column=(type=datetime updatewhereclause=yes name=dh_revisao dbname="analise_filial.dh_revisao" dbalias="a.dh_revisao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_revisao dbname="analise_filial.nr_matricula_revisao" dbalias="a.nr_matricula_revisao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="u.nm_usuario" )
 retrieve="select 	a.dh_analise, 
			a.cd_filial, 
			f.nm_fantasia,
			a.nr_nf,
			(m.de_metrica) as de_metrica,
			(a.de_analise) as de_analise, 
			a.id_revisado, 
			a.de_revisao,
			a.dh_revisao,
			a.nr_matricula_revisao,
			u.nm_usuario
from analise_filial a
inner join metrica_analise_filial m
	on m.cd_metrica = a.cd_metrica
inner join filial f
	on f.cd_filial = a.cd_filial
left outer join usuario u
	on u.nr_matricula = a.nr_matricula_revisao
where a.dh_analise between :dt_inicio and :dt_fim
	and coalesce(a.id_revisado,'N')<>'N'" arguments=(("dt_inicio", datetime),("dt_fim", datetime))  sort="de_metrica A dh_analise A id_revisado A cd_filial A " )
