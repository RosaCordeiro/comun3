table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_venda.nr_nf" dbalias="nf.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_venda.de_especie" dbalias="nf.de_especie" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_venda dbname="nf_venda.id_tipo_venda" dbalias="nf.id_tipo_venda" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_venda.dh_emissao" dbalias="nf.dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf_bruto dbname="nf_venda.vl_total_nf_bruto" dbalias="nf.vl_total_nf_bruto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf_tabela dbname="nf_venda.vl_total_nf_tabela" dbalias="nf.vl_total_nf_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_venda.vl_total_nf" dbalias="nf.vl_total_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto_filial dbname="vl_desconto_filial" )
 column=(type=decimal(12) updatewhereclause=yes name=pc_desc_filial dbname="pc_desc_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="u.nm_usuario" )
 retrieve="select top 20 
		nf.cd_filial,
		f.nm_fantasia,
		nf.nr_nf,
		nf.de_especie,
		nf.id_tipo_venda,
		nf.dh_emissao,
		nf.vl_total_nf_bruto,
		nf.vl_total_nf_tabela,
		nf.vl_total_nf,
		/*coalesce((select sum(i1.qt_vendida * Round((i1.vl_preco_unitario * (id1.pc_desconto / 100)),2)) as vl_desconto
					from item_nf_venda_desconto id1 (index pk_item_nf_venda_desconto)
					inner join item_nf_venda i1 (index pk_item_nf_venda)
						on 	i1.cd_filial = id1.cd_filial
						and 	i1.nr_nf = id1.nr_nf
						and 	i1.de_especie = id1.de_especie
						and 	i1.de_serie = id1.de_serie 
						and 	i1.cd_produto = id1.cd_produto
						and 	i1.nr_sequencial = id1.nr_sequencial 
					Where id1.id_tipo_desconto = 'PVE'
						And i1.cd_filial = nf.cd_filial
						And i1.nr_nf = nf.nr_nf
						And i1.de_serie = nf.de_serie
						And i1.de_especie = nf.de_especie),0) as vl_desconto_pve,*/
		(nf.vl_total_nf_tabela - nf.vl_total_nf) as vl_desconto_filial,
		Round((((nf.vl_total_nf_tabela - nf.vl_total_nf) / nf.vl_total_nf_bruto) * 100),2) as pc_desc_filial,
		u.nm_usuario
from nf_venda nf
inner join usuario u
	on u.nr_matricula = nf.nr_matric_alteracao_preco
inner join filial f
	on f.cd_filial = nf.cd_filial
where nf.dh_movimentacao_caixa between :dt_inicio and :dt_fim
and nf.dh_cancelamento is null
and nf.vl_total_nf_bruto > 0
and nf.vl_total_nf_tabela > nf.vl_total_nf
and not exists (select x1.nr_nf 
					from item_nf_venda_desconto x1 
					where x1.cd_filial = nf.cd_filial
						and x1.nr_nf = nf.nr_nf
						and x1.de_especie = nf.de_especie
						and x1.de_serie = nf.de_serie
						and x1.id_tipo_desconto = 'PVE' )
order by 11 desc
" arguments=(("dt_inicio", datetime),("dt_fim", datetime)) )
