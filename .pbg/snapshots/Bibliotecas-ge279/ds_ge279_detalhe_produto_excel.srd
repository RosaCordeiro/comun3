table(column=(type=long updatewhereclause=yes name=cd_filial dbname="log_cancelamento_fiscal.cd_filial" dbalias="l.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="log_cancelamento_fiscal.dh_movimentacao_caixa" dbalias="l.dh_movimentacao_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="log_cancelamento_fiscal.dh_cancelamento" dbalias="l.dh_cancelamento" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="log_cancelamento_fiscal.cd_produto" dbalias="l.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="p.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="p.de_apresentacao_venda" )
 column=(type=long updatewhereclause=yes name=qt_cancelada dbname="log_cancelamento_fiscal.qt_cancelada" dbalias="l.qt_cancelada" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_pratica dbname="log_cancelamento_fiscal.vl_preco_praticado" dbalias="l.vl_preco_praticado" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_res dbname="log_cancelamento_fiscal.nr_matricula_responsavel" dbalias="l.nr_matricula_responsavel" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="u.nm_usuario" )
 column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="log_cancelamento_fiscal.cd_caixa" dbalias="l.cd_caixa" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="log_cancelamento_fiscal.nr_controle_caixa" dbalias="l.nr_controle_caixa" )
 column=(type=long updatewhereclause=yes name=nr_ecf dbname="log_cancelamento_fiscal.nr_ecf" dbalias="l.nr_ecf" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="log_cancelamento_fiscal.nr_nf" dbalias="l.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="log_cancelamento_fiscal.de_especie" dbalias="l.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="log_cancelamento_fiscal.de_serie" dbalias="l.de_serie" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao_preco dbname="log_cancelamento_fiscal.id_alteracao_preco" dbalias="l.id_alteracao_preco" )
 retrieve="  SELECT l.cd_filial,   
         f.nm_fantasia,  
        	l.dh_movimentacao_caixa as dh_movimentacao_caixa ,   
		l.dh_cancelamento as dh_cancelamento ,   
         l.cd_produto, 
		p.de_produto,   
         p.de_apresentacao_venda,   
         l.qt_cancelada,   
         l.vl_preco_praticado,   
         l.nr_matricula_responsavel,   
         u.nm_usuario,   
         l.cd_caixa,   
         l.nr_controle_caixa,   
         l.nr_ecf,   
         l.nr_nf,   
         l.de_especie,   
         l.de_serie,   
		l.id_alteracao_preco
    FROM log_cancelamento_fiscal l,   
         filial f,   
         usuario u,   
         produto_geral p  
   WHERE l.dh_movimentacao_caixa 	between :dt_inicio and :dt_termino     
	  and l.cd_filial                				= f.cd_filial  
	  and l.nr_matricula_responsavel 	= u.nr_matricula
	  and l.cd_produto               			= p.cd_produto
	order by l.cd_filial
	
" arguments=(("dt_inicio", date),("dt_termino", date)) )
