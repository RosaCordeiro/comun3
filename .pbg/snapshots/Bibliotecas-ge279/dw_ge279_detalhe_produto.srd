table(column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="log_cancelamento_fiscal.dh_movimentacao_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="log_cancelamento_fiscal.dh_cancelamento" )
 column=(type=long updatewhereclause=yes name=qt_cancelada dbname="qt_cancelada" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_praticado dbname="log_cancelamento_fiscal.vl_preco_praticado" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cancelamento dbname="vl_cancelamento" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao_preco dbname="log_cancelamento_fiscal.id_alteracao_preco" values="	S/	N" )
 column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="log_cancelamento_fiscal.cd_caixa" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="log_cancelamento_fiscal.nr_controle_caixa" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="log_cancelamento_fiscal.nr_nf" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_responsavel dbname="log_cancelamento_fiscal.nr_matricula_responsavel" )
 retrieve="  SELECT lo.dh_movimentacao_caixa,   
         lo.dh_cancelamento,   
         sum(lo.qt_cancelada) as qt_cancelada,   
         lo.vl_preco_praticado,  
    		sum(lo.qt_cancelada * lo.vl_preco_praticado) as vl_cancelamento,
         lo.id_alteracao_preco,   
         lo.cd_caixa,   
         lo.nr_controle_caixa,   
         lo.nr_nf,
         us.nm_usuario, 
		lo.nr_matricula_responsavel
    FROM log_cancelamento_fiscal lo, usuario us  
   WHERE lo.cd_filial                = :cd_filial
     AND lo.dh_movimentacao_caixa between :dt_inicio and :dt_termino
     AND lo.cd_produto               = :cd_produto
     AND lo.nr_matricula_responsavel = us.nr_matricula
group by lo.dh_movimentacao_caixa,   
         lo.dh_cancelamento,   
         lo.vl_preco_praticado,  
         lo.id_alteracao_preco,   
         lo.cd_caixa,   
         lo.nr_controle_caixa,   
         lo.nr_nf,
         us.nm_usuario, 
		lo.nr_matricula_responsavel

 

" arguments=(("dt_inicio", date),("dt_termino", date),("cd_filial", number),("cd_produto", number)) )
