table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" dbalias="f.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=qtde_cancelamento dbname="qtde_cancelamento" )
 column=(type=long updatewhereclause=yes name=qtde_produto dbname="qtde_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=vlr_cancelamento dbname="vlr_cancelamento" )
 column=(type=long updatewhereclause=yes name=qtde_venda dbname="qtde_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vlr_venda dbname="vlr_venda" )
 column=(type=decimal(21) updatewhereclause=yes name=pc_qtde dbname="pc_qtde" )
 column=(type=decimal(27) updatewhereclause=yes name=pc_valor dbname="pc_valor" )
 retrieve="select 	f.cd_filial, 
			f.nm_fantasia, 
			c.qtde_cancelamento, 
			c.qtde_produto, 
			c.vlr_cancelamento, 
			vd.qtde_venda,
			vd.vl_total_nf as vlr_venda,
			Round(cast(c.qtde_cancelamento as numeric(18,2))/ cast(vd.qtde_venda as numeric(18,2)),6)*100 as pc_qtde,
			Round(c.vlr_cancelamento / vd.vl_total_nf,6)*100 as pc_valor
from filial f
Inner join (SELECT lo1.cd_filial,
						count(*) as qtde_cancelamento,
						count(distinct(lo1.cd_produto)) as qtde_produto,
						Round(sum(lo1.qt_cancelada * lo1.vl_preco_praticado), 2) vlr_cancelamento
				 FROM log_cancelamento_fiscal lo1
				WHERE lo1.dh_movimentacao_caixa between :dt_inicio and :dt_termino
				Group by lo1.cd_filial) c
	on c.cd_filial = f.cd_filial
inner join (select nf1.cd_filial, sum(nf1.vl_total_nf) as vl_total_nf, count(nf1.nr_nf) as qtde_venda
				from nf_venda nf1
				where nf1.dh_movimentacao_caixa between :dt_inicio and :dt_termino
				and nf1.dh_cancelamento is null
				group by nf1.cd_filial) vd
	on vd.cd_filial = f.cd_filial
inner join regiao rg
	on rg.cd_regiao = f.cd_regiao
Where vd.cd_filial = f.cd_filial //N$$HEX1$$e300$$ENDHEX$$o remover: erro fun$$HEX2$$e700e300$$ENDHEX$$o appendwhere_subquery" arguments=(("dt_inicio", date),("dt_termino", date)) )
