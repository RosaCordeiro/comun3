table(column=(type=long updatewhereclause=yes name=cd_produto dbname="log_cancelamento_fiscal.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="compute_0002" )
 column=(type=long updatewhereclause=yes name=qtde_cancelamentos dbname="qtde_cancelamentos" )
 column=(type=long updatewhereclause=yes name=qtde_cancelados dbname="qtde_cancelados" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cancelamento dbname="vl_cancelamento" )
 retrieve="  SELECT lo.cd_produto,   
         pr.de_produto + ~" : ~" + pr.de_apresentacao_venda,
         count(lo.cd_produto) qtde_cancelamentos,
         sum(lo.qt_cancelada) qtde_cancelados, 
			sum(lo.qt_cancelada * lo.vl_preco_praticado) vl_cancelamento
    FROM log_cancelamento_fiscal lo,
         produto_geral pr
   WHERE lo.cd_produto = pr.cd_produto
     AND lo.dh_movimentacao_caixa between :dt_inicio and :dt_termino
     AND lo.cd_filial = :cd_filial
GROUP BY lo.cd_produto, pr.de_produto, pr.de_apresentacao_venda
     
    
" arguments=(("dt_inicio", date),("dt_termino", date),("cd_filial", number))  sort="de_produto A " )
