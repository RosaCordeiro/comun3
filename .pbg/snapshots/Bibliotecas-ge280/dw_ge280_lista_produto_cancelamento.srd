table(column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="log_cancelamento_fiscal.dh_cancelamento" )
 column=(type=long updatewhereclause=yes name=qt_cancelada dbname="log_cancelamento_fiscal.qt_cancelada" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_bruto dbname="log_cancelamento_fiscal.vl_preco_bruto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_praticado dbname="log_cancelamento_fiscal.vl_preco_praticado" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao_preco dbname="log_cancelamento_fiscal.id_alteracao_preco" values="	S/	N" )
 column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="log_cancelamento_fiscal.cd_caixa" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="log_cancelamento_fiscal.nr_controle_caixa" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 retrieve="select lo.dh_cancelamento, 
		 lo.qt_cancelada,
		 lo.vl_preco_bruto,
		 lo.vl_preco_praticado,
		 lo.id_alteracao_preco,
		 lo.cd_caixa,
		 lo.nr_controle_caixa,
		 u.nm_usuario  
from log_cancelamento_fiscal lo
Inner join usuario u 
	on u.nr_matricula = lo.nr_matricula_responsavel
where lo.dh_movimentacao_caixa between :dh_inicio and :dh_fim
	and lo.cd_filial = :cd_filial
	and lo.cd_produto = :cd_produto" arguments=(("dh_inicio", datetime),("dh_fim", datetime),("cd_filial", number),("cd_produto", number))  sort="dh_cancelamento D " )
