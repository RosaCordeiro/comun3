table(column=(type=datetime updatewhereclause=yes name=dh_atualizacao_estoque dbname="nf_compra.dh_atualizacao_estoque" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_compra.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_compra.de_serie" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="item_nf_compra.qt_recebida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo dbname="vl_custo" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 retrieve="select	n.dh_atualizacao_estoque, 
		f.nm_fantasia,
		n.nr_nf,
		n.de_serie,
		i.qt_recebida,
		(i.qt_recebida * i.vl_preco_unitario) as vl_custo,
		u.nm_usuario  
from nf_compra n
inner join item_nf_compra i
	on i.cd_filial = n.cd_filial
	and i.nr_nf = n.nr_nf
	and i.de_serie = n.de_serie
	and i.de_especie = n.de_especie
	and i.cd_fornecedor = n.cd_fornecedor
Inner join usuario u 
	on u.nr_matricula = n.nr_matric_atualizacao_estoque
inner join fornecedor f
	on f.cd_fornecedor = n.cd_fornecedor
where n.dh_movimentacao_caixa between :dh_inicio and :dh_fim
	and n.cd_filial = :cd_filial
	and i.cd_produto = :cd_produto" arguments=(("dh_inicio", datetime),("dh_fim", datetime),("cd_filial", number),("cd_produto", number))  sort="dh_atualizacao_estoque D " )
