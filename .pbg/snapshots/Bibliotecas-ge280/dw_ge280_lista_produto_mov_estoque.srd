table(column=(type=datetime updatewhereclause=yes name=dh_movimento dbname="dh_movimento" )
 column=(type=long updatewhereclause=yes name=cd_tipo_movimento dbname="cd_tipo_movimento" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_movimento dbname="tipo_movimento_estoque.de_tipo_movimento" )
 column=(type=long updatewhereclause=yes name=qt_movimento dbname="qt_movimento" )
 column=(type=char(7) updatewhereclause=yes name=de_entrada_saida dbname="de_entrada_saida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo dbname="vl_custo" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 retrieve="select m.dh_movimento,
		 m.cd_tipo_movimento,
		 t.de_tipo_movimento,
		 m.qt_movimento,
		 Case When t.id_entrada_saida = 'E' Then 'ENTRADA' ELSE 'SA$$HEX1$$cd00$$ENDHEX$$DA' End as de_entrada_saida,
		 (m.qt_movimento * m.vl_custo_unitario) as vl_custo,
		 m.cd_filial,
		 m.nr_nf,
		 m.de_especie,
		 m.de_serie
FROM movimento_estoque m (index pk_movimento_estoque)
Inner join tipo_movimento_estoque t
	on t.cd_tipo_movimento = m.cd_tipo_movimento
Where m.dh_movimento between :dh_inicio and :dh_fim
	and m.cd_filial_movimento = :cd_filial
	and m.cd_produto = :cd_produto
	and t.id_tipo_movimento <> 'A'" arguments=(("dh_inicio", datetime),("dh_fim", datetime),("cd_filial", number),("cd_produto", number))  sort="dh_movimento D " )
