table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial_ajuste" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_liquida dbname="vl_venda_liquida" )
 column=(type=long updatewhereclause=yes name=qtde_entrada dbname="qtde_entrada" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_entradas dbname="vl_entradas" )
 column=(type=long updatewhereclause=yes name=qtde_saida dbname="qtde_saida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_saidas dbname="vl_saidas" )
 column=(type=long updatewhereclause=yes name=qtde_total dbname="qtde_total" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total dbname="vl_total" )
 column=(type=decimal(28) updatewhereclause=yes name=pc_valor dbname="pc_valor" )
 retrieve="select 	m.cd_filial_ajuste,
			f.nm_fantasia,
			me.vl_venda_liquida,
			sum(case when m.id_entrada_saida = 'E' then m.qt_ajuste else 0 end) as qtde_entrada, 
			sum(m.qt_ajuste * (case when m.id_entrada_saida = 'E' then m.vl_custo_unitario else 0 end)) as vl_entradas,
			sum(case when m.id_entrada_saida = 'S' then m.qt_ajuste else 0 end) as qtde_saida, 
			sum(m.qt_ajuste * (case when m.id_entrada_saida = 'S' then m.vl_custo_unitario else 0 end)) as vl_saidas,
			sum(case when m.id_entrada_saida = 'S' then 0 - m.qt_ajuste else m.qt_ajuste end) as qtde_total, 
			sum(m.qt_ajuste * (case when m.id_entrada_saida = 'S' then m.vl_custo_unitario else 0 - m.vl_custo_unitario end)) as vl_total,
			Case when me.vl_venda_liquida > 0 Then Round(Round((sum(m.qt_ajuste * (case when m.id_entrada_saida = 'S' then m.vl_custo_unitario else 0 - m.vl_custo_unitario end)) / me.vl_venda_liquida),8) * 100,2) else 0.00 end as pc_valor
from ajuste_estoque m (index idx_filial_data)
inner join filial f
	on f.cd_filial = m.cd_filial_ajuste
left outer join ( select r1.cd_filial,
							sum(r1.vl_venda_avista+r1.vl_venda_crediario+r1.vl_venda_convenio+r1.vl_venda_conta_corrente-r1.vl_devolucao_venda+r1.vl_venda_cartao_credito+r1.vl_venda_cartao_debito+r1.vl_venda_cheque_avista+r1.vl_venda_cheque_aprazo) as vl_venda_liquida
					from resumo_movimento_estoque r1
					where r1.dh_resumo between :dh_inicio and :dh_fim
						and r1.cd_filial <> 534
					group by r1.cd_filial) me
	on me.cd_filial = m.cd_filial_ajuste
where m.dh_ajuste between :dh_inicio and :dh_fim
and m.cd_motivo_ajuste  not in (35,3) //resgate de pontos e uso ambulatorio
and m.cd_filial_ajuste <> 534
group by m.cd_filial_ajuste,
			f.nm_fantasia,
			me.vl_venda_liquida
having sum(m.qt_ajuste * (case when m.id_entrada_saida = 'S' then 0 - m.vl_custo_unitario else m.vl_custo_unitario end)) <> 0" arguments=(("dh_inicio", datetime),("dh_fim", datetime))  sort="pc_valor D " )
