table(column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_venda.cd_produto" )
 column=(type=char(102) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_comissao_extra dbname="item_nf_venda.pc_comissao_extra" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="item_nf_venda.qt_vendida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_praticado dbname="item_nf_venda.vl_preco_praticado" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total dbname="vl_total" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao_preco dbname="item_nf_venda.id_alteracao_preco" values="	S/	N" )
 retrieve="select 	i.cd_produto, 
			p.de_produto||': '||p.de_apresentacao_venda as de_produto,
			i.pc_comissao_extra,  
			i.qt_vendida, 
			i.vl_preco_praticado,  
			(i.qt_vendida * i.vl_preco_praticado) as vl_total,
			i.id_alteracao_preco
from item_nf_venda i
inner join produto_geral p
	on p.cd_produto = i.cd_produto
where i.cd_filial = :filial
and i.nr_nf = :nf
and i.de_especie = :especie
and i.de_serie = :serie" arguments=(("filial", number),("nf", number),("serie", string),("especie", string)) )
