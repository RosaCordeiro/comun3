table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_venda.cd_filial" dbalias="n.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_venda.nr_nf" dbalias="n.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_venda.de_serie" dbalias="n.de_serie" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_venda.de_especie" dbalias="n.de_especie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_venda.dh_movimentacao_caixa" dbalias="n.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf_tabela dbname="nf_venda.vl_total_nf_tabela" dbalias="n.vl_total_nf_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_venda.vl_total_nf" dbalias="n.vl_total_nf" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_operador dbname="nf_venda.nr_matric_operador" dbalias="n.nr_matric_operador" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="u.nm_usuario" )
 retrieve="select n.cd_filial, n.nr_nf, n.de_serie, n.de_especie, n.dh_movimentacao_caixa, n.vl_total_nf_tabela, n.vl_total_nf, n.nr_matric_operador, u.nm_usuario
from nf_venda n
inner join usuario u
	on u.nr_matricula = n.nr_matric_operador
where n.dh_movimentacao_caixa between :dt_inicio and :dt_fim
	and n.cd_convenio is not null
	and n.dh_cancelamento is null
	and n.nr_nf_anexa is null" arguments=(("dt_inicio", date),("dt_fim", date)) )
