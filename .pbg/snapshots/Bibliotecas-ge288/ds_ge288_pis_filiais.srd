table(column=(type=char(1) updatewhereclause=yes name=id_situacao_pis_cofins dbname="id_situacao_pis_cofins" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="id_lei_generico" )
 column=(type=long updatewhereclause=yes name=qt_venda dbname="qt_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda dbname="vl_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cmv dbname="vl_cmv" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_comissao dbname="vl_comissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="vl_icms" )
 column=(type=decimal(48) updatewhereclause=yes name=vl_pis_cofins dbname="vl_pis_cofins" )
 retrieve="select	coalesce(hp.id_situacao_pis_cofins, g.id_situacao_pis_cofins) as id_situacao_pis_cofins,
			coalesce(hp.id_lei_generico, g.id_lei_generico) as id_lei_generico,
       	sum(r.qt_venda - r.qt_devolucao_venda) qt_venda,
       	sum(r.vl_venda) vl_venda,
       	sum(r.vl_cmv) vl_cmv,
       	sum(r.vl_comissao) vl_comissao,
			sum(r.vl_cmv_gerencial - r.vl_cmv) vl_icms,
		 	sum(case when coalesce(hp.id_situacao_pis_cofins, g.id_situacao_pis_cofins) = 'T' then /* Produto possui PIS/COFINS tributado? */
					Case when cast(substring(pdp.vl_parametro,7,4)||'/'||substring(pdp.vl_parametro,4,2)||'/'||substring(pdp.vl_parametro,1,2) as date) <= r.dh_resumo then /* A partir dessa data o PIS/COFINS come$$HEX1$$e700$$ENDHEX$$ou a ser analisado na rentabilidade */
						Case pcp.vl_parametro /* Metodo calculo PIS/COFINS */ 
							when '1' then /* Metodo 1: Calcula PIS/COFINS pelo valor de venda */
								round(r.vl_venda * ( cast(pac.vl_parametro as numeric(9,6)) + cast(pap.vl_parametro as numeric(9,6)))/100, 2)
							when '2' then /* Metodo 2: Calcula PIS/COFINS pelo valor de venda (sem ICMS) */
								round((r.vl_venda - (r.vl_cmv_gerencial - r.vl_cmv)) * ( cast(pac.vl_parametro as numeric(9,6)) + cast(pap.vl_parametro as numeric(9,6)))/100, 2)
							when '3' then /* Metodo 3: Calcula PIS/COFINS pelo valor agregado, venda menos CMV gerencial (sem ICMS na base D$$HEX1$$e900$$ENDHEX$$bito PIS/COFINS) */
								round((r.vl_venda - r.vl_cmv_gerencial ) * ( cast(pac.vl_parametro as numeric(9,6)) + cast(pap.vl_parametro as numeric(9,6)))/100, 2)
							when '4' then /* Metodo 4: Calcula PIS/COFINS pelo valor agregado, venda menos CMV (ICMS comp$$HEX1$$f500$$ENDHEX$$e base d$$HEX1$$e900$$ENDHEX$$bito PIS COFINS) */
								round((r.vl_venda - r.vl_cmv ) * ( cast(pac.vl_parametro as numeric(9,6)) + cast(pap.vl_parametro as numeric(9,6)))/100, 2)
							when '5' then /* Metodo 5: Calcula PIS/COFINS pela entrada, baseado no CMV (sem ICMS na base) */
								round(r.vl_cmv / (1 - (cast(pac.vl_parametro as numeric(9,6)) + cast(pap.vl_parametro as numeric(9,6))) / 100) * 
								(cast(pac.vl_parametro as numeric(9,6)) + cast(pap.vl_parametro as numeric(9,6)))/100, 2)
							Else /* Anteriormente a 10/2024 era utilizado um parametro zerado */
						round(r.vl_venda * (cast(p.vl_parametro as numeric(9,6)) / 100), 2) end
					End
				else 0
			  	end) as vl_pis_cofins	
from resumo_produto_filial r
inner join produto_geral g
	on g.cd_produto = r.cd_produto
inner join 	fornecedor f
	on f.cd_fornecedor = g.cd_fornecedor_usual
left outer join parametro_geral p
	on p.cd_parametro 	        = 'PC_PIS_COFINS_RENTABILIDADE'
left outer join historico_produto hp
	on hp.cd_produto = g.cd_produto
	and hp.dh_historico = r.dh_resumo
left outer join vw_classificacao_produto w
	on w.cd_subcategoria = coalesce(hp.cd_subcategoria, g.cd_subcategoria)
left outer join parametro_geral pcp      
	on pcp.cd_parametro 	        = 'ID_CALCULO_PIS_COFINS'
left outer join parametro_geral pdp
	on pdp.cd_parametro 	        = 'DH_INICIO_OPERACAO_PIS_COFINS'
left outer join parametro_geral pap
	on pap.cd_parametro 	        = 'PC_COFINS'
left outer join parametro_geral pac
	on pac.cd_parametro 	        = 'PC_PIS'
where r.dh_resumo       = :data_base
  and r.cd_filial       = :filial
  and substring(coalesce(hp.cd_subcategoria, g.cd_subcategoria), 1, 1) = '1'
group by coalesce(hp.id_situacao_pis_cofins, g.id_situacao_pis_cofins),
			coalesce(hp.id_lei_generico, g.id_lei_generico)" arguments=(("data_base", date),("filial", number)) )
