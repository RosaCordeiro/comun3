table(column=(type=char(40) updatewhereclause=yes name=localizacao dbname="localizacao" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_consulta dbname="consulta_rentabilidade.cd_consulta" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_consulta dbname="consulta_rentabilidade.de_consulta" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inicio dbname="consulta_rentabilidade.dh_inicio" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_termino dbname="consulta_rentabilidade.dh_termino" )
 column=(type=char(2) update=yes updatewhereclause=yes name=id_tipo_venda dbname="consulta_rentabilidade.id_tipo_venda" initial="01" values="TODAS	01/CONV$$HEX1$$ca00$$ENDHEX$$NIO	02/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_apresentacao_periodo dbname="consulta_rentabilidade.id_apresentacao_periodo" initial="D" values="DIA	D/M$$HEX1$$ca00$$ENDHEX$$S	M/TOTALIZADO	T/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_apresentacao_produto dbname="consulta_rentabilidade.id_apresentacao_produto" initial="0" values="GRUPO	1/SUBGRUPO	2/CATEGORIA	3/SUBCATEGORIA	4/PRODUTO	5/LEI GEN$$HEX1$$c900$$ENDHEX$$RICO	6/GRUPO & LEI GEN$$HEX1$$c900$$ENDHEX$$RICO	7/FORNECEDOR & LEI GEN$$HEX1$$c900$$ENDHEX$$RICO	8/TOTALIZADO	0/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_apresentacao_filial dbname="consulta_rentabilidade.id_apresentacao_filial" initial="F" values="FILIAL	F/TOTALIZADO	T/" )
 column=(type=long update=yes updatewhereclause=yes name=cd_promocao dbname="consulta_rentabilidade.cd_promocao" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_selecao_produto dbname="consulta_rentabilidade.id_selecao_produto" initial="T" values="TODOS	T/CONJUNTO DE PRODUTOS	C/MEDICAMENTO EQUIVALENTE	E/MEDICAMENTO GEN$$HEX1$$c900$$ENDHEX$$RICO	G/MEDICAMENTO REFER$$HEX1$$ca00$$ENDHEX$$NCIA	R/MEDICAMENTO SIMILAR	S/NENHUM	N/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_selecao_filial dbname="consulta_rentabilidade.id_selecao_filial" initial="T" values="TODAS	T/CONJUNTO DE FILIAIS	C/NENHUMA	N/" )
 column=(type=char(9) update=yes updatewhereclause=yes name=cd_fornecedor dbname="consulta_rentabilidade.cd_fornecedor" initial="T" values="TODOS	T/CONJUNTO	C/" )
 column=(type=char(40) updatewhereclause=yes name=de_promocao dbname="de_promocao" )
 retrieve="  Select space(40) localizacao,
		   cd_consulta,   
         de_consulta,   
         dh_inicio,   
         dh_termino,
			id_tipo_venda,   
         id_apresentacao_periodo,   
         id_apresentacao_produto,   
         id_apresentacao_filial,   
         cd_promocao,
			id_selecao_produto,
			id_selecao_filial,
			cd_fornecedor,
			space(40) de_promocao
			
    From consulta_rentabilidade
   Where cd_consulta = :codigo
" update="consulta_rentabilidade" updatewhere=0 updatekeyinplace=no arguments=(("codigo", number)) )
