table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_compra_pendente.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_registro dbname="nf_compra_pendente.dh_registro" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_compra_pendente.dh_emissao" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="nf_compra_pendente.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_compra_pendente.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_compra_pendente.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_compra_pendente.de_serie" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_produtos dbname="nf_compra_pendente.vl_total_produtos" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_compra_pendente.vl_total_nf" )
 column=(type=char(1) updatewhereclause=yes name=id_bonificacao dbname="id_bonificacao" )
 column=(type=char(1) updatewhereclause=yes name=id_confirmada dbname="id_confirmada" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_conferente dbname="nr_matricula_conferente" )
 retrieve="select n.cd_filial,
		 l.nm_fantasia,
       n.dh_registro,
		n.dh_emissao,
       n.cd_fornecedor,   
       f.nm_razao_social,   
       n.nr_nf,   
       n.de_especie,   
       n.de_serie,   
       n.vl_total_produtos,   
       n.vl_total_nf,
		 isnull(n.id_bonificacao, 'N') id_bonificacao,
       'N' id_confirmada, 
		 '      ' nr_matricula_conferente 
from nf_compra_pendente n,   
     fornecedor f,
	  filial l
where f.cd_fornecedor = n.cd_fornecedor
  and n.cd_filial = l.cd_filial

union

select n.cd_filial,
		 l.nm_fantasia,
       n.dh_movimentacao_caixa,
		n.dh_emissao,
       n.cd_fornecedor,   
       f.nm_razao_social,   
       n.nr_nf,   
       n.de_especie,   
       n.de_serie,   
       n.vl_total_produtos,   
       n.vl_total_nf,
		 isnull(n.id_bonificacao, 'N') id_bonificacao,
       'S' id_confirmada,
		 n.nr_matricula_conferente  
from nf_compra n,   
     fornecedor f,
	  filial l
where f.cd_fornecedor = n.cd_fornecedor
  and n.cd_filial = l.cd_filial"  sort="cd_filial A razao_social A dh_registro A " )
