table(column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="cd_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="de_grupo" )
 column=(type=char(1) updatewhereclause=yes name=cd_curva dbname="cd_curva" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_central1 dbname="vl_central1" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_dias_central1 dbname="vl_dias_central1" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_filial1 dbname="vl_filial1" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_dias_filial1 dbname="vl_dias_filial1" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total1 dbname="vl_total1" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_dias1 dbname="vl_total_dias1" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_central2 dbname="vl_central2" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_dias_central2 dbname="vl_dias_central2" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_filial2 dbname="vl_filial2" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_dias_filial2 dbname="vl_dias_filial2" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total2 dbname="vl_total2" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_dias2 dbname="vl_total_dias2" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_vendas1 dbname="vl_vendas1" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_vendas2 dbname="vl_vendas2" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_variacao dbname="vl_variacao" )
 column=(type=decimal(2) updatewhereclause=yes name=perc_variacao dbname="perc_variacao" )
 retrieve="select distinct 	cd_grupo, 
					de_grupo, 
					cd_curva,
					0.00 vl_central1,
					0.00 vl_dias_central1,
					0.00 vl_filial1,
					0.00 vl_dias_filial1,
					0.00 vl_total1,
					0.00 vl_total_dias1,
					0.00 vl_central2,
					0.00 vl_dias_central2,
					0.00 vl_filial2,
					0.00 vl_dias_filial2,
					0.00 vl_total2,
					0.00 vl_total_dias2,
					0.00 vl_vendas1,
					0.00 vl_vendas2,
					0.00 vl_variacao,
					0.00 perc_variacao					
from
(
	select w.cd_grupo,
				 w.de_grupo,
			 coalesce(cd_curva_abc_filiais, 'C') as cd_curva
	from saldo_produto s (index saldo_prod_5850531202)
	inner join produto_geral g
		on g.cd_produto      = s.cd_produto
	inner join vw_classificacao_produto w
		on w.cd_subcategoria = g.cd_subcategoria
	inner join produto_central c
		on c.cd_produto = s.cd_produto
	where s.cd_filial = 534
	  and s.dh_saldo  in (:data_base_1, :data_base_2)
	  and s.qt_saldo_final > 0
	  and w.cd_grupo <> '7'
	  and g.cd_produto not in (691026, 691027, 691028, 693074, 693810, 695164,
										123060, 135562, 135570, 693843, 693844, 693845,
										693217, 136437, 504486, 693216, 577625, 684431)
	union
	
	select w.cd_grupo,
					 w.de_grupo,
				 coalesce(cd_curva_abc_filiais, 'C') as cd_curva
		from saldo_produto s (index saldo_prod_5850531202)
		inner join produto_geral g
			on g.cd_produto      = s.cd_produto
		inner join vw_classificacao_produto w
			on w.cd_subcategoria = g.cd_subcategoria
		inner join produto_central c
			on c.cd_produto = s.cd_produto
		where s.cd_filial = 534
		  and s.dh_saldo  in (:data_base_1, :data_base_2)
		  and s.qt_saldo_final > 0
		  and w.cd_grupo = '7'
		  and s.vl_custo_medio > 0
		  and g.cd_produto not in (691026, 691027, 691028, 693074, 693810, 695164,
											123060, 135562, 135570, 693843, 693844, 693845,
											693217, 136437, 504486, 693216, 577625, 684431)

	union
	
	select w.cd_grupo,
				w.de_grupo,
			 coalesce(cd_curva_abc_filiais, 'C') as cd_curva
	from 	resumo_produto r
	inner join produto_geral g 
		on g.cd_produto      = r.cd_produto
	inner join vw_classificacao_produto w
		on w.cd_subcategoria = g.cd_subcategoria
	inner join produto_central c
		on c.cd_produto = r.cd_produto
	where  r.dh_resumo in (:data_base_1, :data_base_2)
		and r.vl_saldo > 0
		and r.cd_produto not in (691026, 691027, 691028, 693074, 693810, 695164,
									123060, 135562, 135570, 693843, 693844, 693845,
								693217, 136437, 504486, 693216, 577625, 684431)
) as tudo

" arguments=(("data_base_1", date),("data_base_2", date))  sort="cd_grupo A cd_curva A " )
