table(column=(type=datetime updatewhereclause=yes name=dh_analise dbname="analise_filial.dh_analise" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="analise_filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="analise_filial.nr_nf" )
 column=(type=char(32768) updatewhereclause=yes name=de_analise dbname="de_analise" )
 column=(type=char(1) updatewhereclause=yes name=id_revisado dbname="analise_filial.id_revisado" values="	S/	N" )
 column=(type=char(500) updatewhereclause=yes name=de_revisao dbname="analise_filial.de_revisao" )
 column=(type=datetime updatewhereclause=yes name=dh_revisao dbname="analise_filial.dh_revisao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula dbname="analise_filial.nr_matricula" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_ocorrencia dbname="usuario.nm_usuario_ocorrencia" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_revisao dbname="analise_filial.nr_matricula_revisao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_revisao dbname="usuario.nm_usuario_revisao" )
 retrieve="select 	a.dh_analise, 
			a.cd_filial, 
			f.nm_fantasia,
			a.nr_nf,
			cast(case when a.cd_metrica < 900 then m.de_metrica || ' - ' else '' end || a.de_analise as text) as de_analise, 
			a.id_revisado, 
			a.de_revisao,
			a.dh_revisao,
			a.nr_matricula,
			uo.nm_usuario as nm_usuario_ocorrencia,
			a.nr_matricula_revisao,
			ur.nm_usuario as nm_usuario_revisao
from analise_filial a
inner join metrica_analise_filial m
	on m.cd_metrica = a.cd_metrica
inner join filial f
	on f.cd_filial = a.cd_filial
left outer join usuario ur
	on ur.nr_matricula = a.nr_matricula_revisao
left outer join usuario uo
	on uo.nr_matricula = a.nr_matricula
where a.dh_analise between :dt_inicio and :dt_fim" arguments=(("dt_inicio", datetime),("dt_fim", datetime)) )
