table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" dbalias="f.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="cd_caixa" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="nr_controle_caixa" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="u.nm_usuario" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula dbname="usuario.nr_matricula" dbalias="u.nr_matricula" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_perda dbname="vl_perda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_sobra dbname="vl_sobra" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_diferenca dbname="vl_diferenca" )
 retrieve="Select f.cd_filial,
		f.nm_fantasia,
		c.dh_movimentacao_caixa,		 
		c.cd_caixa,   
		c.nr_controle_caixa,        
		u.nm_usuario,
		u.nr_matricula ,
		sum(case when l.cd_conta_fluxo_caixa=84 then 1 else 0 end * case when coalesce(l.id_estorno,'N') = 'S' then -1 else 1 end * l.vl_lancamento) as vl_perda,
		sum(case when l.cd_conta_fluxo_caixa=85 then 1 else 0 end * case when coalesce(l.id_estorno,'N') = 'S' then -1 else 1 end * l.vl_lancamento) as vl_sobra,
		sum(case when l.cd_conta_fluxo_caixa=85 then 1 else -1 end * case when coalesce(l.id_estorno,'N') = 'S' then -1 else 1 end * l.vl_lancamento) as vl_diferenca
From caixa cx (index pk_caixa)
inner join controle_caixa c (index idx_data_movimentacao)
	on c.cd_caixa = cx.cd_caixa
inner join usuario u
	on u.nr_matricula 			= c.nr_matricula_operador
inner join lancamento_caixa l (index pk_lancamento_caixa)
	on l.cd_caixa				= c.cd_caixa
  and  l.nr_controle_caixa	= c.nr_controle_caixa
inner join filial f
	on f.cd_filial					= cx.cd_filial
Where c.dh_movimentacao_caixa between :dh_Inicio and :dh_Termino
  and cx.id_caixa_geral			= 'S'
  and l.cd_conta_fluxo_caixa	 in (84,85)
group by f.cd_filial,
		f.nm_fantasia,
		c.dh_movimentacao_caixa,		 
		c.cd_caixa,   
		c.nr_controle_caixa,        
		u.nm_usuario,
		u.nr_matricula
" arguments=(("dh_Inicio", date),("dh_Termino", date))  sort="cd_filial A dh_movimentacao_caixa A vl_diferenca A " )
