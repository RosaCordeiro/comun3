table(column=(type=char(54) updatewhereclause=yes name=nome dbname="compute_0001" )
 column=(type=char(20) updatewhereclause=yes name=registro dbname="vdc_lista_farmaceuticos.registro" )
 column=(type=decimal(30) updatewhereclause=yes name=cpf dbname="vdc_lista_farmaceuticos.cpf" )
 column=(type=char(6) updatewhereclause=yes name=cd_uf_conselho dbname="vdc_lista_farmaceuticos.cd_uf_conselho" )
 column=(type=long updatewhereclause=yes name=empresa dbname="vdc_lista_farmaceuticos.empresa" )
 column=(type=long updatewhereclause=yes name=tipo_colaborador dbname="vdc_lista_farmaceuticos.tipo_colaborador" )
 column=(type=long updatewhereclause=yes name=matricula dbname="vdc_lista_farmaceuticos.matricula" )
 column=(type=char(1) updatewhereclause=yes name=id_selecao dbname="id_selecao" values="	S/	N" )
 retrieve="    SELECT f.nome || ' (RESPONS$$HEX1$$c100$$ENDHEX$$VEL)',   
         f.registro,   
         f.cpf,   
         f.cd_uf_conselho,   
         f.empresa,   
         f.tipo_colaborador,   
         f.matricula,  
         'N' id_selecao
    FROM vdc_lista_farmaceuticos f
   WHERE f.filial = :filial
     And exists (select * from vdc_lista_gerentes where matricula = f.matricula)

Union

  SELECT f.nome,   
         f.registro,   
         f.cpf,   
         f.cd_uf_conselho,   
         f.empresa,   
         f.tipo_colaborador,   
         f.matricula,  
         'N' id_selecao
    FROM vdc_lista_farmaceuticos f
   WHERE f.filial = :filial
     And Not exists (select * from vdc_lista_gerentes where matricula = f.matricula)
" arguments=(("filial", number)) )
