table(column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=id_pagamento dbname="id_pagamento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_venda dbname="vl_total_venda" )
 column=(type=long updatewhereclause=yes name=qt_clientes dbname="qt_clientes" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 retrieve="Select 	nf.dh_movimentacao_caixa,
			pe.id_pagamento,
       		sum(nf.vl_total_nf) as vl_total_venda,   
	   		count(nf.nr_nf) as qt_clientes,
       		nf.cd_filial, 
			fi.nm_fantasia
    FROM nf_venda nf  (index idx_data_ped_ecommerce)
Inner Join pedido_ecommerce   pe (index pk_pedido_ecommerce)
	on pe.cd_filial_ecommerce 	= Coalesce(nf.cd_filial_ecommerce, 809)
  and pe.nr_pedido				= nf.nr_pedido_ecommerce
Inner Join  filial fi (index pk_filial)
     on fi.cd_filial 		= nf.cd_filial
WHERE nf.dh_movimentacao_caixa 	between :inicio and :termino
	and Coalesce(nf.cd_filial_ecommerce, 809) = :filial_ecommerce
     and nf.nr_nf_anexa	   			is null				             
     and nf.nr_pedido_ecommerce 	is not null
     and nf.dh_cancelamento 		is null
group by nf.dh_movimentacao_caixa,
			pe.id_pagamento,
			nf.cd_filial, 
			fi.nm_fantasia" arguments=(("inicio", date),("termino", date),("filial_ecommerce", number))  sort="cd_filial A dh_movimentacao_caixa A " )
