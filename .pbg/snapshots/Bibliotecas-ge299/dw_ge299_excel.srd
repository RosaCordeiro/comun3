table(column=(type=long updatewhereclause=yes name=filial_cd_filial dbname="filial.cd_filial" dbalias="f.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(10) updatewhereclause=yes name=dh_movimentacao dbname="dh_movimentacao" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_venda_vl_total_nf dbname="vl_total_nf" )
 column=(type=char(24) updatewhereclause=yes name=pagamento dbname="pagamento" )
 retrieve=" select f.cd_filial,
		f.nm_fantasia, 
		Convert(Char(10), n.dh_movimentacao_caixa, 103) dh_movimentacao,
		n.vl_total_nf,
		( CASE p.id_pagamento
			  WHEN 3 then 'BOLETO '
			  WHEN 6 then 'VISA   '
			  WHEN 7 then 'MASTER '
			  WHEN 8 then 'DINNERS'
			  WHEN 12 then 'TRANSFER$$HEX1$$ca00$$ENDHEX$$NCIA ELETR$$HEX1$$d400$$ENDHEX$$NICA'
			  ELSE 'CARTAO'
		  END ) as pagamento
From nf_venda n (index idx_data_ped_ecommerce)
inner join pedido_ecommerce p
	  on p.cd_filial_ecommerce = Coalesce(n.cd_filial_ecommerce, 809)
	and p.nr_pedido	= n.nr_pedido_ecommerce
Inner Join filial f
	on f.cd_filial			= n.cd_filial
where n.dh_movimentacao_caixa between :inicio and :termino
	and Coalesce(n.cd_filial_ecommerce, 809) = :filial_ecommerce
	and n.nr_pedido_ecommerce is not null
	and not exists (	select * 
						from nf_devolucao_venda d
						where n.cd_filial			= d.cd_filial_venda
							and n.nr_nf				= d.nr_nf_venda
							and n.de_especie		= d.de_especie_venda
							and n.de_serie			= d.de_serie_venda
							and n.dh_cancelamento  is null)
" arguments=(("inicio", date),("termino", date),("filial_ecommerce", number))  sort="filial_cd_filial A dh_movimentacao A nf_venda_vl_total_nf A " )
