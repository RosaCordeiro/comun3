table(column=(type=long updatewhereclause=yes name=cd_produto dbname="ajuste_estoque.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=long updatewhereclause=yes name=qt_ajuste dbname="ajuste_estoque.qt_ajuste" )
 column=(type=char(1) updatewhereclause=yes name=id_entrada_saida dbname="ajuste_estoque.id_entrada_saida" )
 column=(type=char(3) updatewhereclause=yes name=cd_subgrupo dbname="vw_classificacao_produto.cd_subgrupo" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo dbname="vw_classificacao_produto.de_subgrupo" )
 column=(type=long updatewhereclause=yes name=saldo dbname="vw_saldo_atual_produto.saldo" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 retrieve="SELECT ajuste_estoque.cd_produto,  
	      pg.de_produto,
         ajuste_estoque.qt_ajuste,   
         ajuste_estoque.id_entrada_saida ,
		w.cd_subgrupo, 
		w.de_subgrupo,
		v.qt_saldo_final as saldo , 
		pg.de_apresentacao_estoque, 
		pg.de_apresentacao_venda
FROM ajuste_estoque,   
         produto_geral pg,
		vw_saldo_atual_produto v ,
		vw_classificacao_produto w
	   WHERE pg.cd_produto = ajuste_estoque.cd_produto 
		and ajuste_estoque.cd_filial_ajuste = 534 
		and ajuste_estoque.dh_ajuste between :inicio and :termino 
	 	and  substring( pg.cd_subcategoria, 1,1) = '5' 
		and v.cd_produto		= ajuste_estoque.cd_produto
	    and  v.cd_filial			= 534    
  	    and  w.cd_subcategoria	= pg.cd_subcategoria  
	
" arguments=(("inicio", date),("termino", date)) )
