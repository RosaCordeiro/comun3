table(column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=char(3) updatewhereclause=yes name=cd_subgrupo dbname="vw_classificacao_produto.cd_subgrupo" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo dbname="vw_classificacao_produto.de_subgrupo" )
 column=(type=char(10) updatewhereclause=yes name=dt_ini dbname="dt_ini" )
 column=(type=char(10) updatewhereclause=yes name=dt_ter dbname="dt_ter" )
 column=(type=long updatewhereclause=yes name=saldo dbname="vw_saldo_atual_produto.saldo" )
 column=(type=long updatewhereclause=yes name=qt_transf dbname="qt_transf" )
 column=(type=long updatewhereclause=yes name=nr_dias dbname="nr_dias" )
 column=(type=decimal(2) updatewhereclause=yes name=media_dia dbname="media_dia" )
 column=(type=decimal(2) updatewhereclause=yes name=media_mes dbname="media_mes" )
 column=(type=long updatewhereclause=yes name=ajuste_entrada dbname="ajuste_entrada" )
 column=(type=long updatewhereclause=yes name=ajuste_saida dbname="ajuste_saida" )
 column=(type=char(8) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=long updatewhereclause=yes name=qt_separacao dbname="qt_separacao" )
 retrieve="select  tudo.cd_produto, 
		g.de_produto, 
		g.de_apresentacao_estoque, 
		g.de_apresentacao_venda, 
		w.cd_subgrupo, 
		w.de_subgrupo,
		'00/00/0000' dt_ini,
		'00/00/0000' dt_ter, 
		v.qt_saldo_final as saldo , 
		sum(tudo.qt_transf) as qt_transf,
		0 nr_dias,
      	0.00 media_dia,
		0.00 media_mes,
		0 ajuste_entrada,
		0 ajuste_saida,
		(CASE g.id_situacao
			WHEN 'A' THEN 'ATIVO'
			WHEN 'I' THEN 'INATIVO'
			WHEN 'P' THEN 'PENDENTE'
			ELSE g.id_situacao
		END) id_situacao,
		0 qt_separacao
 
from (
			select pp.cd_produto, sum(qt_faturada) as qt_transf
			from	nf_almoxarifado p 
			inner join item_nf_almoxarifado pp on pp.nr_nf			= p.nr_nf
			inner join produto_geral g on g.cd_produto	= pp.cd_produto
			where	p.dh_cancelamento	is null
					and 	p.dh_movimentacao_caixa between:dt_inicio and :dt_termino
			group by pp.cd_produto
			
			union all
			
			select pp.cd_produto, sum(qt_transferida) as qt_transf
			from	nf_transferencia p 
			inner join item_nf_transferencia pp on pp.cd_filial_origem = p.cd_filial_origem and pp.nr_nf	= p.nr_nf and pp.de_especie  = p.de_especie and pp.de_serie = p.de_serie
			where p.dh_cancelamento	is null
			  and p.dh_movimentacao_caixa between:dt_inicio and :dt_termino
			  and p.cd_filial_origem = 534
			  and p.id_almoxarifado = 'S'
			group by pp.cd_produto
		) as tudo

inner join produto_geral g on g.cd_produto = tudo.cd_produto
inner join vw_saldo_atual_produto v on v.cd_produto	= tudo.cd_produto
inner join vw_classificacao_produto w on w.cd_subcategoria = g.cd_subcategoria
where v.cd_filial = 534
group by  tudo.cd_produto, 
		g.de_produto, 
		g.de_apresentacao_estoque, 
		g.de_apresentacao_venda, 
		g.id_situacao,
		w.cd_subgrupo, 
		w.de_subgrupo,
		v.qt_saldo_final" arguments=(("dt_inicio", date),("dt_termino", date))  sort="de_produto A de_apresentacao_estoque A de_apresentacao_venda A " )
