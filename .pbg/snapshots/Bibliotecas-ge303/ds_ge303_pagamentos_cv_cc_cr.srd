table(column=(type=char(3) updatewhereclause=yes name=tipo dbname="tipo" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=char(4) updatewhereclause=yes name=cd_conta_contabil dbname="cd_conta_contabil" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pago dbname="vl_pago" )
 retrieve="select 	'CV' as tipo,
			f.cd_filial cd_filial,   
			f.nm_fantasia nm_fantasia,
			case t.cd_convenio
				when 52575 then '1266'
				when 53724 then '1267'
				when 53725 then '1268'
				when 52718 then '1269'
				when 52349 then '1270'
			else '1112' end as cd_conta_contabil,
			sum(( m.vl_movimento + m.vl_desconto_concedido) - (m.vl_despesas_recebidas +  m.vl_juros_recebidos +  m.vl_multa_recebida)) vl_pago
from movimento_titulo_receber m //(index idx_conta_tipo_data_movto)
inner join titulo_receber t
	on t.nr_titulo  = m.nr_titulo
inner join convenio cv
	on cv.cd_convenio    = t.cd_convenio  
inner join filial f (index pk_filial)
//	on f.cd_filial     = m.cd_filial_movimento
	on f.cd_filial     = t.cd_filial
where  m.id_estorno     = 'N'
	and m.cd_tipo_movimento = 3
	and m.dh_movimento	  between :pdt_inicio and :pdt_termino
	and t.id_tipo_titulo = 'CV'
	and t.cd_convenio not in (51014, 52602, 53847)
	and not exists (select 1 
						from caixa c1 
						inner join controle_caixa cc1 on cc1.cd_caixa = c1.cd_caixa 
						inner join lancamento_caixa lc1 on lc1.cd_caixa = cc1.cd_caixa and lc1.nr_controle_caixa = cc1.nr_controle_caixa
						Where c1.id_caixa_geral = 'N'
							and lc1.nr_recibo_cobranca = m.nr_recibo_cobranca
							and lc1.cd_conta_fluxo_caixa in (2,212,218,219,220,221,222)
							and c1.cd_filial = m.cd_filial_movimento
							and cc1.dh_movimentacao_caixa = m.dh_movimento)
group by f.cd_filial,   
        		f.nm_fantasia,
			case t.cd_convenio
				when 52575 then '1266'
				when 53724 then '1267'
				when 53725 then '1268'
				when 52718 then '1269'
				when 52349 then '1270'
			else '1112' end

union all

select 	'CV1' as tipo,
			f.cd_filial cd_filial,   
			f.nm_fantasia nm_fantasia,
			case t.cd_convenio
				when 52575 then '1266'
				when 53724 then '1267'
				when 53725 then '1268'
				when 52718 then '1269'
				when 52349 then '1270'
			else '1112' end as cd_conta_contabil,
			sum(( m.vl_movimento + m.vl_desconto_concedido) - (m.vl_despesas_recebidas +  m.vl_juros_recebidos +  m.vl_multa_recebida)) vl_pago
from movimento_titulo_receber m //(index idx_conta_tipo_data_movto)
inner join titulo_receber t
	on t.nr_titulo  = m.nr_titulo
inner join convenio cv
	on cv.cd_convenio    = t.cd_convenio  
left outer join lancamento_caixa lc
	on lc.nr_recibo_cobranca = m.nr_recibo_cobranca
left outer join controle_caixa cc
	on cc.cd_caixa = lc.cd_caixa and 
		cc.nr_controle_caixa = lc.nr_controle_caixa
left outer join caixa cx
	on cx.cd_caixa = cc.cd_caixa and 
		cx.cd_filial = m.cd_filial_movimento
inner join filial f
	on f.cd_filial     = m.cd_filial_movimento
where  m.id_estorno     = 'N'
	and m.cd_tipo_movimento = 3
	and m.dh_movimento	  between :pdt_inicio and :pdt_termino
	and t.id_tipo_titulo = 'CV'
   and cc.dh_movimentacao_caixa between :pdt_inicio and :pdt_termino
	and cx.id_caixa_geral = 'N'
   and lc.cd_conta_fluxo_caixa in (2,212,218,219,220,221,222)
   and lc.nr_recibo_cobranca = m.nr_recibo_cobranca
group by f.cd_filial,   
			f.nm_fantasia,
			case t.cd_convenio
				when 52575 then '1266'
				when 53724 then '1267'
				when 53725 then '1268'
				when 52718 then '1269'
				when 52349 then '1270'
			else '1112' end

union all

select 	t.id_tipo_titulo,
			f.cd_filial,   
			f.nm_fantasia,   
			case when n.nr_nf is null then '1112' else '1192' end as cd_conta_contabil,
			sum(( m.vl_movimento + m.vl_desconto_concedido) - (m.vl_despesas_recebidas +  m.vl_juros_recebidos +  m.vl_multa_recebida))
from movimento_titulo_receber m //(index idx_conta_tipo_data_movto)
inner join titulo_receber t (index pk_titulo_receber)
	on t.nr_titulo  = m.nr_titulo
inner join cliente c (index pk_cliente)
	on c.cd_cliente = t.cd_cliente
inner join filial f (index pk_filial)
	on f.cd_filial  = m.cd_filial_movimento
left outer join nf_diversa n
	on n.cd_filial_origem = t.cd_filial_nf
	and n.nr_nf = t.nr_nf
	and n.de_especie = t.de_especie
	and n.de_serie = t.de_serie
where  m.id_estorno     = 'N'
	and m.cd_tipo_movimento = 3
	and m.dh_movimento	  between :pdt_inicio and :pdt_termino
	and t.id_tipo_titulo in ('CC','CR')
group by t.id_tipo_titulo,
			f.cd_filial,   
			f.nm_fantasia,
			case when n.nr_nf is null then '1112' else '1192' end" arguments=(("pdt_inicio", date),("pdt_termino", date))  sort="cd_filial A tipo A " )
