table(column=(type=long updatewhereclause=yes name=cd_porte dbname="cd_porte" )
 column=(type=char(9) updatewhereclause=yes name=de_porte dbname="de_porte" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="qt_estoque_base" )
 column=(type=long updatewhereclause=yes name=qt_dias_bloqueio dbname="qt_dias_bloqueio" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao dbname="dh_movimentacao" )
 column=(type=datetime updatewhereclause=yes name=dh_bloqueio dbname="dh_bloqueio" )
 retrieve="Select 	0 	cd_porte,
			'SEM PORTE' de_porte,
			0 qt_estoque_base,
			0 qt_dias_bloqueio,
			(select dh_movimentacao from parametro where id_parametro = '1') dh_movimentacao,					
			convert(datetime, null) dh_bloqueio

union

Select distinct 	cd_porte,
						'PORTE ' + CONVERT( CHAR(1), cd_porte) de_porte,
						0 qt_estoque_base,
						0 qt_dias_bloqueio,
						(select dh_movimentacao from parametro where id_parametro = '1') dh_movimentacao,					
						convert(datetime, null) dh_bloqueio
From porte_loja_limite
"  sort="cd_porte A " )
