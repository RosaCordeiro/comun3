table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_compra.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_filial dbname="filial.nm_filial" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="nf_compra.cd_fornecedor" )
 column=(type=char(53) updatewhereclause=yes name=nm_fornecedor dbname="nm_fornecedor" )
 column=(type=long updatewhereclause=yes name=nr_pedido_central dbname="nf_compra.nr_pedido_central" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_compra.dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_compra.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_compra.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_compra.de_serie" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_compra.cd_produto" )
 column=(type=char(102) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="item_nf_compra.qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="item_nf_compra.qt_recebida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_compra.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="item_nf_compra.pc_desconto" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_total_recebido dbname="vl_total_recebido" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_total_faturado dbname="vl_total_faturado" )
 retrieve="select 	n.cd_filial, 
			f.nm_fantasia as nm_filial, 
			n.cd_fornecedor,
			fo.nm_fantasia||' ('||Cast(n.cd_fornecedor as varchar(10))||')' as nm_fornecedor,
			n.nr_pedido_central,
			n.dh_movimentacao_caixa,
			n.nr_nf, 
			n.de_especie, 
			n.de_serie, 
			i.cd_produto, 
			p.de_produto||': '||p.de_apresentacao_venda as de_produto, 
			i.qt_faturada,
			i.qt_recebida,
			i.vl_preco_unitario,
			i.pc_desconto,
			i.qt_recebida * round(i.vl_preco_unitario * (1 - (i.pc_desconto / 100)),2) as vl_total_recebido,
			i.qt_faturada * round(i.vl_preco_unitario * (1 - (i.pc_desconto / 100)),2) as vl_total_faturado
from nf_compra n
inner join pedido_central pd
	on pd.nr_pedido = n.nr_pedido_central
inner join item_nf_compra i
	on i.cd_filial = n.cd_filial and
		i.nr_nf = n.nr_nf and
		i.de_especie = n.de_especie and
		i.de_serie = n.de_serie
inner join filial f
	on f.cd_filial = n.cd_filial
inner join produto_geral p
	on p.cd_produto = i.cd_produto
inner join fornecedor fo
	on fo.cd_fornecedor = n.cd_fornecedor
where pd.id_pbm = 'S' and
		n.dh_movimentacao_caixa between :dt_inicio and :dt_fim" arguments=(("dt_inicio", date),("dt_fim", date)) )
