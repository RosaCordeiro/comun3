table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_devolucao_compra.cd_filial" dbalias="n.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_filial dbname="filial.nm_filial" dbalias="f.nm_filial" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="nf_devolucao_compra.cd_fornecedor" dbalias="n.cd_fornecedor" )
 column=(type=char(53) updatewhereclause=yes name=nm_fornecedor dbname="nm_fornecedor" )
 column=(type=long updatewhereclause=yes name=nr_pedido_central dbname="nf_compra.nr_pedido_central" dbalias="cp.nr_pedido_central" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_devolucao_compra.dh_movimentacao_caixa" dbalias="n.dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_devolucao_compra.nr_nf" dbalias="n.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_devolucao_compra.de_especie" dbalias="n.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_devolucao_compra.de_serie" dbalias="n.de_serie" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_devolucao_compra.cd_produto" dbalias="i.cd_produto" )
 column=(type=char(102) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_devolvida dbname="item_nf_devolucao_compra.qt_devolvida" dbalias="i.qt_devolvida" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_devolucao_compra.vl_preco_unitario" dbalias="i.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="item_nf_devolucao_compra.pc_desconto" dbalias="i.pc_desconto" )
 column=(type=decimal(17) updatewhereclause=yes name=vl_total_item dbname="vl_total_item" )
 column=(type=long updatewhereclause=yes name=nr_nf_compra dbname="nf_devolucao_compra.nr_nf_compra" dbalias="n.nr_nf_compra" )
 column=(type=char(3) updatewhereclause=yes name=de_serie_compra dbname="nf_devolucao_compra.de_serie_compra" dbalias="n.de_serie_compra" )
 column=(type=char(3) updatewhereclause=yes name=de_especie_compra dbname="nf_devolucao_compra.de_especie_compra" dbalias="n.de_especie_compra" )
 retrieve="select 	n.cd_filial, 
			f.nm_fantasia as nm_filial, 
			n.cd_fornecedor,
			fo.nm_fantasia||' ('||Cast(n.cd_fornecedor as varchar(10))||')' as nm_fornecedor,
			cp.nr_pedido_central,
			n.dh_movimentacao_caixa,
			n.nr_nf, 
			n.de_especie, 
			n.de_serie, 
			i.cd_produto, 
			p.de_produto||': '||p.de_apresentacao_venda as de_produto, 
			i.qt_devolvida,
			i.vl_preco_unitario,
			i.pc_desconto,
			i.qt_devolvida * round(i.vl_preco_unitario * (1 - (i.pc_desconto / 100)),2) as vl_total_item,
			n.nr_nf_compra,
			n.de_serie_compra,
			n.de_especie_compra
from nf_devolucao_compra n
inner join nf_compra cp
	on cp.cd_filial = n.cd_filial and 
		cp.nr_nf = n.nr_nf_compra and
		cp.de_serie = n.de_serie_compra and
		cp.de_especie = n.de_especie_compra and
		cp.cd_fornecedor = n.cd_fornecedor
inner join pedido_central pd
	on pd.nr_pedido = cp.nr_pedido_central
inner join item_nf_devolucao_compra i
	on i.cd_filial = n.cd_filial and
		i.nr_nf = n.nr_nf and
		i.de_especie = n.de_especie and
		i.de_serie = n.de_serie
inner join filial f
	on f.cd_filial = n.cd_filial
inner join produto_geral p
	on p.cd_produto = i.cd_produto
inner join fornecedor fo
	on fo.cd_fornecedor = n.cd_fornecedor
where pd.id_pbm = 'S' and
		n.dh_cancelamento is null and
		n.dh_movimentacao_caixa between :dt_inicio and :dt_fim

Union 

select 	n.cd_filial, 
			f.nm_fantasia as nm_filial, 
			n.cd_fornecedor,
			fo.nm_fantasia||' ('||Cast(n.cd_fornecedor as varchar(10))||')' as nm_fornecedor,
			cp.nr_pedido_central,
			n.dh_movimentacao_caixa,
			n.nr_nf, 
			n.de_especie, 
			n.de_serie, 
			i.cd_produto, 
			p.de_produto||': '||p.de_apresentacao_venda as de_produto, 
			i.qt_devolvida,
			i.vl_preco_unitario,
			i.pc_desconto,
			i.qt_devolvida * round(i.vl_preco_unitario * (1 - (i.pc_desconto / 100)),2) as vl_total_item,
			n.nr_nf_compra,
			n.de_serie_compra,
			n.de_especie_compra
from nf_devolucao_compra n
inner join nf_compra cp
	on cp.cd_filial = n.cd_filial and 
		cp.nr_nf = n.nr_nf_compra and
		cp.de_serie = n.de_serie_compra and
		cp.de_especie = n.de_especie_compra and
		cp.cd_fornecedor = n.cd_fornecedor
inner join pedido_central pd
	on pd.nr_pedido = cp.nr_pedido_central
inner join nf_devolucao_compra_produto i
	on i.cd_filial = n.cd_filial and
		i.nr_nf = n.nr_nf and
		i.de_especie = n.de_especie and
		i.de_serie = n.de_serie
inner join filial f
	on f.cd_filial = n.cd_filial
inner join produto_geral p
	on p.cd_produto = i.cd_produto
inner join fornecedor fo
	on fo.cd_fornecedor = n.cd_fornecedor
where pd.id_pbm = 'S' and
		n.dh_cancelamento is null and
		n.dh_movimentacao_caixa between :dt_inicio and :dt_fim" arguments=(("dt_inicio", date),("dt_fim", date)) )
