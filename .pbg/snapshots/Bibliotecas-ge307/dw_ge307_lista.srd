table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_recarga dbname="recarga_celular.dh_recarga" )
 column=(type=char(15) updatewhereclause=yes name=de_concessionaria dbname="recarga_celular.de_concessionaria" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_recarga dbname="compute_0005" )
 retrieve="  SELECT filial.cd_filial,
         filial.nm_fantasia,
         rc.dh_recarga,
         rc.de_concessionaria,
         sum(rc.vl_recarga)
    FROM filial,   
         recarga_celular rc
   WHERE ( rc.cd_filial = filial.cd_filial ) 
     and ( rc.dh_recarga between :inicio and :termino )
     and ( rc.id_cancelado = null )
GROUP BY filial.cd_filial,
         filial.nm_fantasia,
         rc.dh_recarga,
         rc.de_concessionaria
" arguments=(("inicio", date),("termino", date))  sort="cd_filial A nm_fantasia A dh_recarga A de_concessionaria A " )
