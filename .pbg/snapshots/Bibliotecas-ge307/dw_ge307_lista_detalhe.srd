table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" )
 column=(type=char(15) updatewhereclause=yes name=de_concessionaria dbname="recarga_celular.de_concessionaria" )
 column=(type=char(16) updatewhereclause=yes name=nr_telefone dbname="recarga_celular.nr_telefone" )
 column=(type=char(9) updatewhereclause=yes name=nr_nsu dbname="recarga_celular.nr_nsu" )
 column=(type=datetime updatewhereclause=yes name=dh_recarga dbname="recarga_celular.dh_recarga" )
 column=(type=char(8) updatewhereclause=yes name=hr_recarga dbname="recarga_celular.hr_recarga" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_recarga dbname="recarga_celular.vl_recarga" )
 column=(type=char(1) updatewhereclause=yes name=id_cancelado dbname="recarga_celular.id_cancelado" )
 column=(type=char(9) updatewhereclause=yes name=nr_nsu_sitef dbname="recarga_celular.nr_nsu_sitef" )
 column=(type=char(1) updatewhereclause=yes name=id_conciliada dbname="id_conciliada" )
 retrieve="  SELECT filial.cd_filial,
         filial.nm_fantasia,
         cidade.nm_cidade,
         cidade.cd_unidade_federacao,
         rc.de_concessionaria,
         rc.nr_telefone,
         rc.nr_nsu,
         rc.dh_recarga,
         rc.hr_recarga,
         rc.vl_recarga,
         rc.id_cancelado,
         rc.nr_nsu_sitef,
         coalesce(rc.id_conciliada, 'N') id_conciliada
    FROM filial,   
         recarga_celular rc,
         cidade
   WHERE ( rc.cd_filial = filial.cd_filial ) 
     and ( cidade.cd_cidade = filial.cd_cidade )
     and ( rc.dh_recarga between :inicio and :termino )
" arguments=(("inicio", date),("termino", date))  sort="cd_filial A nm_fantasia A de_concessionaria A dh_recarga A hr_recarga A " )
