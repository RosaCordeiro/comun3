table(column=(type=char(15) updatewhereclause=yes name=de_concessionaria dbname="recarga_celular.de_concessionaria" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_recarga dbname="recarga_celular.vl_recarga" )
 column=(type=long updatewhereclause=yes name=qt_recarga dbname="qt_recarga" )
 retrieve="  SELECT de_concessionaria,
			vl_recarga,
         count(*)
    FROM recarga_celular
   WHERE ( dh_recarga between :inicio and :termino )
     and ( id_cancelado = null )
GROUP BY de_concessionaria,
         vl_recarga
" arguments=(("inicio", date),("termino", date))  sort="de_concessionaria A vl_recarga A " )
