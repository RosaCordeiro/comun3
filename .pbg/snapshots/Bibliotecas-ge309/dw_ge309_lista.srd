table(column=(type=long updatewhereclause=yes name=cd_filial dbname="resumo_movimento_estoque.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=id_ordem dbname="id_ordem" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_dinheiro dbname="vl_venda_dinheiro" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_cartao_debito dbname="vl_venda_cartao_debito" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_cartao_debito_recarga dbname="vl_venda_cartao_debito_recarga" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_cartao_deb_pagto_tit dbname="vl_venda_cartao_deb_pagto_tit" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_cheque_avista dbname="vl_venda_cheque_avista" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_crediario dbname="vl_venda_crediario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_convenio dbname="vl_venda_convenio" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_conta_corrente dbname="vl_venda_conta_corrente" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_cartao_credito dbname="vl_venda_cartao_credito" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_cheque_aprazo dbname="vl_venda_cheque_aprazo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_devolucao_venda dbname="vl_devolucao_venda" )
 retrieve="select r.cd_filial,
       f.nm_fantasia,
       case r.cd_filial when 534 then '2' else '1' end id_ordem,
       sum(r.vl_venda_avista)					as vl_venda_dinheiro,
       sum(r.vl_venda_cartao_debito)		as vl_venda_cartao_debito,
       0.00											as vl_venda_cartao_debito_recarga,
       0.00											as vl_venda_cartao_deb_pagto_tit,
       sum(r.vl_venda_cheque_avista)		as vl_venda_cheque_avista,   
       sum(r.vl_venda_crediario)				as vl_venda_crediario,
       sum(r.vl_venda_convenio)				as vl_venda_convenio,
       sum(r.vl_venda_conta_corrente)		as vl_venda_conta_corrente,
       sum(r.vl_venda_cartao_credito)		as vl_venda_cartao_credito,
       sum(r.vl_venda_cheque_aprazo)		as vl_venda_cheque_aprazo,
       sum(r.vl_devolucao_venda)			as vl_devolucao_venda
from resumo_movimento_estoque r
inner join filial f
  on f.cd_filial = r.cd_filial
where r.dh_resumo between :inicio and :termino
  and r.cd_filial <> 1
group by r.cd_filial,
         f.nm_fantasia
" arguments=(("inicio", date),("termino", date))  sort="id_ordem A nm_fantasia A " )
