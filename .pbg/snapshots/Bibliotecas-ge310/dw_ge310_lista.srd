table(column=(type=long updatewhereclause=yes key=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long update=yes updatewhereclause=yes name=nr_prioridade_faturamento dbname="filial.nr_prioridade_faturamento" )
 column=(type=char(1) updatewhereclause=yes name=id_24horas dbname="filial.id_24horas" values="N$$HEX1$$c300$$ENDHEX$$O	N/SIM	S/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_periodo_faturamento dbname="filial.id_periodo_faturamento" values="MANH$$HEX1$$c300$$ENDHEX$$	M/TARDE	T/	/" )
 column=(type=long update=yes updatewhereclause=yes name=nr_rota_entrega dbname="filial.nr_rota_entrega" )
 column=(type=long update=yes updatewhereclause=yes name=nr_dias_entrega dbname="filial.nr_dias_entrega" )
 retrieve="  SELECT filial.cd_filial,   
         filial.nm_fantasia,   
         filial.nr_prioridade_faturamento,   
         filial.id_24horas,   
         filial.id_periodo_faturamento,   
         filial.nr_rota_entrega,
		filial.nr_dias_entrega  
    FROM filial  
   WHERE filial.id_situacao = 'A'    
" update="filial" updatewhere=1 updatekeyinplace=yes  sort="nr_prioridade_faturamento A " )
