table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="nm_fantasia" )
 column=(type=char(14) updatewhereclause=yes name=filial_nr_cgc dbname="nr_cgc" )
 column=(type=char(15) updatewhereclause=yes name=filial_nr_inscricao_estadual dbname="nr_inscricao_estadual" )
 column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="grupo.cd_grupo" dbalias="g.cd_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="grupo.de_grupo" dbalias="g.de_grupo" )
 column=(type=datetime updatewhereclause=yes name=saldo_produto_dh_saldo dbname="dh_saldo" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="qt_saldo_final" )
 column=(type=long updatewhereclause=yes name=nr_classificacao_fiscal dbname="produto_geral.nr_classificacao_fiscal" dbalias="pg.nr_classificacao_fiscal" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="historico_produto.cd_produto" dbalias="h.cd_produto" )
 column=(type=char(102) updatewhereclause=yes name=de_apres_venda dbname="de_apres_venda" )
 column=(type=char(102) updatewhereclause=yes name=de_apres_estoque dbname="de_apres_estoque" )
 column=(type=char(3) updatewhereclause=yes name=historico_produto_cd_unidade_medida_vend dbname="historico_produto.cd_unidade_medida_venda" dbalias="h.cd_unidade_medida_venda" )
 column=(type=char(3) updatewhereclause=yes name=historico_produto_cd_unidade_medida_comp dbname="historico_produto.cd_unidade_medida_compra" dbalias="h.cd_unidade_medida_compra" )
 column=(type=decimal(13) updatewhereclause=yes name=custo_medio dbname="custo_medio" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_medio dbname="vl_custo_medio" )
 column=(type=char(1) updatewhereclause=yes name=id_proprio_consignado dbname="historico_produto.id_proprio_consignado" dbalias="h.id_proprio_consignado" values="PRODUTOS PR$$HEX1$$d300$$ENDHEX$$PRIOS	P/PRODUTOS CONSIGNADOS	C/" )
 column=(type=char(1) updatewhereclause=yes name=msg_transporte dbname="msg_transporte" )
 column=(type=long updatewhereclause=yes name=linha dbname="linha" )
 retrieve="  SELECT f.cd_filial,   
			f.nm_fantasia,   
			f.nr_cgc,   
			f.nr_inscricao_estadual,   
			g.cd_grupo,   
			g.de_grupo,   
			s.dh_saldo,   
			s.qt_saldo_final,   
			pg.nr_classificacao_fiscal,
			h.cd_produto,   
			h.de_produto+': '+h.de_apresentacao_venda   as de_apres_venda,   
			h.de_produto+': '+h.de_apresentacao_estoque as de_apres_estoque,   
			h.cd_unidade_medida_venda,   
			h.cd_unidade_medida_compra,   
			round(h.vl_custo_medio / h.vl_fator_conversao,2) as custo_medio,
			s.vl_custo_medio,
			h.id_proprio_consignado,
			'' msg_transporte,
			0 linha  
    FROM filial f (index pk_filial)
Inner Join saldo_produto s (index saldo_prod_5850531202)
	On s.cd_filial = f.cd_filial
Inner Join historico_produto h
	On	h.cd_produto	= s.cd_produto and 
		h.dh_historico	= s.dh_saldo
Inner Join produto_geral pg
	On pg.cd_produto = s.cd_produto
Inner Join grupo g
	On g.cd_grupo = substring(h.cd_subcategoria,1,1)
WHERE f.cd_filial			in (:cd_filial,:cd_filial_2)
     and h.dh_historico		= :dh_inventario
     And h.vl_custo_medio>= 0
     and s.qt_saldo_final	> 0 
     and s.cd_produto  in (684431,577625)    " arguments=(("cd_filial", number),("cd_filial_2", number),("dh_inventario", date))  sort="id_proprio_consignado A cd_grupo A linha A de_descricao_produto A " )
