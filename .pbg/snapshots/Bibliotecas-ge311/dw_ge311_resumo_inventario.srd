table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(14) update=yes updatewhereclause=yes name=nr_cgc dbname="filial.nr_cgc" )
 column=(type=char(15) update=yes updatewhereclause=yes name=nr_inscricao_estadual dbname="filial.nr_inscricao_estadual" )
 column=(type=char(1) updatewhereclause=yes name=msg dbname="Msg" )
 column=(type=char(1) updatewhereclause=yes name=grupo dbname="Grupo" values="PRODUTOS PR$$HEX1$$d300$$ENDHEX$$PRIOS	P/PRODUTOS CONSIGNADOS	C/" )
 column=(type=decimal(2) updatewhereclause=yes name=valor dbname="Valor" )
 column=(type=long updatewhereclause=yes name=linha dbname="Linha" initial="RowCount()" )
 retrieve=" SELECT	f.cd_filial,   
			f.nm_fantasia,   
			f.nr_cgc,   
			f.nr_inscricao_estadual,
			'' Msg,
			'' Grupo,
			0.00 Valor,
			0 Linha
    FROM filial f
   WHERE f.cd_filial = :cd_filial
" update="filial" updatewhere=1 updatekeyinplace=no arguments=(("cd_filial", number))  sort="cd_filial D grupo A " )
