table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="filial.nm_razao_social" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="filial.nr_cgc" )
 column=(type=char(15) updatewhereclause=yes name=nr_inscricao_estadual dbname="filial.nr_inscricao_estadual" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" )
 column=(type=char(20) updatewhereclause=yes name=de_bairro dbname="filial.de_bairro" )
 column=(type=char(40) updatewhereclause=yes name=de_endereco dbname="filial.de_endereco" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" )
 column=(type=char(11) updatewhereclause=yes name=nr_inscricao_junta_comercial dbname="filial.nr_inscricao_junta_comercial" )
 column=(type=datetime updatewhereclause=yes name=dh_inscricao_junta_comercial dbname="filial.dh_inscricao_junta_comercial" )
 column=(type=char(1) updatewhereclause=yes name=termo dbname="termo" )
 column=(type=long updatewhereclause=yes name=paginas dbname="paginas" )
 column=(type=char(1) updatewhereclause=yes name=dia_mes_ano dbname="dia_mes_ano" )
 column=(type=char(1) updatewhereclause=yes name=de_rede dbname="de_rede" )
 column=(type=long updatewhereclause=yes name=nr_ordem dbname="nr_ordem" )
 retrieve="  SELECT f.cd_filial,   
         f.nm_razao_social,   
         f.nr_cgc,   
         f.nr_inscricao_estadual,   
         c.nm_cidade,   
         f.de_bairro,   
         f.de_endereco,   
         c.cd_unidade_federacao,   
         f.nr_inscricao_junta_comercial,  
         f.dh_inscricao_junta_comercial,
         '' termo,   
         0 paginas,   
         '' dia_mes_ano,
		'' de_rede,
		0 nr_ordem
    FROM filial f
Inner Join cidade c
	On c.cd_cidade = f.cd_cidade
   WHERE( f.cd_filial = :cd_filial ) 
" arguments=(("cd_filial", number))  sort="termo A " )
group(level=1 header.height=0 trailer.height=0 by=("termo" ) newpage=yes header.color="553648127" header.transparency="0" header.gradient.color="8421504" header.gradient.transparency="0" header.gradient.angle="0" header.brushmode="0" header.gradient.repetition.mode="0" header.gradient.repetition.count="0" header.gradient.repetition.length="100" header.gradient.focus="0" header.gradient.scale="100" header.gradient.spread="100" trailer.color="536870912" trailer.transparency="0" trailer.gradient.color="8421504" trailer.gradient.transparency="0" trailer.gradient.angle="0" trailer.brushmode="0" trailer.gradient.repetition.mode="0" trailer.gradient.repetition.count="0" trailer.gradient.repetition.length="100" trailer.gradient.focus="0" trailer.gradient.scale="100" trailer.gradient.spread="100" )
