table(column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="controle_caixa.cd_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_abertura_caixa dbname="controle_caixa.dh_abertura_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="controle_caixa.dh_movimentacao_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_fechamento_caixa dbname="controle_caixa.dh_fechamento_caixa" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="controle_caixa.nr_controle_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_saldo_final dbname="controle_caixa.vl_saldo_final" )
 column=(type=datetime updatewhereclause=yes name=dh_conferencia dbname="controle_caixa.dh_conferencia" )
 column=(type=char(40) updatewhereclause=yes name=usuario_nm_usuario dbname="usuario.nm_usuario" )
 column=(type=char(1) updatewhereclause=yes name=id_contem_anexos dbname="id_contem_anexos" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 retrieve="select c.cd_caixa,
		c.dh_abertura_caixa,
		c.dh_movimentacao_caixa,   
		c.dh_fechamento_caixa,   
		c.nr_controle_caixa,   
		c.vl_saldo_final,   
		c.dh_conferencia,
		u.nm_usuario,
		case when coalesce(c.nr_contador_anexos,0) > 0 Then 'S' else 'N' end id_contem_anexos
from controle_caixa c
     left outer join usuario u on u.nr_matricula = c.nr_matricula_fechamento
where c.cd_caixa = :caixa
  and c.dh_movimentacao_caixa between :inicio and :termino
" arguments=(("caixa", string),("inicio", date),("termino", date))  sort="nr_controle_caixa D " )
