table(column=(type=long updatewhereclause=yes name=cd_conta_fluxo_caixa dbname="lancamento_caixa.cd_conta_fluxo_caixa" dbalias="lc.cd_conta_fluxo_caixa" )
 column=(type=char(40) updatewhereclause=yes name=de_conta_fluxo_caixa dbname="conta_fluxo_caixa.de_conta_fluxo_caixa" dbalias="co.de_conta_fluxo_caixa" )
 column=(type=char(50) updatewhereclause=yes name=de_historico dbname="lancamento_caixa.de_historico" dbalias="lc.de_historico" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_lancamento dbname="lancamento_caixa.vl_lancamento" dbalias="lc.vl_lancamento" )
 column=(type=char(1) updatewhereclause=yes name=id_credito_debito dbname="conta_fluxo_caixa.id_credito_debito" dbalias="co.id_credito_debito" )
 column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="lancamento_caixa.cd_caixa" dbalias="lc.cd_caixa" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="lancamento_caixa.nr_controle_caixa" dbalias="lc.nr_controle_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="controle_caixa.dh_movimentacao_caixa" dbalias="cc.dh_movimentacao_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_abertura_caixa dbname="controle_caixa.dh_abertura_caixa" dbalias="cc.dh_abertura_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_fechamento_caixa dbname="controle_caixa.dh_fechamento_caixa" dbalias="cc.dh_fechamento_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_conferencia dbname="controle_caixa.dh_conferencia" dbalias="cc.dh_conferencia" )
 column=(type=decimal(2) updatewhereclause=yes name=controle_caixa_saldo_dia_anterior dbname="saldo_dia_anterior" )
 column=(type=datetime updatewhereclause=yes name=dh_lancamento dbname="lancamento_caixa.dh_lancamento" dbalias="lc.dh_lancamento" )
 column=(type=long updatewhereclause=yes name=nr_lancamento dbname="lancamento_caixa.nr_lancamento" dbalias="lc.nr_lancamento" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="fi.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" dbalias="fi.cd_filial" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_gerente dbname="filial.nr_matricula_gerente" dbalias="fi.nr_matricula_gerente" )
 column=(type=char(40) updatewhereclause=yes name=caixa_de_caixa dbname="caixa.de_caixa" dbalias="ca.de_caixa" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_operador dbname="controle_caixa.nr_matricula_operador" dbalias="cc.nr_matricula_operador" )
 column=(type=char(40) updatewhereclause=yes name=usuario_nm_usuario dbname="usuario.nm_usuario" dbalias="us.nm_usuario" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_conferencia dbname="controle_caixa.nr_matricula_conferencia" dbalias="cc.nr_matricula_conferencia" )
 column=(type=char(1) updatewhereclause=yes name=id_estorno dbname="lancamento_caixa.id_estorno" dbalias="lc.id_estorno" )
 column=(type=char(20) updatewhereclause=yes name=nr_documento dbname="lancamento_caixa.nr_documento" dbalias="lc.nr_documento" )
 column=(type=char(40) updatewhereclause=yes name=cd_filial_sap dbname="integracao_sap.cd_filial_sap" dbalias="isp.cd_filial_sap" )
 retrieve="select lc.cd_conta_fluxo_caixa,   
       co.de_conta_fluxo_caixa,   
       lc.de_historico,   
       lc.vl_lancamento,   
       co.id_credito_debito,   
       lc.cd_caixa,   
       lc.nr_controle_caixa,   
       cc.dh_movimentacao_caixa,
       cc.dh_abertura_caixa,   
       cc.dh_fechamento_caixa,   
       cc.dh_conferencia,
       0.00 saldo_dia_anterior,   
       lc.dh_lancamento,
       lc.nr_lancamento,
       fi.nm_fantasia,
	  fi.cd_filial,
       fi.nr_matricula_gerente,
       ca.de_caixa,
       cc.nr_matricula_operador,
       us.nm_usuario,
       cc.nr_matricula_conferencia,
		 lc.id_estorno,
		lc.nr_documento,
		isp.cd_chave_sap as  cd_filial_sap
from 	controle_caixa cc
Inner Join lancamento_caixa lc
	on lc.cd_caixa = cc.cd_caixa
	and lc.nr_controle_caixa = cc.nr_controle_caixa
Inner Join conta_fluxo_caixa co
	on  co.cd_conta_fluxo_caixa = lc.cd_conta_fluxo_caixa
Inner Join caixa ca
	on ca.cd_caixa             = cc.cd_caixa
Inner Join filial fi
	on fi.cd_filial = ca.cd_filial
Left Outer Join	usuario us
  	on us.nr_matricula = cc.nr_matricula_operador
Left Outer Join integracao_sap isp
	on isp.cd_empresa = 1000
	and isp.cd_tabela = 'FILIAL'
	and isp.cd_chave_legado = cast(fi.cd_filial as varchar)
where cc.cd_caixa          = :cd_caixa
  and cc.nr_controle_caixa = :nr_controle_caixa
" arguments=(("cd_caixa", string),("nr_controle_caixa", number))  sort="nr_lancamento A " )
