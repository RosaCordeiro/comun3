table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_maximo_caixa dbname="filial.vl_maximo_caixa" )
 column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="controle_caixa.cd_caixa" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="controle_caixa.nr_controle_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="controle_caixa.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_saldo_final dbname="controle_caixa.vl_saldo_final" initial="000.00" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_saldo_especie dbname="vl_saldo_especie" initial="000.00" )
 retrieve="select fi.cd_filial,
       fi.nm_fantasia,   
       fi.vl_maximo_caixa,
       cc.cd_caixa,
       cc.nr_controle_caixa,   
       cc.dh_movimentacao_caixa,   
       cc.vl_saldo_final,
       000.00 vl_saldo_especie  
from controle_caixa cc,   
     caixa cx,   
     filial fi
where cc.dh_movimentacao_caixa between :inicio and :termino
  and cx.cd_caixa  = cc.cd_caixa
  and cx.id_caixa_geral = 'S'
  and fi.cd_filial = cx.cd_filial
" arguments=(("inicio", date),("termino", date))  sort="dh_movimentacao_caixa D nm_fantasia A " )
