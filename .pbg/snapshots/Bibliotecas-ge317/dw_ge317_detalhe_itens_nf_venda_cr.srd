table(column=(type=char(60) updatewhereclause=yes name=produto_geral_de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=produto_geral_de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=long updatewhereclause=yes name=item_nf_venda_cd_produto dbname="item_nf_venda.cd_produto" )
 column=(type=char(2) updatewhereclause=yes name=item_nf_venda_cd_situacao_tributaria dbname="item_nf_venda.cd_situacao_tributaria" values="ISENTA	I/" )
 column=(type=long updatewhereclause=yes name=item_nf_venda_qt_vendida dbname="item_nf_venda.qt_vendida" )
 column=(type=decimal(2) updatewhereclause=yes name=item_nf_venda_vl_preco_unitario dbname="item_nf_venda.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=item_nf_venda_vl_preco_praticado dbname="item_nf_venda.vl_preco_praticado" )
 column=(type=decimal(2) updatewhereclause=yes name=item_nf_venda_pc_desconto_tabela dbname="item_nf_venda.pc_desconto_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=item_nf_venda_pc_icms dbname="item_nf_venda.pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=item_nf_venda_pc_comissao_extra dbname="item_nf_venda.pc_comissao_extra" )
 column=(type=decimal(2) updatewhereclause=yes name=item_nf_venda_pc_comissao_normal dbname="item_nf_venda.pc_comissao_normal" )
 retrieve="select p.de_produto,
       p.de_apresentacao_venda,
       i.cd_produto,
       i.cd_situacao_tributaria,
       i.qt_vendida,
       i.vl_preco_unitario,
       i.vl_preco_praticado,
       i.pc_desconto_tabela,
       i.pc_icms,
       i.pc_comissao_extra,
       i.pc_comissao_normal
from item_nf_venda i,
     produto_geral p   
where p.cd_produto 	= i.cd_produto
  and i.cd_filial  		= :pl_filial
  and i.nr_nf      		= :pl_nr_nf
  and i.de_especie 	= :ps_especie
  and i.de_serie   		= :ps_serie" arguments=(("pl_filial", number),("pl_nr_nf", number),("ps_especie", string),("ps_serie", string))  sort="de_produto A " )
