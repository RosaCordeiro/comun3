table(column=(type=long updatewhereclause=yes key=yes name=nf_venda_nr_nf dbname="nf_venda.nr_nf" )
 column=(type=char(3) updatewhereclause=yes key=yes name=nf_venda_de_especie dbname="nf_venda.de_especie" )
 column=(type=char(3) updatewhereclause=yes key=yes name=nf_venda_de_serie dbname="nf_venda.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_venda.dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_venda.dh_movimentacao_caixa" )
 column=(type=char(2) updatewhereclause=yes name=nf_venda_id_tipo_venda dbname="nf_venda.id_tipo_venda" values="$$HEX1$$c000$$ENDHEX$$ VISTA	AV/CONTA CORRENTE	CC/CONV$$HEX1$$ca00$$ENDHEX$$NIO	CV/CREDI$$HEX1$$c100$$ENDHEX$$RIO	CR/" )
 column=(type=long updatewhereclause=yes name=nf_venda_cd_filial dbname="nf_venda.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia_filial dbname="filial.nm_fantasia_filial" )
 column=(type=char(2) update=yes updatewhereclause=yes key=yes name=cd_forma_pagamento dbname="nf_venda.cd_forma_pagamento" )
 column=(type=long updatewhereclause=yes name=existe_log dbname="existe_log" )
 retrieve="SELECT 	nf_venda.nr_nf,   
			nf_venda.de_especie,   
			nf_venda.de_serie,
			nf_venda.dh_emissao,  
			nf_venda.dh_movimentacao_caixa,   
			nf_venda.id_tipo_venda,
			nf_venda.cd_filial cd_filial,
			f.nm_fantasia nm_fantasia_filial,
			nf_venda.cd_forma_pagamento,

			( select count(1)
			from log_exportacao_docto a
				inner join log_exportacao_docto_det b
					on a.nr_atualizacao = b.nr_atualizacao_log
			where a.cd_filial 				= nf_venda.cd_filial
				and a.nr_nf 					= nf_venda.nr_nf
				and a.de_especie 			= nf_venda.de_especie
				and a.de_serie 				= nf_venda.de_serie
				and a.cd_ambiente_sap 	in ('SPQ','PRD')
				and b.cd_setor 				= 'FIN'
				and id_situacao_log		= 'E' ) as existe_log

    FROM nf_venda 
		inner join filial f
			on  nf_venda.cd_filial = f.cd_filial

 WHERE nf_venda.cd_filial           		 				  = :pl_Filial
   and nf_venda.nr_nf                 		 				  = :pl_Nr_Nf
   and nf_venda.de_especie            		 			  = :ps_Especie 
   and nf_venda.de_serie              		 			  = :ps_Serie

 " update="nf_venda" updatewhere=1 updatekeyinplace=yes arguments=(("pl_Filial", number),("pl_Nr_Nf", number),("ps_especie", string),("ps_serie", string)) )
