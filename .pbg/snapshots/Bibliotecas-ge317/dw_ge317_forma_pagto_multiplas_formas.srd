table(column=(type=long updatewhereclause=yes key=yes name=nr_sequencial dbname="nf_venda_pagamento.nr_sequencial" )
 column=(type=char(2) update=yes updatewhereclause=yes name=cd_forma_pagamento dbname="nf_venda_pagamento.cd_forma_pagamento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pagamento dbname="nf_venda_pagamento.vl_pagamento" )
 column=(type=long updatewhereclause=yes name=existe_log dbname="existe_log" )
 column=(type=long updatewhereclause=yes key=yes name=cd_filial dbname="nf_venda_pagamento.cd_filial" )
 column=(type=long updatewhereclause=yes key=yes name=nr_nf dbname="nf_venda_pagamento.nr_nf" )
 column=(type=char(3) updatewhereclause=yes key=yes name=de_especie dbname="nf_venda_pagamento.de_especie" )
 column=(type=char(3) updatewhereclause=yes key=yes name=de_serie dbname="nf_venda_pagamento.de_serie" )
 retrieve="select a.nr_sequencial,
		a.cd_forma_pagamento,
		a.vl_pagamento,

		( select count(1)
			from log_exportacao_docto b
	 			inner join log_exportacao_docto_det c
					on b.nr_atualizacao	= c.nr_atualizacao_log
			where  b.cd_filial 				= a.cd_filial
				and b.nr_nf 					= a.nr_nf
				and b.de_especie 			= a.de_especie
				and b.de_serie 				= a.de_serie
				and b.cd_ambiente_sap in ('SPQ','PRD')
				and c.cd_setor 				= 'FIN'
				and b.id_situacao_log		in ('E', 'C')
			) as existe_log,

a.cd_filial,
a.nr_nf,
a.de_especie,
a.de_serie

from nf_venda_pagamento a
where a.cd_filial 		= :p_cd_filial
	and a.nr_nf 			= :p_nr_nf 
	and a.de_especie 	= :p_de_especie
	and a.de_serie 		= :p_de_serie" update="nf_venda_pagamento" updatewhere=1 updatekeyinplace=yes arguments=(("p_cd_filial", number),("p_nr_nf", number),("p_de_especie", string),("p_de_serie", string))  sort="nr_sequencial A " )
