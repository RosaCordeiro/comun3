table(column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_venda.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_venda.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_venda.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_venda.dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="nf_venda.dh_cancelamento" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_venda dbname="nf_venda.id_tipo_venda" values="$$HEX1$$c000$$ENDHEX$$ VISTA	AV/CREDI$$HEX1$$c100$$ENDHEX$$RIO	CR/CONTA CORRENTE	CC/CONV$$HEX1$$ca00$$ENDHEX$$NIO	CV/" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_venda.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_venda.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_venda.vl_total_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="nf_venda.pc_desconto" )
 column=(type=long updatewhereclause=yes name=nr_ecf dbname="nf_venda.nr_ecf" )
 column=(type=long updatewhereclause=yes name=nr_coo_ecf dbname="nf_venda.nr_coo_ecf" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_venda_nfe.de_chave_acesso" )
 retrieve="  SELECT 	nf.nr_nf,   
				nf.de_especie,   
				nf.de_serie,   
				nf.dh_emissao,   
				nf.dh_cancelamento,   
				nf.id_tipo_venda,   
				nf.cd_filial,   
				f.nm_fantasia,
				nf.dh_movimentacao_caixa,   
				nf.vl_total_nf,   
				nf.pc_desconto,   
				nf.nr_ecf,   
				nf.nr_coo_ecf,   
				nvn.de_chave_acesso
FROM nf_venda nf 
Inner Join filial f
	on f.cd_filial = nf.cd_filial
Left Outer Join nf_venda_nfe nvn
	On  nvn.cd_filial		= nf.cd_filial    
 	and nvn.nr_nf			= nf.nr_nf
	and nvn.de_especie	= nf.de_especie 
	and nvn.de_serie		= nf.de_serie 
"  sort="cd_filial A dh_movimentacao_caixa A nr_nf A " )
