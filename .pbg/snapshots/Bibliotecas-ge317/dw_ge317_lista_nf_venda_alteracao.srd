table(column=(type=datetime updatewhereclause=yes name=dh_alteracao dbname="nf_venda_alteracao.dh_alteracao" dbalias="nva.dh_alteracao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_alteracao dbname="nf_venda_alteracao.nr_matricula_alteracao" dbalias="nva.nr_matricula_alteracao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="u.nm_usuario" )
 column=(type=char(14) updatewhereclause=yes name=id_tipo_venda_de dbname="id_tipo_venda_de" )
 column=(type=char(14) updatewhereclause=yes name=id_tipo_venda_para dbname="id_tipo_venda_para" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente_de dbname="nf_venda_alteracao.cd_cliente_de" dbalias="nva.cd_cliente_de" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente_de dbname="cliente.nm_cliente" dbalias="cl_de.nm_cliente" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente_para dbname="nf_venda_alteracao.cd_cliente_para" dbalias="nva.cd_cliente_para" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente_para dbname="cliente.nm_cliente" dbalias="cl_para.nm_cliente" )
 column=(type=long updatewhereclause=yes name=cd_convenio_de dbname="nf_venda_alteracao.cd_convenio_de" dbalias="nva.cd_convenio_de" )
 column=(type=char(60) updatewhereclause=yes name=nm_fantasia_de dbname="convenio.nm_fantasia" dbalias="cv_de.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_convenio_para dbname="nf_venda_alteracao.cd_convenio_para" dbalias="nva.cd_convenio_para" )
 column=(type=char(60) updatewhereclause=yes name=nm_fantasia_para dbname="convenio.nm_fantasia" dbalias="cv_para.nm_fantasia" )
 column=(type=char(15) updatewhereclause=yes name=cd_conveniado_de dbname="nf_venda_alteracao.cd_conveniado_de" dbalias="nva.cd_conveniado_de" )
 column=(type=char(40) updatewhereclause=yes name=nm_conveniado_de dbname="conveniado.nm_conveniado" dbalias="cvd_de.nm_conveniado" )
 column=(type=char(15) updatewhereclause=yes name=cd_conveniado_para dbname="nf_venda_alteracao.cd_conveniado_para" dbalias="nva.cd_conveniado_para" )
 column=(type=char(40) updatewhereclause=yes name=nm_conveniado_para dbname="conveniado.nm_conveniado" dbalias="cvd_para.nm_conveniado" )
 column=(type=long updatewhereclause=yes name=cd_condicao_convenio_de dbname="nf_venda_alteracao.cd_condicao_convenio_de" dbalias="nva.cd_condicao_convenio_de" )
 column=(type=char(40) updatewhereclause=yes name=de_condicao_convenio_de dbname="condicao_venda_convenio.de_condicao_convenio" dbalias="cvc_de.de_condicao_convenio" )
 column=(type=long updatewhereclause=yes name=cd_condicao_convenio_para dbname="nf_venda_alteracao.cd_condicao_convenio_para" dbalias="nva.cd_condicao_convenio_para" )
 column=(type=char(40) updatewhereclause=yes name=de_condicao_convenio_para dbname="condicao_venda_convenio.de_condicao_convenio" dbalias="cvc_para.de_condicao_convenio" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pago_avista_de dbname="nf_venda_alteracao.vl_pago_avista_de" dbalias="nva.vl_pago_avista_de" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pago_avista_para dbname="nf_venda_alteracao.vl_pago_avista_para" dbalias="nva.vl_pago_avista_para" )
 column=(type=char(2) updatewhereclause=yes name=cd_forma_pagamento_de dbname="nf_venda_alteracao.cd_forma_pagamento_de" dbalias="nva.cd_forma_pagamento_de" )
 column=(type=char(2) updatewhereclause=yes name=cd_forma_pagamento_para dbname="nf_venda_alteracao.cd_forma_pagamento_para" dbalias="nva.cd_forma_pagamento_para" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa_de dbname="nf_venda_alteracao.nr_controle_caixa_de" dbalias="nva.nr_controle_caixa_de" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa_para dbname="nf_venda_alteracao.nr_controle_caixa_para" dbalias="nva.nr_controle_caixa_para" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa_de dbname="nf_venda_alteracao.dh_movimentacao_caixa_de" dbalias="nva.dh_movimentacao_caixa_de" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa_para dbname="nf_venda_alteracao.dh_movimentacao_caixa_para" dbalias="nva.dh_movimentacao_caixa_para" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso_de dbname="nf_venda_alteracao.de_chave_acesso_de" dbalias="nva.de_chave_acesso_de" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso_para dbname="nf_venda_alteracao.de_chave_acesso_para" dbalias="nva.de_chave_acesso_para" )
 column=(type=char(15) updatewhereclause=yes name=nr_protocolo_envio_de dbname="nf_venda_alteracao.nr_protocolo_envio_de" dbalias="nva.nr_protocolo_envio_de" )
 column=(type=char(15) updatewhereclause=yes name=nr_protocolo_envio_para dbname="nf_venda_alteracao.nr_protocolo_envio_para" dbalias="nva.nr_protocolo_envio_para" )
 column=(type=char(15) updatewhereclause=yes name=nr_protocolo_cancelamento_de dbname="nf_venda_alteracao.nr_protocolo_cancelamento_de" dbalias="nva.nr_protocolo_cancelamento_de" )
 column=(type=char(15) updatewhereclause=yes name=nr_protocolo_cancelamento_para dbname="nf_venda_alteracao.nr_protocolo_cancelamento_para" dbalias="nva.nr_protocolo_cancelamento_para" )
 retrieve="select nva.dh_alteracao, 
        	nva.nr_matricula_alteracao,
		u.nm_usuario,
		case nva.id_tipo_venda_de when 'AV' then '$$HEX1$$c000$$ENDHEX$$ VISTA'
											when 'CV' then 'CONV$$HEX1$$ca00$$ENDHEX$$NIO'
											when 'CC' then 'CONTA-CORRENTE'
											when 'CR' then 'CREDI$$HEX1$$c100$$ENDHEX$$RIO' end id_tipo_venda_de,
		case nva.id_tipo_venda_para when 'AV' then '$$HEX1$$c000$$ENDHEX$$ VISTA'
											when 'CV' then 'CONV$$HEX1$$ca00$$ENDHEX$$NIO'
											when 'CC' then 'CONTA-CORRENTE'
											when 'CR' then 'CREDI$$HEX1$$c100$$ENDHEX$$RIO' end id_tipo_venda_para,
		nva.cd_cliente_de,
		cl_de.nm_cliente,
		nva.cd_cliente_para,
		cl_para.nm_cliente,
		nva.cd_convenio_de,
		cv_de.nm_fantasia,
		nva.cd_convenio_para,
		cv_para.nm_fantasia,
		nva.cd_conveniado_de,
		cvd_de.nm_conveniado,
		nva.cd_conveniado_para,
		cvd_para.nm_conveniado,
		nva.cd_condicao_convenio_de,
		cvc_de.de_condicao_convenio,
 		nva.cd_condicao_convenio_para,
		cvc_para.de_condicao_convenio,
		nva.vl_pago_avista_de,
		nva.vl_pago_avista_para,
		nva.cd_forma_pagamento_de,
		nva.cd_forma_pagamento_para,
		nva.nr_controle_caixa_de,
		nva.nr_controle_caixa_para,
		nva.dh_movimentacao_caixa_de,
		nva.dh_movimentacao_caixa_para,
		nva.de_chave_acesso_de,
		nva.de_chave_acesso_para,
		nva.nr_protocolo_envio_de,
		nva.nr_protocolo_envio_para,
		nva.nr_protocolo_cancelamento_de,
		nva.nr_protocolo_cancelamento_para
from nf_venda_alteracao nva
inner join usuario u 
 on u.nr_matricula = nva.nr_matricula_alteracao
left outer join cliente cl_de
 on cl_de.cd_cliente = nva.cd_cliente_de
left outer join cliente cl_para
 on cl_para.cd_cliente = nva.cd_cliente_para
left outer join convenio cv_de
 on cv_de.cd_convenio = nva.cd_convenio_de
left outer join convenio cv_para
 on cv_para.cd_convenio = nva.cd_convenio_para
left outer join conveniado cvd_de
 on cvd_de.cd_convenio			= cv_de.cd_convenio
   	and cvd_de.cd_conveniado 	= nva.cd_conveniado_de
left outer join conveniado cvd_para
 on cvd_para.cd_convenio			= cv_para.cd_convenio
	and cvd_para.cd_conveniado 	= nva.cd_conveniado_para
left outer join condicao_venda_convenio cvc_de
 on cvc_de.cd_condicao_convenio = nva.cd_condicao_convenio_de
left outer join condicao_venda_convenio cvc_para
 on cvc_para.cd_condicao_convenio = nva.cd_condicao_convenio_para
where nva.cd_filial 	= :pl_cd_filial
  and nva.nr_nf 		= :pl_nr_nf
  and nva.de_especie 	= :ps_de_especie
  and nva.de_serie		= :ps_de_serie" arguments=(("pl_cd_filial", number),("pl_nr_nf", number),("ps_de_especie", string),("ps_de_serie", string))  sort="dh_alteracao A " )
