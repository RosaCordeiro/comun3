 column=(type=decimal(2) updatewhereclause=yes name=nf_venda_vl_frete dbname="nf_venda.vl_frete" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_venda_vl_outras_despesas dbname="nf_venda.vl_outras_despesas" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_venda_pc_desconto dbname="nf_venda.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_venda_vl_pago_avista dbname="nf_venda.vl_pago_avista" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_venda_vl_total_nf dbname="nf_venda.vl_total_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="nf_venda.dh_cancelamento" )
 column=(type=long updatewhereclause=yes name=nr_lote_convenio dbname="nf_venda.nr_lote_convenio" )
 column=(type=long updatewhereclause=yes name=nr_ecf dbname="nf_venda.nr_ecf" )
 column=(type=long updatewhereclause=yes name=convenio_cd_convenio dbname="convenio.cd_convenio" )
 column=(type=char(60) updatewhereclause=yes name=convenio_nm_fantasia dbname="convenio.nm_fantasia" )
 column=(type=char(15) updatewhereclause=yes name=conveniado_cd_conveniado dbname="conveniado.cd_conveniado" )
 column=(type=char(40) updatewhereclause=yes name=conveniado_nm_conveniado dbname="conveniado.nm_conveniado" )
 column=(type=char(6) updatewhereclause=yes name=vendedor_nr_matricula_vendedor dbname="vendedor.nr_matricula_vendedor" )
 column=(type=char(40) updatewhereclause=yes name=usuario_nm_usuario dbname="usuario.nm_usuario" )
 column=(type=char(6) updatewhereclause=yes name=nf_venda_nr_matric_operador dbname="nf_venda.nr_matric_operador" )
 column=(type=char(40) updatewhereclause=yes name=usuario_usuario_operador dbname="usuario.usuario_operador" )
 column=(type=char(2) updatewhereclause=yes name=nf_venda_id_tipo_venda dbname="nf_venda.id_tipo_venda" values="$$HEX1$$c000$$ENDHEX$$ VISTA	AV/CONTA CORRENTE	CC/CONV$$HEX1$$ca00$$ENDHEX$$NIO	CV/CREDI$$HEX1$$c100$$ENDHEX$$RIO	CR/" )
 column=(type=long updatewhereclause=yes name=nf_venda_cd_condicao_convenio dbname="nf_venda.cd_condicao_convenio" )
 column=(type=char(40) updatewhereclause=yes name=condicao_venda_convenio_de_condicao_conv dbname="condicao_venda_convenio.de_condicao_convenio" )
 column=(type=char(6) updatewhereclause=yes name=nf_venda_nr_matric_liberacao_bloqueio dbname="nf_venda.nr_matric_liberacao_bloqueio" )
 column=(type=char(40) updatewhereclause=yes name=usuario_nm_usuario_liberacao dbname="usuario.nm_usuario_liberacao" )
 column=(type=long updatewhereclause=yes name=nf_venda_cd_filial dbname="nf_venda.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia_filial dbname="filial.nm_fantasia_filial" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="cliente.cd_cliente" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="cliente.nm_cliente" )
 retrieve="SELECT nf_venda.nr_nf,   
         nf_venda.de_especie,   
         nf_venda.de_serie,
         nf_venda.dh_emissao,  
		 nf_venda.dh_movimentacao_caixa,   
         nf_venda.vl_bc_icms,   
         nf_venda.vl_icms,   
         nf_venda.vl_bc_icms_st,   
         nf_venda.vl_icms_st,   
         nf_venda.vl_total_produtos,   
         nf_venda.vl_frete, 
         nf_venda.vl_outras_despesas,   
         nf_venda.pc_desconto,     
         nf_venda.vl_pago_avista,   
         nf_venda.vl_total_nf, 
         nf_venda.dh_cancelamento,   
         nf_venda.nr_lote_convenio,
         nf_venda.nr_ecf,
         convenio.cd_convenio,
         convenio.nm_fantasia,
         conveniado.cd_conveniado, 
         conveniado.nm_conveniado,
         vendedor.nr_matricula_vendedor,
         usuario_vendedor.nm_usuario, 
         nf_venda.nr_matric_operador,
	usuario_operador.nm_usuario usuario_operador,
         nf_venda.id_tipo_venda,
         nf_venda.cd_condicao_convenio,
         condicao_venda_convenio.de_condicao_convenio,
	 nf_venda.nr_matric_liberacao_bloqueio,
	  usuario_liberacao.nm_usuario nm_usuario_liberacao,
	nf_venda.cd_filial cd_filial,
	f.nm_fantasia nm_fantasia_filial,
    cl.cd_cliente, 
	cl.nm_cliente
    FROM convenio, 
         conveniado,
         nf_venda,
 	usuario usuario_operador,
 	 vendedor,
         condicao_venda_convenio,
         usuario usuario_vendedor,
	 usuario usuario_liberacao,
	filial f, 
    cliente cl
 WHERE nf_venda.cd_convenio           		 		= convenio.cd_convenio
   and nf_venda.cd_convenio           		 			= conveniado.cd_convenio
   and nf_venda.cd_conveniado         		 			= conveniado.cd_conveniado
   and nf_venda.nr_matric_operador    		 		= usuario_operador.nr_matricula 
   and nf_venda.nr_matricula_vendedor 		 		= vendedor.nr_matricula_vendedor 
   and vendedor.nr_matricula_vendedor 	     		= usuario_vendedor.nr_matricula 
   and nf_venda.cd_condicao_convenio  		 		= condicao_venda_convenio.cd_condicao_convenio 
   and nf_venda.nr_matric_liberacao_bloqueio 		*= usuario_liberacao.nr_matricula
   and nf_venda.cd_cliente								*= cl.cd_cliente
   and nf_venda.cd_filial             		 				  = :pl_Filial
   and nf_venda.nr_nf                 		 				  = :pl_Nr_Nf
   and nf_venda.de_especie            		 			  = :ps_Especie 
   and nf_venda.de_serie              		 			  = :ps_Serie
   and nf_venda.cd_filial = f.cd_filial
 " arguments=(("pl_Filial", number),("pl_Nr_Nf", number),("ps_especie", string),("ps_serie", string)) )
