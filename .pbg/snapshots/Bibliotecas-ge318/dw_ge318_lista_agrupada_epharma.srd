table(column=(type=long updatewhereclause=yes name=tipo_conciliacao_v dbname="tipo_conciliacao_V" )
 column=(type=long updatewhereclause=yes name=tipo_conciliacao_c dbname="tipo_conciliacao_C" )
 column=(type=char(41) updatewhereclause=yes name=dados_venda dbname="dados_venda" )
 column=(type=long updatewhereclause=yes name=venda_pbm_cd_filial dbname="venda_pbm.cd_filial" dbalias="vp.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=venda_pbm_nr_nf dbname="venda_pbm.nr_nf" dbalias="vp.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=venda_pbm_de_especie dbname="venda_pbm.de_especie" dbalias="vp.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=venda_pbm_de_serie dbname="venda_pbm.de_serie" dbalias="vp.de_serie" )
 column=(type=datetime updatewhereclause=yes name=venda_pbm_dh_venda dbname="venda_pbm.dh_venda" dbalias="vp.dh_venda" )
 column=(type=char(20) updatewhereclause=yes name=venda_pbm_nr_autorizacao dbname="venda_pbm.nr_autorizacao" dbalias="vp.nr_autorizacao" )
 column=(type=char(12) updatewhereclause=yes name=venda_pbm_nr_comprovante_venda dbname="venda_pbm.nr_comprovante_venda" dbalias="vp.nr_comprovante_venda" )
 column=(type=char(6) updatewhereclause=yes name=venda_pbm_nr_cupom dbname="venda_pbm.nr_cupom" dbalias="vp.nr_cupom" )
 column=(type=long updatewhereclause=yes name=venda_pbm_produto_cd_produto dbname="venda_pbm_produto.cd_produto" dbalias="vpp.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=produto_geral_de_produto dbname="produto_geral.de_produto" dbalias="pg.de_produto" )
 column=(type=long updatewhereclause=yes name=venda_pbm_produto_qt_vendida dbname="venda_pbm_produto.qt_vendida" dbalias="vpp.qt_vendida" )
 column=(type=decimal(2) updatewhereclause=yes name=venda_pbm_produto_vl_praticado dbname="venda_pbm_produto.vl_praticado" dbalias="vpp.vl_praticado" )
 column=(type=decimal(2) updatewhereclause=yes name=venda_pbm_produto_vl_reembolso dbname="venda_pbm_produto.vl_reembolso" dbalias="vpp.vl_reembolso" )
 column=(type=decimal(2) updatewhereclause=yes name=venda_pbm_produto_vl_preco_maximo dbname="venda_pbm_produto.vl_preco_maximo" dbalias="vpp.vl_preco_maximo" )
 column=(type=decimal(2) updatewhereclause=yes name=venda_pbm_produto_vl_pago_avista dbname="venda_pbm_produto.vl_pago_avista" dbalias="vpp.vl_pago_avista" )
 column=(type=decimal(2) updatewhereclause=yes name=venda_pbm_produto_vl_subsidio dbname="venda_pbm_produto.vl_subsidio" dbalias="vpp.vl_subsidio" )
 column=(type=decimal(2) updatewhereclause=yes name=venda_pbm_produto_vl_reposicao dbname="venda_pbm_produto.vl_reposicao" dbalias="vpp.vl_reposicao" )
 column=(type=char(53) updatewhereclause=yes name=dados_conciliacao dbname="dados_conciliacao" )
 column=(type=char(20) updatewhereclause=yes name=nr_nsu dbname="nr_nsu" )
 column=(type=char(18) updatewhereclause=yes name=ds_status dbname="ds_status" )
 column=(type=char(60) updatewhereclause=yes name=conciliacao_pbm_produto_ds_produto dbname="conciliacao_pbm_produto.ds_produto" dbalias="cpp.ds_produto" )
 column=(type=long updatewhereclause=yes name=conciliacao_pbm_produto_qt_vendida dbname="conciliacao_pbm_produto.qt_vendida" dbalias="cpp.qt_vendida" )
 column=(type=decimal(2) updatewhereclause=yes name=conciliacao_pbm_produto_vl_venda dbname="conciliacao_pbm_produto.vl_venda" dbalias="cpp.vl_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=conciliacao_pbm_produto_vl_reembolso dbname="conciliacao_pbm_produto.vl_reembolso" dbalias="cpp.vl_reembolso" )
 column=(type=long updatewhereclause=yes name=conciliacao_pbm_produto_nr_controle dbname="conciliacao_pbm_produto.nr_controle" dbalias="cpp.nr_controle" )
 column=(type=long updatewhereclause=yes name=conciliacao_pbm_produto_nr_sequencial dbname="conciliacao_pbm_produto.nr_sequencial" dbalias="cpp.nr_sequencial" )
 column=(type=char(8) updatewhereclause=yes name=conciliacao_pbm_produto_nr_cupom dbname="conciliacao_pbm_produto.nr_cupom" dbalias="cpp.nr_cupom" )
 column=(type=char(1) updatewhereclause=yes name=conciliacao_pbm_produto_id_tipo_registro dbname="conciliacao_pbm_produto.id_tipo_registro" dbalias="cpp.id_tipo_registro" )
 column=(type=char(6) updatewhereclause=yes name=conciliacao_pbm_produto_cd_beneficio dbname="conciliacao_pbm_produto.cd_beneficio" dbalias="cpp.cd_beneficio" )
 column=(type=char(40) updatewhereclause=yes name=conciliacao_pbm_produto_ds_beneficio dbname="conciliacao_pbm_produto.ds_beneficio" dbalias="cpp.ds_beneficio" )
 column=(type=long updatewhereclause=yes name=conciliacao_pbm_produto_cd_filial dbname="conciliacao_pbm_produto.cd_filial" dbalias="cpp.cd_filial" )
 column=(type=datetime updatewhereclause=yes name=dh_transacao dbname="conciliacao_pbm_produto.dh_transacao" dbalias="cpp.dh_transacao" )
 column=(type=decimal(2) updatewhereclause=yes name=conciliacao_pbm_produto_vl_copay dbname="conciliacao_pbm_produto.vl_copay" dbalias="cpp.vl_copay" )
 column=(type=decimal(2) updatewhereclause=yes name=conciliacao_pbm_produto_vl_total_copay dbname="conciliacao_pbm_produto.vl_total_copay" dbalias="cpp.vl_total_copay" )
 column=(type=char(8) updatewhereclause=yes name=conciliacao_pbm_produto_cd_cliente dbname="conciliacao_pbm_produto.cd_cliente" dbalias="cpp.cd_cliente" )
 column=(type=char(40) updatewhereclause=yes name=conciliacao_pbm_produto_nm_cliente dbname="conciliacao_pbm_produto.nm_cliente" dbalias="cpp.nm_cliente" )
 column=(type=decimal(2) updatewhereclause=yes name=conciliacao_pbm_produto_vl_total_venda dbname="conciliacao_pbm_produto.vl_total_venda" dbalias="cpp.vl_total_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=conciliacao_pbm_produto_vl_total_reembolso dbname="conciliacao_pbm_produto.vl_total_reembolso" dbalias="cpp.vl_total_reembolso" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="conciliacao_pbm_produto.cd_produto" dbalias="cpp.cd_produto" )
 column=(type=datetime updatewhereclause=yes name=conciliacao_pbm_produto_dh_pagamento dbname="conciliacao_pbm_produto.dh_pagamento" dbalias="cpp.dh_pagamento" )
 retrieve="select 	case isnull(vpp.id_conciliada, 'N') when 'S' then 1 when 'N' then 2 else 3 end tipo_conciliacao_V, 
	 	case cpp.id_conciliada when 'S' then 1 when 'N' then 2 else 3 end tipo_conciliacao_C, 
		~" I N F O R M A $$HEX1$$c700$$ENDHEX$$ $$HEX1$$d500$$ENDHEX$$ E S  D A  V E N D A ->~" dados_venda, 
         vp.cd_filial, f.nm_fantasia, vp.nr_nf, vp.de_especie, vp.de_serie, vp.dh_venda, vp.nr_autorizacao,
		vp.nr_comprovante_venda, vp.nr_cupom, vpp.cd_produto, pg.de_produto, vpp.qt_vendida, vpp.vl_praticado, vpp.vl_reembolso,
         vpp.vl_preco_maximo, vpp.vl_pago_avista, vpp.vl_subsidio, vpp.vl_reposicao,
		 ~" I N F O R M A $$HEX1$$c700$$ENDHEX$$ $$HEX1$$d500$$ENDHEX$$ E S  D A  C O N C I L I A $$HEX1$$c700$$ENDHEX$$ $$HEX1$$c300$$ENDHEX$$ O ->~" dados_conciliacao,
          '' nr_nsu, case cpp.id_status when '-1' then 'CANCELADA' when '0' then 'PENDENTE' when '1' then  'CONFIRMADA' 
										when '2' then 'SONDADA E PENDENTE' END ds_status, cpp.ds_produto, cpp.qt_vendida,
		cpp.vl_venda, cpp.vl_reembolso, cpp.nr_controle, cpp.nr_sequencial, cpp.nr_cupom, cpp.id_tipo_registro,
		cpp.cd_beneficio, cpp.ds_beneficio, cpp.cd_filial, cpp.dh_transacao ,cpp.vl_copay, cpp.vl_total_copay,
		cpp.cd_cliente, cpp.nm_cliente, cpp.vl_total_venda, cpp.vl_total_reembolso, cpp.cd_produto, cpp.dh_pagamento
from 	venda_pbm vp,
		venda_pbm_produto vpp,
		conciliacao_pbm_produto cpp,
		filial f,
		produto_geral pg,
		convenio_epharma_beneficio ceb,
        nf_venda nf
where vp.cd_filial 					= vpp.cd_filial
	and f.cd_filial					= vp.cd_filial
	and vp.nr_nf						= vpp.nr_nf
	and vp.nr_sequencial_pbm		= vpp.nr_sequencial_pbm
	and vp.de_especie					= vpp.de_especie
	and vp.de_serie					= vpp.de_serie
	and pg.cd_produto					= vpp.cd_produto
     and vp.dh_cancelamento is null
     and month(cpp.dh_pagamento) = case :ps_id_apuracao when 'S' then case when ceb.nr_dia_pagamento <= day(:pd_venda_ate) then month(:pd_venda_ate) + 1 else month(:pd_venda_ate) end 
											else month(cpp.dh_pagamento) end
    and year(cpp.dh_pagamento) = case :ps_id_apuracao when 'S' then year(:pd_venda_ate) else year(cpp.dh_pagamento) end
	and case :ps_id_apuracao 
			when 'V' then convert(date, vp.dh_venda) 
			when 'P' then cpp.dh_pagamento 
			when 'S' then cpp.dh_pagamento end
between case :ps_id_apuracao 
			when 'V' then :pd_venda_de
			When 'P' then :pd_fechamento 
			When 'S' then cpp.dh_pagamento end
	  and case :ps_id_apuracao
          	when 'V' then :pd_venda_ate
			when 'P' then :pd_fechamento 
			When 'S' then cpp.dh_pagamento end
	and cpp.nr_cupom					= vp.nr_cupom
	and cpp.dh_transacao			= vp.dh_venda
	and cpp.cd_convenio_pbm 		= vp.cd_convenio
	and cpp.cd_produto				= vpp.cd_produto
    and cpp.cd_filial_venda			= vp.cd_filial
    and cpp.nr_nf_venda				= vp.nr_nf
	and cpp.de_especie_venda		= vp.de_especie
	and cpp.de_serie_venda			= vp.de_serie
	and vp.cd_convenio 				= :pl_convenio
	and ceb.cd_convenio_epharma = cpp.cd_convenio_epharma
	and ceb.cd_cliente      			= cpp.cd_cliente
	and ceb.cd_beneficio 				= cpp.cd_beneficio
	and ceb.nr_dia_fechamento	= case :pi_dia_fechamento when 0 then ceb.nr_dia_fechamento else :pi_dia_fechamento end 
     and nf.cd_filial = vp.cd_filial
     and nf.nr_nf = vp.nr_nf
     and nf.de_especie = vp.de_especie
     and nf.de_serie = vp.de_serie
     and nf.id_tipo_venda = 'CV'
union all
select 	2 tipo_conciliacao_V, 
	 	case cpp.id_conciliada when 'S' then 1 when 'N' then 2 else 3 end tipo_conciliacao_C, 
		~" I N F O R M A $$HEX1$$c700$$ENDHEX$$ $$HEX1$$d500$$ENDHEX$$ E S  D A  V E N D A ->~" dados_venda,
         f.cd_filial, f.nm_fantasia, null, '', '', null, '',
		'', '', null, '', null, null, null, 
          null, null, null, null,
		 ~" I N F O R M A $$HEX1$$c700$$ENDHEX$$ $$HEX1$$d500$$ENDHEX$$ E S  D A  C O N C I L I A $$HEX1$$c700$$ENDHEX$$ $$HEX1$$c300$$ENDHEX$$ O ->~" dados_conciliacao,
         cpp.nr_nsu, case cpp.id_status when '-1' then 'CANCELADA' when '0' then 'PENDENTE' when '1' then  'CONFIRMADA' 
										when '2' then 'SONDADA E PENDENTE' END ds_status, cpp.ds_produto, cpp.qt_vendida,
		cpp.vl_venda, cpp.vl_reembolso, cpp.nr_controle, cpp.nr_sequencial, cpp.nr_cupom, cpp.id_tipo_registro,
		cpp.cd_beneficio, cpp.ds_beneficio, cpp.cd_filial, cpp.dh_transacao, cpp.vl_copay, cpp.vl_total_copay,
		cpp.cd_cliente, cpp.nm_cliente, cpp.vl_total_venda, cpp.vl_total_reembolso, cpp.cd_produto, cpp.dh_pagamento
from 	conciliacao_pbm_produto cpp,
		filial f,
		convenio_epharma_beneficio ceb
where  cpp.cd_convenio_pbm		= :pl_convenio
	and f.cd_filial						= cpp.cd_filial
	and ceb.cd_convenio_epharma = cpp.cd_convenio_epharma
	and ceb.cd_cliente      			= cpp.cd_cliente
	and ceb.cd_beneficio 				= cpp.cd_beneficio
   	and coalesce(cpp.id_conciliada, 'N') = 'N'
	and ceb.nr_dia_fechamento		= case :pi_dia_fechamento when 0 then ceb.nr_dia_fechamento else :pi_dia_fechamento end 
     and month(cpp.dh_pagamento) = case :ps_id_apuracao when 'S' then case when ceb.nr_dia_pagamento <= day(:pd_venda_ate) then month(:pd_venda_ate) + 1 else month(:pd_venda_ate) end 
											else month(cpp.dh_pagamento) end
    and year(cpp.dh_pagamento) = case :ps_id_apuracao when 'S' then year(:pd_venda_ate) else year(cpp.dh_pagamento) end
	and case :ps_id_apuracao 
			when 'V' then convert(date, cpp.dh_transacao) 
			when 'P' then cpp.dh_pagamento 
			When 'S' then cpp.dh_pagamento end
between case :ps_id_apuracao 
			when 'V' then :pd_venda_de
			When 'P' then :pd_fechamento
			When 'S' then cpp.dh_pagamento end
	  and case :ps_id_apuracao
          	when 'V' then :pd_venda_ate
			when 'P' then :pd_fechamento 
			When 'S' then cpp.dh_pagamento end
    and not exists(select 1
					from venda_pbm vp,
						   venda_pbm_produto vpp
					where vp.cd_filial 				= vpp.cd_filial
						and vp.nr_nf					= vpp.nr_nf
						and vp.nr_sequencial_pbm	= vpp.nr_sequencial_pbm
						and vp.de_especie				= vpp.de_especie
						and vp.de_serie				= vpp.de_serie
						and vp.dh_venda				= cpp.dh_transacao
						and cpp.nr_cupom				= vp.nr_cupom
						and cpp.dh_transacao			= vp.dh_venda
						and cpp.cd_convenio_pbm 	= vp.cd_convenio
						and cpp.cd_produto			= vpp.cd_produto
						and vp.dh_cancelamento is null)union all
select distinct	2 tipo_conciliacao_V, 
	 	2 tipo_conciliacao_C, 
		~" I N F O R M A $$HEX1$$c700$$ENDHEX$$ $$HEX1$$d500$$ENDHEX$$ E S  D A  V E N D A ->~" dados_venda,
         vp.cd_filial, f.nm_fantasia, vp.nr_nf, vp.de_especie, vp.de_serie, vp.dh_venda, vp.nr_autorizacao,
		vp.nr_comprovante_venda, vp.nr_cupom, vpp.cd_produto, pg.de_produto, vpp.qt_vendida, vpp.vl_praticado, vpp.vl_reembolso,
         vpp.vl_preco_maximo, vpp.vl_pago_avista, vpp.vl_subsidio, vpp.vl_reposicao,
		 ~" I N F O R M A $$HEX1$$c700$$ENDHEX$$ $$HEX1$$d500$$ENDHEX$$ E S  D A  C O N C I L I A $$HEX1$$c700$$ENDHEX$$ $$HEX1$$c300$$ENDHEX$$ O ->~" dados_conciliacao,
	     '' nr_nsu, '' ds_status, null,null,
		null, null, null, null, null, null,
		null, null, null, null,null, null,
		null, 'VENDA N$$HEX1$$c300$$ENDHEX$$O CONCILIADA', null, null, null, null
from 	venda_pbm vp,
		venda_pbm_produto vpp,
		filial f,
		produto_geral pg,
	   convenio_epharma_beneficio ceb,
        nf_venda nf
where vp.cd_filial 						= vpp.cd_filial
	and f.cd_filial						= vp.cd_filial
	and vp.nr_nf						= vpp.nr_nf
	and vp.nr_sequencial_pbm		= vpp.nr_sequencial_pbm
	and vp.de_especie					= vpp.de_especie
	and vp.de_serie					= vpp.de_serie
     and month(vp.dh_venda) = case :ps_id_apuracao when 'S' then case when ceb.nr_dia_pagamento <= day(:pd_venda_ate) then month(:pd_venda_ate) + 1 else month(:pd_venda_ate) end 
											else month(vp.dh_venda) end
    and year(vp.dh_venda) = case :ps_id_apuracao when 'S' then year(:pd_venda_ate) else year(vp.dh_venda) end
	and convert(date, vp.dh_venda) 
between case :ps_id_apuracao 
			when 'S' then convert(date, vp.dh_venda) 
			when 'V' then :pd_venda_de 
			When 'P' then convert(date, convert(varchar,:pi_ano_fechamento)  + '/' + 
         case ceb.nr_dia_pagamento when 31 then convert(varchar, month(dateadd(month, -1, :pd_fechamento)))
          else convert(varchar, month(dateadd(month, -2, :pd_fechamento))) end + '/' + 
    		case ceb.nr_dia_pagamento when 31 then right('00'+ '1', 2)
      	 else case (:pi_ano_fechamento % 4) when 0 then '29' else case convert(varchar,ceb.nr_dia_pagamento+1) when '29' then '28' else convert(varchar,ceb.nr_dia_pagamento+1) end end end)
         end 
	  and case :ps_id_apuracao
			when 'S' then convert(date, vp.dh_venda) 
          	when 'V' then :pd_venda_ate
			when 'P' then convert(date, convert(varchar,:pi_ano_fechamento) + '/' + convert(varchar, month(dateadd(month, -1,:pd_fechamento))) + '/' + 
		  				case ceb.nr_dia_pagamento when 31 then convert(varchar, DAY(DATEADD(day,-1,DATEADD(Month,1,CONVERT(DATETIME,convert(varchar,:pi_ano_fechamento) + right('00'+ convert(varchar,convert(varchar, month(dateadd(month, -1, :pd_fechamento)))),2) + '01')))))
    	  				else convert(varchar,ceb.nr_dia_pagamento) end)
              end
	and pg.cd_produto					= vpp.cd_produto
	and vp.cd_convenio 				= :pl_convenio
	and ceb.cd_convenio_epharma = vp.cd_convenio_pbm
	and ceb.nr_dia_fechamento 	= case :pi_dia_fechamento when 0 then ceb.nr_dia_fechamento else :pi_dia_fechamento end 
	and vp.vl_total_venda > 0 
   	and coalesce(vpp.id_conciliada, 'N') = 'N'
     and vp.dh_cancelamento is null
	and vp.dh_venda >= '2013/05/01'
    and nf.cd_filial = vp.cd_filial
     and nf.nr_nf = vp.nr_nf
     and nf.de_especie = vp.de_especie
     and nf.de_serie = vp.de_serie
     and nf.id_tipo_venda = 'CV'
	and not exists (select 1
					from conciliacao_pbm_produto cpp
					where  cpp.cd_filial_venda			= vp.cd_filial
						and cpp.nr_nf_venda				= vp.nr_nf
						and cpp.de_especie_venda		= vp.de_especie
						and cpp.de_serie_venda			= vp.de_serie)" arguments=(("pl_convenio", number),("pd_venda_de", date),("pd_venda_ate", date),("pi_dia_fechamento", number),("ps_id_apuracao", string),("pi_ano_fechamento", number),("pd_fechamento", date))  sort="conciliacao_pbm_produto_nm_cliente A dh_transacao A conciliacao_pbm_produto_cd_filial A conciliacao_pbm_produto_nr_cupom A " )
