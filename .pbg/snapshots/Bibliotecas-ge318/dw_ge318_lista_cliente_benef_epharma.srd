table(column=(type=char(20) updatewhereclause=yes name=cd_convenio_epharma dbname="convenio_epharma_beneficio.cd_convenio_epharma" )
 column=(type=char(30) updatewhereclause=yes name=nm_convenio dbname="convenio_epharma.nm_convenio" )
 column=(type=char(8) updatewhereclause=yes name=cd_cliente dbname="convenio_epharma_beneficio.cd_cliente" )
 column=(type=char(60) updatewhereclause=yes name=nm_cliente dbname="convenio_epharma_beneficio.nm_cliente" )
 column=(type=char(6) updatewhereclause=yes name=cd_beneficio dbname="convenio_epharma_beneficio.cd_beneficio" )
 column=(type=char(60) updatewhereclause=yes name=nm_beneficio dbname="convenio_epharma_beneficio.nm_beneficio" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="convenio_epharma.id_situacao" )
 column=(type=long updatewhereclause=yes name=nr_dia_fechamento dbname="convenio_epharma_beneficio.nr_dia_fechamento" )
 retrieve="select ceb.cd_convenio_epharma,
		ce.nm_convenio,
		ceb.cd_cliente,
		ceb.nm_cliente,
		ceb.cd_beneficio,
		ceb.nm_beneficio,
		ce.id_situacao,
		ceb.nr_dia_fechamento
from convenio_epharma ce,
        convenio_epharma_beneficio ceb
where convert(varchar,ce.cd_convenio) = ceb.cd_convenio_epharma
"  sort="nm_convenio A nm_cliente A nm_beneficio A " )
