table(column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=decimal(2) updatewhereclause=yes name=valor_estoque dbname="valor_estoque" )
 retrieve="SELECT	f.nm_fantasia,   
			s.cd_filial,   
			Sum(round(s.qt_saldo_final * s.vl_custo_medio,2)) as valor_estoque
FROM filial f
Inner Join saldo_produto s (index idx_data_produto)
	On s.cd_filial 	= f.cd_filial
Inner Join historico_produto  h (index pk_historico_produto)
	On	h.cd_produto 	= s.cd_produto and 
		h.dh_historico	= s.dh_saldo
WHERE s.dh_saldo  	= :periodo
	and s.qt_saldo_final > 0
	//and g.cd_grupo_produto <> 5
	and substring(h.cd_subcategoria,1,1) <> '5'
	and s.cd_produto > 0
GROUP BY f.nm_fantasia, s.cd_filial


" arguments=(("periodo", date))  sort="nm_fantasia A " )
