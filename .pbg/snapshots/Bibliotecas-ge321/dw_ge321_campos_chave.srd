table(column=(type=char(255) updatewhereclause=yes name=nm_campo dbname="nm_campo" )
 column=(type=char(40) updatewhereclause=yes name=nm_valor dbname="nm_valor" )
 retrieve="		select upper(index_col (:tabela,2,1)) as nm_campo, cast(null as varchar(40)) as nm_valor
union select upper(index_col (:tabela,2,2)) as nm_campo, cast(null as varchar(40)) as nm_valor
union select upper(index_col (:tabela,2,3)) as nm_campo, cast(null as varchar(40)) as nm_valor
union select upper(index_col (:tabela,2,4)) as nm_campo, cast(null as varchar(40)) as nm_valor
