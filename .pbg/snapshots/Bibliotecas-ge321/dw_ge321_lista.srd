table(column=(type=char(180) updatewhereclause=yes name=registro dbname="registro" )
 column=(type=char(40) updatewhereclause=yes name=nm_tabela dbname="historico_alteracao_tabela.nm_tabela" dbalias="h.nm_tabela" )
 column=(type=char(40) updatewhereclause=yes name=nm_coluna dbname="historico_alteracao_tabela.nm_coluna" dbalias="h.nm_coluna" )
 column=(type=char(40) updatewhereclause=yes name=de_coluna dbname="de_coluna" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao dbname="historico_alteracao_tabela.dh_alteracao" dbalias="h.dh_alteracao" )
 column=(type=char(1024) updatewhereclause=yes name=de_alteracao_de dbname="de_alteracao_de" )
 column=(type=char(1024) updatewhereclause=yes name=de_alteracao_para dbname="de_alteracao_para" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao dbname="historico_alteracao_tabela.id_alteracao" dbalias="h.id_alteracao" values="ALTERA$$HEX2$$c700c300$$ENDHEX$$O	A/EXCLUS$$HEX1$$c300$$ENDHEX$$O	E/INCLUS$$HEX1$$c300$$ENDHEX$$O	I/" )
 column=(type=char(73) updatewhereclause=yes name=nm_usuario dbname="nm_usuario" )
 retrieve="select 	str_replace(h.de_chave,'@#!',' - ') as registro, 
			h.nm_tabela, 
			h.nm_coluna, 
			coalesce(b.de_coluna, h.nm_coluna) as de_coluna,
			h.dh_alteracao, 
			cast(h.de_alteracao_de as varchar(1024)) as de_alteracao_de, 
			cast(h.de_alteracao_para as varchar(1024)) as de_alteracao_para, 
			h.id_alteracao, 
			case when h.nr_matric_alteracao is null then '' else u.nm_usuario ||' ('|| CAST(h.nr_matric_alteracao as varchar)||')' end as nm_usuario
from historico_alteracao_tabela h
inner join historico_alteracao_tab_cfg cfg
	on cfg.nm_tabela = h.nm_tabela
	and (coalesce(cfg.nm_coluna,'') = '' or cfg.nm_coluna = h.nm_coluna)
	and cfg.id_visualizacao = 'L'
left outer join usuario u
	on u.nr_matricula = h.nr_matric_alteracao
left outer join historico_alteracao_tabela_col b
	on b.nm_tabela = h.nm_tabela
	and b.nm_coluna = h.nm_coluna
where h.dh_alteracao between :dh_inicio and :dh_termino
	and cfg.cd_sistema = :sistema

union

select 	str_replace(h.de_chave,'@#!',' - ') as registro, 
			h.nm_tabela, 
			h.nm_coluna, 
			coalesce(b.de_coluna, h.nm_coluna) as de_coluna,
			h.dh_alteracao, 
			cast(h.de_alteracao_de as varchar(1024)) as de_alteracao_de, 
			cast(h.de_alteracao_para as varchar(1024)) as de_alteracao_para, 
			h.id_alteracao, 
			case when h.nr_matric_alteracao is null then '' else u.nm_usuario ||' ('|| CAST(h.nr_matric_alteracao as varchar)||')' end as nm_usuario
from historico_alteracao_tabela h
left outer join usuario u
	on u.nr_matricula = h.nr_matric_alteracao
left outer join historico_alteracao_tabela_col b
	on b.nm_tabela = h.nm_tabela
	and b.nm_coluna = h.nm_coluna
where h.dh_alteracao between :dh_inicio and :dh_termino
	and not exists (select 1 from historico_alteracao_tab_cfg a1
						Where a1.cd_sistema = :sistema)" retrieve.asneeded=yes arguments=(("dh_inicio", datetime),("dh_termino", datetime),("sistema", string)) )
