table(column=(type=char(255) updatewhereclause=yes name=nm_coluna dbname="historico_alteracao_tab_cfg.nm_coluna" dbalias="a.nm_coluna" )
 column=(type=char(255) updatewhereclause=yes name=de_coluna dbname="de_coluna" )
 retrieve="select distinct a.nm_coluna, coalesce(b.de_coluna, a.nm_coluna) as de_coluna
from historico_alteracao_tab_cfg a
left outer join historico_alteracao_tabela_col b
	on b.nm_tabela = a.nm_tabela
	and b.nm_coluna = a.nm_coluna
Where a.cd_sistema = :sistema
	and coalesce(a.nm_coluna, '') <> ''
	and a.id_visualizacao = 'L' //Liberado

union

SELECT distinct upper(c.name) as nm_coluna, coalesce(b.de_coluna, upper(c.name)) as de_coluna
FROM    historico_alteracao_tab_cfg a
INNER JOIN    sysobjects o
	on upper(o.name) = a.nm_tabela
INNER JOIN  syscolumns c
	ON  c.id = o.id
left outer join historico_alteracao_tabela_col b
	on b.nm_tabela = a.nm_tabela
	and b.nm_coluna = upper(c.name)
Where a.id_visualizacao = 'L' //Liberado
	and coalesce(a.nm_coluna, '') = ''
	and a.cd_sistema = :sistema
	and upper(c.name) not in ('DH_ALTERACAO', 'DH_INCLUSAO', 'DH_ATUALIZACAO', 'NR_MATRICULA_ATUALIZACAO', 'DH_ATUALIZACAO_FILIAL', 'NR_MATRIC_INCLUSAO', 'NR_MATRIC_ALTERACAO')

union

SELECT distinct upper(c.name) as nm_coluna, coalesce(b.de_coluna, upper(c.name)) as de_coluna
FROM        sysobjects o
INNER JOIN  syscolumns c
	ON  o.id = c.id
left outer join historico_alteracao_tabela_col b
	on b.nm_tabela = upper(o.name)
	and b.nm_coluna = upper(c.name)
Where upper(c.name) not in ('DH_ALTERACAO', 'DH_INCLUSAO', 'DH_ATUALIZACAO', 'NR_MATRICULA_ATUALIZACAO', 'DH_ATUALIZACAO_FILIAL', 'NR_MATRIC_INCLUSAO', 'NR_MATRIC_ALTERACAO')
	and not exists (select 1
						from historico_alteracao_tab_cfg
						Where cd_sistema = :sistema)" arguments=(("sistema", string)) )
