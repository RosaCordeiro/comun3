table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="vw_filial.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="dh_termino" )
 column=(type=char(9) updatewhereclause=yes name=dh_pedido dbname="" )
 column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="cd_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="grupo.de_grupo" )
 column=(type=char(1) updatewhereclause=yes name=cd_curva dbname="cd_curva" )
 column=(type=long updatewhereclause=yes name=qt_dias_reforco dbname="qt_dias_reforco" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo dbname="id_tipo" )
 column=(type=char(1) updatewhereclause=yes name=id_marcado dbname="id_marcado" values="	S/	N" )
 retrieve="select x.cd_filial as cd_filial,
		v.nm_fantasia as nm_fantasia,
		x.dh_inicio as dh_inicio,
		x.dh_termino as dh_termino,
		:pedido,
		x.cd_grupo as cd_grupo,
		g.de_grupo as de_grupo,
		x.cd_curva as cd_curva,
		x.qt_dias_reforco as qt_dias_reforco,
		x.id_tipo as id_tipo,	
		'N' as id_marcado
from ( SELECT cd_filial, dh_inicio, dh_termino, cd_grupo, cd_curva, qt_dias_reforco, 'E' as id_tipo 
		from pedido_filial_reforco_perini
		where dh_inicio 		<= :pedido
			and dh_termino 	>= :pedido 
		
		union		
	
		 SELECT cd_filial, dh_inicio, dh_termino, cd_grupo, cd_curva, qt_dias_reforco, 'D' as id_tipo 
		from pedido_filial_reforco
		where dh_inicio 		<= :pedido
			and dh_termino 	>= :pedido 
		) as x
	inner join vw_filial v
		on v.cd_filial 	= x.cd_filial
	inner join grupo g
		on g.cd_grupo 	= x.cd_grupo
where x.id_tipo = :tipo" arguments=(("pedido", date),("tipo", string))  sort="cd_filial A de_grupo A cd_curva A " )
