table(column=(type=char(5) updatewhereclause=yes name=cfop dbname="cfop" )
 column=(type=char(15) updatewhereclause=yes name=de_grupo dbname="de_grupo" )
 column=(type=char(12) updatewhereclause=yes name=id_pis_cofins_prod dbname="id_pis_cofins_prod" )
 column=(type=long updatewhereclause=yes name=p_nr_classificacao_fiscal dbname="nr_classificacao_fiscal" )
 column=(type=long updatewhereclause=yes name=i_cd_produto dbname="cd_produto" )
 column=(type=char(50) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_bruto dbname="vl_total_bruto" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_total_liquido dbname="vl_total_liquido" )
 column=(type=long updatewhereclause=yes name=n_cd_filial dbname="cd_filial" )
 column=(type=char(5) updatewhereclause=yes name=cd_uf_filial dbname="cd_uf_filial" )
 column=(type=datetime updatewhereclause=yes name=n_dh_recebimento dbname="dh_recebimento" )
 column=(type=long updatewhereclause=yes name=n_nr_nf dbname="nr_nf" )
 column=(type=long updatewhereclause=yes name=n_nr_nf_venda dbname="nr_nf_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_efetivo dbname="vl_bc_icms_efetivo" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_icms_efetivo dbname="pc_icms_efetivo" )
 column=(type=decimal(30) updatewhereclause=yes name=vl_icms_efetivo dbname="vl_icms_efetivo" )
 column=(type=char(15) updatewhereclause=yes name=cst_pis dbname="cst_pis" )
 column=(type=char(20) updatewhereclause=yes name=cst_cofins dbname="cst_cofins" )
 retrieve="select cast(i.cd_natureza_operacao as varchar(5)) as cfop, 
cast(g.de_grupo as varchar(15)) as de_grupo, 
cast(case p.id_situacao_pis_cofins when 'P' then 'POSITIVA' when 'N' then 'NEGATIVA' else 'TRIBUTADA' end as varchar(12)) as id_pis_cofins_prod, 
p.nr_classificacao_fiscal, 
i.cd_produto, 
cast(p.de_produto ||': '|| p.de_apresentacao_venda as varchar(50)) as de_produto, 
sum(i.qt_devolvida * vl_preco_unitario) as vl_total_bruto, 
sum(i.qt_devolvida * Round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2))  as vl_total_liquido, 
n.cd_filial as cd_filial, 
cast(cf.cd_unidade_federacao as varchar(5)) as cd_uf_filial, 
n.dh_recebimento, 
n.nr_nf, 
n.nr_nf_venda, 
CAse when coalesce(i.pc_icms,0) = 0 Then (Case 
											When cf.cd_unidade_federacao = 'PR' and n.dh_movimentacao_caixa<='2019/12/31' and tic.pc_icms = 19.5 Then 18 
											When cf.cd_unidade_federacao = 'RS' and n.dh_movimentacao_caixa<='2019/12/31' and tic.pc_icms = 17 Then 18 
											Else tic.pc_icms End) Else i.pc_icms End as pc_icms, 
sum(i.vl_bc_icms_efetivo) as vl_bc_icms_efetivo, 
CAse when coalesce(i.pc_icms_efetivo,0) = 0 Then (Case 
													When cf.cd_unidade_federacao = 'PR' and n.dh_movimentacao_caixa<='2019/12/31' and tic.pc_icms = 19.5 Then 18 
													When cf.cd_unidade_federacao = 'RS' and n.dh_movimentacao_caixa<='2019/12/31' and tic.pc_icms = 17 Then 18
													Else tic.pc_icms End) Else i.pc_icms_efetivo End as pc_icms_efetivo, 
sum(Case When coalesce(i.vl_icms_efetivo,0) = 0 Then round(i.qt_devolvida * Round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * ((CAse when coalesce(i.pc_icms_efetivo,0) = 0 Then (Case 
																																																When cf.cd_unidade_federacao = 'PR' and n.dh_movimentacao_caixa<='2019/12/31' and tic.pc_icms = 19.5 Then 18 
																																																When cf.cd_unidade_federacao = 'RS' and n.dh_movimentacao_caixa<='2019/12/31' and tic.pc_icms = 17 Then 18
																																																Else tic.pc_icms End) Else i.pc_icms_efetivo End) / 100), 2) Else i.vl_icms_efetivo ENd) as vl_icms_efetivo,
Cast(i.cd_cst_pis as varchar(15)) as cst_pis, 
Cast(i.cd_cst_cofins as varchar(20)) as cst_cofins 
from nf_devolucao_venda n (index idx_dh_movimentacao_caixa) inner join item_nf_devolucao_venda i (index pk_item_nf_devolucao_venda) 	on i.cd_filial = n.cd_filial+0 	and i.nr_nf = n.nr_nf+0 	and i.de_serie = n.de_serie 	and i.de_especie = n.de_especie inner join filial f (index pk_filial) 	on f.cd_filial = n.cd_filial inner join cidade cf (index pk_cidade) 	on cf.cd_cidade = f.cd_cidade+0 inner join filial fv (index pk_filial) 	on fv.cd_filial = n.cd_filial_venda+0 left outer join produto_geral p (index pk_produto_geral) 	on p.cd_produto = i.cd_produto+0 left outer join item_nf_dev_venda_destino id (index pk_item_nf_dev_venda_destino) 	on id.cd_filial = i.cd_filial+0 	and id.nr_nf = i.nr_nf+0 	and id.de_serie = i.de_serie 	and id.de_especie = i.de_especie 	and id.cd_produto = i.cd_produto 	and id.nr_sequencial = i.nr_sequencial left outer join nf_venda v (index pk_nf_venda) 	on v.cd_filial = n.cd_filial_venda+0 	and v.nr_nf = n.nr_nf_venda+0 	and v.de_serie = n.de_serie_venda 	and v.de_especie = n.de_especie_venda left outer join cliente cl (index pk_cliente) 	on cl.cd_cliente = n.cd_cliente||'' left outer join convenio cv (index pk_convenio) 	on cv.cd_convenio = n.cd_convenio+0 left outer join conveniado co (index pk_conveniado) 	on co.cd_convenio = n.cd_convenio+0   and co.cd_conveniado = n.cd_conveniado left outer join usuario uvv (index pk_usuario) 	on uvv.nr_matricula = v.nr_matricula_vendedor left outer join usuario uvo (index pk_usuario) 	on uvo.nr_matricula = v.nr_matric_operador left outer join usuario udo (index pk_usuario) 	on udo.nr_matricula = n.nr_matricula_operador left outer join usuario udc (index pk_usuario) 	on udc.nr_matricula = n.nr_matricula_cancelamento left outer join pedido_ecommerce pe (index pk_pedido_ecommerce) 	on pe.cd_filial_ecommerce = coalesce(v.cd_filial_ecommerce, 809) 	and pe.nr_pedido = v.nr_pedido_ecommerce left outer join pedido_ecommerce_auxiliar pea (index pk_pedido_ecommerce_auxiliar) 	on pea.cd_filial_ecommerce = coalesce(v.cd_filial_ecommerce, 809) 	and pea.nr_pedido = v.nr_pedido_ecommerce left outer join historico_produto hp (index pk_historico_produto) 	on hp.cd_produto = p.cd_produto+0 	and hp.dh_historico = cast(cast(year(n.dh_movimentacao_caixa) as varchar)||'/'||cast(month(n.dh_movimentacao_caixa) as varchar)||'/01' as datetime)left outer join historico_produto_uf hpu (index pk_historico_produto_uf) 	on hpu.cd_produto = hp.cd_produto+0 	and hpu.dh_historico = hp.dh_historico 	and hpu.cd_unidade_federacao = cf.cd_unidade_federacao left outer join subcategoria t (index pk_subcategoria) 	on t.cd_subcategoria = coalesce(hp.cd_subcategoria, p.cd_subcategoria) left outer join categoria c (index pk_categoria) 	on c.cd_categoria = t.cd_categoria||'' left outer join subgrupo s (index pk_subgrupo) 	on s.cd_subgrupo = c.cd_subgrupo||'' left outer join grupo g (index pk_grupo) 	on g.cd_grupo = s.cd_grupo||'' left outer join movimento_estoque me (index idx_nota) 	on me.cd_filial_movimento = i.cd_filial+0 	and me.nr_nf = i.nr_nf+0 	and me.de_serie = i.de_serie 	and me.de_especie = i.de_especie 	and me.cd_produto = i.cd_produto+0 	and coalesce(me.nr_sequencial, 1) = i.nr_sequencial left outer join canal_venda cnv (index pk_canal_venda)  	on cnv.cd_canal_venda = upper(case when v.dh_movimentacao_caixa >= '2019/01/01' then coalesce(case when pe.de_canal_compra_vtex in ('app_android', 'app_ios', 'app_android_n', 'app_ios_n') then 'ap' else v.cd_canal_venda end, 'lf') else case when v.nr_pedido_ecommerce > 0 then 'ec'  else case when v.nr_pedido_drogaexpress is not null then 'de' else 'lf' end end end) 
left join produto_uf pu on pu.cd_unidade_federacao = cf.cd_unidade_federacao and pu.cd_produto = p.cd_produto
left join tipo_icms tic on tic.cd_tipo_icms = pu.cd_tipo_icms
Where  n.dh_cancelamento is null 
and  p.id_situacao_pis_cofins='T' 
and  i.cd_natureza_operacao=1411
and  n.dh_movimentacao_caixa<='2025/02/28' 
and  n.dh_movimentacao_caixa>='2025/02/01'
And i.cd_cst_pis = '50'
And i.cd_cst_cofins = '50'
and 1=1 
group by cast(i.cd_natureza_operacao as varchar(5)), 
cast(g.de_grupo as varchar(15)), 
cast(case p.id_situacao_pis_cofins when 'P' then 'POSITIVA' when 'N' then 'NEGATIVA' else 'TRIBUTADA' end as varchar(12)), 
p.nr_classificacao_fiscal, 
i.cd_produto, 
cast(p.de_produto ||': '|| p.de_apresentacao_venda as varchar(50)), 
n.cd_filial, 
cast(cf.cd_unidade_federacao as varchar(5)), 
n.dh_recebimento, 
n.nr_nf, 
n.nr_nf_venda, 
CAse when coalesce(i.pc_icms,0) = 0 Then (Case 
											When cf.cd_unidade_federacao = 'PR' and n.dh_movimentacao_caixa<='2019/12/31' and tic.pc_icms = 19.5 Then 18 
											When cf.cd_unidade_federacao = 'RS' and n.dh_movimentacao_caixa<='2019/12/31' and tic.pc_icms = 17 Then 18 
											Else tic.pc_icms End) Else i.pc_icms End , 
CAse when coalesce(i.pc_icms_efetivo,0) = 0 Then (Case 
													When cf.cd_unidade_federacao = 'PR' and n.dh_movimentacao_caixa<='2019/12/31' and tic.pc_icms = 19.5 Then 18 
													When cf.cd_unidade_federacao = 'RS' and n.dh_movimentacao_caixa<='2019/12/31' and tic.pc_icms = 17 Then 18
													Else tic.pc_icms End) Else i.pc_icms_efetivo End,
Cast(i.cd_cst_pis as varchar(15)) , 
Cast(i.cd_cst_cofins as varchar(20))  
" data.storage=disk )
