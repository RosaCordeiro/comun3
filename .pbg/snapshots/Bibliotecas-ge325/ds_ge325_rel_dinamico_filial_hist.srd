vl_credito_cofins,
dh_inclusao,
vl_icms_efetivo_calc
from dbo.credito_pis_cofins 
where cd_filial = :pl_cd_filial
and ano_mes = :ps_ano_mes
and dh_movimentacao_caixa >= '20170315'" update="dbo.credito_pis_cofins" updatewhere=0 updatekeyinplace=no data.storage=disk arguments=(("pl_cd_filial", number),("ps_ano_mes", string)) )
