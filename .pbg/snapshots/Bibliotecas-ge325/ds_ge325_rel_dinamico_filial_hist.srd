dh_movimentacao_caixa,
cd_unidade_federacao,
qt_vendida,
cd_cst_origem,
cd_cst_icms,
cd_cst_pis,
vl_bc_pis,
vl_pis,
cd_cst_cofins,
vl_bc_cofins,
vl_cofins,
vl_bc_icms,
pc_icms,
pc_fcp,
vl_icms,
vl_bc_icms_efetivo,
pc_icms_efetivo,
vl_icms_efetivo,
de_chave_acesso,
nf_ecf,
nr_operacao_ecf,
nr_coo_ecf,
nr_serie_ecf,
nr_serie_mfd_ecf,
pc_icms_atual,
pc_fcp_atual,
vl_base_credito_pis,
vl_credito_pis,
