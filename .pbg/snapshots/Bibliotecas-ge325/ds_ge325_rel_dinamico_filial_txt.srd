table(column=(type=long updatewhereclause=yes name=cd_filial dbname="a_nf_venda_cfop.cd_filial" dbalias="x.cd_filial" )
 column=(type=long updatewhereclause=yes name=mes dbname="mes" )
 column=(type=long updatewhereclause=yes name=ano dbname="ano" )
 column=(type=char(5) updatewhereclause=yes name=cd_cfop dbname="a_nf_venda_cfop.cd_cfop" dbalias="x.cd_cfop" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="a_nf_venda_cfop.pc_icms" dbalias="x.pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_efetivo dbname="a_nf_venda_cfop.pc_icms_efetivo" dbalias="x.pc_icms_efetivo" )
