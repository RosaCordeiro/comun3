 column=(type=decimal(2) updatewhereclause=yes name=vl_base_icms dbname="vl_base_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="vl_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_fcp dbname="vl_fcp" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_pis dbname="vl_bc_pis" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pis dbname="vl_pis" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_cofins dbname="vl_bc_cofins" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cofins dbname="vl_cofins" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_efetivo dbname="vl_bc_icms_efetivo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_efetivo dbname="vl_icms_efetivo" )
 retrieve="select 	x.cd_filial, 
		MONTH(x.dh_movimentacao_caixa) as mes, 
		YEAR (x.dh_movimentacao_caixa) as ano,
		x.cd_cfop, 
	    x.pc_icms,
		x.pc_icms_efetivo,
		x.pc_icms_atual,
		x.pc_fcp_atual,
		x.pc_icms_mes,
		x.pc_fcp_mes,
		sum(x.vl_total_bruto) vl_total_bruto , 
		sum(x.vl_total_liquido) vl_total_liquido , 
		sum(x.vl_base_icms) vl_base_icms ,
		sum(x.vl_icms) vl_icms ,
		sum(x.vl_fcp) vl_fcp ,
		sum(x.vl_bc_pis) vl_bc_pis ,
		sum(x.vl_pis) vl_pis ,
		sum(x.vl_bc_cofins) vl_bc_cofins ,
		sum(x.vl_cofins) vl_cofins ,
		sum(x.vl_bc_icms_efetivo) vl_bc_icms_efetivo ,
		sum(x.vl_icms_efetivo) vl_icms_efetivo 
from dbo.a_nf_venda_cfop x
where x.dh_movimentacao_caixa between :pdt_ini and :pdt_fim
group by x.cd_filial, 
			MONTH(x.dh_movimentacao_caixa), 
		YEAR (x.dh_movimentacao_caixa), 
		x.cd_cfop, 
	    x.pc_icms,
		x.pc_icms_efetivo,
		x.pc_icms_atual,
		x.pc_fcp_atual,
		x.pc_icms_mes,
		x.pc_fcp_mes" arguments=(("pdt_ini", datetime),("pdt_fim", datetime)) )
