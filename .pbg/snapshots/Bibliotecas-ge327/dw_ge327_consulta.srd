table(column=(type=long update=yes updatewhereclause=yes name=cd_produto_abcfarma dbname="produto_abcfarma.cd_produto_abcfarma" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_controle_preco dbname="produto_abcfarma.id_controle_preco" values=" LIBERADO	L/MONITORADO	M/LIBER. PRE$$HEX1$$c700$$ENDHEX$$O FAB.	X/HOSPITALAR	T/" )
 column=(type=char(30) update=yes updatewhereclause=yes name=nm_fabricante dbname="produto_abcfarma.nm_fabricante" )
 column=(type=char(45) update=yes updatewhereclause=yes name=de_produto dbname="produto_abcfarma.de_produto" )
 column=(type=char(45) update=yes updatewhereclause=yes name=de_apresentacao dbname="produto_abcfarma.de_apresentacao" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_fabricante dbname="produto_abcfarma.vl_preco_fabricante" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_venda_maximo dbname="produto_abcfarma.vl_preco_venda_maximo" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_ipi dbname="produto_abcfarma.pc_ipi" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_vigencia dbname="produto_abcfarma.dh_vigencia" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_produto_novo dbname="produto_abcfarma.id_produto_novo" values="Produto Novo ?	S/Produto Novo ?	N" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_atualizacao dbname="produto_abcfarma.dh_atualizacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_fabricante_18 dbname="produto_abcfarma.vl_preco_fabricante_18" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_18 dbname="produto_abcfarma.vl_preco_venda_18" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="codigo_barras_produto.cd_produto" )
 column=(type=char(1) updatewhereclause=yes name=de_localizacao dbname="de_localizacao" )
 retrieve="select a.cd_produto_abcfarma,   
       a.id_controle_preco,   
       a.nm_fabricante,   
       a.de_produto,   
       a.de_apresentacao,   
       a.vl_preco_fabricante,   
       a.vl_preco_venda_maximo,   
       a.pc_ipi,   
       a.dh_vigencia,   
       a.id_produto_novo,   
       a.dh_atualizacao, 
       a.vl_preco_fabricante_18,
       a.vl_preco_venda_18,  
       c.cd_produto,     
       '' de_localizacao
from produto_abcfarma a
	left outer join codigo_barras_produto c
		on c.de_codigo_barras = a.de_codigo_barras
where a.cd_produto_abcfarma = :produto" arguments=(("produto", number)) )
