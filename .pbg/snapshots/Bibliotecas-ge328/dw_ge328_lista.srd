table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="nf_compra.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_compra.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_compra.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_compra.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_compra.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_compra.vl_total_nf" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="nf_compra.nr_pedido" )
 column=(type=char(1) updatewhereclause=yes name=id_bonificacao dbname="nf_compra.id_bonificacao" )
 column=(type=char(1) updatewhereclause=yes name=id_confirmada dbname="id_confirmada" )
 column=(type=long updatewhereclause=yes name=cd_condicao_pedido dbname="pedido_central.cd_condicao_pedido" )
 column=(type=char(40) updatewhereclause=yes name=de_condicao_pedido dbname="condicao_pagamento.de_condicao_pedido" )
 column=(type=long updatewhereclause=yes name=cd_condicao_nf dbname="nf_compra.cd_condicao_nf" )
 column=(type=char(40) updatewhereclause=yes name=de_condicao_nf dbname="condicao_pagamento.de_condicao_nf" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="vw_item_nf_compra.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_central_produto.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="vw_item_nf_compra.qt_faturada" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_pedido dbname="pedido_central_produto.vl_preco_pedido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_nf dbname="vw_item_nf_compra.vl_preco_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_pedido dbname="pedido_central_produto.pc_desconto_pedido" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_cabecalho_pedido dbname="pedido_central.pc_desconto_cabecalho_pedido" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_nf dbname="vw_item_nf_compra.pc_desconto_nf" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_custo_atual dbname="vl_custo_atual" )
 column=(type=decimal(28) updatewhereclause=yes name=vl_custo_nf dbname="vw_item_nf_compra.vl_custo_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_repasse_icms dbname="pc_repasse_icms" )
 column=(type=char(1) updatewhereclause=yes name=id_repasse dbname="id_repasse" )
 retrieve="select n.cd_fornecedor,
       f.nm_razao_social,
       n.nr_nf,
       n.de_especie,
       n.de_serie,
       n.dh_movimentacao_caixa,
       n.vl_total_nf,
       n.nr_pedido_central nr_pedido,
       n.id_bonificacao,
       'S' id_confirmada,       
       p.cd_condicao_pagamento cd_condicao_pedido,
       cp.de_condicao de_condicao_pedido,
       n.cd_condicao_pagamento cd_condicao_nf,
       cn.de_condicao de_condicao_nf,
       i.cd_produto,
       g.de_produto + ' : ' + g.de_apresentacao_estoque de_produto,
       b.qt_pedida,
       i.qt_faturada,
       b.vl_preco_unitario vl_preco_pedido,
       i.vl_preco_unitario vl_preco_nf,
       b.pc_desconto pc_desconto_pedido,
	   p.pc_desconto pc_desconto_cabecalho_pedido,
       i.pc_desconto pc_desconto_nf,
       round(c.vl_custo_gerencial * g.vl_fator_conversao, 2) vl_custo_atual,
       i.vl_custo vl_custo_nf,
	  isnull(b.pc_repasse_icms, 0) pc_repasse_icms,
	  :id_repasse id_repasse
from nf_compra n,
     vw_item_nf_compra i,
     pedido_central p,
     pedido_central_produto b,
     produto_geral g,
     produto_central c,
     fornecedor f,
     condicao_pagamento cp,
     condicao_pagamento cn
where i.cd_filial     = n.cd_filial
  and i.cd_fornecedor = n.cd_fornecedor
  and i.nr_nf         = n.nr_nf
  and i.de_especie    = n.de_especie
  and i.de_serie      = n.de_serie
  and p.nr_pedido     = n.nr_pedido_central
  and b.nr_pedido     = n.nr_pedido_central
  and b.cd_produto    = i.cd_produto
  and g.cd_produto    = i.cd_produto
  and c.cd_produto    = i.cd_produto
  and f.cd_fornecedor = n.cd_fornecedor
  and cp.cd_condicao  = p.cd_condicao_pagamento
  and cn.cd_condicao  = n.cd_condicao_pagamento

union

select n.cd_fornecedor,
       f.nm_razao_social,
       n.nr_nf,
       n.de_especie,
       n.de_serie,
       n.dh_registro dh_movimentacao_caixa,
       n.vl_total_nf,
       n.nr_pedido nr_pedido,
       n.id_bonificacao,
       'N' id_confirmada,
       p.cd_condicao_pagamento cd_condicao_pedido,
       cp.de_condicao de_condicao_pedido,
       n.cd_condicao_pagamento cd_condicao_nf,
       cn.de_condicao de_condicao_nf,
       i.cd_produto,
       g.de_produto + ' : ' + g.de_apresentacao_estoque de_produto,
       b.qt_pedida,
       i.qt_faturada,
       b.vl_preco_unitario vl_preco_pedido,
       i.vl_preco_unitario vl_preco_nf,
       b.pc_desconto pc_desconto_pedido,
	   p.pc_desconto pc_desconto_cabecalho_pedido,
       i.pc_desconto pc_desconto_nf,
       round(c.vl_custo_gerencial * g.vl_fator_conversao, 2) vl_custo_atual,
       i.vl_custo vl_custo_nf,
	  isnull(b.pc_repasse_icms, 0) pc_repasse_icms,
  	  :id_repasse id_repasse
from nf_compra_pendente n,
     vw_nf_compra_pendente_produto i,
     pedido_central p,
     pedido_central_produto b,
     produto_geral g,
     produto_central c,
     fornecedor f,
     condicao_pagamento cp,
     condicao_pagamento cn
where i.cd_filial     = n.cd_filial
  and i.cd_fornecedor = n.cd_fornecedor
  and i.nr_nf         = n.nr_nf
  and i.de_especie    = n.de_especie
  and i.de_serie      = n.de_serie
  and p.nr_pedido     = n.nr_pedido
  and b.nr_pedido     = n.nr_pedido
  and b.cd_produto    = i.cd_produto
  and g.cd_produto    = i.cd_produto
  and c.cd_produto    = i.cd_produto
  and f.cd_fornecedor = n.cd_fornecedor
  and cp.cd_condicao  = p.cd_condicao_pagamento
  and cn.cd_condicao  = n.cd_condicao_pagamento" arguments=(("id_repasse", string))  sort="cd_fornecedor A nr_nf A de_especie A de_serie A de_produto A " )
