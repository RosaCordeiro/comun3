table(column=(type=long updatewhereclause=yes name=cd_centro_custo dbname="cd_centro_custo" )
 column=(type=char(40) updatewhereclause=yes name=de_centro_custo dbname="centro_custo.de_centro_custo" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo dbname="vl_custo" )
 retrieve="select tudo.cd_centro_custo,
		 c.de_centro_custo,
		 tudo.cd_produto,   
         g.de_produto,   
         g.de_apresentacao_venda,
		tudo.dh_emissao,
		sum(tudo.qt_faturada) qt_faturada,		
        sum(tudo.vl_custo_unitario) vl_custo 

from (
		SELECT  n.cd_centro_custo,
					i.cd_produto, 
					n.dh_emissao,  
				 	sum(i.qt_faturada) qt_faturada,
					 sum(i.vl_custo_unitario) vl_custo_unitario
		FROM item_nf_almoxarifado i
		inner join nf_almoxarifado n on n.nr_nf 			= i.nr_nf  
		WHERE n.cd_centro_custo 	is not null  
		  and n.dh_cancelamento 	is null
		  and n.dh_movimentacao_caixa 		between :inicio and :termino
			and n.dh_emissao 					between :inicio_emi and :termino_emi
		group by n.cd_centro_custo,
					i.cd_produto,
					n.dh_emissao
		
		union all
		
		SELECT	n.cd_centro_custo,
				 	i.cd_produto,
					n.dh_emissao,
				 	sum(i.qt_transferida)  qt_faturada,
				  sum(i.vl_custo_unitario) vl_custo_unitario 
		FROM item_nf_transferencia i
		inner join nf_transferencia n	on n.cd_filial_origem		= i.cd_filial_origem 
												and n.nr_nf 					= i.nr_nf  
												and n.de_especie 			= i.de_especie 
												and n.de_serie 				= i.de_serie
		left outer join pedido_distribuidora	 p	on p.cd_filial						= n.cd_filial_destino
														and p.nr_pedido_distribuidora 	= n.nr_pedido_distribuidora
		left outer join pedido_distribuidora_almox a	on a.cd_filial						= p.cd_filial
																and a.nr_pedido_distribuidora	= p.nr_pedido_distribuidora
		left outer join pedido_almoxarifado pa	on pa.cd_filial		= a.cd_filial
															and pa.nr_pedido	= a.nr_pedido_almoxarifado
		WHERE n.cd_centro_custo 	is not null  
		  	and n.dh_cancelamento 	is null
		  	and n.dh_movimentacao_caixa 		between :inicio and :termino
			and n.dh_emissao 						between :inicio_emi and :termino_emi
			and n.cd_filial_origem = 534
			and n.id_almoxarifado = 'S'
		group by n.cd_centro_custo,
					i.cd_produto,
					n.dh_emissao
) as tudo
inner join produto_geral g on g.cd_produto = tudo.cd_produto
inner join centro_custo c on c.cd_centro_custo	= tudo.cd_centro_custo
group by	tudo.cd_centro_custo,
			c.de_centro_custo,
			tudo.cd_produto,   
			g.de_produto,   
			g.de_apresentacao_venda,
			tudo.dh_emissao

" arguments=(("inicio", datetime),("termino", datetime),("inicio_emi", datetime),("termino_emi", datetime))  sort="cd_centro_custo A de_produto A de_apresentacao_venda A " )
