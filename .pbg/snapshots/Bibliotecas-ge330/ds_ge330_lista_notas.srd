table(column=(type=char(44) update=yes updatewhereclause=yes key=yes name=de_chave_acesso dbname="nf_agendamento_ent.de_chave_acesso" dbalias="a.de_chave_acesso" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_emissao dbname="nf_agendamento_ent.dh_emissao" dbalias="a.dh_emissao" )
 column=(type=char(14) update=yes updatewhereclause=yes name=nr_cgc_fornecedor dbname="nf_agendamento_ent.nr_cgc_fornecedor" dbalias="a.nr_cgc_fornecedor" )
 retrieve="select a.de_chave_acesso,
		a.dh_emissao,
		a.nr_cgc_fornecedor
from nf_agendamento_ent a
where a.dh_liberacao_agendamento is not null
and a.dh_envio_site is null
and a.dh_cancelamento_agendamento is null
and not exists (select * from nfe_destinadas where de_chave_acesso = a.de_chave_acesso and id_situacao_nf = '3')
and exists (select * from recebimento_sap where de_chave_acesso = a.de_chave_acesso and id_situacao = 'P'   and dh_nf_agend_ent_integrada is not null    )
" update="nf_agendamento_ent" updatewhere=0 updatekeyinplace=no  sort="dh_emissao D " )
