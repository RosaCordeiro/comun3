 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_pedido dbname="pedido_central.pc_desconto_pedido" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_pedido_prd dbname="pedido_central_produto.pc_desconto_pedido_prd" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_repasse_icms_pedido dbname="pedido_central_produto.pc_repasse_icms_pedido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario_pedido dbname="pedido_central_produto.vl_preco_unitario_pedido" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_central_produto.qt_pedida" )
 column=(type=long updatewhereclause=yes name=nr_embalagem_padrao dbname="pedido_central_produto.nr_embalagem_padrao" )
 retrieve="  SELECT 	b.de_chave_acesso,   
				b.nr_item,   
				b.cd_produto,   
				b.cd_produto as cd_produto_original,   
				b.cd_cprod,   
				b.de_codigo_barras,   
				b.de_produto,   
				b.nr_classificacao_fiscal,   
				b.cd_natureza_operacao,   
				b.qt_faturada,   
				b.vl_preco_unitario,   
				b.pc_desconto,   
				b.vl_frete,   
				b.vl_seguro,   
				b.nr_item_pedido,   
				b.cd_cst_origem,   
				b.cd_cst_tributacao, 
				b.cd_cst_tributacao as cd_cst_tributacao_original,  
				b.vl_bc_icms,   
				b.pc_reducao_bc_icms,   
				b.pc_icms,   
				b.vl_icms,   
				b.vl_bc_icms_st,   
				b.pc_reducao_bc_icms_st,   
				b.pc_icms_st,   
				b.vl_icms_st,   
				b.vl_bc_ipi,   
				b.pc_ipi,   
				b.vl_ipi,   
				b.vl_outras_despesas,   
				b.de_codigo_barras_trib,
				(select count(*) from nf_agendamento_ent_item_diverg x where x.de_chave_acesso = b.de_chave_acesso and x.nr_item = b.nr_item) as qt_divergencias,
				b.qt_caixa_padrao,
				b.id_multiplic_dividir_cx_padrao,
				c.pc_desconto as pc_desconto_pedido,
				d.pc_desconto as pc_desconto_pedido_prd,
				d.pc_repasse_icms as pc_repasse_icms_pedido,
				d.vl_preco_unitario as vl_preco_unitario_pedido,
				d.qt_pedida,
				d.nr_embalagem_padrao
FROM nf_agendamento_ent					a
INNER JOIN nf_agendamento_ent_item	b on b.de_chave_acesso = a.de_chave_acesso
LEFT JOIN pedido_central					c on c.nr_pedido = a.nr_pedido_central
LEFT JOIN pedido_central_produto			d on d.nr_pedido = c.nr_pedido
													and  d.cd_produto = b.cd_produto
WHERE a.de_chave_acesso = :de_chave_acesso" update="nf_agendamento_ent_item" updatewhere=1 updatekeyinplace=no arguments=(("de_chave_acesso", string))  sort="de_produto A " )
