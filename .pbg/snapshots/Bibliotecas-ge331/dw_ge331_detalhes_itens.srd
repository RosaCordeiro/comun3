 column=(type=char(20) update=yes updatewhereclause=yes name=de_codigo_barras_trib dbname="nf_agendamento_ent_item.de_codigo_barras_trib" )
 column=(type=long updatewhereclause=yes name=qt_divergencias dbname="qt_divergencias" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_caixa_padrao dbname="nf_agendamento_ent_item.qt_caixa_padrao" )
