table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=char(60) updatewhereclause=yes name=nm_razao_social dbname="nm_razao_social" )
 column=(type=char(3) updatewhereclause=yes name=id_distribuidora dbname="id_distribuidora" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_agendamento_ent.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_agendamento_ent.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_agendamento_ent.de_serie" )
 column=(type=char(60) updatewhereclause=yes name=de_natureza_operacao dbname="nf_agendamento_ent.de_natureza_operacao" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_agendamento_ent.dh_emissao" )
 column=(type=long updatewhereclause=yes name=nr_pedido_central dbname="nf_agendamento_ent.nr_pedido_central" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_agendamento_ent.vl_total_nf" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_agendamento_ent.de_chave_acesso" )
 column=(type=datetime updatewhereclause=yes name=dh_liberacao_agendamento dbname="nf_agendamento_ent.dh_liberacao_agendamento" )
 column=(type=char(32768) updatewhereclause=yes name=de_retorno_webservice dbname="de_retorno_webservice" )
 column=(type=datetime updatewhereclause=yes name=dh_envio_site dbname="nf_agendamento_ent.dh_envio_site" )
 column=(type=long updatewhereclause=yes name=qt_divergencia_nota dbname="qt_divergencia_nota" )
 column=(type=long updatewhereclause=yes name=qt_divergencia_produto dbname="qt_divergencia_produto" )
 column=(type=long updatewhereclause=yes name=qt_nf_cancelada dbname="qt_nf_cancelada" )
 column=(type=long updatewhereclause=yes name=qt_nat_operacao_liberada dbname="qt_nat_operacao_liberada" )
 column=(type=char(40) updatewhereclause=yes name=nm_resp_liberacao dbname="usuario.nm_resp_liberacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_resp_cancelamento dbname="usuario.nm_resp_cancelamento" )
 column=(type=char(100) updatewhereclause=yes name=de_motivo_lib_agendamento dbname="nf_agendamento_ent.de_motivo_lib_agendamento" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento_agendamento dbname="nf_agendamento_ent.dh_cancelamento_agendamento" )
 column=(type=datetime updatewhereclause=yes name=leitura_xml dbname="LEITURA_XML" )
 column=(type=datetime updatewhereclause=yes name=envio_site dbname="nf_agendamento_ent.ENVIO_SITE" )
 column=(type=long updatewhereclause=yes name=lead_time_minutos dbname="LEAD_TIME_MINUTOS" )
 column=(type=long updatewhereclause=yes name=lead_time_horas dbname="LEAD_TIME_HORAS" )
 column=(type=char(3) updatewhereclause=yes name=entrou_nf dbname="ENTROU_NF" )
 column=(type=char(100) updatewhereclause=yes name=de_motivo_canc_agendamento dbname="nf_agendamento_ent.de_motivo_canc_agendamento" )
 column=(type=long updatewhereclause=yes name=qt_volumes dbname="nf_agendamento_ent.qt_volumes" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_cadastramento dbname="pedido_central.nr_matricula_cadastramento" )
 column=(type=char(40) updatewhereclause=yes name=nm_comprador dbname="usuario.nm_comprador" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao dbname="nf_agendamento_ent_msg_recusa.dh_atualizacao" )
 column=(type=char(32768) updatewhereclause=no name=mensagem_recusa dbname="nf_agendamento_ent_msg_recusa.mensagem_recusa" )
 column=(type=char(10) updatewhereclause=yes name=nr_pedido_sap dbname="pedido_central.nr_pedido_sap" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_previsao_entrega dbname="nf_agendamento_ent.dh_previsao_entrega" )
 column=(type=datetime updatewhereclause=yes name=dh_previsao_entrega_og dbname="nf_agendamento_ent.dh_previsao_entrega_og" )
 retrieve="select		case when e.cd_fornecedor is not null then
					e.cd_fornecedor
				else
					(select max(x.cd_fornecedor) from fornecedor x where x.nr_cgc = a.nr_cgc_fornecedor and (x.id_situacao = 'A'  or x.id_situacao is null))
			end as cd_fornecedor,
      
	
			case when e.nm_razao_social is not null then
					Upper( isnull (a.nm_razao_social ,  e.nm_razao_social))
				else
					(select x.nm_razao_social from fornecedor x where x.cd_fornecedor = (select max(x.cd_fornecedor) from fornecedor x where x.nr_cgc = a.nr_cgc_fornecedor and (x.id_situacao = 'A'  or x.id_situacao is null)))
			end as nm_razao_social,
			
			(select case when count(*) > 0 then 'SIM' else 'N$$HEX1$$c300$$ENDHEX$$O' end
			from fornecedor				a1
			inner join cidade				b1	on		b1.cd_cidade					= a1.cd_cidade
			inner join distribuidora_uf	c1	on		c1.cd_distribuidora			= a1.cd_fornecedor
													and	c1.cd_unidade_federacao	= b1.cd_unidade_federacao
			where a1.nr_cgc							= a.nr_cgc_fornecedor
			  and c1.id_homologando_pedido	= 'N') id_distribuidora,


			a.nr_nf,
			a.de_especie,
			a.de_serie,
			a.de_natureza_operacao,
			a.dh_emissao,
			a.nr_pedido_central,
			a.vl_total_nf,
			a.de_chave_acesso,
			a.dh_liberacao_agendamento,
			cast(a.de_retorno_webservice as text) as de_retorno_webservice,
			a.dh_envio_site,
			(select count(*) from nf_agendamento_ent_divergencia x	where x.de_chave_acesso = a.de_chave_acesso) qt_divergencia_nota,
			(select count(*) from nf_agendamento_ent_item_diverg z	where z.de_chave_acesso = a.de_chave_acesso) qt_divergencia_produto,
			(select count(*) from nfe_destinadas y	where y.de_chave_acesso = a.de_chave_acesso and y.id_situacao_nf = '3') qt_nf_cancelada,
			(Select count(cd_natureza_operacao)	 From nf_agendamento_ent_item	where de_chave_acesso = a.de_chave_acesso and cd_natureza_operacao in (6911, 5911, 5910, 6910) ) qt_nat_operacao_liberada,
			b.nm_usuario nm_resp_liberacao,
			c.nm_usuario nm_resp_cancelamento,
			a.de_motivo_lib_agendamento,
			a.dh_cancelamento_agendamento,
			n.dh_entrada 'LEITURA_XML', 
			a.dh_envio_site ENVIO_SITE,
			datediff(SS, n.dh_entrada, a.dh_envio_site) / 60 LEAD_TIME_MINUTOS,
			(Case when (datediff(SS, n.dh_entrada, a.dh_envio_site) / 60) > 1440 Then (datediff(SS, n.dh_entrada, a.dh_envio_site) / 60) / 60 else 0 END) LEAD_TIME_HORAS,
			(Case when (select count(*) from nf_compra_pendente where de_chave_acesso = n.id_nf)  + (select count(*) from nf_compra where de_chave_acesso = n.id_nf) > 0 Then 'SIM' else 'N$$HEX1$$c300$$ENDHEX$$O' END)  ENTROU_NF,
			a.de_motivo_canc_agendamento,
			a.qt_volumes,
			d.nr_matricula_cadastramento,
			u.nm_usuario as nm_comprador,
			r.dh_atualizacao,
			r.de_mensagem as mensagem_recusa,
			d.nr_pedido_sap,
			a.dh_previsao_entrega,
			a.dh_previsao_entrega as dh_previsao_entrega_og
from nf_agendamento_ent		    a
left outer join usuario         b on b.nr_matricula     = a.nr_matricula_lib_agendamento
left outer join usuario			c on c.nr_matricula     = a.nr_matricula_canc_agendamento
left outer join pedido_central	d on d.nr_pedido		= a.nr_pedido_central
left outer join fornecedor      e on e.cd_fornecedor    = d.cd_fornecedor
left outer join nfe_indexacao   n on n.id_nf 			= a.de_chave_acesso
left outer join usuario				u on u.nr_matricula = d.nr_matricula_cadastramento
left outer join nf_agendamento_ent_msg_recusa r on r.de_chave_acesso = a.de_chave_acesso
where a.dh_emissao between :dh_inicio and :dh_fim
order by a.dh_emissao" arguments=(("dh_inicio", date),("dh_fim", date)) )
