table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="pg.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_central_produto.qt_pedida" dbalias="it.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="pedido_central_produto.qt_recebida" dbalias="it.qt_recebida" )
 retrieve="select 
pg.cd_produto,
pg.de_produto+' : '+pg.de_apresentacao_estoque as de_produto,
it.qt_pedida,
it.qt_recebida
from pedido_central_produto it
inner join  produto_geral pg on pg.cd_produto = it.cd_produto
where it.nr_pedido = :nr_pedido
order by pg.de_produto,
			pg.de_apresentacao_estoque" arguments=(("nr_pedido", number)) )
