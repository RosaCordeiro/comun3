table(column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="de_chave_acesso" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=long updatewhereclause=yes name=nr_pedido_central dbname="nr_pedido_central" )
 column=(type=datetime updatewhereclause=yes name=dh_envio_site dbname="dh_envio_site" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento_agendamento dbname="dh_cancelamento_agendamento" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=char(60) updatewhereclause=yes name=nm_razao_social dbname="nm_razao_social" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_cadastramento dbname="nr_matricula_cadastramento" )
 column=(type=char(40) updatewhereclause=yes name=nm_comprador dbname="nm_comprador" )
 column=(type=char(100) updatewhereclause=yes name=de_endereco_email dbname="de_endereco_email" )
 column=(type=char(32768) updatewhereclause=no name=de_mensagem dbname="de_mensagem" )
 column=(type=char(32768) updatewhereclause=no name=de_mensagem_old dbname="de_mensagem_old" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao dbname="dh_atualizacao" )
 column=(type=datetime updatewhereclause=yes name=dh_envio_msg_email dbname="dh_envio_msg_email" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_recusa dbname="nr_matricula_recusa" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_recusa dbname="nm_usuario_recusa" )
 column=(type=char(100) updatewhereclause=yes name=de_endereco_email_aux dbname="de_endereco_email_aux" )
 retrieve="select a.de_chave_acesso, 
		 a.nr_nf,
		 a.de_especie,
		 a.de_serie,
		 a.dh_emissao,
		 a.vl_total_nf,
		 a.nr_pedido_central,
 		 a.dh_envio_site,
		 a.dh_cancelamento_agendamento,

		case when e.cd_fornecedor is not null then
				e.cd_fornecedor
			else
				(select max(x.cd_fornecedor) from fornecedor x where x.nr_cgc = a.nr_cgc_fornecedor and (x.id_situacao = 'A'  or x.id_situacao is null))
		end as cd_fornecedor,
	
		case when e.nm_razao_social is not null then
				Upper( isnull (a.nm_razao_social ,  e.nm_razao_social))
			else
				(select x.nm_razao_social from fornecedor x where x.cd_fornecedor = (select max(x.cd_fornecedor) from fornecedor x where x.nr_cgc = a.nr_cgc_fornecedor and (x.id_situacao = 'A'  or x.id_situacao is null)))
		end as nm_razao_social, 	
		
		d.nr_matricula_cadastramento,
		u.nm_usuario as nm_comprador,
		u.de_endereco_email,
		r.de_mensagem,
		r.de_mensagem as de_mensagem_old,
		r.dh_atualizacao,
		r.dh_envio_msg_email,
		r.nr_matricula_recusa,
		ru.nm_usuario as nm_usuario_recusa,
		cu.de_endereco_email as de_endereco_email_aux

from nf_agendamento_ent		    a
left outer join pedido_central	d on d.nr_pedido		= a.nr_pedido_central
left outer join dbo.comprador 	c on c.nr_matricula 	= d.nr_matricula_cadastramento
left outer join fornecedor      e on e.cd_fornecedor    = d.cd_fornecedor
left outer join usuario         u on u.nr_matricula     	= d.nr_matricula_cadastramento
left outer join nf_agendamento_ent_msg_recusa r on  r.de_chave_acesso = a.de_chave_acesso
left outer join usuario 		ru on r.nr_matricula_recusa = ru.nr_matricula
left outer join usuario 		cu on cu.nr_matricula = c.nr_matricula_auxiliar 
where a.de_chave_acesso = :de_chave_acesso" arguments=(("de_chave_acesso", string)) )
