table(column=(type=long updatewhereclause=yes name=nr_pedido dbname="nr_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_pedido dbname="dh_pedido" )
 column=(type=char(9) updatewhereclause=yes name=situacao dbname="situacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="nm_usuario" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula dbname="nr_matricula" )
 column=(type=char(40) updatewhereclause=yes name=de_condicao dbname="de_condicao" )
 column=(type=char(40) updatewhereclause=yes name=nm_fornecedor dbname="nm_fornecedor" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=perc_atendido dbname="perc_atendido" )
 retrieve="select nr_pedido,
		dh_pedido,
		situacao,
		nm_usuario,
		nr_matricula,
		de_condicao,
		nm_fornecedor,
		cd_fornecedor,
		perc_atendido
from(
	select a.nr_pedido,
			 a.dh_pedido,
			 case a.id_situacao
					when 'A' then 'ATENDIDO'
					when 'C' then 'COLOCADO'
					when 'X' then 'CANCELADO'
			 end as situacao,
			 b.nm_usuario,
			a.nr_matricula_cadastramento as nr_matricula,
			 c.de_condicao,
			 d.nm_fantasia as nm_fornecedor,
			a.cd_fornecedor,
			 (Select Round((sum(qt_recebida) * 100) / sum(qt_pedida), 2)
			  From pedido_central_produto
			  Where nr_pedido = a.nr_pedido) as perc_atendido
	from pedido_central               a
	left join usuario                 b on b.nr_matricula  = a.nr_matricula_cadastramento
	left join condicao_pagamento      c on c.cd_condicao   = a.cd_condicao_pagamento
	left join fornecedor              d on d.cd_fornecedor = a.cd_fornecedor
	where a.cd_fornecedor in (select max(cd_fornecedor) from fornecedor where nr_cgc in (:nr_cgc_fornecedor, :nr_cgc_fornecedor_remessa))
	and a.dh_pedido >= dateadd(day,-60, getdate() )
	and a.cd_filial = 534
	and a.id_situacao in ('A', 'C')
	and a.dh_pedido <= cast(getDate() as date)
) as tudo
where perc_atendido < 100
order by dh_pedido desc" arguments=(("nr_cgc_fornecedor", string),("nr_cgc_fornecedor_remessa", string)) )
