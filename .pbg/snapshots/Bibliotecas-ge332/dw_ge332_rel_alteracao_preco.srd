table(column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(60) update=yes updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" )
 column=(type=char(3) update=yes updatewhereclause=yes name=cd_unidade_medida_compra dbname="produto_geral.cd_unidade_medida_compra" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_venda_atual dbname="produto_geral.vl_preco_venda_atual" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_preco_venda_atual dbname="produto_geral.dh_preco_venda_atual" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_venda_futuro dbname="produto_geral.vl_preco_venda_futuro" )
 column=(type=datetime updatewhereclause=yes name=dh_preco_venda_futuro dbname="produto_geral.dh_preco_venda_futuro" )
 column=(type=long updatewhereclause=yes name=cd_grupo_produto dbname="produto_geral.cd_grupo_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo_produto dbname="grupo_produto.de_grupo_produto" )
 retrieve="select pg.cd_produto,   
        pg.de_produto,   
        pg.de_apresentacao_venda,   
        pg.de_apresentacao_estoque,   
        pg.cd_unidade_medida_compra,   
        pg.vl_preco_venda_atual,   
        pg.dh_preco_venda_atual,   
        pg.vl_preco_venda_futuro,   
        pg.dh_preco_venda_futuro,   
        pg.cd_grupo_produto, 
        gp.de_grupo_produto   
 from produto_geral pg, 
      grupo_produto gp
 where gp.cd_grupo_produto = pg.cd_grupo_produto
and 	 pg.dh_preco_venda_atual >= :inicio
and 	 pg.dh_preco_venda_atual <	:termino

union

select pg.cd_produto,   
        pg.de_produto,   
        pg.de_apresentacao_venda,   
        pg.de_apresentacao_estoque,   
        pg.cd_unidade_medida_compra,   
        pg.vl_preco_venda_atual,   
        pg.dh_preco_venda_atual,   
        pg.vl_preco_venda_futuro,   
        pg.dh_preco_venda_futuro,   
        pg.cd_grupo_produto, 
        gp.de_grupo_produto   
 from produto_geral pg, 
      grupo_produto gp 
 where gp.cd_grupo_produto = pg.cd_grupo_produto
and 	 pg.dh_preco_venda_futuro >= :inicio
and 	 pg.dh_preco_venda_futuro < 	:termino
" arguments=(("inicio", date),("termino", date))  sort="cd_grupo_produto A descricao A cd_unidade_medida_compra A " )
