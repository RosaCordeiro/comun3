table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=qt_entrada dbname="qt_entrada" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_entrada dbname="vl_entrada" )
 column=(type=long updatewhereclause=yes name=qt_saida dbname="qt_saida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_saida dbname="vl_saida" )
 column=(type=long updatewhereclause=yes name=qt_total dbname="qt_total" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total dbname="vl_total" )
 retrieve="select 	f.cd_filial as cd_filial, 	
			f.nm_fantasia,
			//entradas
			sum(case when me.cd_tipo_movimento in (8,12) then  me.qt_movimento else 0 end) as qt_entrada,
			sum(case when me.cd_tipo_movimento in (8,12) then  round(me.qt_movimento * me.vl_custo_unitario,2) else 0.00 end) as vl_entrada,
			//saidas
			sum(case when me.cd_tipo_movimento in (9,13) then  me.qt_movimento else 0 end) as qt_saida,
			sum(case when me.cd_tipo_movimento in (9,13) then  round(me.qt_movimento * me.vl_custo_unitario,2) else 0.00 end) as vl_saida,
			//total (entradas - saidas)
			sum(case when tm.id_entrada_saida = 'E' then 1 else -1 end * case when tm.id_cancelamento = 'S' then -1 else 1 end * me.qt_movimento) as qt_total, 
			sum(case when tm.id_entrada_saida = 'E' then 1 else -1 end * case when tm.id_cancelamento = 'S' then -1 else 1 end * round(me.qt_movimento * me.vl_custo_unitario,2)) as vl_total
from movimento_estoque me (index idx_produto_data_fil)
inner join tipo_movimento_estoque tm (index pk_tipo_movimento_estoque)
	on tm.cd_tipo_movimento = me.cd_tipo_movimento
inner join filial f  (index pk_filial)
	on f.cd_filial = me.cd_filial_movimento
Where me.dh_movimento between :dh_inicio and :dh_fim
and me.cd_produto = :produto
and me.cd_tipo_movimento in (8,9,12,13)
group by f.cd_filial, 	
			f.nm_fantasia" arguments=(("dh_inicio", datetime),("dh_fim", datetime),("produto", number))  sort="cd_filial A " )
