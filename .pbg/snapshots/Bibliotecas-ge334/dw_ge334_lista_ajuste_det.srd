table(column=(type=long updatewhereclause=yes name=cd_motivo_ajuste dbname="motivo_ajuste.cd_motivo_ajuste" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo_ajuste dbname="motivo_ajuste.de_motivo_ajuste" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="ajuste_estoque.dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=qt_ajuste dbname="qt_ajuste" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="ajuste_estoque.vl_custo_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_custo dbname="vl_total_custo" )
 column=(type=char(40) updatewhereclause=yes name=de_comentario_ajuste dbname="ajuste_estoque.de_comentario_ajuste" )
 column=(type=char(1) updatewhereclause=yes name=id_entrada_saida dbname="ajuste_estoque.id_entrada_saida" values="ENTRADA	E/SA$$HEX1$$cd00$$ENDHEX$$DA	S/" )
 retrieve="select 	ma.cd_motivo_ajuste,
			ma.de_motivo_ajuste, 
			aj.dh_movimentacao_caixa, 
			case when aj.id_entrada_saida = 'E' then 1 else -1 end  * aj.qt_ajuste as qt_ajuste, 
			aj.vl_custo_unitario, 
			case when aj.id_entrada_saida = 'E' then 1 else -1 end  * aj.qt_ajuste * aj.vl_custo_unitario as vl_total_custo, 
			aj.de_comentario_ajuste, 	
			aj.id_entrada_saida
from ajuste_estoque aj
inner join motivo_ajuste ma
	on ma.cd_motivo_ajuste = aj.cd_motivo_ajuste
Where aj.dh_movimentacao_caixa between :dh_inicio and :dh_fim
and aj.cd_filial_ajuste = :filial
and aj.cd_produto = :produto" arguments=(("dh_inicio", datetime),("dh_fim", datetime),("produto", number),("filial", number)) )
