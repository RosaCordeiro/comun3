table(column=(type=long updatewhereclause=yes name=cd_filial dbname="resumo_produto_compra.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=qt_compra dbname="qt_compra" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_compra dbname="vl_compra" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_impostos dbname="vl_impostos" )
 retrieve="select 	r.cd_filial, 
			f.nm_fantasia, 
			sum(r.qt_faturada) as qt_compra, 
			sum(r.vl_preco_liquido) as vl_compra,
			sum(r.vl_impostos) as vl_impostos
from resumo_produto_compra r
inner join filial f
	on f.cd_filial = r.cd_filial
where r.cd_produto = :produto 
	and r.dh_resumo between :dh_inicio and :dh_fim
group by r.cd_filial, 
			f.nm_fantasia" arguments=(("dh_inicio", datetime),("dh_fim", datetime),("produto", number))  sort="cd_filial A " )
