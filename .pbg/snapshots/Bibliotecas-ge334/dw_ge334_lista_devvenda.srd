table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=qt_movimento dbname="qt_movimento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_custo dbname="vl_total_custo" )
 column=(type=long updatewhereclause=yes name=qt_devolucao dbname="qt_devolucao" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_devolucao dbname="vl_devolucao" )
 column=(type=long updatewhereclause=yes name=qt_cancelamento dbname="qt_cancelamento" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_cancelamento dbname="vl_cancelamento" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_total dbname="vl_total" )
 retrieve="select 	f.cd_filial as cd_filial, 	
			f.nm_fantasia,
			sum(case when tm.id_entrada_saida = 'E' then 1 else -1 end * case when tm.id_cancelamento = 'S' then -1 else 1 end * me.qt_movimento) as qt_movimento, 
			//custo
			sum(case when tm.id_entrada_saida = 'E' then 1 else -1 end * case when tm.id_cancelamento = 'S' then -1 else 1 end * me.qt_movimento * me.vl_custo_unitario) as vl_total_custo, 
			//devolucoes
			sum(case when me.cd_tipo_movimento = 10 then  me.qt_movimento else 0 end) as qt_devolucao,
			sum(case when me.cd_tipo_movimento = 10 then  round(me.qt_movimento * i.vl_preco_unitario * ( 1 - i.pc_desconto / 100),2) else 0.00 end) as vl_devolucao,
			//cancelamentos devolucoes
			sum(case when me.cd_tipo_movimento = 11 then  me.qt_movimento else 0 end) as qt_cancelamento,
			sum(case when me.cd_tipo_movimento = 11 then  round(me.qt_movimento * i.vl_preco_unitario * ( 1 - i.pc_desconto / 100),2) else 0.00 end) as vl_cancelamento,
			//total (devolucoes - cancelamentos)
			sum(case when tm.id_entrada_saida = 'E' then 1 else -1 end * case when tm.id_cancelamento = 'S' then -1 else 1 end * round(me.qt_movimento * i.vl_preco_unitario * ( 1 - i.pc_desconto / 100),2)) as vl_total
from movimento_estoque me (index idx_produto_data_fil)
inner join tipo_movimento_estoque tm (index pk_tipo_movimento_estoque)
	on tm.cd_tipo_movimento = me.cd_tipo_movimento
inner join filial f  (index pk_filial)
	on f.cd_filial = me.cd_filial_movimento
inner join item_nf_devolucao_venda i  (index pk_item_nf_devolucao_venda)
	on i.cd_filial = me.cd_filial_movimento
	and i.nr_nf = me.nr_nf
	and i.de_serie = me.de_serie
	and i.de_especie = me.de_especie
	and i.cd_produto = me.cd_produto
	and i.nr_sequencial = coalesce(me.nr_sequencial,1)
Where me.dh_movimento between :dh_inicio and :dh_fim
and me.cd_produto = :produto
and me.cd_tipo_movimento in (10,11)
group by f.cd_filial, 	
			f.nm_fantasia" arguments=(("dh_inicio", datetime),("dh_fim", datetime),("produto", number))  sort="cd_filial A " )
