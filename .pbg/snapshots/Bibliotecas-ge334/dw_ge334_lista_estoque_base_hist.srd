table(column=(type=datetime updatewhereclause=yes name=dh_historico dbname="resumo_reposicao_estoque_hist.dh_historico" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_anterior dbname="resumo_reposicao_estoque_hist.qt_estoque_base_anterior" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_atual dbname="resumo_reposicao_estoque_hist.qt_estoque_base_atual" )
 column=(type=char(49) updatewhereclause=yes name=usuario_alteracao dbname="usuario_alteracao" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao_anterior dbname="resumo_reposicao_estoque_hist.id_alteracao_anterior" values="FILIAL	F/REC$$HEX1$$c100$$ENDHEX$$LCULO	N/MATRIZ	M/" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao_atual dbname="resumo_reposicao_estoque_hist.id_alteracao_atual" values="FILIAL	F/REC$$HEX1$$c100$$ENDHEX$$LCULO	N/MATRIZ	M/" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_bloqueio_atual dbname="resumo_reposicao_estoque_hist.dh_termino_bloqueio_atual" )
 retrieve="  SELECT 	r.dh_historico,
			 	r.qt_estoque_base_anterior,   
				r.qt_estoque_base_atual,   
				Case when r.nr_matricula_alteracao_atual is null then  'REC$$HEX1$$c100$$ENDHEX$$LCULO' else u.nm_usuario||' ('||r.nr_matricula_alteracao_atual||')' end  as usuario_alteracao,   
				r.id_alteracao_anterior,   
				r.id_alteracao_atual,   
				r.dh_termino_bloqueio_atual  
    FROM resumo_reposicao_estoque_hist r
Left outer Join usuario u
	On u.nr_matricula = r.nr_matricula_alteracao_atual
Where r.cd_filial = :filial
	and   r.cd_produto = :produto  " arguments=(("filial", number),("produto", number))  sort="dh_historico D dh_termino_bloqueio_atual A " )
