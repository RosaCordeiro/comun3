table(column=(type=long updatewhereclause=yes name=cd_filial dbname="resumo_movto_estq_prd.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=qt_compra dbname="qt_compra" )
 column=(type=long updatewhereclause=yes name=qt_transf_entrada dbname="qt_transf_entrada" )
 column=(type=long updatewhereclause=yes name=qt_devolucao_venda dbname="qt_devolucao_venda" )
 column=(type=long updatewhereclause=yes name=qt_ajuste_entrada dbname="qt_ajuste_entrada" )
 column=(type=long updatewhereclause=yes name=qt_entrada dbname="qt_entrada" )
 column=(type=long updatewhereclause=yes name=qt_ajuste_saida dbname="qt_ajuste_saida" )
 column=(type=long updatewhereclause=yes name=qt_devolucao_compra dbname="qt_devolucao_compra" )
 column=(type=long updatewhereclause=yes name=qt_transf_saida dbname="qt_transf_saida" )
 column=(type=long updatewhereclause=yes name=qt_venda dbname="qt_venda" )
 column=(type=long updatewhereclause=yes name=qt_saida dbname="qt_saida" )
 column=(type=long updatewhereclause=yes name=qt_movimentada dbname="qt_movimentada" )
 retrieve="select 	r.cd_filial,
			f.nm_fantasia,
			sum(r.qt_compra) as qt_compra, 
			sum(r.qt_transf_entrada) as qt_transf_entrada, 
			sum(r.qt_devolucao_venda) as qt_devolucao_venda, 
			sum(r.qt_ajuste_entrada) as qt_ajuste_entrada, 
			sum(r.qt_compra + r.qt_transf_entrada + r.qt_devolucao_venda + r.qt_ajuste_entrada) as qt_entrada,
			sum(r.qt_ajuste_saida) as qt_ajuste_saida, 
			sum(r.qt_devolucao_compra) as qt_devolucao_compra, 
			sum(r.qt_transf_saida) as qt_transf_saida, 
			sum(r.qt_venda) as qt_venda,
			sum(r.qt_ajuste_saida + r.qt_devolucao_compra + r.qt_transf_saida + r.qt_venda) as qt_saida,
			sum(r.qt_compra + r.qt_transf_entrada + r.qt_devolucao_venda + r.qt_ajuste_entrada - r.qt_ajuste_saida - r.qt_devolucao_compra - r.qt_transf_saida - r.qt_venda) as qt_movimentada
from resumo_movto_estq_prd r 
inner join filial f
	on f.cd_filial = r.cd_filial
where r.dh_resumo between :dh_inicio and  :dh_fim
	and r.cd_produto = :produto
group by r.cd_filial,
			f.nm_fantasia" arguments=(("dh_inicio", datetime),("dh_fim", datetime),("produto", number))  sort="cd_filial A " )
