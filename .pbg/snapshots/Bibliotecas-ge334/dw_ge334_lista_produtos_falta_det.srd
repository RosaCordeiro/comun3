table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_procurado_zerado.cd_produto" )
 column=(type=char(102) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" values="ATIVO	A/BLOQUEADO	B/INATIVO	I/" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="produto_procurado_zerado.cd_filial" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao dbname="produto_procurado_zerado.dh_movimentacao" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_preco_venda dbname="vl_preco_venda" )
 column=(type=long updatewhereclause=yes name=qt_falta dbname="produto_procurado_zerado.qt_falta" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_falta dbname="vl_falta" )
 retrieve="select  ppc.cd_produto,
		 pg.de_produto || ': '||pg.de_apresentacao_venda as de_produto,
		 pg.id_situacao,
		 ppc.cd_filial,
		 ppc.dh_movimentacao,
		 (pg.vl_preco_venda_atual / pg.vl_fator_conversao) as vl_preco_venda,
		 ppc.qt_consulta as qt_falta,
		 round(ppc.qt_consulta * (pg.vl_preco_venda_atual / pg.vl_fator_conversao),2) as vl_falta
FROM produto_procurado_zerado ppc
INNER JOIN produto_geral pg
	on pg.cd_produto = ppc.cd_produto
where ppc.dh_movimentacao between :dh_inicio and :dh_fim
	and ppc.cd_filial = :cd_filial
	and ppc.cd_produto = :produto
	and ppc.id_tipo = 'F'
	and ppc.qt_consulta > 0
" arguments=(("dh_inicio", datetime),("dh_fim", datetime),("produto", number),("cd_filial", number))  sort="dh_movimentacao D " )
