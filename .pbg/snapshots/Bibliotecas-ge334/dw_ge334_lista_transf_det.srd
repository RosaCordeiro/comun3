table(column=(type=long updatewhereclause=yes name=cd_tipo_movimento dbname="movimento_estoque.cd_tipo_movimento" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_movimento dbname="tipo_movimento_estoque.de_tipo_movimento" )
 column=(type=datetime updatewhereclause=yes name=dh_movimento dbname="movimento_estoque.dh_movimento" )
 column=(type=long updatewhereclause=yes name=qt_movimento dbname="qt_movimento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="vl_custo_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_custo dbname="vl_total_custo" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="movimento_estoque.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="movimento_estoque.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="movimento_estoque.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="movimento_estoque.de_serie" )
 column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="filial.cd_filial_origem" )
 column=(type=char(40) updatewhereclause=yes name=nm_filial_origem dbname="filial.nm_filial_origem" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="filial.cd_filial_destino" )
 column=(type=char(40) updatewhereclause=yes name=nm_filial_destino dbname="filial.nm_filial_destino" )
 retrieve="select 	me.cd_tipo_movimento,
			tm.de_tipo_movimento, 
			me.dh_movimento, 
			case when tm.id_entrada_saida = 'S' then -1 else 1 end * case when tm.id_cancelamento = 'S' then -1 else 1 end * me.qt_movimento as qt_movimento, 
			case when tm.id_entrada_saida = 'S' then -1 else 1 end * case when tm.id_cancelamento = 'S' then -1 else 1 end * me.vl_custo_unitario as vl_custo_unitario, 
			case when tm.id_entrada_saida = 'S' then -1 else 1 end * case when tm.id_cancelamento = 'S' then -1 else 1 end * me.qt_movimento * me.vl_custo_unitario as vl_total_custo, 
			me.cd_filial_movimento as cd_filial, 	
			me.nr_nf, 
			me.de_especie, 
			me.de_serie,
			fo.cd_filial as cd_filial_origem,
			fo.nm_fantasia as nm_filial_origem,
			fd.cd_filial as cd_filial_destino,
			fd.nm_fantasia as nm_filial_destino
from movimento_estoque me 
inner join tipo_movimento_estoque tm
	on tm.cd_tipo_movimento = me.cd_tipo_movimento
left outer join nf_transferencia n
	on n.cd_filial_origem = case when tm.cd_tipo_movimento in (6,7) then me.cd_filial_movimento else me.cd_filial end
	and n.nr_nf = me.nr_nf
	and n.de_especie = me.de_especie
	and n.de_serie = me.de_serie
left outer join filial fd
	on fd.cd_filial = n.cd_filial_destino
left outer join filial fo
	on fo.cd_filial = n.cd_filial_origem
Where me.dh_movimento between :dh_inicio and :dh_fim
and me.cd_filial_movimento = :filial
and me.cd_produto = :produto
and me.cd_tipo_movimento in (4,5,6,7)" arguments=(("dh_inicio", datetime),("dh_fim", datetime),("produto", number),("filial", number)) )
