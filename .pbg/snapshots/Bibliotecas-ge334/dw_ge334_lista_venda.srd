table(column=(type=long updatewhereclause=yes name=cd_filial dbname="resumo_produto_filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=qt_venda dbname="qt_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda dbname="vl_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cmv dbname="vl_cmv" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_comissao dbname="vl_comissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_rentabilidade dbname="vl_rentabilidade" )
 retrieve="select 	r.cd_filial,
			f.nm_fantasia, 
			sum(r.qt_venda - qt_devolucao_venda) as qt_venda,
			sum(r.vl_venda) as vl_venda,
			sum(r.vl_cmv) as vl_cmv,
			sum(r.vl_comissao) as vl_comissao,
			sum(r.vl_venda - coalesce(r.vl_cmv_gerencial,0) - coalesce(r.vl_comissao,0)) as vl_rentabilidade
from resumo_produto_filial r
Inner join filial f
	on f.cd_filial = r.cd_filial
where r.dh_resumo between :dh_inicio and :dh_fim
	and r.cd_produto = :produto
	and (r.qt_venda + qt_devolucao_venda) > 0
group by r.cd_filial,
			f.nm_fantasia" arguments=(("dh_inicio", datetime),("dh_fim", datetime),("produto", number))  sort="cd_filial A " )
