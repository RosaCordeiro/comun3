table(column=(type=long updatewhereclause=yes name=cd_tipo_movimento dbname="cd_tipo_movimento" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_movimento dbname="tipo_movimento_estoque.de_tipo_movimento" )
 column=(type=datetime updatewhereclause=yes name=dh_movimento dbname="dh_movimento" )
 column=(type=long updatewhereclause=yes name=qt_movimento dbname="qt_movimento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="vl_custo_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_custo dbname="vl_total_custo" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_venda_unitario dbname="vl_venda_unitario" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_total_venda dbname="vl_total_venda" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="cd_convenio" )
 column=(type=char(60) updatewhereclause=yes name=nm_convenio dbname="nm_convenio" )
 column=(type=char(1) updatewhereclause=yes name=id_pbm dbname="id_pbm" values="	S/	N" )
 retrieve="select 	me.cd_tipo_movimento,
			tm.de_tipo_movimento, 
			me.dh_movimento, 
			case when tm.id_entrada_saida = 'S' then 1 else -1 end * case when tm.id_cancelamento = 'S' then -1 else 1 end * me.qt_movimento as qt_movimento, 
			case when tm.id_entrada_saida = 'S' then 1 else -1 end * case when tm.id_cancelamento = 'S' then -1 else 1 end * me.vl_custo_unitario as vl_custo_unitario, 
			case when tm.id_entrada_saida = 'S' then 1 else -1 end * case when tm.id_cancelamento = 'S' then -1 else 1 end * me.qt_movimento * me.vl_custo_unitario as vl_total_custo, 
			case when tm.id_entrada_saida = 'S' then 1 else -1 end * case when tm.id_cancelamento = 'S' then -1 else 1 end * coalesce(i.vl_preco_praticado,round(id.vl_preco_unitario * (1 - id.pc_desconto / 100),2)) as vl_venda_unitario,
			case when tm.id_entrada_saida = 'S' then 1 else -1 end * case when tm.id_cancelamento = 'S' then -1 else 1 end * me.qt_movimento * coalesce(i.vl_preco_praticado,round(id.vl_preco_unitario * (1 - id.pc_desconto / 100),2)) as vl_total_venda, 
			me.cd_filial_movimento as cd_filial, 	
			me.nr_nf, 
			me.de_especie, 
			me.de_serie,
			me.cd_convenio,
			co.nm_fantasia as nm_convenio,
			vpp.id_pbm
from movimento_estoque me (index pk_movimento_estoque)
inner join tipo_movimento_estoque tm
	on tm.cd_tipo_movimento = me.cd_tipo_movimento
Left outer join convenio co (index pk_convenio)
	on co.cd_convenio = me.cd_convenio
left outer join item_nf_venda i  (index pk_item_nf_venda)
	on i.cd_filial = me.cd_filial_movimento
	and i.nr_nf = me.nr_nf
	and i.de_serie = me.de_serie
	and i.de_especie = me.de_especie
	and i.cd_produto = me.cd_produto
	and i.nr_sequencial = coalesce(me.nr_sequencial,1)
	and me.cd_tipo_movimento in (1,2)
left outer join venda_pbm_produto vpp  (index PK_VENDA_PBM_PRODUTO)
	on vpp.cd_filial = me.cd_filial_movimento
	and vpp.nr_nf = me.nr_nf
	and vpp.de_serie = me.de_serie
	and vpp.de_especie = me.de_especie
	and vpp.cd_produto = me.cd_produto
	and vpp.nr_sequencial = coalesce(me.nr_sequencial,1)
	and me.cd_tipo_movimento in (10,11)
left outer join item_nf_devolucao_venda id  (index pk_item_nf_devolucao_venda)
	on id.cd_filial = me.cd_filial_movimento
	and id.nr_nf = me.nr_nf
	and id.de_serie = me.de_serie
	and id.de_especie = me.de_especie
	and id.cd_produto = me.cd_produto
	and id.nr_sequencial = coalesce(me.nr_sequencial,1)
	and me.cd_tipo_movimento in (10,11)
Where me.dh_movimento between :dh_inicio and :dh_fim
and me.cd_filial_movimento = :filial
and me.cd_produto = :produto
and me.cd_tipo_movimento in (1,2,10,11)" arguments=(("dh_inicio", datetime),("dh_fim", datetime),("produto", number),("filial", number)) )
