table(column=(type=long updatewhereclause=yes name=cd_filial dbname="resumo_produto_filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=qt_venda dbname="qt_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda dbname="resumo_produto_filial.vl_venda" )
 retrieve="select r.cd_filial,
      	f.nm_fantasia,
       	r.qt_venda - r.qt_devolucao_venda as qt_venda,
	 	r.vl_venda
from resumo_produto_filial r
inner join filial f
	on f.cd_filial	= r.cd_filial
where r.cd_produto	= :produto
  and r.dh_resumo		= :data_base
 
" arguments=(("produto", number),("data_base", datetime))  sort="qt_venda D " )
