table(column=(type=char(6) updatewhereclause=yes name=nr_matricula_vendedor dbname="nf_devolucao_venda.nr_matricula_vendedor" dbalias="n.nr_matricula_vendedor" )
 column=(type=decimal(28) updatewhereclause=yes name=vl_devolucao dbname="vl_devolucao" )
 column=(type=decimal(35) updatewhereclause=yes name=vl_comissao dbname="vl_comissao" )
 column=(type=long updatewhereclause=yes name=clientes dbname="clientes" )
 column=(type=decimal(28) updatewhereclause=yes name=vl_devolucao_prestes dbname="vl_devolucao_prestes" )
 column=(type=decimal(23) updatewhereclause=yes name=vl_comissao_prestes dbname="vl_comissao_prestes" )
 retrieve="select n.nr_matricula_vendedor,
		 sum(round(round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2)
			* i.qt_devolvida, 2) * ((100 - n.pc_desconto) / 100), 2)) vl_devolucao,
		 sum(round(round(round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2)
			* i.qt_devolvida, 2) * ((100 - n.pc_desconto) / 100), 2)
         * (i.pc_comissao_extra / 100), 2)) vl_comissao,
		 count(distinct n.nr_nf) clientes,
		 sum(round(round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2)
			* COALESCE (i.qt_comissao_preste, 0), 2) * ((100 - n.pc_desconto) / 100), 2)) vl_devolucao_prestes,
		 sum(round(round(round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2)
			* COALESCE (i.qt_comissao_preste, 0), 2) * ((100 - n.pc_desconto) / 100), 2)
         * (COALESCE (i.pc_comissao_preste, 0) / 100), 2)) vl_comissao_prestes
from nf_devolucao_venda n,
     item_nf_devolucao_venda i
where n.dh_movimentacao_caixa between :dt_inicial and :dt_final
  and n.cd_filial = :filial
  and n.dh_cancelamento is null
  and i.cd_filial  = n.cd_filial
  and i.nr_nf      = n.nr_nf
  and i.de_especie = n.de_especie
  and i.de_serie   = n.de_serie
  and (i.pc_comissao_extra > 0 OR COALESCE (i.pc_comissao_preste, 0) > 0)
group by n.nr_matricula_vendedor" arguments=(("dt_inicial", date),("dt_final", date),("filial", number)) )
