table(column=(type=char(6) updatewhereclause=yes name=nr_matricula_vendedor dbname="nr_matricula_vendedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_venda dbname="vl_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_devolucao dbname="vl_devolucao" )
 column=(type=decimal(28) updatewhereclause=yes name=valor dbname="valor" )
 column=(type=long updatewhereclause=yes name=clientes dbname="clientes" )
 column=(type=long updatewhereclause=yes name=qtde dbname="qtde" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_venda_prestes dbname="vl_venda_prestes" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_devolucao_prestes dbname="vl_devolucao_prestes" )
 column=(type=decimal(28) updatewhereclause=yes name=valor_prestes dbname="valor_prestes" )
 column=(type=long updatewhereclause=yes name=qtde_prestes dbname="qtde_prestes" )
 retrieve="SELECT max(n.nr_matricula_vendedor) nr_matricula_vendedor,
		 u.nm_usuario,
		 sum(round(round(i.vl_preco_praticado * i.qt_vendida, 2)
			 * ((100 - n.pc_desconto) / 100), 2)) vl_venda,
		 CAST(0.00 AS DECIMAL(9,2)) vl_devolucao,
		 sum(round(round(round(i.vl_preco_praticado * i.qt_vendida, 2) * ((100 - n.pc_desconto) / 100), 2)
	       * (i.pc_comissao_extra / 100), 2)) valor,
		 count(DISTINCT n.nr_nf) clientes,
		sum(i.qt_vendida) qtde,
		 sum(round(round(i.vl_preco_praticado * COALESCE (i.qt_comissao_preste, 0), 2)
			 * ((100 - n.pc_desconto) / 100), 2)) vl_venda_prestes,
		 CAST(0.00 AS DECIMAL(9,2)) vl_devolucao_prestes,
		 sum(round(round(round(i.vl_preco_praticado * COALESCE (i.qt_comissao_preste, 0), 2) * ((100 - n.pc_desconto) / 100), 2)
	       * (COALESCE (i.pc_comissao_preste, 0) / 100), 2)) valor_prestes,
		sum(COALESCE (i.qt_comissao_preste, 0)) qtde_prestes
FROM nf_venda n INNER JOIN item_nf_venda i   ON i.cd_filial  		= n.cd_filial
														  AND i.nr_nf      		= n.nr_nf
														  AND i.de_especie 	= n.de_especie
														  AND i.de_serie   		= n.de_serie
					 INNER JOIN usuario u			ON u.nr_matricula = n.nr_matricula_vendedor
					 INNER JOIN vendedor v			ON v.nr_matricula_vendedor = n.nr_matricula_vendedor

WHERE n.dh_movimentacao_caixa BETWEEN :dt_inicial AND :dt_final
  AND n.cd_filial  				= :filial
  AND n.dh_cancelamento 	IS NULL
  AND n.nr_nf_anexa     		IS NULL
  AND (i.pc_comissao_extra 	> 0 OR COALESCE (i.pc_comissao_preste, 0) > 0)
GROUP BY u.nm_usuario" arguments=(("dt_inicial", date),("dt_final", date),("filial", number))  sort="nm_usuario A " )
