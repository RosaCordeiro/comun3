table(column=(type=char(6) updatewhereclause=yes name=nr_matricula_vendedor dbname="nf_venda.nr_matricula_vendedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=long updatewhereclause=yes name=nf_venda_nr_nf dbname="nf_venda.nr_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_venda.dh_movimentacao_caixa" )
 column=(type=char(9) updatewhereclause=yes name=de_tipo_venda dbname="de_tipo_venda" )
 column=(type=long updatewhereclause=yes name=produto_geral_cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(101) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(28) updatewhereclause=yes name=vl_comissionado dbname="vl_comissionado" )
 column=(type=decimal(24) updatewhereclause=yes name=vl_comissao dbname="vl_comissao" )
 column=(type=long updatewhereclause=yes name=item_nf_venda_qt_produtos dbname="item_nf_venda.qt_produtos" )
 column=(type=decimal(24) updatewhereclause=yes name=vl_prestes dbname="vl_prestes" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_comissao_prestes dbname="vl_comissao_prestes" )
 column=(type=long updatewhereclause=yes name=qt_prestes dbname="qt_prestes" )
 retrieve="select n.nr_matricula_vendedor,
	   u.nm_usuario,
	   n.nr_nf,
	   n.dh_movimentacao_caixa, 
	   'VENDA    ' de_tipo_venda,
	   g.cd_produto,
	   g.de_produto + ' ' + g.de_apresentacao_venda de_produto,
	   round(round(i.qt_vendida*i.vl_preco_praticado,2)*((100-n.pc_desconto)/100),2) vl_comissionado,
	   round(round(round(i.vl_preco_praticado * i.qt_vendida, 2) * ((100 - n.pc_desconto) / 100), 2) * (i.pc_comissao_extra / 100), 2) vl_comissao,
		i.qt_vendida qt_produtos,
		ROUND (ROUND (COALESCE (i.qt_comissao_preste, 0) * i.vl_preco_praticado, 2) * ((100 - n.pc_desconto) / 100), 2) vl_prestes,
		ROUND (ROUND (ROUND (COALESCE (i.qt_comissao_preste, 0) * i.vl_preco_praticado, 2) * ((100 - n.pc_desconto) / 100), 2) * (COALESCE (i.pc_comissao_preste, 0) / 100), 2) vl_comissao_prestes,
		COALESCE (i.qt_comissao_preste, 0) AS qt_prestes
  FROM nf_venda n INNER JOIN item_nf_venda i ON i.cd_filial    = n.cd_filial
											AND i.nr_nf        = n.nr_nf
											AND i.de_especie   = n.de_especie
											AND i.de_serie     = n.de_serie
				  INNER JOIN usuario u ON u.nr_matricula 	   = n.nr_matricula_vendedor
				  INNER JOIN vendedor v	ON v.nr_matricula_vendedor = n.nr_matricula_vendedor
				  INNER JOIN produto_geral g ON g.cd_produto = i.cd_produto
where n.dh_movimentacao_caixa between :dt_inicial and :dt_final
and n.cd_filial = :filial
and n.dh_cancelamento is null
and n.nr_nf_anexa is null
and (i.pc_comissao_extra > 0 OR COALESCE (i.pc_comissao_preste, 0) > 0)
union 
select nd.nr_matricula_vendedor,
	   u.nm_usuario,
	   nd.nr_nf,
	   nd.dh_movimentacao_caixa, 
	   'DEVOL.' de_tipo_venda,
	   g.cd_produto,
	   g.de_produto + ' ' + g.de_apresentacao_venda de_produto,
	   round(round(id.qt_devolvida*((id.vl_preco_unitario*(100-id.pc_desconto)/100)),2)*((100-nd.pc_desconto)/100),2)*(-1) vl_comissionado,
	   round(round(round(round(id.vl_preco_unitario * ((100 - id.pc_desconto) / 100), 2)* id.qt_devolvida, 2) * ((100 - nd.pc_desconto) / 100), 2) * (id.pc_comissao_extra / 100), 2)*(-1) vl_comissao,
		id.qt_devolvida qt_produtos,
		ROUND (ROUND (COALESCE (id.qt_comissao_preste, 0) * ((id.vl_preco_unitario * (100 - id.pc_desconto) / 100)), 2) * ((100 - nd.pc_desconto) / 100), 2) * (-1) vl_prestes,
		ROUND (ROUND (ROUND (COALESCE (id.qt_comissao_preste, 0) * id.vl_preco_unitario * ((100 - id.pc_desconto) / 100), 2) * ((100 - nd.pc_desconto) / 100), 2) * (COALESCE (id.pc_comissao_preste, 0) / 100), 2) * (-1) vl_comissao_prestes,
		COALESCE (id.qt_comissao_preste, 0) as qt_prestes
  FROM nf_devolucao_venda nd INNER JOIN item_nf_devolucao_venda id ON id.cd_filial    = nd.cd_filial
											AND id.nr_nf        = nd.nr_nf
											AND id.de_especie   = nd.de_especie
											AND id.de_serie     = nd.de_serie
				  INNER JOIN usuario u ON u.nr_matricula 	   = nd.nr_matricula_vendedor
				  INNER JOIN vendedor v	ON v.nr_matricula_vendedor = nd.nr_matricula_vendedor
				  INNER JOIN produto_geral g ON g.cd_produto = id.cd_produto
where nd.dh_movimentacao_caixa between :dt_inicial and :dt_final
and nd.cd_filial = :filial
and nd.dh_cancelamento is null
and (id.pc_comissao_extra > 0 OR COALESCE (id.pc_comissao_preste, 0) > 0)" arguments=(("dt_inicial", date),("dt_final", date),("filial", number))  sort="nm_usuario A " )
