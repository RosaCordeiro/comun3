table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_compra.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_compra.dh_movimentacao_caixa" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="nf_compra.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=char(53) updatewhereclause=yes name=de_fornecedor dbname="de_fornecedor" )
 column=(type=long updatewhereclause=yes name=nr_nf_compra dbname="nf_compra.nr_nf_compra" )
 column=(type=char(3) updatewhereclause=yes name=de_especie_compra dbname="nf_compra.de_especie_compra" )
 column=(type=char(3) updatewhereclause=yes name=de_serie_compa dbname="nf_compra.de_serie_compa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf_compra dbname="nf_compra.vl_total_nf_compra" )
 column=(type=char(1) updatewhereclause=yes name=id_bonificacao dbname="id_bonificacao" )
 column=(type=long updatewhereclause=yes name=nr_nf_devolucao dbname="nf_devolucao_compra.nr_nf_devolucao" )
 column=(type=char(3) updatewhereclause=yes name=de_especie_devolucao dbname="nf_devolucao_compra.de_especie_devolucao" )
 column=(type=char(3) updatewhereclause=yes name=de_serie_devolucao dbname="nf_devolucao_compra.de_serie_devolucao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf_devolucao dbname="nf_devolucao_compra.vl_total_nf_devolucao" )
 column=(type=datetime updatewhereclause=yes name=dh_movim_caixa_devolucao dbname="nf_devolucao_compra.dh_movim_caixa_devolucao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="nf_devolucao_compra_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_devolvida dbname="nf_devolucao_compra_produto.qt_devolvida" )
 retrieve="select 
		a.cd_filial,
		c.nm_fantasia,
		a.dh_movimentacao_caixa,   
		a.cd_fornecedor,   
		b.nm_razao_social,
		'('+substring(a.cd_fornecedor, 1, 4)+'-'+substring(a.cd_fornecedor, 5, 5)+') '+b.nm_razao_social as de_fornecedor,   
		a.nr_nf as nr_nf_compra,   
		a.de_especie as de_especie_compra,   
		a.de_serie as de_serie_compa,     
		a.vl_total_nf as vl_total_nf_compra,
		isnull(a.id_bonificacao, 'N') id_bonificacao,
		d.nr_nf as nr_nf_devolucao,
		d.de_especie as de_especie_devolucao,
		d.de_serie as de_serie_devolucao,
		d.vl_total_nf as vl_total_nf_devolucao,
		d.dh_movimentacao_caixa as dh_movim_caixa_devolucao,
		e.cd_produto,
		f.de_produto+' : '+f.de_apresentacao_estoque as de_produto,
		e.qt_devolvida
from nf_compra									a   
inner join fornecedor						b on b.cd_fornecedor 		= a.cd_fornecedor
inner join filial 							c on c.cd_filial				= a.cd_filial
inner join nf_devolucao_compra			d on d.cd_filial				= a.cd_filial
											 		 and d.cd_fornecedor			= a.cd_fornecedor
											 		 and d.nr_nf_compra			= a.nr_nf
											 		 and d.de_especie_compra	= a.de_especie
											 		 and d.de_serie_compra		= a.de_serie
inner join nf_devolucao_compra_produto e on e.cd_filial				= d.cd_filial
													 and e.nr_nf					= d.nr_nf
													 and e.de_especie				= d.de_especie
													 and e.de_serie				= d.de_serie
inner join produto_geral 					f on f.cd_produto 			= e.cd_produto 
where a.cd_filial = :cd_filial
and a.dh_movimentacao_caixa between :dh_inicio and :dh_termino
order by a.cd_filial,
			a.cd_fornecedor,
			a.nr_nf,
			a.de_especie,   
			a.de_serie,
			d.cd_filial,
			d.nr_nf,
			d.de_especie,
			d.de_serie,
			f.de_produto,
			f.de_apresentacao_estoque" arguments=(("cd_filial", number),("dh_inicio", date),("dh_termino", date)) )
