table(column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="nf_transferencia.cd_filial_origem" dbalias="n.cd_filial_origem" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="nf_transferencia.cd_filial_destino" dbalias="n.cd_filial_destino" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_transferencia.de_especie" dbalias="n.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_transferencia.de_serie" dbalias="n.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_transferencia.dh_movimentacao_caixa" dbalias="n.dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_transferencia.nr_nf" dbalias="n.nr_nf" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_operador dbname="nf_transferencia.nr_matricula_operador" dbalias="n.nr_matricula_operador" )
 column=(type=char(73) updatewhereclause=yes name=nm_filial_origem dbname="nm_filial_origem" )
 column=(type=char(73) updatewhereclause=yes name=nm_filial_destino dbname="nm_filial_destino" )
 column=(type=char(49) updatewhereclause=yes name=nm_operador dbname="nm_operador" )
 column=(type=char(60) updatewhereclause=yes name=nm_solicitante dbname="nm_solicitante" )
 column=(type=long updatewhereclause=yes name=nr_volume dbname="nr_volume" )
 column=(type=char(108) updatewhereclause=yes name=de_endereco_origem dbname="de_endereco_origem" )
 column=(type=char(108) updatewhereclause=yes name=de_endereco_destino dbname="de_endereco_destino" )
 column=(type=long updatewhereclause=yes name=cd_remanejamento dbname="cd_remanejamento" )
 retrieve="SELECT	DISTINCT
			n.cd_filial_origem,
			n.cd_filial_destino,
			n.de_especie,
			n.de_serie,
			n.dh_movimentacao_caixa,   
			n.nr_nf,
			n.nr_matricula_operador AS nr_matricula_operador,
			CAST(n.cd_filial_origem AS VARCHAR) || ' - ' || filial_a.nm_fantasia nm_filial_origem,   
			CAST(n.cd_filial_destino AS VARCHAR) || ' - ' || filial_b.nm_fantasia nm_filial_destino,   
			u.nm_usuario || ' (' || n.nr_matricula_operador || ')' nm_operador,   
			SPACE( 60 ) as nm_solicitante  ,
			1 nr_volume,
			filial_a.de_endereco || ', ' || filial_a.de_bairro || ' ' || cidade_a.nm_cidade || ' - ' || cidade_a.cd_unidade_federacao de_endereco_origem,
			filial_b.de_endereco || ', ' || filial_b.de_bairro || ' ' || cidade_b.nm_cidade || ' - ' || cidade_b.cd_unidade_federacao de_endereco_destino,
			COALESCE( rr.cd_remanejamento, 0 ) AS cd_remanejamento
	FROM	nf_transferencia AS n
			INNER JOIN	filial AS filial_a
				 ON  filial_a.cd_filial = n.cd_filial_origem 
			INNER JOIN filial AS filial_b
				 ON filial_b.cd_filial = n.cd_filial_destino 
			INNER JOIN cidade AS cidade_a
				 ON filial_a.cd_cidade	= cidade_a.cd_cidade
			INNER JOIN cidade AS cidade_b
				 ON filial_b.cd_cidade = cidade_b.cd_cidade
			INNER JOIN usuario  AS u
				 ON u.nr_matricula = n.nr_matricula_operador
			LEFT OUTER JOIN remanejamento_resultado AS rr
				ON rr.cd_filial_origem	= n.cd_filial_origem
				AND rr.nr_nf			= n.nr_nf
				AND rr.de_especie		= n.de_especie
				AND rr.de_serie		= n.de_serie
WHERE n.cd_filial_origem	= :pl_cd_filial_origem 
	AND n.nr_nf					= :pl_nr_nf 
	AND n.de_especie			= :ps_especie
	AND n.de_serie				= :ps_serie



" arguments=(("pl_cd_filial_origem", number),("pl_nr_nf", number),("ps_especie", string),("ps_serie", string)) )
