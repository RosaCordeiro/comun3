table(column=(type=char(60) updatewhereclause=yes name=de_chave dbname="historico_alteracao_tabela.de_chave" )
 column=(type=char(40) updatewhereclause=yes name=nm_coluna dbname="historico_alteracao_tabela.nm_coluna" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao dbname="historico_alteracao_tabela.dh_alteracao" )
 column=(type=char(32768) updatewhereclause=no name=de_alteracao_de dbname="historico_alteracao_tabela.de_alteracao_de" )
 column=(type=char(32768) updatewhereclause=no name=de_alteracao_para dbname="historico_alteracao_tabela.de_alteracao_para" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_alteracao dbname="historico_alteracao_tabela.nr_matric_alteracao" )
 column=(type=char(1) updatewhereclause=yes name=nm_usuario dbname="nm_usuario" )
 column=(type=char(9) updatewhereclause=yes name=id_alteracao dbname="id_alteracao" )
 column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="cd_promocao_sos" )
 column=(type=char(1) updatewhereclause=yes name=nm_promocao_sos dbname="nm_promocao_sos" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_promocao dbname="id_tipo_promocao" )
 column=(type=char(1) updatewhereclause=yes name=de_tipo_promocao dbname="de_tipo_promocao" )
 retrieve="Select	de_chave,
		nm_coluna,
		dh_alteracao,
		de_alteracao_de,
		de_alteracao_para,
		nr_matric_alteracao,
		'' nm_usuario,
		(Case id_alteracao
			When 'I' Then 'INCLUS$$HEX1$$c300$$ENDHEX$$O'
			When 'A' Then 'ALTERA$$HEX2$$c700c300$$ENDHEX$$O'
			When 'E' Then 'EXCLUS$$HEX1$$c300$$ENDHEX$$O'
		End) As id_alteracao,
		0 cd_promocao_sos,
		'' nm_promocao_sos,
		'' id_tipo_promocao,
		'' de_tipo_promocao
From historico_alteracao_tabela
Where nm_tabela = :tabela
    and nm_coluna = :coluna
	And dh_alteracao >= :dh_inicio
	And dh_alteracao <= :dh_termino
Order By dh_alteracao Desc" arguments=(("tabela", string),("coluna", string),("dh_inicio", datetime),("dh_termino", datetime))  sort="dh_alteracao D " )
