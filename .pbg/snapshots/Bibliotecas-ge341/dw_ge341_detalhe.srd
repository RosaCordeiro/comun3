table(column=(type=long updatewhereclause=yes name=nf_agendamento_ent_pedidocentral dbname="nf_agendamento_ent.PedidoCentral" )
 column=(type=long updatewhereclause=yes name=nf_agendamento_ent_nrnf dbname="nf_agendamento_ent.NrNf" )
 column=(type=char(44) updatewhereclause=yes name=nf_agendamento_ent_chaveacesso dbname="nf_agendamento_ent.ChaveAcesso" )
 column=(type=char(100) updatewhereclause=yes name=nf_agendamento_ent_diverg_hist_de_divergencia dbname="nf_agendamento_ent_diverg_hist.De_Divergencia" )
 retrieve="Select  
        n.nr_pedido_central as PedidoCentral, 
        n.nr_nf As NrNf,        
        n.de_chave_acesso as ChaveAcesso, 
	    h.de_divergencia as De_Divergencia         
From nf_agendamento_ent n
Inner join nf_agendamento_ent_diverg_hist h
On h.de_chave_acesso = n.de_chave_acesso
inner join pedido_central pc
on pc.nr_pedido = n.nr_pedido_central
inner join fornecedor f
on f.cd_fornecedor = pc.cd_fornecedor
inner join tipo_divergencia_ped_central a
on a.cd_tipo_divergencia =  h.cd_tipo_divergencia
where  Cast(dh_registro As Date) >=:dh_inicio
and Cast(dh_registro As Date) <=:dh_termino
and f.cd_fornecedor=:cd_fornecedor 
and h.cd_tipo_divergencia=:cd_tipo_divergencia
and not exists (select * 
		from nfe_destinadas y 
		where y.de_chave_acesso = h.de_chave_acesso 
		and y.id_situacao_nf = '3')

" arguments=(("dh_inicio", datetime),("dh_termino", datetime),("cd_fornecedor", string),("cd_tipo_divergencia", number)) )
