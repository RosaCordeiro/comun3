table(column=(type=char(9) update=yes updatewhereclause=yes name=cd_fornecedor dbname="fornecedor.cd_fornecedor" dbalias="f.cd_fornecedor" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" dbalias="f.nm_razao_social" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="fornecedor.nr_cgc" dbalias="f.nr_cgc" )
 column=(type=long updatewhereclause=yes name=qtd dbname="qtd" )
 retrieve="select    f.cd_fornecedor, 
            f.nm_razao_social, 
            f.nr_cgc,             
            count(*) qtd
from nf_agendamento_ent_diverg_hist h
inner join nf_agendamento_ent n
on n.de_chave_acesso = h.de_chave_acesso
inner join pedido_central pc
on pc.nr_pedido = n.nr_pedido_central
inner join fornecedor f
on f.cd_fornecedor = pc.cd_fornecedor
where Cast(dh_registro As Date) >=:dh_inicio
                and Cast(dh_registro As Date) <= :dh_termino
and not exists (select * 
		from nfe_destinadas y 
		where y.de_chave_acesso = h.de_chave_acesso 
		and y.id_situacao_nf = '3')
           
group by 
        f.cd_fornecedor, f.nm_razao_social , 
        f.nr_cgc" arguments=(("dh_inicio", datetime),("dh_termino", datetime))  sort="qtd D nm_razao_social D " )
