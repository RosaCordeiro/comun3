table(column=(type=char(30) updatewhereclause=yes name=tipo_divergencia_ped_central_de_tipo_divergencia dbname="de_tipo_divergencia" )
 column=(type=long updatewhereclause=yes name=cd_tipo_divergencia dbname="nf_agendamento_ent_diverg_hist.cd_tipo_divergencia" dbalias="h.cd_tipo_divergencia" )
 column=(type=long updatewhereclause=yes name=qtd dbname="qtd" )
 retrieve="Select  upper(a.de_tipo_divergencia) de_tipo_divergencia,
		  h.cd_tipo_divergencia, 
		  count(*) as qtd
From nf_agendamento_ent n
Inner join nf_agendamento_ent_diverg_hist h
On h.de_chave_acesso = n.de_chave_acesso
inner join pedido_central pc
on pc.nr_pedido = n.nr_pedido_central
inner join fornecedor f
on f.cd_fornecedor = pc.cd_fornecedor
inner join tipo_divergencia_ped_central a
on a.cd_tipo_divergencia =  h.cd_tipo_divergencia
where  Cast(dh_registro As Date) >=:dh_inicio
and Cast(dh_registro As Date) <=:dh_termino
and f.cd_fornecedor =:cd_fornecedor
and not exists (select * 
		from nfe_destinadas y 
		where y.de_chave_acesso = h.de_chave_acesso 
		and y.id_situacao_nf = '3')

group by h.cd_tipo_divergencia,
			a.de_tipo_divergencia
			





" arguments=(("dh_inicio", datetime),("dh_termino", datetime),("cd_fornecedor", string))  sort="cd_tipo_divergencia A " )
