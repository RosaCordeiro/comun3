table(column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_almoxarifado_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_almoxarifado_produto.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_atendida dbname="pedido_almoxarifado_produto.qt_atendida" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="pedido_almoxarifado_produto.qt_faturada" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionado dbname="id_selecionado" initial="N" values="	S/	N" )
 retrieve="Select	p.cd_produto,
		g.de_produto || ' : ' || g.de_apresentacao_estoque As de_produto,
		p.qt_pedida,
		p.qt_atendida,
		p.qt_faturada,
		'N' as id_selecionado
From pedido_almoxarifado_produto As p
	Inner Join produto_geral As g
		On g.cd_produto = p.cd_produto
Where p.cd_filial = :filial
	And p.nr_pedido = :pedido" arguments=(("filial", number),("pedido", number))  sort="de_produto A " )
