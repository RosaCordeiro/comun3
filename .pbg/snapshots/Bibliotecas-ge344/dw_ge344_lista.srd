table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_almoxarifado.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_almoxarifado.nr_pedido" )
 column=(type=char(19) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=char(12) updatewhereclause=yes name=id_tipo_pedido dbname="id_tipo_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_almoxarifado.dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="pedido_almoxarifado.dh_inclusao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_cadastramento dbname="pedido_almoxarifado.nr_matricula_cadastramento" )
 column=(type=char(40) updatewhereclause=yes name=nm_resp_cad dbname="usuario.nm_resp_cad" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="pedido_almoxarifado.dh_cancelamento" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_cancelamento dbname="pedido_almoxarifado.nr_matricula_cancelamento" )
 column=(type=char(40) updatewhereclause=yes name=nm_resp_canc dbname="usuario.nm_resp_canc" )
 column=(type=char(200) updatewhereclause=yes name=de_dados_adicionais dbname="pedido_almoxarifado.de_dados_adicionais" )
 column=(type=char(1) updatewhereclause=yes name=id_cancela dbname="id_cancela" values="	S/	N" )
 column=(type=long updatewhereclause=yes name=qt_pedida_total dbname="qt_pedida_total" )
 retrieve="Select	Distinct p.cd_filial,
		f.nm_fantasia,
		p.nr_pedido,
		(CASE p.id_situacao
			WHEN 'F' THEN 'FATURADO'
			WHEN 'N' THEN 'N$$HEX1$$c300$$ENDHEX$$O ATENDIDO'
			WHEN 'C' THEN 'COLOCADO'
			WHEN 'X' THEN 'CANCELADO'
			WHEN 'T' THEN 'SEPARA$$HEX2$$c700c300$$ENDHEX$$O TERMINADA'
			WHEN 'S' THEN 'EM SEPARA$$HEX2$$c700c300$$ENDHEX$$O'
			ELSE p.id_situacao
		END) id_situacao,
		(CASE p.id_tipo_pedido
			WHEN 'E' THEN 'EMPURRADO'
			WHEN 'I' THEN 'INICIAL'
			WHEN 'N' THEN 'NORMAL'
			WHEN 'A' THEN 'ALMOXARIFADO'
			ELSE p.id_tipo_pedido
		END) id_tipo_pedido,
		p.dh_emissao,
		p.dh_inclusao,
		p.nr_matricula_cadastramento,
		i.nm_usuario As nm_resp_cad,
		p.dh_cancelamento,
		p.nr_matricula_cancelamento,
		c.nm_usuario As nm_resp_canc,
		p.de_dados_adicionais,
		'N' As id_cancela,
		sum(pp.qt_pedida) As qt_pedida_total
From pedido_almoxarifado As p
	Inner Join pedido_almoxarifado_produto As pp
		On pp.cd_filial = p.cd_filial
		And pp.nr_pedido = p.nr_pedido
	inner join produto_geral g
		on g.cd_produto = pp.cd_produto
	inner join vw_classificacao_produto v
		on v.cd_subcategoria = g.cd_subcategoria
	Inner Join filial As f
		On f.cd_filial = p.cd_filial
	Left Outer Join usuario As i
		On i.nr_matricula = p.nr_matricula_cadastramento
	Left Outer Join usuario As c
		On c.nr_matricula = p.nr_matricula_cancelamento
Where cast(p.dh_emissao as date) Between :inicio And :termino
Group By	p.cd_filial,
			f.nm_fantasia,
			p.nr_pedido,
			p.id_situacao,
			p.id_tipo_pedido,
			p.dh_emissao,
			p.dh_inclusao,
			p.nr_matricula_cadastramento,
			i.nm_usuario,
			p.dh_cancelamento,
			p.nr_matricula_cancelamento,
			c.nm_usuario,
			p.de_dados_adicionais" arguments=(("inicio", datetime),("termino", datetime))  sort="nm_fantasia A nr_pedido D " )
