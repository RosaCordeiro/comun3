table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_solicitacao.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_pedido dbname="pedido_solicitacao.dh_pedido" )
 column=(type=long updatewhereclause=yes name=nr_solicitacao dbname="pedido_solicitacao.nr_solicitacao" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_pedido dbname="pedido_solicitacao.id_tipo_pedido" values="ALMOXARIFADO	A/EMPURRADO	E/" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="pedido_solicitacao.id_situacao" values="ATIVA	A/COLOCADA	C/CANCELADA	X/" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="pedido_solicitacao.dh_inclusao" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="pedido_solicitacao.dh_cancelamento" )
 column=(type=datetime updatewhereclause=yes name=dh_processamento dbname="pedido_solicitacao.dh_processamento" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_solicitacao.nr_pedido" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_cadastramento dbname="pedido_solicitacao.nr_matricula_cadastramento" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_cadastramento dbname="usuario.nm_usuario_cadastramento" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_cancelamento dbname="pedido_solicitacao.nr_matricula_cancelamento" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_cancelamento dbname="usuario.nm_usuario_cancelamento" )
 column=(type=char(1) updatewhereclause=yes name=id_cancela dbname="id_cancela" values="	S/	N" )
 retrieve="SELECT ps.cd_filial,
		f.nm_fantasia,
		ps.dh_pedido,
		ps.nr_solicitacao,
		ps.id_tipo_pedido,
		ps.id_situacao,
		ps.dh_inclusao,
		ps.dh_cancelamento,
		ps.dh_processamento,
		ps.nr_pedido,
		ps.nr_matricula_cadastramento,
		ui.nm_usuario AS nm_usuario_cadastramento,
		ps.nr_matricula_cancelamento,
		uc.nm_usuario AS nm_usuario_cancelamento,
		'N' AS id_cancela
  FROM
		pedido_solicitacao AS ps
		INNER JOIN filial AS f
				ON f.cd_filial = ps.cd_filial
		INNER JOIN usuario AS ui
				ON ui.nr_matricula = ps.nr_matricula_cadastramento
		LEFT OUTER JOIN usuario AS uc
				ON uc.nr_matricula = ps.nr_matricula_cancelamento
 WHERE ps.dh_pedido BETWEEN :adt_inicio AND :adt_termino" arguments=(("adt_inicio", date),("adt_termino", date))  sort="nm_fantasia A dh_pedido A nr_solicitacao A " )
