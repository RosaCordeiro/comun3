table(column=(type=long updatewhereclause=yes key=yes name=cd_promocao_sos dbname="promocao_sos_produto.cd_promocao_sos" )
 column=(type=char(40) updatewhereclause=yes name=nm_promocao_sos dbname="promocao_sos.nm_promocao_sos" )
 column=(type=long updatewhereclause=yes key=yes name=cd_produto dbname="promocao_sos_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_promocao dbname="promocao_sos.id_tipo_promocao" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="promocao_sos.dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="promocao_sos.dh_termino" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="promocao_sos_produto.pc_desconto" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_retira_venda_calculo_eb dbname="id_retira_venda_calculo_eb" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_vigente dbname="id_vigente" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo_anterior dbname="promocao_sos_produto.qt_estoque_minimo_anterior" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo dbname="promocao_sos_produto.qt_estoque_minimo" )
 retrieve="Select Distinct pp.cd_promocao_sos,
		p.nm_promocao_sos,
		pp.cd_produto,
		g.de_produto + ' : ' + g.de_apresentacao_venda de_produto,
		p.id_tipo_promocao,
		p.dh_inicio,
		p.dh_termino,
		pp.pc_desconto,
		Coalesce(pp.id_retira_venda_calculo_eb, 'N') As id_retira_venda_calculo_eb,
		'S' As id_vigente,
		g.vl_fator_conversao,
		pp.qt_estoque_minimo qt_estoque_minimo_anterior,
		pp.qt_estoque_minimo
From promocao_sos As p
	Inner Join promocao_sos_produto As pp
		On pp.cd_promocao_sos = p.cd_promocao_sos
	Inner Join promocao_sos_filial As f
		On f.cd_promocao_sos = p.cd_promocao_sos
	Inner join produto_geral g
		on g.cd_produto = pp.cd_produto
Where Exists (Select *
					From parametro_loja As x
					Where x.cd_filial = f.cd_filial
						And x.cd_parametro = 'ID_UTILIZA_NOVO_CALCULO_ESTOQUE_BASE'
						And x.vl_parametro = 'S')
	And p.cd_promocao_sos Not In (860, 1415)
	And p.id_tipo_promocao In ('N', 'S', 'V')
	And p.dh_inicio <= (Select dh_movimentacao From parametro Where id_parametro = '1')
	And (p.dh_termino >=  (Select dh_movimentacao From parametro Where id_parametro = '1') or p.dh_termino is null)

union

Select Distinct pp.cd_promocao_sos,
		p.nm_promocao_sos,
		pp.cd_produto,
		g.de_produto + ' : ' + g.de_apresentacao_venda de_produto,
		p.id_tipo_promocao,
		p.dh_inicio,
		p.dh_termino,
		pp.pc_desconto,
		Coalesce(pp.id_retira_venda_calculo_eb, 'N') As id_retira_venda_calculo_eb,
		'N' As id_vigente,
		g.vl_fator_conversao,
		pp.qt_estoque_minimo qt_estoque_minimo_anterior,
		pp.qt_estoque_minimo
From promocao_sos As p
	Inner Join promocao_sos_produto As pp
		On pp.cd_promocao_sos = p.cd_promocao_sos
	Inner Join promocao_sos_filial As f
		On f.cd_promocao_sos = p.cd_promocao_sos
	Inner join produto_geral g
		on g.cd_produto = pp.cd_produto
Where Exists (Select *
					From parametro_loja As x
					Where x.cd_filial = f.cd_filial
						And x.cd_parametro = 'ID_UTILIZA_NOVO_CALCULO_ESTOQUE_BASE'
						And x.vl_parametro = 'S')
	And p.cd_promocao_sos Not In (860, 1415)
	And p.id_tipo_promocao In ('N', 'S', 'V')
    And p.dh_inicio > (Select dh_movimentacao From parametro Where id_parametro = '1')" update="promocao_sos_produto" updatewhere=0 updatekeyinplace=no  sort="de_produto_compute A dh_inicio A nm_promocao_sos A " )
