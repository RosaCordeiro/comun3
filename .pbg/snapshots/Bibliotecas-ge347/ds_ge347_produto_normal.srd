table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_promocao_sos dbname="promocao_sos_produto.cd_promocao_sos" dbalias="p.cd_promocao_sos" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="promocao_sos_produto.cd_produto" dbalias="p.cd_produto" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto dbname="promocao_sos_produto.pc_desconto" dbalias="p.pc_desconto" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_anterior dbname="promocao_sos_produto.pc_desconto_anterior" dbalias="p.pc_desconto_anterior" initial="0" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_alteracao dbname="promocao_sos_produto.dh_alteracao" dbalias="p.dh_alteracao" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_alteracao dbname="promocao_sos_produto.nr_matricula_alteracao" dbalias="p.nr_matricula_alteracao" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_atual dbname="produto_geral.vl_preco_venda_atual" dbalias="g.vl_preco_venda_atual" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_simulado dbname="vl_preco_simulado" initial="0" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto_clube dbname="promocao_sos_produto.pc_desconto_clube" dbalias="p.pc_desconto_clube" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_clube_anterior dbname="promocao_sos_produto.pc_desconto_clube_anterior" dbalias="p.pc_desconto_clube_anterior" )
 column=(type=char(10) updatewhereclause=yes name=cd_promocao_sap dbname="cd_promocao_sap" )
 retrieve="select p.cd_promocao_sos,
       p.cd_produto,   
       p.pc_desconto,
       p.pc_desconto pc_desconto_anterior,
       p.dh_alteracao,
	   p.nr_matricula_alteracao,
       g.de_produto + ' : ' + g.de_apresentacao_venda de_produto,   
       g.vl_preco_venda_atual,
		 0.01 vl_preco_simulado,
		p.pc_desconto_clube,
		p.pc_desconto_clube pc_desconto_clube_anterior,
		coalesce(cd_promocao_sap,'0') as cd_promocao_sap
from promocao_sos_produto p,   
     produto_geral g ,
		promocao_sos c 
where p.cd_promocao_sos = :promocao
  and g.cd_produto = p.cd_produto
 and p.cd_promocao_sos = c.cd_promocao_sos 
" update="promocao_sos_produto" updatewhere=0 updatekeyinplace=no arguments=(("promocao", number))  sort="de_produto A " )
