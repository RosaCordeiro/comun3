		DescPromocao,
		DescClube,
		Nome_Promocao,
		Bloq_Alt_Preco,
		Filial_Alte_Est_Min,
		Tp_Replica,
		dt_ini_venda,
		dt_term_venda,
		dt_ini_em,
		dt_term_em,
		Desc_promocao,
		Rede_Libera,
		Desc_grupo,
		qtd_min,
		uf,
		id_status,
		cd_promocao,
		cd_prom_sos_aux
From promocao_vinculo_base
Where id_status = 'P'"  sort="cd_prom_sos_aux A cd_produto A " )
