table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_promocao_sos dbname="promocao_sos_vinculo.cd_promocao_sos" dbalias="p.cd_promocao_sos" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_vinculo dbname="promocao_sos_vinculo.nr_vinculo" dbalias="p.nr_vinculo" )
 column=(type=char(30) update=yes updatewhereclause=yes name=de_vinculo dbname="promocao_sos_vinculo.de_vinculo" dbalias="p.de_vinculo" )
 column=(type=long update=yes updatewhereclause=yes name=qt_vinculo dbname="promocao_sos_vinculo.qt_vinculo" dbalias="p.qt_vinculo" )
 column=(type=long updatewhereclause=yes name=qt_produtos dbname="qt_produtos" )
 column=(type=char(10) updatewhereclause=yes name=cd_promocao_sap dbname="cd_promocao_sap" )
 retrieve="SELECT	p.cd_promocao_sos,
			p.nr_vinculo,
			p.de_vinculo,
			p.qt_vinculo,
			(Select Count(x.cd_produto)
				From promocao_sos_vinculo_prd x
			 Where x.cd_promocao_sos = p.cd_promocao_sos
				And x.nr_vinculo = p.nr_vinculo) As qt_produtos,
				coalesce(c.cd_promocao_sap,'0')  as cd_promocao_sap
FROM promocao_sos_vinculo As p
inner join promocao_sos c on c.cd_promocao_sos  = p.cd_promocao_sos
Where p.cd_promocao_sos = :promocao" update="promocao_sos_vinculo" updatewhere=0 updatekeyinplace=no arguments=(("promocao", number))  sort="de_vinculo A " )
