table(column=(type=long updatewhereclause=yes name=cd_servico dbname="ocorrencia_servico.cd_servico" )
 column=(type=char(40) updatewhereclause=yes name=nm_servico dbname="servico.nm_servico" )
 column=(type=datetime updatewhereclause=yes name=dh_ocorrencia dbname="ocorrencia_servico.dh_ocorrencia" )
 column=(type=datetime updatewhereclause=yes name=dh_previsao dbname="ocorrencia_servico.dh_previsao" )
 column=(type=char(150) updatewhereclause=yes name=de_observacao dbname="ocorrencia_servico.de_observacao" )
 column=(type=char(1) updatewhereclause=yes name=id_status dbname="ocorrencia_servico.id_status" initial="O" values="OSCILANDO	O/INATIVO	I/ATIVO	A/" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo dbname="id_tipo" initial="S" values="SERVI$$HEX1$$c700$$ENDHEX$$O	S/TIPO SERVI$$HEX1$$c700$$ENDHEX$$O	T/" )
 column=(type=long updatewhereclause=yes name=cd_tipo dbname="tipo_servico.cd_tipo" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo dbname="tipo_servico.de_tipo" )
 retrieve="  SELECT os.cd_servico, s.nm_servico, os.dh_ocorrencia, os.dh_previsao,  os.de_observacao, os.id_status, 'S' as id_tipo, ts.cd_tipo, ts.de_tipo
from ocorrencia_servico os
inner join servico s
	on s.cd_servico = os.cd_servico
inner join tipo_servico ts
	on ts.cd_tipo = s.cd_tipo
" )
