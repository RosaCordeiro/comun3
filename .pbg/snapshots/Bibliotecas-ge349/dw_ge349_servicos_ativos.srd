table(column=(type=char(40) updatewhereclause=yes name=nm_servico dbname="servico.nm_servico" dbalias="s.nm_servico" )
 column=(type=long updatewhereclause=yes name=cd_servico dbname="ocorrencia_servico.cd_servico" dbalias="o.cd_servico" )
 column=(type=datetime updatewhereclause=yes name=dh_ocorrencia dbname="ocorrencia_servico.dh_ocorrencia" dbalias="o.dh_ocorrencia" )
 column=(type=datetime updatewhereclause=yes name=dh_previsao dbname="ocorrencia_servico.dh_previsao" dbalias="o.dh_previsao" )
 column=(type=char(1) updatewhereclause=yes name=id_status dbname="ocorrencia_servico.id_status" dbalias="o.id_status" )
 column=(type=char(150) updatewhereclause=yes name=de_observacao dbname="ocorrencia_servico.de_observacao" dbalias="o.de_observacao" )
 retrieve="  SELECT s.nm_servico,   
         o.cd_servico,   
         o.dh_ocorrencia,   
         o.dh_previsao,   
         o.id_status,   
         o.de_observacao
    FROM ocorrencia_servico o
		inner join servico s
				on s.cd_servico = o.cd_servico
where (dh_previsao >= getdate() or dh_previsao is null)
order by dh_ocorrencia" )
