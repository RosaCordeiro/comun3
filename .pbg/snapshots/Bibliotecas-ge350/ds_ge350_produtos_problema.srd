table(column=(type=long updatewhereclause=yes name=retirada dbname="retirada" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="dh_inclusao" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="DE_PRODUTO" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="de_grupo" )
 column=(type=char(50) updatewhereclause=yes name=de_planograma dbname="de_planograma" )
 column=(type=long updatewhereclause=yes name=eb dbname="EB" )
 column=(type=long updatewhereclause=yes name=minimo dbname="MINIMO" )
 column=(type=long updatewhereclause=yes name=min_plan dbname="MIN_PLAN" )
 column=(type=long updatewhereclause=yes name=eb_utilizado dbname="EB_UTILIZADO" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="qt_saldo_final" )
 column=(type=long updatewhereclause=yes name=qt_solicitada dbname="qt_solicitada" )
 column=(type=char(1) updatewhereclause=yes name=id_planograma dbname="id_planograma" )
 column=(type=decimal(13) updatewhereclause=yes name=qt_media_3_meses dbname="qt_media_3_meses" )
 retrieve="	select * , (	 coalesce((select round(sum((qt_venda - qt_devolucao_venda) ) * 1.00 / 90, 2)
				from resumo_movto_estq_prd
				where dh_resumo >= dateadd(day, -90, cast(getdate() as date))
				 and cd_filial = tudo.cd_filial
				 and cd_produto = tudo.cd_produto
				 and (qt_venda - qt_devolucao_venda) > 0), 0)) qt_media_3_meses  from 
(

select rep.nr_retirada_estoque retirada,
		re.dh_inclusao,
		rep.cd_filial,
		f.nm_fantasia,
		rep.cd_produto, 
		pg.de_produto + ' : ' + pg.de_apresentacao_estoque DE_PRODUTO,
		gru.de_grupo,
		cp.de_planograma,
		s.qt_estoque_base EB,
		coalesce((select vw.qt_estoque_minimo from vw_promocao_estoque_minimo vw
		 where vw.cd_filial = rep.cd_filial
			and vw.cd_produto = rep.cd_produto
			and vw.id_tipo_promocao <> 'P'
			and vw.qt_estoque_minimo > 0), 0) MINIMO,
		coalesce((select vw.qt_estoque_minimo from vw_promocao_estoque_minimo vw
		 where vw.cd_filial = rep.cd_filial
			and vw.cd_produto = rep.cd_produto
			and vw.id_tipo_promocao = 'P'
			and vw.qt_estoque_minimo > 0), 0) MIN_PLAN,
		(CASE  WHEN coalesce(rm.qt_estoque_minimo, 0) > s.qt_estoque_base THEN rm.qt_estoque_minimo ELSE s.qt_estoque_base END) EB_UTILIZADO,
		v.qt_saldo_final,
		rep.qt_solicitada,
			(CASE WHEN (select count(*) 
				  from vw_promocao_estoque_minimo
				  where cd_filial = re.cd_filial
					 and id_tipo_promocao = 'P'
					 and cd_produto = rep.cd_produto) > 0 THEN 'S' ELSE 'N'
			END) as id_planograma
from retirada_estoque re
inner join retirada_estoque_produto rep
      on rep.cd_filial = re.cd_filial
      and rep.nr_retirada_estoque = re.nr_retirada_estoque
inner join resumo_reposicao_estoque s
	on s.cd_filial = re.cd_filial
	and s.cd_produto = rep.cd_produto
inner join vw_saldo_atual_produto v
	on v.cd_filial = re.cd_filial
	and v.cd_produto = rep.cd_produto
inner join filial f
	on f.cd_filial = re.cd_filial
inner join produto_geral pg
	on pg.cd_produto = rep.cd_produto
inner join grupo gru
	on gru.cd_grupo = substring(pg.cd_subcategoria, 1,1) 
left outer join categoria_planograma cp
	on cp.cd_planograma = pg.cd_planograma
left outer join resumo_estoque_minimo_filial rm
	on rm.cd_filial = rep.cd_filial
	and rm.cd_produto = rep.cd_produto
where re.id_situacao = 'S'
  and re.dh_inclusao between :dh_inicio and :dh_termino
  and re.id_tipo_retirada = 'V'
  and (CASE WHEN coalesce(rm.qt_estoque_minimo, 0) > s.qt_estoque_base THEN rm.qt_estoque_minimo ELSE s.qt_estoque_base END) > 0
  and (v.qt_saldo_final - rep.qt_solicitada) < (CASE WHEN coalesce(rm.qt_estoque_minimo, 0) > s.qt_estoque_base THEN rm.qt_estoque_minimo ELSE s.qt_estoque_base END)
) as tudo
" arguments=(("dh_inicio", datetime),("dh_termino", datetime)) )
