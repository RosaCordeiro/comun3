table(column=(type=long updatewhereclause=yes key=yes name=cd_filial dbname="retirada_estoque.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes key=yes name=nr_retirada_estoque dbname="retirada_estoque.nr_retirada_estoque" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_retirada dbname="retirada_estoque.id_tipo_retirada" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="retirada_estoque.dh_inclusao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inicio dbname="retirada_estoque.dh_inicio" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_termino dbname="retirada_estoque.dh_termino" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio_old dbname="retirada_estoque.dh_inicio_old" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_old dbname="retirada_estoque.dh_termino_old" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_aprovacao dbname="retirada_estoque.dh_aprovacao" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_aprovacao dbname="retirada_estoque.nr_matricula_aprovacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_aprovacao dbname="usuario.nm_usuario_aprovacao" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="retirada_estoque.id_situacao" )
 column=(type=char(100) updatewhereclause=yes name=de_observacao dbname="retirada_estoque.de_observacao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_vencimento_minimo dbname="retirada_estoque.dh_vencimento_minimo" )
 column=(type=char(100) updatewhereclause=yes name=de_mensagem_logistica dbname="retirada_estoque.de_mensagem_logistica" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionado dbname="id_selecionado" initial="N" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_old dbname="retirada_estoque.id_situacao_old" )
 column=(type=char(64) updatewhereclause=yes name=rota_entrega dbname="rota_entrega" )
 retrieve="select	distinct a.cd_filial,
			b.nm_fantasia,
			a.nr_retirada_estoque,
			a.id_tipo_retirada,
			a.dh_inclusao,
			a.dh_inicio,
			a.dh_termino,
			a.dh_inicio as dh_inicio_old,
			a.dh_termino as dh_termino_old,
			a.dh_aprovacao,
			a.nr_matricula_aprovacao,
			c.nm_usuario as nm_usuario_aprovacao,
			a.id_situacao,
			a.de_observacao,
			a.dh_vencimento_minimo,
			a.de_mensagem_logistica,
			'' as id_selecionado,
			a.id_situacao as id_situacao_old,
			cast( re.nr_rota as char(3)) + '-' + re.de_rota as rota_entrega
from retirada_estoque a
	inner join retirada_estoque_produto p
		on p.cd_filial = a.cd_filial
	  and p.nr_retirada_estoque = a.nr_retirada_estoque
	inner join filial b
		on b.cd_filial = a.cd_filial
	inner join rota_entrega re
			on re.nr_rota = b.nr_rota_entrega
	left join usuario c
		on c.nr_matricula = a.nr_matricula_aprovacao
where a.dh_inclusao between :dh_inicio and :dh_fim" update="retirada_estoque" updatewhere=0 updatekeyinplace=yes arguments=(("dh_inicio", datetime),("dh_fim", datetime))  sort="nm_fantasia A dh_inclusao A " )
