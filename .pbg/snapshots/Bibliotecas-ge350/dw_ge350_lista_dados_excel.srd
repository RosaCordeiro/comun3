table(column=(type=char(18) updatewhereclause=yes name=tipo_retirada dbname="Tipo_Retirada" )
 column=(type=char(16) updatewhereclause=yes name=tipo_situacao dbname="Tipo_Situacao" )
 column=(type=char(100) updatewhereclause=yes name=de_observacao dbname="retirada_estoque.de_observacao" dbalias="f.de_observacao" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="retirada_estoque_produto.cd_filial" dbalias="a.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="g.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_retirada_estoque dbname="retirada_estoque_produto.nr_retirada_estoque" dbalias="a.nr_retirada_estoque" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="retirada_estoque.dh_inclusao" dbalias="f.dh_inclusao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="retirada_estoque_produto.cd_produto" dbalias="a.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="b.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" dbalias="b.de_apresentacao_estoque" )
 column=(type=long updatewhereclause=yes name=qt_aprovada dbname="qt_aprovada" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_aprovacao dbname="usuario.nm_usuario_aprovacao" dbalias="u.nm_usuario_aprovacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_medio dbname="saldo_produto.vl_custo_medio" dbalias="c.vl_custo_medio" )
 column=(type=char(100) updatewhereclause=yes name=de_observacao_produto dbname="retirada_estoque_produto.de_observacao_produto" dbalias="a.de_observacao_produto" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 column=(type=char(64) updatewhereclause=yes name=rota_entrega dbname="rota_entrega" )
 column=(type=long updatewhereclause=yes name=qt_solicitada dbname="retirada_estoque_produto.qt_solicitada" dbalias="a.qt_solicitada" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="retirada_estoque_produto_lote.nr_lote" dbalias="e.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="produto_lote.dh_validade" dbalias="pl.dh_validade" )
 column=(type=char(50) updatewhereclause=yes name=nr_protocolo dbname="retirada_estoque_produto.nr_protocolo" dbalias="a.nr_protocolo" )
 retrieve="select		case f.id_tipo_retirada  
                when 'A' then 'AVARIA'
                when 'E' then 'EXCESSO'
                when 'R' then 'RECALL'
                when 'V' then 'VENCIDO'
                when 'P' then 'PRODUTOS ESPECIAIS'
                when 'D' then 'DEFEITO FABRICA$$HEX2$$c700c300$$ENDHEX$$O'
                when 'F' then 'TRANSFER$$HEX1$$ca00$$ENDHEX$$NCIA SAF'
                when 'S' then 'AUTORIZADO SAF'
			  end as Tipo_Retirada,

              case f.id_situacao  
                when 'S' then 'SOLICITADO'			  
                when 'A' then 'AUTORIZADO'			  
                when 'X' then 'CANCELADO'			  
                when 'F' then 'FATURADO'			  
			   when 'Z' then 'FATURADO PARCIAL'			  
                end as Tipo_Situacao,
				f.de_observacao,
                a.cd_filial,
                g.nm_fantasia,
			   a.nr_retirada_estoque,	
				f.dh_inclusao,
			   a.cd_produto,
			   b.de_produto ,
                 b.de_apresentacao_estoque,			    
			    case when e.cd_produto is null then
				          a.qt_aprovada
				else 	  e.qt_aprovada
			    end as qt_aprovada,
				u.nm_usuario as nm_usuario_aprovacao,
				c.vl_custo_medio,
				a.de_observacao as de_observacao_produto,
	
				(select coalesce(sum(y.qt_transferida), 0)
                    from nf_transferencia x
                        inner join item_nf_transferencia y
                            on y.cd_filial_origem = x.cd_filial_origem
                            and y.nr_nf = x.nr_nf
                            and y.de_especie = x.de_especie
                            and y.de_serie = x.de_serie
					 where x.cd_filial_origem = f.cd_filial
					 and x.nr_retirada_estoque = f.nr_retirada_estoque
					 and x.dh_cancelamento is null
					 and y.cd_produto = a.cd_produto) as qt_faturada,
				cast( re.nr_rota as char(3)) + '-' + re.de_rota as rota_entrega,
				a.qt_solicitada,
				e.nr_lote,
				pl.dh_validade, 
                  a.nr_protocolo
from retirada_estoque_produto a
inner join produto_geral b on b.cd_produto = a.cd_produto
left join saldo_produto c on c.cd_filial = a.cd_filial and c.cd_produto = a.cd_produto and dh_saldo = :dh_saldo
left join resumo_reposicao_estoque	d on d.cd_filial = a.cd_filial and d.cd_produto = a.cd_produto
left join retirada_estoque_produto_lote	e on e.cd_filial = a.cd_filial and e.nr_retirada_estoque = a.nr_retirada_estoque and e.cd_produto = a.cd_produto
inner join retirada_estoque f on f.cd_filial = a.cd_filial and f.nr_retirada_estoque = a.nr_retirada_estoque
inner join filial g on g.cd_filial = a.cd_filial
inner join rota_entrega re on re.nr_rota = g.nr_rota_entrega
left join usuario u on u.nr_matricula = f.nr_matricula_aprovacao
left join produto_lote pl on pl.cd_produto = e.cd_produto and pl.nr_lote = e.nr_lote
where f.dh_inclusao between :dh_inicio and :dh_fim" arguments=(("dh_inicio", datetime),("dh_fim", datetime),("dh_saldo", date))  sort="nm_fantasia A nr_retirada_estoque A " )
