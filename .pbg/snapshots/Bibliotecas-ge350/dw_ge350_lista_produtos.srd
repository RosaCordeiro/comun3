table(column=(type=long updatewhereclause=yes key=yes name=cd_filial dbname="retirada_estoque_produto.cd_filial" dbalias="a.cd_filial" )
 column=(type=long updatewhereclause=yes key=yes name=nr_retirada_estoque dbname="retirada_estoque_produto.nr_retirada_estoque" dbalias="a.nr_retirada_estoque" )
 column=(type=long updatewhereclause=yes key=yes name=cd_produto dbname="retirada_estoque_produto.cd_produto" dbalias="a.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_solicitada dbname="retirada_estoque_produto.qt_solicitada" dbalias="a.qt_solicitada" )
 column=(type=long update=yes updatewhereclause=yes name=qt_aprovada dbname="retirada_estoque_produto.qt_aprovada" dbalias="a.qt_aprovada" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_medio dbname="retirada_estoque_produto.vl_custo_medio" dbalias="a.vl_custo_medio" )
 column=(type=long updatewhereclause=yes name=saldo_filial dbname="saldo_produto.saldo_filial" dbalias="c.saldo_filial" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="b.vl_fator_conversao" )
 column=(type=long updatewhereclause=yes name=qt_saldo_promocao dbname="qt_saldo_promocao" )
 column=(type=long updatewhereclause=yes name=qt_saldo_promocao_planograma dbname="qt_saldo_promocao_planograma" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="qt_estoque_base" )
 column=(type=char(1) updatewhereclause=yes name=id_aprovar dbname="id_aprovar" values="	S/	N" )
 column=(type=char(100) updatewhereclause=yes name=de_observacao dbname="retirada_estoque_produto.de_observacao" dbalias="a.de_observacao" )
 column=(type=char(3) updatewhereclause=yes name=controlado dbname="Controlado" )
 column=(type=char(50) updatewhereclause=yes name=nr_protocolo dbname="retirada_estoque_produto.nr_protocolo" dbalias="a.nr_protocolo" )
 retrieve="select		a.cd_filial,
			a.nr_retirada_estoque,	
			a.cd_produto,
			b.de_produto+' : '+b.de_apresentacao_estoque as de_produto,
			a.qt_solicitada,
			a.qt_aprovada,
			a.vl_custo_medio,
			c.qt_saldo_final as saldo_filial,
			b.vl_fator_conversao,

			coalesce((	select max(c1.qt_estoque_minimo)
							from promocao_sos a1
							inner join promocao_sos_filial b1 on b1.cd_promocao_sos = a1.cd_promocao_sos
							inner join promocao_sos_estoque_minimo c1 on c1.cd_promocao_sos = a1.cd_promocao_sos
							where a1.id_tipo_promocao <> 'P'
							and a1.id_situacao = 'L'
							and cast(a1.dh_termino as date)>= cast(getdate() as date) 
							and cast(a1.dh_inicio as date)<= cast(getdate() as date)
							and c1.cd_filial = a.cd_filial
							and c1.cd_produto = a.cd_produto), 0) as qt_saldo_promocao,

			coalesce((	select max(c1.qt_estoque_minimo)
							from promocao_sos a1
							inner join promocao_sos_filial b1 on b1.cd_promocao_sos = a1.cd_promocao_sos
							inner join promocao_sos_estoque_minimo c1 on c1.cd_promocao_sos = a1.cd_promocao_sos
							where a1.id_tipo_promocao = 'P'
							and a1.id_situacao = 'L'
							and cast(a1.dh_termino as date)>= cast(getdate() as date) 
							and cast(a1.dh_inicio as date)<= cast(getdate() as date)
							and c1.cd_filial = a.cd_filial
							and c1.cd_produto = a.cd_produto), 0) as qt_saldo_promocao_planograma,

			coalesce(qt_estoque_base, 0) as qt_estoque_base,

			'N' id_aprovar,
			a.de_observacao,
			case b.cd_grupo_psico 
         	      when null then 'NAO' 
            	else 'SIM' end as Controlado,
			a.nr_protocolo
from retirada_estoque_produto a
inner join produto_geral b on b.cd_produto = a.cd_produto
left join saldo_produto c on c.cd_filial = a.cd_filial and c.cd_produto = a.cd_produto and dh_saldo = :dh_saldo
left join resumo_reposicao_estoque	d on d.cd_filial = a.cd_filial and d.cd_produto = a.cd_produto
left outer join resumo_estoque_minimo_filial m 
	on m.cd_filial = d.cd_filial
	and m.cd_produto = d.cd_produto
where a.cd_filial = :cd_filial
	and a.nr_retirada_estoque = :nr_retirada
order by de_produto, a.cd_produto" update="retirada_estoque_produto" updatewhere=0 updatekeyinplace=yes arguments=(("cd_filial", number),("nr_retirada", number),("dh_saldo", date)) )
