table(column=(type=char(51) updatewhereclause=yes name=de_distribuidora dbname="de_distribuidora" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf dbname="controle_arquivo_preco_distrib.cd_uf" )
 column=(type=datetime updatewhereclause=yes name=dh_arquivo dbname="controle_arquivo_preco_distrib.dh_arquivo" )
 column=(type=datetime updatewhereclause=yes name=dh_importacao dbname="controle_arquivo_preco_distrib.dh_importacao" )
 column=(type=long updatewhereclause=yes name=qt_atualizados dbname="controle_arquivo_preco_distrib.qt_atualizados" )
 column=(type=long updatewhereclause=yes name=qt_inexistentes dbname="controle_arquivo_preco_distrib.qt_inexistentes" )
 column=(type=long updatewhereclause=yes name=qt_inalterados dbname="controle_arquivo_preco_distrib.qt_inalterados" )
 retrieve="  SELECT f.nm_fantasia + ' - [' + substring(f.cd_fornecedor, 5, 6) + ']' de_distribuidora,
         c.cd_uf,   
         c.dh_arquivo,   
         c.dh_importacao,   
         c.qt_atualizados,   
         c.qt_inexistentes,   
         c.qt_inalterados  
    FROM controle_arquivo_preco_distrib   c
inner join fornecedor f on f.cd_fornecedor = c.cd_distribuidora
Where c.dh_arquivo  between :inicio and :termino
" arguments=(("inicio", date),("termino", date))  sort="de_distribuidora A cd_uf A dh_arquivo D " )
