table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cd_unidade_federacao" )
 column=(type=char(16) updatewhereclause=yes name=de_arquivo dbname="de_arquivo" )
 retrieve="Select	f.cd_fornecedor,
		f.nm_fantasia,
		d.cd_unidade_federacao,
		'ARQUIVO DE PRE$$HEX1$$c700$$ENDHEX$$O' As de_arquivo
From fornecedor As f
	Inner Join distribuidora_uf As d
		On d.cd_distribuidora = f.cd_fornecedor
Where f.id_distribuidora = 'S'
	And f.cd_fornecedor <> '053404705'
	And  coalesce(f.id_arquivo_preco_diario, 'S') = 'S'
	And Not Exists ( Select *
						 From controle_arquivo_preco_distrib As c
						 Where c.cd_distribuidora = d.cd_distribuidora
							And c.cd_uf = d.cd_unidade_federacao
							And cast(c.dh_arquivo  as date) = (Select dh_movimentacao From parametro Where id_parametro = '1'))
	And Exists (Select *
					From filial_distribuidora x
						Inner Join vw_filial y
							On y.cd_filial = x.cd_filial
					Where x.cd_distribuidora = f.cd_fornecedor
						And y.cd_uf = d.cd_unidade_federacao
						And x.id_situacao = 'A')

/*Union

Select	d.cd_distribuidora,
		f.nm_fantasia,
		d.cd_unidade_federacao,
		'ARQUIVO DE ESTOQUE' As de_arquivo
From fornecedor As f
	Inner Join distribuidora_produto As d
		On d.cd_distribuidora = f.cd_fornecedor
	   And d.cd_unidade_federacao = 'SP'
Where f.id_atende_pedido_ecommerce = 'S'
	And f.id_distribuidora = 'S'
	And f.cd_fornecedor <> '053404705'
Group By d.cd_distribuidora, f.nm_fantasia, d.cd_unidade_federacao
Having Cast(coalesce(max(d.dh_arquivo_estoque), '19000101') As Date) < Cast(getdate() As Date)*/
"  sort="de_arquivo D nm_fantasia A cd_unidade_federacao A " )
