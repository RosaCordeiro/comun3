table(column=(type=char(2) update=yes updatewhereclause=yes key=yes name=nr_ddd dbname="telefone_drogaria.nr_ddd" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=nr_telefone dbname="telefone_drogaria.nr_telefone" )
 column=(type=char(100) update=yes updatewhereclause=yes name=de_telefone dbname="telefone_drogaria.de_telefone" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_tipo dbname="telefone_drogaria.id_tipo" initial="N" values="ADSL	A/CELULAR	C/FAX	F/NORMAL	N/VOIP	V/VETOR	T/EQUIP.	E/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="telefone_drogaria.id_situacao" values="ATIVO - MOSTRA NA LISTA	1/ATIVO - N$$HEX1$$c300$$ENDHEX$$O MOSTRA NA LISTA	2/INATIVO	3/PRINCIPAL - MOSTRA NA LISTA	4/" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_ramal dbname="telefone_drogaria.nr_ramal" )
 column=(type=long update=yes updatewhereclause=yes name=cd_centro_custo dbname="telefone_drogaria.cd_centro_custo" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="centro_custo.nm_fantasia" )
 column=(type=long update=yes updatewhereclause=yes name=cd_operadora dbname="telefone_drogaria.cd_operadora" )
 column=(type=char(100) update=yes updatewhereclause=yes name=de_email dbname="telefone_drogaria.de_email" )
 retrieve="  SELECT t.nr_ddd,   
         t.nr_telefone,   
         t.de_telefone,   
         t.id_tipo,   
         t.id_situacao,   
         t.nr_ramal,   
         t.cd_centro_custo ,
		c.de_centro_custo nm_fantasia,
         t.cd_operadora,
		t.de_email
    FROM telefone_drogaria t,
			centro_custo c
   WHERE c.cd_centro_custo = t.cd_centro_custo" update="telefone_drogaria" updatewhere=1 updatekeyinplace=no )
