table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(102) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="vw_classificacao_produto.de_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo dbname="vw_classificacao_produto.de_subgrupo" )
 column=(type=char(40) updatewhereclause=yes name=de_categoria dbname="vw_classificacao_produto.de_categoria" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="vw_classificacao_produto.de_subcategoria" )
 column=(type=long updatewhereclause=yes name=nr_classificacao_fiscal dbname="produto_geral.nr_classificacao_fiscal" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_pis_cofins dbname="produto_geral.id_situacao_pis_cofins" values="TRIBUTADO	T/NEGATIVO	N/POSITIVO	P/" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="produto_geral.id_lei_generico" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="produto_uf.cd_unidade_federacao" )
 column=(type=char(1) updatewhereclause=yes name=cd_tributacao_icms dbname="produto_uf.cd_tributacao_icms" )
 column=(type=char(40) updatewhereclause=yes name=de_tributacao_icms dbname="tributacao_icms.de_tributacao_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="tipo_icms.pc_icms" )
 column=(type=long updatewhereclause=yes name=cd_tributacao_produto dbname="tributa_produtos_farmaceuticos.cd_tributacao_produto" )
 column=(type=char(50) updatewhereclause=yes name=de_tributacao_produto dbname="tributa_produtos_farmaceuticos.de_tributacao_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_st_estadual dbname="tributa_produtos_farmaceuticos.pc_st_estadual" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_reducao_base_st dbname="produto_uf.pc_reducao_base_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_maximo dbname="produto_uf.vl_preco_venda_maximo" )
 column=(type=long updatewhereclause=yes name=nr_ncm_situacao dbname="produto_uf.nr_ncm_situacao" )
 column=(type=char(100) updatewhereclause=yes name=de_situacao_especial dbname="de_situacao_especial" )
 column=(type=char(55) updatewhereclause=yes name=de_divergencia dbname="de_divergencia" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_reposicao dbname="produto_uf.vl_preco_reposicao" )
 column=(type=decimal(2) updatewhereclause=yes name=desconto_forn dbname="produto_central.pc_desconto_fornecedor" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_custo_medio dbname="vl_custo_medio" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_custo_gerencial dbname="vl_custo_gerencial" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=char(3) updatewhereclause=yes name=id_superfluo dbname="id_superfluo" )
 column=(type=long updatewhereclause=yes name=caixa_embarque dbname="produto_geral.caixa_embarque" )
 column=(type=char(7) updatewhereclause=yes name=demanda dbname="demanda" )
 column=(type=char(40) updatewhereclause=yes name=unidade_venda dbname="unidade_medida.Unidade_Venda" )
 column=(type=char(40) updatewhereclause=yes name=unidade_compra dbname="unidade_medida.Unidade_Compra" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_atual dbname="produto_uf.vl_preco_venda_atual" )
 column=(type=date updatewhereclause=yes name=dh_preco_venda_atual dbname="dh_preco_venda_atual" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="de_codigo_barras" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras_abcfarma dbname="de_codigo_barras_abcfarma" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=char(40) updatewhereclause=yes name=nm_fornecedor dbname="fornecedor.nm_fornecedor" )
 column=(type=char(3) updatewhereclause=yes name=controlado dbname="Controlado" )
 column=(type=char(19) updatewhereclause=yes name=liberado dbname="Liberado" )
 column=(type=char(8) updatewhereclause=yes name=situacao dbname="SITUACAO" )
 column=(type=long updatewhereclause=yes name=produto_abcfarma dbname="ID_PRODUTO_ABCFARMA" )
 column=(type=char(30) updatewhereclause=yes name=fab_abc_farma dbname="FAB_ABC_FARMA" )
 retrieve="select g.cd_produto,
		 g.de_produto||': '||g.de_apresentacao_venda as de_produto,
		 v.de_grupo,	
		 v.de_subgrupo,
		 v.de_categoria,
		 v.de_subcategoria,
		 g.nr_classificacao_fiscal,

		 g.id_situacao_pis_cofins,
		 g.id_lei_generico,
		 u.cd_unidade_federacao,
		 u.cd_tributacao_icms,
		 tbi.de_tributacao_icms,
		 ti.pc_icms,
		 tp.cd_tributacao_produto,
		 tp.de_tributacao_produto,
		 tp.pc_st_estadual,
		 u.pc_reducao_base_st,
		 u.vl_preco_venda_maximo,
		 u.nr_ncm_situacao,
		case when u.nr_ncm_situacao is null then null else nse.de_situacao_especial end as de_situacao_especial,




		Case when (u.cd_tipo_icms<>nse.cd_tipo_icms)or(u.cd_tributacao_icms<>nse.cd_tributacao_icms)or(u.cd_tributacao_produto<>nse.cd_tributacao_produto)or(coalesce(u.cd_mensagem_fiscal,0)<>coalesce(nse.cd_mensagem_fiscal,0)) THEN
			'DIVERG. '||		
			rtrim(		Case when (coalesce(u.cd_mensagem_fiscal,0)<>coalesce(nse.cd_mensagem_fiscal,0)) then 'MSG. FISCAL, ' ELSE '' END||
						Case when (u.cd_tipo_icms<>nse.cd_tipo_icms) then 'TIPO ICMS, ' ELSE '' END||
						Case when (u.cd_tributacao_icms<>nse.cd_tributacao_icms) then 'TRIB. ICMS, ' ELSE '' END||
						Case when (u.cd_tributacao_produto<>nse.cd_tributacao_produto) then 'TRIB. PROD.' ELSE '' END
				   ) 
		else 'NENHUMA' end as de_divergencia,

	     u.vl_preco_reposicao,
		pc.pc_desconto_fornecedor,
		round(pc.vl_custo_gerencial * g.vl_fator_conversao, 2) as vl_custo_medio,   
         round(pc.vl_custo_gerencial_geral * g.vl_fator_conversao, 2)  as vl_custo_gerencial,   
		g.vl_fator_conversao,
         case when g.id_superfluo =  'N' then 'N$$HEX1$$c300$$ENDHEX$$O' else 'SIM' end id_superfluo,
         g.nr_embalagem_padrao caixa_embarque,

		Case pc.id_tipo_reposicao_estoque
              when 'S' then 'SAZONAL'
              when 'E' then 'ESTAVEL'
            End as demanda,

	   unVenda.de_unidade_medida as Unidade_Venda,
        unCompra.de_unidade_medida as Unidade_Compra,
	   u.vl_preco_venda_atual,   
	    cast(u.dh_preco_venda_atual as date) dh_preco_venda_atual,
	   isnull (cb.de_codigo_barras,'SEM INFORMA$$HEX2$$c700c300$$ENDHEX$$O') as de_codigo_barras,
	   j.de_codigo_barras as de_codigo_barras_abcfarma,
       g.de_apresentacao_estoque,   
       g.de_apresentacao_venda,
	   f.nm_fantasia as nm_fornecedor,   

	   case g.cd_grupo_psico 
                when null then 'NAO' 
            else 'SIM' end as Controlado, 
      
	   case j.id_controle_preco	 
            when 'M' then 'MONITORADO'
            when 'X' then 'LIBER. PR$$HEX1$$c700$$ENDHEX$$O F$$HEX1$$c100$$ENDHEX$$BRICA'
            when 'L' then 'LIBERADO'
            when 'H' then 'HOSPITALAR' else 'Sem Informa$$HEX2$$e700e300$$ENDHEX$$o' end as Liberado,

	 case g.id_situacao
              when 'A' then 'ATIVO'
              when 'P' then 'PENDENTE' 
              when 'I' then 'INATIVO' end as SITUACAO ,

	 ISNULL (j.cd_produto_abcfarma,0)  AS ID_PRODUTO_ABCFARMA,
      ISNULL (j.nm_fabricante,'SEM INFORMA$$HEX2$$c700c300$$ENDHEX$$O')  as FAB_ABC_FARMA

from produto_geral g
Inner Join produto_uf u
	on	u.cd_produto 				= g.cd_produto and 
		u.cd_unidade_federacao	= :p_estado
Inner Join produto_central As pc
     on pc.cd_produto = g.cd_produto
Left Join unidade_medida as unVenda
        On unVenda.cd_unidade_medida = g.cd_unidade_medida_venda 
Left Join unidade_medida as unCompra
        On unCompra.cd_unidade_medida = g.cd_unidade_medida_compra 
Inner Join tipo_icms ti
	on ti.cd_tipo_icms				= u.cd_tipo_icms
Inner Join tributa_produtos_farmaceuticos tp
	on tp.cd_tributacao_produto	= u.cd_tributacao_produto
Inner Join vw_classificacao_produto v
	on v.cd_subcategoria 			= g.cd_subcategoria
Left outer join tributacao_icms tbi	
	on tbi.cd_tributacao_icms = u.cd_tributacao_icms
Left outer Join ncm_uf nu
	on nu.nr_ncm = g.nr_classificacao_fiscal
	and nu.cd_uf = u.cd_unidade_federacao
Left outer Join ncm_situacao_especial nse
	on nse.nr_ncm = g.nr_classificacao_fiscal
	and nse.cd_uf = u.cd_unidade_federacao
	and ((nse.nr_sequencial = u.nr_ncm_situacao) or (u.nr_ncm_situacao is null and nse.id_padrao = 'S'))
left join ( select a.cd_produto, b.de_codigo_barras, 
                        case pab.id_controle_preco  
                                when 'M' then 'MONITORADO'
                                when 'X' then 'LIBER. PR$$HEX1$$c700$$ENDHEX$$O F$$HEX1$$c100$$ENDHEX$$BRICA'
                                when 'L' then 'LIBERADO'
                                when 'H' then 'HOSPITALAR' else pab.id_controle_preco end as Liberado, pab.nm_fabricante, pab.cd_produto_abcfarma, pab.id_controle_preco
                  from produto_geral a
                  inner   join codigo_barras_produto b on a.cd_produto   = b.cd_produto 
                  inner   join produto_abcfarma pab  on pab.de_codigo_barras = b.de_codigo_barras ) 
        j  on g.cd_produto = j.cd_produto

left join codigo_barras_produto cb on cb.cd_produto = g.cd_produto and cb.id_principal = 'S'
left outer join fornecedor f
	on f.cd_fornecedor = g.cd_fornecedor_usual" arguments=(("p_estado", string))  sort="de_produto A " )
