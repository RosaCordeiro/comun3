table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" )
 column=(type=datetime updatewhereclause=yes name=venc_alvara dbname="venc_alvara" )
 column=(type=char(1) updatewhereclause=yes name=protocolo dbname="protocolo" )
 column=(type=char(1) updatewhereclause=yes name=liberado_psico dbname="liberado_psico" )
 column=(type=long updatewhereclause=yes name=nr_pedido_filial dbname="pedido_filial.nr_pedido_filial" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_filial.dh_emissao" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_filial_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="vw_classificacao_produto.de_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo dbname="vw_classificacao_produto.de_subgrupo" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="vw_classificacao_produto.de_subcategoria" )
 column=(type=char(2) updatewhereclause=yes name=psico dbname="produto_geral.PSICO" )
 column=(type=char(40) updatewhereclause=yes name=comprador dbname="comprador" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_gerencial dbname="produto_central.vl_custo_gerencial" )
 column=(type=char(1) updatewhereclause=yes name=classe_repos_empresa dbname="produto_central.classe_repos_empresa" )
 column=(type=char(1) updatewhereclause=yes name=classe_repos_filial dbname="resumo_reposicao_estoque.classe_repos_filial" )
 column=(type=long updatewhereclause=yes name=rodada dbname="rodada" )
 column=(type=char(3) updatewhereclause=yes name=relacionado dbname="relacionado" )
 column=(type=char(10) updatewhereclause=yes name=id_projeto_conexao dbname="id_projeto_conexao" values="PHARMALINK	1/ENTIRE	2/FIDELIZE	4/" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_filial_produto.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_falta dbname="qt_falta" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_falta dbname="vl_falta" )
 retrieve="select	p.cd_filial, 
		f.nm_fantasia,
		ci.cd_unidade_federacao,
		(select a.dh_vencimento from documento_regulatorio_filial a where a.cd_filial = p.cd_filial and a.cd_tipo_documento = 1) venc_alvara,
		coalesce((select a.id_protocolo from documento_regulatorio_filial a where a.cd_filial = f.cd_filial	and a.cd_tipo_documento = 1), 'N') as protocolo,
		coalesce((select a.id_psico from documento_regulatorio_filial a where a.cd_filial = f.cd_filial and a.cd_tipo_documento = 1), 'N') as liberado_psico,
		p.nr_pedido_filial,
		p.dh_emissao,
		g.id_situacao,
		pp.cd_produto,
		g.de_produto + ' : ' + g.de_apresentacao_estoque as de_produto,
		g.vl_fator_conversao,
		vp.de_grupo,
		vp.de_subgrupo, 
		vp.de_subcategoria,
		g.cd_grupo_psico PSICO,
		coalesce(v.nm_comprador, u.nm_usuario) comprador, 
		c.vl_custo_gerencial,
		c.cd_curva_abc_filiais as classe_repos_empresa,
		r.cd_classe_reposicao as classe_repos_filial,
		(select coalesce(max(x.nr_rodada), 0)
				from pedido_distribuidora x, pedido_distribuidora_produto y
		where x.cd_filial = p.cd_filial
			and x.nr_pedido_filial = p.nr_pedido_filial
			and y.cd_produto = pp.cd_produto
			and x.cd_filial = y.cd_filial
			and x.nr_pedido_distribuidora = y.nr_pedido_distribuidora) as rodada,
		(case when (select count(*)
					from distribuidora_produto d
						inner join distribuidora_uf u
							on u.cd_distribuidora = d.cd_distribuidora
							and u.cd_unidade_federacao = d.cd_unidade_federacao
					where d.cd_produto = pp.cd_produto
					and d.cd_unidade_federacao = ci.cd_unidade_federacao) > 0 then 'SIM' else 'N$$HEX1$$c300$$ENDHEX$$O'
		end) as relacionado,
		(CASE pp.id_projeto_conexao
			WHEN '1' THEN 'PHARMALINK'
			WHEN '2' THEN 'ENTIRE'
			WHEN '4' THEN 'FIDELIZE'
			ELSE pp.id_projeto_conexao
		END) id_projeto_conexao,
		pp.qt_pedida as qt_pedida,
		(coalesce(pp.qt_rateada, 0) + coalesce(pp.qt_faturada, 0)) qt_faturada,
		pp.qt_pedida - (coalesce(pp.qt_rateada, 0) + coalesce(pp.qt_faturada, 0)) qt_falta,
		round((pp.qt_pedida - (coalesce(pp.qt_rateada, 0) + coalesce(pp.qt_faturada, 0))) * c.vl_custo_gerencial, 2) vl_falta
from pedido_filial as p
	inner join pedido_filial_produto	as pp
		on pp.cd_filial = p.cd_filial
		and pp.nr_pedido_filial = p.nr_pedido_filial
	inner join produto_geral as g
		on g.cd_produto = pp.cd_produto
	inner join produto_central as c
		on c.cd_produto = g.cd_produto
	inner join filial as f
		on f.cd_filial = p.cd_filial
	inner join fornecedor as o
		on o.cd_fornecedor = g.cd_fornecedor_usual
	inner join usuario as u
		on u.nr_matricula = o.nr_matricula_comprador
	left outer join tipo_bloqueia_pedido_psico as ti
		on ti.id_bloqueio = f.id_bloqueia_pedido_psico
	left outer join vw_divisao_fornecedor_produto as v
		on v.cd_produto = pp.cd_produto
	inner join cidade as ci
		on ci.cd_cidade = f.cd_cidade
	inner join vw_classificacao_produto as vp
		on vp.cd_subcategoria = g.cd_subcategoria
	left outer join resumo_reposicao_estoque as r
		on r.cd_filial = p.cd_filial
		and r.cd_produto = pp.cd_produto
	Left Outer Join promocao_sos As s
		On s.cd_promocao_sos	= pp.cd_promocao_sos
where p.dh_emissao between :inicio and :termino
  and p.id_gerado_logistica = 'N'
  And coalesce(pp.qt_rateada, 0) + coalesce(pp.qt_faturada, 0) < pp.qt_pedida" arguments=(("inicio", datetime),("termino", datetime))  sort="cd_filial A de_produto A " )
