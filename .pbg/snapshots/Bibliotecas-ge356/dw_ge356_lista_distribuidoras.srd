table(column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="pedido_distribuidora.cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="pedido_distribuidora.nr_pedido_distribuidora" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="pedido_distribuidora.id_situacao" values="COMP. BLOQ.	B/COLOCADO	C/ENVIADO	E/FATURADO	F/REJEITADO	J/N$$HEX1$$c300$$ENDHEX$$O ATENDIDO	N/EM SEPARA$$HEX2$$c700c300$$ENDHEX$$O	S/SEP. TERM.	T/CANCELADO	X/" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_distribuidora.dh_emissao" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_distribuidora_produto.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_atendida dbname="pedido_distribuidora_produto.qt_atendida" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="pedido_distribuidora_produto.qt_faturada" )
 column=(type=long updatewhereclause=yes name=nr_pedido_empurrado dbname="pedido_distribuidora_produto.nr_pedido_empurrado" )
 column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="pedido_filial_produto.cd_promocao_sos" )
 column=(type=long updatewhereclause=yes name=nr_rodada dbname="nr_rodada" )
 column=(type=char(30) updatewhereclause=yes name=de_motivo_rejeicao dbname="pedido_distribuidora.de_motivo_rejeicao" )
 retrieve="Select	p.cd_distribuidora,
		f.nm_fantasia,
		p.nr_pedido_distribuidora,
		p.id_situacao,
		p.dh_emissao,
		pp.qt_pedida,
		pp.qt_atendida,
		pp.qt_faturada,
		pp.nr_pedido_empurrado,
		fp.cd_promocao_sos,
		coalesce(p.nr_rodada, 0) As nr_rodada,
		p.de_motivo_rejeicao
From pedido_distribuidora As p
	Inner Join pedido_distribuidora_produto As pp
		On pp.cd_filial               			= p.cd_filial
	   And pp.nr_pedido_distribuidora 	= p.nr_pedido_distribuidora
	Inner Join fornecedor As f
		On f.cd_fornecedor = p.cd_distribuidora
	Inner Join pedido_filial_produto As fp
		On fp.cd_filial			= p.cd_filial
	   And fp.nr_pedido_filial	= p.nr_pedido_filial
	   And fp.cd_produto		= pp.cd_produto
Where p.cd_filial = :filial
	And p.nr_pedido_filial	= :pedido
	And pp.cd_produto = :produto" arguments=(("filial", number),("pedido", number),("produto", number))  sort="nr_rodada A " )
