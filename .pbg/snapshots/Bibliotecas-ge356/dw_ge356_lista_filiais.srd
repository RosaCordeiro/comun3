table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="vw_filial.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_filial.dh_emissao" )
 column=(type=long updatewhereclause=yes name=nr_pedido_filial dbname="pedido_filial.nr_pedido_filial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_filial_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf dbname="vw_filial.cd_uf" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_falta dbname="qt_falta" )
 column=(type=long updatewhereclause=yes name=nr_rodada dbname="nr_rodada" )
 column=(type=char(1) updatewhereclause=yes name=id_projeto_conexao dbname="pedido_filial_produto.id_projeto_conexao" values="PHARMALINK	1/ENTIRE	2/FIDELIZE	4/" )
 retrieve="Select	p.cd_filial,
		f.nm_fantasia,
		p.dh_emissao,
		p.nr_pedido_filial,
		pp.cd_produto,
		g.de_produto || ' : ' || g.de_apresentacao_estoque As de_produto,
		f.cd_uf,
		sum(pp.qt_pedida) As qt_pedida,
		sum(coalesce(pp.qt_rateada, 0) + coalesce(pp.qt_faturada, 0)) As qt_faturada,
		sum(pp.qt_pedida - (coalesce(pp.qt_rateada, 0) + coalesce(pp.qt_faturada, 0))) As qt_falta,
		(Select max(nr_rodada)
		 From pedido_distribuidora x
			Inner Join pedido_distribuidora_produto yy
		       On yy.cd_filial = x.cd_filial
		      And yy.nr_pedido_distribuidora = x.nr_pedido_distribuidora
		 Where x.cd_filial = p.cd_filial
			 And x.dh_emissao Between :inicio And :termino
			 And x.nr_pedido_filial = p.nr_pedido_filial
			 And yy.cd_produto = :produto) As nr_rodada,
		pp.id_projeto_conexao
From pedido_filial As p
	Inner Join pedido_filial_produto As pp
		On pp.cd_filial			= p.cd_filial
	   And pp.nr_pedido_filial	= p.nr_pedido_filial
	Inner Join vw_filial As f
		On f.cd_filial = p.cd_filial
	Inner Join produto_geral As g
		On g.cd_produto = pp.cd_produto
Where p.dh_emissao Between :inicio And :termino
	And pp.cd_produto = :produto
	And p.id_gerado_logistica = 'N'
	And coalesce(pp.qt_rateada, 0) + coalesce(pp.qt_faturada, 0) < pp.qt_pedida
Group By	p.cd_filial,
			f.nm_fantasia,
			p.dh_emissao,
			p.nr_pedido_filial,
			pp.cd_produto,
			g.de_produto || ' : ' || g.de_apresentacao_estoque,
			f.cd_uf,
			pp.id_projeto_conexao" arguments=(("inicio", datetime),("termino", datetime),("produto", number))  sort="qt_falta D " )
