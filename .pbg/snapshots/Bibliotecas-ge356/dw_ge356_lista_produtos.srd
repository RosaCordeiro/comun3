table(column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_filial_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" values="ATIVO	A/INATIVO	I/PENDENTE	P/" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_falta dbname="qt_falta" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_gerencial dbname="produto_central.vl_custo_gerencial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_falta dbname="vl_falta" )
 column=(type=long updatewhereclause=yes name=qt_est_transito dbname="qt_est_transito" )
 column=(type=long updatewhereclause=yes name=qt_pedida_cd dbname="qt_pedida_cd" )
 column=(type=long updatewhereclause=yes name=qt_saldo_cd dbname="qt_saldo_cd" )
 retrieve="Select	pp.cd_produto,
		g.de_produto || ' : ' || g.de_apresentacao_estoque As de_produto,
		g.id_situacao,
		sum(pp.qt_pedida) As qt_pedida,
		sum(coalesce(pp.qt_rateada, 0) + coalesce(pp.qt_faturada, 0)) As qt_faturada,
		sum(pp.qt_pedida - (coalesce(pp.qt_rateada, 0) + coalesce(pp.qt_faturada, 0))) As qt_falta,
		c.vl_custo_gerencial,
		sum(round((pp.qt_pedida - (coalesce(pp.qt_rateada, 0) + coalesce(pp.qt_faturada, 0))) * c.vl_custo_gerencial, 2)) As vl_falta,
		0 qt_est_transito,
		0 qt_pedida_cd,
		(Select coalesce(x.qt_saldo_final, 0)
			From vw_saldo_atual_produto x
			Where x.cd_produto = pp.cd_produto
				And x.cd_filial = 534) qt_saldo_cd
From pedido_filial As p (Index idx_data_emissao)
	Inner Join pedido_filial_produto	As pp
		On pp.cd_filial			= p.cd_filial
	   And pp.nr_pedido_filial	= p.nr_pedido_filial
	Inner Join produto_central As c
		On c.cd_produto = pp.cd_produto
	Inner Join produto_geral As g
		On g.cd_produto = pp.cd_produto
	Left Outer Join promocao_sos As s
		On s.cd_promocao_sos	= pp.cd_promocao_sos
Where p.dh_emissao Between :dh_inicio And :dh_termino
	And p.id_gerado_logistica = 'N'
	And coalesce(pp.qt_rateada, 0) + coalesce(pp.qt_faturada, 0) < pp.qt_pedida
Group By	pp.cd_produto,
			g.de_produto || ' : ' || g.de_apresentacao_estoque,
			g.id_situacao,
			c.vl_custo_gerencial" arguments=(("dh_inicio", datetime),("dh_termino", datetime))  sort="qt_falta D de_produto A " )
