table(column=(type=char(2) updatewhereclause=yes name=id_rede_filial dbname="id_rede_filial" )
 column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="grupo.cd_grupo" dbalias="g.cd_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="grupo.de_grupo" dbalias="g.de_grupo" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="id_lei_generico" )
 column=(type=char(12) updatewhereclause=yes name=de_lei_generico dbname="de_lei_generico" )
 column=(type=decimal(28) updatewhereclause=yes name=vl_devolucao dbname="vl_devolucao" )
 retrieve="select case when g.cd_grupo = '6' then 'MP' else f.id_rede_filial end as id_rede_filial, 
		g.cd_grupo, 
		g.de_grupo, 
		case when g.cd_grupo = '1' then
			 h.id_lei_generico 
		else 'R' end as id_lei_generico,
		case when g.cd_grupo = '1' then
			case h.id_lei_generico 
				when 'G' then 'GEN$$HEX1$$c900$$ENDHEX$$RICO'
				when 'R' then 'REFER$$HEX1$$ca00$$ENDHEX$$NCIA'
				When 'E' then 'EQUIVALENTE'
				when 'S' then 'SIMILAR'
				when 'O' then 'OUTROS'
			else 'DESCONHECIDO' end
		else 'REFER$$HEX1$$ca00$$ENDHEX$$NCIA' end as de_lei_generico,
		sum(round(i.qt_devolvida * i.vl_preco_unitario * (1 - i.pc_desconto/100) * (1 - n.pc_desconto/100),2)) as vl_devolucao
from nf_devolucao_venda n 
inner join item_nf_devolucao_venda i 
	on i.cd_filial = n.cd_filial
	and i.nr_nf = n.nr_nf
	and i.de_serie = n.de_serie
	and i.de_especie = n.de_especie
inner join nf_venda v
	on v.cd_filial = n.cd_filial_venda
	and v.nr_nf = n.nr_nf_venda
	and v.de_serie = n.de_serie_venda
	and v.de_especie = n.de_especie_venda
inner join historico_produto h (index pk_historico_produto)
	on h.cd_produto = i.cd_produto
	and h.dh_historico = :dh_historico
inner join grupo g
	on g.cd_grupo = substring(h.cd_subcategoria,1,1)
inner join filial f
	on f.cd_filial = n.cd_filial
Where n.dh_movimentacao_caixa between :dh_inicio and :dh_fim
	and v.nr_pedido_ecommerce is not null
	and f.id_rede_filial <> 'FA'
group by case when g.cd_grupo = '6' then 'MP' else f.id_rede_filial end, 
			g.cd_grupo, 
			g.de_grupo, 
			case when g.cd_grupo = '1' then
				 h.id_lei_generico 
			else 'R' end,
			case when g.cd_grupo = '1' then
				case h.id_lei_generico 
					when 'G' then 'GEN$$HEX1$$c900$$ENDHEX$$RICO'
					when 'R' then 'REFER$$HEX1$$ca00$$ENDHEX$$NCIA'
					When 'E' then 'EQUIVALENTE'
					when 'S' then 'SIMILAR'
					when 'O' then 'OUTROS'
				else 'DESCONHECIDO' end
			else 'REFER$$HEX1$$ca00$$ENDHEX$$NCIA' end" arguments=(("dh_inicio", datetime),("dh_fim", datetime),("dh_historico", datetime)) )
