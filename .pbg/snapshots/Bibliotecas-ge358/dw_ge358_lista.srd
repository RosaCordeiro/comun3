table(column=(type=long updatewhereclause=yes name=cd_filial dbname="negociacao_cliente.cd_filial" dbalias="n.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="negociacao_cliente.cd_produto" dbalias="n.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(54) updatewhereclause=yes name=concorrente dbname="concorrente" )
 column=(type=char(60) updatewhereclause=yes name=de_laboratorio dbname="negociacao_cliente.de_laboratorio" dbalias="n.de_laboratorio" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao dbname="cliente_caixa.dh_movimentacao" dbalias="c.dh_movimentacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_atual dbname="pc_desconto_atual" )
 column=(type=decimal(2) updatewhereclause=yes name=preco_atual_unit dbname="preco_atual_unit" )
 column=(type=long updatewhereclause=yes name=qt_negociada dbname="negociacao_cliente.qt_negociada" dbalias="n.qt_negociada" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_negociado dbname="negociacao_cliente.pc_desconto_negociado" dbalias="n.pc_desconto_negociado" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_negociado dbname="negociacao_cliente.vl_preco_negociado" dbalias="n.vl_preco_negociado" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_concorrente dbname="negociacao_cliente.vl_preco_concorrente" dbalias="n.vl_preco_concorrente" )
 column=(type=long updatewhereclause=yes name=nota dbname="cliente_caixa.nota" dbalias="c.nota" )
 column=(type=decimal(2) updatewhereclause=yes name=desc_concedido dbname="desc_concedido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_gerencial dbname="vl_custo_gerencial" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="item_nf_venda.pc_icms" dbalias="i.pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_comissao_extra dbname="item_nf_venda.pc_comissao_extra" dbalias="i.pc_comissao_extra" )
 column=(type=decimal(15) updatewhereclause=yes name=valor_rentabilidade dbname="VALOR_RENTABILIDADE" )
 column=(type=decimal(27) updatewhereclause=yes name=perc_rent dbname="PERC_RENT" )
 retrieve="select n.cd_filial, 
		f.nm_fantasia, 
		n.cd_produto,
		g.de_produto || ' : ' || g.de_apresentacao_venda de_produto,
		(Case when n.cd_concorrente is not null Then cc.nm_concorrente + ' (' + cast(n.cd_concorrente as varchar(10)) + ') ' END) concorrente,
		n.de_laboratorio,

		c.dh_movimentacao,		
		0.00 as vl_preco_unitario,
		0.00 as pc_desconto_atual,

		0.00 as preco_atual_unit,
		
         n.qt_negociada,
         n.pc_desconto_negociado,
         n.vl_preco_negociado,
         n.vl_preco_concorrente,
		c.nr_nf_venda  nota,
		
		0.00 as desc_concedido,

		coalesce(m.vl_custo_gerencial, sp.vl_custo_medio)	as vl_custo_gerencial,
		i.pc_icms,
		i.pc_comissao_extra,

		n.vl_preco_negociado 
		- coalesce(m.vl_custo_gerencial, sp.vl_custo_medio) 
		- (round(n.vl_preco_negociado * (coalesce(i.pc_icms,0) / 100), 2) 
		- round(n.vl_preco_negociado * (coalesce(i.pc_comissao_extra,0) / 100), 2)) VALOR_RENTABILIDADE,

		round(((
		n.vl_preco_negociado 
		- coalesce(m.vl_custo_gerencial, sp.vl_custo_medio) 
		- round(n.vl_preco_negociado * (coalesce(i.pc_icms,0) / 100), 2) 
		- round(n.vl_preco_negociado * (coalesce(i.pc_comissao_extra,0) / 100)
		, 2)) / n.vl_preco_negociado) * 100, 2) PERC_RENT

from cliente_caixa c
inner join negociacao_cliente n
	on n.cd_filial = c.cd_filial
	and n.nr_sequencial_cliente_caixa = c.nr_sequencial
inner join filial f
	on f.cd_filial = n.cd_filial
inner join produto_geral g
	on g.cd_produto = n.cd_produto
left join saldo_produto sp
	on g.cd_produto = sp.cd_produto
	and f.cd_filial = sp.cd_filial
	and sp.dh_saldo  = f.dh_ultimo_saldo
	and sp.cd_filial = n.cd_filial
left outer join concorrente cc
	 on cc.cd_concorrente = n.cd_concorrente
left outer join item_nf_venda i
	on i.cd_filial 		= c.cd_filial
	and i.nr_nf			= c.nr_nf_venda
	and i.de_especie	= c.de_especie_venda
	and i.de_serie		= c.de_serie_venda
	and i.cd_produto 	= n.cd_produto
	and i.pc_desconto_tabela = n.pc_desconto_negociado
left outer join movimento_estoque m
	on m.cd_filial_movimento = n.cd_filial
	and m.nr_nf				= i.nr_nf
	and m.de_especie		= i.de_especie
	and m.de_serie			= i.de_serie
	and m.cd_produto		= i.cd_produto
	and m.nr_sequencial 	= i.nr_sequencial
where (c.dh_movimentacao between :dh_inicio and :dh_termino)" arguments=(("dh_inicio", datetime),("dh_termino", datetime))  sort="nm_fantasia A dh_movimentacao A de_produto A " )
