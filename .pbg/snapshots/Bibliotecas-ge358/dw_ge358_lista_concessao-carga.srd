table(column=(type=long updatewhereclause=yes name=cd_filial dbname="negociacao_cliente.cd_filial" dbalias="n.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_concorrente dbname="concorrente.cd_concorrente" dbalias="cc.cd_concorrente" )
 column=(type=char(40) updatewhereclause=yes name=nm_concorrente dbname="concorrente.nm_concorrente" dbalias="cc.nm_concorrente" )
 column=(type=long updatewhereclause=yes name=qt_negociada dbname="negociacao_cliente.qt_negociada" dbalias="n.qt_negociada" )
 column=(type=char(3) updatewhereclause=yes name=concluiu dbname="Concluiu" )
 retrieve="select n.cd_filial, 		f.nm_fantasia, 	cc.cd_concorrente, 	cc.nm_concorrente,  n.qt_negociada,  'SIM' as Concluiu
from cliente_caixa c
inner join negociacao_cliente n
	on c.cd_filial = n.cd_filial
	and c.nr_sequencial = n.nr_sequencial_cliente_caixa
inner join filial f
	on f.cd_filial = n.cd_filial
left join concorrente cc
	 on cc.cd_concorrente = n.cd_concorrente
left join item_nf_venda i
	on i.cd_filial 		= c.cd_filial
	and i.nr_nf			= c.nr_nf_venda
	and i.de_especie	= c.de_especie_venda
	and i.de_serie		= c.de_serie_venda
	and i.cd_produto 	= n.cd_produto
	and i.pc_desconto_tabela = n.pc_desconto_negociado
where (c.dh_movimentacao between :dh_inicio and :dh_termino)
and c.nr_nf_venda is not null

UNION all

select n.cd_filial, 		f.nm_fantasia, cc.cd_concorrente, cc.nm_concorrente,  n.qt_negociada,  'N$$HEX1$$c300$$ENDHEX$$O' as Concluiu
from cliente_caixa c
inner join negociacao_cliente n
	on c.cd_filial = n.cd_filial
	and c.nr_sequencial = n.nr_sequencial_cliente_caixa
inner join filial f
	on f.cd_filial = n.cd_filial
left join concorrente cc
	 on cc.cd_concorrente = n.cd_concorrente
left join item_nf_venda i
	on i.cd_filial 		= c.cd_filial
	and i.nr_nf			= c.nr_nf_venda
	and i.de_especie	= c.de_especie_venda
	and i.de_serie		= c.de_serie_venda
	and i.cd_produto 	= n.cd_produto
	and i.pc_desconto_tabela = n.pc_desconto_negociado
where (c.dh_movimentacao between :dh_inicio and :dh_termino)
and c.nr_nf_venda is null
" arguments=(("dh_inicio", datetime),("dh_termino", datetime))  sort="cd_filial A cd_concorrente A " )
