table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia_4 dbname="filial.nm_fantasia" )
 column=(type=char(18) updatewhereclause=yes name=vv_uso_cp dbname="vv_uso_cp" )
 column=(type=char(6) updatewhereclause=yes name=vv_fat dbname="vv_fat" )
 column=(type=char(13) updatewhereclause=yes name=vv_fat_meta dbname="vv_fat_meta" )
 column=(type=char(13) updatewhereclause=yes name=vv_num_clientes dbname="vv_num_clientes" )
 column=(type=long updatewhereclause=yes name=periodo01_2 dbname="periodo01" )
 column=(type=long updatewhereclause=yes name=periodo01_2 dbname="periodo01_2" )
