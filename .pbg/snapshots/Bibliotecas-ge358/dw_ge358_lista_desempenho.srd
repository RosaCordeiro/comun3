 column=(type=long updatewhereclause=yes name=periodo01_4 dbname="periodo01_4" )
 column=(type=long updatewhereclause=yes name=periodo02 dbname="periodo02" )
 column=(type=long updatewhereclause=yes name=periodo02_2 dbname="periodo02_2" )
 column=(type=long updatewhereclause=yes name=periodo02_3 dbname="periodo02_3" )
 column=(type=long updatewhereclause=yes name=periodo02_4 dbname="periodo02_4" )
 column=(type=long updatewhereclause=yes name=periodo03 dbname="periodo03" )
 column=(type=long updatewhereclause=yes name=periodo03_2 dbname="periodo03_2" )
 column=(type=long updatewhereclause=yes name=periodo03_3 dbname="periodo03_3" )
 column=(type=long updatewhereclause=yes name=periodo03_4 dbname="periodo03_4" )
 column=(type=long updatewhereclause=yes name=periodo04 dbname="periodo04" )
 column=(type=long updatewhereclause=yes name=periodo04_2 dbname="periodo04_2" )
 column=(type=long updatewhereclause=yes name=periodo04_3 dbname="periodo04_3" )
 column=(type=long updatewhereclause=yes name=periodo04_4 dbname="periodo04_4" )
 column=(type=long updatewhereclause=yes name=periodo05 dbname="periodo05" )
 column=(type=long updatewhereclause=yes name=periodo05_2 dbname="periodo05_2" )
 column=(type=long updatewhereclause=yes name=periodo05_3 dbname="periodo05_3" )
 column=(type=long updatewhereclause=yes name=periodo05_4 dbname="periodo05_4" )
 column=(type=long updatewhereclause=yes name=periodo06 dbname="periodo06" )
 column=(type=long updatewhereclause=yes name=periodo06_2 dbname="periodo06_2" )
 column=(type=long updatewhereclause=yes name=periodo06_3 dbname="periodo06_3" )
 column=(type=long updatewhereclause=yes name=periodo06_4 dbname="periodo06_4" )
 retrieve="select distinct(n.cd_filial), 
		f.nm_fantasia, 
		'R$ Uso Cobre Pre$$HEX1$$e700$$ENDHEX$$o' as vv_uso_cp , 
		'R$ FAT' as vv_fat , 
		'R$ FAT (META)' as vv_fat_meta, 
		'Num. Clientes' as vv_num_clientes , 
		0 as periodo01, 
			0 as periodo01_2, 0 as periodo01_3, 0 as periodo01_4, 
		0 as periodo02, 
			0 as periodo02_2, 0 as periodo02_3, 0 as periodo02_4, 
		0 as periodo03, 
			0 as periodo03_2, 0 as periodo03_3, 0 as periodo03_4, 
		0 as periodo04, 
			0 as periodo04_2, 0 as periodo04_3, 0 as periodo04_4, 
		0 as periodo05, 
			0 as periodo05_2, 0 as periodo05_3, 0 as periodo05_4, 
		0 as periodo06,
			0 as periodo06_2, 0 as periodo06_3, 0 as periodo06_4
from cliente_caixa c 
inner join negociacao_cliente n
	on c.cd_filial = n.cd_filial
	and c.nr_sequencial = n.nr_sequencial_cliente_caixa
inner join filial f
	on f.cd_filial = n.cd_filial
inner join item_nf_venda i
	on i.cd_filial 		= c.cd_filial
	and i.nr_nf			= c.nr_nf_venda
	and i.de_especie	= c.de_especie_venda
	and i.de_serie		= c.de_serie_venda
	and i.cd_produto 	= n.cd_produto
	and i.pc_desconto_tabela = n.pc_desconto_negociado
 where c.nr_nf_venda is not null


"  sort="cd_filial A " )
