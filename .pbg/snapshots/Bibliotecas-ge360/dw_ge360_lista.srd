table(column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(102) updatewhereclause=yes name=produto dbname="produto" )
 column=(type=char(1) updatewhereclause=yes name=cd_grupo_produto dbname="grupo.cd_grupo_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo_produto dbname="grupo.de_grupo_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo dbname="subgrupo.de_subgrupo" )
 column=(type=char(40) updatewhereclause=yes name=de_categoria dbname="categoria.de_categoria" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="subcategoria.de_subcategoria" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="id_situacao" values="INATIVO	I/PENDENTE	P/ATIVO	A/" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_reposicao dbname="cd_classe_reposicao" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_preco_venda_atual dbname="vl_preco_venda_atual" initial="0.00" )
 column=(type=long updatewhereclause=yes name=qt_consulta dbname="qt_consulta" initial="0" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="qt_recebida" initial="0" )
 column=(type=long updatewhereclause=yes name=qt_substituido dbname="qt_substituido" initial="0" )
 retrieve="  SELECT	ppc.cd_produto	as cd_produto,
			pg.de_produto + ': ' + pg.de_apresentacao_venda as produto,
			gp.cd_grupo	as cd_grupo_produto,
			gp.de_grupo	as de_grupo_produto,  
			sg.de_subgrupo,  
			cg.de_categoria,  
			sc.de_subcategoria,  
			pg.id_situacao	as id_situacao,
			min(r.cd_classe_reposicao) as cd_classe_reposicao,
			(pg.vl_preco_venda_atual / pg.vl_fator_conversao)  as vl_preco_venda_atual, 
			sum(ppc.qt_consulta) as qt_consulta,
			sum(ppc.qt_recebida_outra_filial) as qt_recebida,
			sum(ppc.qt_substituido_generico) as qt_substituido
    FROM produto_procurado_zerado ppc (index idx_dt_fil_produto) 
INNER JOIN	produto_geral	pg (index pk_produto_geral)
	ON pg.cd_produto = ppc.cd_produto
INNER JOIN	subcategoria sc
	ON sc.cd_subcategoria  = pg.cd_subcategoria
INNER JOIN categoria cg
	on cg.cd_categoria = sc.cd_categoria
INNER JOIN subgrupo sg
	on sg.cd_subgrupo = cg.cd_subgrupo
INNER JOIN grupo gp
	on gp.cd_grupo = sg.cd_grupo
LEFT OUTER JOIN resumo_reposicao_estoque	r (index pk_resumo_reposicao_estoque)
	ON r.cd_filial	 	= ppc.cd_filial
   AND r.cd_produto	= ppc.cd_produto
WHERE ppc.dh_movimentacao between :dt_inicio and :dt_termino
GROUP BY	ppc.cd_produto,
				pg.de_produto + ': ' + pg.de_apresentacao_venda ,
				gp.cd_grupo	,
				gp.de_grupo,
				sg.de_subgrupo,  
				cg.de_categoria,  
				sc.de_subcategoria,  
				pg.id_situacao	,
				(pg.vl_preco_venda_atual / pg.vl_fator_conversao)" arguments=(("dt_inicio", date),("dt_termino", date))  sort="vl_total_consulta D qt_consulta D " )
