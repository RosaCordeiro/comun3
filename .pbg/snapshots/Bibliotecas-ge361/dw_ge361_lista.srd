table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="g.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" dbalias="g.id_situacao" )
 column=(type=long updatewhereclause=yes name=qt_saldo dbname="qt_saldo" )
 column=(type=long updatewhereclause=yes name=cd_planograma dbname="produto_geral.cd_planograma" dbalias="g.cd_planograma" )
 column=(type=char(50) updatewhereclause=yes name=de_planograma dbname="categoria_planograma.de_planograma" dbalias="p.de_planograma" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="g.vl_fator_conversao" )
 column=(type=long updatewhereclause=yes name=nr_embalagem_padrao dbname="produto_geral.nr_embalagem_padrao" dbalias="g.nr_embalagem_padrao" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="qt_estoque_base" )
 column=(type=char(1) updatewhereclause=yes name=id_possui_promocao_plan dbname="id_possui_promocao_plan" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo dbname="qt_estoque_minimo" )
 column=(type=datetime updatewhereclause=yes name=dh_ultima_entrada dbname="dh_ultima_entrada" )
 column=(type=char(1) updatewhereclause=yes name=tipo_entrada dbname="tipo_entrada" )
 column=(type=char(1) updatewhereclause=yes name=de_motivo_entrada dbname="de_motivo_entrada" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_alteracao dbname="resumo_reposicao_estoque.nr_matricula_alteracao" dbalias="r.nr_matricula_alteracao" )
 column=(type=char(40) updatewhereclause=yes name=nm_responsavel dbname="usuario.nm_responsavel" dbalias="u.nm_responsavel" )
 column=(type=char(60) updatewhereclause=yes name=de_motivo_alteracao dbname="resumo_reposicao_estoque.de_motivo_alteracao" dbalias="r.de_motivo_alteracao" )
 retrieve="Select	s.cd_filial,
		f.nm_fantasia,
		g.cd_produto,
		g.de_produto || ' : ' || g.de_apresentacao_venda As de_produto,
		g.id_situacao,
		s.qt_saldo_final As qt_saldo,
		g.cd_planograma,
		p.de_planograma,
		g.vl_fator_conversao,
		g.nr_embalagem_padrao,
		Coalesce(r.qt_estoque_base, 0) As qt_estoque_base,
		(case when (select Count(*)
			from promocao_sos p (index pk_promocao_sos)
            inner join promocao_sos_produto pp (index pk_promocao_sos_produto) on pp.cd_promocao_sos = p.cd_promocao_sos
			inner join promocao_sos_filial f on f.cd_promocao_sos = p.cd_promocao_sos
			inner join promocao_sos_estoque_minimo m on m.cd_promocao_sos = p.cd_promocao_sos and m.cd_filial = f.cd_filial and m.cd_produto = pp.cd_produto
		where f.cd_filial = s.cd_filial and pp.cd_produto = s.cd_produto
		  and p.id_tipo_promocao = 'P'
		  and p.dh_inicio <= (select dh_movimentacao from parametro where id_parametro = '1')
		  and (p.dh_termino >= (select dh_movimentacao from parametro where id_parametro = '1') or p.dh_termino is null)) > 0 then 'S' Else 'N' end) As id_possui_promocao_plan,
		(select coalesce(qt_estoque_minimo, 0) from resumo_estoque_minimo_filial where cd_produto = g.cd_produto and cd_filial = s.cd_filial) as qt_estoque_minimo,
		Cast('1900/01/01' As DateTime) As dh_ultima_entrada,
		'' As tipo_entrada,
		'' As de_motivo_entrada,
		r.nr_matricula_alteracao,
		u.nm_usuario As nm_responsavel,
		r.de_motivo_alteracao
From produto_geral As g
	Inner Join saldo_produto As s (index saldo_prod_5850531202)
		On s.cd_produto = g.cd_produto
		And s.dh_saldo = :saldo
	Inner Join filial As f
		On f.cd_filial = s.cd_filial
	Left Outer Join categoria_planograma As p
		On p.cd_planograma = g.cd_planograma
	Left Outer Join resumo_reposicao_estoque As r
		On r.cd_filial = s.cd_filial
	   And r.cd_produto = s.cd_produto
	Left Outer Join usuario As u
		On u.nr_matricula = r.nr_matricula_alteracao
Where g.id_situacao = 'A'
	And f.id_situacao = 'A'
	And s.cd_filial Not In (1, 2, 534)
	And g.cd_planograma Is Not Null
	And Exists (Select *
					From movimento_estoque m (index idx_produto_data_fil)
					Where m.cd_filial_movimento = s.cd_filial
					 	And m.dh_movimento >= :movimento
						And m.cd_tipo_movimento In (3, 5)
						And m.cd_produto = g.cd_produto)" arguments=(("saldo", date),("movimento", datetime)) )
