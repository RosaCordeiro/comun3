table(column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="promocao_sos_produto_novo.cd_promocao_sos" dbalias="p.cd_promocao_sos" )
 column=(type=char(40) updatewhereclause=yes name=nm_promocao_sos dbname="promocao_sos.nm_promocao_sos" dbalias="s.nm_promocao_sos" )
 column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="promocao_sos_produto_novo.cd_grupo" dbalias="p.cd_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="grupo.de_grupo" dbalias="g.de_grupo" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="promocao_sos_produto_novo.id_lei_generico" dbalias="p.id_lei_generico" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="promocao_sos_produto_novo.pc_desconto" dbalias="p.pc_desconto" )
 retrieve="Select	p.cd_promocao_sos,
		s.nm_promocao_sos,
		p.cd_grupo,
		g.de_grupo,
		p.id_lei_generico,
		p.pc_desconto
From promocao_sos_produto_novo As p
	Inner Join promocao_sos As s
		On s.cd_promocao_sos = p.cd_promocao_sos
	Inner Join grupo As g
		On g.cd_grupo = p.cd_grupo"  sort="nm_promocao_sos A de_grupo A id_lei_generico A " )
