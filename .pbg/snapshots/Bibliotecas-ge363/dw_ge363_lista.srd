table(column=(type=long updatewhereclause=yes name=cd_filial dbname="libera_pedido_filial_estoque.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="vw_filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_dia_semana dbname="libera_pedido_filial_estoque.nr_dia_semana" )
 column=(type=long updatewhereclause=yes name=qt_dias_reforco dbname="libera_pedido_filial_estoque.qt_dias_reforco" )
 column=(type=char(1) updatewhereclause=yes name=id_mix_completo dbname="libera_pedido_filial_estoque.id_mix_completo" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_pedido_controlado_exclusivo dbname="id_pedido_controlado_exclusivo" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 retrieve="Select	l.cd_filial,
		f.nm_fantasia,
		l.nr_dia_semana,
		l.qt_dias_reforco,
		l.id_mix_completo,
		coalesce(l.id_pedido_controlado_exclusivo, 'N') id_pedido_controlado_exclusivo
From libera_pedido_filial_estoque As l
	Inner Join vw_filial As f
		On f.cd_filial = l.cd_filial
Where f.cd_uf = 'BA'"  sort="nm_fantasia A nr_dia_semana A " )
