 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_adicional dbname="pc_desconto_adicional" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_utilizado dbname="vl_preco_utilizado" )
 column=(type=char(1) updatewhereclause=yes name=id_icms_normal dbname="id_icms_normal" )
