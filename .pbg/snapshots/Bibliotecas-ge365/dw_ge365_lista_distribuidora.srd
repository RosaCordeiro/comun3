table(column=(type=char(9) updatewhereclause=yes key=yes name=cd_distribuidora dbname="cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_distribuidora dbname="nm_razao_distribuidora" )
 column=(type=long updatewhereclause=yes key=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(2) updatewhereclause=yes key=yes name=cd_unidade_federacao dbname="cd_unidade_federacao" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="cd_fornecedor_usual" )
