 column=(type=datetime update=yes updatewhereclause=yes name=dh_alteracao_preco_desconto dbname="dh_alteracao_preco_desconto" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matric_alteracao_preco dbname="nr_matric_alteracao_preco" )
