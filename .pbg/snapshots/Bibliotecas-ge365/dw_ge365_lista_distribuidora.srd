 column=(type=datetime update=yes updatewhereclause=yes name=dh_alteracao_situacao dbname="dh_alteracao_situacao" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matric_alteracao_situacao dbname="nr_matric_alteracao_situacao" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_alteracao_situacao dbname="de_alteracao_situacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_alteracao dbname="vl_preco_alteracao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_alteracao dbname="pc_desconto_alteracao" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_alteracao dbname="id_situacao_alteracao" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao_distribuidora dbname="dh_atualizacao_distribuidora" )
 column=(type=long updatewhereclause=yes name=nr_prioridade_distribuicao dbname="nr_prioridade_distribuicao" )
 column=(type=long update=yes updatewhereclause=yes name=nr_dias_pagamento dbname="nr_dias_pagamento" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_juros dbname="pc_juros" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_financeiro dbname="pc_desconto_financeiro" )
 column=(type=char(1) updatewhereclause=yes name=cd_tributacao_icms dbname="cd_tributacao_icms" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_comprador dbname="nr_matricula_comprador" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="vl_icms_st" )
 column=(type=char(30) updatewhereclause=yes name=de_alteracao dbname="de_alteracao" )
 column=(type=char(20) updatewhereclause=yes name=de_projeto_conexao dbname="de_projeto_conexao" )
 column=(type=long updatewhereclause=yes name=qt_embalagem_padrao_distrib dbname="qt_embalagem_padrao_distrib" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_preco_venda dbname="vl_preco_venda" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_preco_liq dbname="vl_preco_liq" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_preco_clube dbname="vl_preco_clube" )
 column=(type=char(1) updatewhereclause=yes name=id_homologando_pedido dbname="id_homologando_pedido" )
 column=(type=long updatewhereclause=yes name=qt_estoque_disponivel dbname="qt_estoque_disponivel" )
 column=(type=char(1) updatewhereclause=yes name=id_possui_saldo dbname="id_possui_saldo" )
 column=(type=datetime updatewhereclause=yes name=dh_arquivo_estoque dbname="dh_arquivo_estoque" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_calculo_variacao dbname="vl_preco_calculo_variacao" )
 column=(type=long updatewhereclause=yes name=id_distribuidora_bloq dbname="id_distribuidora_bloq" )
 column=(type=char(291) updatewhereclause=yes name=de_motivo_bloqueio_distr_uf dbname="de_motivo_bloqueio_distr_uf" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_promocao_desconto_finan dbname="pc_promocao_desconto_finan" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_acordo_sellin dbname="pc_desconto_acordo_sellin" )
 column=(type=long updatewhereclause=yes name=ncm_produto dbname="ncm_produto" )
 column=(type=long updatewhereclause=yes name=cd_cest dbname="cd_cest" )
 column=(type=char(3) updatewhereclause=yes name=cd_cst dbname="cd_cst" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st_retido dbname="vl_icms_st_retido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_st_retido dbname="vl_bc_st_retido" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_st dbname="pc_icms_st" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_mva dbname="pc_mva" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pmc dbname="vl_pmc" )
 column=(type=long updatewhereclause=yes name=nr_embalagem_distrib dbname="nr_embalagem_distrib" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pis_compra_calculo_bloq dbname="vl_pis_compra_calculo_bloq" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cofins_compra_calculo_bloq dbname="vl_cofins_compra_calculo_bloq" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pis_venda_calculo_bloq dbname="vl_pis_venda_calculo_bloq" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cofins_venda_calculo_bloq dbname="vl_cofins_venda_calculo_bloq" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_venda dbname="pc_icms_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_venda_calculo_bloq dbname="vl_icms_venda_calculo_bloq" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_compra_calculo_bloq dbname="vl_preco_compra_calculo_bloq" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_calculo_bloq dbname="vl_preco_venda_calculo_bloq" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_margem dbname="pc_margem" )
 column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="cd_grupo" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="id_lei_generico" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_utilizado dbname="pc_desconto_utilizado" )
 column=(type=char(1) updatewhereclause=yes name=id_retira_bloq_compra_distrib dbname="id_retira_bloq_compra_distrib" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_pis_cofins dbname="id_situacao_pis_cofins" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_compra dbname="vl_compra" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_compra_plan dbname="vl_compra_plan" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_repasse_plan dbname="vl_repasse_plan" )
 column=(type=char(1) updatewhereclause=yes name=id_legenda dbname="id_legenda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_juros_compra dbname="vl_juros_compra" )
 column=(type=char(1) updatewhereclause=yes name=id_pedido_exclusivo_falta dbname="id_pedido_exclusivo_falta" )
 column=(type=char(1) updatewhereclause=yes name=id_compra_bloqueada dbname="id_compra_bloqueada" )
 column=(type=datetime updatewhereclause=yes name=dt_inicio_stb dbname="dt_inicio_stb" )
 column=(type=datetime updatewhereclause=yes name=dt_fim_stb dbname="dt_fim_stb" )
 column=(type=char(2) updatewhereclause=yes name=id_stb dbname="id_stb" )
 column=(type=char(100) updatewhereclause=yes name=de_desc_stb dbname="de_desc_stb" )
 retrieve="SELECT	d.cd_distribuidora,
		fd.nm_razao_social nm_razao_distribuidora, 
		d.cd_produto, 
		d.cd_unidade_federacao,
		g.de_produto + ' : ' + g.de_apresentacao_estoque de_produto,
		g.cd_fornecedor_usual,
		fu.nm_razao_social nm_razao_usual,
		d.cd_produto_distribuidora,
		d.dh_inclusao,
		d.vl_preco_atual,   
		coalesce(c.pc_desconto_conexao,0),   
		coalesce(d.pc_desconto_conexao,0) as pc_desconto_adicional,
		IsNull(d.vl_preco_novo, d.vl_preco_atual) as vl_preco_utilizado,
		t.id_icms_normal,
		d.pc_icms,
		d.pc_reducao_base_icms,
		isnull(d.pc_repasse_icms, 0) pc_repasse_icms,
		d.dh_alteracao_preco_desconto,
		d.nr_matric_alteracao_preco,
		d.id_situacao,
		d.id_situacao_anterior,
		d.dh_alteracao_situacao,
		d.nr_matric_alteracao_situacao,
		d.de_alteracao_situacao,
		d.vl_preco_atual vl_preco_alteracao,
		d.pc_desconto_atual pc_desconto_alteracao,   
		d.id_situacao id_situacao_alteracao,
		d.dh_atualizacao_distribuidora,
		fd.nr_prioridade_distribuicao,
		d.nr_dias_pagamento,
		round((select coalesce(pc_juros_diario_ped_eletronico, 0) from parametro where id_parametro = '1') * isnull(d.nr_dias_pagamento, 0), 2) pc_juros,
		isnull(case when convert(varchar,coalesce(fd.dh_vigencia_midia, '2099-01-01'),102)<= convert(varchar,getdate(),102) then d.pc_comissao_midia else fd.pc_desconto_financeiro end, 0) pc_desconto_financeiro,
		u.cd_tributacao_icms,
		fu.nr_matricula_comprador,
		d.vl_icms_st,
		(case when d.pc_desconto_atual <> isNull(d.pc_desconto_novo, d.pc_desconto_atual) and d.vl_preco_atual <> isNull(d.vl_preco_novo, d.vl_preco_atual) then 'ALTERA$$HEX2$$c700c300$$ENDHEX$$O: PRE$$HEX1$$c700$$ENDHEX$$O/DESCONTO NOVO' 
			when d.pc_desconto_atual <> isNull(d.pc_desconto_novo, d.pc_desconto_atual) then 'ALTERA$$HEX2$$c700c300$$ENDHEX$$O: DESCONTO NOVO'
			when d.vl_preco_atual <> isNull(d.vl_preco_novo, d.vl_preco_atual) then 'ALTERA$$HEX2$$c700c300$$ENDHEX$$O: PRE$$HEX1$$c700$$ENDHEX$$O NOVO'
			else '' 
		 end ) as de_alteracao,
		z.de_projeto_conexao,
		coalesce(d.qt_embalagem_padrao_distrib, 1) as qt_embalagem_padrao_distrib,
	Round((
		select coalesce(min(
			case 
				when (
					(select upper(vl_parametro)
					 from parametro_geral
					 where cd_parametro = 'ID_UTILIZA_PRECO_CLUBE') = 'S'
				)
				then
					case 
						when y.vl_preco_clube is null or y.vl_preco_clube = 0 then y.vl_preco_liquido
						when y.vl_preco_liquido < y.vl_preco_clube then y.vl_preco_liquido
						else y.vl_preco_clube 
					end
				else y.vl_preco_liquido
			end
		), 0)
		from preco_venda_filial y
		inner join filial w on w.cd_filial = y.cd_filial
		inner join cidade c on c.cd_cidade = w.cd_cidade
		inner join unidade_federacao uf on uf.cd_unidade_federacao = c.cd_unidade_federacao
		where uf.cd_unidade_federacao = d.cd_unidade_federacao
			and y.cd_produto = d.cd_produto
	) * g.vl_fator_conversao, 2) as vl_preco_venda,
	Round((select coalesce(min(y.vl_preco_liquido), 0)
			 from preco_venda_filial y
				inner join filial w
					on w.cd_filial = y.cd_filial
				inner join cidade c
					on c.cd_cidade = w.cd_cidade
				inner join unidade_federacao uf
					on uf.cd_unidade_federacao = c.cd_unidade_federacao
			 where uf.cd_unidade_federacao = d.cd_unidade_federacao
				  and y.cd_produto = d.cd_produto) * g.vl_fator_conversao, 2) as vl_preco_liq,	  
	Round((select coalesce(min(y.vl_preco_clube), 0)
			 from preco_venda_filial y
				inner join filial w
					on w.cd_filial = y.cd_filial
				inner join cidade c
					on c.cd_cidade = w.cd_cidade
				inner join unidade_federacao uf
					on uf.cd_unidade_federacao = c.cd_unidade_federacao
			 where uf.cd_unidade_federacao = d.cd_unidade_federacao
				  and y.cd_produto = d.cd_produto) * g.vl_fator_conversao, 2) as vl_preco_clube,
		uf.id_homologando_pedido,
		Coalesce(d.qt_estoque_disponivel, 0) as qt_estoque_disponivel,
		(case when Coalesce(d.qt_estoque_disponivel, 0) > 0 then 'S' else 'N' end) id_possui_saldo,
		(case when d.dh_atualizacao_estoque is null
				then d.dh_atualizacao_distribuidora
				else
					case when d.dh_atualizacao_estoque > d.dh_atualizacao_distribuidora
						then d.dh_atualizacao_estoque
						else d.dh_atualizacao_distribuidora
					end
				end
		 ) dh_arquivo_estoque,
		( select dph.vl_preco_compra 
			 from distribuidora_produto_hist dph
			where dph.dh_data_posicao = (select max(dph2.dh_data_posicao) 
												 from distribuidora_produto_hist dph2 
												where dph2.cd_distribuidora = d.cd_distribuidora 
												  and dph2.cd_produto = d.cd_produto 
												  and dph2.cd_unidade_federacao = d.cd_unidade_federacao  
												  and dph2.dh_data_posicao <= dateadd(day, :arg_nr_dias_variacao_preco * -1, getdate()))
			  and dph.cd_distribuidora = d.cd_distribuidora
			  and dph.cd_produto = d.cd_produto
			  and dph.cd_unidade_federacao = d.cd_unidade_federacao) as vl_preco_calculo_variacao,
		(select count(*)
			from pedido_filial_bloqueio x			
			where x.id_tipo_bloqueio = 'D'
			and x.cd_filial is null
			and x.cd_distribuidora = d.cd_distribuidora
			and (x.dh_pedido is null or x.dh_pedido = (select dh_movimentacao from parametro where id_parametro = '1'))
			and x.nr_dia_semana is null
			and x.cd_uf is null) as id_distribuidora_bloq,
		(select CHAR(13)||'UF: '||x.cd_uf||
				CHAR(13)||'Per$$HEX1$$ed00$$ENDHEX$$odo: '||CONVERT(VarChar, dh_inicio_bloqueio, 103)||' at$$HEX1$$e900$$ENDHEX$$ '|| CONVERT(VarChar, dh_termino_bloqueio, 103)||
				CHAR(13)||'Motivo: '||de_motivo_bloqueio
			from pedido_filial_bloqueio x			
			where x.id_tipo_bloqueio = 'D'
			and x.cd_filial is null
			and x.cd_distribuidora = d.cd_distribuidora
			and x.dh_pedido is null
			and x.nr_dia_semana is null
			and x.cd_uf = d.cd_unidade_federacao
			and x.dh_inicio_bloqueio <= (select dh_movimentacao from parametro where id_parametro = '1')
			and x.dh_termino_bloqueio >= (select dh_movimentacao from parametro where id_parametro = '1')
			having nr_bloqueio = max(nr_bloqueio)) as de_motivo_bloqueio_distr_uf,
		coalesce(d.pc_promocao_desconto_finan, 0) as pc_promocao_desconto_finan,
		coalesce(d.pc_desconto_acordo_sellin, 0) as pc_desconto_acordo_sellin,
		d.ncm_produto,
		d.cd_cest,
		d.cd_cst,
		d.vl_icms_st_retido,
		d.vl_bc_st_retido,
		d.pc_icms_st,	
		d.pc_mva,
		d.vl_pmc,
		d.nr_embalagem_distrib,
		0.00 as vl_pis_compra_calculo_bloq,
		0.00 as vl_cofins_compra_calculo_bloq,
		0.00 as vl_pis_venda_calculo_bloq,
		0.00 as vl_cofins_venda_calculo_bloq,
		coalesce(ti.pc_icms, 0) as pc_icms_venda,
		0.00 as vl_icms_venda_calculo_bloq,
		0.00 as vl_preco_compra_calculo_bloq,
		0.00 as vl_preco_venda_calculo_bloq,
		0.00 as pc_margem,
		substring(g.cd_subcategoria,1,1) as cd_grupo,
		g.id_lei_generico,
		IsNull(d.pc_desconto_novo, d.pc_desconto_atual) as pc_desconto_utilizado,
		Coalesce(c.id_retira_bloq_compra_distrib, 'N') As id_retira_bloq_compra_distrib,
		g.id_situacao_pis_cofins,
		vl_compra = dbo.f_calc_vl_custo_final(d.cd_distribuidora, d.cd_produto, d.cd_unidade_federacao, null),
		0.00 As vl_compra_plan,
		0.00 As vl_repasse_plan,
		'N' id_legenda,
		0.00 as vl_juros_compra,
		Case when u.id_pedido_exclusivo_falta = 'S' and uf1.id_pedido_exclusivo_falta = 'S'
				Then 'S'
				Else 'N'
		End as id_pedido_exclusivo_falta,
		Case   When (select dh_movimentacao from parametro where id_parametro = '1') between (c.dt_inicio_stb)  and  (c.dt_fim_stb)
        			Then 'S' 
        			Else 'N' 
    		End as id_compra_bloqueada,
		dt_inicio_stb,
		dt_fim_stb,
		id_stb,
		de_desc_stb
FROM distribuidora_produto d 
INNER JOIN fornecedor fd ON fd.cd_fornecedor = d.cd_distribuidora
INNER JOIN produto_geral g ON g.cd_produto = d.cd_produto
INNER JOIN fornecedor fu ON fu.cd_fornecedor = g.cd_fornecedor_usual
INNER JOIN vw_classificacao_produto v ON v.cd_subcategoria = g.cd_subcategoria
INNER JOIN produto_central c ON c.cd_produto = g.cd_produto
INNER JOIN conexao_distribuidora x ON x.cd_distribuidora = d.cd_distribuidora
INNER JOIN produto_uf u ON u.cd_unidade_federacao = d.cd_unidade_federacao AND u.cd_produto = d.cd_produto
LEFT OUTER JOIN unidade_federacao uf1 ON uf1.cd_unidade_federacao = u.cd_unidade_federacao AND uf1.id_pedido_exclusivo_falta = u.id_pedido_exclusivo_falta
INNER JOIN tipo_icms ti (index pk_tipo_icms) ON ti.cd_tipo_icms = u.cd_tipo_icms
INNER JOIN tributacao_icms t ON t.cd_tributacao_icms = u.cd_tributacao_icms
INNER JOIN distribuidora_uf uf ON uf.cd_distribuidora = d.cd_distribuidora AND uf.cd_unidade_federacao = d.cd_unidade_federacao
LEFT OUTER JOIN conexao z ON c.id_projeto_conexao = z.id_projeto_conexao
WHERE d.cd_distribuidora IN (SELECT f.cd_fornecedor
							FROM fornecedor f
								INNER JOIN distribuidora_forn_conexao dfc
									ON dfc.cd_distribuidora = f.cd_fornecedor
									AND dfc.cd_fornecedor = g.cd_fornecedor_usual
							WHERE f.id_distribuidora = 'S')
	AND g.cd_produto IN (SELECT c.cd_produto FROM produto_central c
						INNER JOIN conexao p ON p.id_projeto_conexao = c.id_projeto_conexao
						WHERE p.id_situacao IN ('A', 'P'))
	AND c.id_projeto_conexao = x.id_projeto_conexao
	AND x.id_situacao = 'A'" update="distribuidora_produto" updatewhere=0 updatekeyinplace=no arguments=(("arg_nr_dias_variacao_preco", number))  sort="id_situacao A vl_compra A nr_prioridade_distribuicao A " )
