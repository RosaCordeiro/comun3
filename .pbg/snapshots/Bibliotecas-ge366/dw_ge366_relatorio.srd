 column=(type=char(40) updatewhereclause=yes name=produto_geral_de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="g.de_apresentacao_venda" )
 column=(type=char(45) updatewhereclause=yes name=produto_abcfarma_de_produto dbname="produto_abcfarma.de_produto" dbalias="a.de_produto" )
 column=(type=char(45) updatewhereclause=yes name=produto_abcfarma_de_apresentacao dbname="produto_abcfarma.de_apresentacao" dbalias="a.de_apresentacao" )
 column=(type=long updatewhereclause=yes name=produto_geral_cd_produto dbname="produto_geral.cd_produto" dbalias="g.cd_produto" )
 column=(type=long updatewhereclause=yes name=produto_abcfarma_cd_produto_abcfarma dbname="produto_abcfarma.cd_produto_abcfarma" dbalias="a.cd_produto_abcfarma" )
 retrieve="SELECT	g.de_produto,   
			g.de_apresentacao_venda,   
			a.de_produto,   
			a.de_apresentacao,   
			g.cd_produto,   
			a.cd_produto_abcfarma  
 FROM produto_abcfarma a
	INNER JOIN codigo_barras_produto c
		ON c.de_codigo_barras = a.de_codigo_barras
	INNER JOIN produto_geral g
		ON g.cd_produto = c.cd_produto"  sort="produto_geral_de_produto A produto_geral_de_apresentacao_venda A " )
