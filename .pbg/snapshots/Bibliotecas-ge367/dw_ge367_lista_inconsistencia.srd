table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_central.cd_produto" dbalias="c.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_fabricante_17 dbname="produto_abcfarma.vl_preco_fabricante_17" dbalias="a.vl_preco_fabricante_17" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_17 dbname="produto_abcfarma.vl_preco_venda_17" dbalias="a.vl_preco_venda_17" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_fabricante_18 dbname="produto_abcfarma.vl_preco_fabricante_18" dbalias="a.vl_preco_fabricante_18" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_18 dbname="produto_abcfarma.vl_preco_venda_18" dbalias="a.vl_preco_venda_18" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_fabricante_12 dbname="produto_abcfarma.vl_preco_fabricante_12" dbalias="a.vl_preco_fabricante_12" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_12 dbname="produto_abcfarma.vl_preco_venda_12" dbalias="a.vl_preco_venda_12" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_fabricante_20 dbname="produto_abcfarma.vl_preco_fabricante_20" dbalias="a.vl_preco_fabricante_20" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_20 dbname="produto_abcfarma.vl_preco_venda_20" dbalias="a.vl_preco_venda_20" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_ipi dbname="produto_abcfarma.pc_ipi" dbalias="a.pc_ipi" )
 retrieve="select c.cd_produto,
       g.de_produto + ' : ' + g.de_apresentacao_estoque de_produto,
       a.vl_preco_fabricante vl_preco_fabricante_17,
       a.vl_preco_venda_maximo vl_preco_venda_17,
       a.vl_preco_fabricante_18,
       a.vl_preco_venda_18,
       a.vl_preco_fabricante_12,
       a.vl_preco_venda_12,
       a.vl_preco_fabricante_20,
       a.vl_preco_venda_20,
       a.pc_ipi 
from produto_abcfarma a,
	  produto_central c,   
     produto_geral g,        
     parametro p,
	codigo_barras_produto l
where a.dh_atualizacao >= p.dh_leitura_abcfarma
---  and c.cd_produto_abcfarma = a.cd_produto_abcfarma
and  l.de_codigo_barras = a.de_codigo_barras
and g.cd_produto = c.cd_produto
and coalesce(g.id_caderno_abcfarma, 'N') = 'S'
  and (isnull(a.vl_preco_fabricante, 0) = 0 or
 	    isnull(a.vl_preco_fabricante_18, 0) = 0 or
 	    isnull(a.vl_preco_fabricante_12, 0) = 0 or
 	    isnull(a.vl_preco_fabricante_20, 0) = 0 or
       (isnull(a.vl_preco_venda_maximo, 0) = 0 and (isnull(a.vl_preco_fabricante, 0) = 0 or isnull(a.pc_ipi, 0) = 0)) or
       (isnull(a.vl_preco_venda_12, 0) = 0 and (isnull(a.vl_preco_fabricante_12, 0) = 0 or isnull(a.pc_ipi, 0) = 0)) or
       (isnull(a.vl_preco_venda_20, 0) = 0 and (isnull(a.vl_preco_fabricante_20, 0) = 0 or isnull(a.pc_ipi, 0) = 0)) or
       (isnull(a.vl_preco_venda_18, 0) = 0 and (isnull(a.vl_preco_fabricante_18, 0) = 0 or isnull(a.pc_ipi, 0) = 0)))
"  sort="de_produto A " )
