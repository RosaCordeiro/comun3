table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_central.cd_produto" dbalias="c.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="tipo_icms.pc_icms" dbalias="t.pc_icms" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="produto_uf.cd_unidade_federacao" dbalias="u.cd_unidade_federacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_atual dbname="produto_uf.vl_preco_atual" dbalias="u.vl_preco_atual" )
 column=(type=decimal(19) updatewhereclause=yes name=vl_preco_novo dbname="vl_preco_novo" )
 column=(type=datetime updatewhereclause=yes name=dh_vigencia dbname="produto_abcfarma.dh_vigencia" dbalias="a.dh_vigencia" )
 column=(type=char(40) updatewhereclause=yes name=de_promocao dbname="de_promocao" )
 column=(type=date updatewhereclause=yes name=dh_termino_promocao dbname="dh_termino_promocao" )
 column=(type=char(2) updatewhereclause=yes name=id_preco_fabrica_venda dbname="id_preco_fabrica_venda" )
 retrieve="select c.cd_produto,
       g.de_produto + ' : ' + g.de_apresentacao_estoque de_produto,
	   t.pc_icms,
       u.cd_unidade_federacao,
       u.vl_preco_venda_atual vl_preco_atual,
		(CASE t.pc_icms
      	WHEN 12 THEN (	case isnull(a.vl_preco_venda_12, 0)
								when 0 then round(convert(decimal(9,2), a.vl_preco_fabricante_12 / c.vl_fator_conversao_abcfarma) * (1 + (a.pc_ipi / 100)) * 1.4285, 2)  
								else convert(decimal(9,2), a.vl_preco_venda_12 / c.vl_fator_conversao_abcfarma)
								end)
	  	WHEN 17 THEN (	case isnull(a.vl_preco_venda_maximo, 0)
								when 0 then round(convert(decimal(9,2), a.vl_preco_fabricante / c.vl_fator_conversao_abcfarma) * (1 + (a.pc_ipi / 100)) * 1.4285, 2)  
								else convert(decimal(9,2), a.vl_preco_venda_maximo / c.vl_fator_conversao_abcfarma)
								end)
	  	WHEN 18 THEN (	case isnull(a.vl_preco_venda_18, 0)
								when 0 then round(convert(decimal(9,2), a.vl_preco_fabricante_18 / c.vl_fator_conversao_abcfarma) * (1 + (a.pc_ipi / 100)) * 1.4285, 2)  
								else convert(decimal(9,2), a.vl_preco_venda_18 / c.vl_fator_conversao_abcfarma)
								end)
	  	WHEN 20 THEN (	case isnull(a.vl_preco_venda_20, 0)
								when 0 then round(convert(decimal(9,2), a.vl_preco_fabricante_20 / c.vl_fator_conversao_abcfarma) * (1 + (a.pc_ipi / 100)) * 1.4285, 2)  
								else convert(decimal(9,2), a.vl_preco_venda_20 / c.vl_fator_conversao_abcfarma)
								end)
	  	END) as vl_preco_novo,
       a.dh_vigencia,
		space(40) de_promocao,
		cast(null as date) as dh_termino_promocao,
		'PV' as id_preco_fabrica_venda
from produto_abcfarma a
inner join codigo_barras_produto  l on l.de_codigo_barras = a.de_codigo_barras
inner join produto_geral g on g.cd_produto = l.cd_produto
inner join produto_central c on c.cd_produto = g.cd_produto
inner join produto_uf u on u.cd_produto = c.cd_produto
inner join tipo_icms t on t.cd_tipo_icms = u.cd_tipo_icms
where a.dh_atualizacao >= (select p.dh_leitura_abcfarma from  parametro p where p.id_parametro = '1')
and u.cd_unidade_federacao in ('SP')
and coalesce(g.id_caderno_abcfarma, 'N') = 'S'
  and ((CASE t.pc_icms 
		  	WHEN 12 THEN a.vl_preco_venda_12
			WHEN 17 THEN a.vl_preco_venda_maximo 
			WHEN 18 THEN a.vl_preco_venda_18
			WHEN 20 THEN a.vl_preco_venda_20
		  END) > 0 or (  (CASE t.pc_icms 
								WHEN 12 THEN a.vl_preco_fabricante_12 
								WHEN 17 THEN a.vl_preco_fabricante 
								WHEN 18 THEN a.vl_preco_fabricante_18
								WHEN 20 THEN a.vl_preco_fabricante_20  
							 END)  > 0 and a.pc_ipi > 0))
and u.vl_preco_venda_atual <> ((CASE t.pc_icms
												WHEN 12 THEN (	case isnull(a.vl_preco_venda_12, 0)
																	when 0 then round(convert(decimal(9,2), a.vl_preco_fabricante_12 / c.vl_fator_conversao_abcfarma) * (1 + (a.pc_ipi / 100)) * 1.4285, 2)  
																	else convert(decimal(9,2), a.vl_preco_venda_12 / c.vl_fator_conversao_abcfarma)
																	end)
												WHEN 17 THEN (	case isnull(a.vl_preco_venda_maximo, 0)
																		when 0 then round(convert(decimal(9,2), a.vl_preco_fabricante / c.vl_fator_conversao_abcfarma) * (1 + (a.pc_ipi / 100)) * 1.4285, 2)  
																		else convert(decimal(9,2), a.vl_preco_venda_maximo / c.vl_fator_conversao_abcfarma)
																		end)
												WHEN 18 THEN (	case isnull(a.vl_preco_venda_18, 0)
																		when 0 then round(convert(decimal(9,2), a.vl_preco_fabricante_18 / c.vl_fator_conversao_abcfarma) * (1 + (a.pc_ipi / 100)) * 1.4285, 2)  
																		else convert(decimal(9,2), a.vl_preco_venda_18 / c.vl_fator_conversao_abcfarma)
																		end)
												WHEN 20 THEN (	case isnull(a.vl_preco_venda_20, 0)
																		when 0 then round(convert(decimal(9,2), a.vl_preco_fabricante_20 / c.vl_fator_conversao_abcfarma) * (1 + (a.pc_ipi / 100)) * 1.4285, 2)  
																		else convert(decimal(9,2), a.vl_preco_venda_20 / c.vl_fator_conversao_abcfarma)
																		end)
											END))

"  sort="de_produto A " )
