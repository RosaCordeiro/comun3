table(column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_abcfarma.de_codigo_barras" dbalias="a.de_codigo_barras" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=long updatewhereclause=yes name=cd_produto_abcfarma dbname="produto_abcfarma.cd_produto_abcfarma" dbalias="a.cd_produto_abcfarma" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao dbname="produto_abcfarma.dh_atualizacao" dbalias="a.dh_atualizacao" )
 column=(type=char(1) updatewhereclause=yes name=id_principal dbname="id_principal" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="c.vl_fator_conversao" )
 column=(type=char(1) updatewhereclause=yes name=produto_abcfarma_id_controle_preco dbname="produto_abcfarma.id_controle_preco" dbalias="a.id_controle_preco" )
 column=(type=char(30) updatewhereclause=yes name=nm_fabricante dbname="produto_abcfarma.nm_fabricante" dbalias="a.nm_fabricante" )
 column=(type=char(45) updatewhereclause=yes name=de_produto dbname="produto_abcfarma.de_produto" dbalias="a.de_produto" )
 column=(type=char(45) updatewhereclause=yes name=de_apresentacao dbname="produto_abcfarma.de_apresentacao" dbalias="a.de_apresentacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_fabricante dbname="produto_abcfarma.vl_preco_fabricante" dbalias="a.vl_preco_fabricante" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_maximo dbname="produto_abcfarma.vl_preco_venda_maximo" dbalias="a.vl_preco_venda_maximo" )
 column=(type=datetime updatewhereclause=yes name=dh_vigencia dbname="produto_abcfarma.dh_vigencia" dbalias="a.dh_vigencia" )
 column=(type=char(1) updatewhereclause=yes name=id_produto_novo dbname="produto_abcfarma.id_produto_novo" dbalias="a.id_produto_novo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_fabricante_18 dbname="vl_preco_fabricante_18" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_18 dbname="vl_preco_venda_18" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_fabricante_12 dbname="vl_preco_fabricante_12" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_12 dbname="vl_preco_venda_12" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_fabricante_19 dbname="vl_preco_fabricante_19" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_19 dbname="vl_preco_venda_19" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_fabricante_20 dbname="vl_preco_fabricante_20" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_20 dbname="vl_preco_venda_20" )
 column=(type=char(13) updatewhereclause=yes name=de_registro_ms dbname="produto_abcfarma.de_registro_ms" dbalias="a.de_registro_ms" )
 column=(type=long updatewhereclause=yes name=nr_ncm dbname="produto_abcfarma.nr_ncm" dbalias="a.nr_ncm" )
 retrieve="select coalesce(c.cd_produto,0) as cd_produto ,
       a.de_codigo_barras, 
       coalesce(c.id_situacao,'') as id_situacao, 
       a.cd_produto_abcfarma, 
       a.dh_atualizacao, 
       coalesce(b.id_principal,'') as id_principal,
       c.vl_fator_conversao, 
       a.id_controle_preco, 
       a.nm_fabricante, 
       a.de_produto, 
       a.de_apresentacao,
       a.vl_preco_fabricante,
       a.vl_preco_venda_maximo,
       a.dh_vigencia, 
       a.id_produto_novo,
       coalesce(a.vl_preco_fabricante_18,0) as vl_preco_fabricante_18,
       coalesce(a.vl_preco_venda_18,0) as  vl_preco_venda_18,
       coalesce(a.vl_preco_fabricante_12,0) as vl_preco_fabricante_12,
       coalesce(a.vl_preco_venda_12,0) as vl_preco_venda_12,
       coalesce(a.vl_preco_fabricante_19,0) as vl_preco_fabricante_19,
       coalesce(a.vl_preco_venda_19,0) as vl_preco_venda_19,
       coalesce(a.vl_preco_fabricante_20,0) as vl_preco_fabricante_20,
       coalesce(a.vl_preco_venda_20,0) as vl_preco_venda_20,
       a.de_registro_ms,
       a.nr_ncm
from   produto_abcfarma a
left  join codigo_barras_produto b on a.de_codigo_barras = b.de_codigo_barras
left   join produto_geral c on c.cd_produto = b.cd_produto
where  a.dh_atualizacao>=:ldh_data




" arguments=(("ldh_data", date))  sort="cd_produto A de_codigo_barras A dh_vigencia A " )
