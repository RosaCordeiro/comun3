table(column=(type=char(2) update=yes updatewhereclause=yes key=yes name=cd_unidade_federacao dbname="produto_uf.cd_unidade_federacao" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="produto_uf.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_venda_futuro dbname="produto_uf.vl_preco_venda_futuro" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_preco_venda_futuro dbname="produto_uf.dh_preco_venda_futuro" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matric_preco_venda_futuro dbname="produto_uf.nr_matric_preco_venda_futuro" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_reposicao dbname="produto_uf.vl_preco_reposicao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_preco_reposicao dbname="produto_uf.dh_preco_reposicao" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_preco_reposicao dbname="produto_uf.nr_matricula_preco_reposicao" )
 column=(type=char(1) updatewhereclause=yes name=id_bloqueado_promocao dbname="id_bloqueado_promocao" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_bloqueado_promocao_ant dbname="id_bloqueado_promocao_ant" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_reposicao_a dbname="produto_uf.vl_preco_reposicao_a" )
 column=(type=datetime updatewhereclause=yes name=dh_preco_reposicao_a dbname="produto_uf.dh_preco_reposicao_a" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_atual dbname="produto_uf.vl_preco_venda_atual" )
 column=(type=datetime updatewhereclause=yes name=dh_preco_venda_atual dbname="produto_uf.dh_preco_venda_atual" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_futuro_a dbname="produto_uf.vl_preco_venda_futuro_a" )
 column=(type=datetime updatewhereclause=yes name=dh_preco_venda_futuro_a dbname="produto_uf.dh_preco_venda_futuro_a" )
 column=(type=char(8) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 retrieve="select u.cd_unidade_federacao,
       u.cd_produto,
       g.de_produto + ' : ' + g.de_apresentacao_estoque de_produto,     
       u.vl_preco_venda_futuro,       
       u.dh_preco_venda_futuro,         
       u.nr_matric_preco_venda_futuro,    
       u.vl_preco_reposicao,
       u.dh_preco_reposicao,         
       u.nr_matricula_preco_reposicao,
		 'N' id_bloqueado_promocao,
		 'N' id_bloqueado_promocao_ant,
       u.vl_preco_reposicao vl_preco_reposicao_a,
		 u.dh_preco_reposicao dh_preco_reposicao_a,
       u.vl_preco_venda_atual,
       u.dh_preco_venda_atual,
       u.vl_preco_venda_futuro vl_preco_venda_futuro_a,
       u.dh_preco_venda_futuro dh_preco_venda_futuro_a,
		(CASE g.id_situacao
			WHEN  'A' THEN 'ATIVO'
			WHEN 'I' THEN 'INATIVO'
			WHEN 'P' THEN 'PENDENTE'
			ELSE g.id_situacao
		END) id_situacao
from produto_geral g
inner join produto_central c 
	on c.cd_produto = g.cd_produto
inner join produto_uf u
	on u.cd_produto = g.cd_produto
where u.cd_unidade_federacao = :uf
	and g.id_situacao = 'A'

union

select u.cd_unidade_federacao,
       u.cd_produto,
       g.de_produto + ' : ' + g.de_apresentacao_estoque de_produto,     
       u.vl_preco_venda_futuro,       
       u.dh_preco_venda_futuro,         
       u.nr_matric_preco_venda_futuro,    
       u.vl_preco_reposicao,
       u.dh_preco_reposicao,         
       u.nr_matricula_preco_reposicao,
		 'N' id_bloqueado_promocao,
		 'N' id_bloqueado_promocao_ant,
       u.vl_preco_reposicao vl_preco_reposicao_a,
		 u.dh_preco_reposicao dh_preco_reposicao_a,
       u.vl_preco_venda_atual,
       u.dh_preco_venda_atual,
       u.vl_preco_venda_futuro vl_preco_venda_futuro_a,
       u.dh_preco_venda_futuro dh_preco_venda_futuro_a,
		(CASE g.id_situacao
			WHEN  'A' THEN 'ATIVO'
			WHEN 'I' THEN 'INATIVO'
			WHEN 'P' THEN 'PENDENTE'
			ELSE g.id_situacao
		END) id_situacao
from produto_geral g
inner join produto_central c 
	on c.cd_produto = g.cd_produto
inner join produto_uf u
	on u.cd_produto = g.cd_produto
where u.cd_unidade_federacao = :uf
	and g.id_situacao <> 'A'
	and exists (select * from resumo_produto r
				  where r.id_rede = 'CIA'
					 and r.cd_produto = g.cd_produto
					 and r.dh_resumo = :data_resumo
					 and r.qt_saldo > 0)
" update="produto_uf" updatewhere=0 updatekeyinplace=no arguments=(("uf", string),("data_resumo", date))  sort="de_produto A " )
