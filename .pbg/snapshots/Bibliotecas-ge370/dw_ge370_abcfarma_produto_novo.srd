table(column=(type=long updatewhereclause=yes name=cd_produto_abcfarma dbname="produto_abcfarma.cd_produto_abcfarma" dbalias="abc.cd_produto_abcfarma" )
 column=(type=char(45) updatewhereclause=yes name=de_produto dbname="produto_abcfarma.de_produto" dbalias="abc.de_produto" )
 column=(type=char(45) updatewhereclause=yes name=de_apresentacao dbname="produto_abcfarma.de_apresentacao" dbalias="abc.de_apresentacao" )
 column=(type=datetime updatewhereclause=yes name=dh_vigencia dbname="produto_abcfarma.dh_vigencia" dbalias="abc.dh_vigencia" )
 column=(type=char(30) updatewhereclause=yes name=nm_fabricante dbname="produto_abcfarma.nm_fabricante" dbalias="abc.nm_fabricante" )
 retrieve="Select	abc.cd_produto_abcfarma,
	 	abc.de_produto,
	  	abc.de_apresentacao,
	  	abc.dh_vigencia,
	  	abc.nm_fabricante
From produto_abcfarma As abc
       Inner Join parametro As par
		On par.id_parametro = '1'
Where abc.dh_atualizacao >= par.dh_leitura_abcfarma
	And abc.id_produto_novo = 'S'
	And 0 = ( Select count(*)
				 From codigo_barras_produto c
				 Where c.de_codigo_barras = abc.de_codigo_barras )"  sort="descricao_apresentacao A " )
