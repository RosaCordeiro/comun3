table(column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_abcfarma.de_codigo_barras" )
 column=(type=long updatewhereclause=yes name=cd_produto_abcfarma dbname="produto_central.cd_produto_abcfarma" )
 column=(type=char(45) updatewhereclause=yes name=de_produto dbname="produto_abcfarma.de_produto" )
 column=(type=char(45) updatewhereclause=yes name=de_apresentacao dbname="produto_abcfarma.de_apresentacao" )
 column=(type=datetime updatewhereclause=yes name=dh_vigencia dbname="produto_abcfarma.dh_vigencia" )
 column=(type=char(30) updatewhereclause=yes name=nm_fabricante dbname="produto_abcfarma.nm_fabricante" )
 retrieve="select	abc.de_codigo_barras,	
		pc.cd_produto_abcfarma,
       	abc.de_produto,
       	abc.de_apresentacao,
		abc.dh_vigencia,
		abc.nm_fabricante
from produto_central pc
	inner join produto_geral pg
		on pg.cd_produto = pc.cd_produto
	inner join ( select a.cd_produto, b.de_codigo_barras, 
                        case pab.id_controle_preco  
                                when 'M' then 'MONITORADO'
                                when 'X' then 'LIBER. PR$$HEX1$$c700$$ENDHEX$$O F$$HEX1$$c100$$ENDHEX$$BRICA'
                                when 'L' then 'LIBERADO'
                                when 'H' then 'HOSPITALAR' else pab.id_controle_preco end as Liberado, pab.nm_fabricante, pab.cd_produto_abcfarma, pab.id_controle_preco
                  from produto_geral a
                  inner   join codigo_barras_produto b on a.cd_produto   = b.cd_produto 
                  inner   join produto_abcfarma pab  on pab.de_codigo_barras = b.de_codigo_barras ) 
        j  on pg.cd_produto = j.cd_produto
	inner join produto_abcfarma abc
		on abc.de_codigo_barras = j.de_codigo_barras
where pc.cd_produto = j.cd_produto
  and pg.id_caderno_abcfarma = 'S'
  and 0 = ( Select count(*) 
               from parametro par,
                    produto_abcfarma abc
					Where abc.de_codigo_barras = j.de_codigo_barras
                 			and abc.dh_atualizacao >= par.dh_leitura_abcfarma )"  sort="descricao_apresentacao A " )
