table(column=(type=long updatewhereclause=yes key=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto_fornecedor dbname="produto_central.pc_desconto_fornecedor" )
 retrieve="SELECT pg.cd_produto,   
        		 pg.de_produto,   
       		 pg.de_apresentacao_estoque,   
       		 pc.pc_desconto_fornecedor 
FROM produto_geral pg,   
         produto_central pc  
   WHERE  pc.cd_produto = pg.cd_produto
    and pg.cd_fornecedor_usual = :cd_fornecedor
	and pg.id_situacao = 'A'" update="produto_central" updatewhere=0 updatekeyinplace=no arguments=(("cd_fornecedor", string))  sort="de_produto A de_apresentacao_estoque A " )
