table(column=(type=long update=yes updatewhereclause=yes key=yes identity=yes name=cd_promocao dbname="promocao_vencimento.cd_promocao" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_promocao dbname="promocao_vencimento.nm_promocao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inicio dbname="promocao_vencimento.dh_inicio" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_termino dbname="promocao_vencimento.dh_termino" )
 column=(type=char(1) update=yes updatewhereclause=yes name=cd_grupo dbname="promocao_vencimento.cd_grupo" )
 column=(type=char(3) update=yes updatewhereclause=yes name=cd_subgrupo dbname="promocao_vencimento.cd_subgrupo" )
 column=(type=char(6) update=yes updatewhereclause=yes name=cd_categoria dbname="promocao_vencimento.cd_categoria" )
 column=(type=char(9) update=yes updatewhereclause=yes name=cd_subcategoria dbname="promocao_vencimento.cd_subcategoria" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto dbname="promocao_vencimento.pc_desconto" )
 column=(type=char(40) updatewhereclause=yes name=de_categoria dbname="categoria.de_categoria" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo dbname="subgrupo.de_subgrupo" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="subcategoria.de_subcategoria" )
 column=(type=long update=yes updatewhereclause=yes name=nr_dias_vigencia_promocao dbname="promocao_vencimento.nr_dias_vigencia_promocao" initial="0" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="promocao_vencimento.cd_produto" )
 column=(type=char(101) updatewhereclause=yes name=de_produto dbname="de_produto" )
 retrieve="  SELECT pv.cd_promocao,   
         pv.nm_promocao,   
         pv.dh_inicio,   
         pv.dh_termino,   
         pv.cd_grupo,   
         pv.cd_subgrupo,   
         pv.cd_categoria,   
         pv.cd_subcategoria,  
         pv.pc_desconto,
         c.de_categoria,       
         sg.de_subgrupo,
         sc.de_subcategoria,
         pv.nr_dias_vigencia_promocao,
         pv.cd_produto,
		CASE
			WHEN pg.de_produto IS NULL THEN NULL
			ELSE pg.de_produto + ':' + pg.de_apresentacao_estoque
		END AS de_produto
    FROM promocao_vencimento pv
	LEFT OUTER JOIN subgrupo sg
			  ON sg.cd_subgrupo     = pv.cd_subgrupo
	LEFT OUTER JOIN categoria c
			  ON c.cd_categoria     = pv.cd_categoria
	LEFT OUTER JOIN subcategoria sc
			  ON sc.cd_subcategoria = pv.cd_subcategoria
	LEFT OUTER JOIN produto_geral pg
			  ON pg.cd_produto      = pv.cd_produto
" update="promocao_vencimento" updatewhere=1 updatekeyinplace=no  sort="cd_promocao A " )
