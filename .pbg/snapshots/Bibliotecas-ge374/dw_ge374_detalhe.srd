table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="g.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_clube dbname="pc_desconto_clube" )
 retrieve="select  g.cd_produto, 
		 g.de_produto + ' : ' + g.de_apresentacao_estoque as de_produto, 
		 case when a.id_tipo_promocao='Q' then isnull(c.pc_desconto,0) 
                 else  isnull(b.pc_desconto,0) end as pc_desconto, 
		case when a.id_tipo_promocao = 'Q' then isnull(c1.pc_desconto,0) 
                else isnull(b.pc_desconto_clube,0) end pc_desconto_clube
	from promocao_sos a
    inner join promocao_sos_produto b on a.cd_promocao_sos = b.cd_promocao_sos
	inner join produto_geral g   	on g.cd_produto = b.cd_produto
    left  join desconto_progressivo_qtd c on c.cd_desconto = b.cd_desc_progressivo
    left  join desconto_progressivo_qtd c1 on c1.cd_desconto = b.cd_desc_progressivo_clube
	where a.cd_promocao_sos = :promocao" arguments=(("promocao", number))  sort="de_produto A " )
