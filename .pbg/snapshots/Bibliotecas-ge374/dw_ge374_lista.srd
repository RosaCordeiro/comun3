table(column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="promocao_sos.cd_promocao_sos" )
 column=(type=char(40) updatewhereclause=yes name=nm_promocao_sos dbname="promocao_sos.nm_promocao_sos" )
 column=(type=char(20) updatewhereclause=yes name=de_tipo_promocao dbname="tipo_promocao.de_tipo_promocao" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="promocao_sos.dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="promocao_sos.dh_termino" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_promocao dbname="tipo_promocao.id_tipo_promocao" )
 column=(type=char(10) updatewhereclause=yes name=cd_promocao_sap dbname="promocao_sos.cd_promocao_sap" )
 retrieve="select p.cd_promocao_sos, p.nm_promocao_sos, t.de_tipo_promocao, p.dh_inicio, p.dh_termino , t.id_tipo_promocao, p.cd_promocao_sap
from promocao_sos p
	 inner join promocao_sos_filial f
		on f.cd_promocao_sos = p.cd_promocao_sos
	 inner join tipo_promocao t
		on t.id_tipo_promocao = p.id_tipo_promocao
	 inner join parametro x
		on x.id_parametro = '1'
where f.cd_filial = :filial" arguments=(("filial", number))  sort="nm_promocao_sos A " )
