table(column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="promocao_sos.cd_promocao_sos" dbalias="p.cd_promocao_sos" )
 column=(type=char(40) updatewhereclause=yes name=nm_promocao_sos dbname="promocao_sos.nm_promocao_sos" dbalias="p.nm_promocao_sos" )
 column=(type=char(20) updatewhereclause=yes name=de_tipo_promocao dbname="tipo_promocao.de_tipo_promocao" dbalias="t.de_tipo_promocao" )
 column=(type=char(10) updatewhereclause=yes name=cd_promocao_sap dbname="promocao_sos.cd_promocao_sap" dbalias="p.cd_promocao_sap" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="promocao_sos.dh_inicio" dbalias="p.dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="promocao_sos.dh_termino" dbalias="p.dh_termino" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="promocao_sos_produto.cd_produto" dbalias="pp.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_clube dbname="pc_desconto_clube" )
 retrieve="Select	p.cd_promocao_sos,
		p.nm_promocao_sos,
		t.de_tipo_promocao,
		p.cd_promocao_sap,
		p.dh_inicio,
		p.dh_termino,
		pp.cd_produto,
		g.de_produto || ' : ' || g.de_apresentacao_venda As de_produto,		
    case when p.id_tipo_promocao='Q' then isnull(c.pc_desconto,0) 
                else  isnull(pp.pc_desconto,0) end as pc_desconto, 
		case when p.id_tipo_promocao = 'Q' then isnull(c1.pc_desconto,0) 
                else isnull(pp.pc_desconto_clube,0) end pc_desconto_clube 
From promocao_sos As p
	Inner Join promocao_sos_filial As pf
		On pf.cd_promocao_sos = p.cd_promocao_sos	
	Inner Join tipo_promocao As t
		On t.id_tipo_promocao = p.id_tipo_promocao
	Inner Join promocao_sos_produto As pp
		On pp.cd_promocao_sos = p.cd_promocao_sos
	Inner Join produto_geral As g
		On g.cd_produto = pp.cd_produto
	Inner Join parametro As x
		On x.id_parametro = '1'
    left  join desconto_progressivo_qtd c on c.cd_desconto = pp.cd_desc_progressivo
    left  join desconto_progressivo_qtd c1 on c1.cd_desconto = pp.cd_desc_progressivo_clube
Where pf.cd_filial =:filial" arguments=(("filial", number))  sort="nm_promocao_sos A de_produto A " )
