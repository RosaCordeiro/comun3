 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="alteracao_preco_venda_prd_uf.cd_unidade_federacao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_reducao_base_icms dbname="alteracao_preco_venda_prd.pc_reducao_base_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms dbname="alteracao_preco_venda_prd.vl_bc_icms" )
