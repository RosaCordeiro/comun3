 column=(type=decimal(2) updatewhereclause=yes name=pc_margem_resultado_u_original dbname="alteracao_preco_venda_prd_uf.pc_margem_resultado_u_original" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_u dbname="alteracao_preco_venda_prd_uf.vl_venda_u" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_u_original dbname="alteracao_preco_venda_prd_uf.vl_venda_u_original" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_atual dbname="alteracao_preco_venda_prd_uf.vl_venda_atual" )
 column=(type=char(1) updatewhereclause=yes name=id_preco_bloqueado dbname="id_preco_bloqueado" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_atualizar dbname="id_atualizar" values="	S/	N" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_futuro dbname="produto_uf.vl_preco_venda_futuro" )
 column=(type=datetime updatewhereclause=yes name=dh_preco_venda_futuro dbname="produto_uf.dh_preco_venda_futuro" )
 column=(type=char(49) updatewhereclause=yes name=nm_usuario dbname="nm_usuario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda_sugerido_forn dbname="vl_venda_sugerido_forn" )
 column=(type=char(1) updatewhereclause=yes name=id_utilizado_preco_sug_forn dbname="id_utilizado_preco_sug_forn" initial="N" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_utilizado_preco_sug_forn_or dbname="id_utilizado_preco_sug_forn_or" )
 column=(type=long updatewhereclause=yes name=qt_comissao dbname="qt_comissao" )
 retrieve="select p.nr_alteracao, 
		p.cd_produto,
		g.de_produto + ~" : ~" + g.de_apresentacao_venda as de_produto_clamed,
	 	p.de_produto,   
		p.nr_classificacao_fiscal,   
		p.vl_preco_fabrica,   
		p.pc_desconto,   
		p.pc_mva,   
		p.pc_icms,   
		p.vl_bc_icms_st,   
		p.pc_icms_st,   
		p.vl_icms_st,   
		p.vl_bc_ipi,   
		p.pc_ipi,   
		p.vl_ipi,   
		p.pc_pis_cofins,   
		p.vl_custo_compra,   
		u.cd_unidade_federacao,
		p.pc_reducao_base_icms,
		p.vl_bc_icms,
		p.vl_icms,
		p.pc_repasse_icms,
		u.vl_custo_transferencia vl_custo_transferencia_u,   
         u.vl_bc_icms vl_bc_icms_u,   
         u.pc_reducao_base_icms pc_reducao_base_icms_u,   
         u.pc_icms pc_icms_u,   
         u.vl_icms vl_icms_u,   
         u.pc_mva pc_mva_u,   
         u.vl_bc_icms_st vl_bc_icms_st_u,   
         u.pc_reducao_base_st pc_reducao_base_st_u,   
         u.pc_icms_st pc_icms_st_u,   
         u.vl_icms_st vl_icms_st_u,   
         u.pc_margem_resultado pc_margem_resultado_u,   
		u.pc_margem_resultado pc_margem_resultado_u_original,   
         u.vl_venda vl_venda_u,
		u.vl_venda vl_venda_u_original,
		u.vl_venda_atual,
		'N' id_preco_bloqueado,
		'N' id_atualizar,
		pu.vl_preco_venda_futuro,
		pu.dh_preco_venda_futuro,
		us.nm_usuario + ' (' + us.nr_matricula + ')' nm_usuario,
		coalesce(p.vl_venda_sugerido_forn, 0) vl_venda_sugerido_forn,
		coalesce(id_utilizado_preco_sug_forn, 'N') id_utilizado_preco_sug_forn,
		coalesce(id_utilizado_preco_sug_forn, 'N') id_utilizado_preco_sug_forn_or,
		(select count(*) from tipo_comissao_produto t  where t.cd_produto = g.cd_produto) qt_comissao
from alteracao_preco_venda_prd p	
inner join alteracao_preco_venda_prd_uf u on u.nr_alteracao = p.nr_alteracao and u.cd_produto = p.cd_produto
inner join produto_geral g on g.cd_produto = p.cd_produto
inner join produto_uf pu on pu.cd_unidade_federacao =  u.cd_unidade_federacao and pu.cd_produto = u.cd_produto
left outer join usuario us on us.nr_matricula = pu.nr_matric_preco_venda_futuro 
where p.nr_alteracao					= :codigo
	and u.cd_unidade_federacao 	= :uf
" arguments=(("codigo", number),("uf", string))  sort="de_produto_clamed A " )
