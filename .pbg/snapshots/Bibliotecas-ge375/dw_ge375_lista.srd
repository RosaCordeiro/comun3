 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_transferencia_u dbname="alteracao_preco_venda_prd_uf.vl_custo_transferencia_u" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_u dbname="alteracao_preco_venda_prd_uf.vl_bc_icms_u" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_reducao_base_icms_u dbname="alteracao_preco_venda_prd_uf.pc_reducao_base_icms_u" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_u dbname="alteracao_preco_venda_prd_uf.pc_icms_u" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_u dbname="alteracao_preco_venda_prd_uf.vl_icms_u" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_mva_u dbname="alteracao_preco_venda_prd_uf.pc_mva_u" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_st_u dbname="alteracao_preco_venda_prd_uf.vl_bc_icms_st_u" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_reducao_base_st_u dbname="alteracao_preco_venda_prd_uf.pc_reducao_base_st_u" )
