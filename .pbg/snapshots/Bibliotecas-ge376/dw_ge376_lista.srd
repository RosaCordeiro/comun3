table(column=(type=long updatewhereclause=yes name=nr_alteracao dbname="alteracao_preco_venda.nr_alteracao" )
 column=(type=char(40) updatewhereclause=yes name=de_alteracao dbname="alteracao_preco_venda.de_alteracao" )
 column=(type=char(47) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="alteracao_preco_venda.dh_inclusao" )
 retrieve="SELECT a.nr_alteracao,   
        	a.de_alteracao,   
		substring(cd_fornecedor, 6,4) + ' - ' + f.nm_fantasia nm_fantasia,
        	a.dh_inclusao
FROM alteracao_preco_venda   a
inner join fornecedor f on f.cd_fornecedor = a.cd_fornecedor_faturamento

"  sort="nr_alteracao D " )
