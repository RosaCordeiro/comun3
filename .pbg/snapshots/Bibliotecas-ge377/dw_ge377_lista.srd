table(column=(type=char(2) updatewhereclause=yes name=cd_uf dbname="vw_filial.cd_uf" )
 column=(type=char(40) updatewhereclause=yes name=nm_unidade_federacao dbname="unidade_federacao.nm_unidade_federacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_novo dbname="produto_uf.vl_preco_novo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_atual dbname="produto_uf.vl_preco_atual" )
 column=(type=char(1) updatewhereclause=yes name=id_bloqueado_cadastro dbname="produto_geral.id_bloqueado_cadastro" )
 column=(type=char(1) updatewhereclause=yes name=id_bloqueado_promocao dbname="id_bloqueado_promocao" )
 column=(type=char(1) updatewhereclause=yes name=id_bloqueio dbname="id_bloqueio" values="	S/	N" )
 retrieve="Select	Distinct f.cd_uf,
			u.nm_unidade_federacao,
			p.vl_preco_venda_atual As vl_preco_novo,
			p.vl_preco_venda_atual As vl_preco_atual,
			g.id_preco_bloqueado As id_bloqueado_cadastro,
			'N' id_bloqueado_promocao,
			'N' id_bloqueio
From produto_uf As p
	Inner Join unidade_federacao As u
		On u.cd_unidade_federacao = p.cd_unidade_federacao
	Inner Join vw_filial As f
		On f.cd_uf = u.cd_unidade_federacao
	Inner Join produto_geral As g
		On g.cd_produto = p.cd_produto
Where p.cd_produto = :cd_produto
Order By u.nm_unidade_federacao" arguments=(("cd_produto", number)) )
