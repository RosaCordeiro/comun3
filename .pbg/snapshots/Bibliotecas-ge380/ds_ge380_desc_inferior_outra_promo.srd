table(column=(type=long updatewhereclause=yes name=cd_produto dbname="promocao_sos_produto.cd_produto" dbalias="p.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_atual dbname="promocao_sos_produto.pc_desconto_atual" dbalias="p.pc_desconto_atual" )
 column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="promocao_sos.cd_promocao_sos" dbalias="s.cd_promocao_sos" )
 column=(type=char(40) updatewhereclause=yes name=nm_promocao_sos dbname="promocao_sos.nm_promocao_sos" dbalias="s.nm_promocao_sos" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="promocao_sos.dh_inicio" dbalias="s.dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="promocao_sos.dh_termino" dbalias="s.dh_termino" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 retrieve="Select	p.cd_produto, g.de_produto || ' : ' || g.de_apresentacao_venda As de_produto, p.pc_desconto As pc_desconto_atual, s.cd_promocao_sos, s.nm_promocao_sos, s.dh_inicio, s.dh_termino, 0.00 pc_desconto		
From promocao_sos As s
	Inner Join promocao_sos_produto As p
		On p.cd_promocao_sos = s.cd_promocao_sos
	Inner Join produto_geral As g
		On g.cd_produto = p.cd_produto
Where s.id_preco_bloqueado = 'S'
	And p.cd_produto = :produto
	And s.dh_inicio <= (Select dh_movimentacao From parametro Where id_parametro = '1')
	And (s.dh_termino >= (Select dh_movimentacao From parametro Where id_parametro = '1') Or s.dh_termino Is Null)

Union

Select	p.cd_produto, g.de_produto || ' : ' || g.de_apresentacao_venda As de_produto, p.pc_desconto As pc_desconto_atual, s.cd_promocao_sos, s.nm_promocao_sos, s.dh_inicio, s.dh_termino, 0.00 pc_desconto
From promocao_sos As s
	Inner Join promocao_sos_produto As p
		On p.cd_promocao_sos = s.cd_promocao_sos
	Inner Join produto_geral As g
		On g.cd_produto = p.cd_produto
Where s.id_preco_bloqueado = 'S'
	And p.cd_produto = :produto
	And s.dh_inicio > (Select dh_movimentacao From parametro Where id_parametro = '1')" arguments=(("produto", number)) )
