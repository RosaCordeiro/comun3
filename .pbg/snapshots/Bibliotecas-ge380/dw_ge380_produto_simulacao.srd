table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_promocao_sos dbname="promocao_sos_produto.cd_promocao_sos" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="promocao_sos_produto.cd_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_anterior dbname="promocao_sos_produto.pc_desconto_anterior" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_alteracao dbname="promocao_sos_produto.dh_alteracao" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_preco_venda_atual dbname="vl_preco_venda_atual" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto dbname="promocao_sos_produto.pc_desconto" initial="0.00" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_simulado dbname="vl_preco_simulado" initial="0.00" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_futuro dbname="produto_uf.vl_preco_venda_futuro" )
 column=(type=datetime updatewhereclause=yes name=dh_preco_venda_futuro dbname="produto_uf.dh_preco_venda_futuro" )
 column=(type=long updatewhereclause=yes name=cd_promocao_sos_maior dbname="cd_promocao_sos_maior" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_maior dbname="pc_desconto_maior" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_alteracao dbname="promocao_sos_produto.nr_matricula_alteracao" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto_clube dbname="pc_desconto_clube" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_clube_anterior dbname="pc_desconto_clube_anterior" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pre_simulado_clube dbname="vl_pre_simulado_clube" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_promocao dbname="promocao_sos.id_tipo_promocao" )
 retrieve="select p.cd_promocao_sos,
       p.cd_produto,
       p.pc_desconto pc_desconto_anterior,
       p.dh_alteracao,
       g.de_produto + ' : ' + g.de_apresentacao_venda de_produto,
	   g.vl_fator_conversao,
       (u.vl_preco_venda_atual / g.vl_fator_conversao) as vl_preco_venda_atual,
       p.pc_desconto,
		 0.01 vl_preco_simulado,
	 	u.vl_preco_venda_futuro,
		u.dh_preco_venda_futuro,
		0 cd_promocao_sos_maior,
		0.00 pc_desconto_maior,
		p.nr_matricula_alteracao,
		coalesce(p.pc_desconto_clube, 0.00) pc_desconto_clube,
		coalesce(p.pc_desconto_clube, 0.00) pc_desconto_clube_anterior,
		0.01 vl_pre_simulado_clube,
		s.id_tipo_promocao
  from promocao_sos As s
	inner join promocao_sos_produto As p
		on p.cd_promocao_sos = s.cd_promocao_sos
	inner join produto_geral As g
		on g.cd_produto = p.cd_produto
	inner join produto_uf u
		on u.cd_produto = p.cd_produto
 where p.cd_promocao_sos = :promocao
   and u.cd_unidade_federacao = :uf" update="promocao_sos_produto" updatewhere=0 updatekeyinplace=no arguments=(("uf", string),("promocao", number))  sort="de_produto A " )
