table(column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="promocao_sos_produto.cd_promocao_sos" )
 column=(type=char(40) updatewhereclause=yes name=nm_promocao_sos dbname="promocao_sos.nm_promocao_sos" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_clube dbname="pc_desconto_clube" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_anterior dbname="pc_desconto_anterior" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_clube_ant dbname="pc_desconto_clube_ant" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="promocao_sos.dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="promocao_sos.dh_termino" )
 column=(type=char(10) updatewhereclause=yes name=cd_promocao_sap dbname="cd_promocao_sap" )
 retrieve="Select	p.cd_promocao_sos,
		s.nm_promocao_sos,
		Coalesce(p.pc_desconto, 0.00) As pc_desconto,
		Coalesce(p.pc_desconto_clube, 0.00) As pc_desconto_clube,
		Coalesce(p.pc_desconto, 0.00) As pc_desconto_anterior,
		Coalesce(p.pc_desconto_clube, 0.00) As pc_desconto_clube_ant,
		s.dh_inicio,
		s.dh_termino, 
		coalesce(s.cd_promocao_sap,'0') as cd_promocao_sap
From promocao_sos As s
	Inner Join promocao_sos_produto As p
		On p.cd_promocao_sos = s.cd_promocao_sos
Where p.cd_produto = :produto
And s.id_tipo_promocao = 'N'
" arguments=(("produto", number)) )
