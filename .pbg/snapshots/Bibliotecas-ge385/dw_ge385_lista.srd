table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(102) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="de_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo dbname="de_subgrupo" )
 column=(type=char(40) updatewhereclause=yes name=de_categoria dbname="de_categoria" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="de_subcategoria" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="cd_grupo_psico" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo_psico dbname="de_grupo_psico" )
 column=(type=long updatewhereclause=yes name=qt_total dbname="qt_total" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_total dbname="vl_custo_total" )
 retrieve="select 	x.cd_filial, 
			x.cd_produto, 
			p.de_produto||': '||p.de_apresentacao_venda as de_produto,
			g.de_grupo,
			sgp.de_subgrupo,
			cp.de_categoria,
			scp.de_subcategoria,
			p.cd_grupo_psico,
			gps.de_grupo_psico,
			sum(x.qt_total) as qt_total, 
			sum(case when x.qt_total = 0 then 0.00 else x.vl_custo_total end) as vl_custo_total
from ( SELECT s.cd_filial,   
					s.cd_produto,
					sum(s.qt_saldo_final) as qt_total,
					Sum(round(s.qt_saldo_final * s.vl_custo_medio, 2)) as vl_custo_total
			 FROM  saldo_produto s (index saldo_prod_5850531202)
		WHERE s.dh_saldo   			= :dh_saldo
			AND s.cd_filial				in (:filial_1, :filial_2 )
			  and s.qt_saldo_final 		> 0 
			  and s.cd_produto 			not in (684431,577625)
		Group by s.cd_filial,   
					s.cd_produto

		union all
		
		select 	m.cd_filial_movimento as cd_filial, 
					m.cd_produto, 
					sum(m.qt_movimento * case when t.id_entrada_saida = 'S' then -1 else 1 end * case when t.id_cancelamento = 'S' then -1 else 1 end) as qt_total,
					sum(m.qt_movimento * case when t.id_entrada_saida = 'S' then -1 else 1 end * case when t.id_cancelamento = 'S' then -1 else 1 end * m.vl_custo_unitario) as vl_custo_total
		from movimento_estoque m (index idx_data_filial)
		left outer Join tipo_movimento_estoque t (index pk_tipo_movimento_estoque)
			on t.cd_tipo_movimento = m.cd_tipo_movimento+0
		Where m.dh_movimento between dateadd(mm, 1, :dh_saldo) and :dh_posicao
			and m.cd_filial_movimento	in (:filial_1, :filial_2 )
		group by m.cd_filial_movimento, 
					m.cd_produto
		//having sum(m.qt_movimento * case when t.id_entrada_saida = 'S' then -1 else 1 end * case when t.id_cancelamento = 'S' then -1 else 1 end) <> 0
		) x
left outer join produto_geral p (index pk_produto_geral)
	on p.cd_produto = x.cd_produto+0
left outer join subcategoria scp (index pk_subcategoria)
	on scp.cd_subcategoria = p.cd_subcategoria||''
left outer join categoria cp	(index pk_categoria)
	on cp.cd_categoria = scp.cd_categoria||''
left outer join subgrupo sgp	(index pk_subgrupo)
	on sgp.cd_subgrupo = cp.cd_subgrupo||''
left outer join grupo g	(index pk_grupo)
	on g.cd_grupo= sgp.cd_grupo||''
left outer join grupo_psico gps	(index pk_grupo_psico)
	on gps.cd_grupo_psico = p.cd_grupo_psico
Group by x.cd_filial, 
			x.cd_produto, 
			p.de_produto||': '||p.de_apresentacao_venda,
			g.de_grupo,
			sgp.de_subgrupo,
			cp.de_categoria,
			scp.de_subcategoria,
			p.cd_grupo_psico,
			gps.de_grupo_psico
having sum(x.qt_total) > 0" arguments=(("dh_saldo", datetime),("dh_posicao", datetime),("filial_1", number),("filial_2", number))  sort="vl_custo_total A " )
