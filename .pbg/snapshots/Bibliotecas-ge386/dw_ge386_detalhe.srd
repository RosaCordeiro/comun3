table(column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="cliente.cd_cliente" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_cliente dbname="cliente.id_tipo_cliente" values="CLUBE - FIDELIDADE	RC/CLUBE - FIDELIDADE & PRAZO	CC/CREDI$$HEX1$$c100$$ENDHEX$$RIO	CR/SOMENTE CADASTRO	SC/" )
 column=(type=char(1) updatewhereclause=yes name=id_fisica_juridica dbname="cliente.id_fisica_juridica" values="F$$HEX1$$cd00$$ENDHEX$$SICA	F/JUR$$HEX1$$cd00$$ENDHEX$$DICA	J/" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="cliente.nm_cliente" )
 column=(type=char(14) updatewhereclause=yes name=nr_cpf_cgc dbname="cliente.nr_cpf_cgc" )
 column=(type=char(20) updatewhereclause=yes name=nr_rg dbname="cliente.nr_rg" )
 column=(type=char(15) updatewhereclause=yes name=nr_inscricao_estadual dbname="cliente.nr_inscricao_estadual" )
 column=(type=char(10) updatewhereclause=yes name=de_orgao_emissor_rg dbname="cliente.de_orgao_emissor_rg" )
 column=(type=datetime updatewhereclause=yes name=dh_nascimento dbname="cliente.dh_nascimento" )
 column=(type=char(40) updatewhereclause=yes name=nm_mae dbname="cliente.nm_mae" )
 column=(type=char(1) updatewhereclause=yes name=id_sexo dbname="cliente.id_sexo" values="MASCULINO	M/FEMININO	F/" )
 column=(type=char(1) updatewhereclause=yes name=id_estado_civil dbname="cliente.id_estado_civil" )
 column=(type=char(40) updatewhereclause=yes name=nm_conjuge dbname="cliente.nm_conjuge" )
 column=(type=char(1) updatewhereclause=yes name=id_possui_filhos dbname="cliente.id_possui_filhos" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=datetime updatewhereclause=yes name=dh_nascimento_filho_1 dbname="cliente.dh_nascimento_filho_1" )
 column=(type=datetime updatewhereclause=yes name=dh_nascimento_filho_2 dbname="cliente.dh_nascimento_filho_2" )
 column=(type=datetime updatewhereclause=yes name=dh_nascimento_filho_3 dbname="cliente.dh_nascimento_filho_3" )
 column=(type=datetime updatewhereclause=yes name=dh_nascimento_filho_4 dbname="cliente.dh_nascimento_filho_4" )
 column=(type=long updatewhereclause=yes name=cd_cidade dbname="cliente.cd_cidade" )
 column=(type=char(40) updatewhereclause=yes name=de_endereco dbname="cliente.de_endereco" )
 column=(type=char(6) updatewhereclause=yes name=nr_endereco dbname="cliente.nr_endereco" )
 column=(type=char(20) updatewhereclause=yes name=de_complemento dbname="cliente.de_complemento" )
 column=(type=char(20) updatewhereclause=yes name=de_bairro dbname="cliente.de_bairro" )
 column=(type=char(100) updatewhereclause=yes name=de_endereco_email dbname="cliente.de_endereco_email" )
 column=(type=char(3) updatewhereclause=yes name=nr_ddd_fone_residencial dbname="cliente.nr_ddd_fone_residencial" )
 column=(type=char(10) updatewhereclause=yes name=nr_fone_residencial dbname="cliente.nr_fone_residencial" )
 column=(type=char(3) updatewhereclause=yes name=nr_ddd_celular dbname="cliente.nr_ddd_celular" )
 column=(type=char(10) updatewhereclause=yes name=nr_celular dbname="cliente.nr_celular" )
 column=(type=char(3) updatewhereclause=yes name=nr_ddd_fone_comercial dbname="cliente.nr_ddd_fone_comercial" )
 column=(type=char(10) updatewhereclause=yes name=nr_fone_comercial dbname="cliente.nr_fone_comercial" )
 column=(type=char(3) updatewhereclause=yes name=nr_ddd_fone_recado dbname="cliente.nr_ddd_fone_recado" )
 column=(type=char(10) updatewhereclause=yes name=nr_fone_recado dbname="cliente.nr_fone_recado" )
 column=(type=char(1) updatewhereclause=yes name=id_medicamento_uso_continuo dbname="cliente.id_medicamento_uso_continuo" values="Faz uso de medicamentos de uso cont$$HEX1$$ed00$$ENDHEX$$nuo ?	S/Faz uso de medicamentos de uso cont$$HEX1$$ed00$$ENDHEX$$nuo ?	N" )
 column=(type=char(1) updatewhereclause=yes name=id_autoriza_comunicacao dbname="cliente.id_autoriza_comunicacao" values="Autoriza a encaminhar novidades e promo$$HEX2$$e700f500$$ENDHEX$$es ?	S/Autoriza a encaminhar novidades e promo$$HEX2$$e700f500$$ENDHEX$$es ?	N" )
 column=(type=char(40) updatewhereclause=yes name=nm_empresa_convenio dbname="cliente.nm_empresa_convenio" )
 column=(type=char(1) updatewhereclause=yes name=id_permite_resgate_dependente dbname="cliente.id_permite_resgate_dependente" )
 column=(type=char(1) updatewhereclause=yes name=id_permite_credito_dependente dbname="cliente.id_permite_credito_dependente" )
 column=(type=char(1) updatewhereclause=yes name=id_documentacao_pendente dbname="cliente.id_documentacao_pendente" )
 column=(type=long updatewhereclause=yes name=cd_grau_instrucao dbname="cliente.cd_grau_instrucao" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep_aux dbname="cliente.nr_cep_aux" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf dbname="cidade.cd_uf" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep dbname="cliente.nr_cep" )
 retrieve="select c.cd_cliente,   
		 c.id_tipo_cliente,  
		 c.id_fisica_juridica,   
		 c.nm_cliente,
		 c.nr_cpf_cgc,   
		 c.nr_rg,   
		 c.nr_inscricao_estadual,
		 c.de_orgao_emissor_rg,   
		 c.dh_nascimento,   
		 c.nm_mae,   
		 c.id_sexo,   
		 c.id_estado_civil, 
       	c.nm_conjuge,  
	 	 c.id_possui_filhos,   
	 	 c.dh_nascimento_filho_1,   
	 	 c.dh_nascimento_filho_2,   
		 c.dh_nascimento_filho_3,   
		 c.dh_nascimento_filho_4,   
		 c.cd_cidade,   
		 c.de_endereco,
		 c.nr_endereco,   
		 c.de_complemento,   
		 c.de_bairro,   
		 c.de_endereco_email,   
		 c.nr_ddd_fone_residencial,   
		 c.nr_fone_residencial,   
		 c.nr_ddd_celular,   
		 c.nr_celular,   
		 c.nr_ddd_fone_comercial,   
		 c.nr_fone_comercial,   
		 c.nr_ddd_fone_recado,   
		 c.nr_fone_recado,   
		 c.id_medicamento_uso_continuo,   
		 c.id_autoriza_comunicacao,   
       	c.nm_empresa_convenio,
       	c.id_permite_resgate_dependente,
       	c.id_permite_credito_dependente,
       	c.id_documentacao_pendente,
		 c.cd_grau_instrucao,
		c.nr_cep as nr_cep_aux,
		 ci.nm_cidade nm_cidade,
		 ci.cd_unidade_federacao as cd_uf,
		c.nr_cep as nr_cep
from cliente c
left outer join cidade ci
	on ci.cd_cidade = c.cd_cidade
where c.cd_cliente = :cliente" arguments=(("cliente", string)) )
