table(column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="cliente.cd_cliente" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="cliente.nm_cliente" )
 column=(type=char(14) updatewhereclause=yes name=nr_cpf_cgc dbname="cliente.nr_cpf_cgc" )
 column=(type=char(26) updatewhereclause=yes name=de_tipo_cliente dbname="de_tipo_cliente" )
 column=(type=char(1) updatewhereclause=yes name=id_fisica_juridica dbname="cliente.id_fisica_juridica" )
 column=(type=char(8) updatewhereclause=yes name=de_fisica_juridica dbname="de_fisica_juridica" )
 column=(type=char(1) updatewhereclause=yes name=cliente_id_sexo dbname="cliente.id_sexo" )
 column=(type=char(9) updatewhereclause=yes name=de_sexo dbname="de_sexo" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" )
 retrieve="select 	c.cd_cliente,  
			c.nm_cliente, 
			c.nr_cpf_cgc, 
			case c.id_tipo_cliente 
				when 'RC' then 'CLUBE - FIDELIDADE'
				when 'CC' then 'CLUBE - FIDELIDADE & PRAZO'
				when 'SC' then 'SOMENTE CADASTRO'
				when 'CR' then 'CREDI$$HEX1$$c100$$ENDHEX$$RIO'
			else '' end as de_tipo_cliente,
			c.id_fisica_juridica,
			case c.id_fisica_juridica 
				when 'J' then 'JURIDICA' 
				when 'F' then 'FISICA' 
			else '' end as de_fisica_juridica,
			c.id_sexo,
			case c.id_sexo  
				when 'M' then 'MASCULINO'
				when 'F' then 'FEMININO' 
			else '' end as de_sexo,
			ci.nm_cidade,
			ci.cd_unidade_federacao
from cliente c
left outer join cidade ci
	on ci.cd_cidade = c.cd_cidade
Where coalesce(c.id_falecido,'N')<>'S'"  sort="nm_cliente A " )
