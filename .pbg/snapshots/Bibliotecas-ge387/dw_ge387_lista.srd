table(column=(type=decimal(0) updatewhereclause=yes name=nr_matricula dbname="vdc_lista_colaboradores.nr_matricula" dbalias=".nr_matricula" )
 column=(type=decimal(0) updatewhereclause=yes name=cd_filial dbname="vdc_lista_colaboradores.cd_filial" dbalias=".cd_filial" )
 column=(type=char(30) updatewhereclause=yes name=de_cargo dbname="de_cargo" )
 column=(type=char(24) updatewhereclause=yes name=cd_cargo dbname="cd_cargo" )
 column=(type=decimal(0) updatewhereclause=yes name=id_situacao dbname="vdc_lista_colaboradores.id_situacao" dbalias=".id_situacao" )
 column=(type=char(30) updatewhereclause=yes name=de_situacao dbname="de_situacao" )
 column=(type=datetime updatewhereclause=yes name=dh_afastamento dbname="vdc_lista_colaboradores.dh_afastamento" dbalias=".dh_afastamento" )
 retrieve="select matricula as nr_matricula, 
		filial as cd_filial, 
		case when filial in (100,534) then 'N$$HEX1$$c300$$ENDHEX$$O PERMITIDA EXIBI$$HEX2$$c700c300$$ENDHEX$$O' else Upper(descargo) end as de_cargo, 
		case when filial in (100,534) then '' else codcargo end as cd_cargo, 
		sitafa as id_situacao, 
		Upper(dessit) as de_situacao, 
		datafa  as dh_afastamento
from vdc_lista_colaboradores
where empresa = 1
  and tipcol = 1
  and matricula = :matricula	" arguments=(("matricula", string)) )
