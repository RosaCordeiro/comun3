 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"filial~" )  TABLE(NAME=~"cidade~" )  TABLE(NAME=~"unidade_federacao~" ) COLUMN(NAME=~"filial.cd_filial~") COLUMN(NAME=~"filial.nm_fantasia~") COLUMN(NAME=~"filial.nm_razao_social~") COLUMN(NAME=~"filial.nr_cgc~") COLUMN(NAME=~"filial.nr_inscricao_estadual~") COLUMN(NAME=~"cidade.nm_cidade~") COLUMN(NAME=~"cidade.cd_unidade_federacao~") COLUMN(NAME=~"filial.de_endereco~") COLUMN(NAME=~"filial.de_bairro~") COLUMN(NAME=~"filial.nr_cep~") COLUMN(NAME=~"filial.nr_ddd_telefone~") COLUMN(NAME=~"filial.nr_telefone~") COLUMN(NAME=~"unidade_federacao.nm_unidade_federacao~") COMPUTE(NAME=~"getdate() dh_inicio~") COMPUTE(NAME=~"getdate() dh_termino~")    JOIN (LEFT=~"cidade.cd_cidade~"    OP =~"=~"RIGHT=~"filial.cd_cidade~" )    JOIN (LEFT=~"unidade_federacao.cd_unidade_federacao~"    OP =~"=~"RIGHT=~"cidade.cd_unidade_federacao~" )WHERE(    EXP1 =~"filial.cd_filial~"   OP =~"=~"    EXP2 =~"534~" ) ) " retrieve.asneeded=yes )
