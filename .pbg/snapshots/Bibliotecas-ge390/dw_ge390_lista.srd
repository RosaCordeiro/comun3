table(column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="produto_central.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="grupo.de_grupo" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=char(1) updatewhereclause=yes name=id_pedido_exclusivo_falta dbname="produto_uf.id_pedido_exclusivo_falta" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="produto_uf.cd_unidade_federacao" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_comprador dbname="produto_central.nr_matricula_comprador" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=datetime updatewhereclause=yes name=dh_ultima_compra dbname="dh_ultima_compra" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="vw_saldo_atual_produto.qt_saldo_final" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionado dbname="id_selecionado" initial="N" values="	S/	N" )
 retrieve="Select	c.cd_produto,
		g.de_produto || ' : ' || g.de_apresentacao_estoque As de_produto,
		g.id_situacao,
		vw.de_grupo,
		g.vl_fator_conversao,
		pu.id_pedido_exclusivo_falta,
		pu.cd_unidade_federacao,
		g.cd_grupo_psico,
		c.nr_matricula_comprador,
		u.nm_usuario,
		(Select max(re.dh_resumo)
			From resumo_movto_estq_prd re
		Where re.cd_filial = 534
		  	And re.cd_produto = c.cd_produto
		  	And re.qt_compra > 0) As dh_ultima_compra,
		s.qt_saldo_final,
		'N' As id_selecionado
From produto_central As c
	Inner Join produto_geral As g
		On g.cd_produto = c.cd_produto
	Inner Join produto_uf As pu
		On pu.cd_produto = c.cd_produto
	Inner Join unidade_federacao uf
		On uf.cd_unidade_federacao = pu.cd_unidade_federacao
		And pu.id_pedido_exclusivo_falta = uf.id_pedido_exclusivo_falta
	Left Outer Join grupo As vw
		On vw.cd_grupo = substring(g.cd_subcategoria, 1, 1)
	Left Outer Join usuario As u
		On u.nr_matricula = c.nr_matricula_comprador
	Left Outer Join vw_saldo_atual_produto As s
		On s.cd_filial = 534
		And s.cd_produto = g.cd_produto
Where pu.id_pedido_exclusivo_falta = 'S'"  sort="id_situacao D de_produto A " )
