table(column=(type=long updatewhereclause=yes name=de_chave dbname="de_chave" )
 column=(type=char(1) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao dbname="historico_alteracao_tabela.dh_alteracao" dbalias="h.dh_alteracao" )
 column=(type=char(32768) updatewhereclause=no name=de_alteracao_de dbname="historico_alteracao_tabela.de_alteracao_de" dbalias="h.de_alteracao_de" )
 column=(type=char(32768) updatewhereclause=no name=de_alteracao_para dbname="historico_alteracao_tabela.de_alteracao_para" dbalias="h.de_alteracao_para" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_alteracao dbname="historico_alteracao_tabela.nr_matric_alteracao" dbalias="h.nr_matric_alteracao" )
 column=(type=char(1) updatewhereclause=yes name=nm_responsavel dbname="nm_responsavel" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao dbname="historico_alteracao_tabela.id_alteracao" dbalias="h.id_alteracao" values="INCLUS$$HEX1$$c300$$ENDHEX$$O	I/EXCLUS$$HEX1$$c300$$ENDHEX$$O	E/ALTERA$$HEX2$$c700c300$$ENDHEX$$O	A/" )
 retrieve="Select	Cast(h.de_chave As Integer) As de_chave,
		'' As de_produto,
		h.dh_alteracao,
		h.de_alteracao_de,
		h.de_alteracao_para,
		h.nr_matric_alteracao,
		'' As nm_responsavel,
		h.id_alteracao
From historico_alteracao_tabela As h
Where h.nm_tabela = 'PRODUTO_CENTRAL'
	And h.nm_coluna = 'ID_EXCLUSIVO_PEDIDO_FALTA_BA'
	And h.dh_alteracao >= :inicio
	And h.dh_alteracao <= :termino" arguments=(("inicio", datetime),("termino", datetime))  sort="dh_alteracao D " )
