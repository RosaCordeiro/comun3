table(column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="grupo.de_grupo" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=datetime updatewhereclause=yes name=dh_ultima_compra dbname="dh_ultima_compra" )
 column=(type=char(1) updatewhereclause=yes name=id_retira_lista dbname="id_retira_lista" )
 column=(type=char(1) updatewhereclause=yes name=id_exclusivo dbname="id_exclusivo" values="SIM	S/NAO	N/" )
 column=(type=long updatewhereclause=yes name=qt_falta dbname="qt_falta" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="qt_saldo_final" )
 retrieve="select  tudo.cd_produto, 
        pg.de_produto + ' : ' + pg.de_apresentacao_estoque de_produto,
        g.de_grupo,
		pg.vl_fator_conversao,
		pg.cd_grupo_psico	,	
		u.nm_usuario,
		(select max(re.dh_resumo) from resumo_movto_estq_prd re
		where re.cd_filial = 534
		  and re.cd_produto = tudo.cd_produto
		  and re.qt_compra > 0) dh_ultima_compra, 
		'N' id_retira_lista,
		coalesce(pc.id_exclusivo_pedido_falta_ba, 'N') id_exclusivo,
        sum(qt_falta) qt_falta,
		(select qt_saldo_final
			from saldo_produto
			where cd_filial = 534
		 	and cd_produto = tudo.cd_produto
			and dh_saldo = :dh_saldo) as qt_saldo_final
from
(
	select 	r.cd_produto,
			((Case when coalesce(rm.qt_estoque_minimo, 0) > r.qt_estoque_base Then rm.qt_estoque_minimo else r.qt_estoque_base END) - s.qt_saldo_final) qt_falta
	from resumo_reposicao_estoque r
	left outer join resumo_estoque_minimo_filial rm
		on rm.cd_filial = r.cd_filial
		and rm.cd_produto = r.cd_produto
	inner join filial f
		 on f.cd_filial = r.cd_filial
	inner join cidade c
		 on c.cd_cidade = f.cd_cidade
	inner join saldo_produto s
		on s.cd_filial = r.cd_filial
		and s.cd_produto = r.cd_produto
	inner join produto_geral pg
		 on pg.cd_produto = r.cd_produto
	where c.cd_unidade_federacao = 'BA'
	  and f.id_pedido_centralizado = 'S'
	  and pg.id_situacao = 'A'
	  and s.dh_saldo = f.dh_ultimo_saldo
	  and ((Case when coalesce(rm.qt_estoque_minimo, 0) > r.qt_estoque_base Then rm.qt_estoque_minimo else r.qt_estoque_base END) - s.qt_saldo_final) > 0
	  and coalesce(pg.id_geladeira, 'N') = 'N'
	  and substring(pg.cd_subcategoria, 1,6) <> '308003'
	  and pg.cd_subcategoria <> '307003002'
	  and substring(pg.cd_subcategoria, 1,1) <> '5'
	  
) as tudo
inner join produto_geral pg
    on pg.cd_produto = tudo.cd_produto
inner join grupo g
	on g.cd_grupo = substring(pg.cd_subcategoria,1,1)
inner join produto_central pc
	on pc.cd_produto = tudo.cd_produto
inner join usuario u 
	on u.nr_matricula = pc.nr_matricula_comprador
where not exists (select * from distribuidora_produto dp
              inner join distribuidora_uf du
                on du.cd_distribuidora = dp.cd_distribuidora
                and du.cd_unidade_federacao = 'BA'
                and coalesce(du.id_homologando_pedido, 'N') = 'N'
              where dp.cd_produto = tudo.cd_produto
                and dp.cd_unidade_federacao = 'BA'
                and dp.id_situacao = 'A')
 and exists (select * from distribuidora_produto dp
              inner join distribuidora_uf du
                on du.cd_distribuidora = dp.cd_distribuidora
                and du.cd_unidade_federacao = 'SC'
                and coalesce(du.id_homologando_pedido, 'N') = 'N'
              where dp.cd_produto = tudo.cd_produto
                and dp.cd_unidade_federacao = 'SC'
                and dp.id_situacao = 'A')
group by tudo.cd_produto, 
        pg.de_produto + ' : ' + pg.de_apresentacao_estoque,
        g.de_grupo,
		pg.vl_fator_conversao,
		pg.cd_grupo_psico,
		u.nm_usuario,
		coalesce(pc.id_exclusivo_pedido_falta_ba, 'N')

union

select	tudo.cd_produto, 
      	pg.de_produto + ' : ' + pg.de_apresentacao_estoque de_produto,
        	g.de_grupo,
		pg.vl_fator_conversao,
		pg.cd_grupo_psico	,
		u.nm_usuario,	
		(select max(re.dh_resumo) from resumo_movto_estq_prd re
		where re.cd_filial = 534
		  	and re.cd_produto = tudo.cd_produto
		  	and re.qt_compra > 0) dh_ultima_compra, 	
		'N' id_retira_lista,
		coalesce(pc.id_exclusivo_pedido_falta_ba, 'N') id_exclusivo,
        sum(qt_falta) qt_falta,
		(select qt_saldo_final
			from saldo_produto
			where cd_filial = 534
		 	and cd_produto = tudo.cd_produto
			and dh_saldo = :dh_saldo) as qt_saldo_final
from
(
	select 	r.cd_produto,
			((Case when coalesce(rm.qt_estoque_minimo, 0) > r.qt_estoque_base Then rm.qt_estoque_minimo else r.qt_estoque_base END) - s.qt_saldo_final) qt_falta
	from resumo_reposicao_estoque r
	left outer join resumo_estoque_minimo_filial rm
		on rm.cd_filial = r.cd_filial
		and rm.cd_produto = r.cd_produto
	inner join filial f
		 on f.cd_filial = r.cd_filial
	inner join cidade c
		 on c.cd_cidade = f.cd_cidade
	inner join saldo_produto s
		on s.cd_filial = r.cd_filial
		and s.cd_produto = r.cd_produto
	inner join produto_geral pg
		 on pg.cd_produto = r.cd_produto
	where c.cd_unidade_federacao = 'BA'
	  and f.id_pedido_centralizado = 'S'
	  and pg.id_situacao = 'A'
	  and s.dh_saldo = f.dh_ultimo_saldo
	  and ((Case when coalesce(rm.qt_estoque_minimo, 0) > r.qt_estoque_base Then rm.qt_estoque_minimo else r.qt_estoque_base END) - s.qt_saldo_final) > 0
	  and coalesce(pg.id_geladeira, 'N') = 'N'
	  and substring(pg.cd_subcategoria, 1,6) <> '308003'
	  and pg.cd_subcategoria <> '307003002'
	  and substring(pg.cd_subcategoria, 1,1) <> '5'
 ) as tudo
inner join produto_geral pg
    on pg.cd_produto = tudo.cd_produto
inner join grupo g
	on g.cd_grupo = substring(pg.cd_subcategoria,1,1)
inner join produto_central pc
	on pc.cd_produto = tudo.cd_produto
inner join usuario u 
	on u.nr_matricula = pc.nr_matricula_comprador
where exists (select * from distribuidora_produto dp
              inner join distribuidora_uf du
                on du.cd_distribuidora = dp.cd_distribuidora
                and du.cd_unidade_federacao = 'BA'
                and coalesce(du.id_homologando_pedido, 'N') = 'N'
              where dp.cd_produto = tudo.cd_produto
                and dp.cd_unidade_federacao = 'BA'
                and dp.id_situacao = 'A')
    and pg.cd_grupo_psico is not null
   and exists (select * from distribuidora_produto dp
              inner join distribuidora_uf du
                on du.cd_distribuidora = dp.cd_distribuidora
                and du.cd_unidade_federacao = 'SC'
                and coalesce(du.id_homologando_pedido, 'N') = 'N'
              where dp.cd_produto = tudo.cd_produto
                and dp.cd_unidade_federacao = 'SC'
                and dp.id_situacao = 'A')
group by tudo.cd_produto, 
        pg.de_produto + ' : ' + pg.de_apresentacao_estoque,
        g.de_grupo,
		pg.vl_fator_conversao,
		pg.cd_grupo_psico,
		u.nm_usuario,
		coalesce(pc.id_exclusivo_pedido_falta_ba, 'N')" arguments=(("dh_saldo", date))  sort="de_produto A " )
