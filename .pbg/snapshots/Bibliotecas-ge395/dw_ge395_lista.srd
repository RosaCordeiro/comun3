table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" )
 column=(type=long update=yes updatewhereclause=yes name=id_semana dbname="remanejamento_filial_semana.id_semana" )
 retrieve="select 	a.cd_filial, 
          	a.nm_fantasia,
			cd_unidade_federacao,          	
			b.id_semana 
from   	filial a
inner  	join remanejamento_filial_semana b
on 	 	a.cd_filial = b.cd_filial
inner 	join cidade c 
on 		c.cd_cidade = a.cd_cidade
where  	a.id_situacao = 'A'
order by a.cd_filial, b.id_semana" update="remanejamento_filial_semana" updatewhere=0 updatekeyinplace=no )
