table(column=(type=long updatewhereclause=yes key=yes name=cd_promocao_sos dbname="promocao_sos_produto.cd_promocao_sos" dbalias="p.cd_promocao_sos" )
 column=(type=long updatewhereclause=yes key=yes name=cd_produto dbname="promocao_sos_produto.cd_produto" dbalias="p.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="promocao_sos.dh_inicio" dbalias="s.dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="promocao_sos.dh_termino" dbalias="s.dh_termino" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="promocao_sos_produto.pc_desconto" dbalias="p.pc_desconto" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio_estoque_minimo dbname="promocao_sos.dh_inicio_estoque_minimo" dbalias="s.dh_inicio_estoque_minimo" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_estoque_minimo dbname="promocao_sos.dh_termino_estoque_minimo" dbalias="s.dh_termino_estoque_minimo" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_clube dbname="pc_desconto_clube" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto_futuro dbname="pc_desconto_futuro" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto_clube_futuro dbname="pc_desconto_clube_futuro" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_vigencia_futuro dbname="promocao_sos_produto.dh_vigencia_futuro" dbalias="p.dh_vigencia_futuro" )
 column=(type=datetime updatewhereclause=yes name=dh_vigencia_futuro_ant dbname="promocao_sos_produto.dh_vigencia_futuro_ant" dbalias="p.dh_vigencia_futuro_ant" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_alteracao_futuro dbname="promocao_sos_produto.nr_matricula_alteracao_futuro" dbalias="p.nr_matricula_alteracao_futuro" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_futuro_ant dbname="pc_desconto_futuro_ant" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_clube_futuro_ant dbname="pc_desconto_clube_futuro_ant" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao dbname="promocao_sos_produto.dh_alteracao" dbalias="p.dh_alteracao" )
 column=(type=char(10) updatewhereclause=yes name=cd_promocao_sap dbname="cd_promocao_sap" )
 retrieve="Select	Distinct p.cd_promocao_sos,
		p.cd_produto,
		g.de_produto || ' : ' || g.de_apresentacao_venda As de_produto,
		s.dh_inicio,
		s.dh_termino,
		p.pc_desconto,
		s.dh_inicio_estoque_minimo,
		s.dh_termino_estoque_minimo,
		Coalesce(p.pc_desconto_clube, 0.00) As pc_desconto_clube,
		Coalesce(p.pc_desconto_futuro, 0.00) As pc_desconto_futuro,
		Coalesce(p.pc_desconto_clube_futuro, 0.00) As pc_desconto_clube_futuro,
		p.dh_vigencia_futuro,
		p.dh_vigencia_futuro As dh_vigencia_futuro_ant,
		p.nr_matricula_alteracao_futuro,
		Coalesce(p.pc_desconto_futuro, 0.00) As pc_desconto_futuro_ant,
		Coalesce(p.pc_desconto_clube_futuro, 0.00) As pc_desconto_clube_futuro_ant,
		p.dh_alteracao,
		coalesce(s.cd_promocao_sap,'0') as cd_promocao_sap
From promocao_sos As s
	Inner Join promocao_sos_filial As f
		On f.cd_promocao_sos = s.cd_promocao_sos
	Inner Join promocao_sos_produto As p
		On p.cd_promocao_sos = s.cd_promocao_sos
	Inner Join produto_geral As g
		On g.cd_produto = p.cd_produto
Where s.cd_promocao_sos = :promocao" update="promocao_sos_produto" updatewhere=0 updatekeyinplace=yes arguments=(("promocao", number))  sort="de_produto A " )
