table(column=(type=char(20) update=yes updatewhereclause=yes key=yes name=de_codigo_barras dbname="codigo_barras_produto.de_codigo_barras" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="codigo_barras_produto.cd_produto" )
 column=(type=char(3) update=yes updatewhereclause=yes name=id_principal dbname="id_principal" initial="N" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao dbname="codigo_barras_produto.dh_atualizacao" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_atualizacao dbname="codigo_barras_produto.nr_matricula_atualizacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_venda dbname="codigo_barras_produto.cd_unidade_medida_venda" )
 retrieve="select c.de_codigo_barras,   
       c.cd_produto,   
       (CASE WHEN c.id_principal = 'S' THEN 'SIM' ELSE 'N$$HEX1$$c300$$ENDHEX$$O' END) id_principal,   
       c.dh_atualizacao,   
       c.nr_matricula_atualizacao,
       u.nm_usuario,
		c.cd_unidade_medida_venda
from codigo_barras_produto c,   
     usuario u
where c.cd_produto = :produto
  and u.nr_matricula =* c.nr_matricula_atualizacao
" update="codigo_barras_produto" updatewhere=0 updatekeyinplace=no arguments=(("produto", number))  sort="cd_unidade_medida_venda A id_principal D " )
