 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_comissao dbname="tipo_comissao_produto.pc_comissao" )
 retrieve="select t.cd_produto,
       t.cd_tipo_comissao,   
       d.de_tipo_comissao,   
       t.pc_comissao  
from tipo_comissao_produto t,
     tipo_comissao d     
where t.cd_produto = :produto
  and d.cd_tipo_comissao = t.cd_tipo_comissao
" update="tipo_comissao_produto" updatewhere=0 updatekeyinplace=no arguments=(("produto", number)) )
