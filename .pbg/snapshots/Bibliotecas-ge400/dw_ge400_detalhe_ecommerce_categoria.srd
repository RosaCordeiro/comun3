table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_categoria dbname="categoria_ecommerce_produto.cd_categoria" )
 column=(type=char(40) updatewhereclause=yes name=de_categoria dbname="categoria_ecommerce.de_categoria" )
 column=(type=long updatewhereclause=yes name=cd_categoria_pai dbname="categoria_ecommerce.cd_categoria_pai" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_principal dbname="categoria_ecommerce_produto.id_principal" initial="S" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="categoria_ecommerce_produto.cd_produto" )
 column=(type=char(1) updatewhereclause=yes name=de_detalhe dbname="de_detalhe" )
 retrieve="SELECT	ep.cd_categoria,
			e.de_categoria,
			e.cd_categoria_pai,
			ep.id_principal,
			ep.cd_produto,
			'' AS de_detalhe
FROM categoria_ecommerce AS e
	INNER JOIN categoria_ecommerce_produto AS ep
		ON ep.cd_categoria = e.cd_categoria
WHERE ep.cd_produto = :produto" update="categoria_ecommerce_produto" updatewhere=0 updatekeyinplace=no arguments=(("produto", number)) )
