 column=(type=char(1) updatewhereclause=yes name=id_farm_gov_bolsa_familia dbname="id_farm_gov_bolsa_familia" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_temp_minima dbname="vl_temp_minima" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_temp_maxima dbname="vl_temp_maxima" )
 column=(type=char(1) updatewhereclause=yes name=id_pbm_permite_cobre_preco dbname="id_pbm_permite_cobre_preco" )
 column=(type=char(100) updatewhereclause=yes name=de_produto_primaria dbname="de_produto_primaria" )
 column=(type=char(100) updatewhereclause=yes name=de_produto_secundaria dbname="de_produto_secundaria" )
 column=(type=char(140) updatewhereclause=yes name=de_texto_legal dbname="de_texto_legal" )
 column=(type=char(80) updatewhereclause=yes name=de_alergenicos dbname="de_alergenicos" )
 column=(type=char(1) updatewhereclause=yes name=id_permite_publicidade dbname="id_permite_publicidade" )
 column=(type=char(1) updatewhereclause=yes name=id_publi_obriga_texto_legal dbname="id_publi_obriga_texto_legal" )
 column=(type=char(1) updatewhereclause=yes name=id_lib_marketing_externo dbname="id_lib_marketing_externo" )
 column=(type=char(1) updatewhereclause=yes name=id_lib_marketing_interno dbname="id_lib_marketing_interno" )
 column=(type=char(50) updatewhereclause=yes name=de_produto_area_atuacao dbname="de_produto_area_atuacao" )
 column=(type=char(50) updatewhereclause=yes name=de_produto_atributo dbname="de_produto_atributo" )
 column=(type=char(50) updatewhereclause=yes name=de_produto_faixa_etaria dbname="de_produto_faixa_etaria" )
 column=(type=char(255) updatewhereclause=yes name=de_produto_posologia dbname="de_produto_posologia" )
 column=(type=char(255) updatewhereclause=yes name=de_produto_precaucoes dbname="de_produto_precaucoes" )
 column=(type=char(50) updatewhereclause=yes name=de_produto_publico_dest dbname="de_produto_publico_dest" )
 column=(type=char(50) updatewhereclause=yes name=de_produto_selo dbname="de_produto_selo" )
 column=(type=char(255) updatewhereclause=yes name=de_produto_texto_min_saude dbname="de_produto_texto_min_saude" )
 column=(type=char(1) updatewhereclause=yes name=id_contem_corante dbname="id_contem_corante" )
 column=(type=char(1) updatewhereclause=yes name=id_testado_animais dbname="id_testado_animais" )
 column=(type=char(1) updatewhereclause=yes name=id_vegano dbname="id_vegano" )
 column=(type=char(2) updatewhereclause=yes name=id_stb dbname="id_stb" )
 column=(type=char(100) updatewhereclause=yes name=de_desc_stb dbname="de_desc_stb" )
 column=(type=datetime updatewhereclause=yes name=dt_inicio_stb dbname="dt_inicio_stb" )
 column=(type=datetime updatewhereclause=yes name=dt_fim_stb dbname="dt_fim_stb" )
 retrieve="Select pc.cd_produto,   
       pc.cd_mix_produto,
       pc.id_tipo_reposicao_estoque,
       pc.cd_produto_fornecedor,   
       pc.pc_desconto_fornecedor,   
       pc.vl_peso_liquido,   
       pc.dh_situacao,   
       pc.cd_local_estocagem,   
       pc.id_origem_produto_fornecedor,   
       0 as cd_produto_abcfarma,   
	  '' as nm_fabricante_abc_farma,
       pc.vl_fator_conversao_abcfarma,   
       pc.cd_divisao_estocagem,   
       pc.id_preco_informado,   
       pc.id_contrato_fornecedor,   
       pc.id_pagamento_apos_venda,
       pc.id_sugere_pedido_filial,
       pc.id_lei_generico,
       pg.id_lei_generico,
       pg.de_produto,   
       pg.de_apresentacao_estoque,   
       pg.de_apresentacao_venda,   
       pg.nr_embalagem_padrao,   
       pg.nr_classificacao_fiscal,   
       pg.cd_unidade_medida_compra,   
       pg.cd_unidade_medida_venda,   
       pg.cd_grupo_produto,   
       pg.cd_subgrupo_produto,   
       pg.cd_linha_produto,   
       pg.cd_fornecedor_usual,   
       pg.id_situacao, 
       pg.id_situacao as id_situacao_anterior,
       pc.nr_matric_alteracao_situacao,
       pc.de_alteracao_situacao,     
       pc.de_alteracao_situacao as de_alteracao_situacao_anterior,
       pg.id_liberado_filial,   
       pg.de_codigo_barras,   
       pg.dh_alteracao_codigo_barras,   
       pg.vl_fator_conversao,   
       round(pc.vl_custo_gerencial * pg.vl_fator_conversao, 2) 'vl_custo_medio',   
       round(pc.vl_custo_gerencial_geral * pg.vl_fator_conversao, 2) 'vl_custo_gerencial',   
       pg.pc_desconto_atual,   
       pg.pc_desconto_futuro,   
       pg.id_preco_bloqueado,   
       pg.pc_ipi,   
       pg.cd_grupo_psico,   
       pg.cd_dcb,   
       pg.cd_origem_produto,   
       pg.id_caderno_abcfarma,   
       pg.pc_reducao_base_icms,   
       pg.cd_produto,   
       pg.nr_matricula_desconto_futuro,   
       pg.nr_matricula_desconto_atual,   
       pg.dh_desconto_atual,   
       pg.dh_desconto_futuro,   
       pg.dh_inclusao_produto,   
       pg.dh_termino_avaliacao,
       pg.id_tipo_desconto_atual,   
       pg.id_tipo_desconto_futuro,
       pg.id_proprio_consignado,
       pg.id_situacao_pis_cofins,
       pg.cd_subcategoria,
       pg.vl_ponto_clube,
       pg.qt_pontos_resgate,
       pg.pc_desconto_clube_atual,
       pg.dh_desconto_clube_atual,
       pg.nr_matric_desc_clube_atual,
       pg.pc_desconto_clube_futuro,
       pg.dh_desconto_clube_futuro,
       pg.nr_matric_desc_clube_futuro,
       pg.id_utiliza_vale_resgate,
       pg.qt_unidades_embalagem,
       pg.qt_concentracao,
       isnull(pg.id_apresentacao, '00') id_apresentacao,
       pg.qt_dias_maximo_tratamento,
       pg.vl_volume,
       pg.cd_fabricante,
       pg.de_registro_ms,
       isnull(pc.id_projeto_conexao, '0') id_projeto_conexao,
       pg.id_recuperacao_vencido,
       pg.de_descricao_internet,
       pg.qt_largura_cm,
       pg.qt_altura_cm,
       pg.qt_profundidade_cm,
       pg.qt_peso_grama,
       isnull(pg.id_liberado_ecommerce, 'N') id_liberado_ecommerce,
       pg.de_principal_internet,
       cp.de_grupo,
       cp.de_subgrupo,
       cp.de_categoria,
       cp.de_subcategoria,
	  '' as de_produto_abcfarma, 
       '' as de_apresentacao_abcfarma, 
       fo.nm_razao_social As nm_fornecedor,
       fa.nm_razao_social As nm_fabricante,   
       dcb.de_dcb,   
       '' As de_produto_localizacao,
       'N' id_foto,
       'N' id_foto_categoria,
       space(10) principal_internet,
       gap.de_grupo as de_grupo_alteracao_preco,
       pc.cd_grupo_alteracao_preco,
       pg.id_farmacia_popular,
       pg.id_gratis_farm_popular,
       pg.cd_planograma,
       pc.id_revisao_fiscal,
       mp.de_marca,
       pg.cd_marca,
       pg.cd_st_origem,
       pg.id_geladeira,
       pc.qt_largura_cm_caixa_forn,   
       pc.qt_altura_cm_caixa_forn,    
       pc.qt_profundidade_cm_caixa_forn,    
       pc.qt_largura_cm_caixa_estoque,    
       pc.qt_altura_cm_caixa_estoque,    
       pc.qt_profund_cm_caixa_estoque,
       pc.cd_bairro_wms,
    	   (Case pc.id_projeto_conexao
			  when null then 'N' 
			  else 'S' End ) as id_conexao,
       (Case pc.id_projeto_conexao
			 when null Then 'NENHUM'
			 Else (select x.de_projeto_conexao from conexao x where x.id_projeto_conexao = pc.id_projeto_conexao)
    	   End) as de_conexao,
       pg.id_exclusivo as id_exclusivo,
       00 nr_divisao_fornecedor,
       pg.cd_unidade_medida_padrao ,
       pg.vl_fator_conversao_padrao,
       pg.id_promover_venda,
       space(40) de_ncm,
       pg.id_permite_devolucao,
       pg.cd_marca_ecommerce,
       me.de_marca,
	  '' as id_controle_preco,
	  ~"~" As nm_pbm,
	 Coalesce(pg.qt_estoque_minimo, 0) As qt_estoque_minimo,
	Coalesce(pg.id_contem_gluten, 'N') As id_contem_gluten,
	Coalesce(pg.id_contem_acucar, 'N') As id_contem_acucar,
	Coalesce(pg.id_contem_lactose, 'N') As id_contem_lactose,
	pg.vl_reembolso_fpb,
	pg.nr_matricula_inclusao,
	pg.cd_cest,
	'' As id_pbm,
	pc.nr_matric_solicitacao_alt_sit,
	us.nm_usuario,
	pc.id_tipo_un_calc_preco,
	pc.qt_peso_apresentacao,
	pg.cd_tipo_prescricao,
	tar.de_tipo_alerta,
	pg.cd_produto_sap,
	pg.id_liberado_filial_sap,
	pc.cd_categoria_ecommerce,
	ce.de_categoria as de_categoria_ecommerce,
		(select ep.cd_sku
			from ecommerce_prd ep
			where ep.cd_produto = pg.cd_produto
			and ep.id_ecommerce = '2'
			and ep.id_rede_filial = 'DC') as cd_sku_dc,
(select ep.cd_sku
			from ecommerce_prd ep
			where ep.cd_produto = pg.cd_produto
			and ep.id_ecommerce = '2'
			and ep.id_rede_filial = 'FA') as cd_sku_fa,
(select ep.cd_sku
			from ecommerce_prd ep
			where ep.cd_produto = pg.cd_produto
			and ep.id_ecommerce = '2'
			and ep.id_rede_filial = 'PP') as cd_sku_pp,
(select ep.cd_sku
			from ecommerce_prd ep
			where ep.cd_produto = pg.cd_produto
			and ep.id_ecommerce = '2'
			and ep.id_rede_filial = 'MP') as cd_sku_mp,
		isnull(pg.id_liberado_ecommerce_dc, 'N') id_liberado_ecommerce_dc,
		isnull(pg.id_liberado_ecommerce_mp, 'N') id_liberado_ecommerce_mp,
		pg.id_liberado_ecommerce_pp,
		pc.cd_categ_mercadologica,
		pg.qt_comprimento,
		pg.de_motivo_registro_ms_isento,
		pg.qt_prazo_reposicao,
		coalesce(mp.id_marca_propria,'N') as id_marca_propria, 
		pg.cd_arvore_mercadologica_sap,
		pc.cd_segmento_ims,
		si.de_segmento,
		pg.cd_area_farmacia,
		af.de_area_farmacia,
		pg.cd_tarja,
		tj.de_tarja,
		pg.cd_cronicidade,
		cr.de_cronicidade,
		gm.cd_grupo as cd_grupo_mercadorias,
		gm.de_grupo as de_grupo_mercadorias,
		Coalesce(pg.id_sem_gtin, 'N') As id_sem_gtin,
		Coalesce(pg.id_farm_gov_bolsa_familia, 'N') As id_farm_gov_bolsa_familia,
		pg.vl_temp_minima,
		pg.vl_temp_maxima,
		coalesce(pg.id_pbm_permite_cobre_preco, 'N') as id_pbm_permite_cobre_preco,
		pc.de_produto_primaria,
		pc.de_produto_secundaria,
		pc.de_texto_legal,
		pc.de_alergenicos,
		pc.id_permite_publicidade,
		pc.id_publi_obriga_texto_legal,
		pc.id_lib_marketing_externo,
		pc.id_lib_marketing_interno,
		paa.de_produto_area_atuacao,
		pa.de_produto_atributo,
		pfe.de_produto_faixa_etaria,
		pp.de_produto_posologia,
		ppr.de_produto_precaucoes,
		ppd.de_produto_publico_dest,
		ps.de_produto_selo,
		ptms.de_produto_texto_min_saude,
		pg.id_contem_corante,
		pg.id_testado_animais,
		pg.id_vegano,
		pc.id_stb,
		pc.de_desc_stb,
		pc.dt_inicio_stb,
		pc.dt_fim_stb
From produto_geral As pg
	Inner Join produto_central As pc
		On pc.cd_produto = pg.cd_produto
	Left Outer Join fabricante As fa
		On fa.cd_fabricante = pg.cd_fabricante
	Left Outer Join fornecedor As fo
		On fo.cd_fornecedor = pg.cd_fornecedor_usual
	Left Outer Join vw_classificacao_produto As cp
		On cp.cd_subcategoria = pg.cd_subcategoria
	Left Outer Join marca_produto As mp
		On mp.cd_marca = pg.cd_marca
	Left Outer Join dcb_produto As dcb
		On dcb.cd_dcb = pg.cd_dcb
	Left Outer Join grupo_alteracao_preco As gap
		On gap.cd_grupo = pc.cd_grupo_alteracao_preco
	Left Outer Join marca_ecommerce As me
		On me.cd_marca = pg.cd_marca_ecommerce
	Left Outer Join usuario As us
		On us.nr_matricula = pc.nr_matric_solicitacao_alt_sit
	Left Outer Join categoria_ecommerce As ce
		On ce.cd_categoria = pc.cd_categoria_ecommerce
	Left Outer Join segmento_ims As si
		On si.cd_segmento = pc.cd_segmento_ims 
	Left Outer Join area_farmacia As af
		On af.cd_area_farmacia = pg.cd_area_farmacia 
	Left Outer Join tarja As tj 
		On tj.cd_tarja = pg.cd_tarja 
	Left Outer Join cronicidade As cr 
		On cr.cd_cronicidade = pg.cd_cronicidade 
	Left Outer Join grupo_mercadorias As gm 
		On gm.cd_grupo  = pg.cd_grupo_mercadoria_sap

	Left Outer Join produto_area_atuacao As paa
		On paa.cd_produto_area_atuacao = pg.cd_produto_area_atuacao

	Left Outer Join produto_atributo As pa
		On pa.cd_produto_atributo = pg.cd_produto_atributo

	Left Outer Join produto_faixa_etaria As pfe
		On pfe.cd_produto_faixa_etaria = pg.cd_produto_faixa_etaria

	Left Outer Join produto_posologia As pp
		On pp.cd_produto_posologia = pg.cd_produto_posologia

	Left Outer Join produto_precaucoes As ppr
		On ppr.cd_produto_precaucoes = pg.cd_produto_precaucoes

	Left Outer Join produto_publico_dest As ppd
		On ppd.cd_produto_publico_dest = pg.cd_produto_publico_dest

	Left Outer Join produto_selo As ps
		On ps.cd_produto_selo = pg.cd_produto_selo

	Left Outer Join produto_texto_min_saude As ptms
		On ptms.cd_produto_texto_min_saude = pg.cd_produto_texto_min_saude

	Left Outer Join tipo_alerta_restricao AS tar
		On tar.cd_tipo_alerta = pg.cd_tipo_alerta_restricao

Where pg.cd_produto = :produto" arguments=(("produto", number)) )
