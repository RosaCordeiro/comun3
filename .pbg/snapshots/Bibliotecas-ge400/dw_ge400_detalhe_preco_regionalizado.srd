table(column=(type=long updatewhereclause=yes name=cd_filial dbname="preco_regionalizado.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_atual dbname="preco_regionalizado.vl_preco_venda_atual" )
 column=(type=datetime updatewhereclause=yes name=dh_preco_venda_atual dbname="preco_regionalizado.dh_preco_venda_atual" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_futuro dbname="preco_regionalizado.vl_preco_venda_futuro" )
 column=(type=datetime updatewhereclause=yes name=dh_preco_venda_futuro dbname="preco_regionalizado.dh_preco_venda_futuro" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_clube_atual dbname="preco_regionalizado.vl_preco_clube_atual" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_clube_futuro dbname="preco_regionalizado.vl_preco_clube_futuro" )
 retrieve="select p.cd_filial,   
       f.nm_fantasia,   
       p.vl_preco_venda_atual,   
       p.dh_preco_venda_atual,   
       p.vl_preco_venda_futuro,   
       p.dh_preco_venda_futuro,
		 p.vl_preco_clube_atual, 
		 p.vl_preco_clube_futuro
from preco_regionalizado p,   
     filial f 
where p.cd_produto = :produto
  and (p.vl_preco_venda_atual > 0 or p.vl_preco_venda_futuro is not null)
  and f.cd_filial = p.cd_filial
" arguments=(("produto", number)) )
