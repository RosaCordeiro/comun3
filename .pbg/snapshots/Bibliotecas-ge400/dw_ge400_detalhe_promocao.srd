table(column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="promocao_sos.cd_promocao_sos" )
 column=(type=char(40) updatewhereclause=yes name=nm_promocao_sos dbname="promocao_sos.nm_promocao_sos" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_promocao dbname="promocao_sos.id_tipo_promocao" values="NORMAL	N/SOS	S/FARMAG.	F/PLANOG.	P/VINC.	V/" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="promocao_sos.id_situacao" values="ELABORA$$HEX2$$c700c300$$ENDHEX$$O	E/LIBERADA	L/	/" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="promocao_sos.dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="promocao_sos.dh_termino" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="promocao_sos_produto.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_clube dbname="promocao_sos_produto.pc_desconto_clube" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="promocao_sos_produto.cd_produto" )
 column=(type=char(10) updatewhereclause=yes name=cd_promocao_sap dbname="promocao_sos.cd_promocao_sap" )
 column=(type=char(2) updatewhereclause=yes name=id_canal_distribuicao dbname="id_canal_distribuicao" )
 retrieve="Select	 Distinct a.cd_promocao_sos,
		a.nm_promocao_sos,
		a.id_tipo_promocao,
		a.id_situacao,
		a.dh_inicio,
		a.dh_termino,
		b.pc_desconto,
		b.pc_desconto_clube,
		b.cd_produto,
	    a.cd_promocao_sap,
	CAse When f.cd_filial in (select er.cd_filial_preco from ecommerce_rede er inner join filial fi on fi.cd_filial = er.cd_filial_preco where er.id_ecommerce = '2' and fi.id_ecommerce = 'S' ) Then 'EC' 
			When a.id_tipo_promocao = 'F' Then 'EC'
			Else 'LF' ENd as id_canal_distribuicao
From promocao_sos As a
	Inner Join promocao_sos_produto As b
		On b.cd_promocao_sos = a.cd_promocao_sos
	Inner Join promocao_sos_filial As f
		On f.cd_promocao_sos = a.cd_promocao_sos
	Inner Join parametro As p
		On p.id_parametro = '1'
Where a.dh_inicio <= p.dh_movimentacao
	And (a.dh_termino >= p.dh_movimentacao Or a.dh_termino Is Null)
	And b.cd_produto = :produto" arguments=(("produto", number)) )
