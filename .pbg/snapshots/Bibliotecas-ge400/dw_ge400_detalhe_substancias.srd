table(column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="composicao_produto.cd_produto" )
 column=(type=long update=yes updatewhereclause=yes name=cd_substancia dbname="composicao_produto.cd_substancia" )
 column=(type=decimal(5) update=yes updatewhereclause=yes name=qt_concentracao dbname="composicao_produto.qt_concentracao" )
 column=(type=char(3) update=yes updatewhereclause=yes name=cd_tipo_concentracao dbname="composicao_produto.cd_tipo_concentracao" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_concentracao dbname="tipo_concentracao.de_tipo_concentracao" )
 column=(type=char(3) update=yes updatewhereclause=yes name=cd_unidade_medida dbname="composicao_produto.cd_unidade_medida" )
 column=(type=char(40) updatewhereclause=yes name=de_unidade_medida dbname="de_unidade_medida" )
 retrieve="  SELECT cp.cd_produto,   
         cp.cd_substancia,   
         cp.qt_concentracao,   
         cp.cd_tipo_concentracao,   
		 tc.de_tipo_concentracao,
         cp.cd_unidade_medida,
		upper(um.de_unidade_medida) as de_unidade_medida
    FROM composicao_produto cp
		inner join tipo_concentracao tc on (tc.cd_tipo_concentracao = cp.cd_tipo_concentracao)
		inner join unidade_medida um on (um.cd_unidade_medida = cp.cd_unidade_medida)
   WHERE cp.cd_produto = :cd_produto    
" arguments=(("cd_produto", number)) )
