table(column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="tipo_comissao_produto_sap.cd_produto" dbalias="t.cd_produto" )
 column=(type=long update=yes updatewhereclause=yes name=cd_tipo_comissao dbname="tipo_comissao_produto_sap.cd_tipo_comissao" dbalias="t.cd_tipo_comissao" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_comissao dbname="tipo_comissao.de_tipo_comissao" dbalias="ti.de_tipo_comissao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inicio dbname="tipo_comissao_produto_sap.dh_inicio" dbalias="t.dh_inicio" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_termino dbname="tipo_comissao_produto_sap.dh_termino" dbalias="t.dh_termino" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_comissao dbname="tipo_comissao_produto_sap.pc_comissao" dbalias="t.pc_comissao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inclusao dbname="tipo_comissao_produto_sap.dh_inclusao" dbalias="t.dh_inclusao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_alteracao dbname="tipo_comissao_produto_sap.dh_alteracao" dbalias="t.dh_alteracao" )
 column=(type=char(8) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 retrieve="SELECT t.cd_produto,   
       t.cd_tipo_comissao,   
       ti.de_tipo_comissao,
       t.dh_inicio,   
       t.dh_termino,   
       t.pc_comissao,   
       t.dh_inclusao,   
       t.dh_alteracao,	   
       CASE 
           WHEN CAST(t.dh_inicio AS date) <= CAST(getdate() AS date) and CAST(t.dh_termino AS date) >= CAST(getdate() AS date) THEN 'VIGENTE'
		  WHEN CAST(getdate() AS date) > CAST(t.dh_termino AS date) THEN 'EXPIRADO'
           ELSE 'FUTURA'
       END AS id_situacao 
FROM tipo_comissao_produto_sap t 
INNER JOIN tipo_comissao ti
    ON ti.cd_tipo_comissao = t.cd_tipo_comissao
WHERE t.cd_produto = :produto
    AND t.cd_tipo_comissao = :tipo_comissao
    //--AND CAST(t.dh_inicio AS date) <= CAST(getdate() AS date)
ORDER BY t.dh_inicio
" arguments=(("produto", number),("tipo_comissao", number)) )
