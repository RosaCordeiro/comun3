table(column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="pg.cd_produto_sap" )
 column=(type=char(1) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(1500) updatewhereclause=yes name=de_alteracao_para dbname="historico_alteracao_tabela.de_alteracao_para" dbalias="hat.de_alteracao_para" )
 column=(type=char(1500) updatewhereclause=yes name=de_alteracao_de dbname="historico_alteracao_tabela.de_alteracao_de" dbalias="hat.de_alteracao_de" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao dbname="historico_alteracao_tabela.dh_alteracao" dbalias="hat.dh_alteracao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_alteracao dbname="historico_alteracao_tabela.nr_matric_alteracao" dbalias="hat.nr_matric_alteracao" )
 column=(type=char(1) updatewhereclause=yes name=nm_responsavel dbname="nm_responsavel" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="vw_classificacao_produto.de_grupo" dbalias="vcp.de_grupo" )
 column=(type=char(6) updatewhereclause=yes name=nr_comprador dbname="usuario.nr_comprador" dbalias="u.nr_comprador" )
 column=(type=char(40) updatewhereclause=yes name=nm_comprador dbname="usuario.nm_comprador" dbalias="u.nm_comprador" )
 retrieve="Select	cast(hat.de_chave as integer) As cd_produto,
		pg.cd_produto_sap,
		'' As de_produto,
		hat.de_alteracao_para,
		hat.de_alteracao_de,
		hat.dh_alteracao,
		hat.nr_matric_alteracao,
		'' As nm_responsavel,
		vcp.de_grupo,
		u.nr_matricula as nr_comprador,
		u.nm_usuario as nm_comprador
From historico_alteracao_tabela hat
left join produto_geral pg on pg.cd_produto = cast(hat.de_chave  as int)
left join produto_central pc on pc.cd_produto = cast(hat.de_chave  as int)
left join usuario u on u.nr_matricula = pc.nr_matricula_comprador
left join vw_classificacao_produto vcp on vcp.cd_subcategoria = pg.cd_subcategoria
Where hat.nm_tabela = 'PRODUTO_GERAL'
	And hat.nm_coluna = 'ID_SITUACAO'
	And hat.dh_alteracao >= :inicio
	And hat.dh_alteracao <= :termino" arguments=(("inicio", datetime),("termino", datetime))  sort="dh_alteracao D " )
