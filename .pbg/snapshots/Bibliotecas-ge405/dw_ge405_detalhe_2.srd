table(column=(type=long updatewhereclause=yes key=yes name=cd_filial dbname="resumo_reposicao_estoque.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_porte dbname="vw_porte_filial.cd_porte" )
 column=(type=char(40) updatewhereclause=yes name=de_porte dbname="vw_porte_filial.de_porte" )
 column=(type=long updatewhereclause=yes key=yes name=cd_produto dbname="resumo_reposicao_estoque.cd_produto" )
 column=(type=long update=yes updatewhereclause=yes name=qt_estoque_base_inicial dbname="resumo_reposicao_estoque.qt_estoque_base_inicial" )
 column=(type=long update=yes updatewhereclause=yes name=qt_estoque_base dbname="resumo_reposicao_estoque.qt_estoque_base" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_definido dbname="resumo_reposicao_estoque.qt_estoque_base_definido" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_alteracao dbname="resumo_reposicao_estoque.dh_alteracao" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_alteracao dbname="resumo_reposicao_estoque.nr_matricula_alteracao" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_alteracao dbname="resumo_reposicao_estoque.id_alteracao" )
 column=(type=char(60) update=yes updatewhereclause=yes name=de_motivo_alteracao dbname="resumo_reposicao_estoque.de_motivo_alteracao" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_demanda_similar dbname="qt_demanda_similar" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_similar dbname="qt_estoque_base_similar" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_similar dbname="cd_classe_similar" )
 retrieve="select r.cd_filial,   
       	f.nm_fantasia,   
		v.cd_porte,
		v.de_porte,
       r.cd_produto,
       r.qt_estoque_base_inicial,   
       r.qt_estoque_base,
       r.qt_estoque_base_definido,
       r.dh_alteracao,
       r.nr_matricula_alteracao,
       r.id_alteracao,
	   r.de_motivo_alteracao,
       0.00 qt_demanda_similar,
       0    qt_estoque_base_similar,
       ''   cd_classe_similar
from resumo_reposicao_estoque r
inner join filial f 					on f.cd_filial        = r.cd_filial
inner join produto_central c on c.cd_produto = r.cd_produto
inner join vw_porte_filial v 	on v.cd_filial = r.cd_filial
where r.cd_produto = :produto
  	and f.id_pedido_centralizado = 'S'
  	and c.cd_mix_produto in (select m.cd_mix_produto
                           from mix_produto_filial m
                           where m.cd_filial = r.cd_filial)" update="resumo_reposicao_estoque" updatewhere=0 updatekeyinplace=no arguments=(("produto", number))  sort="cd_porte A nm_fantasia A " )
