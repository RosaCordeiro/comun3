table(column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="g.cd_produto" )
 column=(type=char(60) update=yes updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="g.de_produto" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="g.de_apresentacao_venda" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="g.vl_fator_conversao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inclusao_produto dbname="produto_geral.dh_inclusao_produto" dbalias="g.dh_inclusao_produto" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_termino_avaliacao dbname="produto_geral.dh_termino_avaliacao" dbalias="g.dh_termino_avaliacao" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao dbname="parametro.dh_movimentacao" dbalias="p.dh_movimentacao" )
 column=(type=char(9) updatewhereclause=yes name=cd_subcategoria dbname="produto_geral.cd_subcategoria" dbalias="g.cd_subcategoria" )
 retrieve="select g.cd_produto,   
       g.de_produto,   
       g.de_apresentacao_venda,
       g.vl_fator_conversao,
       g.dh_inclusao_produto,
       g.dh_termino_avaliacao,
       p.dh_movimentacao,
	  g.cd_subcategoria
from produto_geral g,
     parametro p"  sort="dh_inclusao_produto A de_produto A " )
