table(column=(type=char(20) updatewhereclause=yes name=cd_produto_distribuidora dbname="distribuidora_produto.cd_produto_distribuidora" dbalias="a.cd_produto_distribuidora" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="distribuidora_produto.cd_produto" dbalias="a.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto_relacionado dbname="de_produto_relacionado" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_clamed dbname="produto_geral.id_situacao_clamed" dbalias="x.id_situacao_clamed" values="ATIVO	A/INATIVO	I/PENDENTE	P/BLOQUEADO	B/" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="distribuidora_produto.cd_unidade_federacao" dbalias="a.cd_unidade_federacao" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras_arquivo_preco dbname="distribuidora_produto.de_codigo_barras_arquivo_preco" dbalias="a.de_codigo_barras_arquivo_preco" )
 column=(type=long updatewhereclause=yes name=cd_produto_ref_ean dbname="codigo_barras_produto.cd_produto_ref_ean" dbalias="c.cd_produto_ref_ean" )
 column=(type=char(103) updatewhereclause=yes name=de_produto_ref_ean dbname="de_produto_ref_ean" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_dist dbname="distribuidora_produto.id_situacao_dist" dbalias="a.id_situacao_dist" values="ATIVO	A/INATIVO	I/PENDENTE	P/BLOQUEADO	B/" )
 column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="distribuidora_produto.cd_distribuidora" dbalias="a.cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionado dbname="id_selecionado" initial="N" values="	S/	N" )
 retrieve="Select	a.cd_produto_distribuidora,
		a.cd_produto,
		x.de_produto || ' : ' || x.de_apresentacao_estoque As de_produto_relacionado,
		x.id_situacao As id_situacao_clamed,
		a.cd_unidade_federacao,
		a.de_codigo_barras_arquivo_preco,
		c.cd_produto As cd_produto_ref_ean,
		g.de_produto || ' : ' || g.de_apresentacao_estoque As de_produto_ref_ean,
		a.id_situacao As id_situacao_dist,
		a.cd_distribuidora,
		f.nm_fantasia,
		'N' As id_selecionado
From distribuidora_produto As a
	Inner Join codigo_barras_produto c
		On c.de_codigo_barras = a.de_codigo_barras_arquivo_preco
	Inner Join produto_geral As g
		On g.cd_produto = c.cd_produto                                                                                                                                                                              
	Inner Join produto_geral As x
		On x.cd_produto = a.cd_produto
	Inner Join fornecedor As f
		On f.cd_fornecedor = a.cd_distribuidora
	Inner Join distribuidora_uf As u
		On u.cd_distribuidora = a.cd_distribuidora
		And u.cd_unidade_federacao = a.cd_unidade_federacao
Where a.de_codigo_barras_arquivo_preco Is Not Null
    And c.cd_produto <> a.cd_produto
	And f.id_distribuidora = 'S'

Union All

Select	a.cd_produto_distribuidora,
		null as cd_produto,
		'' As de_produto_relacionado,
		'' As id_situacao_clamed,
		a.cd_unidade_federacao,
		a.de_codigo_barras_arquivo_preco,
		a.cd_produto As cd_produto_ref_ean,
		x.de_produto || ' : ' || x.de_apresentacao_estoque As de_produto_ref_ean,
		a.id_situacao As id_situacao_dist,
		a.cd_distribuidora,
		f.nm_fantasia,
		'N' As id_selecionado 
From distribuidora_produto a
	Inner Join produto_geral x
		On x.cd_produto = a.cd_produto
	Inner Join fornecedor f
		On f.cd_fornecedor = a.cd_distribuidora
	Inner Join distribuidora_uf As u
		On u.cd_distribuidora = a.cd_distribuidora
		And u.cd_unidade_federacao = a.cd_unidade_federacao
Where a.de_codigo_barras_arquivo_preco Is Not Null
    And f.id_distribuidora = 'S'
	and not exists(select 1 from codigo_barras_produto cbp where cbp.de_codigo_barras = a.de_codigo_barras_arquivo_preco)
	and a.id_situacao = 'B'
	and a.de_alteracao_situacao = 'BLOQUEIO AUT. [EAN SEM CADASTRO CLAMED]'
	"  sort="nm_fantasia A de_produto_relacionado A de_produto_ref_ean A cd_unidade_federacao A " )
