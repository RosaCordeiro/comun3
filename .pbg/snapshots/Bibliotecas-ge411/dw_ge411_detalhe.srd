 retrieve="Select	f.cd_mix_produto,
		p.de_mix_produto
From mix_produto As p
	Inner Join mix_produto_filial As f
		On f.cd_mix_produto = p.cd_mix_produto
Where f.cd_filial = :filial
Order By p.de_mix_produto" arguments=(("filial", number)) )
