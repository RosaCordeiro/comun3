table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="documento_regulatorio_filial.cd_filial" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_tipo_documento dbname="documento_regulatorio_filial.cd_tipo_documento" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_vencimento dbname="documento_regulatorio_filial.dh_vencimento" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_protocolo dbname="id_protocolo" initial="N" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_taxa dbname="id_taxa" initial="N" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_psico dbname="id_psico" initial="N" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_alteracao dbname="documento_regulatorio_filial.nr_matricula_alteracao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_alteracao dbname="documento_regulatorio_filial.dh_alteracao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_vencimento_protocolo dbname="documento_regulatorio_filial.dh_vencimento_protocolo" )
 retrieve="Select	cd_filial,
		cd_tipo_documento,
		dh_vencimento,
		Coalesce(id_protocolo, 'N') As id_protocolo,
		Coalesce(id_taxa, 'N') As id_taxa,
		Coalesce(id_psico, 'N') As id_psico,
		nr_matricula_alteracao,
		dh_alteracao,
		dh_vencimento_protocolo
From documento_regulatorio_filial
Where cd_filial = :filial
And cd_tipo_documento = :tipo" update="documento_regulatorio_filial" updatewhere=0 updatekeyinplace=no arguments=(("filial", number),("tipo", number)) )
