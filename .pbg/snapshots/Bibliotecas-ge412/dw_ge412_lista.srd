table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="filial.nr_cgc" )
 column=(type=char(40) updatewhereclause=yes name=nm_gerente dbname="usuario.nm_gerente" )
 column=(type=datetime updatewhereclause=yes name=alvara_sanitario_vcto dbname="alvara_sanitario_vcto" )
 column=(type=char(1) updatewhereclause=yes name=alvara_protocolo dbname="alvara_protocolo" )
 column=(type=char(1) updatewhereclause=yes name=alvara_taxa dbname="alvara_taxa" )
 column=(type=char(1) updatewhereclause=yes name=psico dbname="psico" )
 column=(type=datetime updatewhereclause=yes name=crf_vcto dbname="crf_vcto" )
 column=(type=char(1) updatewhereclause=yes name=crf_protocolo dbname="crf_protocolo" )
 column=(type=char(1) updatewhereclause=yes name=crf_taxa dbname="crf_taxa" )
 column=(type=datetime updatewhereclause=yes name=afe_vcto dbname="afe_vcto" )
 column=(type=char(1) updatewhereclause=yes name=afe_protocolo dbname="afe_protocolo" )
 column=(type=char(1) updatewhereclause=yes name=afe_taxa dbname="afe_taxa" )
 column=(type=datetime updatewhereclause=yes name=isotretinoina_vcto dbname="isotretinoina_vcto" )
 retrieve="select 	f.cd_filial,
			f.nm_fantasia,
			f.nr_cgc,
			u.nm_usuario as nm_gerente, 
			(select a.dh_vencimento 
				from documento_regulatorio_filial a
			where a.cd_filial = f.cd_filial
				and a.cd_tipo_documento = 1) as alvara_sanitario_vcto,
			coalesce((select a.id_protocolo 
				from documento_regulatorio_filial a
			where a.cd_filial = f.cd_filial
				and a.cd_tipo_documento = 1), 'N') as alvara_protocolo,
			coalesce((select a.id_taxa
				from documento_regulatorio_filial a
			where a.cd_filial = f.cd_filial
				and a.cd_tipo_documento = 1), 'N') as alvara_taxa,
			coalesce((select a.id_psico
				from documento_regulatorio_filial a
			where a.cd_filial = f.cd_filial
				and a.cd_tipo_documento = 1), 'N') as psico,
			(select a.dh_vencimento 
				from documento_regulatorio_filial a
			where a.cd_filial = f.cd_filial
				and a.cd_tipo_documento = 2) as crf_vcto,
			coalesce((select a.id_protocolo 
				from documento_regulatorio_filial a
			where a.cd_filial = f.cd_filial
				and a.cd_tipo_documento = 2), 'N') as crf_protocolo,
			coalesce((select a.id_taxa
				from documento_regulatorio_filial a
			where a.cd_filial = f.cd_filial
				and a.cd_tipo_documento = 2), 'N') as crf_taxa,
			(select a.dh_vencimento 
				from documento_regulatorio_filial a
			where a.cd_filial = f.cd_filial
				and a.cd_tipo_documento = 3) as afe_vcto,
			coalesce((select a.id_protocolo 
				from documento_regulatorio_filial a
			where a.cd_filial = f.cd_filial
				and a.cd_tipo_documento = 3), 'N') as afe_protocolo,
			coalesce((select a.id_taxa
				from documento_regulatorio_filial a
			where a.cd_filial = f.cd_filial
				and a.cd_tipo_documento = 3), 'N') as afe_taxa,
			(select a.dh_vencimento 
				from documento_regulatorio_filial a
			where a.cd_filial = f.cd_filial
				and a.cd_tipo_documento = 4) as isotretinoina_vcto
from filial f
left outer join usuario u
	on u.nr_matricula = f.nr_matricula_gerente
where f.cd_filial Not In (534, 1, 2)
and f.id_situacao = 'A'
order by f.nm_fantasia" )
