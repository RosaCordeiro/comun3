 column=(type=datetime updatewhereclause=yes name=dh_inicio_periodo_2 dbname="parametro_reposicao_estoque.dh_inicio_periodo_2" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_periodo_2 dbname="parametro_reposicao_estoque.dh_termino_periodo_2" )
