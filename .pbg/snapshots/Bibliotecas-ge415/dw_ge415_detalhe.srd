 column=(type=datetime updatewhereclause=yes name=dh_termino_periodo_3 dbname="parametro_reposicao_estoque.dh_termino_periodo_3" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio_periodo_4 dbname="parametro_reposicao_estoque.dh_inicio_periodo_4" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_periodo_4 dbname="parametro_reposicao_estoque.dh_termino_periodo_4" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio_periodo_5 dbname="parametro_reposicao_estoque.dh_inicio_periodo_5" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_periodo_5 dbname="parametro_reposicao_estoque.dh_termino_periodo_5" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio_periodo_6 dbname="parametro_reposicao_estoque.dh_inicio_periodo_6" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_periodo_6 dbname="parametro_reposicao_estoque.dh_termino_periodo_6" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_inclusao dbname="nm_usuario_inclusao" )
 retrieve="Select	r.qt_venda_periodo_1,
		r.qt_venda_periodo_2,
		r.qt_venda_periodo_3,
		r.qt_venda_periodo_4,
		r.qt_venda_periodo_5,
		r.qt_venda_periodo_6,
		r.cd_classe_reposicao,
		r.qt_demanda_diaria,
		r.qt_estoque_calculado,
		r.qt_estoque_base,
		r.qt_estoque_minimo,
		p.dh_inicio_periodo_1,
		p.dh_termino_periodo_1,
		p.dh_inicio_periodo_2,
		p.dh_termino_periodo_2,
		p.dh_inicio_periodo_3,
		p.dh_termino_periodo_3,
		p.dh_inicio_periodo_4,
		p.dh_termino_periodo_4,
		p.dh_inicio_periodo_5,
		p.dh_termino_periodo_5,
		p.dh_inicio_periodo_6,
		p.dh_termino_periodo_6,
		space(40) as nm_usuario_inclusao
From resumo_reposicao_estoque As r
	Inner Join parametro_reposicao_estoque As p
		On p.cd_filial = r.cd_filial
	   And p.id_tipo_reposicao = r.id_tipo_reposicao
Where r.cd_filial  = :filial
	And r.cd_produto = :produto" arguments=(("filial", number),("produto", number)) )
