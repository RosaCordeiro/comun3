table(column=(type=long updatewhereclause=yes name=nr_pedido_empurrado dbname="pedido_empurrado_produto.nr_pedido_empurrado" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_empurrado.dh_emissao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_empurrado_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_empurrada dbname="pedido_empurrado_produto.qt_empurrada" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="pedido_empurrado_produto.qt_faturada" )
 retrieve="
SELECT
    b.nr_pedido_empurrado,
	a.dh_emissao,
    b.cd_produto,
    c.de_produto + ' : ' + c.de_apresentacao_estoque de_produto,
    b.qt_empurrada,
    b.qt_faturada
FROM
         pedido_empurrado_produto b
    INNER JOIN pedido_empurrado a ON a.cd_filial = b.cd_filial
                                     AND a.nr_pedido_empurrado = b.nr_pedido_empurrado
    INNER JOIN produto_geral    c ON c.cd_produto = b.cd_produto
WHERE
        b.cd_filial = :a_filial
    AND b.cd_produto in (:a_produto)
    AND b.id_situacao = 'C'
    AND a.id_processado = 'S'
    AND ( a.id_tipo_pedido IS NULL
          OR a.id_tipo_pedido = 'E' )" arguments=(("a_Produto", number),("a_Filial", number)) )
