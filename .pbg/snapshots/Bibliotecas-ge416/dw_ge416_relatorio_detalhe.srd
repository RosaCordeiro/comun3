table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="produto_geral.cd_fornecedor_usual" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bruto dbname="vl_bruto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto dbname="vl_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_liquido dbname="vl_liquido" )
 retrieve="  SELECT p.cd_fornecedor_usual,
	     f.nm_razao_social,
		 Sum(i.qt_faturada * i.vl_preco_unitario) vl_bruto,
         0.00 vl_desconto,
		 0.00 pc_desconto,
         Sum(i.qt_faturada * Round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2)) vl_liquido
    FROM item_nf_compra i,   
         nf_compra n,   
         produto_geral p,   
         fornecedor f
   WHERE n.cd_filial     	     = i.cd_filial 
	 and n.cd_fornecedor 	     = i.cd_fornecedor 
	 and n.nr_nf 		 	     = i.nr_nf 
	 and n.de_especie 	 	     = i.de_especie 
	 and n.de_serie 	 	     = i.de_serie 
 	 and p.cd_produto 	 	     = i.cd_produto 
	 and p.cd_fornecedor_usual   = f.cd_fornecedor
     and n.cd_fornecedor 	     = :cd_fornecedor
     and n.dh_movimentacao_caixa between :dt_inicio and :dt_fim
group by p.cd_fornecedor_usual, f.nm_razao_social
    


" arguments=(("dt_inicio", date),("dt_fim", date),("cd_fornecedor", string))  sort="nm_razao_social A " )
