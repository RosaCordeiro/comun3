table(column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="cd_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="grupo.de_grupo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bruto dbname="vl_bruto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto dbname="vl_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_liquido dbname="vl_liquido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 retrieve="select substring(p.cd_subcategoria, 1, 1) as cd_grupo,
       g.de_grupo,
       0.00 vl_bruto,
       0.00 vl_desconto,
       0.00 pc_desconto,
       sum(n.vl_total_produtos - n.vl_desconto) vl_liquido,
       sum(n.vl_icms_st) vl_icms_st,
       sum(n.vl_total_nf) vl_total_nf
from nf_compra n,
     item_nf_compra i,
     produto_geral p,
     grupo g
where n.dh_movimentacao_caixa between :inicio and :termino
  and i.cd_filial       = n.cd_filial
  and i.cd_fornecedor   = n.cd_fornecedor
  and i.nr_nf           = n.nr_nf
  and i.de_especie      = n.de_especie
  and i.de_serie        = n.de_serie
  and p.cd_produto      = i.cd_produto
  and g.cd_grupo        = substring(p.cd_subcategoria, 1, 1)
group by substring(p.cd_subcategoria, 1, 1),
         g.de_grupo" arguments=(("inicio", date),("termino", date)) )
