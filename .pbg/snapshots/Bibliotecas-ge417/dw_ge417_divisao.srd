table(column=(type=char(9) update=yes updatewhereclause=yes name=cd_fornecedor dbname="fornecedor_divisao.cd_fornecedor" )
 column=(type=long update=yes updatewhereclause=yes name=nr_divisao dbname="fornecedor_divisao.nr_divisao" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_divisao dbname="fornecedor_divisao.nm_divisao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=char(40) updatewhereclause=yes name=de_condicao dbname="condicao_pagamento.de_condicao" )
 retrieve="SELECT	f.cd_fornecedor,   
         	f.nr_divisao,   
         	f.nm_divisao,   
        		u.nm_usuario,
			c.de_condicao
FROM fornecedor_divisao f  
inner join usuario u 
		on u.nr_matricula = f.nr_matricula_comprador
left outer join condicao_pagamento c
			on c.cd_condicao = f.cd_condicao_pagamento
where f.cd_fornecedor = :fornecedor
" arguments=(("fornecedor", string)) )
