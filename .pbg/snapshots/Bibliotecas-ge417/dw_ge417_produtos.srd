table(column=(type=long update=yes updatewhereclause=yes key=yes name=nr_divisao dbname="fornecedor_divisao_produto.nr_divisao" )
 column=(type=char(9) update=yes updatewhereclause=yes key=yes name=cd_fornecedor dbname="fornecedor_divisao_produto.cd_fornecedor" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="fornecedor_divisao_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(8) updatewhereclause=yes name=de_situacao dbname="de_situacao" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_divergencia dbname="id_divergencia" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionado dbname="id_selecionado" initial="N" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=de_divergencia dbname="de_divergencia" )
 retrieve="select 	p.nr_divisao,
			p.cd_fornecedor,
			p.cd_produto, 
			g.de_produto + ' : ' + g.de_apresentacao_estoque de_produto,
			( CASE g.id_situacao WHEN 'A' then 'ATIVO' WHEN 'I' then 'INATIVO' ELSE 'PENDENTE' END ) as de_situacao,
			'N' id_selecionar,
			'' id_divergencia,
			'N' id_selecionado,
			'' de_divergencia
from fornecedor_divisao_produto p
inner join produto_geral g on g.cd_produto = p.cd_produto
where p.cd_fornecedor = :fornecedor
	and p.nr_divisao = :divisao
order by g.de_produto, g.de_apresentacao_estoque" update="fornecedor_divisao_produto" updatewhere=0 updatekeyinplace=no arguments=(("fornecedor", string),("divisao", number))  sort="de_produto A " )
