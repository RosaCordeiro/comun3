 retrieve="  SELECT cd_promocao_sos,   
         nm_promocao_sos,   
         dh_inicio,   
         dh_termino 
    FROM promocao_sos
   WHERE id_situacao = 'L'
     and id_tipo_promocao = 'N'    
" update="promocao_sos" updatewhere=1 updatekeyinplace=no  sort="cd_promocao_sos D " )
