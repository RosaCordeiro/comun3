table(column=(type=char(44) updatewhereclause=yes name=regiao dbname="Regiao" )
 column=(type=char(47) updatewhereclause=yes name=filial dbname="Filial" )
 column=(type=long updatewhereclause=yes name=produto_geral_codigo dbname="produto_geral.Codigo" )
 column=(type=char(60) updatewhereclause=yes name=produto_geral_descricao dbname="produto_geral.Descricao" )
 column=(type=char(40) updatewhereclause=yes name=produto_geral_apresentacao dbname="produto_geral.Apresentacao" )
 column=(type=char(7) updatewhereclause=yes name=data_resumo dbname="Data_Resumo" )
 column=(type=decimal(2) updatewhereclause=yes name=custo dbname="produto_central.Custo" )
 column=(type=decimal(13) updatewhereclause=yes name=venda dbname="Venda" )
 column=(type=char(40) updatewhereclause=yes name=fornecedor_desc_fornecedor dbname="fornecedor.Desc_Fornecedor" )
 column=(type=char(9) updatewhereclause=yes name=produto_geral_cod_fornecedor dbname="produto_geral.Cod_Fornecedor" )
 column=(type=long updatewhereclause=yes name=vendas dbname="Vendas" )
 column=(type=long updatewhereclause=yes name=devolucao dbname="Devolucao" )
 retrieve="SELECT Convert (Char(1),rg.cd_regiao) + ' - ' +  rg.de_regiao Regiao,
	    Convert (Char(4),fl.cd_filial) + ' - ' +  fl.nm_fantasia Filial,
       pg.cd_produto Codigo,
       pg.de_produto Descricao,
       pg.de_apresentacao_venda Apresentacao,
       Convert (Char(2),rm.dh_resumo, 101) + '/' + Convert (Char(4),rm.dh_resumo, 102)  Data_Resumo,
       pc.vl_custo_gerencial Custo,
       pg.vl_preco_venda_atual / vl_fator_conversao Venda,
       f.nm_razao_social Desc_Fornecedor,
       pg.cd_fornecedor_usual Cod_Fornecedor,
       sum(rm.qt_venda) Vendas,
       sum(rm.qt_devolucao_venda) Devolucao
  FROM produto_geral pg,
		 produto_central pc,
       regiao rg,
       resumo_movto_estq_prd rm,
       filial fl,
       promocao_sos pm,
       promocao_sos_filial pf,
       promocao_sos_produto pp, 
       fornecedor f
 WHERE f.cd_fornecedor    = pg.cd_fornecedor_usual
   and pg.cd_produto      = rm.cd_produto 
   and pg.cd_produto      = pp.cd_produto
   and rg.cd_regiao       = fl.cd_regiao 
   and fl.cd_filial       = rm.cd_filial 
   and fl.cd_filial       = pf.cd_filial
   and pf.cd_promocao_sos = pm.cd_promocao_sos 
   and pp.cd_promocao_sos = pm.cd_promocao_sos 
   and rm.dh_resumo       between :data_inicio and :data_fim 
   and pm.cd_promocao_sos = :numero
   and pc.cd_produto      = pg.cd_produto
Group By Convert (Char(1),rg.cd_regiao) + ' - ' +  rg.de_regiao,
         Convert (Char(4),fl.cd_filial) + ' - ' +  fl.nm_fantasia,
			pg.cd_produto,
			pg.de_produto,
			pg.de_apresentacao_venda,
         Convert (Char(2),rm.dh_resumo, 101) + '/' + Convert (Char(4),rm.dh_resumo, 102),
			pc.vl_custo_gerencial,
			pg.vl_preco_venda_atual / vl_fator_conversao,
         f.nm_razao_social,
			pg.cd_fornecedor_usual" arguments=(("numero", number),("data_inicio", datetime),("data_fim", datetime)) )
