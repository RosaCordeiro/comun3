table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_perfil_filial dbname="filial.cd_perfil_filial" )
 column=(type=char(40) updatewhereclause=yes name=de_perfil_filial dbname="perfil_filial.de_perfil_filial" )
 column=(type=long updatewhereclause=yes name=qt_empurrada dbname="qt_empurrada" )
 column=(type=char(1) updatewhereclause=yes name=id_possui_mix dbname="id_possui_mix" )
 retrieve="select f.cd_filial,   
       f.nm_fantasia,
       f.cd_perfil_filial,
       p.de_perfil_filial,   
       0 qt_empurrada,
       'S' id_possui_mix  
from filial f,
     perfil_filial p
where f.id_situacao = 'A'
  and f.cd_filial in (select cd_filial 
                      from produto_central c,
                           mix_produto_filial m
						    where c.cd_produto = :produto
                        and m.cd_mix_produto = c.cd_mix_produto)
  and p.cd_perfil_filial = f.cd_perfil_filial

union

select f.cd_filial,   
       f.nm_fantasia,
       f.cd_perfil_filial,
       p.de_perfil_filial,   
       0 qt_empurrada,
       'N' id_possui_mix  
from filial f,
     perfil_filial p
where f.id_situacao = 'A'
  and f.cd_filial not in (select cd_filial 
								  from produto_central c,
										 mix_produto_filial m
								  where c.cd_produto = :produto
									 and m.cd_mix_produto = c.cd_mix_produto)
  and p.cd_perfil_filial = f.cd_perfil_filial
" arguments=(("produto", number))  sort="cd_perfil_filial A nm_fantasia A " )
