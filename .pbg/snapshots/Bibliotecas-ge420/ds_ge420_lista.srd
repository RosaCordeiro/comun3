table(column=(type=long updatewhereclause=yes name=cd_filial dbname="vw_saldo_atual_produto.cd_filial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="vw_saldo_atual_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="grupo.de_grupo" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="vw_saldo_atual_produto.qt_saldo_final" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_medio dbname="vw_saldo_atual_produto.vl_custo_medio" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" )
 retrieve="select v.cd_filial, 
		v.cd_produto, 
		g.de_produto + ' : ' + g.de_apresentacao_venda as de_produto,
		p.de_grupo,
		v.qt_saldo_final, 
		v.vl_custo_medio, 
		g.vl_fator_conversao,
		g.id_situacao
 from vw_saldo_atual_produto v
inner join produto_geral g
    on g.cd_produto = v.cd_produto
inner join vw_filial f
	on f.cd_filial = v.cd_filial
inner join grupo p
	on p.cd_grupo = Cast(g.cd_grupo_produto as varchar)
where v.cd_filial <> 534
and g.id_situacao = 'A'
and g.cd_produto_sap is not null
and v.qt_saldo_final > 0
and not exists (
    select * from resumo_movto_estq_prd r
    where r.cd_produto = v.cd_produto
    and r.cd_filial = v.cd_filial
    and r.dh_resumo >= :periodo)

union

select r.cd_filial, 
		r.cd_produto,
		g.de_produto + ' : ' + g.de_apresentacao_venda as de_produto,
		p.de_grupo,
		v.qt_saldo_final, 
		v.vl_custo_medio, 
		g.vl_fator_conversao,
		g.id_situacao
 from resumo_movto_estq_prd r
    inner join produto_geral g
        on g.cd_produto = r.cd_produto
    inner join vw_saldo_atual_produto v
        on v.cd_filial         		= r.cd_filial
         and v.cd_produto     	= r.cd_produto
	inner join vw_filial f
		on f.cd_filial = v.cd_filial
	inner join grupo p
		on p.cd_grupo = Cast(g.cd_grupo_produto as varchar)
 where r.dh_resumo >= :periodo       
and v.cd_filial <> 534
and g.id_situacao = 'A'
and v.qt_saldo_final > 0
and g.cd_produto_sap is not null
group by r.cd_filial, r.cd_produto, g.de_produto + ' : ' + g.de_apresentacao_venda,  p.de_grupo, v.qt_saldo_final, v.vl_custo_medio, g.vl_fator_conversao, g.id_situacao
  having sum(r.qt_venda) = 0

" arguments=(("periodo", date))  sort="cd_filial A de_produto A " )
