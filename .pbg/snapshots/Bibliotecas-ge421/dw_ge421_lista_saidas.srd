table(column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_transferencia.cd_filial_origem" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="vw_classificacao_produto.cd_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="vw_classificacao_produto.de_grupo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_saidas dbname="vl_saidas" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_entradas dbname="vl_entradas" )
 retrieve="select n.cd_filial_origem,
       f.nm_fantasia,
       w.cd_grupo,
       w.de_grupo,
       sum(round(i.qt_transferida * i.vl_custo_unitario, 2)) vl_saidas,
       0.00 vl_entradas
from nf_transferencia n,
     item_nf_transferencia i,
     filial f,
     produto_geral g,
     vw_classificacao_produto w
where n.dh_movimentacao_caixa between :dt_inicio and :dt_termino
  and n.dh_cancelamento         is null
  and n.nr_pedido_distribuidora is null
  and i.cd_filial_origem = n.cd_filial_origem
  and i.nr_nf            = n.nr_nf
  and i.de_especie       = n.de_especie
  and i.de_serie         = n.de_serie
  and f.cd_filial        = n.cd_filial_origem
  and g.cd_produto       = i.cd_produto
  and w.cd_subcategoria  = g.cd_subcategoria
group by n.cd_filial_origem,
         f.nm_fantasia,
         w.cd_grupo,
         w.de_grupo" arguments=(("dt_inicio", date),("dt_termino", date))  sort="nm_fantasia A cd_grupo A " )
