table(column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=produto dbname="produto" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao dbname="historico_produto_conexao.dh_alteracao" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao dbname="historico_produto_conexao.id_alteracao" values="INCLUS$$HEX1$$c300$$ENDHEX$$O	I/EXCLUS$$HEX1$$c300$$ENDHEX$$O	E/" )
 retrieve="Select	 Top 10	g.cd_produto,	
					g.de_produto || ' : ' || de_apresentacao_venda As produto,
					h.dh_alteracao,
					h.id_alteracao
From historico_produto_conexao As h
	Inner Join produto_geral As g
		On g.cd_produto = h.cd_produto
Where h.cd_produto = :produto
Order By h.dh_alteracao desc" arguments=(("produto", number)) )
