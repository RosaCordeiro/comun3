table(column=(type=char(9) updatewhereclause=yes name=cd_laboratorio dbname="produto_geral.cd_laboratorio" )
 column=(type=long updatewhereclause=yes key=yes name=cd_produto dbname="produto_central.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_marcado_anterior dbname="id_marcado_anterior" )
 column=(type=char(1) updatewhereclause=yes name=id_marcado dbname="id_marcado" values="	S/	N" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto_conexao dbname="pc_desconto_conexao" )
 retrieve="select p.cd_fornecedor_usual as cd_laboratorio,
		 c.cd_produto,
		 p.de_produto + ' : ' + p.de_apresentacao_estoque as de_produto,
		 'N' as id_marcado_anterior,
		 'N' as id_marcado,
		 coalesce(c.pc_desconto_conexao, 0.00) pc_desconto_conexao
from produto_geral p
inner join produto_central c on c.cd_produto = p.cd_produto
where p.cd_fornecedor_usual = :laboratorio
	and p.id_situacao = 'A'
Order by 4" update="produto_central" updatewhere=0 updatekeyinplace=no arguments=(("laboratorio", string))  sort="de_produto A " )
