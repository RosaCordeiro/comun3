table(column=(type=long updatewhereclause=yes name=cd_filial dbname="parametro_reposicao_estoque.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="vw_filial.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_calculo dbname="parametro_reposicao_estoque.dh_termino_calculo" )
 column=(type=datetime updatewhereclause=yes name=dh_proximo_calculo dbname="parametro_reposicao_estoque.dh_proximo_calculo" )
 column=(type=char(1) updatewhereclause=yes name=id_reduz_estoque_base dbname="id_reduz_estoque_base" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_reduz_estoque_base_ant dbname="id_reduz_estoque_base_ant" )
 column=(type=char(1) updatewhereclause=yes name=id_abre_domingo dbname="vw_filial.id_abre_domingo" )
 column=(type=long updatewhereclause=yes name=qt_dias_movimento dbname="qt_dias_movimento" )
 column=(type=char(1) updatewhereclause=yes name=id_selecao dbname="id_selecao" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_reduz dbname="id_reduz" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio_movimento_calculo_eb dbname="filial.dh_inicio_movimento_calculo_eb" )
 column=(type=char(2) updatewhereclause=yes name=id_rede dbname="vw_filial.id_rede" )
 column=(type=char(3) updatewhereclause=yes name=id_novo_calculo dbname="id_novo_calculo" )
 retrieve="select p.cd_filial,   
       	f.nm_fantasia,   
       	p.dh_termino_calculo,   
       	p.dh_proximo_calculo,
		isnull(p.id_reduz_estoque_base, 'N') id_reduz_estoque_base,
		isnull(p.id_reduz_estoque_base, 'N') id_reduz_estoque_base_ant,
		f.id_abre_domingo,
		coalesce(qt_dias_movimento, 0) qt_dias_movimento,
       	'N' id_selecao,
		'Z' id_reduz,
		fi.dh_inicio_movimento_calculo_eb,
		f.id_rede,
		coalesce((select (Case when pl.vl_parametro = 'S' Then 'SIM' else 'N$$HEX1$$c300$$ENDHEX$$O' END) from parametro_loja pl
		where pl.cd_filial = f.cd_filial
		  and pl.cd_parametro = 'ID_UTILIZA_NOVO_CALCULO_ESTOQUE_BASE'), 'N$$HEX1$$c300$$ENDHEX$$O') as id_novo_calculo
from parametro_reposicao_estoque p
inner join vw_filial f
	on f.cd_filial = p.cd_filial
inner join filial fi 
	on fi.cd_filial = f.cd_filial
where p.id_tipo_reposicao 	= 'E'
  	and p.cd_filial 				<= 1000
  	and fi.cd_perfil_estoque in (select cd_perfil_estoque from cobertura_estoque_filial)

"  sort="id_reduz_estoque_base A cd_filial A " )
