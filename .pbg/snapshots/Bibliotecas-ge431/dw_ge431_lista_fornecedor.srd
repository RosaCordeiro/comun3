table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="fornecedor.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" )
 column=(type=long updatewhereclause=yes name=qt_atendida dbname="qt_atendida" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="qt_recebida" )
 column=(type=long updatewhereclause=yes name=qt_falta dbname="qt_falta" )
 retrieve=" select 	c.cd_fornecedor,
			c.nm_fantasia,
			d.cd_unidade_federacao, 
			sum(b.qt_atendida) qt_atendida, 
			sum(b.qt_faturada) qt_recebida,
			sum(b.qt_atendida) - sum(b.qt_faturada) as qt_falta
from pedido_distribuidora a 
inner join pedido_distribuidora_produto b on  b.cd_filial  = a.cd_filial
  														and b.nr_pedido_distribuidora = a.nr_pedido_distribuidora
  														and b.qt_faturada < b.qt_atendida 

inner join fornecedor c on c.cd_fornecedor = a.cd_distribuidora 
left join cidade d on d.cd_cidade = c.cd_cidade 
where a.dh_emissao between :dt_inicio and :dt_fim
  and a.id_situacao = 'F'
  and a.nr_pedido_conexao is null 
group by  c.cd_fornecedor,
			 c.nm_fantasia,
			 d.cd_unidade_federacao 
order by  c.nm_fantasia
" arguments=(("dt_inicio", date),("dt_fim", date)) )
