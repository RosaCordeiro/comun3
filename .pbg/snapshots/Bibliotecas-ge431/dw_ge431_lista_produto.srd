table(column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_distribuidora_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_atendida dbname="qt_atendida" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="qt_recebida" )
 column=(type=long updatewhereclause=yes name=qt_falta dbname="qt_falta" )
 retrieve="select 	pp.cd_produto, 
			g.de_produto + ' : ' + g.de_apresentacao_estoque as de_produto, 
			sum(pp.qt_atendida) as qt_atendida, 
			sum(pp.qt_faturada) as qt_recebida,
			sum(pp.qt_atendida) - sum(pp.qt_faturada) as qt_falta
from pedido_distribuidora p
inner join pedido_distribuidora_produto pp   on pp.cd_filial  = p.cd_filial
														  and pp.nr_pedido_distribuidora = p.nr_pedido_distribuidora
														  and pp.qt_faturada < pp.qt_atendida 
inner join produto_geral g on g.cd_produto		= pp.cd_produto

where p.cd_distribuidora =  :cd_distribuidora
  and p.dh_emissao between  :dt_inicio and :dt_fim
  and p.id_situacao = 'F'
  and p.nr_pedido_conexao is null  
group by pp.cd_produto,
			g.de_produto,
			g.de_apresentacao_estoque
order by g.de_produto
" arguments=(("cd_distribuidora", string),("dt_inicio", date),("dt_fim", date)) )
