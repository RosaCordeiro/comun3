table(column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_central.nr_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_pedido dbname="pedido_central.dh_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_previsao_entrega dbname="pedido_central.dh_previsao_entrega" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="fornecedor.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=decimal(2) updatewhereclause=yes name=total_pedido dbname="pedido_central.vl_total_pedido" )
 column=(type=char(1) updatewhereclause=yes name=id_programado dbname="pedido_central.id_programado" values="PRG	S/	N/" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula dbname="usuario.nr_matricula" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=qt_dias_atraso dbname="qt_dias_atraso" )
 column=(type=char(1) updatewhereclause=yes name=pbm dbname="pbm" )
 retrieve="Select	p.nr_pedido,
		p.dh_pedido,
		p.dh_previsao_entrega,
		f.cd_fornecedor,
		f.nm_razao_social,
		p.vl_total_pedido,
		p.id_programado,
		u.nr_matricula,
		u.nm_usuario,
		a.cd_filial,
		a.nm_fantasia,
		Datediff(day, dh_previsao_entrega, getdate()) As qt_dias_atraso,
		coalesce(p.id_pbm, 'N') As pbm
From pedido_central As p
	Inner Join fornecedor As f
		On f.cd_fornecedor = p.cd_fornecedor
	Inner Join condicao_pagamento As c
		On c.cd_condicao = p.cd_condicao_pagamento
	Inner Join usuario As u
		On u.nr_matricula = p.nr_matricula_cadastramento
	Inner Join filial As a
		On a.cd_filial = p.cd_filial
Where p.dh_previsao_entrega < (Select dh_movimentacao From parametro Where id_parametro = '1')
    And p.id_situacao = 'C'
Order By qt_dias_atraso Desc, f.nm_razao_social" )
