table(column=(type=datetime updatewhereclause=yes name=dh_registro dbname="produto_aprovacao.dh_registro" dbalias=".dh_registro" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_registro dbname="usuario.nm_usuario_registro" dbalias="u1.nm_usuario_registro" )
 column=(type=datetime updatewhereclause=yes name=dh_aprovacao_ecommerce dbname="produto_aprovacao.dh_aprovacao_ecommerce" dbalias=".dh_aprovacao_ecommerce" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_eco dbname="usuario.nm_usuario_eco" dbalias="u2.nm_usuario_eco" )
 column=(type=datetime updatewhereclause=yes name=dh_aprovacao_farmaceutico dbname="produto_aprovacao.dh_aprovacao_farmaceutico" dbalias=".dh_aprovacao_farmaceutico" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_farm dbname="usuario.nm_usuario_farm" dbalias="u3.nm_usuario_farm" )
 column=(type=datetime updatewhereclause=yes name=dh_aprovacao_fiscal dbname="produto_aprovacao.dh_aprovacao_fiscal" dbalias=".dh_aprovacao_fiscal" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_fiscal dbname="usuario.nm_usuario_fiscal" dbalias="u4.nm_usuario_fiscal" )
 column=(type=datetime updatewhereclause=yes name=dh_aprovacao_price dbname="produto_aprovacao.dh_aprovacao_price" dbalias=".dh_aprovacao_price" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_price dbname="usuario.nm_usuario_price" dbalias="u5.nm_usuario_price" )
 retrieve="select 	dh_registro,
			u1.nm_usuario nm_usuario_registro,
			dh_aprovacao_ecommerce,
			u2.nm_usuario nm_usuario_eco,
			dh_aprovacao_farmaceutico,
			u3.nm_usuario nm_usuario_farm,
			dh_aprovacao_fiscal,			
			u4.nm_usuario nm_usuario_fiscal,
			dh_aprovacao_price,
			u5.nm_usuario nm_usuario_price			
from produto_aprovacao a
inner join produto_geral g
	on g.cd_produto = a.cd_produto
left outer join usuario u1
	on u1.nr_matricula = a.nr_matric_registro
left outer join usuario u2
	on u2.nr_matricula = a.nr_matric_aprov_ecommerce
left outer join usuario u3
	on u3.nr_matricula = a.nr_matric_aprov_farmaceutico
left outer join usuario u4
	on u4.nr_matricula = a.nr_matric_aprov_fiscal
left outer join usuario u5
	on u5.nr_matricula = a.nr_matric_aprov_price
where a.cd_produto = :produto" arguments=(("produto", number)) )
