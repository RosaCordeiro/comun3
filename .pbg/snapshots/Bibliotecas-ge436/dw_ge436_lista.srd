table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_aprovacao.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_inclusao_alteracao dbname="produto_aprovacao.id_inclusao_alteracao" values="INCLUS$$HEX1$$c300$$ENDHEX$$O	I/ALTERA$$HEX2$$c700c300$$ENDHEX$$O	A/" )
 column=(type=datetime updatewhereclause=yes name=dh_registro dbname="produto_aprovacao.dh_registro" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=datetime updatewhereclause=yes name=dh_aprovacao_ecommerce dbname="produto_aprovacao.dh_aprovacao_ecommerce" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_eco dbname="usuario.nm_usuario_eco" )
 column=(type=datetime updatewhereclause=yes name=dh_aprovacao_farmaceutico dbname="produto_aprovacao.dh_aprovacao_farmaceutico" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_farm dbname="usuario.nm_usuario_farm" )
 column=(type=datetime updatewhereclause=yes name=dh_aprovacao_fiscal dbname="produto_aprovacao.dh_aprovacao_fiscal" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_fiscal dbname="usuario.nm_usuario_fiscal" )
 column=(type=datetime updatewhereclause=yes name=dh_aprovacao_price dbname="produto_aprovacao.dh_aprovacao_price" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_price dbname="usuario.nm_usuario_price" )
 retrieve="select 	a.cd_produto, 
			g.de_produto + ' : ' + g.de_apresentacao_venda de_produto,
			id_inclusao_alteracao,
			dh_registro,
			u1.nm_usuario,
			dh_aprovacao_ecommerce,
			u2.nm_usuario nm_usuario_eco,
			dh_aprovacao_farmaceutico,
			u3.nm_usuario nm_usuario_farm,
			dh_aprovacao_fiscal,			
			u4.nm_usuario nm_usuario_fiscal,
			dh_aprovacao_price,
			u5.nm_usuario nm_usuario_price			
from produto_aprovacao a
inner join produto_geral g
	on g.cd_produto = a.cd_produto
left outer join usuario u1
	on u1.nr_matricula = a.nr_matric_registro
left outer join usuario u2
	on u2.nr_matricula = a.nr_matric_aprov_ecommerce
left outer join usuario u3
	on u3.nr_matricula = a.nr_matric_aprov_farmaceutico
left outer join usuario u4
	on u4.nr_matricula = a.nr_matric_aprov_fiscal
left outer join usuario u5
	on u5.nr_matricula = a.nr_matric_aprov_price"  sort="dh_registro D de_produto A " )
