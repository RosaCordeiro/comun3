table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_ativo dbname="id_ativo" initial="N" values="	S/	N" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="filial.nr_cgc" )
 column=(type=char(1) updatewhereclause=yes name=id_ativo_anterior dbname="id_ativo_anterior" )
 retrieve="  SELECT distinct	filial.cd_filial,   
     				    filial.nm_fantasia  ,
						'N' id_ativo,
						filial.nr_cgc,
						'N' id_ativo_anterior
    FROM filial   
   where id_situacao = 'A'
	and cd_filial <> 2


" update="filial" updatewhere=1 updatekeyinplace=no  sort="cd_filial A " )
