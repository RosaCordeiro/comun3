table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(52) updatewhereclause=yes name=nm_fornecedor dbname="nm_fornecedor" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao dbname="dh_alteracao" )
 column=(type=char(8) updatewhereclause=yes name=id_alteracao dbname="id_alteracao" )
 column=(type=char(47) updatewhereclause=yes name=usuario dbname="usuario" )
 retrieve="  SELECT	top 150	h.cd_filial,   
						f.nm_fantasia + ' (' + h.cd_fornecedor + ')' nm_fornecedor,
						h.dh_alteracao,
						case
									when id_alteracao = ~"I~" then ~"INCLUIDO~"
									else ~"EXCLUIDO~"
							end id_alteracao,
                            coalesce( (j.nr_matricula +~":~"+j.nm_usuario), '')  as usuario
    FROM historico_filial_conexao   h
inner join fornecedor f on f.cd_fornecedor = h.cd_fornecedor
left  join usuario j on j.nr_matricula = h.nr_matricula  
where h.cd_filial				= :filial
	and h.cd_fornecedor	= :fornecedor
order by h.dh_alteracao desc
" arguments=(("filial", number),("fornecedor", string))  sort="dh_alteracao D " )
