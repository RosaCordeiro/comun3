table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="fornecedor.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=fornecedor_nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=id_ativo dbname="id_ativo" initial="N" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_ativo_anterior dbname="id_ativo_anterior" )
 column=(type=char(20) updatewhereclause=yes name=de_projeto_conexao dbname="conexao.de_projeto_conexao" )
 retrieve="select distinct f.cd_fornecedor, 
                    	f.nm_fantasia,
				  'N' id_ativo,
					'N' id_ativo_anterior,
					x.de_projeto_conexao
  from produto_central c 
	inner join produto_geral g on c.cd_produto 			= g.cd_produto
	inner join fornecedor f 	on f.cd_fornecedor 		= g.cd_fornecedor_usual
	inner join conexao x			on x.id_projeto_conexao = c.id_projeto_conexao
where x.id_situacao in ('A', 'P')
and g.id_situacao in ('A' , 'P')"  sort="fornecedor_nm_fantasia A " )
