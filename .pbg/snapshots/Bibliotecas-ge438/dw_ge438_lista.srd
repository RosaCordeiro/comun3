table(column=(type=char(101) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="preco_regionalizado.cd_produto" dbalias="r.cd_produto" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="preco_regionalizado.cd_filial" dbalias="r.cd_filial" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_venda_atual dbname="preco_regionalizado.vl_preco_venda_atual" dbalias="r.vl_preco_venda_atual" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_preco_venda_atual dbname="preco_regionalizado.dh_preco_venda_atual" dbalias="r.dh_preco_venda_atual" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_venda_futuro dbname="preco_regionalizado.vl_preco_venda_futuro" dbalias="r.vl_preco_venda_futuro" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_futuro_ant dbname="preco_regionalizado.vl_preco_venda_futuro_ant" dbalias="r.vl_preco_venda_futuro_ant" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_preco_venda_futuro dbname="preco_regionalizado.dh_preco_venda_futuro" dbalias="r.dh_preco_venda_futuro" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matric_preco_venda_atual dbname="preco_regionalizado.nr_matric_preco_venda_atual" dbalias="r.nr_matric_preco_venda_atual" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matric_preco_venda_futuro dbname="preco_regionalizado.nr_matric_preco_venda_futuro" dbalias="r.nr_matric_preco_venda_futuro" )
 column=(type=char(1) updatewhereclause=yes name=id_bloqueado_promocao dbname="id_bloqueado_promocao" initial="N" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_bloqueado_promocao_ant dbname="id_bloqueado_promocao_ant" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="produto_uf.cd_unidade_federacao" dbalias="u.cd_unidade_federacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_atual dbname="vl_preco_atual" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_atual dbname="pc_desconto_atual" )
 column=(type=char(1) updatewhereclause=yes name=id_caderno_abcfarma dbname="produto_geral.id_caderno_abcfarma" dbalias="p.id_caderno_abcfarma" )
 column=(type=char(1) updatewhereclause=yes name=id_controle_preco dbname="id_controle_preco" )
 retrieve="SELECT 	p.de_produto+ ~":~" + p.de_apresentacao_estoque de_produto,
  			r.cd_produto,
			r.cd_filial,
			r.vl_preco_venda_atual,
			r.dh_preco_venda_atual,
			r.vl_preco_venda_futuro, 
			r.vl_preco_venda_futuro vl_preco_venda_futuro_ant,
			r.dh_preco_venda_futuro, 
			r.nr_matric_preco_venda_atual,
			r.nr_matric_preco_venda_futuro,
      			 'N' id_bloqueado_promocao,
		 	'N' id_bloqueado_promocao_ant,
			u.cd_unidade_federacao,
			coalesce(u.vl_preco_venda_atual_sap, u.vl_preco_venda_atual) vl_preco_atual,
			0.00 pc_desconto_atual,
			p.id_caderno_abcfarma,
			coalesce(pa.id_controle_preco, 'L') id_controle_preco
From produto_geral As p
	Inner Join preco_regionalizado As r
		On r.cd_produto = p.cd_produto
	Inner Join filial As f
		on f.cd_filial = r.cd_filial
	inner join cidade c
		on c.cd_cidade = f.cd_cidade
	Inner Join produto_uf As u
		On u.cd_produto	= p.cd_produto
		and u.cd_unidade_federacao = c.cd_unidade_federacao
	inner join produto_central pc
		on pc.cd_produto = p.cd_produto
	left outer join produto_abcfarma pa
		on pa.cd_produto_abcfarma = pc.cd_produto_abcfarma
Where r.cd_filial = :filial" update="preco_regionalizado" updatewhere=0 updatekeyinplace=no arguments=(("filial", number))  sort="de_produto A " )
