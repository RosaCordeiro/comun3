table(column=(type=char(10) updatewhereclause=yes name=de_movimento dbname="de_movimento" )
 column=(type=char(12) updatewhereclause=yes name=de_hora dbname="de_hora" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=de_filial dbname="de_filial" )
 column=(type=char(40) updatewhereclause=yes name=de_cidade dbname="cidade.de_cidade" dbalias="ci.de_cidade" )
 column=(type=char(2) updatewhereclause=yes name=de_uf dbname="cidade.de_uf" dbalias="ci.de_uf" )
 column=(type=char(20) updatewhereclause=yes name=de_bandeira dbname="de_bandeira" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="nr_sequencial" )
 column=(type=char(40) updatewhereclause=yes name=de_fabricante dbname="de_fabricante" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="de_subcategoria" )
 column=(type=char(40) updatewhereclause=yes name=de_categoria dbname="de_categoria" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo dbname="de_subgrupo" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="de_grupo" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="qt_vendida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_tabela dbname="pc_desconto_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_liquido dbname="vl_preco_liquido" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_comissao_extra dbname="pc_comissao_extra" )
 column=(type=char(14) updatewhereclause=yes name=id_tipo_venda dbname="id_tipo_venda" )
 column=(type=char(60) updatewhereclause=yes name=nm_convenio dbname="nm_convenio" )
 column=(type=char(6) updatewhereclause=yes name=cd_promocao dbname="cd_promocao" )
 column=(type=char(40) updatewhereclause=yes name=de_promocao dbname="de_promocao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_promocao dbname="pc_desconto_promocao" )
 column=(type=char(1) updatewhereclause=yes name=id_venda_pbm dbname="id_venda_pbm" )
 column=(type=char(1) updatewhereclause=yes name=id_venda_farm_gov dbname="id_venda_farm_gov" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_unimed dbname="pc_desconto_unimed" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_convenio dbname="pc_desconto_convenio" )
 column=(type=char(1) updatewhereclause=yes name=id_pedido_ecommerce dbname="id_pedido_ecommerce" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_imposto dbname="vl_imposto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_medio dbname="vl_custo_medio" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_comissao dbname="vl_comissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_rentabilidade dbname="vl_rentabilidade" )
 retrieve="select		substring(CONVERT( CHAR(10), n.dh_movimentacao_caixa, 103 ), 1, 10)  de_movimento,
						convert(char(12), dh_emissao, 18) de_hora,
						n.cd_filial cd_filial,
						f.nm_fantasia de_filial,	
						ci.nm_cidade de_cidade,
						ci.cd_unidade_federacao de_uf, 
						( case coalesce(f.id_rede_filial, 'XX')
								when    'AL' then 'ALOMED'
							when    'CP' then 'CATARINENSE PLUS'
							when    'DC' then 'DROGARIA CATARINENSE'
							when    'DP' then 'DROG. PRECO POPULAR'									
							when    'FA' then 'FARMAGORA'
							when    'MP' then 'MANIPULACAO'
							when    'PP' then 'PRECO POPULAR'
							when	'PF' then 'PROFORMULA'
							else 'NAO IDENTIFICADO'
						end ) de_bandeira,
						n.nr_nf nr_nf,
						i.nr_sequencial nr_sequencial,
						fo.nm_razao_social de_fabricante,
						(select de_subcategoria 	from subcategoria su where su.cd_subcategoria = g.cd_subcategoria) de_subcategoria ,
						(select de_categoria 		from categoria ca where ca.cd_categoria = substring(g.cd_subcategoria, 1,6)) de_categoria ,
						(select de_subgrupo 		from subgrupo sub where sub.cd_subgrupo = substring(g.cd_subcategoria, 1,3)) de_subgrupo ,
						(select de_grupo 			from grupo gr where gr.cd_grupo = substring(g.cd_subcategoria, 1,1)) de_grupo ,
						i.cd_produto as cd_produto,
						g.de_produto  + ' : ' + g.de_apresentacao_venda de_produto,
						i.qt_vendida as qt_vendida	,
						i.vl_preco_unitario as vl_preco_unitario,
						i.pc_desconto_tabela  as pc_desconto_tabela,
						n.pc_desconto pc_desconto ,
						round(i.qt_vendida * cast(round(round(i.vl_preco_unitario * ((100 - i.pc_desconto_tabela) / 100), 2) * ((100 - n.pc_desconto) / 100), 2) as decimal(11,2)) ,2) vl_preco_liquido,
						i.pc_comissao_extra pc_comissao_extra,
						 (case n.id_tipo_venda 
							when 'AV' THEN 'AVISTA'
							when 'CV' THEN 'CONVENIO'
							when 'CC' THEN 'CONTA CORRENTE'
							when 'CR' THEN 'CREDIARIO'
						 END) id_tipo_venda,
						coalesce(co.nm_fantasia, '') nm_convenio,
						coalesce((CASE WHEN coalesce(v.id_pbm, 'N') = 'S' THEN '' ELSE cast(i.cd_promocao_sos as VARCHAR(6)) END), '') cd_promocao ,
						coalesce((CASE WHEN coalesce(v.id_pbm, 'N') = 'S' THEN '' ELSE pro.nm_promocao_sos END), '') de_promocao,
						coalesce((CASE WHEN coalesce(v.id_pbm, 'N') = 'S' THEN 0 ELSE prop.pc_desconto END), 0) pc_desconto_promocao,
						coalesce(v.id_pbm, 'N') id_venda_pbm,
						 (Case When (	select count(*) 
											from venda_pbm vp 
											WHERE vp.cd_filial = n.cd_filial 
												and vp.nr_nf = n.nr_nf 
												and vp.de_especie = n.de_especie 
												and vp.de_serie = n.de_serie
												AND vp.cd_convenio = 52575 
												and vp.nr_comprovante_venda = 'AVFARPOP') > 0 
								Then 'S' 	else 'N' END	) id_venda_farm_gov,
						coalesce(uv.pc_desconto_drogaria  + uv.pc_desconto_unimed, 0) pc_desconto_unimed,
					(CASE WHEN coalesce(uv.pc_desconto_nf, 0) > 0 
							 THEN coalesce(uv.pc_desconto_nf, 0) 
							  ELSE (CASE WHEN (coalesce(uv.pc_desconto_drogaria, 0) + coalesce(uv.pc_desconto_unimed, 0)) = 0  
										THEN n.pc_desconto 
										ELSE 0
									  END) 
					 END) pc_desconto_convenio ,
					(Case when coalesce(n.nr_pedido_ecommerce, 0) > 0 Then 'S' else 'N' END) id_pedido_ecommerce ,
					 i.pc_icms  as pc_icms,
					 round(i.qt_vendida * cast(round(round(round(i.vl_preco_unitario * ((100 - i.pc_desconto_tabela) / 100), 2) * ((100 - n.pc_desconto) / 100), 2) * (i.pc_icms / 100), 2) as decimal(11,2)) ,2) vl_imposto, 
					 round(i.qt_vendida * coalesce(m.vl_custo_unitario, 0),2) vl_custo_medio, 
					 round(i.qt_vendida * cast(round(round(round(i.vl_preco_unitario * ((100 - i.pc_desconto_tabela) / 100), 2) * ((100 - n.pc_desconto) / 100), 2) * (i.pc_comissao_extra / 100), 2) as decimal(11,2)) ,2) vl_comissao, 
					 round(i.qt_vendida * cast(round(round(i.vl_preco_unitario * ((100 - i.pc_desconto_tabela) / 100), 2) * ((100 - n.pc_desconto) / 100), 2) 
					 - m.vl_custo_unitario
					 - round(round(round(i.vl_preco_unitario * ((100 - i.pc_desconto_tabela) / 100), 2) * ((100 - n.pc_desconto) / 100), 2) * (i.pc_comissao_extra / 100), 2)
					 - round(round(round(i.vl_preco_unitario * ((100 - i.pc_desconto_tabela) / 100), 2) * ((100 - n.pc_desconto) / 100), 2) * (i.pc_icms / 100), 2) as decimal(11,2)) ,2) vl_rentabilidade
			from nf_venda n (index idx_data_filial)
			inner join filial f (index pk_filial)
				on f.cd_filial = n.cd_filial
			inner join cidade ci
				on ci.cd_cidade = f.cd_cidade
			inner join item_nf_venda i (index pk_item_nf_venda)
				on i.cd_filial = n.cd_filial
				and i.nr_nf = n.nr_nf
				and i.de_especie = n.de_especie
				and i.de_serie		= n.de_serie
			inner join movimento_estoque m (index idx_nota)
				on m.cd_filial_movimento = i.cd_filial
				and m.nr_nf			= i.nr_nf
				and m.de_especie	= i.de_especie
				and m.de_serie		= i.de_serie
				and m.cd_produto	= i.cd_produto
				and coalesce(m.nr_sequencial, 1) = coalesce(i.nr_sequencial, 1)
			inner join produto_geral g (index pk_produto_geral)
				on g.cd_produto = i.cd_produto
			inner join fornecedor fo (index pk_fornecedor)
				on fo.cd_fornecedor = g.cd_fornecedor_usual
			left outer join convenio co
				on co.cd_convenio = n.cd_convenio
			left outer join venda_pbm_produto v
				on v.cd_filial = n.cd_filial
				and v.nr_nf		= n.nr_nf
				and v.de_especie	 = n.de_especie
				and v.de_serie		= n.de_serie
				and v.cd_produto	= i.cd_produto
				and v.nr_sequencial = i.nr_sequencial
			left outer join promocao_sos pro
				on pro.cd_promocao_sos = i.cd_promocao_sos
			left outer join promocao_sos_produto prop
				on prop.cd_promocao_sos = pro.cd_promocao_sos
				and prop.cd_produto = i.cd_produto
			left outer join unimed_venda uv
				 on uv.cd_filial = n.cd_filial 
				and uv.nr_nf = n.nr_nf 
				and uv.de_especie = n.de_especie 
				and uv.de_serie = n.de_serie
			where n.dh_movimentacao_caixa = :movimento
			  and n.dh_cancelamento is null
			  and n.nr_nf_anexa is null
			  and n.nr_pedido_ecommerce is null
			  and g.id_situacao = 'A'
			  and i.cd_produto <> 684431
			  and n.cd_filial = :filial
			order by n.cd_filial, n.nr_nf, i.nr_sequencial" arguments=(("movimento", date),("filial", number)) )
