 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_diversa.vl_preco_unitario" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto dbname="item_nf_diversa.pc_desconto" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_icms dbname="item_nf_diversa.pc_icms" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_outras_despesas dbname="item_nf_diversa.vl_outras_despesas" )
 column=(type=char(7) update=yes updatewhereclause=yes name=cd_cest dbname="item_nf_diversa.cd_cest" )
 column=(type=char(10) updatewhereclause=yes name=cd_bem dbname="item_nf_diversa.cd_bem" )
 column=(type=char(10) updatewhereclause=yes name=nr_etiqueta_preste dbname="item_nf_diversa.nr_etiqueta_preste" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="item_nf_diversa.dh_validade" )
 column=(type=long updatewhereclause=yes name=nr_ajuste_estoque dbname="item_nf_diversa.nr_ajuste_estoque" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="item_nf_diversa.nr_lote" )
 retrieve="SELECT	i.cd_produto,
			i.cd_filial_origem,	
			i.nr_nf,
			i.de_especie,
			i.de_serie,
			i.cd_item,
			i.de_item,   
			i.de_unidade_medida,   
			i.qt_item,   
			i.vl_preco_unitario,   
			i.pc_desconto,   
			i.pc_icms,
			i.vl_outras_despesas,
			i.cd_cest,
			i.cd_bem,
			i.nr_etiqueta_preste,
			i.dh_validade,
			i.nr_ajuste_estoque,
			i.nr_lote
    FROM item_nf_diversa i 
   WHERE i.cd_filial_origem 	= :cd_filial_origem
	  	AND i.nr_nf 				= :nr_nf
        	AND i.de_especie 		= :de_especie
		AND i.de_serie 			= :de_serie
" update="item_nf_diversa" updatewhere=0 updatekeyinplace=yes arguments=(("cd_filial_origem", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
