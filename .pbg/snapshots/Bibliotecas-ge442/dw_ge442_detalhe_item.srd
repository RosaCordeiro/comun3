table(column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_diversa.cd_produto" )
 column=(type=long updatewhereclause=yes key=yes name=cd_filial_origem dbname="item_nf_diversa.cd_filial_origem" )
 column=(type=long updatewhereclause=yes key=yes name=nr_nf dbname="item_nf_diversa.nr_nf" )
 column=(type=char(3) updatewhereclause=yes key=yes name=de_especie dbname="item_nf_diversa.de_especie" )
 column=(type=char(3) updatewhereclause=yes key=yes name=de_serie dbname="item_nf_diversa.de_serie" )
 column=(type=long updatewhereclause=yes key=yes name=cd_item dbname="item_nf_diversa.cd_item" )
