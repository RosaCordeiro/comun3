table(column=(type=long update=yes updatewhereclause=yes name=cd_filial_origem dbname="nf_diversa.cd_filial_origem" )
 column=(type=long update=yes updatewhereclause=yes name=nr_nf dbname="nf_diversa.nr_nf" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_especie dbname="nf_diversa.de_especie" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_serie dbname="nf_diversa.de_serie" )
