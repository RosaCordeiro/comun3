 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_outras_despesas dbname="nf_diversa.vl_outras_despesas" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_seguro dbname="nf_diversa.vl_seguro" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_total_produtos dbname="nf_diversa.vl_total_produtos" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_total_nf dbname="nf_diversa.vl_total_nf" )
 column=(type=char(60) update=yes updatewhereclause=yes name=nm_destinatario dbname="nf_diversa.nm_destinatario" )
 column=(type=char(15) update=yes updatewhereclause=yes name=nr_cgc_cpf dbname="nf_diversa.nr_cgc_cpf" )
 column=(type=char(15) update=yes updatewhereclause=yes name=nr_inscricao_estadual dbname="nf_diversa.nr_inscricao_estadual" )
 column=(type=long update=yes updatewhereclause=yes name=cd_cidade dbname="nf_diversa.cd_cidade" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_cidade dbname="nf_diversa.nm_cidade" )
 column=(type=char(2) update=yes updatewhereclause=yes name=nm_uf dbname="nf_diversa.nm_uf" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_endereco dbname="nf_diversa.de_endereco" )
 column=(type=char(20) update=yes updatewhereclause=yes name=de_bairro dbname="nf_diversa.de_bairro" )
 column=(type=char(8) update=yes updatewhereclause=yes name=nr_cep dbname="nf_diversa.nr_cep" )
 column=(type=char(15) update=yes updatewhereclause=yes name=nr_telefone dbname="nf_diversa.nr_telefone" )
 column=(type=char(30) updatewhereclause=yes name=dh_cancelamento dbname="dh_cancelamento" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_bc_icms_st dbname="nf_diversa.vl_bc_icms_st" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_diversa_nfe.de_chave_acesso" )
 column=(type=char(15) updatewhereclause=yes name=nr_protocolo_envio dbname="nf_diversa_nfe.nr_protocolo_envio" )
 column=(type=char(30) updatewhereclause=yes name=dh_envio dbname="dh_envio" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_endereco dbname="nf_diversa.nr_endereco" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="nf_diversa.cd_filial_destino" )
 column=(type=char(1) updatewhereclause=yes name=id_ajusta_estoque dbname="nf_diversa.id_ajusta_estoque" values="Ajustou Estoque?	S/Ajustou Estoque?	N" )
 column=(type=long updatewhereclause=yes name=cd_perfil_nf dbname="nf_diversa.cd_perfil_nf" )
 column=(type=long updatewhereclause=yes name=cd_motivo_ajuste dbname="nf_diversa.cd_motivo_ajuste" )
 column=(type=char(100) updatewhereclause=yes name=de_comentario_ajuste dbname="nf_diversa.de_comentario_ajuste" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_operador dbname="nf_diversa.nr_matricula_operador" )
 column=(type=char(40) updatewhereclause=yes name=nm_operador dbname="usuario.nm_operador" )
 column=(type=long updatewhereclause=yes name=nr_agrupamento_dev_compra dbname="nr_agrupamento_dev_compra" )
 retrieve="SELECT	nd.cd_filial_origem,   
			nd.nr_nf,   
			nd.de_especie,   
			nd.de_serie,   
			nd.cd_natureza_operacao,   
			nd.de_natureza_operacao,   
			dbo.tochar( nd.dh_emissao, 'dd/mm/yyyy hh:mi:ss' ) as dh_emissao,   
			nd.vl_bc_icms,   
			nd.vl_icms,   
			nd.vl_icms_st,   
			nd.vl_frete,   
			nd.vl_outras_despesas,   
			nd.vl_seguro,   
			nd.vl_total_produtos,   
			nd.vl_total_nf,   
			nd.nm_destinatario,   
			nd.nr_cgc_cpf,   
			nd.nr_inscricao_estadual,
			nd.cd_cidade,   
			nd.nm_cidade,   
			nd.nm_uf,   
			nd.de_endereco,   
			nd.de_bairro,   
			nd.nr_cep,   
			nd.nr_telefone, 
			dbo.tochar( nd.dh_cancelamento, 'dd/mm/yyyy hh:mi:ss' ) as dh_cancelamento,  
			f.nm_fantasia,   
			nd.vl_bc_icms_st ,
			ndv.de_chave_acesso,
			ndv.nr_protocolo_envio,
			dbo.tochar( ndv.dh_envio, 'dd/mm/yyyy hh:mi:ss' ) as dh_envio, 
			nd.nr_endereco,
			nd.cd_filial_destino AS cd_filial_destino,
			nd.id_ajusta_estoque,
			nd.cd_perfil_nf,
			nd.cd_motivo_ajuste,
			nd.de_comentario_ajuste,
			nd.nr_matricula_operador,
			uop.nm_usuario as nm_operador,
			0 as nr_agrupamento_dev_compra
FROM nf_diversa nd
INNER JOIN filial f
	ON nd.cd_filial_origem 		= f.cd_filial
LEFT OUTER JOIN nf_diversa_nfe ndv
	  ON ndv.cd_filial_origem 	= nd.cd_filial_origem 
	AND ndv.nr_nf 					= nd.nr_nf
	AND ndv.de_especie 			= nd.de_especie
	AND ndv.de_serie 				= nd.de_serie
LEFT OUTER JOIN usuario uop
	ON uop.nr_matricula			= nd.nr_matricula_operador
WHERE nd.cd_filial_origem		= :cd_filial_origem  
		AND nd.nr_nf				= :nr_nf  
		AND nd.de_especie 		= :de_especie  
		AND nd.de_serie			= :de_serie     " arguments=(("cd_filial_origem", number),("nr_nf", number),("de_especie", string),("de_serie", string))  sort="nr_nf A " )
