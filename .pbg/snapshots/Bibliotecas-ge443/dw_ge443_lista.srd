table(column=(type=long updatewhereclause=yes key=yes name=cd_produto dbname="produto_central.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(2) update=yes updatewhereclause=yes name=cd_uf_encarte dbname="produto_central.cd_uf_encarte" )
 retrieve="Select	c.cd_produto,
		g.de_produto || ' : ' || g.de_apresentacao_estoque As de_produto,
		c.cd_uf_encarte
From produto_geral As g
	Inner Join produto_central As c
		On c.cd_produto = g.cd_produto
Where g.cd_subcategoria = '509001001'
	And g.id_situacao = 'A'" update="produto_central" updatewhere=0 updatekeyinplace=no )
