 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"dcb_produto~" )  TABLE(NAME=~"produto_geral~" )  TABLE(NAME=~"saldo_produto~" )  TABLE(NAME=~"filial~" ) COLUMN(NAME=~"dcb_produto.cd_dcb~") COLUMN(NAME=~"dcb_produto.de_dcb~") COLUMN(NAME=~"produto_geral.de_produto~") COLUMN(NAME=~"produto_geral.de_apresentacao_venda~") COLUMN(NAME=~"produto_geral.id_apresentacao~") COLUMN(NAME=~"produto_geral.qt_concentracao~") COLUMN(NAME=~"saldo_produto.qt_saldo_final~") COLUMN(NAME=~"produto_geral.cd_grupo_psico~") COLUMN(NAME=~"filial.nm_razao_social~") COLUMN(NAME=~"filial.nr_cgc~")    JOIN (LEFT=~"produto_geral.cd_dcb~"    OP =~"=~"RIGHT=~"dcb_produto.cd_dcb~" )    JOIN (LEFT=~"saldo_produto.cd_produto~"    OP =~"=~"RIGHT=~"produto_geral.cd_produto~" )    JOIN (LEFT=~"filial.cd_filial~"    OP =~"=~"RIGHT=~"saldo_produto.cd_filial~" )WHERE(    EXP1 =~"saldo_produto.cd_filial~"   OP =~"=~"    EXP2 =~":cd_filial~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"saldo_produto.dh_saldo~"   OP =~"=~"    EXP2 =~":dh_saldo~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"saldo_produto.qt_saldo_final~"   OP =~">~"    EXP2 =~"0~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"produto_geral.cd_grupo_psico~"   OP =~"is not~"    EXP2 =~"null~" ) ) ARG(NAME = ~"cd_filial~" TYPE = number)  ARG(NAME = ~"dh_saldo~" TYPE = datetime)  ARG(NAME = ~"dh_emissao~" TYPE = datetime) " arguments=(("cd_filial", number),("dh_saldo", datetime),("dh_emissao", datetime))  sort="cd_grupo_psico A nome_comercial A " )
