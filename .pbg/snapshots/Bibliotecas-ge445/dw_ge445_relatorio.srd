table(column=(type=char(10) updatewhereclause=yes name=dcb_produto_cd_dcb dbname="dcb_produto.cd_dcb" )
 column=(type=char(40) updatewhereclause=yes name=dcb_produto_de_dcb dbname="dcb_produto.de_dcb" )
 column=(type=char(60) updatewhereclause=yes name=produto_geral_de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=produto_geral_de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=char(2) updatewhereclause=yes name=produto_geral_id_apresentacao dbname="produto_geral.id_apresentacao" values="COMPR.	01/INJET$$HEX1$$c100$$ENDHEX$$VEL	02/GOTAS	03/L$$HEX1$$cd00$$ENDHEX$$QUID.	04/P$$HEX1$$d300$$ENDHEX$$	05/POMADA	06/SUPOSIT.	07/LO$$HEX2$$c700c300$$ENDHEX$$O	08/SABON.	09/DR$$HEX1$$c100$$ENDHEX$$GEA	10/C$$HEX1$$c100$$ENDHEX$$PSULA	11/CREME	12/GEL	13/ADESIVO	14/SUBLING.	15/COL$$HEX1$$cd00$$ENDHEX$$RIO	16/AEROSOL	17/DISPERS.	18/" )
 column=(type=decimal(4) updatewhereclause=yes name=produto_geral_qt_concentracao dbname="produto_geral.qt_concentracao" )
 column=(type=long updatewhereclause=yes name=saldo_produto_qt_saldo_final dbname="saldo_produto.qt_saldo_final" )
 column=(type=char(2) updatewhereclause=yes name=produto_geral_cd_grupo_psico dbname="produto_geral.cd_grupo_psico" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_razao_social dbname="filial.nm_razao_social" )
 column=(type=char(14) updatewhereclause=yes name=filial_nr_cgc dbname="filial.nr_cgc" )
 retrieve="  SELECT dcb_produto.cd_dcb,   
         dcb_produto.de_dcb,   
         produto_geral.de_produto,   
         produto_geral.de_apresentacao_venda,   
         produto_geral.id_apresentacao,   
         produto_geral.qt_concentracao,   
         saldo_produto.qt_saldo_final,   
         produto_geral.cd_grupo_psico,   
         filial.nm_razao_social,   
         filial.nr_cgc  
    FROM dcb_produto,   
         produto_geral,   
         saldo_produto,   
         filial  
   WHERE ( produto_geral.cd_dcb = dcb_produto.cd_dcb ) and  
         ( saldo_produto.cd_produto = produto_geral.cd_produto ) and  
         ( filial.cd_filial = saldo_produto.cd_filial ) and  
         ( ( saldo_produto.cd_filial = :cd_filial ) AND  
         ( saldo_produto.dh_saldo = :dh_saldo ) AND  
         ( saldo_produto.qt_saldo_final > 0 ) AND  
         ( produto_geral.cd_grupo_psico is not null ) )    
" arguments=(("cd_filial", number),("dh_saldo", datetime))  sort="produto_geral_cd_grupo_psico A produto_geral_de_produto A " )
