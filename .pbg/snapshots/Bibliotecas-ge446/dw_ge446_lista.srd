table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_mensagem dbname="mensagem_email_sistema_usuario.cd_mensagem" )
 column=(type=char(6) update=yes updatewhereclause=yes key=yes name=nr_matricula dbname="mensagem_email_sistema_usuario.nr_matricula" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=char(100) update=yes updatewhereclause=yes name=de_email dbname="mensagem_email_sistema_usuario.de_email" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inicio_envio dbname="mensagem_email_sistema_usuario.dh_inicio_envio" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_termino_envio dbname="mensagem_email_sistema_usuario.dh_termino_envio" )
 column=(type=char(2) update=yes updatewhereclause=yes key=yes name=id_tipo_envio dbname="mensagem_email_sistema_usuario.id_tipo_envio" initial="TO" values="PARA	TO/COM C$$HEX1$$d300$$ENDHEX$$PIA	CC/C$$HEX1$$d300$$ENDHEX$$P. OCULTA	CO/" )
 retrieve="Select	m.cd_mensagem,
		m.nr_matricula,
		u.nm_usuario,
		m.de_email,
		m.dh_inicio_envio,
		m.dh_termino_envio,
		m.id_tipo_envio
From usuario As u
	Inner Join mensagem_email_sistema_usuario As m
		On m.nr_matricula = u.nr_matricula
Where m.cd_mensagem = :mensagem" update="mensagem_email_sistema_usuario" updatewhere=0 updatekeyinplace=no arguments=(("mensagem", number))  sort="nm_usuario A " )
