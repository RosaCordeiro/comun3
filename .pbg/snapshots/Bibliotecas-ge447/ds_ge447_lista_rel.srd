table(column=(type=long updatewhereclause=yes name=nf_nota_comp dbname="nf_devolucao_compra.nota_comp" )
 column=(type=char(3) updatewhereclause=yes name=nf_especie_comp dbname="nf_devolucao_compra.nota_especie_comp" )
 column=(type=char(3) updatewhereclause=yes name=serie_comp dbname="nf_devolucao_compra.nota_serie_comp" )
 column=(type=char(48) updatewhereclause=yes name=fornecedor dbname="fornecedor" )
 column=(type=long updatewhereclause=yes name=agrupamento dbname="wms_segregado_coleta.agrupamento" )
 column=(type=char(40) updatewhereclause=yes name=motivo_devolucao dbname="motivo_devolucao_compra.de_motivo_devolucao" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="Situacao" values="Coletado	C/Pendente	P/Substituido	S/Descartado	D/Cancelado	X/" )
 column=(type=long updatewhereclause=yes name=nf_dev dbname="nf_devolucao_compra.nota_dev" )
 column=(type=char(3) updatewhereclause=yes name=nf_dev_especie dbname="nf_devolucao_compra.nota_especie_dev" )
 column=(type=char(3) updatewhereclause=yes name=serie_dev dbname="nf_devolucao_compra.nota_serie_dev" )
 column=(type=char(40) updatewhereclause=yes name=usuario_usr_dev dbname="usuario.usr_dev" )
 column=(type=long updatewhereclause=yes name=diasprazo dbname="DiasPrazo" )
 column=(type=char(40) updatewhereclause=yes name=usr_compra dbname="usuario.usr_compra" )
 column=(type=long updatewhereclause=yes identity=yes name=nr_coleta dbname="wms_segregado_coleta.nr_coleta" )
 column=(type=char(1) updatewhereclause=yes name=idsituacao dbname="wms_segregado_coleta.idSituacao" )
 column=(type=char(50) updatewhereclause=yes name=nr_nf_subs dbname="wms_segregado_coleta.nr_nf_subs" )
 column=(type=char(3) updatewhereclause=yes name=de_especie_subs dbname="wms_segregado_coleta.de_especie_subs" )
 column=(type=char(3) updatewhereclause=yes name=de_serie_subs dbname="wms_segregado_coleta.de_serie_subs" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_devolucao_compra.dh_movimentacao_caixa" )
 column=(type=char(44) updatewhereclause=yes name=nf_devolucao_compra_nfe_de_chave_acesso dbname="nf_devolucao_compra_nfe.de_chave_acesso" )
 column=(type=datetime updatewhereclause=yes name=dh_situacao dbname="wms_segregado_coleta.dh_situacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_nf_dev dbname="nf_devolucao_compra.vl_total_nf" )
 retrieve="select b.nr_nf_compra as nota_comp, 
       b.de_especie_compra as nota_especie_comp, 
       b.de_serie_compra as nota_serie_comp,
       '('+(substring(f.cd_fornecedor,5,5) + ') ' +  f.nm_razao_social) as fornecedor, 
       a.nr_agrupamento as agrupamento,
       m.de_motivo_devolucao,
       '' Situacao,
       b.nr_nf as nota_dev,
       b.de_especie as nota_especie_dev,
       b.de_serie as nota_serie_dev,
       usu_dev.nm_usuario as usr_dev,
       datediff(dd, b.dh_movimentacao_caixa, getdate() ) as DiasPrazo,
       usu_compr.nm_usuario as usr_compra, 
	   a.nr_coleta,
	   a.id_situacao as idSituacao, 
       a.nr_nf_subs,
   	   a.de_especie_subs,
       a.de_serie_subs,
	   b.dh_movimentacao_caixa,
	   nfe.de_chave_acesso, 
	   a.dh_situacao,
	   b.vl_total_nf
from   wms_segregado_coleta a
inner  join nf_devolucao_compra b on a.cd_filial = b.cd_filial
and    a.nr_nf = b.nr_nf
and    a.de_especie = b.de_especie
and    a.de_serie   = b.de_serie
and    a.nr_agrupamento = b.nr_agrupamento_dev_compra
and    a.cd_fornecedor = b.cd_fornecedor
inner  join fornecedor f on f.cd_fornecedor = a.cd_fornecedor
inner  join motivo_devolucao_compra m on m.cd_motivo_devolucao = b.cd_motivo_devolucao
inner  join usuario usu_dev on usu_dev.nr_matricula = b.nr_matricula_operador
inner  join nf_compra n on n.nr_nf = b.nr_nf_compra 
and 	n.de_especie=b.de_especie_compra
and 	n.de_serie  = b.de_serie_compra 
and 	n.cd_filial = b.cd_filial
/*Nome Comprador Incorreto
inner  join pedido_central p on p.nr_pedido =  n.nr_pedido_central and  p.cd_fornecedor = b.cd_fornecedor
inner  join usuario usu_compr on usu_compr.nr_matricula = p.nr_matricula_cadastramento*/
inner join agrupamento_dev_compra p on p.nr_agrupamento = a.nr_agrupamento
inner  join usuario usu_compr on usu_compr.nr_matricula = p.nr_matricula_comprador
inner  join nf_devolucao_compra_nfe nfe on nfe.cd_filial = n.cd_filial
and    nfe.nr_nf = b.nr_nf
and    nfe.de_especie = b.de_especie
and    nfe.de_serie   = b.de_serie
where a.nr_coleta>0
"  sort="usr_compra A diasprazo D " )
