table(column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" dbalias="c.cd_unidade_federacao" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_filial dbname="filial.id_rede_filial" dbalias="f.id_rede_filial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo dbname="vl_custo" )
 retrieve="select c.cd_unidade_federacao, 
		f.id_rede_filial, 
		sum((vl_comissao + coalesce(vl_cmv_gerencial, 0))) vl_custo
from resumo_produto_filial r
inner join filial f
	on f.cd_filial = r.cd_filial
inner join cidade c
	on c.cd_cidade = f.cd_cidade
where r.cd_produto = :produto
  and r.dh_resumo = :data
  and r.qt_venda - r.qt_devolucao_venda > 0
group by c.cd_unidade_federacao, 
		f.id_rede_filial" arguments=(("data", date),("produto", number)) )
