detail(height=84 color="536870912" transparency="0" gradient.color="8421504" gradient.transparency="0" gradient.angle="0" brushmode="0" gradient.repetition.mode="0" gradient.repetition.count="0" gradient.repetition.length="100" gradient.focus="0" gradient.scale="100" gradient.spread="100" )
table(column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cd_unidade_federacao" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_filial dbname="id_rede_filial" )
 column=(type=decimal(24) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 retrieve="Select	 	c.cd_unidade_federacao,
			f.id_rede_filial,
			round((1 - round(sum((i.qt_vendida * i.vl_preco_praticado) - round( i.qt_vendida * i.vl_preco_praticado * (coalesce(n.pc_desconto,0) / 100), 2)) / sum(i.qt_vendida * vl_preco_unitario), 4)) * 100, 2) as pc_desconto
from movimento_estoque m 
inner join filial f (index pk_filial)
	on f.cd_filial = m.cd_filial_movimento
inner join cidade c (index pk_cidade)
	on c.cd_cidade = f.cd_cidade
inner join nf_venda n (index pk_nf_venda)
	on n.cd_filial		= m.cd_filial_movimento+0
	and n.nr_nf			= m.nr_nf+0
	and n.de_especie	= m.de_especie
	and n.de_serie		= m.de_serie
inner join item_nf_venda i (index pk_item_nf_venda)
	 on i.cd_filial			= m.cd_filial_movimento+0
	 and i.nr_nf				= m.nr_nf+0
	 and i.de_especie		= m.de_especie
	 and i.de_serie			= m.de_serie
	 and i.cd_produto		= m.cd_produto+0
	 and i.nr_sequencial	= coalesce(m.nr_sequencial,1)
left outer join promocao_sos ps (index pk_promocao_sos)
	on ps.cd_promocao_sos = i.cd_promocao_sos+0
left outer join venda_pbm_produto vpp (index PK_VENDA_PBM_PRODUTO)
	 on vpp.cd_filial				= i.cd_filial+0
	 and vpp.nr_nf				= i.nr_nf+0
	 and vpp.de_especie		= i.de_especie||''
	 and vpp.de_serie			= i.de_serie||''
	 and vpp.cd_produto		= i.cd_produto+0
	 and vpp.nr_sequencial	= coalesce(i.nr_sequencial,1)
	 and vpp.id_pbm 			= 'N'
left outer join item_nf_venda_desconto ivd (index pk_item_nf_venda_desconto)
	on ivd.cd_filial 			= i.cd_filial+0
	and ivd.nr_nf 			= i.nr_nf+0
	and ivd.de_serie 		= i.de_serie
	and ivd.de_especie 	= i.de_especie
	and ivd.cd_produto 	= i.cd_produto+0
	and ivd.nr_sequencial	= coalesce(i.nr_sequencial,1)
where m.dh_movimento between :inicio_mes and :termino_mes
	and m.cd_produto = :produto
	and m.cd_filial_movimento <> 534
	and m.cd_filial_movimento > 0
	and m.cd_tipo_movimento = 1
	and n.dh_cancelamento is null
	and vpp.id_pbm is null
	and n.nr_nf_anexa is null
	and ((ps.nr_promocao_marketing is null and ps.id_tipo_promocao = 'N') or i.cd_promocao_sos is null) //Remove vendas de promo$$HEX2$$e700f500$$ENDHEX$$es vinculadas e SOS
	and ivd.id_tipo_desconto is null
group by c.cd_unidade_federacao,
			f.id_rede_filial" arguments=(("inicio_mes", date),("termino_mes", date),("produto", number)) )
