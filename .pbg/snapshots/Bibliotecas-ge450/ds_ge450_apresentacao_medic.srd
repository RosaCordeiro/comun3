table(column=(type=long updatewhereclause=yes name=nr_precificacao dbname="precificacao_prd.nr_precificacao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="precificacao_prd.cd_produto" )
 column=(type=char(14) updatewhereclause=yes name=nr_cnpj_laboratorio dbname="precificacao_prd.nr_cnpj_laboratorio" )
 column=(type=char(9) updatewhereclause=yes name=cd_subcategoria dbname="precificacao_prd.cd_subcategoria" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_concentracao dbname="precificacao_prd.qt_concentracao" )
 column=(type=char(2) updatewhereclause=yes name=id_apresentacao dbname="precificacao_prd.id_apresentacao" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_un_calc_preco dbname="precificacao_prd.id_tipo_un_calc_preco" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="precificacao_prd.id_lei_generico" )
 column=(type=decimal(3) updatewhereclause=yes name=vl_volume dbname="precificacao_prd.vl_volume" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_grama dbname="precificacao_prd.qt_peso_grama" )
 column=(type=long updatewhereclause=yes name=qt_unidades_embalagem dbname="precificacao_prd.qt_unidades_embalagem" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_liquido dbname="precificacao_prd.vl_preco_liquido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_minimo dbname="precificacao_prd.vl_preco_minimo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_maximo dbname="precificacao_prd.vl_preco_maximo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_exponencial dbname="precificacao_prd.vl_preco_exponencial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_apresentacao dbname="precificacao_prd.vl_preco_apresentacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_fat_liquido_anual dbname="precificacao_prd.vl_fat_liquido_anual" )
 retrieve="  SELECT nr_precificacao,   
         	cd_produto,
			nr_cnpj_laboratorio,
			cd_subcategoria,
			qt_concentracao,
			id_apresentacao,
         	id_tipo_un_calc_preco,   
			id_lei_generico,
         	vl_volume,   
         	qt_peso_grama,   
         	qt_unidades_embalagem,   
			vl_preco_liquido,
         	vl_preco_minimo,   
         	vl_preco_maximo,   
         	vl_preco_exponencial,   
         	vl_preco_apresentacao,
			vl_fat_liquido_anual
    FROM precificacao_prd 
Where  nr_precificacao 			= :precificacao
	And cd_subcategoria  		= :CD_Subcategoria
	And qt_concentracao  		= :QT_Concentracao
	And id_apresentacao 			= :ID_Apresentacao
	And id_tipo_un_calc_preco	= :ID_Un_Calc_Preco
	And coalesce(vl_preco_minimo,0) > 0
" arguments=(("precificacao", number),("CD_Subcategoria", string),("QT_Concentracao", number),("ID_Apresentacao", string),("ID_Un_Calc_Preco", string))  sort="cd_subcategoria A qt_concentracao A id_apresentacao A id_tipo_un_calc_preco A id_lei_generico A " )
