table(column=(type=char(9) updatewhereclause=yes name=cd_subcategoria dbname="produto_geral.cd_subcategoria" dbalias="pg.cd_subcategoria" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="subcategoria.de_subcategoria" dbalias="s.de_subcategoria" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="qt_vendida" )
 column=(type=decimal(8) updatewhereclause=yes name=pc_qt_vendida dbname="pc_qt_vendida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo dbname="vl_custo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_liquido dbname="vl_total_liquido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_margem dbname="vl_margem" )
 column=(type=decimal(8) updatewhereclause=yes name=pc_margem dbname="pc_margem" )
 retrieve="select 	pg.cd_subcategoria, 
			s.de_subcategoria,
			sum(r.qt_vendida) as qt_vendida, 
			cast(round(cast(sum(r.qt_vendida) as decimal(18,0)) / rl.qt_total, 8) as decimal(12,8)) as pc_qt_vendida, 
			sum(r.vl_custo) as vl_custo, 
			sum(r.vl_preco_liquido) as vl_total_liquido,
			sum(r.vl_preco_liquido) - sum(r.vl_custo)  as vl_margem,
			cast(round((sum(r.vl_preco_liquido) - sum(r.vl_custo)) / sum(r.vl_preco_liquido),8) as decimal(12,8)) as pc_margem
from resumo_precificacao r
inner join produto_geral pg
	on pg.cd_produto = r.cd_produto
inner join subcategoria s
	on s.cd_subcategoria = pg.cd_subcategoria
left outer join (	select :categoria as cd_categoria, sum(r1.vl_preco_liquido) as vl_total, sum(r1.qt_vendida) as qt_total
						from resumo_precificacao r1
						inner join produto_geral pg1
							on pg1.cd_produto = r1.cd_produto
						Where pg1.cd_marca  = 877
							and substring(pg1.cd_subcategoria,1,6) = :categoria
							and r1.dh_resumo between :data_inicio and :data_termino
						) rl
	on rl.cd_categoria = s.cd_categoria
where pg.cd_marca  = :marca
	and s.cd_categoria = :categoria
	and r.dh_resumo between :data_inicio and :data_termino
group by pg.cd_subcategoria, 
			s.de_subcategoria
order by 3 desc" arguments=(("data_inicio", date),("data_termino", date),("marca", number),("categoria", string)) )
