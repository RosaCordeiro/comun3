table(column=(type=long update=yes updatewhereclause=yes name=nr_precificacao dbname="precificacao_prd.nr_precificacao" dbalias="p.nr_precificacao" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="precificacao_prd.cd_produto" dbalias="p.cd_produto" )
 column=(type=char(2) update=yes updatewhereclause=yes name=cd_unidade_federacao dbname="precificacao_prd.cd_unidade_federacao" dbalias="p.cd_unidade_federacao" )
 column=(type=char(2) update=yes updatewhereclause=yes name=id_rede_filial dbname="precificacao_prd.id_rede_filial" dbalias="p.id_rede_filial" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_margem_minima dbname="precificacao_prd.pc_margem_minima" dbalias="p.pc_margem_minima" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_custo_medio dbname="precificacao_prd.vl_custo_medio" dbalias="p.vl_custo_medio" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_venda_fornecedor dbname="precificacao_prd.vl_preco_venda_fornecedor" dbalias="p.vl_preco_venda_fornecedor" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_reembolso_fpb dbname="precificacao_prd.vl_reembolso_fpb" dbalias="p.vl_reembolso_fpb" )
 column=(type=long updatewhereclause=yes name=cd_tipo_precificacao dbname="precificacao_prd.cd_tipo_precificacao" dbalias="p.cd_tipo_precificacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_minimo dbname="precificacao_prd.vl_preco_minimo" dbalias="p.vl_preco_minimo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_liquido dbname="precificacao_prd.vl_preco_liquido" dbalias="p.vl_preco_liquido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_fat_liquido_anual dbname="precificacao_prd.vl_fat_liquido_anual" dbalias="p.vl_fat_liquido_anual" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_exponencial dbname="precificacao_prd.vl_preco_exponencial" dbalias="p.vl_preco_exponencial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_lab_parceiro dbname="precificacao_prd.vl_preco_lab_parceiro" dbalias="p.vl_preco_lab_parceiro" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_psicologico dbname="precificacao_prd.vl_preco_psicologico" dbalias="p.vl_preco_psicologico" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_final dbname="precificacao_prd.vl_preco_final" dbalias="p.vl_preco_final" )
 column=(type=char(9) updatewhereclause=yes name=cd_subcategoria dbname="precificacao_prd.cd_subcategoria" dbalias="p.cd_subcategoria" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="subcategoria.de_subcategoria" dbalias="s.de_subcategoria" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_concentracao dbname="precificacao_prd.qt_concentracao" dbalias="p.qt_concentracao" )
 column=(type=char(2) updatewhereclause=yes name=id_apresentacao dbname="precificacao_prd.id_apresentacao" dbalias="p.id_apresentacao" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_venda dbname="precificacao_prd.cd_unidade_medida_venda" dbalias="p.cd_unidade_medida_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_atual dbname="precificacao_prd.vl_preco_venda_atual" dbalias="p.vl_preco_venda_atual" )
 column=(type=char(1) updatewhereclause=yes name=id_farmacia_popular dbname="precificacao_prd.id_farmacia_popular" dbalias="p.id_farmacia_popular" )
 column=(type=char(1) updatewhereclause=yes name=id_gratis_farm_popular dbname="precificacao_prd.id_gratis_farm_popular" dbalias="p.id_gratis_farm_popular" )
 column=(type=char(1) updatewhereclause=yes name=id_pbm dbname="precificacao_prd.id_pbm" dbalias="p.id_pbm" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="precificacao_prd.id_lei_generico" dbalias="p.id_lei_generico" )
 column=(type=long updatewhereclause=yes name=cd_grupo_alteracao_preco dbname="precificacao_prd.cd_grupo_alteracao_preco" dbalias="p.cd_grupo_alteracao_preco" )
 column=(type=long updatewhereclause=yes name=cd_marca_produto dbname="precificacao_prd.cd_marca_produto" dbalias="p.cd_marca_produto" )
 retrieve="  SELECT	 	p.nr_precificacao,   
         		p.cd_produto,   
				p.cd_unidade_federacao,   
				p.id_rede_filial,   
				p.pc_margem_minima,   
				p.vl_custo_medio,   
				p.vl_preco_venda_fornecedor,   
				p.vl_reembolso_fpb,   
				p.cd_tipo_precificacao,   
				p.vl_preco_minimo,   
				p.vl_preco_liquido,   
				p.vl_fat_liquido_anual,   
				p.vl_preco_exponencial,   
				p.vl_preco_lab_parceiro,   
				p.vl_preco_psicologico,   
				p.vl_preco_final,   
				p.cd_subcategoria,  
				s.de_subcategoria, 
				p.qt_concentracao,   
				p.id_apresentacao,   
				p.cd_unidade_medida_venda,   
				p.vl_preco_venda_atual,   
				p.id_farmacia_popular,   
				p.id_gratis_farm_popular,   
				p.id_pbm,   
				p.id_lei_generico,   
				p.cd_grupo_alteracao_preco,   
				p.cd_marca_produto  
    FROM precificacao_prd   p
Left Outer Join subcategoria s
	on s.cd_subcategoria = p.cd_subcategoria
where p.nr_precificacao = :precificacao
	and p.cd_tipo_precificacao = :tipo_precificacao
" arguments=(("precificacao", number),("tipo_precificacao", number)) )
