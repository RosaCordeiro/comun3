table(column=(type=long updatewhereclause=yes name=nr_precificacao dbname="precificacao_prd.nr_precificacao" dbalias="pr.nr_precificacao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="precificacao_prd.cd_produto" dbalias="pr.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="pg.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="pg.de_apresentacao_venda" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_un_calc_preco dbname="precificacao_prd.id_tipo_un_calc_preco" dbalias="pr.id_tipo_un_calc_preco" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_apresentacao dbname="qt_apresentacao" )
 column=(type=long updatewhereclause=yes name=qt_unidades_embalagem dbname="precificacao_prd.qt_unidades_embalagem" dbalias="pr.qt_unidades_embalagem" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_grama dbname="precificacao_prd.qt_peso_grama" dbalias="pr.qt_peso_grama" )
 column=(type=decimal(3) updatewhereclause=yes name=vl_volume dbname="precificacao_prd.vl_volume" dbalias="pr.vl_volume" )
 column=(type=char(9) updatewhereclause=yes name=cd_subcategoria dbname="precificacao_prd.cd_subcategoria" dbalias="pr.cd_subcategoria" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="subcategoria.de_subcategoria" dbalias="sc.de_subcategoria" )
 column=(type=long updatewhereclause=yes name=cd_tipo_produto dbname="precificacao_prd.cd_tipo_produto" dbalias="pr.cd_tipo_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_produto dbname="tipo_produto_pricing.de_tipo_produto" dbalias="tpp.de_tipo_produto" )
 column=(type=long updatewhereclause=yes name=cd_marca dbname="marca_produto.cd_marca" dbalias="mp.cd_marca" )
 column=(type=char(40) updatewhereclause=yes name=de_marca dbname="marca_produto.de_marca" dbalias="mp.de_marca" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco dbname="vl_preco" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_minimo dbname="precificacao_prd.vl_preco_minimo" dbalias="pr.vl_preco_minimo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_maximo dbname="precificacao_prd.vl_preco_maximo" dbalias="pr.vl_preco_maximo" )
 retrieve="select 	pr.nr_precificacao, 
			pr.cd_produto, 
			pg.de_produto,
			pg.de_apresentacao_venda,
			pr.id_tipo_un_calc_preco,
			case pr.id_tipo_un_calc_preco
				when 'Q' then cast(pr.qt_unidades_embalagem as decimal(18,3))
				when 'P' then cast(pr.qt_peso_grama as decimal(18,3))
				when 'V' then cast(pr.vl_volume as decimal(18,3))
			else 0 end as qt_apresentacao,	
			pr.qt_unidades_embalagem,
			pr.qt_peso_grama,
			pr.vl_volume,
			pr.cd_subcategoria, 
			sc.de_subcategoria,
			pr.cd_tipo_produto_pricing as cd_tipo_produto,
			tpp.de_tipo_produto,
			mp.cd_marca,
			mp.de_marca,
			coalesce(pr.vl_preco_indexado, coalesce(pr.vl_preco_unificado, coalesce(pr.vl_preco_marca_propria, pr.vl_preco_apresentacao))) as vl_preco, 
			pr.vl_preco_minimo, 
			pr.vl_preco_maximo
from precificacao_prd pr
inner join produto_geral pg
	on pg.cd_produto = pr.cd_produto
inner join marca_produto mp
	on mp.cd_marca = pg.cd_marca
inner join subcategoria sc
	on sc.cd_subcategoria = pr.cd_subcategoria
left outer join tipo_produto_pricing tpp
	on tpp.cd_tipo_produto = pr.cd_tipo_produto_pricing
Where pr.nr_precificacao = :precificacao
	And mp.id_marca_propria = 'S'" arguments=(("precificacao", number)) )
