table(column=(type=long updatewhereclause=yes name=nr_precificacao dbname="precificacao_prd_regional.nr_precificacao" dbalias="pr.nr_precificacao" )
 column=(type=long updatewhereclause=yes name=cd_cidade dbname="precificacao_prd_regional.cd_cidade" dbalias="pr.cd_cidade" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="precificacao_prd_regional.cd_produto" dbalias="pr.cd_produto" )
 column=(type=char(9) updatewhereclause=yes name=cd_subcategoria dbname="precificacao_prd.cd_subcategoria" dbalias="p.cd_subcategoria" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco dbname="precificacao_prd_regional.vl_preco" dbalias="pr.vl_preco" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_minimo dbname="precificacao_prd.vl_preco_minimo" dbalias="p.vl_preco_minimo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_maximo dbname="precificacao_prd.vl_preco_maximo" dbalias="p.vl_preco_maximo" )
 retrieve="select pr.nr_precificacao, pr.cd_cidade, pr.cd_produto, p.cd_subcategoria, pr.vl_preco_regionalizado as vl_preco, p.vl_preco_minimo, p.vl_preco_maximo
from precificacao_prd_regional pr
inner join precificacao_prd p
	on p.nr_precificacao = pr.nr_precificacao
	and p.cd_produto = pr.cd_produto
	and p.id_rede_filial = pr.id_rede_filial
	and p.cd_unidade_federacao = pr.cd_uf
Where pr.nr_precificacao = :precificacao" arguments=(("precificacao", number)) )
