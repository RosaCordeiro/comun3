table(column=(type=long updatewhereclause=yes name=cd_cidade dbname="cd_cidade" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_preco_bruto dbname="vl_preco_bruto" )
 column=(type=decimal(26) updatewhereclause=yes name=vl_preco_liquido dbname="vl_preco_liquido" )
 column=(type=decimal(24) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_faturamento_bruto dbname="vl_faturamento_bruto" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_faturamento_liquido dbname="vl_faturamento_liquido" )
 retrieve="Select 	f.cd_cidade,
			sum(i.qt_vendida) as qt_faturada,
			round(sum(i.qt_vendida * i.vl_preco_unitario) / sum(i.qt_vendida),2) as vl_preco_bruto, 
			sum((i.qt_vendida * i.vl_preco_praticado) - round( i.qt_vendida * i.vl_preco_praticado * (coalesce(n.pc_desconto,0) / 100), 2)) / sum(i.qt_vendida ) as vl_preco_liquido,
			round((1 - round(sum((i.qt_vendida * i.vl_preco_praticado) - round( i.qt_vendida * i.vl_preco_praticado * (coalesce(n.pc_desconto,0) / 100), 2)) / sum(i.qt_vendida * vl_preco_unitario), 4)) * 100, 2) as pc_desconto,
			round(sum(i.qt_vendida * i.vl_preco_unitario),2) as vl_faturamento_bruto, 
			round(sum(round(i.qt_vendida * i.vl_preco_praticado * (1 - n.pc_desconto /100),2)) ,2) as vl_faturamento_liquido
from movimento_estoque m (index idx_produto_data_fil)
inner join item_nf_venda i (index pk_item_nf_venda)
	on i.cd_filial = m.cd_filial_movimento+0
	and i.nr_nf = m.nr_nf+0
	and i.de_serie = m.de_serie
	and i.de_especie = m.de_especie
	and i.cd_produto = m.cd_produto+0
	and i.nr_sequencial = coalesce(m.nr_sequencial, 1)
inner join nf_venda n (index pk_nf_venda)
	on n.cd_filial = m.cd_filial_movimento+0
	and n.nr_nf = m.nr_nf+0
	and n.de_serie = m.de_serie
	and n.de_especie = m.de_especie
inner join filial f (index pk_filial)
	on f.cd_filial = m.cd_filial_movimento+0
left outer join promocao_sos ps (index pk_promocao_sos)
	on ps.cd_promocao_sos = i.cd_promocao_sos
Where m.dh_movimento between :dh_inicio and :dh_fim
	and m.cd_produto = :produto
	and n.dh_cancelamento is null
	and n.nr_nf_anexa is null
  	and m.cd_tipo_movimento = 1
	and ((ps.nr_promocao_marketing is null and ps.id_tipo_promocao = 'N') or i.cd_promocao_sos is null)
	and m.cd_filial_movimento in (select f1.cd_filial 
											from filial f1 
											inner join cidade c1
												on c1.cd_cidade = f1.cd_cidade
											where f1.id_rede_filial = :rede_filial
												and c1.cd_unidade_federacao = :uf)
	and not exists ( 	select 1 from item_nf_venda_desconto ivd1 (index pk_item_nf_venda_desconto)
							Where ivd1.cd_filial = i.cd_filial+0
							and ivd1.nr_nf = i.nr_nf+0
							and ivd1.de_serie = i.de_serie
							and ivd1.de_especie = i.de_especie
							and ivd1.cd_produto = i.cd_produto+0
							and ivd1.nr_sequencial = coalesce(i.nr_sequencial, 1))
Group by f.cd_cidade" arguments=(("dh_inicio", datetime),("dh_fim", datetime),("produto", number),("rede_filial", string),("uf", string)) )
