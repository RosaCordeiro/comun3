table(column=(type=char(9) updatewhereclause=yes name=cd_subcategoria dbname="precificacao_prd.cd_subcategoria" dbalias="p.cd_subcategoria" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="subcategoria.de_subcategoria" dbalias="sc.de_subcategoria" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_concentracao dbname="precificacao_prd.qt_concentracao" dbalias="p.qt_concentracao" )
 column=(type=char(2) updatewhereclause=yes name=id_apresentacao dbname="precificacao_prd.id_apresentacao" dbalias="p.id_apresentacao" )
 column=(type=char(30) updatewhereclause=yes name=de_apresentacao dbname="tipo_apresentacao_produto.de_apresentacao" dbalias="t.de_apresentacao" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_un_calc_preco dbname="precificacao_prd.id_tipo_un_calc_preco" dbalias="p.id_tipo_un_calc_preco" )
 retrieve="select distinct p.cd_subcategoria, sc.de_subcategoria, p.qt_concentracao, p.id_apresentacao, t.de_apresentacao, p.id_tipo_un_calc_preco
from precificacao_prd p
inner join subcategoria sc
	on sc.cd_subcategoria = p.cd_subcategoria
inner join tipo_apresentacao_produto t
	on t.id_apresentacao = p.id_apresentacao
where nr_precificacao = :precificacao
	and qt_concentracao > 0
order by p.cd_subcategoria, p.qt_concentracao, p.id_apresentacao, p.id_tipo_un_calc_preco" arguments=(("precificacao", number)) )
