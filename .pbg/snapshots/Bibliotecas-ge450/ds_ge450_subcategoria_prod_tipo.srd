table(column=(type=char(9) updatewhereclause=yes name=cd_subcategoria dbname="precificacao_prd.cd_subcategoria" dbalias="p.cd_subcategoria" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="subcategoria.de_subcategoria" dbalias="sc.de_subcategoria" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="pg.de_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_un_calc_preco dbname="produto_central.id_tipo_un_calc_preco" dbalias="pc.id_tipo_un_calc_preco" )
 column=(type=long updatewhereclause=yes name=cd_tipo_produto_pricing dbname="produto_central.cd_tipo_produto_pricing" dbalias="pc.cd_tipo_produto_pricing" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_produto_pricing dbname="tipo_produto_pricing.de_tipo_produto_pricing" dbalias="tpp.de_tipo_produto_pricing" )
 retrieve="select distinct p.cd_subcategoria, sc.de_subcategoria, pg.de_produto, pc.id_tipo_un_calc_preco, pc.cd_tipo_produto_pricing, tpp.de_tipo_produto as de_tipo_produto_pricing
from precificacao_prd p
inner join subcategoria sc
	on sc.cd_subcategoria = p.cd_subcategoria
inner join produto_geral pg
	on pg.cd_produto = p.cd_produto
inner join produto_central pc
	on pc.cd_produto = p.cd_produto
Left Outer Join tipo_produto_pricing tpp
	on tpp.cd_tipo_produto = pc.cd_tipo_produto_pricing
where nr_precificacao = :precificacao
	and coalesce(p.vl_preco_minimo,0) > 0
order by p.cd_subcategoria, sc.de_subcategoria, pg.de_produto, pc.id_tipo_un_calc_preco, pc.cd_tipo_produto_pricing" arguments=(("precificacao", number)) )
