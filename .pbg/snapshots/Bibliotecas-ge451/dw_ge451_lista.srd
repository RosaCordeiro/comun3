table(column=(type=long updatewhereclause=yes name=nr_margem dbname="margem_resultado_preco.nr_margem" )
 column=(type=long updatewhereclause=yes name=cd_tipo_margem dbname="margem_resultado_preco.cd_tipo_margem" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_margem dbname="tipo_margem_resultado_preco.de_tipo_margem" )
 column=(type=char(20) updatewhereclause=yes name=de_rede dbname="de_rede" )
 column=(type=char(11) updatewhereclause=yes name=de_lei_generico dbname="de_lei_generico" )
 column=(type=char(40) updatewhereclause=yes name=de_classificacao dbname="classificacao_subcategoria.de_classificacao" )
 column=(type=char(40) updatewhereclause=yes name=de_tier dbname="tier_subcategoria.de_tier" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_margem_resultado dbname="margem_resultado_preco.pc_margem_resultado" )
 retrieve="select 	m.nr_margem,
			m.cd_tipo_margem, 
			t.de_tipo_margem, 
			case m.id_rede_filial
				when 'PP' then 'PRE$$HEX1$$c700$$ENDHEX$$O POPULAR'
				when 'DC' then 'DROGARIA CATARINENSE'
				when 'CP' then 'CATARINENSE PLUS'
				when 'MP' then 'MANIPULA$$HEX2$$c700c300$$ENDHEX$$O'
				when 'FA' then 'FARMAGORA'
				when 'CD' then 'CENTRO DISTRIBUI$$HEX2$$c700c300$$ENDHEX$$O'
			Else '' end as de_rede,
			Case m.id_lei_generico
				when 'R' then 'REFER$$HEX1$$ca00$$ENDHEX$$NCIA'
				when 'S' then 'SIMILAR'
				when 'G' then 'GEN$$HEX1$$c900$$ENDHEX$$RICO'
				when 'E' then 'EQUIVALENTE'
				when 'O' then 'OUTROS'
			Else '' end as de_lei_generico,
			c.de_classificacao,
			ts.de_tier,
			m.pc_margem_resultado
from margem_resultado_preco m
inner join tipo_margem_resultado_preco t
	on t.cd_tipo_margem = m.cd_tipo_margem
left outer join classificacao_subcategoria c
	on c.cd_classificacao = m.cd_classificacao_subcategoria
left outer join tier_subcategoria ts
	on ts.cd_tier = m.cd_tier_subcategoria" )
