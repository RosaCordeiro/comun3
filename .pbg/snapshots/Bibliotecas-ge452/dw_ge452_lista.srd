table(column=(type=long updatewhereclause=yes name=nr_precificacao dbname="precificacao.nr_precificacao" )
 column=(type=char(20) updatewhereclause=yes name=de_tipo_precificacao dbname="tipo_precificacao.de_tipo_precificacao" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf dbname="precificacao.cd_uf" )
 column=(type=char(50) updatewhereclause=yes name=nm_rede_filial dbname="rede_filial.nm_rede_filial" )
 column=(type=char(52) updatewhereclause=yes name=de_subcategoria dbname="de_subcategoria" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="precificacao.id_situacao" values="COLOCADO	C/PROCESSANDO	P/FINALIZADO	F/CALCULADO	T/ERRO	E/REGIONALIZADO	R/APROVADO (REVISADO)	A/" )
 retrieve="select 	p.nr_precificacao, 
			t.de_tipo_precificacao,
			p.cd_uf,
			r.nm_rede_filial,
			case when p.cd_subcategoria is null then '' else s.de_subcategoria||' ('||p.cd_subcategoria||')' end as de_subcategoria,
			p.id_situacao
from precificacao p
inner join tipo_precificacao t
	on t.cd_tipo_precificacao = p.cd_tipo_precificacao
inner join rede_filial r
	on r.id_rede_filial = p.id_rede_filial
left outer join subcategoria s
	on s.cd_subcategoria = p.cd_subcategoria"  sort="nr_precificacao D " )
