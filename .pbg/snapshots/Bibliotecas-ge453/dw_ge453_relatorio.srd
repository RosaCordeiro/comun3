table(column=(type=char(9) updatewhereclause=yes name=tipo dbname="tipo" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cliente_caixa.cd_filial" dbalias="cc.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_regiao dbname="filial.cd_regiao" dbalias="f.cd_regiao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cliente_caixa_produto.cd_produto" dbalias="ccp.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_produto dbname="cliente_caixa_produto.qt_produto" dbalias="ccp.qt_produto" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao dbname="cliente_caixa.dh_movimentacao" dbalias="cc.dh_movimentacao" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio_reserva dbname="cliente_caixa.dh_inicio_reserva" dbalias="cc.dh_inicio_reserva" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_reserva dbname="cliente_caixa.dh_termino_reserva" dbalias="cc.dh_termino_reserva" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="cliente_caixa.nm_cliente" dbalias="cc.nm_cliente" )
 column=(type=char(40) updatewhereclause=yes name=usuario_cliente_funcionario dbname="usuario.cliente_funcionario" dbalias="u2.cliente_funcionario" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_vendedor dbname="cliente_caixa.nr_matricula_vendedor" dbalias="cc.nr_matricula_vendedor" )
 column=(type=char(40) updatewhereclause=yes name=usuario_resp_reserva dbname="usuario.resp_reserva" dbalias="u.resp_reserva" )
 retrieve="SELECT  'VIGENTES' as tipo,
           	cc.cd_filial,
		  	f.nm_fantasia,
		  	f.cd_regiao,
        		ccp.cd_produto,
        		pg.de_produto || ' : ' || pg.de_apresentacao_venda as de_produto,
        		ccp.qt_produto,
        		cc.dh_movimentacao,
        		cc.dh_inicio_reserva,
        		cc.dh_termino_reserva,
        		cc.nm_cliente,
        		u2.nm_usuario as cliente_funcionario,
        		cc.nr_matricula_vendedor,
        		u.nm_usuario as resp_reserva
FROM cliente_caixa cc
INNER JOIN cliente_caixa_produto ccp
ON ccp.cd_filial = cc.cd_filial
   AND ccp.nr_sequencial_cliente_caixa = cc.nr_sequencial
INNER JOIN produto_geral pg
    ON pg.cd_produto = ccp.cd_produto
INNER JOIN filial f
    ON f.cd_filial = cc.cd_filial
LEFT OUTER JOIN usuario u
    ON u.nr_matricula = cc.nr_matricula_vendedor
LEFT OUTER JOIN cliente c
    ON c.cd_cliente = cc.cd_cliente
LEFT OUTER JOIN usuario u2
    ON u2.nr_cpf = c.nr_cpf_cgc
WHERE cc.dh_movimentacao >= :pdt_periodo_de
    and cc.dh_movimentacao <= :pdt_periodo_ate
    AND getdate() BETWEEN cc.dh_inicio_reserva AND cc.dh_termino_reserva
    AND cc.id_tipo = 'R'
    AND cc.nr_nf_venda IS NULL

union all

SELECT  'EXPIRADAS' as tipo,
    			cc.cd_filial,
	 		f.nm_fantasia,
	 		f.cd_regiao,
    			ccp.cd_produto,
    			pg.de_produto || ' : ' || pg.de_apresentacao_venda as de_produto,
    			ccp.qt_produto,
    			cc.dh_movimentacao,
    			cc.dh_inicio_reserva,
    			cc.dh_termino_reserva,
    			cc.nm_cliente,
    			u2.nm_usuario as cliente_funcionario,
    			cc.nr_matricula_vendedor,
    			u.nm_usuario as resp_reserva
FROM cliente_caixa cc
INNER JOIN cliente_caixa_produto ccp
ON ccp.cd_filial = cc.cd_filial
   AND ccp.nr_sequencial_cliente_caixa = cc.nr_sequencial
INNER JOIN produto_geral pg
ON pg.cd_produto = ccp.cd_produto
INNER JOIN filial f
ON f.cd_filial = cc.cd_filial
LEFT OUTER JOIN usuario u
ON u.nr_matricula = cc.nr_matricula_vendedor
LEFT OUTER JOIN cliente c
ON c.cd_cliente = cc.cd_cliente
LEFT OUTER JOIN usuario u2
ON u2.nr_cpf = c.nr_cpf_cgc
WHERE getdate() > cc.dh_termino_reserva
    AND cc.id_tipo = 'R'
    AND cc.nr_nf_venda IS NULL
    and cc.dh_movimentacao >= :pdt_periodo_de
    and cc.dh_movimentacao <= :pdt_periodo_ate
" arguments=(("pdt_periodo_de", date),("pdt_periodo_ate", date))  sort="tipo A cd_regiao A cd_filial A de_produto A " )
