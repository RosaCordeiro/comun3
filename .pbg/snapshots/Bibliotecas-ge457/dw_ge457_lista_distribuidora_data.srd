table(column=(type=datetime updatewhereclause=yes name=dh_pedido dbname="pedido_filial_bloqueio.dh_pedido" )
 column=(type=decimal(0) updatewhereclause=yes identity=yes name=nr_bloqueio dbname="pedido_filial_bloqueio.nr_bloqueio" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="pedido_filial_bloqueio.cd_distribuidora" )
 column=(type=char(1) updatewhereclause=yes name=id_excluir dbname="id_excluir" values="	S/	N" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 retrieve="Select	p.dh_pedido,
		p.nr_bloqueio,
		fo.nm_fantasia,
		p.cd_distribuidora,
		'N' id_excluir,
		0 cd_filial
From pedido_filial_bloqueio As p
	Inner Join fornecedor As fo
		On fo.cd_fornecedor = p.cd_distribuidora
Where p.cd_filial Is Null
	And p.nr_dia_semana	 Is Null
	And p.cd_uf Is Null"  sort="dh_pedido D nm_fantasia A " )
