table(column=(type=datetime updatewhereclause=yes name=dh_pedido dbname="pedido_filial_bloqueio.dh_pedido" dbalias="p.dh_pedido" )
 column=(type=decimal(0) updatewhereclause=yes identity=yes name=nr_bloqueio dbname="pedido_filial_bloqueio.nr_bloqueio" dbalias="p.nr_bloqueio" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_filial_bloqueio.cd_filial" dbalias="p.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia_filial dbname="filial.nm_fantasia_filial" dbalias="f.nm_fantasia_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" dbalias="fo.nm_fantasia" )
 column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="pedido_filial_bloqueio.cd_distribuidora" dbalias="p.cd_distribuidora" )
 column=(type=char(1) updatewhereclause=yes name=id_excluir dbname="id_excluir" values="	S/	N" )
 column=(type=char(40) updatewhereclause=yes name=vl_parametro dbname="parametro_loja.vl_parametro" dbalias="par.vl_parametro" )
 retrieve="  SELECT p.dh_pedido,
		 p.nr_bloqueio,
		 p.cd_filial,
  		 f.nm_fantasia as nm_fantasia_filial,
		 fo.nm_fantasia,
		 p.cd_distribuidora,
	     'N' id_excluir, 
         par.vl_parametro
    FROM pedido_filial_bloqueio p 
    inner join fornecedor fo on fo.cd_fornecedor  = p.cd_distribuidora 
    inner join filial f on f.cd_filial  = p.cd_filial 
	inner join parametro_loja par on par.cd_filial  = f.cd_filial 
        and par.cd_parametro = 'ID_ADM_FILIAL_SAP'
Where p.cd_distribuidora = fo.cd_fornecedor
  and p.cd_filial		 = f.cd_filial
  and p.nr_dia_semana	 is null
  and p.cd_uf is null"  sort="dh_pedido D cd_filial A nm_fantasia A " )
