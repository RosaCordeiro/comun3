table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="filial.cd_filial" dbalias="f.cd_filial" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=id_abre_domingo dbname="id_abre_domingo" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="unidade_federacao.cd_unidade_federacao" dbalias="u.cd_unidade_federacao" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" values="	S/	N" )
 column=(type=char(40) updatewhereclause=yes name=vl_parametro dbname="parametro_loja.vl_parametro" dbalias="par.vl_parametro" )
 retrieve="Select	f.cd_filial,
		f.nm_fantasia,
		Coalesce(f.id_abre_domingo, 'N') As id_abre_domingo,
		u.cd_unidade_federacao,
		'' As id_selecionar, 
		 par.vl_parametro
From filial As f
	Inner Join cidade As c
		On c.cd_cidade = f.cd_cidade
	Inner Join unidade_federacao As u
		On u.cd_unidade_federacao = c.cd_unidade_federacao
	Inner join parametro_loja par on par.cd_filial  = f.cd_filial 
        and par.cd_parametro = 'ID_ADM_FILIAL_SAP'
Where f.id_pedido_centralizado = 'S'
	And f.id_situacao = 'A'
	 And par.vl_parametro = 'N'" update="filial" updatewhere=0 updatekeyinplace=no  sort="nm_fantasia A " )
