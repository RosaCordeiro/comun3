table(column=(type=long updatewhereclause=yes name=cd_filial dbname="controle_pinpad.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=nr_serie dbname="controle_pinpad.nr_serie" )
 column=(type=char(15) updatewhereclause=yes name=de_marca dbname="controle_pinpad.de_marca" )
 column=(type=char(40) updatewhereclause=yes name=de_modelo dbname="controle_pinpad.de_modelo" )
 column=(type=char(25) updatewhereclause=yes name=nr_versao_sb dbname="controle_pinpad.nr_versao_sb" )
 column=(type=char(10) updatewhereclause=yes name=nr_versao_especificacao dbname="controle_pinpad.nr_versao_especificacao" )
 column=(type=char(20) updatewhereclause=yes name=nr_versao_aplic_basica dbname="controle_pinpad.nr_versao_aplic_basica" )
 column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="controle_pinpad.cd_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_ultima_utilizacao dbname="controle_pinpad.dh_ultima_utilizacao" )
 retrieve="Select	c.cd_filial,
		f.nm_fantasia,
		c.nr_serie,
		c.de_marca,
		c.de_modelo,
		c.nr_versao_sb,
		c.nr_versao_especificacao,
		c.nr_versao_aplic_basica,
		c.cd_caixa,
		c.dh_ultima_utilizacao
From controle_pinpad As c
	Inner Join filial As f
		On f.cd_filial = c.cd_filial
Where f.id_situacao = 'A'"  sort="nm_fantasia A " )
