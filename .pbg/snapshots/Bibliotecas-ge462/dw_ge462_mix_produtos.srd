table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_mix_produto dbname="mix_produto.cd_mix_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_mix_produto dbname="mix_produto.de_mix_produto" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(101) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(1) update=yes updatewhereclause=yes name=dh_alteracao dbname="dh_alteracao" )
 column=(type=char(1) update=yes updatewhereclause=yes name=nr_matricula dbname="nr_matricula" )
 retrieve="select a.cd_mix_produto, a.de_mix_produto, c.cd_produto , 
       (c.de_produto + ':' + c.de_apresentacao_estoque) as de_produto, '' as dh_alteracao, '' as nr_matricula   
From mix_produto a
inner join  mix_produto_lista b on b.cd_mix_produto = a.cd_mix_produto
inner join produto_geral c on c.cd_produto=b.cd_produto 
group by a.cd_mix_produto, a.de_mix_produto, c.cd_produto,
c.de_produto,   
       c.de_apresentacao_estoque




" update="mix_produto_lista" updatewhere=0 updatekeyinplace=no  sort="cd_produto A cd_mix_produto A " )
