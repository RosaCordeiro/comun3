table(column=(type=long updatewhereclause=yes key=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(102) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="vw_classificacao_produto.de_subcategoria" )
 column=(type=char(40) updatewhereclause=yes name=de_categoria dbname="vw_classificacao_produto.de_categoria" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo dbname="vw_classificacao_produto.de_subgrupo" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="vw_classificacao_produto.de_grupo" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_compra dbname="produto_geral.cd_unidade_medida_compra" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_venda dbname="produto_geral.cd_unidade_medida_venda" )
 column=(type=long update=yes updatewhereclause=yes name=nr_classificacao_fiscal dbname="produto_geral.nr_classificacao_fiscal" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" )
 column=(type=char(60) updatewhereclause=yes name=de_ncm dbname="ncm.de_ncm" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao_pis_cofins dbname="produto_geral.id_situacao_pis_cofins" )
 column=(type=char(1) update=yes updatewhereclause=yes name=cd_st_origem dbname="produto_geral.cd_st_origem" )
 column=(type=char(1) updatewhereclause=yes name=id_caderno_abcfarma dbname="produto_geral.id_caderno_abcfarma" values="ABC Farma?	S/ABC Farma?	N" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_custo_medio dbname="vl_custo_medio" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_custo_gerencial dbname="vl_custo_gerencial" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="produto_geral.id_lei_generico" )
 column=(type=char(1) updatewhereclause=yes name=id_farmacia_popular dbname="produto_geral.id_farmacia_popular" values="Farm$$HEX1$$e100$$ENDHEX$$cia Pop.?	S/Farm$$HEX1$$e100$$ENDHEX$$cia Pop.?	N" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_ipi dbname="produto_geral.pc_ipi" )
 column=(type=char(7) update=yes updatewhereclause=yes name=cd_cest dbname="produto_geral.cd_cest" )
 column=(type=char(100) updatewhereclause=yes name=de_cest dbname="cest.de_cest" )
 column=(type=char(150) updatewhereclause=yes name=de_historico_fiscal dbname="produto_central.de_historico_fiscal" )
 column=(type=datetime updatewhereclause=yes name=dh_revisao_fiscal dbname="produto_central.dh_revisao_fiscal" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_revisao_fiscal dbname="produto_central.nr_matricula_revisao_fiscal" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_rev_prod dbname="usuario.nm_usuario_rev_prod" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao_ncm dbname="ncm.dh_alteracao_ncm" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_alt_ncm dbname="ncm.nr_matric_alt_ncm" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_alt_ncm dbname="usuario.nm_usuario_alt_ncm" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao_alt_prod dbname="produto_geral.dh_atualizacao_alt_prod" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_alt_prod dbname="produto_geral.nr_matric_alt_prod" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_atualizacao dbname="produto_geral.nr_matricula_atualizacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_alt_prod dbname="usuario.nm_usuario_alt_prod" )
 column=(type=char(1) updatewhereclause=yes name=nm_matricula_atualizacao dbname="nm_matricula_atualizacao" )
 column=(type=char(1) updatewhereclause=yes name=nm_usuario_atualizacao dbname="nm_usuario_atualizacao" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao_prd dbname="dh_atualizacao_prd" )
 retrieve="  SELECT pg.cd_produto, 
			pg.de_produto||': '||pg.de_apresentacao_venda as de_produto,
			pwc.de_subcategoria,
			pwc.de_categoria,
			pwc.de_subgrupo,
			pwc.de_grupo,
			pg.cd_unidade_medida_compra,
			pg.cd_unidade_medida_venda,
			pg.nr_classificacao_fiscal,  
			pg.de_codigo_barras,
			n.de_ncm, 
			pg.id_situacao_pis_cofins,
			pg.cd_st_origem,
			pg.id_caderno_abcfarma,
			round(pc.vl_custo_gerencial * pg.vl_fator_conversao, 2) as vl_custo_medio,   
			round(pc.vl_custo_gerencial_geral * pg.vl_fator_conversao, 2) as vl_custo_gerencial ,
			pg.id_lei_generico,
			pg.id_farmacia_popular,
			pg.pc_ipi,
			pg.cd_cest,
			c.de_cest,
			pc.de_historico_fiscal,
			pc.dh_revisao_fiscal,
			pc.nr_matricula_revisao_fiscal,
			urf.nm_usuario as nm_usuario_rev_prod,
			n.dh_alteracao as dh_alteracao_ncm,
			n.nr_matric_alteracao as nr_matric_alt_ncm,
			uan.nm_usuario as nm_usuario_alt_ncm,
			pg.dh_atualizacao as dh_atualizacao_alt_prod,
			pg.nr_matricula_atualizacao as nr_matric_alt_prod,
			pg.nr_matricula_atualizacao,
			uap.nm_usuario as nm_usuario_alt_prod,
			'' As nm_matricula_atualizacao,
			'' As nm_usuario_atualizacao,
			cast('1900/01/01 00:00:00' as datetime) as dh_atualizacao_prd
    FROM produto_geral pg
Inner join produto_central pc
	on pc.cd_produto = pg.cd_produto
Inner join vw_classificacao_produto pwc
	on pwc.cd_subcategoria = pg.cd_subcategoria
Left Outer Join ncm n
	on n.nr_ncm = pg.nr_classificacao_fiscal
Left Outer Join cest c
	on c.cd_cest = pg.cd_cest
left outer join usuario uan
	on uan.nr_matricula = n.nr_matric_alteracao
left outer join usuario urf
	on urf.nr_matricula = pc.nr_matricula_revisao_fiscal
left outer join usuario uap
	on uap.nr_matricula = pg.nr_matricula_atualizacao
where pg.cd_produto = :produto   
" update="produto_geral" updatewhere=1 updatekeyinplace=no arguments=(("produto", number)) )
