table(column=(type=char(2) update=yes updatewhereclause=yes key=yes name=cd_unidade_federacao dbname="produto_uf.cd_unidade_federacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_unidade_federacao dbname="unidade_federacao.nm_unidade_federacao" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="produto_uf.cd_produto" )
 column=(type=char(1) update=yes updatewhereclause=yes name=cd_tributacao_icms dbname="produto_uf.cd_tributacao_icms" )
 column=(type=long update=yes updatewhereclause=yes name=cd_tipo_icms dbname="produto_uf.cd_tipo_icms" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_icms_compra_preco dbname="produto_uf.pc_icms_compra_preco" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_icms_venda_preco dbname="produto_uf.pc_icms_venda_preco" )
 column=(type=long update=yes updatewhereclause=yes name=cd_tributacao_produto dbname="produto_uf.cd_tributacao_produto" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=pc_reducao_base_st dbname="produto_uf.pc_reducao_base_st" )
 column=(type=long update=yes updatewhereclause=yes name=cd_mensagem_fiscal dbname="produto_uf.cd_mensagem_fiscal" )
 column=(type=char(200) updatewhereclause=yes name=de_mensagem_fiscal dbname="mensagem_fiscal.de_mensagem_fiscal" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_atual dbname="produto_uf.vl_preco_venda_atual" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_maximo dbname="produto_uf.vl_preco_venda_maximo" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_farmacia_popular dbname="produto_uf.vl_preco_farmacia_popular" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_considera_preco_fp_st dbname="produto_uf.id_considera_preco_fp_st" )
 column=(type=char(1) updatewhereclause=yes name=id_sit_especial dbname="id_sit_especial" values="	S/	N" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="tipo_icms.pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_fcp dbname="tipo_icms.pc_fcp" )
 column=(type=long update=yes updatewhereclause=yes name=nr_ncm_situacao dbname="produto_uf.nr_ncm_situacao" )
 column=(type=char(1) updatewhereclause=yes name=id_tributacao_lista_pis_cofins dbname="id_tributacao_lista_pis_cofins" )
 column=(type=char(1) updatewhereclause=yes name=id_tributacao_lei_generico dbname="id_tributacao_lei_generico" )
 retrieve="select p.cd_unidade_federacao,   
		u.nm_unidade_federacao,
		p.cd_produto,      
		p.cd_tributacao_icms,   
		p.cd_tipo_icms,   
		p.pc_icms_compra_preco,
		p.pc_icms_venda_preco,
		p.cd_tributacao_produto,
		p.pc_reducao_base_st,
		p.cd_mensagem_fiscal,
		m.de_mensagem_fiscal,
		p.vl_preco_venda_atual,
		p.vl_preco_venda_maximo,
		p.vl_preco_farmacia_popular,
		p.id_considera_preco_fp_st,
		'N' as id_sit_especial,
		ti.pc_icms,
		ti.pc_fcp,
		p.nr_ncm_situacao,
		coalesce(tp.id_situacao_pis_cofins,'') as id_tributacao_lista_pis_cofins,
		coalesce(tp.id_lei_generico,'') as id_tributacao_lei_generico
from produto_uf p
inner join unidade_federacao u
	on u.cd_unidade_federacao = p.cd_unidade_federacao
left outer join mensagem_fiscal m
	on m.cd_mensagem_fiscal = p.cd_mensagem_fiscal
left outer join tipo_icms ti
	on ti.cd_tipo_icms = p.cd_tipo_icms
left outer join tributa_produtos_farmaceuticos tp
	on tp.cd_tributacao_produto = p.cd_tributacao_produto
where p.cd_produto = :produto
order by  (Case When p.cd_unidade_federacao = 'SC' Then 0 
					   When p.cd_unidade_federacao = 'PR' Then 1
					   When	p.cd_unidade_federacao = 'RS' Then 2 
					   When p.cd_unidade_federacao = 'BA' Then 3
					   When p.cd_unidade_federacao = 'MS' Then 4
					   When p.cd_unidade_federacao = 'SP' Then 5
				Else 6 End), 
			   u.nm_unidade_federacao" update="produto_uf" updatewhere=1 updatekeyinplace=no arguments=(("produto", number)) )
