table(column=(type=long updatewhereclause=yes name=promocao_sos_produto_cd_produto dbname="promocao_sos_produto.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="promocao_sos_produto.pc_desconto" )
 column=(type=long updatewhereclause=yes name=promocao_sos_filial_cd_filial dbname="promocao_sos_filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=saldo_filiais dbname="vw_saldo_atual_produto.saldo_filiais" )
 column=(type=decimal(4) updatewhereclause=yes name=saldo_matriz dbname="saldo_matriz" )
 retrieve="select 	pp.cd_produto,
		 	pg.de_produto,
			pg.de_apresentacao_venda,
			pp.pc_desconto,
			pf.cd_filial,
			f.nm_fantasia,
			vw.qt_saldo_final saldo_filiais,
			v.qt_saldo_final * pg.vl_fator_conversao saldo_matriz
from vw_saldo_atual_produto vw,
	  vw_saldo_atual_produto v,
	  produto_geral pg,
	  promocao_sos_produto pp,
	  promocao_sos ps,
	  promocao_sos_filial pf,
	  filial f
where vw.cd_produto 		= pg.cd_produto
and pg.cd_produto				= pp.cd_produto
and pp.cd_promocao_sos 	= ps.cd_promocao_sos
and pp.cd_promocao_sos	= :promocao
and v.cd_produto				= pg.cd_produto
and pf.cd_promocao_sos		= ps.cd_promocao_sos
and pf.cd_filial					= vw.cd_filial
and f.cd_filial					= pf.cd_filial
and v.cd_filial					= 534	
group By pp.cd_produto,
		 	pg.de_produto,
			pg.de_apresentacao_venda,
			pp.pc_desconto,
			pf.cd_filial,
			f.nm_fantasia,
			vw.qt_saldo_final,
			v.qt_saldo_final * pg.vl_fator_conversao" arguments=(("promocao", number))  sort="de_produto A de_apresentacao_venda A " )
