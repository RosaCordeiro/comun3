 retrieve="select a.qt_minima, a.pc_desconto, b.de_desconto 
from  desconto_progressivo_qtd a
inner join desconto_progressivo b on a.cd_desconto = b.cd_desconto  
where  a.cd_desconto =:cd_desconto
" arguments=(("cd_desconto", number))  sort="qt_minima A " )
