table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(48) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=id_filial dbname="id_filial" initial="'N'" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_marcacao_anterior dbname="id_marcacao_anterior" )
 column=(type=char(40) updatewhereclause=yes name=vl_parametro dbname="parametro_loja.vl_parametro" )
 column=(type=char(40) updatewhereclause=yes name=id_adm_sap dbname="parametro_loja.id_adm_sap" )
 retrieve="select f.cd_filial,   
        case when c.vl_parametro  = 'S' then f.nm_fantasia + '->AdmSAP' else f.nm_fantasia end as nm_fantasia,   
       'N' id_filial,
	   'N' id_marcacao_anterior,
	   p.vl_parametro  ,
	   c.vl_parametro as id_adm_sap 
from filial f,
	   parametro_loja p, 
	   parametro_loja c 
where f.id_situacao = 'A'
  and p.cd_filial = f.cd_filial
  and f.cd_filial = c.cd_filial
  and p.cd_parametro = 'ID_REDE_FILIAL'  
  and f.cd_filial not in (534)
  and c.cd_parametro = 'ID_ADM_FILIAL_SAP'   "  sort="nm_fantasia A " )
