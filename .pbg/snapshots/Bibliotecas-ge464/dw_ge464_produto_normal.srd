table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_promocao_sos dbname="promocao_sos_produto.cd_promocao_sos" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="promocao_sos_produto.cd_produto" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto dbname="promocao_sos_produto.pc_desconto" initial="0" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto_clube dbname="pc_desconto_clube" initial="0" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_alteracao dbname="promocao_sos_produto.dh_alteracao" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_alteracao dbname="promocao_sos_produto.nr_matricula_alteracao" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_atual dbname="produto_geral.vl_preco_venda_atual" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_simulado dbname="vl_preco_simulado" initial="0" )
 column=(type=long update=yes updatewhereclause=yes name=cd_desc_progressivo dbname="promocao_sos_produto.cd_desc_progressivo" )
 column=(type=long updatewhereclause=yes name=cd_desc_progr_anterior dbname="promocao_sos_produto.cd_desc_progr_anterior" )
 column=(type=char(100) updatewhereclause=yes name=desc_normalprogressivo dbname="desconto_progressivo.Desc_NormalProgressivo" )
 column=(type=long update=yes updatewhereclause=yes name=cd_desc_progressivo_clube dbname="promocao_sos_produto.cd_desc_progressivo_clube" )
 column=(type=long updatewhereclause=yes name=cd_desc_progr_clube_anterior dbname="promocao_sos_produto.cd_desc_progr_clube_anterior" )
 column=(type=char(100) updatewhereclause=yes name=desc_clubeprogressivo dbname="desconto_progressivo.Desc_ClubeProgressivo" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_promocao dbname="id_tipo_promocao" )
 retrieve="select p.cd_promocao_sos,
       p.cd_produto,   

       p.pc_desconto,
       Coalesce(p.pc_desconto_clube, 0.00) pc_desconto_clube,
	  

       p.dh_alteracao,
	   p.nr_matricula_alteracao,
       g.de_produto + ' : ' + g.de_apresentacao_venda de_produto,   
       g.vl_preco_venda_atual,
	   0.01 vl_preco_simulado,

 	   p.cd_desc_progressivo,
	   p.cd_desc_progressivo cd_desc_progr_anterior,
       d.de_desconto as Desc_NormalProgressivo,	   
       p.cd_desc_progressivo_clube, 
       p.cd_desc_progressivo_clube  cd_desc_progr_clube_anterior , 
	   e.de_desconto as Desc_ClubeProgressivo, 
       'Q' as id_tipo_promocao     
       
from promocao_sos_produto p  
inner join produto_geral g  on p.cd_produto = g.cd_produto 
left    join   desconto_progressivo d on d.cd_desconto  = p.cd_desc_progressivo
left    join   desconto_progressivo e on e.cd_desconto  = p.cd_desc_progressivo_clube
where p.cd_promocao_sos = :promocao

" update="promocao_sos_produto" updatewhere=0 updatekeyinplace=no arguments=(("promocao", number))  sort="de_produto A " )
