table(column=(type=long update=yes updatewhereclause=yes name=cd_promocao_sos dbname="promocao_sos_produto.cd_promocao_sos" dbalias="p.cd_promocao_sos" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="promocao_sos_produto.cd_produto" dbalias="p.cd_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_anterior dbname="promocao_sos_produto.pc_desconto_anterior" dbalias="p.pc_desconto_anterior" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_alteracao dbname="promocao_sos_produto.dh_alteracao" dbalias="p.dh_alteracao" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="g.vl_fator_conversao" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_preco_venda_atual dbname="vl_preco_venda_atual" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_futuro dbname="produto_uf.vl_preco_venda_futuro" dbalias="u.vl_preco_venda_futuro" )
 column=(type=datetime updatewhereclause=yes name=dh_preco_venda_futuro dbname="produto_uf.dh_preco_venda_futuro" dbalias="u.dh_preco_venda_futuro" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_promocao dbname="promocao_sos.id_tipo_promocao" dbalias="s.id_tipo_promocao" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="produto_uf.cd_unidade_federacao" dbalias="u.cd_unidade_federacao" )
 retrieve="select p.cd_promocao_sos,
         p.cd_produto,
         p.pc_desconto pc_desconto_anterior,
         p.dh_alteracao,
         g.de_produto + ' : ' + g.de_apresentacao_venda de_produto,
	     g.vl_fator_conversao,
         (u.vl_preco_venda_atual / g.vl_fator_conversao) as vl_preco_venda_atual,
	 	u.vl_preco_venda_futuro,
		u.dh_preco_venda_futuro,
		s.id_tipo_promocao, 
		u.cd_unidade_federacao
  from promocao_sos As s
	inner join promocao_sos_produto As p
		on p.cd_promocao_sos = s.cd_promocao_sos
	inner join produto_geral As g
		on g.cd_produto = p.cd_produto
	inner join produto_uf u
		on u.cd_produto = p.cd_produto
 where p.cd_promocao_sos = :promocao
   and u.cd_unidade_federacao = :uf
   and s.id_tipo_promocao = 'Q'" arguments=(("uf", string),("promocao", number))  sort="de_produto A " )
