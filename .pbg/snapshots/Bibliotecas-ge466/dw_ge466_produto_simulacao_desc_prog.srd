table(column=(type=char(100) updatewhereclause=yes name=de_desconto dbname="desconto_progressivo.de_desconto" )
 column=(type=long updatewhereclause=yes name=qtd_qt_minima dbname="desconto_progressivo_qtd.qt_minima" )
 column=(type=decimal(2) updatewhereclause=yes name=qtd_pc_desconto dbname="desconto_progressivo_qtd.pc_desconto" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_preco_venda_atual dbname="vl_preco_venda_atual" )
 column=(type=decimal(26) updatewhereclause=yes name=valor_simulado dbname="valor_simulado" )
 column=(type=decimal(2) updatewhereclause=yes name=valor_preco dbname="Valor_Preco" )
 column=(type=decimal(2) updatewhereclause=yes name=desconto dbname="Desconto" )
 retrieve="select a.de_desconto, 
		b.qt_minima, b.pc_desconto   ,  
       	(u.vl_preco_venda_atual / g.vl_fator_conversao) as vl_preco_venda_atual,
		((u.vl_preco_venda_atual / g.vl_fator_conversao) - ((u.vl_preco_venda_atual / g.vl_fator_conversao) *(b.pc_desconto/100)))   as valor_simulado,
		0.00 as Valor_Preco,
         0.00 as Desconto
From desconto_progressivo a
inner join desconto_progressivo_qtd b on  a.cd_desconto   = b.cd_desconto
inner join promocao_sos_produto     p  on p.cd_desc_progressivo_clube = b.cd_desconto
inner join produto_uf u  	on u.cd_produto = p.cd_produto
inner join produto_geral As g  	on g.cd_produto = p.cd_produto
where p.cd_promocao_sos = :promocao
and     p.cd_produto = :produto 
and     u.cd_unidade_federacao = :uf" arguments=(("uf", string),("promocao", number),("produto", number)) )
