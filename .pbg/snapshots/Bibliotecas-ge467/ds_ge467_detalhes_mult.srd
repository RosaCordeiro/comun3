table(column=(type=char(4) updatewhereclause=yes name=de_banco dbname="de_banco" )
 column=(type=number updatewhereclause=yes name=cd_filial dbname="log_exportacao_sap.cd_filial" dbalias=".cd_filial" )
 column=(type=char(50) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=decimal(0) updatewhereclause=yes key=yes name=nr_atualizacao dbname="log_exportacao_sap.nr_atualizacao" dbalias="a.nr_atualizacao" )
 column=(type=char(100) updatewhereclause=yes name=de_tipo_documento dbname="log_exportacao_sap.de_tipo_documento" dbalias="a.de_tipo_documento" )
 column=(type=char(20) updatewhereclause=yes name=de_referencia dbname="log_exportacao_sap.de_referencia" dbalias="a.de_referencia" )
 column=(type=char(20) updatewhereclause=yes name=nr_documento_sap dbname="log_exportacao_sap.nr_documento_sap" dbalias="a.nr_documento_sap" )
 column=(type=char(20) updatewhereclause=yes name=nr_documento_sap_estornado dbname="log_exportacao_sap.nr_documento_sap_estornado" dbalias="a.nr_documento_sap_estornado" )
 column=(type=datetime updatewhereclause=yes name=dh_exportacao dbname="log_exportacao_sap.dh_exportacao" dbalias="a.dh_exportacao" )
 column=(type=datetime updatewhereclause=yes name=dh_estornado_sap dbname="dh_estornado_sap" )
 column=(type=datetime updatewhereclause=yes name=dh_lancamento dbname="log_exportacao_sap.dh_lancamento" dbalias="a.dh_lancamento" )
 column=(type=char(100) updatewhereclause=yes name=de_erro_cabecalho dbname="de_erro_cabecalho" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" )
 column=(type=char(1) updatewhereclause=yes name=id_status_integracao dbname="id_status_integracao" )
 column=(type=number updatewhereclause=yes name=qt_erros_itens dbname="qt_erros_itens" )
 column=(type=char(1) updatewhereclause=yes name=id_estornado_excluido dbname="id_estornado_excluido" )
 retrieve="select distinct
 	'MULT' as de_banco,
	case a.cd_filial 
		when 100 then 534
		when 534 then 2
		else a.cd_filial 
	end as cd_filial,
	( SELECT C1.FANTASIA
	from M3_FILIAL A1
	INNER JOIN MTMG_PAPELREL B1 ON B1.id = A1.IDA
	INNER JOIN MTMG_IDENT C1 ON C1.id = B1.IDF_IDENT
	WHERE a1.codigo = a.cd_filial
	AND a1.idf_empresa = CASE a.cd_empresa
								 WHEN 1000 THEN 2
								 WHEN 9900 THEN 1
								 WHEN 9600 THEN 21
								 WHEN 9700 THEN 22
								 WHEN 9800 THEN 24
								 WHEN 9500 THEN 21
								 ELSE a.cd_empresa END) AS nm_fantasia,
	a.nr_atualizacao,
	a.de_tipo_doc_mult as de_tipo_documento,
	a.nr_documento_ref as de_referencia,
	a.nr_documento_sap,
	a.nr_documento_sap_estornado,
	a.dh_exportacao,
	coalesce(a.dh_excluido_sap, a.dh_estornado_sap) as dh_estornado_sap,
	a.dh_lancamento,
	coalesce(a.de_erro, ' ') as de_erro_cabecalho,
	'N' as id_selecionar,
	case when (coalesce(a.id_estornar, 'N') = 'S') and (a.dh_estornado_sap is null) then
			'A'
		when (coalesce(a.id_estornar, 'N') = 'S') and (a.dh_estornado_sap is not null) then  
			'B'
		else
			a.id_status_integracao
	end as id_status_integracao,
	(	select count(*) 
			from log_exportacao_sap_item x 
			where x.nr_atualizacao = a.nr_atualizacao 
			and x.de_erro is not null) as qt_erros_itens	,
(CASE WHEN a.dh_estornado_sap is not null THEN 'E' ELSE (CASE WHEN a.dh_excluido_sap is not null THEN 'X' ELSE '' END) END) id_estornado_excluido
from log_exportacao_sap a
where a.nr_atualizacao is not null" update="log_exportacao_sap" updatewhere=0 updatekeyinplace=no )
