table(column=(type=char(3) updatewhereclause=yes name=de_banco dbname="de_banco" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="log_exportacao_sap.nr_atualizacao" )
 column=(type=char(86) updatewhereclause=yes name=de_tipo_documento dbname="de_tipo_documento" )
 column=(type=char(40) updatewhereclause=yes name=de_referencia dbname="log_exportacao_sap.de_referencia" )
 column=(type=char(20) updatewhereclause=yes name=nr_documento_sap dbname="log_exportacao_sap.nr_documento_sap" )
 column=(type=char(20) updatewhereclause=yes name=nr_documento_sap_estornado dbname="log_exportacao_sap.nr_documento_sap_estornado" )
 column=(type=datetime updatewhereclause=yes name=dh_exportacao dbname="log_exportacao_sap.dh_exportacao" )
 column=(type=datetime updatewhereclause=yes name=dh_documento dbname="log_exportacao_sap_historico.dh_documento" )
 column=(type=datetime updatewhereclause=yes name=dh_estornado_sap dbname="log_exportacao_sap.dh_estornado_sap" )
 column=(type=char(100) updatewhereclause=yes name=de_erro_cabecalho dbname="de_erro_cabecalho" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_status_integracao dbname="id_status_integracao" )
 column=(type=long updatewhereclause=yes name=qt_erros_itens dbname="qt_erros_itens" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_nf dbname="log_exportacao_sap.id_tipo_nf" )
 column=(type=char(1) updatewhereclause=yes name=id_estornado_excluido dbname="id_estornado_excluido" )
 retrieve="select distinct
		'SYB' as de_banco,
		c.cd_filial,
		c.nm_fantasia,
		a.nr_atualizacao,
		'('+d.id_tipo_nf+') '+d.de_tipo_nf as de_tipo_documento,
		a.cd_chave de_referencia,
		a.nr_documento_sap,
		a.nr_documento_sap_estornado,
		a.dh_exportacao,
		b.dh_documento,
		a.dh_estornado_sap,
		coalesce(a.de_erro, ' ') as de_erro_cabecalho,
		'N' as id_selecionar,
		case when (coalesce(a.id_estornar, 'N') = 'S') and (a.dh_estornado_sap is null) then
				'A'
			when (coalesce(a.id_estornar, 'N') = 'S') and (a.dh_estornado_sap is not null) then  
				'B'
			else
				a.id_status_integracao
		end as id_status_integracao,
		(	select count(*) 
			from log_exportacao_sap_historico x 
			where x.nr_atualizacao = a.nr_atualizacao 
			and x.de_erro is not null) as qt_erros_itens,
			a.id_tipo_nf,
			'' id_estornado_excluido
from log_exportacao_sap					a
left outer join log_exportacao_sap_historico	b on b.nr_atualizacao	= a.nr_atualizacao
inner join filial									c on c.cd_filial			= a.cd_filial
left join tipo_log_exportacao_sap_nf		d on d.id_tipo_nf		= a.id_tipo_nf
WHERE a.nr_atualizacao is not null"  sort="cd_filial A nr_atualizacao A " )
