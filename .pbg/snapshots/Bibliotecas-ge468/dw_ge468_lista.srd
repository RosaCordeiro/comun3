table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" dbalias="f.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=de_natureza_operacao dbname="nf_diversa.de_natureza_operacao" dbalias="n.de_natureza_operacao" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_diversa.nr_nf" dbalias="n.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_diversa.de_especie" dbalias="n.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_diversa.de_serie" dbalias="n.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_diversa.dh_emissao" dbalias="n.dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_diversa.vl_total_nf" dbalias="n.vl_total_nf" )
 column=(type=char(60) updatewhereclause=yes name=nm_destinatario dbname="nf_diversa.nm_destinatario" dbalias="n.nm_destinatario" )
 column=(type=char(15) updatewhereclause=yes name=nr_cgc_cpf dbname="nf_diversa.nr_cgc_cpf" dbalias="n.nr_cgc_cpf" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_diversa_nfe.de_chave_acesso" dbalias="nfe.de_chave_acesso" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="nf_diversa.dh_cancelamento" dbalias="n.dh_cancelamento" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo_ajuste dbname="motivo_ajuste.de_motivo_ajuste" dbalias="m.de_motivo_ajuste" )
 retrieve="select distinct f.cd_filial,
			f.nm_fantasia,
			n.de_natureza_operacao, 
			n.nr_nf, 
			n.de_especie,
			n.de_serie,
			n.dh_emissao, 
			n.vl_total_nf, 
			n.nm_destinatario, 
			n.nr_cgc_cpf,
			nfe.de_chave_acesso,
			n.dh_cancelamento,
			m.de_motivo_ajuste
From nf_diversa n
	left outer join nf_diversa_nfe nfe on nfe.cd_filial_origem = n.cd_filial_origem
										and nfe.nr_nf = n.nr_nf
										and nfe.de_especie = n.de_especie
										and nfe.de_serie = n.de_serie
	inner join filial f on f.cd_filial = n.cd_filial_origem
	inner join cidade c on c.cd_cidade = f.cd_cidade
	inner join item_nf_diversa i on i.nr_nf = n.nr_nf
										and i.de_especie = n.de_especie
										and i.de_serie = n.de_serie
	left outer join motivo_ajuste m on m.cd_motivo_ajuste = n.cd_motivo_ajuste
where n.dh_emissao >= :inicio
	and n.dh_emissao <= :termino" arguments=(("inicio", datetime),("termino", datetime))  sort="nm_fantasia A " )
