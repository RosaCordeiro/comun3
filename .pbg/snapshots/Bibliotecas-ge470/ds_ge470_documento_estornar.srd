 column=(type=char(3) update=yes updatewhereclause=yes name=de_especie dbname="log_exportacao_sap.de_especie" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_serie dbname="log_exportacao_sap.de_serie" )
 column=(type=char(9) update=yes updatewhereclause=yes name=cd_fornecedor dbname="log_exportacao_sap.cd_fornecedor" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao_docto dbname="log_exportacao_sap.id_situacao_docto" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_documento_mult dbname="log_exportacao_sap.id_documento_mult" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_status_integracao dbname="log_exportacao_sap.id_status_integracao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_exportacao dbname="log_exportacao_sap.dh_exportacao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_importacao dbname="log_exportacao_sap.dh_importacao" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_documento_sap dbname="log_exportacao_sap.nr_documento_sap" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_reprocessar dbname="log_exportacao_sap.id_reprocessar" )
 column=(type=long update=yes updatewhereclause=yes name=nr_lancamento dbname="log_exportacao_sap.nr_lancamento" )
 column=(type=long update=yes updatewhereclause=yes name=nr_lancamento_caixa dbname="log_exportacao_sap.nr_lancamento_caixa" )
 column=(type=char(3) update=yes updatewhereclause=yes name=cd_ambiente_sap dbname="log_exportacao_sap.cd_ambiente_sap" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_estornar dbname="log_exportacao_sap.id_estornar" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_estornado_sap dbname="log_exportacao_sap.dh_estornado_sap" )
 retrieve="  SELECT l.nr_atualizacao,   
         l.cd_empresa,   
         l.cd_chave,   
         l.id_tipo_nf,   
         l.id_tipo_log,   
         l.cd_filial,   
         l.nr_nf,   
         l.de_especie,   
         l.de_serie,   
         l.cd_fornecedor,   
         l.id_situacao_docto,   
         l.id_documento_mult,   
         l.id_status_integracao,   
         l.dh_exportacao,   
         l.dh_importacao,   
         l.nr_documento_sap,   
         l.id_reprocessar,   
         l.nr_lancamento,   
         l.nr_lancamento_caixa,   
         l.cd_ambiente_sap,   
         l.id_estornar,   
         l.dh_estornado_sap  
    FROM log_exportacao_sap  l
where coalesce(l.id_estornar, 'N') = 'S'
	and l.dh_estornado_sap is null
" update="log_exportacao_sap" updatewhere=1 updatekeyinplace=no )
