 column=(type=long update=yes updatewhereclause=yes name=cd_empresa dbname="log_exportacao_sap.cd_empresa" )
 column=(type=char(40) update=yes updatewhereclause=yes name=cd_chave dbname="log_exportacao_sap.cd_chave" )
 column=(type=char(3) update=yes updatewhereclause=yes name=id_tipo_nf dbname="log_exportacao_sap.id_tipo_nf" )
