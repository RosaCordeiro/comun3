table(column=(type=decimal(0) updatewhereclause=yes name=codigo dbname="m3_filial.codigo" )
 column=(type=char(20) updatewhereclause=yes name=cod_conta dbname="mtmg_classe.cod_conta" )
 column=(type=char(400) updatewhereclause=yes name=complhist dbname="m3_movctb.complhist" )
 column=(type=char(1) updatewhereclause=yes name=tipo_lancto dbname="tipo_lancto" )
 column=(type=number updatewhereclause=yes name=vl_lancamento dbname="vl_doc" )
 retrieve="SELECT t.codigo, 
        H.CODIGO AS COD_CONTA, 
        complhist,
        substr(J.NOMELANCTO,1,1) as tipo_lancto,
        sum(J.VALLAN)as VL_DOC
FROM M3_ANACNTCTB A
LEFT OUTER JOIN MTMG_ANALITICO B
ON B.ID = A.IDA
LEFT OUTER JOIN MTMG_SINTETICO C
ON C.ID = B.IDF_SINTETICO
LEFT OUTER JOIN MTMG_CLASSEVIS D
ON D.ID = C.IDA
LEFT OUTER JOIN MTMG_CLASSEVIS F
ON F.ID = B.IDA
LEFT OUTER JOIN MTMG_PLVISUAL G
ON G.ID = F.IDF_PLANOVISUAL
LEFT OUTER JOIN MTMG_CLASSE H
ON H.ID = B.IDF_CLASSE
LEFT OUTER JOIN M3_CTACTB I
ON I.IDA = H.ID
LEFT OUTER JOIN M3_MOVCTB J
ON J.IDF_CONTACONTABIL = I.ID
LEFT OUTER JOIN M3_FILIAL T
ON T.ID = J.IDF_FILIAL
LEFT OUTER JOIN M3_HISPADRAO HP
ON HP.ID = J.IDF_HistoricoPadrao
LEFT OUTER JOIN M3_LCTCTB K
ON K.IDA = J.ID
LEFT OUTER JOIN M3_Integra Q
ON Q.ID = J.IDF_Integra
LEFT OUTER JOIN M3_Docto R
ON R.ID = Q.IDF_Docto
LEFT OUTER JOIN M3_TipDoc S
ON S.ID = R.IDF_TpDocto
LEFT OUTER JOIN M3_PERCENCLS L
ON L.ID = K.IDF_PERCENCLASSES
LEFT OUTER JOIN M3_CENCLS M
ON M.ID                 = L.IDF_CENCLASSES
LEFT OUTER JOIN MTMG_IDENT MI
    ON MI.ID = R.IDF_IDENT
LEFT OUTER JOIN m3_ccusmovctb mc ON mc.idf_movimentocontab = J.id
LEFT OUTER JOIN m3_ccusto mu ON mu.id = mc.idf_centrocusto
LEFT OUTER JOIN mtmg_classe mx ON mx.id = mu.ida
WHERE G.ID              = 688
AND ((L.IDF_CENCLASSES IS NULL)
OR (L.IDF_CENCLASSES    = 21))
and r.doctodigitado = :ps_nr_docto_digitado
and R.nrodocto = :pl_doc
and s.codtpdocto = 'REMVPATIMP'
and VALLAN <> :pdc_valor
group by t.codigo, 
         H.CODIGO, 
         complhist,
         substr(J.NOMELANCTO,1,1)
" arguments=(("ps_nr_docto_digitado", string),("pl_doc", number),("pdc_valor", decimal)) )
