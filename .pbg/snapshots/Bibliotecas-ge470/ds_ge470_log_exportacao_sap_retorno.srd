table(column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="log_exportacao_sap.nr_atualizacao" )
 column=(type=long updatewhereclause=yes name=cd_empresa dbname="log_exportacao_sap.cd_empresa" )
 column=(type=datetime updatewhereclause=yes name=dh_documento dbname="dh_documento" )
 retrieve="select distinct l.nr_atualizacao,
		l.cd_empresa,
		(CASE WHEN lh.dh_documento IS NULL 
				THEN (select max(y.dh_documento)
						 from log_exportacao_sap x
						 inner join log_exportacao_sap_historico y
							on y.nr_atualizacao = x.nr_atualizacao
						 where x.nr_atualizacao < l.nr_atualizacao
							and x.cd_chave = substring(l.cd_chave, 2, len(l.cd_chave) - 1)
							and x.id_tipo_nf = l.id_tipo_nf
							and x.id_tipo_log = l.id_tipo_log
							and x.cd_filial = l.cd_filial
							and x.nr_nf = l.nr_nf
							) 
				ELSE lh.dh_documento 
		END)	dh_documento	
from log_exportacao_sap l
left outer join log_exportacao_sap_historico lh 
  on lh.nr_atualizacao = l.nr_atualizacao
where l.nr_documento_sap is null
   and l.cd_ambiente_sap = :ambiente_sap
   //and l.nr_atualizacao >= 143597
order by l.nr_atualizacao
" arguments=(("ambiente_sap", string)) )
