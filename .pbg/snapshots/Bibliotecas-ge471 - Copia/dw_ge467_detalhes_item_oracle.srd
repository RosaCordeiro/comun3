table(column=(type=decimal(0) updatewhereclause=yes name=nr_item dbname="log_exportacao_sap_item.nr_item" dbalias="a.nr_item" )
 column=(type=char(8) updatewhereclause=yes name=dh_doc dbname="dh_doc" )
 column=(type=char(8) updatewhereclause=yes name=dh_lancmto dbname="dh_lancmto" )
 column=(type=char(1) updatewhereclause=yes name=de_tipo_conta dbname="log_exportacao_sap_item.de_tipo_conta" dbalias="a.de_tipo_conta" )
 column=(type=char(20) updatewhereclause=yes name=nr_conta_contabil_sap dbname="log_exportacao_sap_item.nr_conta_contabil_sap" dbalias="a.nr_conta_contabil_sap" )
 column=(type=char(20) updatewhereclause=yes name=nr_atribuicao dbname="log_exportacao_sap_item.nr_atribuicao" dbalias="a.nr_atribuicao" )
 column=(type=char(20) updatewhereclause=yes name=doc_ref dbname="log_exportacao_sap.doc_ref" dbalias="lo.doc_ref" )
 column=(type=char(20) updatewhereclause=yes name=cd_tipo_doc_mult dbname="log_exportacao_sap.cd_tipo_doc_mult" dbalias="lo.cd_tipo_doc_mult" )
 column=(type=char(10) updatewhereclause=yes name=c_custo_mult dbname="log_exportacao_sap_item.c_custo_mult" dbalias="a.c_custo_mult" )
 column=(type=char(10) updatewhereclause=yes name=c_custo dbname="log_exportacao_sap_item.c_custo" dbalias="a.c_custo" )
 column=(type=char(10) updatewhereclause=yes name=c_lucro dbname="log_exportacao_sap_item.c_lucro" dbalias="a.c_lucro" )
 column=(type=char(4) updatewhereclause=yes name=cd_filial_sap dbname="log_exportacao_sap_item.cd_filial_sap" dbalias="a.cd_filial_sap" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_documento dbname="log_exportacao_sap_item.vl_documento" dbalias="a.vl_documento" )
 column=(type=char(100) updatewhereclause=yes name=de_erro_item dbname="log_exportacao_sap_item.de_erro_item" dbalias="a.de_erro_item" )
 retrieve="select	a.nr_item,
		TO_CHAR(lo.DH_DOCUMENTO,'DD-MM-YY') DH_DOC,
		TO_CHAR(lo.DH_LANCAMENTO,'DD-MM-YY') DH_LANCMTO,
		a.id_tipo_conta as de_tipo_conta,
		a.nr_conta_contabil_sap,
		a.nr_atribuicao,
		lo.NR_DOCUMENTO_REF DOC_REF,
		lo.CD_TIPO_DOC_MULT,
		a.CD_CENTRO_CUSTO_MULT C_CUSTO_MULT,
		a.CD_CENTRO_CUSTO C_CUSTO,
		a.CD_CENTRO_LUCRO C_LUCRO,
		a.CD_FILIAL_SAP,
		a.vl_documento,
		a.de_erro as de_erro_item
from  log_exportacao_sap_item	a
inner join log_exportacao_sap lo
	on lo.nr_atualizacao = a.nr_atualizacao
where a.nr_atualizacao	= :nr_atualizacao
order by a.nr_item" arguments=(("nr_atualizacao", number)) )
