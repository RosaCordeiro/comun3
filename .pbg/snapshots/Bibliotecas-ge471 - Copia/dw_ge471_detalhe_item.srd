 retrieve="select 	nr_atualizacao_log, 
			nr_atualizacao_item, 
			nr_item_sequencial, 
			id_tipo_log, 
			id_classe_log, 
			nr_mensagem, 
			coalesce(de_log,'') as de_log, 
			coalesce(de_complemento_log,'') as de_complemento_log
from log_exportacao_docto_det
Where nr_atualizacao_log = :nr_atualizacao" update="log_exportacao_docto_det" updatewhere=1 updatekeyinplace=no arguments=(("nr_atualizacao", number)) )
