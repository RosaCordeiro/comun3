table(column=(type=char(3) updatewhereclause=yes name=cd_ambiente_sap dbname="log_exportacao_docto.cd_ambiente_sap" dbalias="le.cd_ambiente_sap" )
 column=(type=char(3) updatewhereclause=yes name=mandt dbname="mandt" )
 column=(type=char(40) updatewhereclause=yes name=werks dbname="integracao_sap.werks" dbalias="isf.werks" )
 column=(type=char(5) updatewhereclause=yes name=cdsis dbname="cdsis" )
 column=(type=char(3) updatewhereclause=yes name=nupdv dbname="nupdv" )
 column=(type=char(4) updatewhereclause=yes name=tpopr dbname="tpopr" )
 column=(type=char(2) updatewhereclause=yes name=mvend dbname="mvend" )
 column=(type=datetime updatewhereclause=yes name=dtopr dbname="log_exportacao_docto.dtopr" dbalias="le.dtopr" )
 column=(type=char(30) updatewhereclause=yes name=ntran dbname="ntran" )
 column=(type=char(3) updatewhereclause=yes name=serie dbname="log_exportacao_docto.serie" dbalias="le.serie" )
 column=(type=long updatewhereclause=yes name=seqnu dbname="seqnu" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="log_exportacao_docto.nr_atualizacao" dbalias="le.nr_atualizacao" )
 retrieve="  SELECT 
		le.cd_ambiente_sap,
		'500' as mandt,
		isf.cd_chave_sap as werks,
		'00001' as cdsis,
		'999' as nupdv,
		'1806' as tpopr,
		'10' as mvend,
		le.dh_documento as dtopr,
		cast(le.nr_transacao as varchar) as ntran,
		le.de_serie as serie,
		001 as seqnu,
		le.nr_atualizacao 
       
    FROM log_exportacao_docto le
INNER JOIN integracao_sap isf
	ON isf.cd_chave_legado = cast(le.cd_filial as varchar)
	AND isf.cd_empresa = 1000
	AND isf.cd_tabela = 'FILIAL'
WHERE le.nr_atualizacao = :pdc_Nr_Atualizacao" arguments=(("pdc_Nr_Atualizacao", decimal)) )
