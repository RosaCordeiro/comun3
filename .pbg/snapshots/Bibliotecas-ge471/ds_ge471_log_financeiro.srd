 column=(type=decimal(2) updatewhereclause=yes name=taxad dbname="taxad" )
 column=(type=char(30) updatewhereclause=yes name=nsuid dbname="log_exportacao_docto_fin.nsuid" dbalias="lf.nsuid" )
 column=(type=char(30) updatewhereclause=yes name=banad dbname="log_exportacao_docto_fin.banad" dbalias="lf.banad" )
 column=(type=char(8) updatewhereclause=yes name=nucov dbname="nucov" )
 column=(type=char(60) updatewhereclause=yes name=nacov dbname="log_exportacao_docto_fin.nacov" dbalias="lf.nacov" )
 column=(type=char(15) updatewhereclause=yes name=mcvdo dbname="log_exportacao_docto_fin.mcvdo" dbalias="lf.mcvdo" )
 column=(type=char(60) updatewhereclause=yes name=ncvdo dbname="log_exportacao_docto_fin.ncvdo" dbalias="lf.ncvdo" )
 column=(type=decimal(4) updatewhereclause=yes name=pctax dbname="log_exportacao_docto_fin.pctax" dbalias="lf.pctax" )
 column=(type=char(1) updatewhereclause=yes name=nrzae dbname="log_exportacao_docto_fin.nrzae" dbalias="lf.nrzae" )
 column=(type=char(60) updatewhereclause=yes name=obspg dbname="obspg" )
 column=(type=char(40) updatewhereclause=yes name=xref3 dbname="log_exportacao_docto_fin.xref3" dbalias="lf.xref3" )
 column=(type=char(40) updatewhereclause=yes name=rbank dbname="log_exportacao_docto_fin.rbank" dbalias="lf.rbank" )
 column=(type=char(40) updatewhereclause=yes name=nrautcd dbname="log_exportacao_docto_fin.nrautcd" dbalias="lf.nrautcd" )
 retrieve="  SELECT 
		'500' as mandt,
		isf.cd_chave_sap as werks,
		'00001' as cdsis,
		'999' as nupdv,
		'1806' as tpopr,
		'10' as mvend,
		le.dh_documento as dtopr,
		cast(le.nr_transacao as varchar) as ntran,
		le.de_serie as serie,
		001 as seqnu,
		lf.nr_atualizacao,   
		lf.nr_sequencial as finnu,   
		lf.qt_parcelas as pcela,   
		lf.qt_dias as qtdia,   
		lf.cd_forma_pagto as cdfin,   
		lf.cd_condicao_pagto as zterm,   
		lf.vl_total_finalizadora * case when le.id_tipo_docto in ('CV','DV','EST','CGF','CIS','CFS') then -1 else 1 end as vlrec,   
		lf.nr_cartao as cardn,   
		lf.nr_autorizacao as cdaut,   
		lf.dh_operacao as dtaut,   
		cast(lf.dh_credito as date) as dtpag, 
		cast(cast(lf.dh_credito as time) as datetime) as hrpag,
		lf.cd_banco as bnknu,   
		lf.nr_agencia as agnnu,    
		lf.nr_conta as connu,   
		lf.de_cmc7 as ccmc7,   
		lf.nr_cheque as chqnu,   
		lf.nm_titular as chqna,   
		lf.nr_cnpj as stcd1,   
		lf.nr_cpf as stcd2,   
		lf.nr_ie as stcd3,   
		lf.nr_referencia_banco as refbn,   
		lf.nr_boleto as refbl,   
		cast(lf.cd_administradora as char(3)) as redad,   
		lf.vl_comissao * case when le.id_tipo_docto in ('CV','DV','EST','CGF','CIS','CFS') then -1 else 1 end as taxad,   
		lf.nr_nsu as nsuid,   
		lf.cd_bandeira as banad,   
		cast(lf.cd_convenio as varchar(8)) as nucov,   
		lf.nm_convenio as nacov,   
		lf.cd_conveniado as mcvdo,   
		lf.nm_conveniado as ncvdo,   
		// lf.nr_parcela,   
		lf.pc_taxa_cartao as pctax,   
		lf.id_razao_especial as nrzae,   
		// lf.id_query,   
		case when coalesce(lf.cd_autorizacao_cd,'')<>'' then lf.cd_autorizacao_cd else lf.obspg end as obspg,
		lf.xref3,
		lf.rbank, 
		lf.nrautcd
		
    FROM log_exportacao_docto_fin lf
INNER JOIN log_exportacao_docto le
	ON le.nr_atualizacao = lf.nr_atualizacao
INNER JOIN integracao_sap isf
	ON isf.cd_chave_legado = cast(le.cd_filial as varchar)
	AND isf.cd_empresa = 1000
	AND isf.cd_tabela = 'FILIAL'
WHERE lf.nr_atualizacao = :pdc_Nr_Atualizacao" arguments=(("pdc_Nr_Atualizacao", decimal)) )
