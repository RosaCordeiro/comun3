 column=(type=decimal(3) update=yes updatewhereclause=yes name=vlbrt dbname="hubt101.vlbrt" initial="0" )
 column=(type=char(35) update=yes updatewhereclause=yes name=nlote dbname="hubt101.nlote" )
 column=(type=char(40) update=yes updatewhereclause=yes name=dcref dbname="hubt101.dcref" )
 column=(type=long update=yes updatewhereclause=yes name=qtitm dbname="hubt101.qtitm" initial="0" )
 column=(type=long update=yes updatewhereclause=yes name=qtfrm dbname="hubt101.qtfrm" )
 retrieve="  SELECT 	a.cd_ambiente_sap,   
				a.mandt,   
				a.werks,   
				a.cdsis,   
				a.nupdv,   
				a.tpopr,   
				a.mvend,   
				a.dtopr,   
				a.ntran,   
				a.serie,   
				a.seqnu,   
				a.cdopr,   
				a.kunnr,   
				a.stcd1,   
				a.stcd2,   
				a.stcd3,   
				a.stcd4,   
				a.stcd5,   
				a.waerk,   
				a.vlliq,   
				a.vlbrt,   
				a.nlote,   
				a.dcref,   
				a.qtitm,   
				a.qtfrm  
    FROM hubt101 a
Where a.cd_ambiente_sap 	= :ps_ambiente_sap
	And a.mandt 				= :ps_mandante
	And a.werks					= :ps_filial_sap
	And a.cdsis					= :ps_sistema 
	And a.nupdv					= :ps_num_pdv 
	And a.tpopr					= :ps_tipo_operacao 
	And a.mvend				= :ps_meio_venda   
	And a.dtopr					= :pdt_operacao 
	And a.ntran					= :ps_transacao   
	And a.serie					= :ps_serie 
	And a.seqnu					= :pl_sequencial" update="hubt101" updatewhere=1 updatekeyinplace=no arguments=(("ps_ambiente_sap", string),("ps_mandante", string),("ps_filial_sap", string),("ps_sistema", string),("ps_num_pdv", string),("ps_tipo_operacao", string),("ps_meio_venda", string),("pdt_operacao", datetime),("ps_transacao", string),("ps_serie", string),("pl_sequencial", number)) )
