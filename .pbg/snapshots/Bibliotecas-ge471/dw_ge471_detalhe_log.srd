table(column=(type=decimal(0) update=yes updatewhereclause=yes key=yes name=nr_atualizacao_log dbname="log_exportacao_docto_det.nr_atualizacao_log" )
 column=(type=decimal(0) update=yes updatewhereclause=yes key=yes name=nr_atualizacao_item dbname="log_exportacao_docto_det.nr_atualizacao_item" )
 column=(type=long update=yes updatewhereclause=yes name=nr_item_sequencial dbname="log_exportacao_docto_det.nr_item_sequencial" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_tipo_log dbname="log_exportacao_docto_det.id_tipo_log" )
 column=(type=char(20) update=yes updatewhereclause=yes name=id_classe_log dbname="log_exportacao_docto_det.id_classe_log" )
 column=(type=long update=yes updatewhereclause=yes name=nr_mensagem dbname="log_exportacao_docto_det.nr_mensagem" )
