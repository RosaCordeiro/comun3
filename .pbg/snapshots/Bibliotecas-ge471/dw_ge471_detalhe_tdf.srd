table(column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="log_exportacao_docto.nr_atualizacao" )
 column=(type=number updatewhereclause=yes name=nr_lote_envio dbname="log_exportacao_docto.nr_lote_envio" )
 column=(type=char(60) updatewhereclause=yes name=cd_chave_docto dbname="log_exportacao_docto.cd_chave_docto" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_docto dbname="log_exportacao_docto.id_tipo_docto" )
 column=(type=char(40) updatewhereclause=yes name=cd_integracao dbname="log_exportacao_docto.cd_integracao" )
 column=(type=number updatewhereclause=yes name=cd_filial dbname="log_exportacao_docto.cd_filial" )
 column=(type=char(50) updatewhereclause=yes name=nm_filial dbname="mtmg_ident.nm_filial" )
 column=(type=char(40) updatewhereclause=yes name=cd_filial_sap dbname="integracao_sap.cd_filial_sap" )
 column=(type=number updatewhereclause=yes name=nr_nf dbname="log_exportacao_docto.nr_nf" )
 column=(type=number updatewhereclause=yes name=nr_transacao dbname="log_exportacao_docto.nr_transacao" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="log_exportacao_docto.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="log_exportacao_docto.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_documento dbname="log_exportacao_docto.dh_documento" )
 column=(type=datetime updatewhereclause=yes name=dh_exportacao dbname="log_exportacao_docto.dh_exportacao" )
 column=(type=datetime updatewhereclause=yes name=dh_processamento dbname="log_exportacao_docto.dh_processamento" )
 column=(type=datetime updatewhereclause=yes name=dh_exclusao dbname="log_exportacao_docto.dh_exclusao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_exclusao dbname="log_exportacao_docto.nr_matricula_exclusao" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_log dbname="log_exportacao_docto.id_situacao_log" )
 column=(type=char(20) updatewhereclause=yes name=nr_documento_sap dbname="log_exportacao_docto.nr_documento_sap" )
 column=(type=char(3) updatewhereclause=yes name=cd_ambiente_sap dbname="log_exportacao_docto.cd_ambiente_sap" values="DESENVOLVIMENTO (TXD)	TXD/QUALIDADE (TXQ)	TXQ/PRODU$$HEX2$$c700c300$$ENDHEX$$O (TXP)	TXP/TESTE INTEGRADO (600)	TX6/TESTE INTEGRADO (500)	TXB/" )
 column=(type=char(1) updatewhereclause=yes name=id_revisado dbname="log_exportacao_docto.id_revisado" values="REPROCESSADO	R/PENDENTE	P/IGNORADO	I/SUCESSO	S/" )
 column=(type=datetime updatewhereclause=yes name=dh_revisao dbname="log_exportacao_docto.dh_revisao" )
 column=(type=char(255) updatewhereclause=yes name=de_revisao dbname="log_exportacao_docto.de_revisao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_revisao dbname="log_exportacao_docto.nr_matricula_revisao" )
 column=(type=char(6) updatewhereclause=yes name=nm_usuario_revisao dbname="log_exportacao_docto.nm_usuario_revisao" )
 retrieve="  SELECT		l.nr_atualizacao,   
				l.nr_lote_envio,   
				l.cd_chave_docto,   
				l.id_tipo_docto,   
				l.cd_integracao,
				l.cd_filial,
				i.fantasia as nm_filial,
				ifil.cd_chave_sap as cd_filial_sap,
				l.nr_nf,   
				l.nr_transacao,   
				l.de_especie,   
				l.de_serie,   
				l.dh_documento,   
				l.dh_exportacao,   
				l.dh_processamento,   
				l.dh_exclusao,   
				l.nr_matricula_exclusao,
				l.id_situacao_log,   
				l.nr_documento_sap,   
				l.cd_ambiente_sap,   
				l.id_revisado,   
				l.dh_revisao,   
				l.de_revisao,   
				l.nr_matricula_revisao,
				l.nr_matricula_revisao as nm_usuario_revisao
    FROM log_exportacao_docto l
		Left Outer Join m3_filial f 
			on f.codigo 	= CASE l.cd_filial
								WHEN 534 THEN 100
								WHEN 2 THEN 534
								WHEN 688 THEN 534
							ELSE l.cd_filial END
		Left Outer Join MTMG_PAPELREL m  
			on m.id = f.ida
		Left Outer Join MTMG_IDENT i
			on i.id = m.idf_ident
		Left Outer Join integracao_sap ifil
			on ifil.cd_empresa = 1000
			and ifil.cd_chave_legado = l.cd_filial
			and ifil.cd_tabela = 'FILIAL'
Where l.nr_atualizacao = :nr_atualizacao" arguments=(("nr_atualizacao", decimal)) )
