 column=(type=char(4) update=yes updatewhereclause=yes name=bnknu dbname="hubt104.bnknu" )
 column=(type=char(15) update=yes updatewhereclause=yes name=agnnu dbname="hubt104.agnnu" )
 column=(type=char(18) update=yes updatewhereclause=yes name=connu dbname="hubt104.connu" )
 column=(type=char(12) update=yes updatewhereclause=yes name=chqnu dbname="hubt104.chqnu" )
 column=(type=char(40) update=yes updatewhereclause=yes name=chqna dbname="hubt104.chqna" )
 column=(type=char(34) update=yes updatewhereclause=yes name=ccmc7 dbname="hubt104.ccmc7" )
 column=(type=char(50) update=yes updatewhereclause=yes name=refbn dbname="hubt104.refbn" )
 column=(type=char(50) update=yes updatewhereclause=yes name=refbl dbname="hubt104.refbl" )
 column=(type=char(10) update=yes updatewhereclause=yes name=kunnr dbname="hubt104.kunnr" )
 column=(type=char(14) update=yes updatewhereclause=yes name=stcd1 dbname="hubt104.stcd1" )
 column=(type=char(11) update=yes updatewhereclause=yes name=stcd2 dbname="hubt104.stcd2" )
 column=(type=char(18) update=yes updatewhereclause=yes name=stcd3 dbname="hubt104.stcd3" )
 column=(type=char(25) update=yes updatewhereclause=yes name=cardn dbname="hubt104.cardn" )
 column=(type=char(30) update=yes updatewhereclause=yes name=nsuid dbname="hubt104.nsuid" )
 column=(type=datetime updatewhereclause=yes name=dtaut dbname="hubt104.dtaut" )
 column=(type=char(30) update=yes updatewhereclause=yes name=cdaut dbname="hubt104.cdaut" )
 column=(type=datetime update=yes updatewhereclause=yes name=dtpag dbname="hubt104.dtpag" )
 column=(type=datetime update=yes updatewhereclause=yes name=hrpag dbname="hubt104.hrpag" )
 column=(type=char(30) update=yes updatewhereclause=yes name=obspg dbname="hubt104.obspg" )
 column=(type=char(3) update=yes updatewhereclause=yes name=nroad dbname="hubt104.nroad" )
 column=(type=decimal(2) updatewhereclause=yes name=pctax dbname="hubt104.pctax" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=taxad dbname="hubt104.taxad" )
 column=(type=char(3) update=yes updatewhereclause=yes name=redad dbname="hubt104.redad" )
 column=(type=char(5) update=yes updatewhereclause=yes name=banad dbname="hubt104.banad" )
 column=(type=char(15) update=yes updatewhereclause=yes name=nucov dbname="hubt104.nucov" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nacov dbname="hubt104.nacov" )
 column=(type=char(15) update=yes updatewhereclause=yes name=mcvdo dbname="hubt104.mcvdo" )
 column=(type=char(40) update=yes updatewhereclause=yes name=ncvdo dbname="hubt104.ncvdo" )
 column=(type=char(1) update=yes updatewhereclause=yes name=nrzae dbname="hubt104.nrzae" )
 column=(type=char(40) update=yes updatewhereclause=yes name=xref3 dbname="hubt104.xref3" )
 column=(type=char(40) update=yes updatewhereclause=yes name=rbank dbname="hubt104.rbank" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nrautcd dbname="hubt104.nrautcd" )
 retrieve="  SELECT 	a.cd_ambiente_sap,   
				a.mandt,   
				a.werks,   
				a.cdsis,   
				a.nupdv,   
				a.tpopr,   
				a.mvend,   
				a.dtopr,   
				a.ntran,   
				a.serie,   
				a.seqnu,   
				a.finnu,   
				a.cdfin,   
				a.pcela,   
				a.qtdia,   
				a.zterm,   
				a.vlrec,   
				a.vltro,   
				a.bnknu,   
				a.agnnu,   
				a.connu,   
				a.chqnu,   
				a.chqna,   
				a.ccmc7,   
				a.refbn,   
				a.refbl,   
				a.kunnr,   
				a.stcd1,   
				a.stcd2,   
				a.stcd3,   
				a.cardn,   
				a.nsuid,
				a.dtaut,   
				a.cdaut,   
				a.dtpag,   
				a.hrpag,   
				a.obspg,   
				a.nroad,
				a.pctax,   
				a.taxad,   
				a.redad,   
				a.banad,   
				a.nucov,   
				a.nacov,   
				a.mcvdo,   
				a.ncvdo,
				a.nrzae,
				a.xref3,
				a.rbank,
				a.nrautcd
    FROM hubt104 a 
Where a.cd_ambiente_sap 	= :ps_ambiente_sap
	And a.mandt 				= :ps_mandante
	And a.werks					= :ps_filial_sap
	And a.cdsis					= :ps_sistema 
	And a.nupdv					= :ps_num_pdv 
	And a.tpopr					= :ps_tipo_operacao 
	And a.mvend				= :ps_meio_venda   
	And a.dtopr					= :pdt_operacao 
	And a.ntran					= :ps_transacao   
	And a.serie					= :ps_serie 
	And a.seqnu					= :pl_sequencial" update="hubt104" updatewhere=1 updatekeyinplace=no arguments=(("ps_ambiente_sap", string),("ps_mandante", string),("ps_filial_sap", string),("ps_sistema", string),("ps_num_pdv", string),("ps_tipo_operacao", string),("ps_meio_venda", string),("pdt_operacao", datetime),("ps_transacao", string),("ps_serie", string),("pl_sequencial", number))  sort="finnu A " )
