table(column=(type=char(3) update=yes updatewhereclause=yes key=yes name=cd_ambiente_sap dbname="hubt104.cd_ambiente_sap" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=mandt dbname="hubt104.mandt" )
 column=(type=char(4) update=yes updatewhereclause=yes key=yes name=werks dbname="hubt104.werks" )
 column=(type=char(5) update=yes updatewhereclause=yes key=yes name=cdsis dbname="hubt104.cdsis" )
 column=(type=char(6) update=yes updatewhereclause=yes key=yes name=nupdv dbname="hubt104.nupdv" )
 column=(type=char(4) update=yes updatewhereclause=yes key=yes name=tpopr dbname="hubt104.tpopr" )
 column=(type=char(2) update=yes updatewhereclause=yes key=yes name=mvend dbname="hubt104.mvend" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=dtopr dbname="hubt104.dtopr" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=ntran dbname="hubt104.ntran" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=serie dbname="hubt104.serie" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seqnu dbname="hubt104.seqnu" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=finnu dbname="hubt104.finnu" )
 column=(type=char(4) update=yes updatewhereclause=yes name=cdfin dbname="hubt104.cdfin" initial="PCS1" )
 column=(type=long update=yes updatewhereclause=yes name=pcela dbname="hubt104.pcela" initial="1" )
 column=(type=long update=yes updatewhereclause=yes name=qtdia dbname="hubt104.qtdia" initial="0" )
