table(column=(type=long updatewhereclause=yes name=status dbname="status" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_log dbname="id_situacao_log" )
 column=(type=char(3) updatewhereclause=yes name=cd_ambiente_sap dbname="cd_ambiente_sap" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="nr_atualizacao" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_docto dbname="id_tipo_docto" )
 column=(type=char(22) updatewhereclause=yes name=de_tipo_docto dbname="de_tipo_docto" )
 column=(type=char(100) updatewhereclause=yes name=cd_chave_docto dbname="cd_chave_docto" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_transacao dbname="nr_transacao" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=char(20) updatewhereclause=yes name=nr_documento_sap dbname="nr_documento_sap" )
 column=(type=datetime updatewhereclause=yes name=dh_documento dbname="dh_documento" )
 column=(type=datetime updatewhereclause=yes name=dh_exportacao dbname="dh_exportacao" )
 column=(type=datetime updatewhereclause=yes name=dh_processamento dbname="dh_processamento" )
 column=(type=long updatewhereclause=yes name=nr_lote_envio dbname="nr_lote_envio" )
 column=(type=char(1) updatewhereclause=yes name=id_revisado dbname="id_revisado" )
 column=(type=long updatewhereclause=yes name=qt_erros_itens dbname="qt_erros_itens" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" values="	S/	N" )
 column=(type=char(3) updatewhereclause=yes name=nm_destino dbname="nm_destino" )
 column=(type=char(6) updatewhereclause=yes name=base_dados dbname="base_dados" )
 column=(type=char(3) updatewhereclause=yes name=cd_setor dbname="cd_setor" values="INFORM$$HEX1$$c100$$ENDHEX$$TICA	INF/FIN CART$$HEX1$$d500$$ENDHEX$$ES	FIN/FISCAL	FIS/FIN T$$HEX1$$cd00$$ENDHEX$$TULOS	FIT/" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="nr_atualizacao" )
 retrieve="select case a.id_situacao_log 
			when 'C' then 1
			when 'E' then 2
			when 'V' then 2
			when 'F' then 2
			when 'A' then 3
			when 'P' then 4
			when 'I' then 5
			when 'X' then 6
			else 0 end as status,
		a.id_situacao_log ,
		a.cd_ambiente_sap,
		c.nm_fantasia,
		c.cd_filial,
		a.nr_atualizacao,
		a.id_tipo_docto,
		case a.id_tipo_docto
			when 'AN' then 'VENDA ANEXA'
			when 'CA' then 'CANC. ANEXA'
			when 'VD' then 'VENDA'
			when 'CV' then 'CANC. VENDA'
			when 'RC' then 'RECARGA'
			when 'RZ' then 'REDU$$HEX2$$c700c300$$ENDHEX$$O Z'
			when 'CX' then 'CAIXA'
			when 'PED' then 'PEDIDO ECOMMERCE'
			when 'POS' then 'INVERS$$HEX1$$c300$$ENDHEX$$O POS'
			when 'PGA' then 'PGTO ANTECIPADO MANIP.'
		else a.id_tipo_docto end as de_tipo_docto,
		a.cd_chave_docto,
		a.nr_nf, 
		a.nr_transacao, 
		a.de_especie,
		a.de_serie,
		a.nr_documento_sap,
		a.dh_documento,
		a.dh_exportacao,
		a.dh_processamento,
		a.nr_lote_envio,
		a.id_revisado,
		(	select count(1) 
			from log_exportacao_docto_det x (index pk_log_exportacao_docto_det)
			where x.nr_atualizacao_log = a.nr_atualizacao 
			and x.id_tipo_log not in ('P', 'X')) as qt_erros_itens,
		'N' as id_selecionar,
	 	coalesce(a.id_interface,'CAR') as nm_destino,
		'SYBASE' as base_dados,
		'INF' as cd_setor,
		a.nr_atualizacao as nr_atualizacao
from log_exportacao_docto a
inner join filial	c 
		on c.cd_filial = a.cd_filial
WHERE a.nr_atualizacao is not null" )
