table(column=(type=long updatewhereclause=yes name=status dbname="status" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_log dbname="log_exportacao_docto.id_situacao_log" )
 column=(type=char(3) updatewhereclause=yes name=cd_ambiente_sap dbname="log_exportacao_docto.cd_ambiente_sap" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="m3_filial.cd_filial" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="log_exportacao_docto.nr_atualizacao" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_docto dbname="log_exportacao_docto.id_tipo_docto" )
 column=(type=char(16) updatewhereclause=yes name=de_tipo_docto dbname="de_tipo_docto" )
 column=(type=char(100) updatewhereclause=yes name=cd_chave_docto dbname="compute_0009" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_nf dbname="log_exportacao_docto.nr_nf" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_transacao dbname="log_exportacao_docto.nr_transacao" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="log_exportacao_docto.de_serie" )
 column=(type=char(20) updatewhereclause=yes name=nr_documento_sap dbname="log_exportacao_docto.nr_documento_sap" )
 column=(type=datetime updatewhereclause=yes name=dh_documento dbname="log_exportacao_docto.dh_documento" )
 column=(type=datetime updatewhereclause=yes name=dh_exportacao dbname="log_exportacao_docto.dh_exportacao" )
 column=(type=datetime updatewhereclause=yes name=dh_processamento dbname="log_exportacao_docto.dh_processamento" )
 column=(type=long updatewhereclause=yes name=nr_lote_envio dbname="log_exportacao_docto.nr_lote_envio" )
 column=(type=char(1) updatewhereclause=yes name=id_revisado dbname="log_exportacao_docto.id_revisado" )
 column=(type=long updatewhereclause=yes name=qt_erros_itens dbname="qt_erros_itens" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" values="	S/	N" )
 column=(type=char(3) updatewhereclause=yes name=nm_destino dbname="nm_destino" )
 column=(type=char(6) updatewhereclause=yes name=base_dados dbname="base_dados" )
 column=(type=char(3) updatewhereclause=yes name=cd_setor dbname="cd_setor" values="INFORM$$HEX1$$c100$$ENDHEX$$TICA	INF/FISCAL	FIS/FINANCEIRO	FIN/" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="log_exportacao_docto.nr_atualizacao" )
 retrieve="Select  (case a.id_situacao_log 
			when 'C' then 1
			when 'E' then 2
			when 'V' then 2
			when 'F' then 2
			when 'A' then 3
			when 'P' then 4
			when 'I' then 5
			when 'X' then 6
			else 0 end )  as status,
		a.id_situacao_log ,
		a.cd_ambiente_sap,
        cast( i.fantasia as char(40)) as nm_fantasia,
        f.codigo as cd_filial,
		a.nr_atualizacao,
		a.id_tipo_docto,
		case a.id_tipo_docto
			when 'AN' then 'VENDA ANEXA'
			when 'CA' then 'CANC. ANEXA'
			when 'VD' then 'VENDA'
			when 'CV' then 'CANC. VENDA'
			when 'RC' then 'RECARGA'
			when 'RZ' then 'REDU$$HEX2$$c700c300$$ENDHEX$$O Z'
			when 'CX' then 'CAIXA'
			when 'PED' then 'PEDIDO ECOMMERCE'
			when 'POS' then 'INVERS$$HEX1$$c300$$ENDHEX$$O POS'
		else a.id_tipo_docto end as de_tipo_docto,
		cast(a.cd_chave_docto as char(100)),
		a.nr_nf, 
		a.nr_transacao, 
		decode(trim(a.de_especie),	'55', 'NFE','65', 'NFC','57', 'CTE','67', 'CTO','59', 'SAT','2D', 'CF','') as de_especie,
		a.de_serie,
		a.nr_documento_sap,
		a.dh_documento,
		a.dh_exportacao,
		a.dh_processamento,
		a.nr_lote_envio,
		a.id_revisado,
		(	select count(1) 
			from log_exportacao_docto_det x 
			where x.nr_atualizacao_log = a.nr_atualizacao 
			and x.id_tipo_log not in ('P', 'X')) as qt_erros_itens,
		'N' as id_selecionar,
		coalesce(a.id_interface, 'TDF') as nm_destino,
		'MULT' as base_dados,
		'INF' as cd_setor,
		a.nr_atualizacao as nr_atualizacao

from log_exportacao_docto a
    inner join m3_filial f      
		on f.codigo 	= CASE a.cd_filial
								WHEN 534 THEN 100
								WHEN 2 THEN 534
								WHEN 688 THEN 534
							ELSE a.cd_filial END

    inner join MTMG_PAPELREL m  
		on m.id         = f.ida
	
    inner join MTMG_IDENT i  
		on i.id         = m.idf_ident 

WHERE a.nr_atualizacao is not null
and 1=1" )
