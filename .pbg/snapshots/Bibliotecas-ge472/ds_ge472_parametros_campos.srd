table(column=(type=long updatewhereclause=yes name=cd_empresa dbname="parametro_sap_interface.cd_empresa" )
 column=(type=char(4) updatewhereclause=yes name=cd_tipo_docto dbname="parametro_sap_interface.cd_tipo_docto" )
 column=(type=char(40) updatewhereclause=yes name=cd_integracao dbname="parametro_sap_interface_det.cd_integracao" )
 column=(type=char(40) updatewhereclause=yes name=cd_registro dbname="parametro_sap_interface.cd_registro" )
 column=(type=char(40) updatewhereclause=yes name=cd_campo dbname="parametro_sap_interface.cd_campo" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_campo dbname="parametro_sap_interface.id_tipo_campo" )
 column=(type=char(1) updatewhereclause=yes name=id_campo_obrigatorio dbname="parametro_sap_interface_det.id_campo_obrigatorio" )
 column=(type=char(1) updatewhereclause=yes name=id_preench_obrigatorio dbname="parametro_sap_interface_det.id_preench_obrigatorio" )
 column=(type=char(40) updatewhereclause=yes name=id_formato dbname="parametro_sap_interface.id_formato" )
 column=(type=long updatewhereclause=yes name=qt_caracteres dbname="parametro_sap_interface.qt_caracteres" )
 retrieve="select	p.cd_empresa, 
		p.cd_tipo_docto, 
		pd.cd_integracao, 
		p.cd_registro, 
		p.cd_campo, 
		p.id_tipo_campo, 
		pd.id_campo_obrigatorio, 
		pd.id_preench_obrigatorio, 
		p.id_formato, 
		p.qt_caracteres
from parametro_sap_interface p
inner join parametro_sap_interface_det pd
	on pd.cd_empresa = p.cd_empresa
	and pd.cd_tipo_docto =p.cd_tipo_docto
	and pd.cd_registro =p.cd_registro
	and pd.cd_campo =p.cd_campo"  sort="cd_integracao A cd_registro A cd_campo A " )
