table(column=(type=decimal(0) update=yes updatewhereclause=yes name=nr_controle dbname="interface_sap.nr_controle" )
 column=(type=char(32768) updatewhereclause=no name=vl_item dbname="interface_sap_item.vl_item" )
 column=(type=char(30) updatewhereclause=yes name=cd_coluna dbname="interface_sap_item.cd_coluna" )
 column=(type=long updatewhereclause=yes name=nr_item dbname="interface_sap_item.nr_item" )
 column=(type=char(1) updatewhereclause=yes name=id_obrigatorio dbname="id_obrigatorio" )
 retrieve="  SELECT i.nr_controle,   
			ii.vl_item,
			ii.cd_coluna,
			ii.nr_item,
			coalesce(d.id_obrigatorio, 'N') id_obrigatorio  
    FROM interface_sap  i 
inner join interface_sap_item ii
	on ii.nr_controle = i.nr_controle
left outer join tabela_interface_sap_definicao d
	on d.cd_tabela = i.cd_tabela
	and upper(d.cd_coluna) = upper(ii.cd_coluna)
Where i.cd_tabela = 3
	and i.cd_tabela_pai = 1
	and i.nr_controle_pai = :controle_pai
	--and UPPER(ii.cd_coluna) = 'DE_CODIGO_BARRAS'
order by ii.nr_item, ii.cd_coluna" arguments=(("controle_pai", number)) )
