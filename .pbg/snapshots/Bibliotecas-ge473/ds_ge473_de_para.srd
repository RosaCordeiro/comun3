table(column=(type=char(40) updatewhereclause=yes name=cd_tabela dbname="cd_tabela" )
 column=(type=char(40) updatewhereclause=yes name=cd_chave_sap dbname="cd_chave_sap" )
 column=(type=char(40) updatewhereclause=yes name=cd_chave_legado dbname="cd_chave_legado" )
 retrieve="  SELECT cast('PORTADOR' as varchar(40)) as cd_tabela, 
			cast(case when coalesce(p.cd_banco,'')<>'' Then p.cd_banco||'01' else '' end as varchar(40)) as cd_chave_sap, 
			cast(p.cd_portador as varchar(40)) as cd_chave_legado
FROM portador p
WHERE cd_portador IN (50,10)

UNION

SELECT 	cd_tabela,
			cd_chave_sap,
			cd_chave_legado
FROM integracao_sap isp
WHERE isp.cd_tabela = 'FILIAL'
	AND isp.cd_empresa = 1000
	AND isp.cd_chave_sap in ('1156','1001') /* Inicialmente busca somente as duas principais filiais de t$$HEX1$$ed00$$ENDHEX$$tulos */

UNION

SELECT 	'USUARIO' as cd_tabela,
			'EXECJOB' as cd_chave_sap,
			u.nr_matricula as cd_chave_legado
FROM usuario u
WHERE u.nr_matricula = '14330'	" )
