table(column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_compra.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="item_nf_compra.qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="item_nf_compra.qt_recebida" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="item_nf_compra.cd_natureza_operacao" )
 column=(type=long updatewhereclause=yes name=qt_divergencia dbname="qt_divergencia" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_bc_icms_st dbname="vl_bc_icms_st" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_icms_st dbname="vl_icms_st" )
 retrieve="SELECT	i.cd_produto,   
			i.qt_faturada,   
			i.qt_recebida,
			i.cd_natureza_operacao,
			i.qt_faturada - i.qt_recebida as qt_divergencia,
			case when coalesce(i.vl_bc_icms_st_total , 0) = 0 then
				case when coalesce(i.vl_bc_icms_st_calculado , 0) = 0 then
					case when coalesce(i.vl_bc_icms_st_retido , 0) = 0 then
						0
					else
						i.vl_bc_icms_st_retido 
					end
				else
					i.vl_bc_icms_st_calculado
				end
			else
				i.vl_bc_icms_st_total 
			end as vl_bc_icms_st,
			
			case when coalesce(i.vl_icms_st_total, 0) = 0 then
				case when coalesce(i.vl_icms_st_calculado, 0) = 0 then
					case when coalesce(i.vl_icms_st_retido, 0) = 0 then
						0
					else
						i.vl_icms_st_retido
					end
				else
					i.vl_icms_st_calculado
				end
			else
				i.vl_icms_st_total
			end as vl_icms_st
FROM item_nf_compra  i
Where i.cd_filial		=:filial
	and i.cd_fornecedor	=:fornecedor
	and i.nr_nf					=:nota
	and i.de_especie		=:especie
	and i.de_serie			=:serie
	and i.qt_faturada - i.qt_recebida >0
" arguments=(("filial", number),("fornecedor", string),("nota", number),("especie", string),("serie", string)) )
