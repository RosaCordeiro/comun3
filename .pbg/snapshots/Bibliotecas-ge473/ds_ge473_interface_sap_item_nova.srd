table(column=(type=decimal(0) update=yes updatewhereclause=yes name=nr_controle dbname="interface_sap_item.nr_controle" dbalias="i.nr_controle" )
 column=(type=char(30) update=yes updatewhereclause=yes name=cd_coluna dbname="cd_coluna" )
 column=(type=long update=yes updatewhereclause=yes name=nr_item dbname="interface_sap_item.nr_item" dbalias="i.nr_item" )
 column=(type=char(1500) update=yes updatewhereclause=yes name=vl_item dbname="interface_sap_item.vl_item" dbalias="i.vl_item" )
 column=(type=char(100) update=yes updatewhereclause=yes name=de_erro dbname="interface_sap_item.de_erro" dbalias="i.de_erro" )
 retrieve="  SELECT i.nr_controle,   
         lower(i.cd_coluna) cd_coluna,   
         i.nr_item,   
         i.vl_item,   
         i.de_erro
    FROM interface_sap_item i  
   WHERE i.nr_controle = :controle
	  AND i.nr_item = :item
" arguments=(("controle", number),("item", number)) )
