table(column=(type=long updatewhereclause=yes name=nr_lote dbname="lote_rec_vol_geladeira_prd.nr_lote" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="lote_rec_vol_geladeira_prd.cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote_produto dbname="lote_rec_vol_geladeira_prd.nr_lote_produto" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="lote_recebimento_produto_wms.dh_validade" )
 column=(type=long updatewhereclause=yes name=qt_caixa_padrao dbname="lote_rec_vol_geladeira_prd.qt_caixa_padrao" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="item_nf_compra.qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="qt_recebida" )
 column=(type=long updatewhereclause=yes name=qt_avariada dbname="qt_avariada" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="item_nf_compra.cd_natureza_operacao" )
 column=(type=char(1) updatewhereclause=yes name=id_aceite dbname="id_aceite" )
 column=(type=long updatewhereclause=yes name=qt_divergencia dbname="qt_divergencia" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_bc_icms_st dbname="vl_bc_icms_st" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_icms_st dbname="vl_icms_st" )
 retrieve="SELECT 
    lrvgp.nr_lote,
    lrvgp.cd_produto,   
    lrvgp.nr_lote_produto,
    lrpw.dh_validade,
    lrvgp.qt_caixa_padrao,
    inc.qt_faturada,   
    SUM(lrvgp.qt_recebida_produto) - SUM(lrvgp.qt_avariada) AS qt_recebida,
    SUM(lrvgp.qt_avariada) AS qt_avariada,
    inc.cd_natureza_operacao,
    COALESCE(lrvgp.id_aceite, 'S') AS id_aceite, 
    inc.qt_faturada - inc.qt_recebida AS qt_divergencia,
    CASE 
        WHEN COALESCE(inc.vl_bc_icms_st_total, 0) = 0 THEN
            CASE 
                WHEN COALESCE(inc.vl_bc_icms_st_calculado, 0) = 0 THEN
                    CASE 
                        WHEN COALESCE(inc.vl_bc_icms_st_retido, 0) = 0 THEN 0
                        ELSE inc.vl_bc_icms_st_retido 
                    END 
                ELSE inc.vl_bc_icms_st_calculado
            END 
        ELSE inc.vl_bc_icms_st_total
    END AS vl_bc_icms_st,
    CASE 
        WHEN COALESCE(inc.vl_icms_st_total, 0) = 0 THEN
            CASE 
                WHEN COALESCE(inc.vl_icms_st_calculado, 0) = 0 THEN
                    CASE 
                        WHEN COALESCE(inc.vl_icms_st_retido, 0) = 0 THEN 0
                        ELSE inc.vl_icms_st_retido
                    END 
                ELSE inc.vl_icms_st_calculado
            END 
        ELSE inc.vl_icms_st_total
    END AS vl_icms_st
FROM 
    item_nf_compra inc
INNER JOIN lote_recebimento_nf lrn 
    ON lrn.nr_nf = inc.nr_nf 
    AND lrn.de_especie = inc.de_especie 
    AND lrn.de_serie = inc.de_serie
INNER JOIN lote_recebimento_produto_wms lrpw
    ON lrpw.nr_lote_recebimento = lrn.nr_lote 
    AND lrpw.cd_produto = inc.cd_produto 
INNER JOIN lote_rec_vol_geladeira_prd lrvgp 
    ON lrvgp.nr_lote = lrpw.nr_lote_recebimento   
    AND lrvgp.cd_produto = lrpw.cd_produto 
    AND lrvgp.nr_lote_produto = lrpw.nr_lote 
    AND lrvgp.qt_caixa_padrao = lrpw.qt_caixa_padrao 
INNER JOIN produto_geral pg 
    ON pg.cd_produto = inc.cd_produto
WHERE 
    inc.cd_filial = :al_filial 
    AND inc.cd_fornecedor = :as_fornecedor
    AND inc.nr_nf = :al_nota
    AND inc.de_especie = :as_especie
    AND inc.de_serie = :as_serie
    AND pg.id_geladeira = 'S'
    AND COALESCE(lrpw.id_vencimento_proximo_lib, 'S') = 'S' 
GROUP BY 
    lrvgp.nr_lote,
    lrvgp.cd_produto,
    lrvgp.nr_lote_produto,
    lrpw.dh_validade,
    lrvgp.qt_caixa_padrao,
    COALESCE(lrvgp.id_aceite, 'S'),
    inc.cd_filial,
    inc.cd_fornecedor,
    inc.nr_nf,
    inc.de_especie,
    inc.de_serie,
    pg.id_geladeira,
    inc.cd_natureza_operacao,
    inc.qt_faturada,
    inc.qt_recebida,
    inc.vl_bc_icms_st_total,
    inc.vl_bc_icms_st_calculado,
    inc.vl_bc_icms_st_retido,
    inc.vl_icms_st_total,
    inc.vl_icms_st_calculado,
    inc.vl_icms_st_retido" arguments=(("al_filial", number),("as_fornecedor", string),("al_nota", number),("as_especie", string),("as_serie", string)) )
