table(column=(type=long updatewhereclause=yes key=yes name=cd_filial dbname="item_nf_compra_lote.cd_filial" )
 column=(type=char(9) updatewhereclause=yes key=yes name=cd_fornecedor dbname="item_nf_compra_lote.cd_fornecedor" )
 column=(type=long updatewhereclause=yes key=yes name=nr_nf dbname="item_nf_compra_lote.nr_nf" )
 column=(type=char(3) updatewhereclause=yes key=yes name=de_especie dbname="item_nf_compra_lote.de_especie" )
 column=(type=char(3) updatewhereclause=yes key=yes name=de_serie dbname="item_nf_compra_lote.de_serie" )
 column=(type=long updatewhereclause=yes key=yes name=cd_natureza_operacao dbname="item_nf_compra_lote.cd_natureza_operacao" )
 column=(type=long updatewhereclause=yes key=yes name=cd_produto dbname="item_nf_compra_lote.cd_produto" )
 column=(type=char(10) updatewhereclause=yes key=yes name=nr_lote dbname="item_nf_compra_lote.nr_lote" )
 column=(type=long updatewhereclause=yes name=qt_lote dbname="qt_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="item_nf_compra_lote.dh_validade" )
 column=(type=long update=yes updatewhereclause=yes name=qt_avariada dbname="qt_avariada" )
 column=(type=char(1) updatewhereclause=yes name=id_vencimento_proximo dbname="item_nf_compra_lote.id_vencimento_proximo" )
 retrieve="  SELECT n.cd_filial,   
			n.cd_fornecedor,   
			n.nr_nf,   
			n.de_especie,   
			n.de_serie,   
			n.cd_natureza_operacao,   
			n.cd_produto,   
			n.nr_lote,   
			(n.qt_lote - coalesce(n.qt_falta, 0)) as qt_lote,   
			n.dh_validade,   
			isnull(n.qt_avariada,0) qt_avariada, 
			n.id_vencimento_proximo
FROM item_nf_compra_lote   n
where n.cd_filial = :filial
	and n.cd_fornecedor = :fornecedor
	and n.nr_nf		= :nota
	and n.de_especie	= :especie
	and n.de_serie		= :serie
	and n.id_vencimento_proximo = 'S'" update="item_nf_compra_lote" updatewhere=1 updatekeyinplace=no arguments=(("filial", number),("fornecedor", string),("nota", number),("especie", string),("serie", string)) )
