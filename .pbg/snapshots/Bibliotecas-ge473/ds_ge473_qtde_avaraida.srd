table(column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_compra_lote.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_avariada dbname="item_nf_compra_lote.qt_avariada" )
 column=(type=char(10) updatewhereclause=yes name=nr_lote dbname="item_nf_compra_lote.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="item_nf_compra_lote.dh_validade" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="item_nf_compra_lote.cd_natureza_operacao" )
 retrieve="Select 	p.cd_produto,
			p.qt_avariada,
			p.nr_lote,
			p.dh_validade,
			p.cd_natureza_operacao
From item_nf_compra_lote p
Where	p.cd_filial			  	= :filial
	and 	p.cd_fornecedor	= :fornecedor
	and 	p.nr_nf					= :nota
	and 	p.de_especie			= :especie
	and 	p.de_serie				=	:serie
	and 	p.qt_avariada	 		> 0

" arguments=(("filial", number),("fornecedor", string),("nota", number),("especie", string),("serie", string)) )
