table(column=(type=decimal(0) update=yes updatewhereclause=yes name=nr_controle dbname="interface_sap.nr_controle" dbalias="i.nr_controle" )
 column=(type=long update=yes updatewhereclause=yes name=cd_tabela dbname="interface_sap.cd_tabela" dbalias="i.cd_tabela" )
 column=(type=char(48) updatewhereclause=yes name=nm_tabela dbname="nm_tabela" )
 column=(type=char(100) updatewhereclause=yes name=de_tabela dbname="tabela_interface_sap.de_tabela" dbalias="ia.de_tabela" )
 column=(type=long update=yes updatewhereclause=yes name=cd_tabela_pai dbname="interface_sap.cd_tabela_pai" dbalias="i.cd_tabela_pai" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="interface_sap.id_situacao" dbalias="i.id_situacao" )
 column=(type=char(10) updatewhereclause=yes name=de_situacao dbname="de_situacao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inclusao dbname="interface_sap.dh_inclusao" dbalias="i.dh_inclusao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_processamento dbname="interface_sap.dh_processamento" dbalias="i.dh_processamento" )
 column=(type=char(1) updatewhereclause=yes name=id_processa dbname="id_processa" initial="N" values="	S/	N" )
 column=(type=char(40) updatewhereclause=yes name=cd_codigo_legado dbname="cd_codigo_legado" )
 column=(type=char(103) updatewhereclause=yes name=de_identificacao dbname="de_identificacao" )
 column=(type=char(5000) updatewhereclause=yes name=de_chave_sap dbname="de_chave_sap" )
 column=(type=char(255) updatewhereclause=yes name=de_erro dbname="interface_sap.de_erro" dbalias="i.de_erro" )
 retrieve=" SELECT	i.nr_controle,   
			i.cd_tabela,   
			cast(i.cd_tabela as varchar(5)) + ' - ' + ia.nm_tabela as nm_tabela,
			ia.de_tabela,
			i.cd_tabela_pai,
			i.id_situacao,
			case i.id_situacao
				when 'C' then 'COLOCADO'
				when 'P' then 'PROCESSADO'
				when 'E' then 'ERRO'
				else i.id_situacao
			end as de_situacao,   
			i.dh_inclusao,   
			i.dh_processamento,
			'' id_processa,
			case	when i.cd_tabela = 1 then --Produto 
						(CASE WHEN (select cast(x.vl_item as varchar) from interface_sap_item x where x.nr_controle = i.nr_controle and x.cd_coluna in ('CD_PRODUTO_LEGADO', 'cd_produto_legado')) <> '' 
								THEN (select cast(x.vl_item as varchar) from interface_sap_item x where x.nr_controle = i.nr_controle and x.cd_coluna in ('CD_PRODUTO_LEGADO', 'cd_produto_legado')) 
							ELSE 
								(select cast(cd_produto as varchar) from produto_geral where cd_produto_sap = cast(cast(i.de_chave_sap as numeric ) as varchar)) 
						END)
					when i.cd_tabela = 10 then   --Forncedor
						(select cast(x.vl_item as varchar) from interface_sap_item x where x.nr_controle = i.nr_controle and x.cd_coluna = 'cd_fornecedor_legado')
					when i.cd_tabela = 20 then	--Cliente
						(select cast(x.vl_item as varchar) from interface_sap_item x where x.nr_controle = i.nr_controle and x.cd_coluna = 'cd_cliente_legado')
					when i.cd_tabela in (24, 25) then  --PRODUTO_UF, PRECO_REGIONALIZADO
						(select cast(x.cd_produto as varchar) from produto_geral x where x.cd_produto_sap = (select convert(varchar, convert(bigint, cast(x.vl_item as varchar))) from interface_sap_item x where x.nr_controle = i.nr_controle and x.cd_coluna  IN ('cd_produto', 'CD_PRODUTO')))
					 when i.cd_tabela = 32 then --PEDIDO_FILIAL_BLOQUEIO
                        	(select cd_chave_legado from integracao_sap where cd_tabela = 'FILIAL' and cd_chave_sap = (select max(cast(x.vl_item as varchar)) from interface_sap_item x where x.nr_controle = i.nr_controle and x.cd_coluna  IN ('cd_filial_sap', 'CD_FILIAL_SAP') and x.nr_item = 1))
					else 
					'N$$HEX1$$c300$$ENDHEX$$O LOCALIZADO'
			end as cd_codigo_legado,
			case when i.cd_tabela = 1 then --Produto
						(select cast(x.vl_item as varchar) from interface_sap_item x where x.nr_controle = i.nr_controle and x.cd_coluna  IN ('de_produto', 'DE_PRODUTO')) +' : '+
						(select cast(x.vl_item as varchar) from interface_sap_item x where x.nr_controle = i.nr_controle and x.cd_coluna IN ( 'de_apresentacao_estoque', 'DE_APRESENTACAO_ESTOQUE'))
					when i.cd_tabela = 10 then   --Forncedor
						(select cast(x.vl_item as varchar) from interface_sap_item x where x.nr_controle = i.nr_controle and x.cd_coluna = 'nm_fantasia')
					when i.cd_tabela = 20 then	--Cliente
						case when (select cast(x.vl_item as varchar) from interface_sap_item x where x.nr_controle = i.nr_controle and x.cd_coluna = 'id_fisica_juridica') = 'F' then
								(select cast(x.vl_item as varchar) from interface_sap_item x where x.nr_controle = i.nr_controle and x.cd_coluna = 'nm_cliente') +' '+
								(select cast(x.vl_item as varchar) from interface_sap_item x where x.nr_controle = i.nr_controle and x.cd_coluna = 'nm_sobrenome')
							else
								(select cast(x.vl_item as varchar) from interface_sap_item x where x.nr_controle = i.nr_controle and x.cd_coluna = 'nm_razao_social')
						end
					when i.cd_tabela in (24, 25) then --PRODUTO_UF, PRECO_REGIONALIZADO
							  (select x.de_produto +' : '+ x.de_apresentacao_estoque from produto_geral x where x.cd_produto_sap = (select convert(varchar, convert(bigint, cast(x.vl_item as varchar))) from interface_sap_item x where x.nr_controle = i.nr_controle and x.cd_coluna  IN ('cd_produto', 'CD_PRODUTO')))
					when i.cd_tabela = 32 then --PEDIDO_FILIAL_BLOQUEIO
                            case    when (select cast(x.vl_item as varchar) from interface_sap_item x where x.nr_controle = i.nr_controle and x.cd_coluna  IN ('cd_tipo_pedido_distribuidora', 'CD_TIPO_PEDIDO_DISTRIBUIDORA') and x.nr_item = 1) = 'X' then
                                        'PEDIDO DISTRIBUIDORA'
                                    when (select cast(x.vl_item as varchar) from interface_sap_item x where x.nr_controle = i.nr_controle and x.cd_coluna  IN ('cd_tipo_pedido_estoque_central', 'CD_TIPO_PEDIDO_ESTOQUE_CENTRAL') and x.nr_item = 1) = 'X' then
                                        'PEDIDO ESTOQUE CENTRAL'
								when (select cast(x.vl_item as varchar) from interface_sap_item x where x.nr_controle = i.nr_controle and x.cd_coluna  IN ('cd_tipo_pedido_almoxarifado', 'CD_TIPO_PEDIDO_ALMOXARIFADO') and x.nr_item = 1) = 'X' then
                                        'PEDIDO ALMOXARIFADO'
                                    else
                                        ''
                            end
					else 
						'N$$HEX1$$c300$$ENDHEX$$O LOCALIZADO'
			end as de_identificacao,
			Coalesce(dbo.removeZerosEsquerda(i.de_chave_sap), i.de_chave_sap) de_chave_sap,
			i.de_erro
			//(CASE WHEN  i.cd_tabela = 1 THEN cast(cast(i.de_chave_sap as numeric ) as varchar) ELSE i.de_chave_sap END) de_chave_sap,
FROM interface_sap  i
inner join tabela_interface_sap ia	on ia.cd_tabela = i.cd_tabela
left outer join tabela_interface_sap ip	on ip.cd_tabela = i.cd_tabela_pai
where	coalesce(ia.id_tabela_pai, 'N') = 'S'
order by ia.nm_tabela, i.nr_controle
" )
