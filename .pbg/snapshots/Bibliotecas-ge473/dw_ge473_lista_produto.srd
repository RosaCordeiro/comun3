table(column=(type=long updatewhereclause=yes name=nr_lote_recebimento dbname="lote_recebimento_produto_wms.nr_lote_recebimento" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="lote_recebimento_produto_wms.cd_produto" )
 column=(type=char(112) updatewhereclause=yes name=nm_produto dbname="nm_produto" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="lote_recebimento_produto_wms.nr_lote" )
 column=(type=long updatewhereclause=yes name=qt_caixa_padrao dbname="lote_recebimento_produto_wms.qt_caixa_padrao" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="lote_recebimento_produto_wms.dh_validade" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="lote_recebimento_produto_wms.qt_recebida" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_compra dbname="produto_geral.cd_unidade_medida_compra" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" )
 column=(type=char(1) updatewhereclause=yes name=id_flow_rack dbname="lote_recebimento_produto_wms.id_flow_rack" )
 column=(type=long updatewhereclause=yes name=qt_avariada dbname="lote_recebimento_produto_wms.qt_avariada" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" )
 column=(type=char(1) updatewhereclause=yes name=id_vencimento_proximo dbname="id_vencimento_proximo" )
 column=(type=char(1) updatewhereclause=yes name=id_vencimento_proximo_lib dbname="id_vencimento_proximo_lib" )
 column=(type=char(9) updatewhereclause=yes name=id_caixa_utilizada dbname="id_caixa_utilizada" )
 column=(type=char(3) updatewhereclause=yes name=vencido_proximo dbname="vencido_proximo" )
 column=(type=char(3) updatewhereclause=yes name=vencido_prox_liberado dbname="vencido_prox_liberado" )
 retrieve="  SELECT	w.nr_lote_recebimento,
				w.cd_produto,   
				g.de_produto + ' : ' +  g.de_apresentacao_estoque + ' (' + cast(w.cd_produto as char(6)) + ')' nm_produto,   
				w.nr_lote,
				w.qt_caixa_padrao,
				w.dh_validade,
         		w.qt_recebida,   
         		g.cd_unidade_medida_compra,   
         		g.de_codigo_barras,
				w.id_flow_rack,
				w.qt_avariada,
				g.cd_grupo_psico,
				isnull(w.id_vencimento_proximo, 'N') as id_vencimento_proximo,
				isnull(w.id_vencimento_proximo_lib, 'X') as id_vencimento_proximo_lib,
				Case id_caixa_utilizada 
							When 'M' Then 'MONTADA'
                           	When 'I'  Then 'IND$$HEX1$$da00$$ENDHEX$$STRIA' else '' 
							end id_caixa_utilizada,
			  case isnull(w.id_vencimento_proximo,'N') 
                         when 'N' then 'N$$HEX1$$c300$$ENDHEX$$O'
                        when 'S' then 'SIM' end as vencido_proximo,
				case isnull(w.id_vencimento_proximo_lib,'N') 
                        when 'S' then 'SIM'
                        when 'N'  then 'N$$HEX1$$c300$$ENDHEX$$O' end as vencido_prox_liberado
FROM			lote_recebimento_produto_wms w
INNER JOIN produto_geral g on g.cd_produto = w.cd_produto
 WHERE w.nr_lote_recebimento = :nr_lote
" arguments=(("nr_lote", number))  sort="nm_produto A " )
