table(column=(type=long updatewhereclause=yes name=nr_lote_recebimento dbname="lote_recebimento_produto_wms.nr_lote" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="lote_recebimento_produto_wms.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_compra dbname="produto_geral.cd_unidade_medida_compra" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="qt_recebida" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 retrieve="SELECT 	l.nr_lote_recebimento as nr_lote,   
				l.cd_produto,   
				g.de_produto + ' : ' + g.de_apresentacao_estoque de_produto,   
				g.cd_unidade_medida_compra,   
				g.de_codigo_barras,  
				sum(l.qt_recebida * l.qt_caixa_padrao) as qt_recebida,
				0 qt_faturada

FROM lote_recebimento_produto_wms l
inner join produto_geral  g on g.cd_produto = l.cd_produto
WHERE nr_lote_recebimento = :nr_lote
group by	l.nr_lote_recebimento,   
				l.cd_produto,   
				g.de_produto,   
				g.de_apresentacao_estoque,   
				g.cd_unidade_medida_compra,   
				g.de_codigo_barras
				
				" filter=" qt_recebida <>  qt_faturada "arguments=(("nr_lote", number))  sort="de_produto A " )
