table(column=(type=decimal(0) update=yes updatewhereclause=yes name=nr_controle dbname="interface_sap_item.nr_controle" )
 column=(type=char(30) update=yes updatewhereclause=yes name=cd_coluna dbname="interface_sap_item.cd_coluna" )
 column=(type=long update=yes updatewhereclause=yes name=nr_item dbname="interface_sap_item.nr_item" )
 column=(type=char(32768) update=yes updatewhereclause=no name=vl_item dbname="interface_sap_item.vl_item" )
 column=(type=char(100) update=yes updatewhereclause=yes name=de_erro dbname="interface_sap_item.de_erro" )
 column=(type=char(1) updatewhereclause=yes name=id_obrigatorio dbname="id_obrigatorio" )
 retrieve="  SELECT i.nr_controle,   
         i.cd_coluna,   
         i.nr_item,   
         i.vl_item,   
         i.de_erro,
			coalesce(d.id_obrigatorio, 'N') id_obrigatorio
    FROM interface_sap_item  i
inner join interface_sap ia
	on ia.nr_controle = i.nr_controle
left outer join tabela_interface_sap_definicao d
	on d.cd_tabela = ia.cd_tabela
	and upper(d.cd_coluna) = upper(i.cd_coluna)
where i.nr_controle = :controle
order by i.nr_item
	
" arguments=(("controle", number)) )
