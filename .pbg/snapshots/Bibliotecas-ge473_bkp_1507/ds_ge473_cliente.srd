 retrieve="SELECT	c.cd_cliente,
			c.cd_cidade,
			c.de_bairro,
			c.de_complemento,
			c.de_endereco,
			c.de_endereco_email,
			c.de_endereco_email_envio_xml,
			c.dh_atualizacao,
			c.dh_nascimento,
			c.id_estado_civil,
			c.id_fisica_juridica,
			c.id_possui_filhos,
			c.id_sexo,
			c.id_tempo_empresa,
			c.id_tempo_residencia,
			c.id_tipo_cliente,
			c.nm_cliente,
			c.nm_empresa,
			c.nm_razao_social,
			c.nr_ddd_celular,
			c.nr_celular,
			c.nr_cep,
			c.nr_cpf_cgc,
			c.nr_endereco,
			c.nr_ddd_fone_comercial,
			c.nr_fone_comercial,
			c.nr_ddd_fone_recado,
			c.nr_fone_recado,
			c.nr_ddd_fone_residencial,
			c.nr_fone_residencial,
			c.nr_inscricao_estadual,
			c.nr_rg,
			c.id_tipo_residencia,
			c.cd_filial_inclusao,
			c.nr_matricula_inclusao,
			c.dh_inclusao,
			c.cd_filial_atualizacao,
			c.nr_matricula_atualizacao,
			c.cd_portador,
			c.id_dono_farmacia,
			c.id_medicamento_uso_continuo,
			c.id_autoriza_comunicacao,
			c.cd_cliente_sap,
			c.id_natureza_ocupacao
FROM cliente  c" update="cliente" updatewhere=1 updatekeyinplace=yes )
