table(column=(type=decimal(0) updatewhereclause=yes key=yes name=nr_controle dbname="interface_sap.nr_controle" dbalias=".nr_controle" )
 column=(type=long updatewhereclause=yes name=cd_tabela dbname="interface_sap.cd_tabela" dbalias=".cd_tabela" )
 column=(type=long updatewhereclause=yes name=cd_tabela_pai dbname="interface_sap.cd_tabela_pai" dbalias=".cd_tabela_pai" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="interface_sap.id_situacao" dbalias=".id_situacao" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="interface_sap.dh_inclusao" dbalias=".dh_inclusao" )
 column=(type=datetime updatewhereclause=yes name=dh_processamento dbname="interface_sap.dh_processamento" dbalias=".dh_processamento" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_controle_pai dbname="interface_sap.nr_controle_pai" dbalias=".nr_controle_pai" )
 column=(type=char(30) updatewhereclause=yes name=de_chave_sap dbname="interface_sap.de_chave_sap" dbalias=".de_chave_sap" )
 column=(type=char(255) updatewhereclause=yes name=de_erro dbname="interface_sap.de_erro" dbalias=".de_erro" )
 retrieve="  SELECT nr_controle,   
               cd_tabela,   
               cd_tabela_pai,   
               id_situacao,   
               dh_inclusao,   
               dh_processamento,   
               nr_controle_pai,   
               de_chave_sap,   
               de_erro   
    FROM interface_sap   (index idx_situacao)   
   WHERE  nr_controle            =  isnull( :an_nr_controle,    nr_controle) 
        and  cd_tabela               =  isnull( :an_cd_tabela,      cd_tabela )
        and  id_situacao             in   ( :asr_id_situacao  )
        and  dh_processamento = isnull( :adt_dh_processamento,  dh_processamento)

" update="interface_sap" updatewhere=0 updatekeyinplace=no arguments=(("an_nr_controle", number),("an_cd_tabela", number),("asr_id_situacao", stringlist),("adt_dh_processamento", datetime)) )
