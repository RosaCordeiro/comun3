 column=(type=char(1) update=yes updatewhereclause=yes name=id_alteracao dbname="planejamento_estoque_sap.id_alteracao" dbalias=".id_alteracao" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_bloqueia_geracao_pedido dbname="planejamento_estoque_sap.id_bloqueia_geracao_pedido" dbalias=".id_bloqueia_geracao_pedido" )
 retrieve="SELECT cd_filial, 
            cd_produto, 
             qt_demanda_diaria, 
             qt_dias_cobertura, 
             cd_curva_abc, 
             dh_planejamento,
             id_alteracao, 
             id_bloqueia_geracao_pedido
FROM  planejamento_estoque_sap ( index pk_planejamento_estoque_sap )
where  cd_filial      = isnull( :an_cd_filial, cd_filial )
   and  cd_produto =  isnull( :an_cd_produto, cd_produto)
" update="planejamento_estoque_sap" updatewhere=1 updatekeyinplace=no arguments=(("an_cd_filial", number),("an_cd_produto", number)) )
