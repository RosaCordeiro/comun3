 column=(type=long updatewhereclause=yes name=qt_tamanho_coluna dbname="tabela_interface_sap_definicao.qt_tamanho_coluna" dbalias="t.qt_tamanho_coluna" )
 retrieve="  SELECT t.cd_tabela,   
         	lower(t.cd_coluna) cd_coluna,   
         	t.id_tipo_dado,   
         	t.id_obrigatorio,   
         	t.de_coluna ,
			t.qt_tamanho_coluna 
    FROM tabela_interface_sap_definicao   t
Where t.cd_tabela = :tabela
" arguments=(("tabela", number))  sort="cd_coluna A " )
