table(column=(type=long update=yes updatewhereclause=yes name=cd_tabela dbname="tabela_interface_sap_definicao.cd_tabela" dbalias="t.cd_tabela" )
 column=(type=char(30) update=yes updatewhereclause=yes name=cd_coluna dbname="cd_coluna" )
 column=(type=char(15) update=yes updatewhereclause=yes name=id_tipo_dado dbname="tabela_interface_sap_definicao.id_tipo_dado" dbalias="t.id_tipo_dado" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_obrigatorio dbname="tabela_interface_sap_definicao.id_obrigatorio" dbalias="t.id_obrigatorio" )
