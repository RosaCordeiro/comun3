table(column=(type=long updatewhereclause=yes name=cd_centro_custo dbname="telefone_drogaria.cd_centro_custo" )
 column=(type=char(40) updatewhereclause=yes name=de_centro_custo dbname="centro_custo.de_centro_custo" )
 column=(type=long updatewhereclause=yes name=cd_filial_debito dbname="parametro_contabilizacao.cd_filial_debito" )
 column=(type=char(10) updatewhereclause=yes name=cd_conta_debito dbname="parametro_contabilizacao.cd_conta_debito" )
 column=(type=char(10) updatewhereclause=yes name=cd_conta_credito dbname="parametro_contabilizacao.cd_conta_credito" )
 column=(type=char(10) updatewhereclause=yes name=cd_centro_debito dbname="parametro_contabilizacao.cd_centro_debito" )
 column=(type=char(10) updatewhereclause=yes name=cd_centro_credito dbname="parametro_contabilizacao.cd_centro_credito" )
 column=(type=char(10) updatewhereclause=yes name=cd_centro_debito_m3 dbname="parametro_contabilizacao.cd_centro_debito_m3" )
 column=(type=char(10) updatewhereclause=yes name=cd_centro_credito_m3 dbname="parametro_contabilizacao.cd_centro_credito_m3" )
 column=(type=char(2) updatewhereclause=yes name=nr_ddd dbname="telefone_drogaria.nr_ddd" )
 column=(type=char(10) updatewhereclause=yes name=nr_telefone dbname="telefone_drogaria.nr_telefone" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_servico dbname="extrato_conta_telefone.id_tipo_servico" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_servico dbname="vl_total_servico" )
 retrieve="select t.cd_centro_custo,   
       c.de_centro_custo,
		 p.cd_filial_debito, 
		 p.cd_conta_debito,
       p.cd_conta_credito,
	   p.cd_centro_debito,
       p.cd_centro_credito,
	  p.cd_centro_debito_m3,
	  p.cd_centro_credito_m3,
       t.nr_ddd,   
       t.nr_telefone,
       e.id_tipo_servico,   
       sum(e.vl_servico) vl_total_servico
from extrato_conta_telefone e,   
     telefone_drogaria t,  
     centro_custo c,
     parametro_contabilizacao p     
where t.nr_ddd             = e.nr_ddd_origem
  and t.nr_telefone        = e.nr_telefone_origem
  and c.cd_centro_custo = t.cd_centro_custo
  and c.cd_centro_custo *= p.cd_centro_custo
  and p.id_tipo = 'TEL'
  and e.dh_vencimento = :pdt_periodo
group by t.cd_centro_custo,   
       		c.de_centro_custo,
		 	p.cd_filial_debito, 
		 	p.cd_conta_debito,
       		p.cd_conta_credito,
		 	p.cd_centro_debito,
       		p.cd_centro_credito,
  			p.cd_centro_debito_m3,
	 		p.cd_centro_credito_m3,
       		t.nr_ddd,   
       		t.nr_telefone,
       		e.id_tipo_servico" arguments=(("pdt_periodo", date))  sort="cd_centro_custo A nr_ddd A nr_telefone A id_tipo_servico A " )
