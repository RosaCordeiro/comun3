 column=(type=char(40) updatewhereclause=yes name=de_classificacao_subcat_pp dbname="de_classificacao_subcat_pp" )
 column=(type=char(1) updatewhereclause=yes name=id_bloqueia_calculo_preco dbname="id_bloqueia_calculo_preco" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
