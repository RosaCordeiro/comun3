 column=(type=long updatewhereclause=yes name=cd_produto_abcfarma dbname="produto_abcfarma.cd_produto_abcfarma" )
 column=(type=char(92) updatewhereclause=yes name=de_produto_abcfarma dbname="de_produto_abcfarma" )
 column=(type=char(30) updatewhereclause=yes name=fabricante_abc_farma dbname="produto_abcfarma.fabricante_abc_farma" )
 column=(type=long updatewhereclause=yes name=nr_classificacao_fiscal dbname="produto_geral.nr_classificacao_fiscal" )
 column=(type=char(7) updatewhereclause=yes name=cd_cest dbname="produto_geral.cd_cest" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_pis_cofins dbname="produto_geral.id_situacao_pis_cofins" values="TRIBUTADO	T/NEGATIVO	N/POSITIVO	P/" )
 column=(type=char(9) updatewhereclause=yes name=de_situacao_pis_cofins dbname="de_situacao_pis_cofins" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="produto_geral.id_lei_generico" )
 column=(type=char(11) updatewhereclause=yes name=de_lei_generico dbname="de_lei_generico" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cd_unidade_federacao" )
 column=(type=char(1) updatewhereclause=yes name=cd_tributacao_icms dbname="cd_tributacao_icms" )
 column=(type=char(40) updatewhereclause=yes name=de_tributacao_icms dbname="de_tributacao_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_fcp dbname="pc_fcp" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_ipi dbname="produto_geral.pc_ipi" )
 column=(type=long updatewhereclause=yes name=cd_tributacao_produto dbname="tributa_produtos_farmaceuticos.cd_tributacao_produto" )
 column=(type=char(50) updatewhereclause=yes name=de_tributacao_produto dbname="tributa_produtos_farmaceuticos.de_tributacao_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_st_estadual dbname="tributa_produtos_farmaceuticos.pc_st_estadual" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_reducao_base_st dbname="pc_reducao_base_st" )
 column=(type=long updatewhereclause=yes name=nr_ncm_situacao dbname="nr_ncm_situacao" )
 column=(type=char(100) updatewhereclause=yes name=de_situacao_especial dbname="de_situacao_especial" )
 retrieve="select  u.cd_unidade_federacao, 
		 g.cd_produto,
		 g.de_produto||': '||g.de_apresentacao_venda as de_produto,
		 g.cd_unidade_medida_venda,
		 g.qt_concentracao,
		 g.id_apresentacao,
		 tap.de_apresentacao,
		 g.vl_volume,
		 g.qt_unidades_embalagem,
		 pc.qt_peso_apresentacao,
		 g.de_codigo_barras,
		 gp.de_grupo,	
		 sgp.de_subgrupo,
		 cp.de_categoria,
		 scp.de_subcategoria,
		 Case scp.id_obriga_tipo_produto
			When 'P' then 'PERGUNTA'
			When 'S' then 'OBRIGA'
			When 'N' then 'N$$HEX1$$c300$$ENDHEX$$O OBRIGA'
		 Else '' end as de_obriga_tipo_produto,
		 pc.cd_tipo_produto_pricing,
		 tpp.de_tipo_produto as de_tipo_produto_pricing,
		 Case pc.id_tipo_un_calc_preco
			When 'Q' then 'QUANTIDADE'
			When 'P' then 'PESO'
			When 'V' then 'VOLUME'
		 Else '' end as de_tipo_un_calc_preco,
		 mp.cd_marca,
		 mp.de_marca,
		 gap.cd_grupo as cd_grupo_alteracao_preco,
		 gap.de_grupo as de_grupo_alteracao_preco,
		 pc.cd_prod_referencia_preco,
		 case when pc.cd_prod_referencia_preco is null then '' else pr.de_produto||': '||pr.de_apresentacao_venda end as de_prod_referencia_preco,
		 pc.pc_prod_referencia_preco,
		 tsc1.de_tier as de_tier_dc,
		 tsc2.de_tier as de_tier_pp,
		 csc1.de_classificacao as de_classificacao_subcat_dc,
		 csc2.de_classificacao as de_classificacao_subcat_pp,
		 coalesce(pc.id_bloqueia_calculo_preco,'N') as id_bloqueia_calculo_preco,
		 u.vl_preco_venda_fornecedor,
		 u.vl_preco_venda_maximo,
	     u.vl_preco_reposicao,
		pc.pc_desconto_fornecedor,
		round(pc.vl_custo_gerencial * g.vl_fator_conversao, 2) as vl_custo_medio,   
         round(pc.vl_custo_gerencial_geral * g.vl_fator_conversao, 2)  as vl_custo_gerencial,   
		g.vl_fator_conversao,
         case when g.id_superfluo =  'N' then 'N$$HEX1$$c300$$ENDHEX$$O' else 'SIM' end id_superfluo,
         g.nr_embalagem_padrao as caixa_embarque,

		Case pc.id_tipo_reposicao_estoque
              when 'S' then 'SAZONAL'
              when 'E' then 'ESTAVEL'
            End as demanda,

		u.vl_preco_venda_atual,   
		cast(u.dh_preco_venda_atual as date) as dh_preco_venda_atual,
		g.de_apresentacao_estoque,   
		g.de_apresentacao_venda,
		f.cd_fornecedor,
		f.nm_fantasia as nm_fornecedor,   

		case g.cd_grupo_psico 
                when null then 'N$$HEX1$$c300$$ENDHEX$$O' 
		else 'SIM' end as controlado, 
      
		case pab.id_controle_preco	 
            when 'M' then 'MONITORADO'
            when 'X' then 'LIBER. PRE$$HEX1$$c700$$ENDHEX$$O F$$HEX1$$c100$$ENDHEX$$BRICA'
            when 'L' then 'LIBERADO'
            when 'T' then 'HOSPITALAR' 
		else '' end as liberado,

		case g.id_situacao
              when 'A' then 'ATIVO'
              when 'P' then 'PENDENTE' 
              when 'I' then 'INATIVO' 
		end as situacao ,
		
		case when coalesce(g.id_caderno_abcfarma,'N') = 'N' then 'N$$HEX1$$c300$$ENDHEX$$O' else 'SIM' end as id_caderno_abcfarma,
		pab.cd_produto_abcfarma as cd_produto_abcfarma,
		pab.de_produto||': '||pab.de_apresentacao as de_produto_abcfarma,
		pab.nm_fabricante as fabricante_abc_farma,

		 g.nr_classificacao_fiscal,
		 g.cd_cest,
		 g.id_situacao_pis_cofins,
		 Case g.id_situacao_pis_cofins
			When 'P' then 'POSITIVA'
			When 'N' then 'NEGATIVA'
			When 'T' then 'TRIBUTADA'
		else '' end as de_situacao_pis_cofins,
		 g.id_lei_generico,
		 Case g.id_lei_generico
			When 'E' then 'EQUIVALENTE'
			When 'R' then 'REFER$$HEX1$$ca00$$ENDHEX$$NCIA'
			When 'S' then 'SIMILAR'
			When 'G' then 'GEN$$HEX1$$c900$$ENDHEX$$RICO'
			When 'O' then 'OUTROS'
		else '' end as de_lei_generico,
		 u.cd_unidade_federacao,
		 u.cd_tributacao_icms,
		 tbi.de_tributacao_icms,
		 ti.pc_icms,
		 ti.pc_fcp,
		 g.pc_ipi,
		 tp.cd_tributacao_produto,
		 tp.de_tributacao_produto,
		 tp.pc_st_estadual,
		 u.pc_reducao_base_st,
		 u.nr_ncm_situacao,
		case when u.nr_ncm_situacao is null then null else nse.de_situacao_especial end as de_situacao_especial
from produto_geral g
Inner Join produto_central pc 
	on pc.cd_produto = g.cd_produto
Inner Join produto_uf u (index pk_produto_uf)
	on	u.cd_produto 				= g.cd_produto and 
		u.cd_unidade_federacao	= :p_estado
Inner Join tipo_icms ti (index pk_tipo_icms)
	on ti.cd_tipo_icms				= u.cd_tipo_icms
Inner Join tributa_produtos_farmaceuticos tp
	on tp.cd_tributacao_produto	= u.cd_tributacao_produto
Inner Join subcategoria scp (index pk_subcategoria)
	on scp.cd_subcategoria = g.cd_subcategoria
Inner Join categoria cp (index pk_categoria)
	on cp.cd_categoria = scp.cd_categoria
Inner Join subgrupo sgp (index pk_subgrupo)
	on sgp.cd_subgrupo = cp.cd_subgrupo
Inner Join grupo gp (index pk_grupo)
	on gp.cd_grupo = sgp.cd_grupo
Left outer join subcategoria_rede_filial srf1 (index pk_subcategoria_rede_filial)
	on srf1.cd_subcategoria = g.cd_subcategoria
	and srf1.id_rede_filial = 'DC'
Left outer join tier_subcategoria tsc1	 (index pk_tier_subcategoria)
	on tsc1.cd_tier = srf1.cd_tier
Left outer join classificacao_subcategoria csc1 (index pk_classificacao_subcategoria)
	on csc1.cd_classificacao = srf1.cd_classificacao
Left outer join subcategoria_rede_filial srf2 (index pk_subcategoria_rede_filial)
	on srf2.cd_subcategoria = g.cd_subcategoria
	and srf2.id_rede_filial = 'PP'
Left outer join tier_subcategoria tsc2	 (index pk_tier_subcategoria)
	on tsc2.cd_tier = srf2.cd_tier
Left outer join classificacao_subcategoria csc2 (index pk_classificacao_subcategoria)
	on csc2.cd_classificacao = srf2.cd_classificacao
Left outer join produto_geral pr	 (index pk_produto_geral)
	on pr.cd_produto = pc.cd_prod_referencia_preco
Left outer join tributacao_icms tbi	 (index pk_tributacao_icms)
	on tbi.cd_tributacao_icms = u.cd_tributacao_icms
Left outer join marca_produto mp	 (index pk_marca_produto)
	on mp.cd_marca = g.cd_marca
Left outer join grupo_alteracao_preco gap (index pk_grupo_alteracao_preco)
	on gap.cd_grupo = pc.cd_grupo_alteracao_preco
Left outer join tipo_apresentacao_produto tap (index pk_tipo_apresentacao_produto)
	on tap.id_apresentacao = g.id_apresentacao
Left outer Join ncm_uf nu (index pk_ncm_uf)
	on nu.nr_ncm = g.nr_classificacao_fiscal
	and nu.cd_uf = u.cd_unidade_federacao
Left outer Join ncm_situacao_especial nse (index pk_ncm_situacao_especial)
	on nse.nr_ncm = g.nr_classificacao_fiscal
	and nse.cd_uf = u.cd_unidade_federacao
	and ((nse.nr_sequencial = u.nr_ncm_situacao) or (u.nr_ncm_situacao is null and nse.id_padrao = 'S'))
left outer join produto_abcfarma pab
	on pab.de_codigo_barras = g.de_codigo_barras
left outer join fornecedor f
	on f.cd_fornecedor = g.cd_fornecedor_usual
Left Outer Join tipo_produto_pricing tpp
	on tpp.cd_tipo_produto = pc.cd_tipo_produto_pricing" arguments=(("p_estado", string))  sort="de_produto A " )
