table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="g.cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="g.cd_produto_sap" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" dbalias="g.de_codigo_barras" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="g.vl_fator_conversao" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="produto_geral.cd_fornecedor_usual" dbalias="g.cd_fornecedor_usual" )
 column=(type=char(20) updatewhereclause=yes name=cd_fornecedor_sap dbname="fornecedor.cd_fornecedor_sap" dbalias="f.cd_fornecedor_sap" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" dbalias="f.nm_razao_social" )
 column=(type=char(1) updatewhereclause=yes name=id_liberado dbname="id_liberado" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_liberado_ant dbname="id_liberado_ant" )
 retrieve="Select	g.cd_produto,
		g.cd_produto_sap,
		g.de_produto + ' : ' + g.de_apresentacao_venda As de_produto,
		g.de_codigo_barras,
		g.vl_fator_conversao,
		g.cd_fornecedor_usual,
		f.cd_fornecedor_sap,
		f.nm_razao_social,
		(Case When (Select count(*) From conveniencia_prd_pedido_auto Where cd_produto = g.cd_produto) > 0
			Then 'S'
			 Else 'N'
		 End) As id_liberado,
		(Case When (Select count(*) From conveniencia_prd_pedido_auto Where cd_produto = g.cd_produto) > 0
			Then 'S'
			 Else 'N'
		 End) As id_liberado_ant
From produto_geral As g
	Inner Join fornecedor As f
		On f.cd_fornecedor = g.cd_fornecedor_usual
	Left Outer Join conveniencia_prd_pedido_auto As c
		On c.cd_produto = g.cd_produto
Where substring(g.cd_subcategoria, 1, 1) = '4'
	And g.id_situacao = 'A'
	And g.cd_fornecedor_usual In (Select vl_parametro From parametro_geral Where cd_parametro = 'CD_FORNECEDOR_CONV_PEDIDO')"  sort="nm_razao_social A de_produto A " )
