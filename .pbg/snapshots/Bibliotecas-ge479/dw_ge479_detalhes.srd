table(column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="wms_endereco.cd_endereco" dbalias="a.cd_endereco" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=long updatewhereclause=yes name=valor dbname="Valor" )
 column=(type=decimal(2) updatewhereclause=yes name=valorcalculado dbname="ValorCalculado" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=total dbname="Total" )
 retrieve="

select  a.cd_endereco,        
	   isnull (g.cd_produto,0) as cd_produto,

	   isnull ( b.qt_saldo * b.qt_caixa_padrao	 ,0) as Valor,  
	   isnull ( m.vl_custo_medio,0)  as ValorCalculado,       
        case when g.cd_produto is null then '' else
			g.de_produto + ' : ' + g.de_apresentacao_estoque end as de_produto,
        (b.qt_saldo * b.qt_caixa_padrao *  m.vl_custo_medio)  as Total       
from wms_endereco  a
left join wms_localizacao b on a.cd_endereco = b.cd_endereco
left join produto_geral g on g.cd_produto = b.cd_produto
left join vw_saldo_atual_produto m on m.cd_produto = g.cd_produto and m.cd_filial = 534
where a.cd_bairro in ( '1'  , '9')
and a.id_flow_rack = 'N' 
and a.cd_endereco = :cd_endereco



" arguments=(("cd_endereco", string)) )
