table(column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="wms_endereco.cd_endereco" dbalias="a.cd_endereco" )
 column=(type=char(1) updatewhereclause=yes name=cd_bairro dbname="wms_endereco.cd_bairro" dbalias="a.cd_bairro" )
 column=(type=char(2) updatewhereclause=yes name=cd_rua dbname="wms_endereco.cd_rua" dbalias="a.cd_rua" )
 column=(type=char(3) updatewhereclause=yes name=cd_predio dbname="wms_endereco.cd_predio" dbalias="a.cd_predio" )
 column=(type=char(1) updatewhereclause=yes name=cd_andar dbname="wms_endereco.cd_andar" dbalias="a.cd_andar" )
 column=(type=char(1) updatewhereclause=yes name=cd_apartamento dbname="wms_endereco.cd_apartamento" dbalias="a.cd_apartamento" )
 column=(type=long updatewhereclause=yes name=valor dbname="Valor" )
 column=(type=decimal(2) updatewhereclause=yes name=valorcalculado dbname="ValorCalculado" )
 column=(type=long updatewhereclause=yes name=qt_vazio_controlado dbname="qt_vazio_controlado" )
 column=(type=long updatewhereclause=yes name=qt_utilizado_controlado dbname="qt_utilizado_controlado" )
 column=(type=long updatewhereclause=yes name=qt_vazio_nao_controlado dbname="qt_vazio_nao_controlado" )
 column=(type=long updatewhereclause=yes name=qt_utilizado_nao_controlado dbname="qt_utilizado_nao_controlado" )
 column=(type=long updatewhereclause=yes name=parametro dbname="Parametro" )
 retrieve="select	a.cd_endereco,        
		a.cd_bairro,
		a.cd_rua,
		a.cd_predio,
		a.cd_andar,
		a.cd_apartamento,	
		isnull ( sum ( b.qt_saldo),0) as Valor,
		isnull ( sum( m.vl_custo_medio * b.qt_saldo * b.qt_caixa_padrao) , 0 )  as ValorCalculado,
	  
		--//PULM$$HEX1$$c300$$ENDHEX$$O CONTROLADO - Endere$$HEX1$$e700$$ENDHEX$$os VAZIOS
		(select count( distinct f.cd_endereco )   
		FROM wms_endereco f 
		INNER JOIN wms_bairro wb ON wb.cd_bairro = f.cd_bairro
		WHERE f.cd_bairro IN ('9')  
		  AND f.id_flow_rack = 'N'
		  AND wb.cd_filial IN (:il_filial)
		  AND f.cd_endereco NOT IN (
			SELECT a.cd_endereco  
			FROM wms_localizacao b
			INNER JOIN wms_endereco a ON a.cd_endereco = b.cd_endereco
			INNER JOIN wms_bairro wb2 ON wb2.cd_bairro = a.cd_bairro
			WHERE wb2.cd_filial IN (:il_filial)
			  AND a.cd_bairro = '9'))  as qt_vazio_controlado,
		
		--//PULM$$HEX1$$c300$$ENDHEX$$O CONTROLADO - Endere$$HEX1$$e700$$ENDHEX$$os utilizados
		(select count( distinct f.cd_endereco )  
		FROM wms_endereco f 
		INNER JOIN wms_bairro wb ON wb.cd_bairro = f.cd_bairro
		WHERE f.cd_bairro IN ('9') 
		  AND f.id_flow_rack = 'N'   
		  AND wb.cd_filial IN (:il_filial)
		  AND f.cd_endereco IN ( 
			SELECT a.cd_endereco   
			FROM wms_localizacao b
			INNER JOIN wms_endereco a ON a.cd_endereco = b.cd_endereco
			INNER JOIN wms_bairro wb2 ON wb2.cd_bairro = a.cd_bairro
			WHERE wb2.cd_filial IN (:il_filial)
			  AND a.cd_bairro = '9'))  as qt_utilizado_controlado,  

		--//PULM$$HEX1$$c300$$ENDHEX$$O NORMAL - Endere$$HEX1$$e700$$ENDHEX$$os VAZIOS
		(select count( distinct f.cd_endereco )  
		FROM wms_endereco f 
		INNER JOIN wms_bairro wb ON wb.cd_bairro = f.cd_bairro
		WHERE f.cd_bairro IN ('1','3')  
		  AND f.id_flow_rack = 'N'    
		  AND wb.cd_filial IN (:il_filial)
		  AND f.cd_endereco NOT IN ( 
			SELECT a.cd_endereco   
			FROM wms_localizacao b
			INNER JOIN wms_endereco a ON a.cd_endereco = b.cd_endereco
			INNER JOIN wms_bairro wb2 ON wb2.cd_bairro = a.cd_bairro
			WHERE wb2.cd_filial IN (:il_filial)
			  AND a.cd_bairro IN ('1','3')))  as qt_vazio_nao_controlado,

		--//PULM$$HEX1$$c300$$ENDHEX$$O NORMAL - Endere$$HEX1$$e700$$ENDHEX$$os utilizados
		(select count( distinct f.cd_endereco )  
		FROM wms_endereco f 
		INNER JOIN wms_bairro wb ON wb.cd_bairro = f.cd_bairro
		WHERE f.cd_bairro IN ('1','3') 
		  AND f.id_flow_rack = 'N'   
		  AND wb.cd_filial IN (:il_filial)
		  AND f.cd_endereco IN ( 
			SELECT a.cd_endereco   
			FROM wms_localizacao b
			INNER JOIN wms_endereco a ON a.cd_endereco = b.cd_endereco
			INNER JOIN wms_bairro wb2 ON wb2.cd_bairro = a.cd_bairro
			WHERE wb2.cd_filial IN (:il_filial)
			  AND a.cd_bairro IN ('1','3')))  as qt_utilizado_nao_controlado,  

		--//Custo do pallet  
		(Select cast (vl_parametro as int) 
		FROM wms_parametro
		WHERE cd_parametro IN ('ID_CUSTO_ARMAZENAGEM_PALLET'))  as Parametro

from wms_endereco  a
left join wms_localizacao b on a.cd_endereco = b.cd_endereco
left join produto_geral g on g.cd_produto = b.cd_produto
left join vw_saldo_atual_produto m on m.cd_produto = g.cd_produto and m.cd_filial = 534
left join wms_bairro wb on wb.cd_bairro = a.cd_bairro
where	a.id_flow_rack = 'N' 
and		a.cd_bairro in ('1','9','3')
and	wb.cd_filial in (:il_filial)
group by a.cd_endereco,
		  a.cd_bairro,
		  a.cd_rua,
		  a.cd_predio,
		  a.cd_andar,
		  a.cd_apartamento
order by a.cd_endereco" arguments=(("il_filial", numberlist)) )
