table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial_distribuidora.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="filial_distribuidora.id_situacao" )
 column=(type=char(20) updatewhereclause=yes name=cd_filial_distribuidora dbname="filial_distribuidora.cd_filial_distribuidora" )
 column=(type=char(14) updatewhereclause=yes name=nr_gln dbname="filial_distribuidora.nr_gln" )
 column=(type=char(14) updatewhereclause=yes name=nr_cnpj dbname="filial.nr_cnpj" )
 column=(type=char(1) updatewhereclause=yes name=de_dia_semana dbname="de_dia_semana" )
 column=(type=char(1) updatewhereclause=yes name=nr_dia_semana dbname="nr_dia_semana" )
 retrieve="Select	fd.cd_filial,
		f.nm_fantasia,
		fd.id_situacao,
		fd.cd_filial_distribuidora,
		fd.nr_gln,
		f.nr_cgc As nr_cnpj,
		'' As de_dia_semana,
		'' As nr_dia_semana
	From filial_distribuidora As fd
		Inner Join filial As f
			On f.cd_filial = fd.cd_filial
Where fd.cd_distribuidora = :distribuidora
	And f.id_situacao = 'A'" arguments=(("distribuidora", string))  sort="nm_fantasia A " )
