table(column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_devolucao_compra.dh_emissao" dbalias="n.dh_emissao" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_devolucao_compra_nfe.de_chave_acesso" dbalias="nfe.de_chave_acesso" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_devolucao_compra.vl_total_nf" dbalias="n.vl_total_nf" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo_devolucao dbname="motivo_devolucao_compra.de_motivo_devolucao" dbalias="m.de_motivo_devolucao" )
 column=(type=datetime updatewhereclause=yes name=dh_situacao_coleta dbname="dh_situacao_coleta" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_sit_coleta dbname="nr_matricula_sit_coleta" )
 column=(type=long updatewhereclause=yes name=nr_nf_compra dbname="nf_devolucao_compra.nr_nf_compra" dbalias="n.nr_nf_compra" )
 column=(type=char(3) updatewhereclause=yes name=de_serie_compra dbname="nf_devolucao_compra.de_serie_compra" dbalias="n.de_serie_compra" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso_compra dbname="nf_compra.de_chave_acesso_compra" dbalias="c.de_chave_acesso_compra" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="nf_compra.nr_pedido_distribuidora" dbalias="c.nr_pedido_distribuidora" )
 column=(type=long updatewhereclause=yes name=nr_agrupamento_dev_compra dbname="nr_agrupamento_dev_compra" )
 column=(type=char(40) updatewhereclause=yes name=nr_matricula_comprador dbname="nr_matricula_comprador" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_agrup_wms dbname="nm_usuario_agrup_wms" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_sit_coleta dbname="nm_usuario_sit_coleta" )
 retrieve="select	n.dh_emissao,
		nfe.de_chave_acesso,
		n.vl_total_nf,
		m.de_motivo_devolucao,
		COALESCE(n.dh_situacao_coleta, nc.dh_situacao) as dh_situacao_coleta,
		COALESCE(n.nr_matricula_sit_coleta, nc.nr_matricula_situacao) as nr_matricula_sit_coleta,
		n.nr_nf_compra,
		n.de_serie_compra,
		c.de_chave_acesso de_chave_acesso_compra ,
		c.nr_pedido_distribuidora,
		null as nr_agrupamento_dev_compra,
		null as nr_matricula_comprador,
		null as nm_usuario_agrup_wms,
		COALESCE(us.nm_usuario, us2.nm_usuario) as nm_usuario_sit_coleta
from nf_devolucao_compra n
inner join nf_devolucao_compra_nfe nfe on n.nr_nf = nfe.nr_nf and n.cd_filial = nfe.cd_filial and n.de_serie = nfe.de_serie and n.de_especie = nfe.de_especie
inner join nf_compra c on c.nr_nf = n.nr_nf_compra and c.de_serie = n.de_serie_compra and c.de_especie = n.de_especie_compra and c.cd_fornecedor = n.cd_fornecedor and c.cd_filial = n.cd_filial
left outer join usuario us on us.nr_matricula = n.nr_matricula_sit_coleta
left outer join motivo_devolucao_compra m on m.cd_motivo_devolucao = n.cd_motivo_devolucao
left join nf_devolucao_compra_coleta nc on nc.cd_filial = n.cd_filial and nc.nr_nf = n.nr_nf and nc.de_especie = n.de_especie and nc.de_serie = n.de_serie 
left join usuario us2 on us2.nr_matricula = nc.nr_matricula_situacao 
where n.cd_filial <> 534
and n.nr_nf = :p_nr_nf 
and n.cd_filial = :p_cd_filial
and n.de_serie = :p_de_serie 
and n.de_especie = :p_de_especie
and (:p_tipo = 'DEV' or :p_tipo = 'COL')

union all

select	n.dh_emissao,
		nfe.de_chave_acesso,
		n.vl_total_nf,
		m.de_motivo_devolucao,
		w.dh_situacao,
		w.nr_matricula,
		n.nr_nf_compra,
		n.de_serie_compra,
		c.de_chave_acesso,
		c.nr_pedido_central,
		n.nr_agrupamento_dev_compra,
		usu.nm_usuario as nr_matricula_comprador,
		u.nm_usuario as nm_usuario_agrup_wms,
		us.nm_usuario as nm_usuario_sit_coleta
from wms_segregado_coleta w
inner join nf_devolucao_compra n on w.nr_nf = n.nr_nf and w.de_serie = n.de_serie and w.de_especie = n.de_especie and w.cd_filial = n.cd_filial
inner join nf_devolucao_compra_nfe nfe on n.nr_nf = nfe.nr_nf and n.cd_filial = nfe.cd_filial and n.de_serie = nfe.de_serie and n.de_especie = nfe.de_especie
inner join nf_compra c on c.nr_nf = n.nr_nf_compra and c.de_serie = n.de_serie_compra and c.de_especie = n.de_especie_compra and c.cd_fornecedor = n.cd_fornecedor and c.cd_filial = n.cd_filial
left outer join agrupamento_dev_compra a on a.nr_agrupamento = n.nr_agrupamento_dev_compra
left outer join usuario u on u.nr_matricula = a.nr_matricula_inclusao
left outer join usuario us on us.nr_matricula = n.nr_matricula_sit_coleta
left outer join pedido_central p on p.nr_pedido = c.nr_pedido_central
left outer join usuario usu on usu.nr_matricula = p.nr_matricula_cadastramento
left outer join motivo_devolucao_compra m on m.cd_motivo_devolucao = n.cd_motivo_devolucao
where n.cd_filial = 534
and n.nr_nf = :p_nr_nf 
and n.cd_filial = :p_cd_filial
and n.de_serie = :p_de_serie 
and n.de_especie = :p_de_especie
and :p_tipo = 'COL'" arguments=(("p_cd_filial", number),("p_nr_nf", number),("p_de_serie", string),("p_de_especie", string),("p_tipo", string)) )
