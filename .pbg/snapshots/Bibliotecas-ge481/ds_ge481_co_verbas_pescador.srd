table(column=(type=long updatewhereclause=yes name=cd_filial dbname="log_exportacao_sap.cd_filial" dbalias="l.cd_filial" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="log_exportacao_sap.cd_fornecedor" dbalias="l.cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="log_exportacao_sap.nr_nf" dbalias="l.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="log_exportacao_sap.de_serie" dbalias="l.de_serie" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="log_exportacao_sap.de_especie" dbalias="l.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_nf dbname="log_exportacao_sap.id_tipo_nf" dbalias="l.id_tipo_nf" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="log_exportacao_sap.nr_atualizacao" dbalias="l.nr_atualizacao" )
 column=(type=char(40) updatewhereclause=yes name=centro dbname="integracao_sap.centro" dbalias="sa.centro" )
 column=(type=char(20) updatewhereclause=yes name=cd_fornecedor_sap dbname="fornecedor.cd_fornecedor_sap" dbalias="f.cd_fornecedor_sap" )
 column=(type=char(1) updatewhereclause=yes name=id_utiliza_imposto_base_verba dbname="id_utiliza_imposto_base_verba" )
 retrieve="select	l.cd_filial,
		l.cd_fornecedor,
		l.nr_nf,
		l.de_serie,
		l.de_especie,
		l.id_tipo_nf,
		l.nr_atualizacao,
		sa.cd_chave_sap as centro,
		f.cd_fornecedor_sap,
		coalesce(f.id_utiliza_imposto_base_verba,'N') as id_utiliza_imposto_base_verba
from log_exportacao_sap l
left outer join integracao_sap sa on (sa.cd_chave_legado = cast(l.cd_filial as varchar) and sa.cd_tabela = 'FILIAL' and sa.cd_empresa = 1000)
left outer join fornecedor f on f.cd_fornecedor  = l.cd_fornecedor
 where l.id_tipo_nf in ('VEB', 'VED', 'VEC') and 
       l.id_status_integracao = 'C' and 
       l.cd_tipo_documento in ('VEB', 'VED', 'VEC')" )
