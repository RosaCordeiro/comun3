table(column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="de_chave_acesso" )
 column=(type=char(40) updatewhereclause=yes name=cd_deposito_sap dbname="cd_deposito_sap" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="cd_filial_destino" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="nr_atualizacao" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_nf dbname="id_tipo_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_documento dbname="dh_documento" )
 column=(type=char(15) updatewhereclause=yes name=nr_protocolo_cancelamento dbname="nr_protocolo_cancelamento" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="dh_cancelamento" )
 retrieve="select * from (
select ntn.de_chave_acesso,
 		 les.cd_varchar as cd_deposito_sap,
		 nt.cd_filial_destino,
		 les.nr_atualizacao,
		 les.id_tipo_nf,
		 les.dh_documento,
		 ntn.nr_protocolo_cancelamento,
		 ntn.dh_cancelamento
  from log_exportacao_sap les
  inner join nf_transferencia nt 
     		 on nt.cd_filial_origem = les.cd_filial 
     	   and nt.nr_nf  = les.nr_nf 
     	   and nt.de_serie = les.de_serie 
     	   and nt.de_especie = les.de_especie 
  inner join nf_transferencia_nfe ntn
     		 on ntn.cd_filial_origem = nt.cd_filial_origem 
     		and ntn.nr_nf = nt.nr_nf 
     		and ntn.de_serie = nt.de_serie 
     		and ntn.de_especie = nt.de_especie 
where les.id_tipo_nf 				in ('CRN', 'CTL')
  and les.id_status_integracao 	in ('C', 'E')
  and les.cd_tipo_documento in ('CRN', 'CTL')
union
select ndcn.de_chave_acesso,
 		 null,
		 null,
		 les.nr_atualizacao,
		 les.id_tipo_nf,
		 les.dh_documento,
		 ndcn.nr_protocolo_cancelamento,
		 ndcn.dh_cancelamento
  from log_exportacao_sap les
  inner join nf_devolucao_compra ndc 
     		 on ndc.cd_filial = les.cd_filial 
     	   and ndc.nr_nf  = les.nr_nf 
     	   and ndc.de_serie = les.de_serie 
     	   and ndc.de_especie = les.de_especie 
  inner join nf_devolucao_compra_nfe ndcn
     		 on ndcn.cd_filial = ndc.cd_filial 
     		and ndcn.nr_nf = ndc.nr_nf 
     		and ndcn.de_serie = ndc.de_serie 
     		and ndcn.de_especie = ndc.de_especie 
where les.id_tipo_nf 				in ('CDL')
  and les.id_status_integracao 	in ('C', 'E')
  and les.cd_tipo_documento in ('CDL')) as retorno" )
