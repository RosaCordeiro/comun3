table(column=(type=decimal(0) update=yes updatewhereclause=yes name=nr_atualizacao dbname="nr_atualizacao" )
 column=(type=char(40) update=yes updatewhereclause=yes name=cd_chave dbname="cd_chave" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(40) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf dbname="cd_uf" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_atual dbname="distribuidora_produto.vl_preco_atual" dbalias="dp.vl_preco_atual" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_atual dbname="distribuidora_produto.pc_desconto_atual" dbalias="dp.pc_desconto_atual" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_repasse_icms dbname="distribuidora_produto.pc_repasse_icms" dbalias="dp.pc_repasse_icms" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_compra dbname="produto_geral.cd_unidade_medida_compra" dbalias="pg.cd_unidade_medida_compra" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="pg.cd_produto_sap" )
 column=(type=char(20) updatewhereclause=yes name=cd_fornecedor_sap dbname="cd_fornecedor_sap" )
 retrieve="Select Aux.nr_atualizacao, Aux.cd_chave, Aux.cd_produto, Aux.cd_fornecedor, Aux.cd_uf,
        dp.vl_preco_atual, dp.pc_desconto_atual, dp.pc_repasse_icms, pg.cd_unidade_medida_compra,
        pg.cd_produto_sap,
        (Select fc.cd_fornecedor_sap
                from fornecedor fc
                where fc.cd_fornecedor = Aux.cd_fornecedor) as cd_fornecedor_sap
from
(
select nr_atualizacao, cd_chave, cd_produto,
    left(cd_chave, charindex('@#!',cd_chave) -1) as cd_fornecedor,
    right(cd_chave,2) as cd_uf
from log_exportacao_sap
where id_tipo_nf = '153'
    and id_tipo_log = 31
    and id_situacao_docto = 'C'
) Aux
    inner join distribuidora_produto dp on (dp.cd_distribuidora = Aux.cd_fornecedor
                                            and dp.cd_unidade_federacao = Aux.cd_uf
                                            and dp.cd_produto = Aux.cd_produto)
    inner join produto_geral pg on (pg.cd_produto = dp.cd_produto)
Where Exists (Select 1
                from fornecedor fc
                where fc.cd_fornecedor = Aux.cd_fornecedor
                and fc.cd_fornecedor_sap is not null)
and pg.cd_produto_sap is not null"  sort="cd_fornecedor A nr_atualizacao A " )
