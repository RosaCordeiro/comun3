table(column=(type=decimal(0) update=yes updatewhereclause=yes name=nr_atualizacao dbname="log_exportacao_sap.nr_atualizacao" dbalias="l.nr_atualizacao" )
 column=(type=char(40) update=yes updatewhereclause=yes name=cd_chave dbname="log_exportacao_sap.cd_chave" dbalias="l.cd_chave" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="log_exportacao_sap.cd_produto" dbalias="l.cd_produto" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="log_exportacao_sap.cd_fornecedor" dbalias="l.cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=qt_estoque_disponivel dbname="log_exportacao_sap.qt_estoque_disponivel" dbalias="l.qt_estoque_disponivel" )
 column=(type=char(1) updatewhereclause=yes name=id_estoque_maior_10dias dbname="log_exportacao_sap.id_estoque_maior_10dias" dbalias="l.id_estoque_maior_10dias" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="g.cd_produto_sap" )
 column=(type=char(20) updatewhereclause=yes name=cd_fornecedor_sap dbname="fornecedor.cd_fornecedor_sap" dbalias="fo.cd_fornecedor_sap" )
 retrieve="select l.nr_atualizacao, 
		l.cd_chave, 
		l.cd_produto,
		l.cd_fornecedor,
		l.qt_estoque_disponivel,
		l.id_estoque_maior_10dias,
		g.cd_produto_sap,
		fo.cd_fornecedor_sap
from log_exportacao_sap l
inner join produto_geral g
	on g.cd_produto = l.cd_produto
inner join fornecedor fo
	on fo.cd_fornecedor = l.cd_fornecedor
where l.id_tipo_nf = '154'
    and l.id_tipo_log = 51
    and l.id_situacao_docto = 'C'
	and g.cd_produto_sap is not null
	and fo.cd_fornecedor_sap is not null"  sort="cd_fornecedor A nr_atualizacao A " )
