table(column=(type=long updatewhereclause=yes name=nr_atualizacao dbname="nr_atualizacao" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="pg.cd_produto_sap" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="pg.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" dbalias="f.nm_razao_social" )
 column=(type=char(20) updatewhereclause=yes name=cd_fornecedor_sap dbname="fornecedor.cd_fornecedor_sap" dbalias="f.cd_fornecedor_sap" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="distribuidora_produto.cd_unidade_federacao" dbalias="dp.cd_unidade_federacao" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_distribuidora dbname="distribuidora_produto.cd_produto_distribuidora" dbalias="dp.cd_produto_distribuidora" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_preco dbname="vl_preco" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=char(1) updatewhereclause=yes name=id_icms_st dbname="tributacao_icms.id_icms_st" dbalias="ti.id_icms_st" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst dbname="tributacao_icms.cd_cst" dbalias="ti.cd_cst" )
 column=(type=long updatewhereclause=yes name=ncm dbname="produto_geral.ncm" dbalias="pg.ncm" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="distribuidora_produto.id_situacao" dbalias="dp.id_situacao" )
 column=(type=char(7) updatewhereclause=yes name=cd_cest dbname="produto_geral.cd_cest" dbalias="pg.cd_cest" )
 column=(type=char(1) updatewhereclause=yes name=cd_origem_produto dbname="produto_geral.cd_origem_produto" dbalias="pg.cd_origem_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_st dbname="pc_icms_st" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_mva dbname="pc_mva" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_pmc dbname="vl_pmc" )
 column=(type=long updatewhereclause=yes name=ncm_dist dbname="distribuidora_produto.ncm_dist" dbalias="dp.ncm_dist" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_dist dbname="distribuidora_produto.id_situacao_dist" dbalias="dp.id_situacao_dist" )
 column=(type=long updatewhereclause=yes name=cd_cest_dist dbname="distribuidora_produto.cd_cest_dist" dbalias="dp.cd_cest_dist" )
 column=(type=char(1) updatewhereclause=yes name=cd_origem_dist dbname="cd_origem_dist" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_dist dbname="cd_cst_dist" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_st_dist dbname="pc_icms_st_dist" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_mva_dist dbname="pc_mva_dist" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pmc_dist dbname="vl_pmc_dist" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao_dist dbname="dh_atualizacao_dist" )
 column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="cd_grupo" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="pg.cd_produto" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="fornecedor.cd_fornecedor" dbalias="f.cd_fornecedor" )
 column=(type=char(20) updatewhereclause=yes name=cd_fornecedor_sap_usual dbname="cd_fornecedor_sap_usual" )
 retrieve="  select 0 nr_atualizacao,
			pg.cd_produto_sap,
			pg.de_produto,
			f.nm_razao_social,
			f.cd_fornecedor_sap,
			dp.cd_unidade_federacao,
			dp.cd_produto_distribuidora,
			Coalesce(case when dp.cd_distribuidora  = par.cd_distribuidora_estoque
		      then ((IsNull(dp.vl_preco_novo, dp.vl_preco_atual) *0.05) + IsNull(dp.vl_preco_novo, dp.vl_preco_atual))    
		      else  IsNull(dp.vl_preco_novo, dp.vl_preco_atual) 
		   end, 0)  as vl_preco,
		 	Coalesce(dp.pc_desconto_novo, dp.pc_desconto_atual, 0) as pc_desconto,
			ti.id_icms_st,
			ti.cd_cst_tributacao as cd_cst,
			pg.nr_classificacao_fiscal as ncm,
			dp.id_situacao,
			pg.cd_cest,
			pg.cd_origem_produto,
			coalesce(tpi.pc_icms, 0) as pc_icms_st,
			coalesce(tpfm.pc_mva, 0)  as pc_mva,
		 	coalesce(round(pu.vl_preco_venda_maximo/pg.vl_fator_conversao,2), 0) as vl_pmc,
			dp.ncm_produto as ncm_dist,
		 	dp.id_situacao as id_situacao_dist,
			dp.cd_cest as cd_cest_dist,
       	substring(dp.cd_cst, 1, 1) as cd_origem_dist,
			substring(dp.cd_cst, 2, 2) as cd_cst_dist,
		 	coalesce(dp.pc_icms_st, 0) as pc_icms_st_dist,
		 	coalesce(dp.pc_mva, 0)  as pc_mva_dist,
			coalesce(dp.vl_pmc, 0) as vl_pmc_dist,
       	Coalesce(dp.dh_atualizacao_distribuidora, '1900-01-01') as dh_atualizacao_dist,
			substring(pg.cd_subcategoria, 1, 1) as cd_grupo,
			pg.cd_produto,
			f.cd_fornecedor,
			Coalesce(fu.cd_fornecedor_sap, '') as cd_fornecedor_sap_usual
    from distribuidora_produto dp
	inner join fornecedor f on f.cd_fornecedor = dp.cd_distribuidora
	inner join produto_geral pg on pg.cd_produto = dp.cd_produto
	left outer join fornecedor fu on fu.cd_fornecedor = pg.cd_fornecedor_usual
	inner join produto_uf pu                         on pu.cd_produto = dp.cd_produto and pu.cd_unidade_federacao = dp.cd_unidade_federacao 
   inner join tributacao_icms ti                    on ti.cd_tributacao_icms = pu.cd_tributacao_icms 
	inner join tipo_icms tpi                         on tpi.cd_tipo_icms = pu.cd_tipo_icms
	left outer join tributa_produtos_farm_mva tpfm on tpfm.cd_tributacao_produto = pu.cd_tributacao_produto and tpfm.pc_icms = pu.pc_icms_compra_preco,
			parametro par
   where (dp.dh_atualizacao_distribuidora > dp.dh_exportacao_divergencia_sap or 
			dp.dh_exportacao_divergencia_sap is null)" )
