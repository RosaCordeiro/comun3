table(column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="nr_atualizacao" )
 column=(type=long updatewhereclause=yes name=nota_fiscal dbname="nota_fiscal" )
 column=(type=char(44) updatewhereclause=yes name=chave_acesso dbname="chave_acesso" )
 column=(type=char(20) updatewhereclause=yes name=fornecedor dbname="fornecedor" )
 column=(type=datetime updatewhereclause=yes name=dt_conferencia dbname="dt_conferencia" )
 retrieve="select 
	lo.nr_atualizacao,
	lo.nr_nf as nota_fiscal,
	ntn.de_chave_acesso as chave_acesso,
	null as fornecedor,
	lo.dh_exportacao as dt_conferencia
from 
	log_exportacao_sap lo 
Inner Join 
	filial f
	on f.cd_filial = lo.cd_filial
inner join
	nf_transferencia_nfe ntn
	on ntn.cd_filial_origem = lo.cd_filial
	and ntn.nr_nf = lo.nr_nf
	and ntn.de_especie = lo.de_especie
	and ntn.de_serie = lo.de_serie
where 
	lo.id_tipo_nf = 'WMR'
	and lo.id_status_integracao 	= 'C'
	and lo.cd_tipo_documento = 'WMR'
	and Coalesce(f.id_centro_distribuicao, 'N') = 'S'
	and lo.cd_fornecedor is null

union

select 
	lo.nr_atualizacao,
	lo.nr_nf as nota_fiscal,
	nfcp.de_chave_acesso as chave_acesso,
	f.cd_fornecedor_sap as fornecedor,
	lo.dh_exportacao as dt_conferencia
from 
	log_exportacao_sap lo 
Inner Join 
	nf_compra_pendente nfcp 
	on nfcp.cd_fornecedor = lo.cd_fornecedor 
	and nfcp.cd_filial = lo.cd_filial 
	and nfcp.nr_nf = lo.nr_nf 
	and nfcp.de_especie = lo.de_especie 
	and nfcp.de_serie = lo.de_serie
Inner Join 
	fornecedor f
	on f.cd_fornecedor = nfcp.cd_fornecedor
Inner join
	filial fi
	on fi.cd_filial = lo.cd_filial
where 
	lo.id_tipo_nf = 'WMR'
	and lo.id_status_integracao = 'C'
	and lo.cd_tipo_documento = 'WMR'
	and Coalesce(fi.id_centro_distribuicao, 'N') = 'S'
	and lo.cd_fornecedor is not null

union

select 
	lo.nr_atualizacao,
	lo.nr_nf as nota_fiscal,
	nfc.de_chave_acesso as chave_acesso,
	f.cd_fornecedor_sap as fornecedor,
	lo.dh_exportacao as dt_conferencia
from 
	log_exportacao_sap lo 
Inner Join 
	nf_compra nfc 
	on nfc.cd_fornecedor = lo.cd_fornecedor 
	and nfc.cd_filial = lo.cd_filial 
	and nfc.nr_nf = lo.nr_nf 
	and nfc.de_especie = lo.de_especie 
	and nfc.de_serie = lo.de_serie
Inner Join 
	fornecedor f 
	on f.cd_fornecedor = nfc.cd_fornecedor
Inner Join
	filial fi
	on fi.cd_filial = lo.cd_filial
where 
	lo.id_tipo_nf = 'WMR'
	and lo.id_status_integracao = 'C'
	and lo.cd_tipo_documento = 'WMR'
	and Coalesce(fi.id_centro_distribuicao, 'N') = 'N'

union

select 
	lo.nr_atualizacao,
	lo.nr_nf as nota_fiscal,
	ntn.de_chave_acesso as chave_acesso,
	null as fornecedor,
	lo.dh_exportacao as dt_conferencia
from 
	log_exportacao_sap lo 
Inner Join 
	nf_transferencia nt 
	on nt.cd_filial_origem = lo.cd_filial 
	and nt.nr_nf = lo.nr_nf
	and nt.de_especie = lo.de_especie
	and nt.de_serie = lo.de_serie
inner join 
	nf_transferencia_nfe ntn 
	on nt.cd_filial_origem = ntn.cd_filial_origem
	and nt.nr_nf = ntn.nr_nf
	and nt.de_especie = ntn.de_especie
	and nt.de_serie = ntn.de_serie
Inner Join
	filial fi
	on fi.cd_filial = lo.cd_filial
where 
	lo.id_tipo_nf = 'WMR'
	and lo.id_status_integracao = 'C'
	and lo.cd_tipo_documento = 'WMR'
	and Coalesce(fi.id_centro_distribuicao, 'N') = 'N'" )
