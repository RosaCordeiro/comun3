table(column=(type=long updatewhereclause=yes name=cd_produto dbname="distribuidora_produto.CD_PRODUTO" dbalias="a.CD_PRODUTO" )
 column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="distribuidora_produto.CD_DISTRIBUIDORA" dbalias="a.CD_DISTRIBUIDORA" )
 column=(type=char(20) updatewhereclause=yes name=cd_fornecedor_sap dbname="fornecedor.CD_FORNECEDOR_SAP" dbalias="f.CD_FORNECEDOR_SAP" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf dbname="distribuidora_produto.CD_UF" dbalias="a.CD_UF" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.CD_PRODUTO_SAP" dbalias="g.CD_PRODUTO_SAP" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_distribuidora dbname="distribuidora_produto.CD_PRODUTO_DISTRIBUIDORA" dbalias="a.CD_PRODUTO_DISTRIBUIDORA" )
 column=(type=long updatewhereclause=yes name=qt_emb_pdr_distrib dbname="QT_EMB_PDR_DISTRIB" )
 column=(type=long updatewhereclause=yes name=qt_est_disponivel dbname="QT_EST_DISPONIVEL" )
 column=(type=datetime updatewhereclause=yes name=dt_atualz_distrib dbname="distribuidora_produto.DT_ATUALZ_DISTRIB" dbalias="a.DT_ATUALZ_DISTRIB" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_preco dbname="VL_PRECO" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="PC_DESCONTO" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="ID_SITUACAO" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_anterior dbname="ID_SITUACAO_ANTERIOR" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="PC_ICMS" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_reducao_base_icms dbname="PC_REDUCAO_BASE_ICMS" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_comissao_midia dbname="PC_COMISSAO_MIDIA" )
 column=(type=datetime updatewhereclause=yes name=dh_atualiz_estoque dbname="DH_ATUALIZ_ESTOQUE" )
 column=(type=long updatewhereclause=yes name=nr_dias_pagamento dbname="NR_DIAS_PAGAMENTO" )
 column=(type=decimal(3) updatewhereclause=yes name=vl_repasse dbname="VL_REPASSE" )
 column=(type=decimal(3) updatewhereclause=yes name=vl_compra dbname="VL_COMPRA" )
 column=(type=decimal(3) updatewhereclause=yes name=pc_desconto_financeiro dbname="PC_DESCONTO_FINANCEIRO" )
 column=(type=decimal(3) updatewhereclause=yes name=vl_melhor_compra dbname="VL_MELHOR_COMPRA" )
 column=(type=decimal(3) updatewhereclause=yes name=vl_juros_descrescimo_dist dbname="VL_JUROS_DESCRESCIMO_DIST" )
 column=(type=decimal(3) updatewhereclause=yes name=vl_preco_atual dbname="VL_PRECO_ATUAL" )
 column=(type=decimal(3) updatewhereclause=yes name=vl_icms_st dbname="VL_ICMS_ST" )
 column=(type=decimal(3) updatewhereclause=yes name=vl_base_icms dbname="VL_BASE_ICMS" )
 retrieve="select   a.cd_produto as CD_PRODUTO,
		  a.cd_distribuidora AS CD_DISTRIBUIDORA, 
		  f.cd_fornecedor_sap AS CD_FORNECEDOR_SAP,
		  a.cd_unidade_federacao AS CD_UF,
		  g.cd_produto_sap     AS CD_PRODUTO_SAP , 
		  a.cd_produto_distribuidora AS CD_PRODUTO_DISTRIBUIDORA,
		  coalesce(a.qt_embalagem_padrao_distrib,1) AS QT_EMB_PDR_DISTRIB,
		  coalesce(a.qt_estoque_disponivel,0)  AS QT_EST_DISPONIVEL,
		  a.dh_atualizacao_distribuidora AS DT_ATUALZ_DISTRIB,
		  coalesce(	case when a.cd_distribuidora  = '053404705'   
				  then ((IsNull(a.vl_preco_novo, a.vl_preco_atual) *0.05) + IsNull(a.vl_preco_novo, a.vl_preco_atual))    
						  else  IsNull(a.vl_preco_novo, a.vl_preco_atual) end ,0)  as VL_PRECO,
		  coalesce (a.pc_desconto_novo, a.pc_desconto_atual) as PC_DESCONTO,
		  isnull(a.id_situacao,'') AS ID_SITUACAO,		 
		  isnull(a.id_situacao_anterior,'')  AS ID_SITUACAO_ANTERIOR,
		  coalesce(a.pc_icms,0)  AS PC_ICMS,
		  coalesce(a.pc_reducao_base_icms,0)  AS PC_REDUCAO_BASE_ICMS ,    
		  coalesce(a.pc_comissao_midia,0)  AS PC_COMISSAO_MIDIA,
		  isnull(a.dh_atualizacao_estoque,'') AS DH_ATUALIZ_ESTOQUE   ,
		  coalesce(a.nr_dias_pagamento,0)  as NR_DIAS_PAGAMENTO,
		  0.000 AS VL_REPASSE,
	 	  0.000 AS VL_COMPRA,
		  0.000 AS PC_DESCONTO_FINANCEIRO  ,
		  0.000 AS VL_MELHOR_COMPRA,
		  0.000 AS VL_JUROS_DESCRESCIMO_DIST,
		  0.000 AS VL_PRECO_ATUAL,
		  0.000 AS VL_ICMS_ST,
		  0.000 AS VL_BASE_ICMS
from    distribuidora_produto  a
inner join produto_geral g
	    on g.cd_produto = a.cd_produto
inner join fornecedor f
        on f.cd_fornecedor  = a.cd_distribuidora    
where g.cd_produto_sap is not null
	and a.dh_exportacao_sap is null
	and ltrim(g.cd_produto_sap) <> ''
	and a.cd_unidade_federacao 	= :al_uf
   and  f.cd_fornecedor_sap 		= :as_fornecedor_sap
	and a.cd_distribuidora in (select cd_fornecedor from fornecedor f  where f.id_distribuidora = 'S')

Union 

select  a.cd_produto as CD_PRODUTO,
		  a.cd_distribuidora AS CD_DISTRIBUIDORA, 
		  f.cd_fornecedor_sap AS CD_FORNECEDOR_SAP,
		  a.cd_unidade_federacao AS CD_UF,
		  g.cd_produto_sap     AS CD_PRODUTO_SAP , 
		  a.cd_produto_distribuidora AS CD_PRODUTO_DISTRIBUIDORA,
		  coalesce(a.qt_embalagem_padrao_distrib,1) AS QT_EMB_PDR_DISTRIB,
		  coalesce(a.qt_estoque_disponivel,0)  AS QT_EST_DISPONIVEL,
		  a.dh_atualizacao_distribuidora AS DT_ATUALZ_DISTRIB,
		  coalesce(	case when a.cd_distribuidora  = '053404705'   
				  then ((IsNull(a.vl_preco_novo, a.vl_preco_atual) *0.05) + IsNull(a.vl_preco_novo, a.vl_preco_atual))    
						  else  IsNull(a.vl_preco_novo, a.vl_preco_atual) end ,0)  as VL_PRECO,
		  coalesce (a.pc_desconto_novo, a.pc_desconto_atual) as PC_DESCONTO,
		  isnull(a.id_situacao,'') AS ID_SITUACAO,		 
		  isnull(a.id_situacao_anterior,'')  AS ID_SITUACAO_ANTERIOR,
		  coalesce(a.pc_icms,0)  AS PC_ICMS,
		  coalesce(a.pc_reducao_base_icms,0)  AS PC_REDUCAO_BASE_ICMS ,    
		  coalesce(a.pc_comissao_midia,0)  AS PC_COMISSAO_MIDIA,
		 isnull(a.dh_atualizacao_estoque,'') AS DH_ATUALIZ_ESTOQUE   ,
		  coalesce(a.nr_dias_pagamento,0)  as NR_DIAS_PAGAMENTO,
		  0.000 AS VL_REPASSE,
	 	  0.000 AS VL_COMPRA,
		  0.000 AS PC_DESCONTO_FINANCEIRO  ,
		  0.000 AS VL_MELHOR_COMPRA,
		  0.000 AS VL_JUROS_DESCRESCIMO_DIST,
		  0.000 AS VL_PRECO_ATUAL,
		  0.000 AS VL_ICMS_ST,
		  0.000 AS VL_BASE_ICMS
from    distribuidora_produto  a
inner join produto_geral g
	    on g.cd_produto = a.cd_produto
inner join fornecedor f
        on f.cd_fornecedor  = a.cd_distribuidora    
where g.cd_produto_sap is not null
	and a.dh_exportacao_sap is not null
     and a.dh_atualizacao_distribuidora > a.dh_exportacao_sap
	and ltrim(g.cd_produto_sap) <> ''	
	and a.cd_unidade_federacao	=:al_uf
    and  f.cd_fornecedor_sap		 =:as_fornecedor_sap
	and a.cd_distribuidora in (select cd_fornecedor from fornecedor f  where f.id_distribuidora = 'S')" arguments=(("al_uf", string),("as_fornecedor_sap", string))  sort="cd_uf A cd_fornecedor_sap A " )
