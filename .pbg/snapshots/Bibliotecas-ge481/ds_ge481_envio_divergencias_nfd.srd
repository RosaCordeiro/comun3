table(column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="nr_atualizacao" )
 column=(type=char(20) updatewhereclause=yes name=cd_fornecedor_sap dbname="cd_fornecedor_sap" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_devolucao dbname="nr_devolucao" )
 column=(type=char(250) updatewhereclause=yes name=de_dados_adicionais dbname="de_dados_adicionais" )
 column=(type=char(20) updatewhereclause=yes name=cd_transportadora dbname="cd_transportadora" )
 column=(type=long updatewhereclause=yes name=qt_volume dbname="qt_volume" )
 column=(type=char(20) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(20) updatewhereclause=yes name=de_marca dbname="de_marca" )
 column=(type=char(20) updatewhereclause=yes name=nr_volume dbname="nr_volume" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_bruto dbname="qt_peso_bruto" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_liquido dbname="qt_peso_liquido" )
 column=(type=char(4) updatewhereclause=yes name=cd_motivo_devolucao dbname="cd_motivo_devolucao" )
 column=(type=char(1) updatewhereclause=yes name=status_devolucao dbname="status_devolucao" )
 column=(type=char(1) updatewhereclause=yes name=nr_docnum dbname="nr_docnum" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="wms_int_sap.dh_inclusao" dbalias="wis.dh_inclusao" )
 column=(type=char(50) updatewhereclause=yes name=cd_chave_interface dbname="log_exportacao_sap.cd_chave_interface" dbalias="lo.cd_chave_interface" )
 retrieve="select 
		coalesce(lo.nr_atualizacao,0) as nr_atualizacao,
		coalesce(f.cd_fornecedor_sap,'') as cd_fornecedor_sap,
		coalesce(wis.nr_integracao,0) as nr_devolucao,
		coalesce(wis.de_dados_adicionais,'') as de_dados_adicionais,
		coalesce(t.cd_fornecedor_sap,'') as cd_transportadora,
		coalesce(wis.qt_volume,0) as qt_volume,
		coalesce(wis.de_especie_volume,'') as de_especie,
		coalesce(wis.de_marca_volume,'') as de_marca,
		coalesce(wis.nr_volume,'') as nr_volume,
		coalesce(wis.qt_peso_bruto,0) as qt_peso_bruto,
		coalesce(wis.qt_peso_liquido,0) as qt_peso_liquido,
		coalesce(m.cd_motivo_sap,'') as cd_motivo_devolucao,
		'' as status_devolucao,
		'' as nr_docnum,
		wis.dh_inclusao,
		lo.cd_chave_interface
From log_exportacao_sap lo
Inner Join wms_int_sap wis 
	On wis.nr_integracao = cast(lo.cd_chave as integer)
Left Outer Join fornecedor f 
	On f.cd_fornecedor = wis.cd_fornecedor 
Left Outer Join fornecedor t 
	On t.cd_fornecedor = wis.cd_transportadora 
Left Outer Join motivo_devolucao_compra m 
    On (m.cd_motivo_devolucao = wis.cd_motivo_devolucao)
Where lo.id_tipo_nf 				= 'WMD'
	and lo.cd_tipo_documento 	= 'WMD'
	and lo.id_status_integracao = 'C'
	and lo.cd_chave_interface 	is not null
	and lo.cd_chave_interface <> ''
	and (wis.id_situacao 			= 'C' or lo.id_reprocessar = 'S')" )
