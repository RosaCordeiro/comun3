table(column=(type=long updatewhereclause=yes name=cd_promocao dbname="cd_promocao" )
 column=(type=char(10) updatewhereclause=yes name=cd_promocao_sap dbname="cd_promocao_sap" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo dbname="log_exportacao_sap.id_tipo" dbalias="b.id_tipo" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio_vigencia dbname="promocao_sos.dh_inicio_vigencia" dbalias="c.dh_inicio_vigencia" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_vigencia dbname="promocao_sos.dh_termino_vigencia" dbalias="c.dh_termino_vigencia" )
 column=(type=char(40) updatewhereclause=yes name=id_filial_sap dbname="integracao_sap.id_filial_sap" dbalias="s.id_filial_sap" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="d.cd_produto_sap" )
 column=(type=long updatewhereclause=yes name=qt_estoque_atual dbname="log_exportacao_sap.qt_estoque_atual" dbalias="b.qt_estoque_atual" )
 column=(type=char(100) updatewhereclause=yes name=de_motivo dbname="log_exportacao_sap.de_motivo_est_base" dbalias="b.de_motivo_est_base" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_alteracao dbname="nr_matricula_alteracao" )
 column=(type=datetime updatewhereclause=yes name=dh_documento dbname="log_exportacao_sap.dh_documento" dbalias="b.dh_documento" )
 column=(type=datetime updatewhereclause=yes name=dh_item_termino_vigencia dbname="promocao_sos.dh_item_termino_vigencia" dbalias="c.dh_item_termino_vigencia" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="log_exportacao_sap.nr_atualizacao" dbalias="b.nr_atualizacao" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao dbname="id_alteracao" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo_matriz dbname="qt_estoque_minimo_matriz" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="log_exportacao_sap.cd_produto" dbalias="b.cd_produto" )
 retrieve="select  Case When c.id_tipo_promocao = 'P' Then b.cd_promocao_sos Else 0 End as cd_promocao,
       Case When c.id_tipo_promocao <> 'P' Then c.cd_promocao_sap Else '' End as cd_promocao_sap,
       b.cd_tipo_documento  as id_tipo,
       c.dh_inicio   as dh_inicio_vigencia ,
       c.dh_termino   as dh_termino_vigencia ,
       s.cd_chave_sap as id_filial_sap, 
       d.cd_produto_sap,      
       b.nr_lancamento as qt_estoque_atual,      
       b.de_erro      as de_motivo_est_base ,
	  RTRIM(substring(b.nr_titulo, 5, 6)) as nr_matricula_alteracao,
       b.dh_documento,	
		c.dh_termino  as dh_item_termino_vigencia,
		b.nr_atualizacao, 
		case when b.cd_filial=534 then 'M' else 'L' end as id_alteracao, 
		coalesce(c1.qt_estoque_minimo_matriz, 0) as qt_estoque_minimo_matriz,
		b.cd_produto
from   log_exportacao_sap b
inner  join promocao_sos c 
    on c.cd_promocao_sos  = b.cd_promocao_sos
left outer join integracao_sap s
	on  s.cd_empresa = 1000
	and s.cd_tabela  = 'FILIAL'
    and s.cd_chave_legado = cast(b.cd_filial as varchar)
inner join produto_geral d 
    on d.cd_produto  = b.cd_produto
inner join promocao_sos_estoque_minimo c1   
	on	 c1.cd_promocao_sos  = c.cd_promocao_sos 
	and c1.cd_produto = d.cd_produto
	and c1.cd_filial  = cast(b.cd_filial as int )
where  b.id_tipo_nf = 'PRO'
and    b.dh_exportacao is not null 
and    b.id_situacao_docto    = 'C'
and d.cd_produto_sap is not null
and    ( b.cd_tipo_documento = 'PLA' Or (b.cd_tipo_documento = 'PRO' and c.cd_promocao_sap  is not null ) )

union 

select  0 as cd_promocao,
       '' as cd_promocao_sap,
       a.id_tipo_nf as id_tipo,     
       a.dh_documento  as dh_inicio_vigencia,
       a.dh_estornado_sap  as dh_termino_vigencia,
       s.cd_chave_sap as id_filial_sap,
       c.cd_produto_sap,      
       a.nr_lancamento as qt_estoque_atual,      
       coalesce(a.de_erro, '') as de_motivo_est_base,
	  RTRIM(substring(a.nr_titulo, 5, 6)) as nr_matricula_alteracao,
       a.dh_documento,
		'' as dh_item_termino_vigencia,
		a.nr_atualizacao, 
		case when a.cd_filial=534 then 'M' else 'L' end as id_alteracao,
		0,
		a.cd_produto
from   log_exportacao_sap a
inner  join resumo_reposicao_estoque b 
    on  a.cd_produto = b.cd_produto
    and a.cd_filial = b.cd_filial 
inner join produto_geral c 
    on c.cd_produto  = a.cd_produto
left outer join integracao_sap s
	on  s.cd_empresa = 1000
	and s.cd_tabela  = 'FILIAL'
    and s.cd_chave_legado = cast(a.cd_filial as varchar)
where  a.id_tipo_nf = 'ESB'
and    a.dh_exportacao is not null 
and    a.id_situacao_docto  	= 'C'
and c.cd_produto_sap is not null

"  sort="id_tipo A id_filial_sap A " )
