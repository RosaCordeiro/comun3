table(column=(type=long updatewhereclause=yes name=cd_promocao dbname="cd_promocao" )
 column=(type=char(60) updatewhereclause=yes name=cd_promocao_sap dbname="cd_promocao_sap" )
 column=(type=long updatewhereclause=yes name=cd_tipo_exportacao dbname="log_exportacao.cd_tipo_exportacao" dbalias="le.cd_tipo_exportacao" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio_vigencia dbname="dh_inicio_vigencia" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_vigencia dbname="dh_termino_vigencia" )
 column=(type=char(40) updatewhereclause=yes name=id_filial_sap dbname="integracao_sap.id_filial_sap" dbalias="isap.id_filial_sap" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="pg.cd_produto_sap" )
 column=(type=long updatewhereclause=yes name=qt_estoque_atual dbname="log_exportacao.qt_estoque_atual" dbalias="le.qt_estoque_atual" )
 column=(type=char(60) updatewhereclause=yes name=de_motivo dbname="log_exportacao.de_motivo_est_base" dbalias="le.de_motivo_est_base" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_alteracao dbname="nr_matricula_alteracao" )
 column=(type=datetime updatewhereclause=yes name=dh_documento dbname="log_exportacao.dh_documento" dbalias="le.dh_documento" )
 column=(type=date updatewhereclause=yes name=dh_item_termino_vigencia dbname="dh_item_termino_vigencia" )
 column=(type=char(32) updatewhereclause=yes name=nr_exportacao dbname="log_exportacao.nr_exportacao" dbalias="le.nr_exportacao" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao dbname="id_alteracao" )
 column=(type=long updatewhereclause=yes name=qt_estoque_minimo_matriz dbname="qt_estoque_minimo_matriz" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="log_exportacao.cd_produto" dbalias="le.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=id_tipo_promocao dbname="log_exportacao.id_tipo_promocao" dbalias="le.id_tipo_promocao" )
 retrieve="SELECT
	CASE WHEN le.cd_varchar5 = 'P' 
		THEN le.cd_integer4  
		ELSE 0 
	END AS cd_promocao,
	CASE WHEN le.cd_varchar5 <> 'P' 
		THEN le.cd_varchar4
		ELSE '' 
	END AS cd_promocao_sap,
	le.cd_tipo_exportacao,
	COALESCE(ps.dh_inicio, CAST('2000-01-01' AS datetime)) AS dh_inicio_vigencia,
	COALESCE(ps.dh_termino, GetDate()) AS dh_termino_vigencia,
	isap.cd_chave_sap AS id_filial_sap,
	pg.cd_produto_sap,
	le.cd_integer1 AS qt_estoque_atual,
	le.cd_varchar3 AS de_motivo_est_base,
	RTRIM(substring(le.cd_varchar2, 5, 6)) AS nr_matricula_alteracao,
	le.dh_inclusao AS dh_documento,
	COALESCE(ps.dh_termino, CAST(getdate() AS date)) AS dh_item_termino_vigencia,
	le.nr_exportacao,
	CASE WHEN le.cd_integer2 = 534 
		THEN 'M' 
		ELSE 'L' 
	END AS id_alteracao,
	COALESCE(le.cd_integer5, 0) AS qt_estoque_minimo_matriz,
	le.cd_integer3 AS cd_produto,
	le.cd_varchar1 AS id_tipo_promocao
FROM 
	log_exportacao le
LEFT JOIN 
	promocao_sos ps
	ON ps.cd_promocao_sos  = le.cd_integer4 
LEFT JOIN 
	promocao_sos_estoque_minimo psem 
	ON psem.cd_promocao_sos  = ps.cd_promocao_sos 
	AND psem.cd_produto = le.cd_integer3
	AND psem.cd_filial  = le.cd_integer2
LEFT JOIN 
	integracao_sap isap
	ON isap.cd_empresa = 1000
	AND isap.cd_tabela  = 'FILIAL'
   AND isap.cd_chave_legado = cast(le.cd_integer2 as varchar)
INNER JOIN 
	produto_geral pg
   ON pg.cd_produto  = le.cd_integer3
WHERE
	le.cd_tipo_exportacao = 3
	AND le.id_situacao_exportacao	= 'C'"  sort="id_filial_sap A " )
