table(column=(type=char(32) updatewhereclause=yes name=nr_exportacao dbname="log_exportacao.nr_exportacao" dbalias="le.nr_exportacao" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="pg.cd_produto_sap" )
 column=(type=char(40) updatewhereclause=yes name=cd_filial_sap dbname="integracao_sap.cd_filial_sap" dbalias="isap.cd_filial_sap" )
 column=(type=long updatewhereclause=yes name=estoque_base dbname="log_exportacao.estoque_base" dbalias="le.estoque_base" )
 column=(type=date updatewhereclause=yes name=dt_documento dbname="dt_documento" )
 column=(type=time updatewhereclause=yes name=hora_doc dbname="hora_doc" )
 column=(type=datetime updatewhereclause=yes name=dh_documento dbname="log_exportacao.dh_documento" dbalias="le.dh_documento" )
 column=(type=char(1) updatewhereclause=yes name=curva dbname="resumo_reposicao_estoque.curva" dbalias="rre.curva" )
 column=(type=long updatewhereclause=yes name=nr_dias_cobertura dbname="nr_dias_cobertura" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="pg.cd_produto" )
 retrieve="SELECT
	le.nr_exportacao, 
	pg.cd_produto_sap,   
	isap.cd_chave_sap as cd_filial_sap,
	le.cd_integer1 as estoque_base,               
	cast(le.cd_datetime1 as date) as dt_documento,               
	cast(le.cd_datetime1 as time) as hora_doc, 
	le.cd_datetime1 as dh_documento,              
	rre.cd_classe_reposicao as curva,
	Coalesce(le.cd_integer4, 0) as nr_dias_cobertura,
	pg.cd_produto
FROM 
	log_exportacao le
LEFT JOIN
	resumo_reposicao_estoque rre ON le.cd_integer3 = rre.cd_produto 
										 AND le.cd_integer2 = rre.cd_filial
INNER JOIN 
	produto_geral pg ON pg.cd_produto  = le.cd_integer3
INNER JOIN 
	integracao_sap isap ON isap.cd_empresa = 1000 
							 AND isap.cd_tabela = 'FILIAL'
	    					 AND isap.cd_chave_legado = cast(le.cd_integer2 as varchar)
INNER JOIN
	parametro_reposicao_estoque pre ON pre.cd_filial = le.cd_integer2
											 AND pre.id_tipo_reposicao = 'E'
WHERE
	le.cd_tipo_exportacao = 2 
	AND le.id_situacao_exportacao	= 'C'
	AND pre.dh_termino_calculo is not null" )
