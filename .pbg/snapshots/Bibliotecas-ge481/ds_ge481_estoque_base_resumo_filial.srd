table(column=(type=char(32) update=yes updatewhereclause=yes key=yes name=nr_exportacao dbname="log_exportacao.nr_exportacao" dbalias="le.nr_exportacao" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="log_exportacao.cd_filial" dbalias="le.cd_filial" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="log_exportacao.cd_produto" dbalias="le.cd_produto" )
 column=(type=long update=yes updatewhereclause=yes name=qt_estoque_base dbname="log_exportacao.qt_estoque_base" dbalias="le.qt_estoque_base" )
 column=(type=long update=yes updatewhereclause=yes name=empresa dbname="log_exportacao.empresa" dbalias="le.empresa" )
 column=(type=char(60) updatewhereclause=yes name=tp_estoque_base dbname="log_exportacao.tp_estoque_base" dbalias="le.tp_estoque_base" )
 retrieve="SELECT 
	le.nr_exportacao,
	le.cd_integer1 as cd_filial,
	le.cd_integer2 as cd_produto,
	le.cd_integer3 as qt_estoque_base,
	le.cd_empresa as empresa,
	le.cd_varchar1 as tp_estoque_base
FROM
	log_exportacao le
WHERE
	le.cd_tipo_exportacao			= 5
	and le.id_situacao_exportacao	= 'C'
ORDER BY
	le.dh_inclusao ASC" update="log_exportacao" updatewhere=1 updatekeyinplace=no )
