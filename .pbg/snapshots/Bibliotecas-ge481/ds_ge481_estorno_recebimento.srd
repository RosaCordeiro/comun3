table(column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="log_exportacao_sap.nr_atualizacao" dbalias="lo.nr_atualizacao" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="log_exportacao_sap.nr_nf" dbalias="lo.nr_nf" )
 column=(type=char(50) updatewhereclause=yes name=cd_chave_interface dbname="log_exportacao_sap.cd_chave_interface" dbalias="lo.cd_chave_interface" )
 column=(type=char(20) updatewhereclause=yes name=cd_fornecedor_sap dbname="fornecedor.cd_fornecedor_sap" dbalias="f.cd_fornecedor_sap" )
 column=(type=datetime updatewhereclause=yes name=dh_documento dbname="log_exportacao_sap.dh_documento" dbalias="lo.dh_documento" )
 retrieve="select lo.nr_atualizacao,
		lo.nr_nf,
		lo.cd_chave_interface,
		f.cd_fornecedor_sap,
        lo.dh_documento
From log_exportacao_sap lo
Inner Join fornecedor f 
	On f.cd_fornecedor = lo.cd_fornecedor 
Where lo.id_tipo_nf = 'WMS'
and lo.id_status_integracao = 'C'
and lo.cd_tipo_documento = 'WMS'" )
