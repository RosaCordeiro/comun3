table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" dbalias="fl.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=cd_filial_sap dbname="integracao_sap.cd_filial_sap" dbalias="i.cd_filial_sap" )
 retrieve="select fl.cd_filial, i.cd_chave_sap as cd_filial_sap
from filial fl
		inner join integracao_sap i on (i.cd_tabela = 'FILIAL'
	                             and i.cd_chave_legado = cast(fl.cd_filial as varchar) )
where Exists (Select 1
					from parametro_loja pl
					Where pl.cd_filial = fl.cd_filial
					and pl.cd_parametro = 'ID_FILIAL_RETAGUARDA_SAP'
					and pl.vl_parametro = 'N')
and Exists (Select 1
					from parametro_loja pl
					Where pl.cd_filial = fl.cd_filial
					and pl.cd_parametro = 'ID_ADM_FILIAL_SAP'
					and pl.vl_parametro = 'S') 
and fl.cd_filial > 99563

union

select fl.cd_filial, i.cd_chave_sap as cd_filial_sap
from filial fl
		inner join integracao_sap i on (i.cd_tabela = 'FILIAL'
	                             and i.cd_chave_legado = cast(fl.cd_filial as varchar) )
where fl.cd_filial = (CASE WHEN (select dbo.inicio_operacao_cd_sap()) = 'S' THEN 534 ELSE 0 END)

" )
