table(column=(type=decimal(0) update=yes updatewhereclause=yes name=nr_atualizacao dbname="log_exportacao_sap.nr_atualizacao" dbalias="ls.nr_atualizacao" )
 column=(type=char(40) update=yes updatewhereclause=yes name=cd_chave dbname="log_exportacao_sap.cd_chave" dbalias="ls.cd_chave" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="log_exportacao_sap.cd_filial" dbalias="ls.cd_filial" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="log_exportacao_sap.cd_produto" dbalias="ls.cd_produto" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_documento dbname="log_exportacao_sap.dh_documento" dbalias="ls.dh_documento" )
 column=(type=long update=yes updatewhereclause=yes name=nr_lancamento dbname="log_exportacao_sap.nr_lancamento" dbalias="ls.nr_lancamento" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="pg.cd_produto_sap" )
 column=(type=char(40) updatewhereclause=yes name=cd_filial_sap dbname="cd_filial_sap" )
 retrieve="select ls.nr_atualizacao, ls.cd_chave, ls.cd_filial, ls.cd_produto, ls.dh_documento, ls.nr_lancamento, pg.cd_produto_sap,
	(select iss.cd_chave_sap from integracao_sap iss where iss.cd_tabela = 'FILIAL' and iss.cd_chave_legado = convert(varchar,ls.cd_filial)) as cd_filial_sap
from log_exportacao_sap ls
	inner join produto_geral pg on (pg.cd_produto = ls.cd_produto)
where ls.id_tipo_nf = 'MRP'
and ls.id_situacao_docto = 'C'"  sort="nr_atualizacao A " )
htmltable(border="1" )
htmlgen(clientevents="1" clientvalidation="1" clientcomputedfields="1" clientformatting="0" clientscriptable="0" generatejavascript="1" encodeselflinkargs="1" netscapelayers="0" pagingmethod=0 generatedddwframes="1" )
xhtmlgen() cssgen(sessionspecific="0" )
xmlgen(inline="0" )
xsltgen()
jsgen()
export.xml(headgroups="1" includewhitespace="0" metadatatype=0 savemetadata=0 )
import.xml()
export.pdf(method=0 distill.custompostscript="0" xslfop.print="0" )
