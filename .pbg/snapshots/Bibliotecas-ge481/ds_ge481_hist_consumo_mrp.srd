table(column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="g.cd_produto_sap" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="g.cd_produto" )
 column=(type=datetime updatewhereclause=yes name=dh_resumo dbname="resumo_movto_estq_prd.dh_resumo" dbalias="r.dh_resumo" )
 column=(type=long updatewhereclause=yes name=qt_venda dbname="qt_venda" )
 retrieve="select	g.cd_produto_sap, g.cd_produto,
       	r.dh_resumo as dh_resumo,
 		(CASE WHEN substring(g.cd_subcategoria, 1,1) <> '5' THEN r.qt_venda - r.qt_devolucao_venda ELSE qt_transf_saida END) qt_venda
from resumo_movto_estq_prd r
    inner join produto_geral g on g.cd_produto = r.cd_produto
    inner join resumo_reposicao_estoque re on (re.cd_produto = r.cd_produto
                                    	and re.cd_filial = r.cd_filial)
where r.cd_filial = :pl_Cd_filial
	and re.id_tipo_reposicao = 'E'
	and r.dh_resumo >= :pdt_inicio_E 
	and r.dh_resumo <= :pdt_termino_E
	and (CASE WHEN substring(g.cd_subcategoria, 1,1) <> '5' THEN  r.qt_venda - r.qt_devolucao_venda ELSE qt_transf_saida END) > 0
	and ( r.dh_exportacao_sap is null )
	and r.cd_produto = 181
	and g.cd_produto_sap is not null

UNION ALL

select	g.cd_produto_sap, g.cd_produto,
        	r.dh_resumo as dh_resumo,
		(CASE WHEN substring(g.cd_subcategoria, 1,1) <> '5' THEN r.qt_venda - r.qt_devolucao_venda ELSE qt_transf_saida END) qt_venda
from resumo_movto_estq_prd r
    inner join produto_geral g on g.cd_produto = r.cd_produto
    inner join resumo_reposicao_estoque re on (re.cd_produto = r.cd_produto
                                    	and re.cd_filial = r.cd_filial)
where r.cd_filial = :pl_Cd_filial
	and re.id_tipo_reposicao = 'S'
	and r.dh_resumo >= :pdt_inicio_S
	and r.dh_resumo <= :pdt_termino_S
	and (CASE WHEN substring(g.cd_subcategoria, 1,1) <> '5' THEN  r.qt_venda - r.qt_devolucao_venda ELSE qt_transf_saida END) > 0
	and ( r.dh_exportacao_sap is null )
	and r.cd_produto = 181
	and g.cd_produto_sap is not null
order by g.cd_produto_sap asc, r.dh_resumo desc" arguments=(("pl_Cd_filial", number),("pdt_inicio_E", date),("pdt_termino_E", date),("pdt_inicio_S", date),("pdt_termino_S", date)) )
