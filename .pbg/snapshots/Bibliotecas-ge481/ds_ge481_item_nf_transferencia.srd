table(column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="item_nf_transferencia.cd_produto" )
 column=(type=long update=yes updatewhereclause=yes name=cd_natureza_operacao dbname="item_nf_transferencia.cd_natureza_operacao" )
 column=(type=long update=yes updatewhereclause=yes name=qt_transferida dbname="item_nf_transferencia.qt_transferida" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="qt_recebida" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" )
 column=(type=char(1) updatewhereclause=yes name=id_produto_vencido dbname="nf_transferencia.id_produto_vencido" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_transferencia dbname="id_tipo_transferencia" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_bc_icms_st dbname="vl_bc_icms_st" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_icms_st dbname="vl_icms_st" )
 retrieve="SELECT i.cd_produto,   
			i.cd_natureza_operacao,
			i.qt_transferida,
			isnull(i.qt_recebida, 0) as qt_recebida,
			g.de_produto + ' : ' + g.de_apresentacao_estoque as de_produto,
			g.cd_grupo_psico,
			n.id_produto_vencido,
			g.vl_fator_conversao,
			( CASE n.id_produto_vencido
					WHEN 'S' then '1'
					ELSE '0'
			END ) as id_tipo_transferencia,
			
			case when coalesce(i.vl_bc_icms_st, 0) = 0 then
				case when coalesce(i.vl_bc_icms_st_retido, 0) = 0 then
					case when coalesce(i.vl_bc_icms_st_origem, 0) = 0 then
						0
					else
						i.vl_bc_icms_st_origem
					end
				else
					i.vl_bc_icms_st_retido
				end
			else
				i.vl_bc_icms_st
			end as vl_bc_icms_st,

			case when coalesce(i.vl_icms_st, 0) = 0 then
				case when coalesce(i.vl_icms_st_retido, 0) = 0 then
					case when coalesce(i.vl_icms_st_origem, 0) = 0 then
						0
					else
						i.vl_icms_st_origem
					end
				else
					i.vl_icms_st_retido
				end
			else
				i.vl_icms_st
			end as vl_icms_st
FROM item_nf_transferencia i      
inner join nf_transferencia n on n.cd_filial_origem = i.cd_filial_origem
										and n.nr_nf = i.nr_nf 
										and n.de_especie = i.de_especie
										and n.de_serie = i.de_serie
inner join produto_geral g on g.cd_produto = i.cd_produto
WHERE  i.cd_filial_origem 	= :cd_filial_origem
	AND i.nr_nf 				= :nr_nf
	AND i.de_especie 		= :de_especie 
	AND i.de_serie 			= :de_serie" arguments=(("cd_filial_origem", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
