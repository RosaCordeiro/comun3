table(column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_transferencia_lote.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_lote dbname="item_nf_transferencia_lote.qt_lote" )
 column=(type=char(10) updatewhereclause=yes name=nr_lote dbname="item_nf_transferencia_lote.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="item_nf_transferencia_lote.dh_validade" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco_wms dbname="tipo_nf_transferencia.cd_endereco_wms" )
 column=(type=char(1) updatewhereclause=yes name=id_protocolo dbname="tipo_nf_transferencia.id_protocolo" )
 retrieve="SELECT i.cd_produto,   
			i.qt_lote,
			i.nr_lote,
			i.dh_validade,
			g.de_produto + ' : ' + g.de_apresentacao_estoque as de_produto,
			g.cd_grupo_psico,
			t.cd_endereco_wms,
         t.id_protocolo
FROM item_nf_transferencia_lote i      
inner join produto_geral g on g.cd_produto = i.cd_produto
left join tipo_nf_transferencia t on t.cd_tipo = i.cd_tipo_transferencia
WHERE  i.cd_filial_origem 	= :cd_filial_origem
	AND i.nr_nf 				= :nr_nf
	AND i.de_especie 		= :de_especie 
	AND i.de_serie 			= :de_serie
	and i.cd_natureza_operacao = :cd_natureza_operacao
	and i.cd_produto		= :cd_produto" arguments=(("cd_filial_origem", number),("nr_nf", number),("de_especie", string),("de_serie", string),("cd_natureza_operacao", number),("cd_produto", number)) )
