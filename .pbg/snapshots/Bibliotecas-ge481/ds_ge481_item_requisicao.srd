table(column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long update=yes updatewhereclause=yes name=nr_pedido_distribuidora dbname="nr_pedido_distribuidora" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=long update=yes updatewhereclause=yes name=nr_sequencial dbname="nr_sequencial" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=nr_requisicao dbname="nr_requisicao" )
 column=(type=long updatewhereclause=yes name=nr_item_requisacao dbname="nr_item_requisacao" )
 column=(type=long update=yes updatewhereclause=yes name=qt_requisicao dbname="qt_requisicao" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="g.cd_produto_sap" )
 retrieve="  SELECT p.cd_filial,   
         p.nr_pedido_distribuidora,   
         p.cd_produto,   
         p.nr_sequencial,   
         p.nr_requisicao,   
         p.nr_item nr_item_requisacao,   
         p.qt_requisicao ,
		g.cd_produto_sap 
    FROM pedido_distrib_prd_item_req  p (index idx_pedido)
inner join produto_geral g
	on g.cd_produto = p.cd_produto
   WHERE p.cd_filial = :filial  
	  AND  p.nr_pedido_distribuidora = :pedido  
	  AND  p.cd_produto = :produto  
	  AND  p.nr_sequencial = :sequencial
" arguments=(("filial", number),("pedido", number),("produto", number),("sequencial", number)) )
