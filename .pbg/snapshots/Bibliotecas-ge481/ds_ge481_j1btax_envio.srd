 column=(type=char(1) updatewhereclause=yes name=regra dbname="regra" )
 retrieve="SELECT
	les.nr_atualizacao,
	lej.nr_controle,
	lej.mandt,
	leji.nr_item,
	leji.dh_exportacao,
	leji.country,
	leji.gruop,
	leji.land1,
	leji.shipfrom,
	leji.shipto,
	leji.taxjurcode,
	leji.value,
	leji.value2,
	leji.value3,
	leji.stgrp,
	leji.validfrom,
	leji.validto,
	leji.sur_type,
	leji.rate,
	leji.price,
	leji.base,
	leji.exempt,
	leji.amount,
	leji.factor,
	leji.unit,
	leji.basered1,
	leji.basered2,
	leji.icmsbaser,
	leji.minprice,
	leji.waers,
	leji.minfact,
	leji.surchin,
	leji.fcp_basered1,
	leji.fcp_basered2,
	leji.taxlaw,
	leji.conven100,
	leji.specf_rate,
	leji.specf_base,
	leji.specf_resale,
	leji.partilha_exempt,
	leji.taxrelloc,
	leji.withhold,
	leji.minval_wt,
	leji.rate4dec,
	leji.amount4dec,
	leji.factor4dec,
	leji.minprice_amount,
	leji.minprice_currency,
	leji.minprice_quantity,
	leji.minprice_uom,
	leji.minprice_taxlaw,
	CASE WHEN leji.regra = 'ENCERRAMENTO' THEN 'X' ELSE '' END AS regra
FROM 
	log_exportacao_j1btax lej
	inner join log_exportacao_j1btax_item leji
		on leji.nr_controle = lej.nr_controle
	inner join log_exportacao_sap les
		on les.cd_empresa = 1000
		and les.id_tipo_log = 99
		and les.cd_chave = cast(lej.nr_controle as varchar)
WHERE
	leji.dh_exportacao is null
	AND leji.id_aprovado = 'S'" )
