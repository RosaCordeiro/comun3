table(column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="log_exportacao_sap.nr_atualizacao" dbalias="l.nr_atualizacao" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_diversa.dh_movimentacao_caixa" dbalias="n.dh_movimentacao_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_diversa.dh_emissao" dbalias="n.dh_emissao" )
 column=(type=long updatewhereclause=yes name=empresa dbname="log_exportacao_sap.empresa" dbalias="l.empresa" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="nf_diversa.cd_natureza_operacao" dbalias="n.cd_natureza_operacao" )
 column=(type=char(487) updatewhereclause=yes name=dados_adicionais dbname="dados_adicionais" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_diversa_nfe.de_chave_acesso" dbalias="nfe.de_chave_acesso" )
 column=(type=char(15) updatewhereclause=yes name=nr_protocolo_envio dbname="nf_diversa_nfe.nr_protocolo_envio" dbalias="nfe.nr_protocolo_envio" )
 column=(type=char(4) updatewhereclause=yes name=cd_motivo_sap dbname="motivo_ajuste.cd_motivo_sap" dbalias="ma.cd_motivo_sap" )
 column=(type=char(100) updatewhereclause=yes name=de_comentario_ajuste dbname="nf_diversa.de_comentario_ajuste" dbalias="n.de_comentario_ajuste" )
 column=(type=long updatewhereclause=yes name=cd_perfil_nf dbname="nf_diversa.cd_perfil_nf" dbalias="n.cd_perfil_nf" )
 column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="nf_diversa.cd_filial_origem" dbalias="n.cd_filial_origem" )
 retrieve="select 
	l.nr_atualizacao,
	n.dh_movimentacao_caixa,
	n.dh_emissao,
	l.cd_empresa as empresa,
	n.cd_natureza_operacao,
	n.de_dados_adicionais_1 + ' ' + n.de_dados_adicionais_2 + ' ' + n.de_dados_adicionais_3 + ' ' + n.de_dados_adicionais_4 + ' ' + n.de_dados_adicionais_5 + ' ' + n.de_dados_adicionais_6 + ' ' + n.de_dados_adicionais_7 + ' ' + n.de_dados_adicionais_8 as dados_adicionais,
	nfe.de_chave_acesso,
	nfe.nr_protocolo_envio,
	ma.cd_motivo_sap,
	n.de_comentario_ajuste,
	n.cd_perfil_nf,
	n.cd_filial_origem
from 
	log_exportacao_sap l
inner join 
	nf_diversa n 
	on l.nr_nf = n.nr_nf
	and l.cd_filial = n.cd_filial_origem
	and l.de_serie = n.de_serie
	and l.de_especie = n.de_especie
left outer join 
	nf_diversa_nfe nfe 
	on nfe.nr_nf = n.nr_nf
	and nfe.cd_filial_origem = n.cd_filial_origem
	and nfe.de_serie = n.de_serie
	and nfe.de_especie = n.de_especie
left outer join 
	motivo_ajuste ma 
	on ma.cd_motivo_ajuste = n.cd_motivo_ajuste
where 
	l.id_tipo_nf = 'IVL'
	and l.id_status_integracao in ('C', 'E')
	and l.cd_tipo_documento = 'IVL'" )
