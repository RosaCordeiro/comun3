table(column=(type=decimal(0) update=yes updatewhereclause=yes key=yes name=nr_atualizacao dbname="log_exportacao_sap.nr_atualizacao" )
 column=(type=char(3) update=yes updatewhereclause=yes name=cd_tipo_documento dbname="log_exportacao_sap.cd_tipo_documento" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="log_exportacao_sap.cd_filial" )
 column=(type=long update=yes updatewhereclause=yes name=nr_nf dbname="log_exportacao_sap.nr_nf" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_serie dbname="log_exportacao_sap.de_serie" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_especie dbname="log_exportacao_sap.de_especie" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_documento dbname="log_exportacao_sap.dh_documento" )
 column=(type=long update=yes updatewhereclause=yes name=ano_documento dbname="" )
 retrieve="	select l.nr_atualizacao,
		    l.cd_tipo_documento,
		    l.cd_filial,
			 l.nr_nf,
			 l.de_serie,
			 l.de_especie,
			 l.dh_documento,
			 DatePart(year, cast(dh_documento as date))
	  from log_exportacao_sap l
	 where l.id_tipo_nf 				= 'IVX'
    	and l.id_status_integracao = 'C'
    	and l.cd_tipo_documento 	= 'IVX'" update="log_exportacao_sap" updatewhere=1 updatekeyinplace=no )
