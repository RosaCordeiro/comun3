table(column=(type=char(20) updatewhereclause=yes name=material dbname="produto_geral.material" dbalias="g.material" )
 column=(type=char(3) updatewhereclause=yes name=unidade_de_medida dbname="produto_geral.unidade_de_medida" dbalias="g.unidade_de_medida" )
 column=(type=long updatewhereclause=yes name=quantidade dbname="item_nf_diversa.quantidade" dbalias="i.quantidade" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="log_exportacao_sap.cd_filial" dbalias="l.cd_filial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_diversa.vl_preco_unitario" dbalias="i.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="item_nf_diversa.vl_icms" dbalias="i.vl_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="item_nf_diversa.pc_icms" dbalias="i.pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms dbname="item_nf_diversa.vl_bc_icms" dbalias="i.vl_bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_ipi dbname="item_nf_diversa.vl_ipi" dbalias="i.vl_ipi" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_ipi dbname="item_nf_diversa.pc_ipi" dbalias="i.pc_ipi" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_ipi dbname="item_nf_diversa.vl_bc_ipi" dbalias="i.vl_bc_ipi" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_tributacao dbname="item_nf_diversa.cd_cst_tributacao" dbalias="i.cd_cst_tributacao" )
 retrieve="select g.cd_produto_sap as material,
		 g.cd_unidade_medida_venda as unidade_de_medida,
		 i.qt_item as quantidade,
		 l.cd_filial,
		 i.vl_preco_unitario,
		 i.vl_icms, 
		 i.pc_icms,
	    i.vl_bc_icms,
		 i.vl_ipi,
		 i.pc_ipi,
		 i.vl_bc_ipi,
		 i.cd_cst_tributacao
from log_exportacao_sap l inner join nf_diversa n on l.nr_nf 					= n.nr_nf and
																	  l.cd_filial			 	= n.cd_filial_origem and
																	  l.de_serie 				= n.de_serie and
																	  l.de_especie 			= n.de_especie
								  inner join item_nf_diversa i on i.nr_nf 				= n.nr_nf and
																		    i.cd_filial_origem = n.cd_filial_origem and
																		    i.de_serie 			= n.de_serie and
																		    i.de_especie 		= n.de_especie
inner join produto_geral g on g.cd_produto = i.cd_produto
where l.nr_atualizacao 		= :al_nr_atualizacao" arguments=(("al_nr_atualizacao", number)) )
