table(column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="distrib_produto_melhor_compra.cd_produto" dbalias="d.cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="g.cd_produto_sap" )
 column=(type=char(2) update=yes updatewhereclause=yes name=cd_unidade_federacao dbname="distrib_produto_melhor_compra.cd_unidade_federacao" dbalias="d.cd_unidade_federacao" )
 column=(type=char(9) update=yes updatewhereclause=yes name=cd_distribuidora dbname="distrib_produto_melhor_compra.cd_distribuidora" dbalias="d.cd_distribuidora" )
 column=(type=char(20) updatewhereclause=yes name=cd_fornecedor_sap dbname="fornecedor.cd_fornecedor_sap" dbalias="f.cd_fornecedor_sap" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco_atual dbname="distrib_produto_melhor_compra.vl_preco_atual" dbalias="d.vl_preco_atual" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto_atual dbname="distrib_produto_melhor_compra.pc_desconto_atual" dbalias="d.pc_desconto_atual" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto_financeiro dbname="distrib_produto_melhor_compra.pc_desconto_financeiro" dbalias="d.pc_desconto_financeiro" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto_midia dbname="distrib_produto_melhor_compra.pc_desconto_midia" dbalias="d.pc_desconto_midia" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_repasse_icms dbname="distrib_produto_melhor_compra.vl_repasse_icms" dbalias="d.vl_repasse_icms" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_icms_st dbname="distrib_produto_melhor_compra.vl_icms_st" dbalias="d.vl_icms_st" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_compra dbname="distrib_produto_melhor_compra.vl_compra" dbalias="d.vl_compra" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_melhor_compra dbname="distrib_produto_melhor_compra.vl_melhor_compra" dbalias="d.vl_melhor_compra" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_juros_decrescimo_dist dbname="distrib_produto_melhor_compra.vl_juros_decrescimo_dist" dbalias="d.vl_juros_decrescimo_dist" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_atualizacao dbname="distrib_produto_melhor_compra.dh_atualizacao" dbalias="d.dh_atualizacao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_envio_sap dbname="distrib_produto_melhor_compra.dh_envio_sap" dbalias="d.dh_envio_sap" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_repasse_icms dbname="pc_repasse_icms" )
 column=(type=long updatewhereclause=yes name=nr_dias_pagamento dbname="nr_dias_pagamento" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_acordo_sellin dbname="pc_desconto_acordo_sellin" )
 retrieve="  SELECT d.cd_produto,   
		g.cd_produto_sap,
         d.cd_unidade_federacao,   
         d.cd_distribuidora,   
		f.cd_fornecedor_sap,
         d.vl_preco_atual,   
         d.pc_desconto_atual,   
         d.pc_desconto_financeiro,   
         d.pc_desconto_midia,   
         d.vl_repasse_icms,   
         d.vl_icms_st,   
         d.vl_compra,   
         d.vl_melhor_compra,   
         d.vl_juros_decrescimo_dist,   
         d.dh_atualizacao,   
         d.dh_envio_sap,
		coalesce(dp.pc_repasse_icms  , 0) pc_repasse_icms,
		coalesce(dp.nr_dias_pagamento, 0) nr_dias_pagamento,
		coalesce(d.pc_desconto_acordo_sellin, 0) pc_desconto_acordo_sellin
    FROM distrib_produto_melhor_compra  d 
inner join distribuidora_produto dp
	on dp.cd_produto = d.cd_produto
	and dp.cd_distribuidora = d.cd_distribuidora
	and dp.cd_unidade_federacao  = d.cd_unidade_federacao
inner join produto_geral g
	on g.cd_produto = d.cd_produto
inner join fornecedor f
	on f.cd_fornecedor = d.cd_distribuidora
where g.cd_produto_sap is not null
	and d.dh_envio_sap is null
	and ltrim(g.cd_produto_sap) <> ''

union

 SELECT d.cd_produto,   
		g.cd_produto_sap,
         d.cd_unidade_federacao,   
         d.cd_distribuidora,   
		f.cd_fornecedor_sap,
         d.vl_preco_atual,   
         d.pc_desconto_atual,   
         d.pc_desconto_financeiro,   
         d.pc_desconto_midia,   
         d.vl_repasse_icms,   
         d.vl_icms_st,   
         d.vl_compra,   
         d.vl_melhor_compra,   
         d.vl_juros_decrescimo_dist,   
         d.dh_atualizacao,   
         d.dh_envio_sap,
		coalesce(dp.pc_repasse_icms  , 0) pc_repasse_icms,
		coalesce(dp.nr_dias_pagamento, 0) nr_dias_pagamento,
		coalesce(d.pc_desconto_acordo_sellin, 0) pc_desconto_acordo_sellin
    FROM distrib_produto_melhor_compra  d 
inner join distribuidora_produto dp
	on dp.cd_produto = d.cd_produto
	and dp.cd_distribuidora = d.cd_distribuidora
	and dp.cd_unidade_federacao  = d.cd_unidade_federacao
inner join produto_geral g
	on g.cd_produto = d.cd_produto
inner join fornecedor f
	on f.cd_fornecedor = d.cd_distribuidora
where g.cd_produto_sap is not null
	and d.dh_envio_sap is not null
    and d.dh_atualizacao > d.dh_envio_sap
	and ltrim(g.cd_produto_sap) <> ''" )
