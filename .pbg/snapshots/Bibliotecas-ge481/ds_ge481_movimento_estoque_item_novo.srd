table(column=(type=long updatewhereclause=yes name=cd_produto dbname="log_exportacao.cd_produto" dbalias="le.cd_produto" )
 column=(type=long updatewhereclause=yes name=quantidade dbname="log_exportacao.quantidade" dbalias="le.quantidade" )
 column=(type=char(60) updatewhereclause=yes name=centro dbname="centro" )
 column=(type=char(60) updatewhereclause=yes name=centro_de_custo dbname="centro_de_custo" )
 column=(type=char(60) updatewhereclause=yes name=deposito_saida dbname="log_exportacao.deposito_saida" dbalias="le.deposito_saida" )
 column=(type=char(60) updatewhereclause=yes name=deposito_entrada dbname="log_exportacao.deposito_entrada" dbalias="le.deposito_entrada" )
 retrieve="SELECT
	le.cd_integer1 as cd_produto,
	le.cd_integer2 as quantidade,
	COALESCE(lee.cd_varchar7, '') as centro,
	COALESCE(lee.cd_varchar6, '') as centro_de_custo,
	le.cd_varchar5 as deposito_saida,
	le.cd_varchar4 as deposito_entrada
FROM
	log_exportacao le
LEFT JOIN log_exportacao_extra lee 
	ON lee.nr_exportacao	= le.nr_exportacao 
WHERE
	le.nr_exportacao		= :as_nr_exportacao" arguments=(("as_nr_exportacao", string)) )
