table(column=(type=char(32) update=yes updatewhereclause=yes name=nr_exportacao dbname="nr_exportacao" )
 column=(type=datetime update=yes updatewhereclause=yes name=data_movimentacao dbname="data_movimentacao" )
 column=(type=datetime update=yes updatewhereclause=yes name=data_lancamento dbname="data_lancamento" )
 column=(type=char(60) update=yes updatewhereclause=yes name=direcao_movimento dbname="direcao_movimento" )
 column=(type=char(60) update=yes updatewhereclause=yes name=tipo_movimento dbname="tipo_movimento" )
 column=(type=long update=yes updatewhereclause=yes name=empresa dbname="empresa" )
 column=(type=char(60) updatewhereclause=yes name=cd_varchar3 dbname="cd_varchar3" )
 retrieve="SELECT 
	le.nr_exportacao,
	le.dh_inclusao as data_movimentacao, 
	le.dh_inclusao as data_lancamento, 
	cd_varchar2 as direcao_movimento,
	cd_varchar1 as tipo_movimento,
	le.cd_empresa as empresa,
	le.cd_varchar3
FROM
	log_exportacao le
WHERE
	le.cd_tipo_exportacao			= 4
	and le.id_situacao_exportacao	in ('C', 'E')
	and le.dh_inclusao >= cast(dateadd(DAY, -2, getdate()) as date)
	and le.cd_varchar3 is not null
	and le.cd_varchar3 <> ''" )
