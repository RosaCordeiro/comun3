table(column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="pg.cd_produto_sap" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_venda dbname="produto_geral.cd_unidade_medida_venda" dbalias="pg.cd_unidade_medida_venda" )
 column=(type=long updatewhereclause=yes name=qt_lote dbname="item_nf_diversa.qt_lote" dbalias="ind.qt_lote" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="item_nf_diversa.vl_custo_unitario" dbalias="ind.vl_custo_unitario" )
 column=(type=char(30) updatewhereclause=yes name=nr_lote dbname="nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_fabricacao dbname="dh_fabricacao" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="dh_validade" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="cd_filial_destino" )
 column=(type=char(487) updatewhereclause=yes name=dados_adicionais dbname="dados_adicionais" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="item_nf_diversa.nr_sequencial" dbalias="ind.nr_sequencial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms dbname="item_nf_diversa.vl_bc_icms" dbalias="ind.vl_bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="item_nf_diversa.pc_icms" dbalias="ind.pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="item_nf_diversa.vl_icms" dbalias="ind.vl_icms" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_tributacao dbname="item_nf_diversa.cd_cst_tributacao" dbalias="ind.cd_cst_tributacao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_st dbname="item_nf_diversa.pc_icms_st" dbalias="ind.pc_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="item_nf_diversa.vl_icms_st" dbalias="ind.vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_st dbname="item_nf_diversa.vl_bc_icms_st" dbalias="ind.vl_bc_icms_st" )
 column=(type=char(15) updatewhereclause=yes name=nr_cgc_cpf dbname="nf_diversa.nr_cgc_cpf" dbalias="nd.nr_cgc_cpf" )
 column=(type=long updatewhereclause=yes name=cd_perfil_nf dbname="nf_diversa.cd_perfil_nf" dbalias="nd.cd_perfil_nf" )
 retrieve="select pg.cd_produto_sap,
		 pg.cd_unidade_medida_venda,
		 ind.qt_item qt_lote,
		 ind.vl_preco_unitario vl_custo_unitario,
		 cast(null as varchar) nr_lote,
		 cast(null as datetime) dh_fabricacao,
		 cast(null as datetime) dh_validade,
		 cast(null as integer) cd_filial_destino,
		 nd.de_dados_adicionais_1 + ' ' + nd.de_dados_adicionais_2 + ' ' + nd.de_dados_adicionais_3 + ' ' + nd.de_dados_adicionais_4 + ' ' + nd.de_dados_adicionais_5 + ' ' + nd.de_dados_adicionais_6 + ' ' + nd.de_dados_adicionais_7 + ' ' + nd.de_dados_adicionais_8 as dados_adicionais,
		 ind.cd_item nr_sequencial,
		 ind.vl_bc_icms,
		 ind.pc_icms,
		 ind.vl_icms,
		 ind.cd_cst_tributacao,
		 ind.pc_icms_st,
		 ind.vl_icms_st,
		 ind.vl_bc_icms_st,
		 nd.nr_cgc_cpf nr_cgc_cpf,
		 nd.cd_perfil_nf
  from item_nf_diversa ind inner join nf_diversa nd on ind.nr_nf 					= nd.nr_nf and
																		 ind.cd_filial_origem	= nd.cd_filial_origem and
																		 ind.de_serie				= nd.de_serie and
																		 ind.de_especie			= nd.de_especie
									inner join produto_geral pg on pg.cd_produto = ind.cd_produto
 where ind.nr_nf 					= :anr_nf and
		 ind.cd_filial_origem	= :acd_filial_origem  and
		 ind.de_serie 				= :ade_serie  and
		 ind.de_especie 			= :ade_especie" arguments=(("acd_filial_origem", number),("anr_nf", number),("ade_serie", string),("ade_especie", string)) )
