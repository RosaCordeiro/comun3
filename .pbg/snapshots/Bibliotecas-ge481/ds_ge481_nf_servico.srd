table(column=(type=char(2) updatewhereclause=yes name=id_tipo dbname="id_tipo" )
 column=(type=char(20) updatewhereclause=yes name=cd_fornecedor_sap dbname="fornecedor.cd_fornecedor_sap" dbalias="f.cd_fornecedor_sap" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="log_exportacao_sap.nr_nf" dbalias="les.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="log_exportacao_sap.de_especie" dbalias="les.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="log_exportacao_sap.de_serie" dbalias="les.de_serie" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="log_exportacao_sap.cd_filial" dbalias="les.cd_filial" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="log_exportacao_sap.cd_fornecedor" dbalias="les.cd_fornecedor" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_compra_pendente.dh_emissao" dbalias="nc.dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_compra_pendente.dh_movimentacao_caixa" dbalias="nc.dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_compra_pendente.vl_total_nf" dbalias="nc.vl_total_nf" )
 column=(type=long updatewhereclause=yes name=nr_pedido_central dbname="nf_compra_pendente.nr_pedido_central" dbalias="nc.nr_pedido_central" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_registro dbname="nf_compra_pendente.nr_matricula_registro" dbalias="nc.nr_matricula_registro" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso_remessa dbname="nf_compra_pendente.de_chave_acesso_remessa" dbalias="nc.de_chave_acesso_remessa" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="log_exportacao_sap.nr_atualizacao" dbalias="les.nr_atualizacao" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_nf dbname="log_exportacao_sap.id_tipo_nf" dbalias="les.id_tipo_nf" )
 column=(type=char(40) updatewhereclause=yes name=cd_chave dbname="log_exportacao_sap.cd_chave" dbalias="les.cd_chave" )
 column=(type=char(10) updatewhereclause=yes name=nr_pedido_sap dbname="pedido_central.nr_pedido_sap" dbalias="pc.nr_pedido_sap" )
 retrieve="select '01' as id_tipo, 
		 f.cd_fornecedor_sap , 
		 les.nr_nf, 
		 les.de_especie, 
		 les.de_serie,
		 les.cd_filial,
		 les.cd_fornecedor,
		 nc.dh_emissao , 
		 nc.dh_movimentacao_caixa , 
		 nc.vl_total_nf , 
		 nc.nr_pedido as nr_pedido_central , 
		 nc.nr_matricula_registro , 
		 nc.de_chave_acesso_remessa,
		 les.nr_atualizacao,
		 les.id_tipo_nf,
		 les.cd_chave,
		pc.nr_pedido_sap
  from dbo.log_exportacao_sap les
 inner join fornecedor f 
	 on f.cd_fornecedor = les.cd_fornecedor 
  left outer join nf_compra_pendente nc 
	 on nc.nr_nf 			= les.nr_nf 
   and nc.cd_fornecedor = les.cd_fornecedor 
	and nc.cd_filial 		= les.cd_filial 
	and nc.de_especie 	= les.de_especie 
	and nc.de_serie 		= les.de_serie
  left outer join pedido_central pc 
	on pc.nr_pedido = nc.nr_pedido
 where id_tipo_nf 		in ('NFS')" )
