table(column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="nf_compra_pendente_produto.cd_natureza_operacao" dbalias="inc.cd_natureza_operacao" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="pg.cd_produto_sap" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="nf_compra_pendente_produto.qt_faturada" dbalias="inc.qt_faturada" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="nf_compra_pendente_produto.vl_preco_unitario" dbalias="inc.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="nf_compra_pendente_produto.pc_desconto" dbalias="inc.pc_desconto" )
 retrieve="select inc.cd_natureza_operacao, 
		 pg.cd_produto_sap, 
		 inc.qt_faturada, 
		 inc.vl_preco_unitario,
		 inc.pc_desconto
  from nf_compra_pendente_produto inc inner join produto_geral pg 
											 on pg.cd_produto = inc.cd_produto
 where inc.cd_filial			= :acd_filial
	and inc.nr_nf				= :anr_nf
	and inc.de_serie			= :ade_serie
	and inc.de_especie		= :ade_especie
	and inc.cd_fornecedor	= :acd_fornecedor" arguments=(("acd_filial", number),("anr_nf", number),("ade_serie", string),("ade_especie", string),("acd_fornecedor", string)) )
