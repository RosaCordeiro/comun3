table(column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="pg.cd_produto_sap" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_venda dbname="produto_geral.cd_unidade_medida_venda" dbalias="pg.cd_unidade_medida_venda" )
 column=(type=long updatewhereclause=yes name=qt_lote dbname="qt_lote" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="item_nf_transferencia.vl_custo_unitario" dbalias="int.vl_custo_unitario" )
 column=(type=char(10) updatewhereclause=yes name=nr_lote dbname="item_nf_transferencia_lote.nr_lote" dbalias="intl.nr_lote" )
 column=(type=date updatewhereclause=yes name=dh_fabricacao dbname="item_nf_transferencia_lote.dh_fabricacao" dbalias="intl.dh_fabricacao" )
 column=(type=date updatewhereclause=yes name=dh_validade dbname="item_nf_transferencia_lote.dh_validade" dbalias="intl.dh_validade" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="nf_transferencia.cd_filial_destino" dbalias="nt.cd_filial_destino" )
 column=(type=char(487) updatewhereclause=yes name=de_dados_adicionais dbname="nf_transferencia.de_dados_adicionais" dbalias="nt.de_dados_adicionais" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="item_nf_transferencia.nr_sequencial" dbalias="int.nr_sequencial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms dbname="item_nf_transferencia.vl_bc_icms" dbalias="int.vl_bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="item_nf_transferencia.pc_icms" dbalias="int.pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="item_nf_transferencia.vl_icms" dbalias="int.vl_icms" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_tributacao dbname="item_nf_transferencia.cd_cst_tributacao" dbalias="int.cd_cst_tributacao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_st dbname="item_nf_transferencia.pc_icms_st" dbalias="int.pc_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="item_nf_transferencia.vl_icms_st" dbalias="int.vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_st dbname="item_nf_transferencia.vl_bc_icms_st" dbalias="int.vl_bc_icms_st" )
 column=(type=char(15) updatewhereclause=yes name=nr_cgc_cpf dbname="nr_cgc_cpf" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="item_nf_transferencia.cd_natureza_operacao" dbalias="int.cd_natureza_operacao" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_pis dbname="item_nf_transferencia.cd_cst_pis" dbalias="int.cd_cst_pis" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_cofins dbname="item_nf_transferencia.cd_cst_cofins" dbalias="int.cd_cst_cofins" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_icms dbname="item_nf_transferencia.cd_cst_icms" dbalias="int.cd_cst_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario_nf dbname="item_nf_transferencia.vl_custo_unitario_nf" dbalias="int.vl_custo_unitario_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_fcp dbname="item_nf_transferencia.pc_fcp" dbalias="int.pc_fcp" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_fcp dbname="item_nf_transferencia.vl_fcp" dbalias="int.vl_fcp" )
 retrieve="select pg.cd_produto_sap,
		 pg.cd_unidade_medida_venda, 
		 coalesce(intl.qt_lote, int.qt_transferida) qt_lote,
		 int.vl_custo_gerencial vl_custo_unitario,
		 intl.nr_lote,
		 intl.dh_fabricacao,
		 intl.dh_validade,
		 nt.cd_filial_destino,
		 nt.de_dados_adicionais,
		 int.nr_sequencial,
		 int.vl_bc_icms,
		 int.pc_icms,
		 int.vl_icms,
		 int.cd_cst_tributacao,
		 int.pc_icms_st,
		 int.vl_icms_st,
		 int.vl_bc_icms_st,
		 '' nr_cgc_cpf,
		 int.cd_natureza_operacao,
		 int.cd_cst_pis,
		 int.cd_cst_cofins,
		 int.cd_cst_tributacao as cd_cst_icms,
		 int.vl_custo_unitario as vl_custo_unitario_nf,
		 int.pc_fcp,
		 int.vl_fcp
  from item_nf_transferencia int inner join nf_transferencia nt on int.nr_nf 					= nt.nr_nf and
																						 int.cd_filial_origem	= nt.cd_filial_origem and
																						 int.de_serie				= nt.de_serie and
																						 int.de_especie			= nt.de_especie
											inner join produto_geral pg on pg.cd_produto = int.cd_produto
											left  join item_nf_transferencia_lote intl on int.nr_nf = intl.nr_nf and
																										 int.cd_filial_origem		= intl.cd_filial_origem and
																										 int.de_serie					= intl.de_serie and
																										 int.de_especie				= intl.de_especie and
																										 int.cd_natureza_operacao	= intl.cd_natureza_operacao and
																										 int.cd_produto				= intl.cd_produto
 where int.nr_nf 					= :anr_nf and
		 int.cd_filial_origem	= :acd_filial_origem  and
		 int.de_serie 				= :ade_serie  and
		 int.de_especie 			= :ade_especie and
		 :aid_tipo_nf				= '156' and
		 (int.cd_filial_origem	<> 534 or
		 int.de_serie				<> '1')

union

select pg.cd_produto_sap,
		 Case When int.cd_filial_origem = 534 and pg.vl_fator_conversao > 1 then 'CXU' else pg.cd_unidade_medida_venda end as cd_unidade_medida_venda,
		 coalesce(int.qt_transferida, 1) qt_lote,
		 int.vl_custo_gerencial vl_custo_unitario,
		 'SEM LOTE',
		 cast('2000-01-01' as date),
		 cast('2099-12-31' as date),
		 nt.cd_filial_destino,
		 nt.de_dados_adicionais,
		 int.nr_sequencial,
		 int.vl_bc_icms,
		 int.pc_icms,
		 int.vl_icms,
		 int.cd_cst_tributacao,
		 int.pc_icms_st,
		 int.vl_icms_st,
		 int.vl_bc_icms_st,
		 '' nr_cgc_cpf,
		 int.cd_natureza_operacao,
		 int.cd_cst_pis,
		 int.cd_cst_cofins,
		 int.cd_cst_tributacao as cd_cst_icms,
		 int.vl_custo_unitario as vl_custo_unitario_nf,
		 int.pc_fcp,
		 int.vl_fcp
  from item_nf_transferencia int inner join nf_transferencia nt on int.nr_nf 					= nt.nr_nf and
																						 int.cd_filial_origem	= nt.cd_filial_origem and
																						 int.de_serie				= nt.de_serie and
																						 int.de_especie			= nt.de_especie
											inner join produto_geral pg on pg.cd_produto = int.cd_produto
 where int.nr_nf 					= :anr_nf and
		 int.cd_filial_origem	= :acd_filial_origem  and
		 int.de_serie 				= :ade_serie  and
		 int.de_especie 			= :ade_especie and
		 :aid_tipo_nf				= '156' and
		 int.cd_filial_origem	= 534 and
		 int.de_serie				= '1'

union

select pg.cd_produto_sap,
		 pg.cd_unidade_medida_venda,
		 ind.qt_item qt_lote,
		 ind.vl_preco_unitario,
		 null,
		 null,
		 null,
		 null,
		 nd.de_dados_adicionais_1 + ' ' + nd.de_dados_adicionais_2 + ' ' + nd.de_dados_adicionais_3 + ' ' + nd.de_dados_adicionais_4 + ' ' + nd.de_dados_adicionais_5 + ' ' + nd.de_dados_adicionais_6 + ' ' + nd.de_dados_adicionais_7 + ' ' + nd.de_dados_adicionais_8 as dados_adicionais,
		 ind.cd_item,
		 ind.vl_bc_icms,
		 ind.pc_icms,
		 ind.vl_icms,
		 ind.cd_cst_tributacao,
		 ind.pc_icms_st,
		 ind.vl_icms_st,
		 ind.vl_bc_icms_st,
		 nd.nr_cgc_cpf nr_cgc_cpf,
		 nd.cd_natureza_operacao,
		 ind.cd_cst_pis,
		 ind.cd_cst_cofins,
		 null as cd_cst_icms,
		 null as vl_custo_unitario_nf,
		 null as pc_fcp,
		 null as vl_fcp
  from item_nf_diversa ind inner join nf_diversa nd on ind.nr_nf 					= nd.nr_nf and
																		 ind.cd_filial_origem	= nd.cd_filial_origem and
																		 ind.de_serie				= nd.de_serie and
																		 ind.de_especie			= nd.de_especie
									inner join produto_geral pg on pg.cd_produto = ind.cd_produto
 where ind.nr_nf 					= :anr_nf and
		 ind.cd_filial_origem	= :acd_filial_origem  and
		 ind.de_serie 				= :ade_serie  and
		 ind.de_especie 			= :ade_especie and
		 :aid_tipo_nf				= 'BLE'

union

select pg.cd_produto_sap,
		 pg.cd_unidade_medida_venda,
		 coalesce(indcl.qt_lote, indc.qt_devolvida) qt_lote,
		 indc.vl_preco_unitario,
		 indcl.nr_lote,
		 pl.dh_fabricacao,
		 pl.dh_validade,
		 null,
		 ndc.de_dados_adicionais,
		 indc.nr_sequencial,
		 indc.vl_bc_icms,
		 indc.pc_icms,
		 indc.vl_icms,
		 indc.cd_cst_tributacao,
		 indc.pc_icms_st,
		 indc.vl_icms_st,
		 indc.vl_bc_icms_st,
		 '' nr_cgc_cpf,
		 indc.cd_natureza_operacao,
		 indc.cd_cst_pis,
		 indc.cd_cst_cofins,
		 null as cd_cst_icms,
		 null as vl_custo_unitario_nf,
		 null as pc_fcp,
		 null as vl_fcp
  from item_nf_devolucao_compra indc inner join nf_devolucao_compra ndc on indc.nr_nf 		= ndc.nr_nf and
																								 indc.cd_filial	= ndc.cd_filial and
																								 indc.de_serie		= ndc.de_serie and
																								 indc.de_especie	= ndc.de_especie
											inner join produto_geral pg on pg.cd_produto = indc.cd_produto
											left  join item_nf_devolucao_compra_lote indcl on indc.nr_nf 				= indcl.nr_nf and
																										 indc.cd_filial				= indcl.cd_filial and
																										 indc.de_serie					= indcl.de_serie and
																										 indc.de_especie				= indcl.de_especie and
																										 indc.cd_natureza_operacao	= indcl.cd_natureza_operacao and
																										 indc.cd_produto				= indcl.cd_produto
											left join produto_lote pl on pl.cd_produto = indcl.cd_produto and
																				pl.nr_lote = indcl.nr_lote
 where indc.nr_nf 		= :anr_nf and
		 indc.cd_filial	= :acd_filial_origem  and
		 indc.de_serie 	= :ade_serie  and
		 indc.de_especie 	= :ade_especie and
		 :aid_tipo_nf		= 'WDL'" arguments=(("acd_filial_origem", number),("anr_nf", number),("ade_serie", string),("ade_especie", string),("aid_tipo_nf", string)) )
