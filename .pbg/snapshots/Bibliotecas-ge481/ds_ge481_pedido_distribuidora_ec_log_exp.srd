table(column=(type=decimal(0) updatewhereclause=yes key=yes name=nr_atualizacao dbname="log_exportacao_sap.nr_atualizacao" dbalias="lo.nr_atualizacao" )
 column=(type=char(40) updatewhereclause=yes name=cd_chave dbname="log_exportacao_sap.cd_chave" dbalias="lo.cd_chave" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="log_exportacao_sap.cd_filial" dbalias="lo.cd_filial" )
 column=(type=char(3) updatewhereclause=yes name=cd_tipo_documento dbname="log_exportacao_sap.cd_tipo_documento" dbalias="lo.cd_tipo_documento" )
 column=(type=char(1) updatewhereclause=yes name=id_reprocessar dbname="id_reprocessar" )
 column=(type=char(3) updatewhereclause=yes name=tp_po dbname="tp_po" )
 retrieve="select lo.nr_atualizacao, 
		lo.cd_chave,
		lo.cd_filial,
		lo.cd_tipo_documento,
		CASE WHEN lo.id_reprocessar = 'N' THEN 'I' 
			ELSE 'M' 
			END as id_reprocessar,
		'ZPL' as tp_po
from log_exportacao_sap lo
where lo.id_tipo_nf = 'ZPL'
   and lo.cd_tipo_documento = 'ZPL'
   and lo.id_status_integracao = 'C'" update="log_exportacao_sap" updatewhere=0 updatekeyinplace=no )
