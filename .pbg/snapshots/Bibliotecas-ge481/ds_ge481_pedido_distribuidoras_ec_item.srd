table(column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_distribuidora_prd_item.nr_pedido" dbalias="pdpi.nr_pedido" )
 column=(type=long updatewhereclause=yes name=nr_item dbname="pedido_distribuidora_prd_item.nr_item" dbalias="pdpi.nr_item" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="pg.cd_produto_sap" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_distribuidora_prd_item.qt_pedida" dbalias="pdpi.qt_pedida" )
 column=(type=char(40) updatewhereclause=yes name=cd_filial_sap dbname="integracao_sap.cd_filial_sap" dbalias="isap.cd_filial_sap" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco dbname="vl_preco" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_repasse_icms dbname="pc_repasse_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=char(1) updatewhereclause=yes name=cd_origem_produto dbname="pedido_distribuidora_prd_item.cd_origem_produto" dbalias="pdpi.cd_origem_produto" )
 column=(type=char(10) updatewhereclause=yes name=dh_remessa dbname="dh_remessa" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_distribuidora.cd_filial" dbalias="pd.cd_filial" )
 column=(type=long updatewhereclause=yes name=cd_produto_legado dbname="produto_geral.cd_produto_legado" dbalias="pg.cd_produto_legado" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_financeiro dbname="pc_desconto_financeiro" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_midia dbname="pc_desconto_midia" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="pg.vl_fator_conversao" )
 column=(type=long updatewhereclause=yes name=qt_embalagem_padrao_distrib dbname="qt_embalagem_padrao_distrib" )
 retrieve="	select pdpi.nr_pedido_distribuidora as nr_pedido,
		 	 pdpi.nr_sequencial as nr_item,
		 	 pg.cd_produto_sap as cd_produto_sap,
		 	 pdpi.qt_atendida as qt_pedida,
		 	 isap.cd_chave_sap as cd_filial_sap,
		 	 cast(round(pdp.vl_preco / coalesce(pdp.qt_embalagem_padrao_distrib, 1), 2) as decimal(9,2)) as vl_preco,
		 	 coalesce(pdp.pc_repasse_icms, 0) as pc_repasse_icms,
		 	 coalesce(pdp.pc_desconto, 0) as pc_desconto,
		 	 pdpi.cd_origem_produto as cd_origem_produto,		 
		 	 convert(char(10), dateadd(day, 1, pd.dh_emissao), 103 ) as dh_remessa, 
		 	 pd.cd_filial as cd_filial, 
		 	 pg.cd_produto as cd_produto_legado,
			 coalesce(pdp.pc_desconto_financeiro, 0) as pc_desconto_financeiro,
		 	 coalesce(pdp.pc_desconto_midia, 0) as pc_desconto_midia,
			 pg.vl_fator_conversao,
			 Coalesce(pdp.qt_embalagem_padrao_distrib, 1) as qt_embalagem_padrao_distrib
	  from pedido_distribuidora_prd_item pdpi inner join produto_geral pg
																	  on pg.cd_produto = pdpi.cd_produto
															inner join pedido_distribuidora pd
																 	  on pd.cd_filial 					= pdpi.cd_filial
																	 and pd.nr_pedido_distribuidora 	= pdpi.nr_pedido_distribuidora
															inner join pedido_distribuidora_produto pdp
																	  on pdp.cd_filial 					= pdpi.cd_filial
																	 and pdp.nr_pedido_distribuidora = pdpi.nr_pedido_distribuidora
																	 and pdp.cd_produto 					= pdpi.cd_produto
													 left outer join integracao_sap isap
																	  on isap.cd_empresa 		= 1000
																	 and isap.cd_tabela  		= 'FILIAL'
   																 and isap.cd_chave_legado 	= cast(pdpi.cd_filial as varchar)
	 where pd.cd_filial 						= :al_filial
		and pd.nr_pedido_distribuidora	= :al_numero_pedido
		and pdp.qt_atendida > 0" arguments=(("al_numero_pedido", number),("al_filial", number))  sort="nr_pedido A nr_item A " )
