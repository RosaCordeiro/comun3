table(column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="log_exportacao_sap.nr_atualizacao" dbalias="l.nr_atualizacao" )
 column=(type=char(40) updatewhereclause=yes name=cd_centro dbname="integracao_sap.cd_centro" dbalias="s.cd_centro" )
 column=(type=char(40) updatewhereclause=yes name=descricao_centro dbname="filial.descricao_centro" dbalias="fi.descricao_centro" )
 column=(type=char(20) updatewhereclause=yes name=cd_fornecedor_sap dbname="fornecedor.cd_fornecedor_sap" dbalias="fo.cd_fornecedor_sap" )
 column=(type=char(40) updatewhereclause=yes name=nm_forncedor dbname="fornecedor.nm_forncedor" dbalias="fo.nm_forncedor" )
 column=(type=char(38) updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(61) updatewhereclause=yes name=criadopor dbname="criadopor" )
 column=(type=char(30) updatewhereclause=yes name=dtaemissaonf dbname="dtaEmissaonf" )
 column=(type=char(30) updatewhereclause=yes name=datarecebimento dbname="datarecebimento" )
 column=(type=char(30) updatewhereclause=yes name=horarecebimento dbname="horarecebimento" )
 column=(type=char(30) updatewhereclause=yes name=datafinalizacao dbname="datafinalizacao" )
 column=(type=char(30) updatewhereclause=yes name=horafinalizacao dbname="horafinalizacao" )
 column=(type=decimal(2) updatewhereclause=yes name=valornf dbname="nf_compra.valornf" dbalias="c.valornf" )
 column=(type=char(40) updatewhereclause=yes name=chaveacesso dbname="log_exportacao_sap.chaveacesso" dbalias="l.chaveacesso" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" dbalias="ci.cd_unidade_federacao" )
 retrieve=" select 
    l.nr_atualizacao,
	s.cd_chave_sap as cd_centro,
    fi.nm_fantasia as descricao_centro,  
    fo.cd_fornecedor_sap,      
    fo.nm_fantasia as nm_forncedor,
    cast(l.nr_nf as varchar)||'/'||l.de_especie||'/'||l.de_serie as nr_nf,
    (cast(l.nr_titulo as varchar)||'-'||cast(co.nm_usuario as varchar)) as criadopor,           
    convert(varchar, c.dh_emissao,103) as dtaEmissaonf ,            
    convert(varchar,l.dh_documento,103) as datarecebimento,
    convert(varchar,l.dh_documento,108) as horarecebimento,   
    convert(varchar,c.dh_atualizacao_estoque,103) as datafinalizacao,
    convert(varchar,c.dh_atualizacao_estoque,108) as horafinalizacao,
    c.vl_total_nf as valornf,
    l.cd_chave as chaveacesso,
    ci.cd_unidade_federacao as cd_unidade_federacao
from log_exportacao_sap l
inner  join nf_compra  c on c.cd_filial = l.cd_filial 
            and c.cd_fornecedor = l.cd_fornecedor 
            and c.nr_nf  = l.nr_nf 
            and c.de_especie  = l.de_especie 
            and c.de_serie = l.de_serie
inner  join integracao_sap s on  s.cd_empresa = 1000 and s.cd_tabela  = 'FILIAL' and s.cd_chave_legado = cast(c.cd_filial as varchar)
inner  join filial fi on fi.cd_filial = c.cd_filial
inner join cidade ci on ci.cd_cidade = fi.cd_cidade
inner join fornecedor fo on fo.cd_fornecedor  = c.cd_fornecedor
inner  join usuario co on cast(co.nr_matricula as char) = cast(l.nr_titulo  as char)
where l.id_tipo_nf = 'REC'
  and l.id_status_integracao = 'C'
  and l.cd_tipo_documento = 'REC'   

union

 select 
    l.nr_atualizacao,
	s.cd_chave_sap as cd_centro,
    fi.nm_fantasia as descricao_centro,  
    fo.cd_fornecedor_sap,      
    fo.nm_fantasia as nm_forncedor,
    cast(l.nr_nf as varchar)||'/'||l.de_especie||'/'||l.de_serie as nr_nf,
    (cast(l.nr_titulo as varchar)||'-'||cast(co.nm_usuario as varchar)) as criadopor,           
    convert(varchar, c.dh_emissao,103) as dtaEmissaonf ,            
    convert(varchar,l.dh_documento,103) as datarecebimento,
    convert(varchar,l.dh_documento,108) as horarecebimento,   
    convert(varchar,c.dh_atualizacao_estoque,103) as datafinalizacao,
    convert(varchar,c.dh_atualizacao_estoque,108) as horafinalizacao,
    c.vl_total_nf as valornf,
    l.cd_chave as chaveacesso,
    ci.cd_unidade_federacao as cd_unidade_federacao
from log_exportacao_sap l
inner  join nf_compra  c on c.de_chave_acesso	= l.cd_chave
inner  join integracao_sap s on  s.cd_empresa = 1000 and s.cd_tabela  = 'FILIAL' and s.cd_chave_legado = cast(c.cd_filial as varchar)
inner  join filial fi on fi.cd_filial = c.cd_filial
inner join cidade ci on ci.cd_cidade = fi.cd_cidade
inner join fornecedor fo on fo.cd_fornecedor  = c.cd_fornecedor
inner  join usuario co on cast(co.nr_matricula as char) = cast(l.nr_titulo  as char)
where l.id_tipo_nf = 'REC'
  and l.id_status_integracao = 'C'
  and l.cd_tipo_documento = 'REC'   
" )
