table(column=(type=char(68) updatewhereclause=yes name=nm_campo_clamed dbname="nm_campo_clamed" )
 column=(type=char(46) updatewhereclause=yes name=nm_campo_distrib dbname="nm_campo_distrib" )
 retrieve=" select nm_campo_clamed = ~"coalesce(pg.nr_classificacao_fiscal, -1)~"
      , nm_campo_distrib = ~"coalesce(dp.ncm_produto, -1)~"
  union
 select nm_campo_clamed = ~"coalesce(pg.id_situacao, 'NULL')~"
      , nm_campo_distrib = ~"coalesce(dp.id_situacao, 'NULL')~"
  union
 select nm_campo_clamed = ~"coalesce(pg.cd_cest, 'NULL')~"
      , nm_campo_distrib = ~"coalesce(convert(varchar, dp.cd_cest), 'NULL')~"
  union
 select nm_campo_clamed = ~"coalesce(ti.cd_cst_tributacao, 'NULL')~"
      , nm_campo_distrib = ~"coalesce(substring(dp.cd_cst, 2, 2), 'NULL')~"
  union
 select nm_campo_clamed = ~"coalesce(tpi.pc_icms, 0)~"
      , nm_campo_distrib = ~"coalesce(dp.pc_icms_st, 0)~"
  union
 select nm_campo_clamed = ~"coalesce(tpfm.pc_mva, 0)~"
      , nm_campo_distrib = ~"coalesce(dp.pc_mva, 0)~"
  union
 select nm_campo_clamed = ~"coalesce(pg.cd_origem_produto, NULL)~"
      , nm_campo_distrib = ~"coalesce(substring(dp.cd_cst, 1, 1), NULL)~"
  union
 select nm_campo_clamed = ~"coalesce(round(pu.vl_preco_venda_maximo/pg.vl_fator_conversao,2), 0)~"
      , nm_campo_distrib = ~"coalesce(dp.vl_pmc, 0)~"
" )
