table(column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="log_exportacao_sap.nr_atualizacao" dbalias="l.nr_atualizacao" )
 column=(type=datetime updatewhereclause=yes name=data_movimentacao dbname="data_movimentacao" )
 column=(type=datetime updatewhereclause=yes name=data_lancamento dbname="data_lancamento" )
 column=(type=char(2) updatewhereclause=yes name=direcao_movimento dbname="direcao_movimento" )
 column=(type=char(3) updatewhereclause=yes name=tipo_movimento dbname="wms_tipo_movimento_estoque.tipo_movimento" dbalias="t.tipo_movimento" )
 column=(type=long updatewhereclause=yes name=empresa dbname="log_exportacao_sap.empresa" dbalias="l.empresa" )
 column=(type=char(50) updatewhereclause=yes name=cd_chave_interface dbname="log_exportacao_sap.cd_chave_interface" dbalias="l.cd_chave_interface" )
 column=(type=char(40) updatewhereclause=yes name=cd_varchar dbname="log_exportacao_sap.cd_varchar" dbalias="l.cd_varchar" )
 column=(type=long updatewhereclause=yes name=nr_inventario dbname="nr_inventario" )
 column=(type=long updatewhereclause=yes name=nr_agrupamento_dev_compra dbname="nr_agrupamento_dev_compra" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_incineracao dbname="cd_fornecedor_incineracao" )
 column=(type=char(293) updatewhereclause=yes name=de_dados_adicionais dbname="de_dados_adicionais" )
 column=(type=char(20) updatewhereclause=yes name=cd_centro_custo_sap dbname="cd_centro_custo_sap" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_nf dbname="log_exportacao_sap.id_tipo_nf" dbalias="l.id_tipo_nf" )
 retrieve="select l.nr_atualizacao, --Movimenta$$HEX2$$e700e300$$ENDHEX$$o entre dep$$HEX1$$f300$$ENDHEX$$sitos
		 getdate() as data_movimentacao, 
		 getdate() as data_lancamento, 
		 '04' as direcao_movimento,
		 t.cd_tipo_sap as tipo_movimento, 
		 l.cd_empresa as empresa,
		 l.cd_chave_interface,
		 l.cd_varchar,
		 null nr_inventario,
		 null nr_agrupamento_dev_compra,
		 null cd_fornecedor_incineracao,
		 '' de_dados_adicionais,
		 null as cd_centro_custo_sap,
		 l.id_tipo_nf
  from log_exportacao_sap l
 inner join wms_movimento_estoque w on (w.cd_chave_movimento = l.cd_chave)
 inner join wms_tipo_movimento_estoque t on (t.cd_tipo_movimento = w.cd_tipo_movimento)
 where l.id_tipo_nf 				= 'WMM'
	and l.id_status_integracao in ('C', 'E')
	and l.cd_tipo_documento 	= 'WMM'
	and t.id_entrada_saida 		= (CASE WHEN coalesce(cd_varchar, 'XX') = 'SEGREG RECEB' THEN 'E' 
																													ELSE 'S' 
											END)
   and l.dh_exportacao 			>= '20210812'
	and l.cd_chave_interface 	is not null
	and l.cd_chave_interface <> ''
group by l.nr_atualizacao,
			t.cd_tipo_sap, 
			l.cd_empresa,
			l.cd_chave_interface,
			l.cd_varchar,
			l.id_tipo_nf

union

select l.nr_atualizacao, --Descarte de agrupamentos 
		 getdate() as data_movimentacao, 
		 getdate() as data_lancamento, 
		 w.cd_direcao_movimento_sap as direcao_movimento,
		 w.cd_tipo_movimento_sap as tipo_movimento, 
		 1000 as empresa,
		 l.cd_chave_interface,
		 'SEGREG DESCARTE' as cd_varchar,
		 w.nr_inventario nr_inventario,
		 w.nr_agrupamento_dev_compra,
		 w.cd_fornecedor_incineracao,
		 w.de_dados_adicionais + Coalesce(' - ' + mdc.de_motivo_devolucao, ''),
		 w.cd_centro_custo_sap,
		 l.id_tipo_nf
  from log_exportacao_sap l
 inner join wms_int_sap_detalhe d on (l.cd_chave = cast(w.nr_integracao as varchar(10)))
 inner join wms_int_sap w on (w.nr_integracao = d.nr_integracao)
  left outer join agrupamento_dev_compra adc on w.nr_agrupamento_dev_compra	= adc.nr_agrupamento
  left outer join motivo_devolucao_compra mdc on mdc.cd_motivo_devolucao = adc.cd_motivo_devolucao
 where l.id_tipo_nf 				= 'WMA'
	and l.id_status_integracao in ('C', 'E')
	and l.cd_tipo_documento 	= 'WMA'
   and l.dh_exportacao 			>= '20210812'
	and l.cd_chave_interface 	is not null
	and l.cd_chave_interface <> ''
Group By l.nr_atualizacao,
			l.cd_empresa,
			l.cd_chave_interface,
			l.cd_varchar,
			w.cd_direcao_movimento_sap,
			w.cd_tipo_movimento_sap,
			w.nr_inventario,
			w.nr_agrupamento_dev_compra,
			w.cd_fornecedor_incineracao,
			w.de_dados_adicionais,
			w.cd_centro_custo_sap,
			mdc.de_motivo_devolucao,
			l.id_tipo_nf

union

select l.nr_atualizacao, --Ajustes dee invent$$HEX1$$e100$$ENDHEX$$rio e pontuais
		 w.dh_inclusao as data_movimentacao, 
		 w.dh_inclusao as data_lancamento, 
		 w.cd_direcao_movimento_sap as direcao_movimento,
		 w.cd_tipo_movimento_sap as tipo_movimento, 
		 1000 as empresa,
		 l.cd_chave_interface,
		 'INVENTARIO' as cd_varchar,
		 w.nr_inventario nr_inventario,
		 w.nr_agrupamento_dev_compra,
		 w.cd_fornecedor_incineracao,
		 w.de_dados_adicionais,
		 w.cd_centro_custo_sap,
		 l.id_tipo_nf
  from log_exportacao_sap l
 inner join wms_int_sap w on (l.cd_chave = cast(w.nr_integracao as varchar(10)))
 where l.id_tipo_nf 				= 'WMI'
	and l.id_status_integracao in ('C', 'E')
	and l.cd_tipo_documento 	= 'WMI'
	and l.cd_chave_interface 	is not null

union

select l.nr_atualizacao, --Equaliza$$HEX2$$e700e300$$ENDHEX$$o (N$$HEX1$$e300$$ENDHEX$$o usar)
		 w.dh_inclusao as data_movimentacao, 
		 w.dh_inclusao as data_lancamento, 
		 w.cd_direcao_movimento_sap as direcao_movimento,
		 w.cd_tipo_movimento_sap as tipo_movimento, 
		 1000 as empresa,
		 l.cd_chave_interface,
		 'EQUALIZACAO' as cd_varchar,
		 w.nr_inventario nr_inventario,
		 w.nr_agrupamento_dev_compra,
		 w.cd_fornecedor_incineracao,
		 w.de_dados_adicionais,
		 w.cd_centro_custo_sap,
		 l.id_tipo_nf
  from log_exportacao_sap l
 inner join wms_int_sap w on (l.cd_chave = cast(w.nr_integracao as varchar(10)))
 where l.id_tipo_nf 				= 'WMT'
	and l.id_status_integracao in ('C')
	and l.cd_tipo_documento 	= 'WMT'
	and l.cd_chave_interface 	is not null

order by 1 asc" )
