table(column=(type=char(5) updatewhereclause=yes name=id_sql dbname="id_sql" )
 column=(type=char(32) updatewhereclause=yes name=cd_chave_movimento dbname="cd_chave_movimento" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=long updatewhereclause=yes name=nr_movimento dbname="nr_movimento" )
 column=(type=char(20) updatewhereclause=yes name=material dbname="material" )
 column=(type=char(3) updatewhereclause=yes name=unidade_de_medida dbname="unidade_de_medida" )
 column=(type=decimal(4) updatewhereclause=yes name=quantidade dbname="quantidade" )
 column=(type=char(40) updatewhereclause=yes name=centro dbname="centro" )
 column=(type=char(20) updatewhereclause=yes name=centro_de_custo dbname="centro_de_custo" )
 column=(type=char(4) updatewhereclause=yes name=deposito_saida dbname="deposito_saida" )
 column=(type=char(4) updatewhereclause=yes name=de_motivo_devolucao dbname="de_motivo_devolucao" )
 column=(type=char(4) updatewhereclause=yes name=deposito_entrada dbname="deposito_entrada" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="dh_validade" )
 column=(type=datetime updatewhereclause=yes name=dh_fabricacao dbname="dh_fabricacao" )
 column=(type=char(15) updatewhereclause=yes name=cd_conta_sap dbname="cd_conta_sap" )
 retrieve="select 
	'SQL01' id_sql,
	w.cd_chave_movimento,			
	w.cd_produto,
	w.nr_movimento,
	g.cd_produto_sap as material,
	Case When g.vl_fator_conversao > 1 then 'CXU' else g.cd_unidade_medida_venda end as unidade_de_medida,
	w.qt_movimento * w.qt_caixa_padrao as quantidade,
	(select cd_chave_sap from integracao_sap where cd_tabela = 'FILIAL' and cd_chave_legado = cast(coalesce(b.cd_filial, 534) as varchar(4))) as centro,
	cast(w.cd_centro_custo as varchar(10)) as centro_de_custo,
	b.cd_deposito_sap as deposito_saida,
	'' as de_motivo_devolucao,
	'' as deposito_entrada,
	w.nr_lote,
	w.dh_validade,
	cast(null as datetime) as dh_fabricacao,
	'' cd_conta_sap
from log_exportacao_sap l
inner join wms_movimento_estoque w on (w.cd_chave_movimento = l.cd_chave)
inner join wms_endereco e on (e.cd_endereco = w.cd_endereco_localizacao)
inner join wms_bairro b on (b.cd_bairro = e.cd_bairro)
inner join wms_tipo_movimento_estoque t on (t.cd_tipo_movimento = w.cd_tipo_movimento)
inner join produto_geral g on (g.cd_produto = w.cd_produto)
where l.nr_atualizacao 		= :p_nr_atualizacao
  and t.id_entrada_saida 	= :p_entrada_saida
  and :p_tipo					<> 'SEGREG DESCARTE'

union

select 
	'SQL02' id_sql,
	'' as cd_chave_movimento,			
	g.cd_produto,
	null as nr_movimento,
	g.cd_produto_sap as material,
	Case When (w.cd_filial = 534 or w.nr_agrupamento_dev_compra > 0) and g.vl_fator_conversao > 1 then 'CXU' else g.cd_unidade_medida_venda end as unidade_de_medida,
	d.qt_lote as quantidade,
	(select cd_chave_sap from integracao_sap where cd_tabela = 'FILIAL' and cd_chave_legado = cast(coalesce(w.cd_filial, 534) as varchar(4))) as centro,
	null as centro_de_custo,
	'0002' as deposito_saida,
	m.cd_motivo_sap as de_motivo_devolucao,
	'' as deposito_entrada,
	d.nr_lote,
	d.dh_validade,
	d.dh_fabricacao,
	w.cd_conta_sap as cd_conta_sap
from log_exportacao_sap l
inner join wms_int_sap w on (cast(w.nr_integracao as varchar(20)) = l.cd_chave)
inner join wms_int_sap_detalhe d on (w.nr_integracao = d.nr_integracao)
inner join produto_geral g on (g.cd_produto = d.cd_produto)
left outer join motivo_devolucao_compra m on (m.cd_motivo_devolucao = w.cd_motivo_devolucao)
where l.nr_atualizacao 	= :p_nr_atualizacao
  and :p_tipo				= 'SEGREG DESCARTE'

union

select 
	'SQL03' id_sql,
	'' as cd_chave_movimento,			
	g.cd_produto,
	null as nr_movimento,
	g.cd_produto_sap as material,
	Case When g.vl_fator_conversao > 1 then 'CXU' else g.cd_unidade_medida_venda end as unidade_de_medida,
	d.qt_lote as quantidade,
	(select cd_chave_sap from integracao_sap where cd_tabela = 'FILIAL' and cd_chave_legado = cast(coalesce(w.cd_filial, 534) as varchar(4))) as centro,
	coalesce(cast(wme.cd_centro_custo as varchar(10)), w.cd_centro_custo_sap) as centro_de_custo,
	d.cd_deposito_sap_saida as deposito_saida,
	m.cd_motivo_sap as de_motivo_devolucao,
	d.cd_deposito_sap_entrada as deposito_entrada,
	wme.nr_lote,
	wme.dh_validade,
	d.dh_fabricacao,
	w.cd_conta_sap as cd_conta_sap
from log_exportacao_sap l
inner join wms_int_sap w on (cast(w.nr_integracao as varchar(20)) = l.cd_chave)
inner join wms_int_sap_detalhe d on (w.nr_integracao = d.nr_integracao)
inner join wms_movimento_estoque wme on 
	(wme.cd_chave_movimento = d.cd_chave_movimento_estoque_wms 
and wme.nr_lote = d.nr_lote 
and wme.cd_produto = d.cd_produto 
and coalesce(wme.dh_validade, '1900-01-01') = coalesce(d.dh_validade, wme.dh_validade, '1900-01-01'))
inner join produto_geral g on (g.cd_produto = d.cd_produto)
left outer join motivo_ajuste m on (m.cd_motivo_ajuste = w.cd_motivo_devolucao)
where l.nr_atualizacao 	= :p_nr_atualizacao
  and :p_tipo					<> 'SEGREG DESCARTE'

union

select 
	'SQL04' id_sql,
	'' as cd_chave_movimento,			
	pg.cd_produto,
	null as nr_movimento,
	pg.cd_produto_sap as material,
	pg.cd_unidade_medida_venda as unidade_de_medida,
	wisd.qt_lote * pg.vl_fator_conversao as quantidade,
	(select cd_chave_sap from integracao_sap where cd_tabela = 'FILIAL' and cd_chave_legado = cast(coalesce(wis.cd_filial, 534) as varchar(4))) as centro,
	null as centro_de_custo,
	wisd.cd_deposito_sap_saida as deposito_saida,
	ma.cd_motivo_sap as de_motivo_devolucao,
	wisd.cd_deposito_sap_entrada as deposito_entrada,
	null,
	null,
	wisd.dh_fabricacao,
	wis.cd_conta_sap as cd_conta_sap
from log_exportacao_sap les
inner join wms_int_sap wis on (cast(wis.nr_integracao as varchar(20)) = les.cd_chave)
inner join wms_int_sap_detalhe wisd on (wis.nr_integracao = wisd.nr_integracao)
inner join produto_geral pg on (pg.cd_produto = wisd.cd_produto)
left outer join motivo_ajuste ma on (ma.cd_motivo_ajuste = wis.cd_motivo_devolucao)
where les.nr_atualizacao 	= :p_nr_atualizacao
  and :p_tipo					= 'EQUALIZACAO'
	and pg.cd_produto_sap is not null" arguments=(("p_nr_atualizacao", number),("p_entrada_saida", string),("p_tipo", string)) )
