table(column=(type=long updatewhereclause=yes name=number_po dbname="number_po" )
 column=(type=char(4) updatewhereclause=yes name=tp_po dbname="tp_po" )
 column=(type=char(4) updatewhereclause=yes name=center_provider dbname="center_provider" )
 column=(type=char(1) updatewhereclause=yes name=code_pgto dbname="code_pgto" )
 column=(type=char(10) updatewhereclause=yes name=date dbname="date" )
 column=(type=long updatewhereclause=yes name=item_po dbname="item_po" )
 column=(type=char(20) updatewhereclause=yes name=material dbname="material" )
 column=(type=char(3) updatewhereclause=yes name=unidade_medida dbname="unidade_medida" )
 column=(type=long updatewhereclause=yes name=amount dbname="amount" )
 column=(type=char(40) updatewhereclause=yes name=store dbname="store" )
 column=(type=char(20) updatewhereclause=yes name=batch dbname="batch" )
 column=(type=date updatewhereclause=yes name=fab_date dbname="fab_date" )
 column=(type=datetime updatewhereclause=yes name=exp_date dbname="exp_date" )
 column=(type=char(1) updatewhereclause=yes name=id_controlado dbname="id_controlado" )
 column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="cd_distribuidora" )
 column=(type=long updatewhereclause=yes name=cd_centro_custo_legado dbname="cd_centro_custo_legado" )
 column=(type=char(1) updatewhereclause=yes name=id_pedido_almoxarifado dbname="id_pedido_almoxarifado" )
 column=(type=char(1) updatewhereclause=yes name=cd_categoria dbname="cd_categoria" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=de_tipo_pedido dbname="de_tipo_pedido" )
 column=(type=char(50) updatewhereclause=yes name=de_motivo_rejeicao dbname="de_motivo_rejeicao" )
 column=(type=long updatewhereclause=yes name=qt_atendida dbname="qt_atendida" )
 column=(type=char(4) updatewhereclause=yes name=cd_deposito_sap dbname="cd_deposito_sap" )
 column=(type=char(1) updatewhereclause=yes name=id_sobra dbname="id_sobra" )
 column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="cd_filial_origem" )
 retrieve="select pedido_distribuidora.nr_pedido_distribuidora as number_po,
			 coalesce(tipo_pedido_distribuidora.id_tipo_pedido_sap, 'X') as tp_po,
			 '1156' as center_provider,
		 	 '' as code_pgto,
			 convert ( char(10), pedido_distribuidora.dh_emissao, 104 ) date,
			 pedido_distribuidora_prd_item.nr_sequencial as item_po,
		 	 coalesce(produto_geral.cd_produto_sap, '') as material,
			 dbo.retorna_um_compra_sap(pedido_distribuidora_prd_item.cd_produto) as unidade_medida,
			 sum(pedido_distribuidora_prd_lote.qt_lote) as amount,
			 coalesce(integracao_sap.cd_chave_sap, '') as store,
			 '' as batch,
			 '' as fab_date, 
			 '' as exp_date,
			 case when produto_geral.cd_grupo_psico is null then 'N' else 'S' end as id_controlado,
			 pedido_distribuidora.cd_distribuidora,
		    coalesce(pedido_distribuidora.cd_centro_custo, pedido_almoxarifado.cd_centro_custo) cd_centro_custo_legado,
			 pedido_distribuidora.id_pedido_almoxarifado,
			 substring(produto_geral.cd_subcategoria, 1,1) as cd_categoria,
			 pedido_distribuidora_prd_item.cd_produto as cd_produto,
			 coalesce(tipo_pedido_distribuidora.de_tipo, '') as de_tipo_pedido,
			 coalesce(pedido_distribuidora_produto.de_motivo_rejeicao, '') as de_motivo_rejeicao,
			 coalesce(pedido_distribuidora_produto.qt_lista_separacao, 0) as qt_atendida,
			 tipo_pedido_distribuidora.cd_deposito_sap,
			 tipo_pedido_distribuidora.id_sobra,
			wte.cd_filial_origem
	  from pedido_distribuidora inner join pedido_distribuidora_prd_item on pedido_distribuidora_prd_item.cd_filial 					= pedido_distribuidora.cd_filial and
																									pedido_distribuidora_prd_item.nr_pedido_distribuidora = pedido_distribuidora.nr_pedido_distribuidora
										 inner join pedido_distribuidora_prd_lote on pedido_distribuidora_prd_lote.cd_filial 					= pedido_distribuidora_prd_item.cd_filial and 
																									pedido_distribuidora_prd_lote.nr_pedido_distribuidora = pedido_distribuidora_prd_item.nr_pedido_distribuidora and 
																									pedido_distribuidora_prd_lote.cd_produto 					= pedido_distribuidora_prd_item.cd_produto
										 left join produto_lote on produto_lote.nr_lote 		= pedido_distribuidora_prd_lote.nr_lote and 
																			 produto_lote.cd_produto 	= pedido_distribuidora_prd_lote.cd_produto
										 inner join pedido_distribuidora_produto on pedido_distribuidora_produto.nr_pedido_distribuidora = pedido_distribuidora.nr_pedido_distribuidora
																							 and pedido_distribuidora_produto.cd_filial						= pedido_distribuidora.cd_filial
																							 and pedido_distribuidora_produto.cd_produto						= pedido_distribuidora_prd_lote.cd_produto
										 inner join tipo_pedido_distribuidora on tipo_pedido_distribuidora.id_tipo	= pedido_distribuidora.id_tipo_pedido
										 left outer join produto_geral on produto_geral.cd_produto	= pedido_distribuidora_prd_item.cd_produto
										 left outer join integracao_sap on integracao_sap.cd_chave_legado = cast(pedido_distribuidora.cd_filial as varchar) and 
																					  integracao_sap.cd_tabela 		= 'FILIAL'
										left outer join pedido_distribuidora_almox on (pedido_distribuidora_almox.cd_filial = pedido_distribuidora.cd_filial and pedido_distribuidora_almox.nr_pedido_distribuidora = pedido_distribuidora.nr_pedido_distribuidora)
										left outer join pedido_almoxarifado  on  (pedido_almoxarifado.cd_filial = pedido_distribuidora_almox.cd_filial and pedido_almoxarifado.nr_pedido = pedido_distribuidora_almox.nr_pedido_almoxarifado)
										left outer join wms_transferencia_estoque wte on wte.nr_pedido_distribuidora = pedido_distribuidora.nr_pedido_distribuidora and wte.cd_filial_destino = pedido_distribuidora.cd_filial
  where pedido_distribuidora.cd_filial 					= :al_cd_filial and 
		  pedido_distribuidora.nr_pedido_distribuidora 	= :al_nr_pedido_distribuidora and 
		  pedido_distribuidora_prd_lote.dh_validade is null and
		  produto_lote.dh_validade is null and
		  substring(produto_geral.cd_subcategoria, 1,1) = '1' and
		  COALESCE(pedido_distribuidora_produto.qt_separada, 0) > COALESCE(pedido_distribuidora_produto.qt_faturada, 0)
group by pedido_distribuidora.nr_pedido_distribuidora,
			coalesce(tipo_pedido_distribuidora.id_tipo_pedido_sap, 'X'),
			convert ( char(10), pedido_distribuidora.dh_emissao, 104 ),
			pedido_distribuidora_prd_item.nr_sequencial,
			coalesce(produto_geral.cd_produto_sap, ''),
			dbo.retorna_um_compra_sap(pedido_distribuidora_prd_item.cd_produto),
			coalesce(integracao_sap.cd_chave_sap, ''),
			case when produto_geral.cd_grupo_psico is null then 'N' else 'S' end,
			pedido_distribuidora.cd_distribuidora,
			coalesce(pedido_distribuidora.cd_centro_custo, pedido_almoxarifado.cd_centro_custo),
			pedido_distribuidora.id_pedido_almoxarifado,
			substring(produto_geral.cd_subcategoria, 1,1),
			pedido_distribuidora_prd_item.cd_produto,
			tipo_pedido_distribuidora.de_tipo,
			coalesce(pedido_distribuidora_produto.de_motivo_rejeicao, ''),
			coalesce(pedido_distribuidora_produto.qt_lista_separacao, 0) ,
			 tipo_pedido_distribuidora.cd_deposito_sap,
			 tipo_pedido_distribuidora.id_sobra,
			wte.cd_filial_origem

union

	select pedido_distribuidora.nr_pedido_distribuidora as number_po,
			 coalesce(tipo_pedido_distribuidora.id_tipo_pedido_sap, 'X') as tp_po,
			 '1156' as center_provider,
		 	 '' as code_pgto,
			 convert ( char(10), pedido_distribuidora.dh_emissao, 104 ) date,
			 pedido_distribuidora_prd_item.nr_sequencial as item_po,
		 	 coalesce(produto_geral.cd_produto_sap, '') as material,
			 dbo.retorna_um_compra_sap(pedido_distribuidora_prd_item.cd_produto) as unidade_medida,
			 pedido_distribuidora_prd_lote.qt_lote as amount,
			 coalesce(integracao_sap.cd_chave_sap, '') as store,
			 pedido_distribuidora_prd_lote.nr_lote as batch,
			 case when produto_lote.dh_fabricacao is not null then produto_lote.dh_fabricacao else DateAdd(DAY, -90, cast(produto_lote.dh_validade as date)) end as fab_date,
			 case when produto_lote.dh_validade is not null then produto_lote.dh_validade else pedido_distribuidora_prd_lote.dh_validade end as exp_date,
			 case when produto_geral.cd_grupo_psico is null then 'N' else 'S' end as id_controlado,
			 pedido_distribuidora.cd_distribuidora,
		    coalesce(pedido_distribuidora.cd_centro_custo, pedido_almoxarifado.cd_centro_custo) cd_centro_custo_legado,
			 pedido_distribuidora.id_pedido_almoxarifado,
			 substring(produto_geral.cd_subcategoria, 1,1) as cd_categoria,
			 pedido_distribuidora_prd_item.cd_produto as cd_produto,
			 coalesce(tipo_pedido_distribuidora.de_tipo, '') as de_tipo_pedido,
			 coalesce(pedido_distribuidora_produto.de_motivo_rejeicao, '') as de_motivo_rejeicao,
			 coalesce(pedido_distribuidora_produto.qt_lista_separacao, 0) as qt_atendida,
			 tipo_pedido_distribuidora.cd_deposito_sap,
			 tipo_pedido_distribuidora.id_sobra,
			wte.cd_filial_origem
	  from pedido_distribuidora inner join pedido_distribuidora_prd_item on pedido_distribuidora_prd_item.cd_filial 					= pedido_distribuidora.cd_filial and
																									pedido_distribuidora_prd_item.nr_pedido_distribuidora = pedido_distribuidora.nr_pedido_distribuidora
										 inner join pedido_distribuidora_prd_lote on pedido_distribuidora_prd_lote.cd_filial 					= pedido_distribuidora_prd_item.cd_filial and 
																									pedido_distribuidora_prd_lote.nr_pedido_distribuidora = pedido_distribuidora_prd_item.nr_pedido_distribuidora and 
																									pedido_distribuidora_prd_lote.cd_produto 					= pedido_distribuidora_prd_item.cd_produto
										 left join produto_lote on produto_lote.nr_lote 		= pedido_distribuidora_prd_lote.nr_lote and 
																			 produto_lote.cd_produto 	= pedido_distribuidora_prd_lote.cd_produto
										 inner join tipo_pedido_distribuidora on tipo_pedido_distribuidora.id_tipo	= pedido_distribuidora.id_tipo_pedido
										 left outer join produto_geral on produto_geral.cd_produto	= pedido_distribuidora_prd_lote.cd_produto
										 left outer join integracao_sap on integracao_sap.cd_chave_legado = cast(pedido_distribuidora.cd_filial as varchar) and 
																					  integracao_sap.cd_tabela 		= 'FILIAL'
										left outer join pedido_distribuidora_almox on (pedido_distribuidora_almox.cd_filial = pedido_distribuidora.cd_filial and pedido_distribuidora_almox.nr_pedido_distribuidora = pedido_distribuidora.nr_pedido_distribuidora)
										left outer join pedido_almoxarifado  on  (pedido_almoxarifado.cd_filial = pedido_distribuidora_almox.cd_filial and pedido_almoxarifado.nr_pedido = pedido_distribuidora_almox.nr_pedido_almoxarifado)
										inner join pedido_distribuidora_produto on pedido_distribuidora_produto.nr_pedido_distribuidora = pedido_distribuidora.nr_pedido_distribuidora
																							 and pedido_distribuidora_produto.cd_filial						= pedido_distribuidora.cd_filial
																							 and pedido_distribuidora_produto.cd_produto						= pedido_distribuidora_prd_lote.cd_produto
										left outer join wms_transferencia_estoque wte on wte.nr_pedido_distribuidora = pedido_distribuidora.nr_pedido_distribuidora and wte.cd_filial_destino = pedido_distribuidora.cd_filial
  where pedido_distribuidora.cd_filial 					= :al_cd_filial and 
		  pedido_distribuidora.nr_pedido_distribuidora 	= :al_nr_pedido_distribuidora and  
		  (convert ( char(10), pedido_distribuidora_prd_lote.dh_validade, 104 ) <> '' or
		  convert ( char(10), produto_lote.dh_validade, 104 ) <> '') and
          substring(produto_geral.cd_subcategoria, 1,1) = '1' and
          COALESCE(pedido_distribuidora_produto.qt_separada, 0) > COALESCE(pedido_distribuidora_produto.qt_faturada, 0)

union

select p.nr_pedido_distribuidora as number_po,
		  	 coalesce(t.id_tipo_pedido_sap, 'X') as tp_po,
		    '1156' as center_provider,
		    '' as code_pgto,
		    CONVERT( CHAR(10), p.dh_emissao, 104 ) date,
		    0 as item_po,
		    pg.cd_produto_sap as material,
 		    dbo.retorna_um_compra_sap(pp.cd_produto) as unidade_medida,
		    pp.qt_separada as amount,
		    int.cd_chave_sap as store,
		    '' batch,
		    '' fab_date, 
		    '' exp_date,
		    case when pg.cd_grupo_psico is null then 'N' else 'S' end as id_controlado,
 		    p.cd_distribuidora,
		    coalesce(p.cd_centro_custo,  pa.cd_centro_custo) cd_centro_custo_legado,
		    p.id_pedido_almoxarifado,
			 substring(pg.cd_subcategoria, 1,1) as cd_categoria,
			 pp.cd_produto as cd_produto,
			 coalesce(t.de_tipo, '') as de_tipo_pedido,
			 coalesce(pp.de_motivo_rejeicao, '') as de_motivo_rejeicao,
			 coalesce(pp.qt_lista_separacao, 0) as qt_atendida,
			 COALESCE (t.cd_deposito_sap, ''),
			 COALESCE (t.id_sobra, 'N'),
			wte.cd_filial_origem
from pedido_distribuidora p
left outer join tipo_pedido_distribuidora t on (t.id_tipo	= p.id_tipo_pedido)
inner join pedido_distribuidora_produto pp on (pp.cd_filial = p.cd_filial and pp.nr_pedido_distribuidora = p.nr_pedido_distribuidora)
inner join produto_geral pg on( pg.cd_produto = pp.cd_produto)
inner join integracao_sap int on (int.cd_chave_legado 	= cast(p.cd_filial as varchar) and int.cd_tabela 			= 'FILIAL')
inner join pedido_distribuidora_almox pda on (pda.cd_filial = p.cd_filial and pda.nr_pedido_distribuidora = p.nr_pedido_distribuidora)
inner join pedido_almoxarifado  pa on  (pa.cd_filial = pda.cd_filial and pa.nr_pedido = pda.nr_pedido_almoxarifado)
inner join dbo.pedido_almoxarifado_produto pap on pa.cd_filial = pap.cd_filial and pa.nr_pedido = pap.nr_pedido and pap.cd_produto = pp.cd_produto 
left outer join wms_transferencia_estoque wte on wte.nr_pedido_distribuidora = p.nr_pedido_distribuidora and wte.cd_filial_destino = p.cd_filial
where p.cd_filial 						= :al_cd_filial
   and p.nr_pedido_distribuidora 	= :al_nr_pedido_distribuidora
   and substring(pg.cd_subcategoria, 1,1) <> '1' 
	and p.id_pedido_almoxarifado = 'S'
	and p.id_tipo_pedido 			<> '6'
   and pp.qt_separada 				> 0 
	and COALESCE(pp.qt_separada, 0) > COALESCE(pp.qt_faturada, 0)
	and pa.cd_centro_custo is not null

	union

select p.nr_pedido_distribuidora as number_po,
		  	 coalesce(t.id_tipo_pedido_sap, 'X') as tp_po,
		    '1156' as center_provider,
		    '' as code_pgto,
		    CONVERT( CHAR(10), p.dh_emissao, 104 ) date,
		    0 as item_po,
		    pg.cd_produto_sap as material,
 		    dbo.retorna_um_compra_sap(pp.cd_produto) as unidade_medida,
		    pp.qt_separada as amount,
		    int.cd_chave_sap as store,
		    '' batch,
		    '' fab_date, 
		    '' exp_date,
		    case when pg.cd_grupo_psico is null then 'N' else 'S' end as id_controlado,
 		    p.cd_distribuidora,
		    coalesce(p.cd_centro_custo,  pa.cd_centro_custo) cd_centro_custo_legado,
		    p.id_pedido_almoxarifado,
			 substring(pg.cd_subcategoria, 1,1) as cd_categoria,
			 pp.cd_produto as cd_produto,
			 coalesce(t.de_tipo, '') as de_tipo_pedido,
			 coalesce(pp.de_motivo_rejeicao, '') as de_motivo_rejeicao,
			 coalesce(pp.qt_lista_separacao, 0) as qt_atendida,
			 COALESCE (t.cd_deposito_sap, ''),
			 COALESCE (t.id_sobra, 'N'),
			wte.cd_filial_origem
from pedido_distribuidora p
left outer join tipo_pedido_distribuidora t on (t.id_tipo	= p.id_tipo_pedido)
inner join pedido_distribuidora_produto pp on (pp.cd_filial = p.cd_filial and pp.nr_pedido_distribuidora = p.nr_pedido_distribuidora)
inner join produto_geral pg on( pg.cd_produto = pp.cd_produto)
inner join integracao_sap int on (int.cd_chave_legado 	= cast(p.cd_filial as varchar) and int.cd_tabela 			= 'FILIAL')
inner join pedido_distribuidora_almox pda on (pda.cd_filial = p.cd_filial and pda.nr_pedido_distribuidora = p.nr_pedido_distribuidora)
inner join pedido_almoxarifado  pa on  (pa.cd_filial = pda.cd_filial and pa.nr_pedido = pda.nr_pedido_almoxarifado)
inner join dbo.pedido_almoxarifado_produto pap on pa.cd_filial = pap.cd_filial and pa.nr_pedido = pap.nr_pedido and pap.cd_produto = pp.cd_produto 
left outer join wms_transferencia_estoque wte on wte.nr_pedido_distribuidora = p.nr_pedido_distribuidora and wte.cd_filial_destino = p.cd_filial
where p.cd_filial 						= :al_cd_filial
   and p.nr_pedido_distribuidora 	= :al_nr_pedido_distribuidora
   and substring(pg.cd_subcategoria, 1,1) <> '1' 
	and p.id_pedido_almoxarifado = 'S'
	and p.id_tipo_pedido 			<> '6'
   and pp.qt_separada 				> 0 
	and COALESCE(pp.qt_separada, 0) > COALESCE(pp.qt_faturada, 0)
	and pa.cd_centro_custo is null
	and not exists (select 1 from 
	pedido_distribuidora_almox pda2 
	inner join pedido_almoxarifado  pa2 on  (pa2.cd_filial = pda2.cd_filial and pa2.nr_pedido = pda2.nr_pedido_almoxarifado)
	inner join dbo.pedido_almoxarifado_produto pap2 on pa2.cd_filial = pap2.cd_filial and pa2.nr_pedido = pap2.nr_pedido and pap2.cd_produto = pp.cd_produto
	where pa2.cd_centro_custo is not null
	and (pda2.cd_filial = p.cd_filial and pda2.nr_pedido_distribuidora = p.nr_pedido_distribuidora)
	)

	union

 	select p.nr_pedido_distribuidora as number_po,
		  	 coalesce(t.id_tipo_pedido_sap, 'X') as tp_po,
		    '1156' as center_provider,
		    '' as code_pgto,
		    CONVERT( CHAR(10), p.dh_emissao, 104 ) date,
		    0 as item_po,
		    pg.cd_produto_sap as material,
 		    dbo.retorna_um_compra_sap(pp.cd_produto) as unidade_medida,
		    pp.qt_separada as amount,
		    int.cd_chave_sap as store,
		    '' batch,
		    '' fab_date, 
		    '' exp_date,
		    case when pg.cd_grupo_psico is null then 'N' else 'S' end as id_controlado,
 		    p.cd_distribuidora,
		    p.cd_centro_custo cd_centro_custo_legado,
		    p.id_pedido_almoxarifado,
			 substring(pg.cd_subcategoria, 1,1) as cd_categoria,
			 pp.cd_produto as cd_produto,
			 coalesce(t.de_tipo, '') as de_tipo_pedido,
			 coalesce(pp.de_motivo_rejeicao, '') as de_motivo_rejeicao,
			 coalesce(pp.qt_lista_separacao, 0) as qt_atendida,
			 COALESCE (t.cd_deposito_sap, ''),
			 COALESCE (t.id_sobra, 'N'),
			wte.cd_filial_origem
from pedido_distribuidora p
left outer join tipo_pedido_distribuidora t on (t.id_tipo	= p.id_tipo_pedido)
inner join pedido_distribuidora_produto pp on (pp.cd_filial = p.cd_filial and pp.nr_pedido_distribuidora = p.nr_pedido_distribuidora)
inner join produto_geral pg on( pg.cd_produto = pp.cd_produto)
inner join integracao_sap int on (int.cd_chave_legado 	= cast(p.cd_filial as varchar) and int.cd_tabela 			= 'FILIAL')
left outer join wms_transferencia_estoque wte on wte.nr_pedido_distribuidora = p.nr_pedido_distribuidora and wte.cd_filial_destino = p.cd_filial
where  p.cd_filial 						= :al_cd_filial
   and p.nr_pedido_distribuidora 	= :al_nr_pedido_distribuidora
   and substring(pg.cd_subcategoria, 1,1) <> '1' 
	and p.id_pedido_almoxarifado = 'S'
	and p.id_tipo_pedido 			= '6'
   and pp.qt_separada 				> 0 
	and COALESCE(pp.qt_separada, 0) > COALESCE(pp.qt_faturada, 0)

union

select p.nr_pedido_distribuidora as number_po,
		  	 coalesce(t.id_tipo_pedido_sap, 'X') as tp_po,
		    '1156' as center_provider,
		    '' as code_pgto,
		    CONVERT( CHAR(10), p.dh_emissao, 104 ) date,
		    0 as item_po,
		    pg.cd_produto_sap as material,
 		    dbo.retorna_um_compra_sap(pp.cd_produto) as unidade_medida,
		    pp.qt_separada as amount,
		    int.cd_chave_sap as store,
		    '' batch,
		    '' fab_date, 
		    '' exp_date,
		    case when pg.cd_grupo_psico is null then 'N' else 'S' end as id_controlado,
 		    p.cd_distribuidora,
		    p.cd_centro_custo cd_centro_custo_legado,
		    p.id_pedido_almoxarifado,
			 substring(pg.cd_subcategoria, 1,1) as cd_categoria,
			 pp.cd_produto as cd_produto,
			 coalesce(t.de_tipo, '') as de_tipo_pedido,
			 coalesce(pp.de_motivo_rejeicao, '') as de_motivo_rejeicao,
			 coalesce(pp.qt_lista_separacao, 0) as qt_atendida,
			 COALESCE (t.cd_deposito_sap, ''),
			 COALESCE (t.id_sobra, 'N'),
			wte.cd_filial_origem
from pedido_distribuidora p
left outer join tipo_pedido_distribuidora t on (t.id_tipo	= p.id_tipo_pedido)
inner join pedido_distribuidora_produto pp on (pp.cd_filial = p.cd_filial and pp.nr_pedido_distribuidora = p.nr_pedido_distribuidora)
inner join produto_geral pg on( pg.cd_produto = pp.cd_produto)
inner join integracao_sap int on (int.cd_chave_legado 	= cast(p.cd_filial as varchar) and int.cd_tabela 			= 'FILIAL')
left outer join wms_transferencia_estoque wte on wte.nr_pedido_distribuidora = p.nr_pedido_distribuidora and wte.cd_filial_destino = p.cd_filial
where p.cd_filial 						= :al_cd_filial
   and p.nr_pedido_distribuidora 	= :al_nr_pedido_distribuidora
   and substring(pg.cd_subcategoria, 1,1) <> '1' 
	and p.id_pedido_almoxarifado = 'N'
   and pp.qt_separada 				> 0 
	and COALESCE(pp.qt_separada, 0) > COALESCE(pp.qt_faturada, 0)" arguments=(("al_cd_filial", number),("al_nr_pedido_distribuidora", number))  sort="item_po A " )
