table(column=(type=long updatewhereclause=yes name=item_po dbname="licitacao_pedido_produto.item_po" dbalias="lpp.item_po" )
 column=(type=char(20) updatewhereclause=yes name=material dbname="produto_geral.material" dbalias="pg.material" )
 column=(type=char(3) updatewhereclause=yes name=unidade_medida dbname="unidade_medida" )
 column=(type=long updatewhereclause=yes name=amount dbname="licitacao_pedido_produto_lote.amount" dbalias="lppl.amount" )
 column=(type=decimal(13) updatewhereclause=yes name=price dbname="price" )
 column=(type=decimal(2) updatewhereclause=yes name=desconto dbname="licitacao_pedido_produto.desconto" dbalias="lpp.desconto" )
 column=(type=char(20) updatewhereclause=yes name=store dbname="cliente.store" dbalias="c.store" )
 column=(type=char(1) updatewhereclause=yes name=date_shipping dbname="date_shipping" )
 column=(type=char(20) updatewhereclause=yes name=batch dbname="licitacao_pedido_produto_lote.batch" dbalias="lppl.batch" )
 column=(type=datetime updatewhereclause=yes name=prod_date dbname="prod_date" )
 column=(type=datetime updatewhereclause=yes name=expirydate dbname="expirydate" )
 column=(type=char(1) updatewhereclause=yes name=lgort dbname="lgort" )
 column=(type=char(1) updatewhereclause=yes name=umlgo dbname="umlgo" )
 retrieve="select	lpp.nr_item as item_po,   
		pg.cd_produto_sap as material, 
		(select dbo.retorna_um_compra_sap(lpp.cd_produto)) as unidade_medida,
		lppl.qt_lote as amount,
		(CASE WHEN vl_total is null THEN lpp.vl_preco_unitario ELSE round(lpp.vl_total / lpp.qt_pedida, 6) END) as price,
		lpp.pc_desconto as desconto,
		c.cd_cliente_sap as store,
		'' as date_shipping,
		lppl.nr_lote as batch,
		coalesce(lppl.dh_fabricacao, pl.dh_fabricacao) as prod_date,
		coalesce(lppl.dh_validade, pl.dh_validade) as expirydate,
		'' as lgort,
		'' as umlgo
from licitacao_pedido lp
inner join licitacao_pedido_produto lpp on (lpp.nr_pedido = lp.nr_pedido)
left outer join licitacao_pedido_produto_lote lppl on (lppl.nr_pedido = lpp.nr_pedido and lppl.nr_item = lpp.nr_item)
left outer join produto_geral pg on (pg.cd_produto = lpp.cd_produto)
left outer join produto_lote pl on (pl.cd_produto = lpp.cd_produto and pl.nr_lote = lppl.nr_lote)
left outer join cliente c on (c.cd_cliente = lp.cd_cliente_entrega)
where lp.nr_pedido = :p_nr_pedido
" arguments=(("p_nr_pedido", number)) )
