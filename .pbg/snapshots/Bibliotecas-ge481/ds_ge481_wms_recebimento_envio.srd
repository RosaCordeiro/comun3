table(column=(type=decimal(0) update=yes updatewhereclause=yes key=yes name=nr_atualizacao dbname="log_exportacao_sap.nr_atualizacao" dbalias="lo.nr_atualizacao" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="log_exportacao_sap.cd_filial" dbalias="lo.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="log_exportacao_sap.nr_nf" dbalias="lo.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="log_exportacao_sap.de_especie" dbalias="lo.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="log_exportacao_sap.de_serie" dbalias="lo.de_serie" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="log_exportacao_sap.cd_fornecedor" dbalias="lo.cd_fornecedor" )
 retrieve="  SELECT	lo.nr_atualizacao,   
           	lo.cd_filial,   
         	lo.nr_nf,   
         	lo.de_especie,   
         	lo.de_serie,   
         	lo.cd_fornecedor
    FROM log_exportacao_sap  lo 
Where lo.id_tipo_nf = 'WMR'
	and lo.id_status_integracao = 'C'
	and lo.cd_tipo_documento = 'WMS'

" update="log_exportacao_sap" updatewhere=1 updatekeyinplace=no )
