table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_tabela dbname="tabela_interface_sap.cd_tabela" dbalias="t.cd_tabela" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_tabela dbname="tabela_interface_sap.nm_tabela" dbalias="t.nm_tabela" )
 column=(type=char(100) update=yes updatewhereclause=yes name=de_tabela dbname="tabela_interface_sap.de_tabela" dbalias="t.de_tabela" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_executa dbname="id_executa" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_subida_descida dbname="tabela_interface_sap.id_subida_descida" dbalias="t.id_subida_descida" )
 column=(type=char(11) updatewhereclause=yes name=tipo dbname="tipo" )
 column=(type=char(2) updatewhereclause=yes name=cd_sistema dbname="cd_sistema" )
 column=(type=long updatewhereclause=yes name=nr_ordenacao dbname="tabela_interface_sap.nr_ordenacao" dbalias="t.nr_ordenacao" )
 retrieve="SELECT	t.cd_tabela,   
        	t.nm_tabela,   
        	t.de_tabela,
		'S' id_executa, 
		t.id_subida_descida, 
	 case t.id_subida_descida when 'D' then 'SAP->LEGADO' when 'S' then  'LEGADO->SAP' else '' end as tipo, 
     isnull(t.cd_sistema, ' ') as cd_sistema,
	t.nr_ordenacao
    FROM tabela_interface_sap t
where t.id_situacao = 'A'
	and t.id_tabela_pai = 'S'
" update="tabela_interface_sap" updatewhere=0 updatekeyinplace=no  sort="de_tabela A " )
