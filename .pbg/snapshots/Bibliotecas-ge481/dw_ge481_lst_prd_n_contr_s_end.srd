table(column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(112) updatewhereclause=yes name=nm_produto dbname="nm_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="de_grupo" )
 column=(type=char(1) updatewhereclause=yes name=cd_curva_abc_filiais dbname="cd_curva_abc_filiais" )
 column=(type=char(1) updatewhereclause=yes name=id_exclusivo_pedido_falta_ba dbname="id_exclusivo_pedido_falta_ba" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="qt_recebida" )
 column=(type=long updatewhereclause=yes name=qt_mes1 dbname="qt_mes1" )
 column=(type=long updatewhereclause=yes name=qt_mes2 dbname="qt_mes2" )
 column=(type=long updatewhereclause=yes name=qt_mes3 dbname="qt_mes3" )
 column=(type=long updatewhereclause=yes name=qt_mes_atual dbname="qt_mes_atual" )
 column=(type=char(73) updatewhereclause=yes name=de_filial dbname="de_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=long updatewhereclause=yes name=qt_total dbname="qt_total" )
 column=(type=number updatewhereclause=yes name=qt_media dbname="qt_media" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="nr_lote" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo dbname="de_subgrupo" )
 column=(type=char(14) updatewhereclause=yes name=tipo dbname="tipo" )
 retrieve="Select  cd_produto,
nm_produto,
de_grupo,
cd_curva_abc_filiais,
id_exclusivo_pedido_falta_ba,
qt_recebida,
qt_mes1,
qt_mes2,
qt_mes3,
qt_mes_atual,
de_filial,
nr_nf,
de_especie,
de_serie,
(qt_mes1 + qt_mes2 + qt_mes3 + qt_mes_atual) as qt_total,
round(cast((qt_mes1 + qt_mes2 + qt_mes3 + qt_mes_atual) as float) / 
		dbo.diasuteis( DATEADD( MONTH, -3, cast(DATEPART( YEAR, getdate() ) as varchar)+right('0'+cast(DATEPART( MONTH, getdate() ) as varchar),2)+'01' ), getDate()), 2) as qt_media,
nr_lote,
de_subgrupo,
'NAO CONTROLADO'  as tipo 
From(
		 SELECT	distinct a.cd_produto,   
					g.de_produto + ' : ' +  g.de_apresentacao_estoque + ' (' + cast(a.cd_produto as char(6)) + ')' nm_produto,
					c.de_grupo,
					isnull(pc.cd_curva_abc_filiais, 'E') as cd_curva_abc_filiais,
					coalesce(pc.id_exclusivo_pedido_falta_ba, 'N') as id_exclusivo_pedido_falta_ba,
					'('+Cast(f.cd_filial as varchar)+') '+f.nm_fantasia as de_filial,
					a.nr_nf,
					a.de_especie,
					a.de_serie,
					
					isnull((Select  qt_transferida
						From resumo_transferencia_perini
						Where dh_resumo 	= DATEADD( MONTH, -3, cast(DATEPART( YEAR, getdate() ) as varchar)+right('0'+cast(DATEPART( MONTH, getdate() ) as varchar),2)+'01' )
						and cd_produto	= g.cd_produto), 0) as qt_mes1,
			
					isnull((Select  qt_transferida
						From resumo_transferencia_perini
						Where dh_resumo 	= DATEADD( MONTH, -2, cast(DATEPART( YEAR, getdate() ) as varchar)+right('0'+cast(DATEPART( MONTH, getdate() ) as varchar),2)+'01' )
						and cd_produto	= g.cd_produto), 0) as qt_mes2,
			
					isnull((Select  qt_transferida
						From resumo_transferencia_perini
						Where dh_resumo 	= DATEADD( MONTH, -1, cast(DATEPART( YEAR, getdate() ) as varchar)+right('0'+cast(DATEPART( MONTH, getdate() ) as varchar),2)+'01' )
						and cd_produto	= g.cd_produto), 0) as qt_mes3,
			
					isnull((Select  qt_transferida
						From resumo_transferencia_perini
						Where dh_resumo 	= cast(DATEPART( YEAR, getdate() ) as varchar)+right('0'+cast(DATEPART( MONTH, getdate() ) as varchar),2)+'01' 
						and cd_produto	= g.cd_produto), 0) as qt_mes_atual,

					sum(a.qt_recebida) as qt_recebida,
 					space(20) as nr_lote,  
		            	c.de_subgrupo  		
		FROM	item_nf_transferencia a
		inner join produto_geral g on g.cd_produto = a.cd_produto
		inner join vw_classificacao_produto c on c.cd_subcategoria = g.cd_subcategoria
		inner join produto_central pc on pc.cd_produto = g.cd_produto
		inner join filial f on f.cd_filial = a.cd_filial_origem		
 WHERE a.cd_filial_origem = :cd_filial
            and a.nr_nf = :nr_nf
            and a.de_especie = :de_especie
            and a.de_serie = :de_serie
		and substring(g.cd_subcategoria, 1, 1) <> '5'
         and a.qt_recebida > 0		
		and ((g.cd_grupo_psico is null and coalesce(pc.id_vigiado, 'N') = 'N') or coalesce(g.id_geladeira, 'N') = 'S')     //// NAO CONTROLADO : N$$HEX1$$c300$$ENDHEX$$O PRECISA DE LOTE
		and not exists (select * from wms_endereco_produto where cd_produto = a.cd_produto)
		group by  a.cd_produto,
					g.de_produto, 
					g.de_apresentacao_estoque,
					c.de_grupo,
					pc.cd_curva_abc_filiais,
					pc.id_exclusivo_pedido_falta_ba,
					g.cd_produto,
					f.cd_filial,
					f.nm_fantasia,
					a.nr_nf,
					a.de_especie,
					a.de_serie, 					
		            	c.de_subgrupo  
) as tudo" arguments=(("cd_filial", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
