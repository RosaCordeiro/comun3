table(column=(type=decimal(0) updatewhereclause=yes name=filial_mult dbname="m3_filial.filial_mult" )
 column=(type=char(40) updatewhereclause=yes name=filial_sap dbname="filial_sap" )
 column=(type=char(50) updatewhereclause=yes name=filial_fantasia dbname="mtmg_ident.filial_fantasia" )
 column=(type=datetime updatewhereclause=yes name=data_movimento dbname="m3_docto.data_movimento" )
 column=(type=char(2) updatewhereclause=yes name=ct_modelo dbname="m3_modelodoct.modelo" )
 column=(type=char(3) updatewhereclause=yes name=docto_serie dbname="m3_seriedocto.serie" )
 column=(type=decimal(0) updatewhereclause=yes name=docto dbname="m3_docto.docto" )
 column=(type=char(10) updatewhereclause=yes name=tipo_codigo dbname="m3_tipdoc.tipo_codigo" )
 column=(type=char(80) updatewhereclause=yes name=tipo_descricao dbname="m3_tipdoc.tipo_descricao" )
 column=(type=char(20) updatewhereclause=yes name=destino_cnpj dbname="mtmg_ident.destino_cnpj" )
 column=(type=char(50) updatewhereclause=yes name=destino_fantasia dbname="mtmg_ident.destino_fantasia" )
 column=(type=char(19) updatewhereclause=yes name=data_digitacao dbname="data_digitacao" )
 column=(type=char(1) updatewhereclause=yes name=cancelada dbname="cancelada" )
 column=(type=number updatewhereclause=yes name=valor_nf dbname="valor_nf" )
 retrieve=" SELECT fil.codigo as filial_mult,
        CASE WHEN ins.cd_chave_sap = '1001' THEN '1002' ELSE ins.cd_chave_sap END as filial_sap,
        fia.fantasia as filial_fantasia,
        DOC.DTENTSAI as data_movimento,
        MOD.CODMODELO as modelo,
        SER.CODIGO as serie,
        DOC.NRODOCTO as docto,
        TIP.CODTPDOCTO as tipo_codigo,
        TIP.DESCRICAO as tipo_descricao,
        PAR.IDENTIFICACAO as destino_cnpj,
        PAR.FANTASIA as destino_fantasia,
        TO_CHAR(DOC.DATADIGITACAO,'DD/MM/YYYY')||' '||To_CHAR(DOC.HORAEMI,'HH24:MI:SS') as data_digitacao,
        case when DOC.SITUACAONF = '1' then 'X' else '' end cancelada,
        coalesce(TRF.VALTOTALNF, coalesce(com.valtotalnf, coalesce(rem.VALTOTALNF, dvc.valtotalnf))) as valor_nf

FROM m3_docto doc

INNER JOIN m3_tipdoc tip 					ON tip.ID = doc.idf_tpdocto /*tipo do doc.*/
INNER JOIN m3_partetpdoc ptd 			ON ptd.idf_tipdoc = tip.ID /*parte tip.doc*/
INNER JOIN m3_tpdoctoger tdg 			ON tdg.ida = ptd.ID /*inf.ger doc*/

INNER JOIN m3_filial fil 						ON fil.ID = doc.idf_filial /*filial do doc.*/
INNER JOIN mtmg_papelrel pap 			ON pap.ID = fil.ida /* papel da filial*/
INNER JOIN mtmg_ident fia 					ON fia.ID = pap.idf_ident /*identificacao da filial*/


INNER JOIN mtmg_ident par 				ON par.ID = doc.idf_ident /*identificacao do parceiro*/
LEFT OUTER JOIN mtmg_pesjur pjp 		ON pjp.ida = par.ID /*dados pj do parceiro*/
LEFT OUTER JOIN m3_seriedocto ser 	ON ser.ID = doc.idf_seriedocto /*serie da nf*/
LEFT OUTER JOIN m3_modelodoct MOD 	ON MOD.ID = tdg.idf_modelodoct /*modelo doc. nfe*/

LEFT OUTER JOIN integracao_sap ins 	ON ins.cd_empresa = 1000 AND ins.cd_tabela = 'FILIAL' AND ins.cd_chave_legado = fil.codigo /*de-para filial - sap*/

/*Tabelas espec$$HEX1$$ed00$$ENDHEX$$ficas por documento*/
LEFT OUTER JOIN m3_doctotrffi trf on TRF.IDA = doc.id --Transfer$$HEX1$$ea00$$ENDHEX$$ncia
LEFT OUTER JOIN m3_doctormrt rem on rem.ida = doc.id --Remessa/Retorno 
LEFT OUTER JOIN m3_doctodefor dvc on dvc.ida = doc.id --Devolu$$HEX2$$e700e300$$ENDHEX$$o Compra
LEFT OUTER JOIN m3_doctontfic com on com.ida = doc.id --Compra

WHERE /*doc.dtentsai between :p_dt_ini AND :p_dt_fin data de emissao*/
  /* AND tip.idf_padraodocto IN(61,62, 68,69,71, 66,67,70, 50,51, 52,53) */
  /* AND fil.idf_empresa = :p_empresa empresa*/  
/* AND */
NOT EXISTS(SELECT 1
                  FROM integracao_sap_excecao ise
                 WHERE ise.cd_tabela = 'TIPO_DOCUMENTO'
                   AND ise.cd_tipo IN('INTEGRACAO_TDF')
                   AND ise.vl_parametro = 'N'
                   AND lower(ise.cd_chave) = lower(tip.codtpdocto)) /*excecoes por tipo de documento*/
  AND NOT EXISTS (SELECT 1 
                    FROM log_exportacao_docto l1
                   WHERE l1.cd_filial = fil.codigo
					AND l1.cd_fornecedor = pjp.cnpj
                     AND l1.nr_nf = doc.nrodocto
                     AND TRIM(l1.de_especie) = TRIM(mod.codmodelo)
                     AND l1.de_serie = COALESCE(ser.codigo,'0')
                     AND l1.cd_integracao = 'PADRAO'
                    /*AND l1.id_tipo_docto = 'NTE' Nota Fiscal Transferencia (Entrada)*/
                   /*  AND l1.cd_ambiente_sap = :p_ambiente  */
                     AND l1.id_situacao_log = 'P') /*Exceto documentos ja integrados com o TDF*/ 
  
  union
  
SELECT fil.codigo as filial_mult,
        CASE WHEN ins.cd_chave_sap = '1001' THEN '1002' ELSE ins.cd_chave_sap END AS filial_sap, /*cod. filial */
        fia.fantasia as filial_fantasia,
        DOC.DTENTSAI as data_movimento,
        MOD.CODMODELO as modelo,
        SER.CODIGO as serie,
        DOC.NRODOCTO as docto,
        TIP.CODTPDOCTO as tipo_codigo,
        TIP.DESCRICAO as tipo_descricao,
        PAR.IDENTIFICACAO as destino_cnpj,
        PAR.FANTASIA as destino_fantasia,
        TO_CHAR(DOC.DATADIGITACAO,'DD/MM/YYYY')||' '||To_CHAR(DOC.HORAEMI,'HH24:MI:SS') as data_digitacao,
        case when DOC.SITUACAONF = '1' then 'X' else '' end cancelada,
        fre.valorfrete AS valor_nf

FROM m3_docto doc /* extensao do documento */

INNER JOIN m3_partedocto pdo1 ON pdo1.idf_docto = doc.ID /*Parte de documento*/
INNER JOIN m3_pardccofre fre ON fre.ida = pdo1.id /*Conhecimento de frete*/
INNER JOIN m3_tipdoc tip ON tip.ID = doc.idf_tpdocto /*tipo do doc.*/
INNER JOIN m3_partetpdoc ptd ON ptd.idf_tipdoc = tip.ID /*parte tip.doc*/
INNER JOIN m3_tpdoctoger tdg ON tdg.ida = ptd.ID /*inf.ger doc*/

INNER JOIN m3_filial fil ON fil.ID = doc.idf_filial /*filial do doc.*/
INNER JOIN mtmg_papelrel pap ON pap.ID = fil.ida /* papel da filial*/
INNER JOIN mtmg_ident fia ON fia.ID = pap.idf_ident /*identificacao da filial*/

INNER JOIN mtmg_ident par ON par.ID = doc.idf_ident /*identificacao do parceiro*/
LEFT OUTER JOIN mtmg_pesjur pjp ON pjp.ida = par.ID /*dados pj do parceiro*/

LEFT OUTER JOIN m3_seriedocto ser ON ser.ID = fre.idf_seriedocto /*serie da nf*/
LEFT OUTER JOIN integracao_sap ins ON ins.cd_empresa = 1000 AND ins.cd_tabela = 'FILIAL' AND ins.cd_chave_legado = fil.codigo /*de-para filial - sap*/
LEFT OUTER JOIN m3_modelodoct MOD ON MOD.ID = tdg.idf_modelodoct /*modelo doc. nfe*/

WHERE /* fre.dataentrada >= :p_dt_ini AND fre.dataentrada <= :p_dt_fin data de emissao*/
 /* AND tip.idf_padraodocto IN(40)  40-Fatura Conhecimento Frete*/
/*  AND fil.idf_empresa = :p_empresa empresa*/
/*  AND */
NOT EXISTS(SELECT 1
                  FROM integracao_sap_excecao ise
                 WHERE ise.cd_tabela = 'TIPO_DOCUMENTO'
                   AND ise.cd_tipo IN('INTEGRACAO_TDF')
                   AND ise.vl_parametro = 'N'
                   AND lower(ise.cd_chave) = lower(tip.codtpdocto)) /*excecoes por tipo de documento*/
 AND NOT EXISTS (SELECT 1 
                    FROM log_exportacao_docto l1
                   WHERE l1.cd_filial = fil.codigo
					AND l1.cd_fornecedor = pjp.cnpj
                     AND l1.nr_nf = doc.nrodocto
                     AND TRIM(l1.de_especie) = TRIM(mod.codmodelo)
                     AND l1.de_serie = COALESCE(ser.codigo,'0')
                     AND l1.cd_integracao = 'CTE'
                    /* AND l1.id_tipo_docto = 'NCF' Nota Fiscal de Conehcimento de Frete*/
                    /*   AND l1.cd_ambiente_sap = :p_ambiente */
                     AND l1.id_situacao_log <> 'X')     /*Exceto documentos ja integrados com o TDF*/ 
" )  /*arguments=(("p_ambiente", string),("p_empresa", number),("p_dt_ini", date),("p_dt_fin", date)) ) */
