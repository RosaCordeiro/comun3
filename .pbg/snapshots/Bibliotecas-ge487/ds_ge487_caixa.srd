table(column=(type=long updatewhereclause=yes name=filial_syb dbname="caixa.filial_syb" dbalias="cx.filial_syb" )
 column=(type=char(40) updatewhereclause=yes name=filial_fantasia dbname="filial.filial_fantasia" dbalias="f.filial_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=cd_filial_sap dbname="cd_filial_sap" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(2) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=char(5) updatewhereclause=yes name=tpo_lancto dbname="tpo_lancto" )
 column=(type=char(30) updatewhereclause=yes name=tpo_operacao dbname="tpo_operacao" )
 column=(type=long updatewhereclause=yes name=nr_ecf dbname="nr_ecf" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_operacao_ecf dbname="nr_operacao_ecf" )
 column=(type=datetime updatewhereclause=yes name=dh_movtacao_cx dbname="controle_caixa.dh_movtacao_cx" dbalias="cc.dh_movtacao_cx" )
 column=(type=date updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=date updatewhereclause=yes name=dh_cancelamento dbname="dh_cancelamento" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="cd_convenio" )
 column=(type=long updatewhereclause=yes name=nr_pedido_ecommerce dbname="nr_pedido_ecommerce" )
 column=(type=char(5) updatewhereclause=yes name=cd_setor dbname="cd_setor" )
 retrieve="Select  cx.cd_filial								as filial_syb,   
		f.nm_fantasia							as filial_fantasia,
		ifil.cd_chave_sap 						as cd_filial_sap,
		cast(cc.nr_controle_caixa as decimal)	as nr_nf,   
		(Case lc.cd_conta_fluxo_caixa when 85 then 'SBR' when 84 then 'QBR' else 'NMR' End) as de_especie,   
		right(cast(cx.cd_caixa as varchar), 2)	as de_serie,     
        (Case :ps_tipo_venda when 'CX' then 'CAIXA' End)  as tpo_lancto, 
 		cast(null as char)				    		as tpo_operacao,   
		cast(null as integer)					as nr_ecf, 
		cast(null as decimal)                   	as nr_operacao_ecf,
		cc.dh_movimentacao_caixa			as dh_movtacao_cx,      
		cast(null as date)						as dh_emissao,      
		coalesce(lc.vl_lancamento,0)		as vl_total_nf,   
		cast((Case lc.id_estorno when 'S' then cc.dh_movimentacao_caixa else null End)  as date) 	as dh_cancelamento, 
		cast(null as integer)					as cd_convenio, 
	    cast(null as integer)       				as nr_pedido_ecommerce,
    	(select Max(ledd.cd_setor)
			from log_exportacao_docto led (index idx_docto_ambiente)
			inner join log_exportacao_docto_det ledd (index pk_log_exportacao_docto_det)
			on ledd.nr_atualizacao_log = led.nr_atualizacao
		where led.cd_filial = cx.cd_filial
			and led.nr_nf = cast(cc.nr_controle_caixa as decimal)
			and led.de_especie = Case lc.cd_conta_fluxo_caixa when 85 then 'SBR' when 84 then 'QBR' else 'NMR' End
			and led.de_serie = right(cast(cx.cd_caixa as varchar), 2)
             and ledd.id_tipo_log = 'E'
             and (led.id_tipo_docto = :ps_tipo_venda or :ps_tipo_venda is null)
             and led.cd_ambiente_sap = :ps_ambiente_sap) as cd_setor	

from controle_caixa cc

Inner Join caixa cx
  on cx.cd_caixa  				= cc.cd_caixa
  and cx.id_caixa_geral 		= 'S'
  
Inner Join lancamento_caixa lc
     on lc.cd_conta_fluxo_caixa in (Select distinct lc3.cd_conta_fluxo_caixa from conta_fluxo_caixa lc3 where coalesce(lc3.id_exporta_sap, 'N') = 'S'  
                                            and (lc3.id_tipo_conta = 'D' or lc3.cd_conta_fluxo_caixa in (39, 84, 85))
                                            and (lc3.cd_tipo_numerario_sap is not null or (lc3.cd_tipo_numerario_sap is null and lc3.cd_conta_fluxo_caixa in (84,85)))    
                                    )
	and lc.nr_controle_caixa    = cc.nr_controle_caixa 
    and lc.cd_caixa          	= cc.cd_caixa

Inner Join filial f
    on f.cd_filial      			= cx.cd_filial

Left Outer join integracao_sap ifil (index pk_integracao_sap) on ifil.cd_tabela = 'FILIAL' and ifil.cd_empresa = 1000 and ifil.cd_chave_legado = cast(f.cd_filial as varchar)

Where cc.dh_movimentacao_caixa between :pdt_inicio and :pdt_fim
  and (cx.cd_filial = :pi_filial or :pi_filial = null)
  and  cc.dh_conferencia is not null

order by  1,11,5,4	
" arguments=(("pdt_inicio", date),("pdt_fim", date),("pi_filial", number),("ps_tipo_venda", string),("ps_ambiente_sap", string)) )
