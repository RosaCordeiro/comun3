table(column=(type=long updatewhereclause=yes name=cheque_filial_syb dbname="cheque.filial_syb" dbalias="ch.filial_syb" )
 column=(type=char(40) updatewhereclause=yes name=filial_fantasia dbname="filial_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=cd_filial_sap dbname="cd_filial_sap" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=char(16) updatewhereclause=yes name=tpo_lancto dbname="tpo_lancto" )
 column=(type=char(2) updatewhereclause=yes name=tpo_operacao dbname="tpo_operacao" )
 column=(type=long updatewhereclause=yes name=nr_ecf dbname="nr_ecf" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_operacao_ecf dbname="nr_operacao_ecf" )
 column=(type=datetime updatewhereclause=yes name=dh_movtacao_cx dbname="cheque.dh_movtacao_cx" dbalias="ch.dh_movtacao_cx" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="cheque.dh_emissao" dbalias="ch.dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="cheque.vl_total_nf" dbalias="ch.vl_total_nf" )
 column=(type=date updatewhereclause=yes name=dh_cancelamento dbname="dh_cancelamento" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="cd_convenio" )
 column=(type=long updatewhereclause=yes name=nr_pedido_ecommerce dbname="nr_pedido_ecommerce" )
 column=(type=char(5) updatewhereclause=yes name=cd_setor dbname="cd_setor" )
 retrieve="Select  ch.cd_filial_atualizacao						as filial_syb,   
		f.nm_fantasia									as filial_fantasia,
		ifil.cd_chave_sap 								as cd_filial_sap,
		cast(ch.nr_cheque  as decimal)        		as nr_nf,  
		'PGT'								            		as de_especie,   
		cast(ch.nr_agencia as char(3))				as de_serie,   
    		(Case :ps_tipo_venda when 'PGT' then 'PAGAMENTO-CH' End) as tpo_lancto, 
 		'AV'  								            		as tpo_operacao,
		cast(null as integer)							as nr_ecf, 
		cast(ch.nr_cpf_cliente as decimal)			as nr_operacao_ecf, 
		ch.dh_baixa					                    	as dh_movtacao_cx,      
		ch.dh_emissao						            	as dh_emissao,  
		ch.vl_pago								        	as vl_total_nf,   
		cast(null as date)								as dh_cancelamento, 
		cast(null as integer) 							as cd_convenio, 
	    cast(null as integer)					    		as nr_pedido_ecommerce,
		(select Max(ledd.cd_setor)
			from log_exportacao_docto led (index idx_docto_ambiente)
		inner join log_exportacao_docto_det ledd (index pk_log_exportacao_docto_det)
			on ledd.nr_atualizacao_log = led.nr_atualizacao
		where led.cd_filial = ch.cd_filial_atualizacao
			and led.nr_nf = cast(ch.nr_cheque  as decimal) 
			and led.de_especie = 'PGT'
			and led.de_serie = cast(ch.nr_agencia as char(3))
			and ledd.id_tipo_log = 'E'
			and (led.id_tipo_docto = :ps_tipo_venda or :ps_tipo_venda is null)
			and led.cd_ambiente_sap = :ps_ambiente_sap) as cd_setor		

from cheque ch

Inner join filial f (index pk_filial) 	on f.cd_filial = ch.cd_filial_atualizacao
Left outer join integracao_sap ifil (index pk_integracao_sap) 	on ifil.cd_tabela = 'FILIAL'  and ifil.cd_empresa = 1000 and ifil.cd_chave_legado = cast(f.cd_filial as varchar)

where ch.dh_baixa is not null
and (ch.cd_filial_atualizacao = :pi_filial or :pi_filial is null )
and ch.dh_emissao  between :pdt_inicio and :pdt_fim
and ch.cd_motivo_devolucao is not null

UNION 

Select  crm.cd_filial						            		as filial_mult,   
		f.nm_fantasia										as filial_fantasia,
		ifil.cd_chave_sap 									as cd_filial_sap,
		cast(substring(crm.nr_documento,6,7) as decimal) as nr_nf,
		'CNT'								            			as de_especie,   
		crm.id_tipo_conta									as de_serie,   
        (Case :ps_tipo_venda when 'PGT' then 'PAGAMENTO-CONTA' End) 	as tpo_lancto, 
 		'AV'  								            			as tpo_operacao,
		cast(null as integer)								as nr_ecf, 
		cast(null as decimal)     	        		   		 	as nr_operacao_ecf,
		crm.dh_movimento				              	as dh_movtacao_cx,      
		crm.dh_movimento						     	as dh_emissao,  
		crm.vl_movimento									as vl_total_nf,   
		cast(null as date)							    		as dh_cancelamento, 
		cast(null as integer) 								as cd_convenio, 
	    cast(null as integer)					    			as nr_pedido_ecommerce,
		(select Max(ledd.cd_setor)
			from log_exportacao_docto led (index idx_docto_ambiente)
		inner join log_exportacao_docto_det ledd (index pk_log_exportacao_docto_det)
			on ledd.nr_atualizacao_log = led.nr_atualizacao
		where led.cd_filial = crm.cd_filial
			and led.nr_nf = cast(substring(crm.nr_documento,6,7) as decimal)
			and led.de_especie = 'CNT'
			and led.de_serie = crm.id_tipo_conta
			and ledd.id_tipo_log = 'E'
			and (led.id_tipo_docto = :ps_tipo_venda or :ps_tipo_venda is null)
			and led.cd_ambiente_sap = :ps_ambiente_sap) as cd_setor	
		
from contas_receber_movimento crm

inner join filial f (index pk_filial) 	on f.cd_filial = crm.cd_filial
left outer join integracao_sap ifil (index pk_integracao_sap) on ifil.cd_tabela = 'FILIAL'  and ifil.cd_empresa = 1000 and ifil.cd_chave_legado = cast(f.cd_filial as varchar)

inner join contas_receber_tipo_movimento crtm
 on crm.cd_tipo_movimento = crtm.cd_tipo_movimento

where   crtm.id_pagamento_titulo = 'S'
and crm.dh_movimento between :pdt_inicio and :pdt_fim
and (crm.cd_filial = :pi_filial or :pi_filial is null )

UNION

Select  tr.cd_filial						            			as filial_mult,   
		f.nm_fantasia										as filial_fantasia,
		ifil.cd_chave_sap 									as cd_filial_sap,
		cast(tr.nr_titulo as decimal)                   	    	as nr_nf,   
		'TIT'								            			as de_especie,   
		tr.de_serie								        		as de_serie,   
        (Case :ps_tipo_venda when 'PGT' then 'PAGAMENTO-T$$HEX1$$cd00$$ENDHEX$$TULO' End) as tpo_lancto, 
 		'AV'  								            			as tpo_operacao,
		cast(null as integer)								as nr_ecf, 
		cast(null as decimal)    	        		    			as nr_operacao_ecf,
		tr.dh_emissao				                    		as dh_movtacao_cx,      
		tr.dh_emissao						            		as dh_emissao,  
		tr.vl_recebido								    		as vl_total_nf,    
		cast(null as date)							    		as dh_cancelamento, 
		tr.cd_convenio								    		as cd_convenio, 
	    cast(null as integer)					    			as nr_pedido_ecommerce,
		(select Max(ledd.cd_setor)
			from log_exportacao_docto led (index idx_docto_ambiente)
		inner join log_exportacao_docto_det ledd (index pk_log_exportacao_docto_det)
			on ledd.nr_atualizacao_log = led.nr_atualizacao
		where led.cd_filial =  tr.cd_filial
			and led.nr_nf = cast(tr.nr_titulo as decimal)
			and led.de_especie = 'TIT'
			and led.de_serie = tr.de_serie
			and ledd.id_tipo_log = 'E'
			and (led.id_tipo_docto = :ps_tipo_venda or :ps_tipo_venda is null)
			and led.cd_ambiente_sap = :ps_ambiente_sap) as cd_setor	
		
from titulo_receber tr

inner join movimento_titulo_receber mtr0 on mtr0.nr_titulo = tr.nr_titulo

inner join filial f (index pk_filial)  on f.cd_filial = tr.cd_filial
left outer join integracao_sap ifil (index pk_integracao_sap) on ifil.cd_tabela = 'FILIAL' and ifil.cd_empresa = 1000 and ifil.cd_chave_legado = cast(f.cd_filial as varchar)

where tr.dh_emissao between :pdt_inicio and :pdt_fim
	and (tr.cd_filial  = :pi_filial or :pi_filial is null )
	and mtr0.cd_tipo_movimento  = 3  /*3	PAGAMENTO*/

	and not exists (Select 1  from  movimento_titulo_receber mtra
						 where mtra.cd_tipo_movimento in (2,4,5,6) 
						   and mtra.nr_titulo = tr.nr_titulo) 

" arguments=(("pdt_inicio", date),("pdt_fim", date),("pi_filial", number),("ps_tipo_venda", string),("ps_ambiente_sap", string)) )
