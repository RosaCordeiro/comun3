table(column=(type=long updatewhereclause=yes name=filial_syb dbname="filial_syb" )
 column=(type=char(40) updatewhereclause=yes name=filial_fantasia dbname="filial_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=cd_filial_sap dbname="cd_filial_sap" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=char(6) updatewhereclause=yes name=tpo_lancto dbname="tpo_lancto" )
 column=(type=char(3) updatewhereclause=yes name=tpo_operacao dbname="tpo_operacao" )
 column=(type=long updatewhereclause=yes name=nr_ecf dbname="nr_ecf" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_operacao_ecf dbname="nr_operacao_ecf" )
 column=(type=datetime updatewhereclause=yes name=dh_movtacao_cx dbname="dh_movtacao_cx" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="dh_cancelamento" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="cd_convenio" )
 column=(type=long updatewhereclause=yes name=nr_pedido_ecommerce dbname="nr_pedido_ecommerce" )
 column=(type=char(5) updatewhereclause=yes name=cd_setor dbname="cd_setor" )
 retrieve="Select  pe.cd_filial											as filial_syb,   
		f.nm_fantasia										as filial_fantasia,
		ifil.cd_chave_sap 									as cd_filial_sap,
		cast(pe.nr_pedido as decimal)					as nr_nf,  
		cast(coalesce(pea.id_rede_ecommerce, 'FA') as varchar(3)) 	as de_especie,  
		cast((Case when lc.cd_conta_fluxo_caixa in (172, 205) then 'A' else 'M' end) as varchar(3)) as de_serie,   
         (Case :ps_tipo_venda when  'PED' then 'PEDIDO'  End) as tpo_lancto, 
		'E'+cast(pe.id_pagamento as varchar(2))	as tpo_operacao,  
		cast(null as integer)								as nr_ecf, 
		cast(null as decimal)                                  as nr_operacao_ecf,
		cc.dh_movimentacao_caixa				        	as dh_movtacao_cx,      
		pe.dh_inclusao           							as dh_emissao,  
		coalesce(pe.vl_total,0)			        			as vl_total_nf,   
		coalesce(pe.dh_cancelamento,cast(null as datetime))	 as dh_cancelamento, 
		cast(null as integer)       							as cd_convenio, 
	     cast(pe.nr_pedido_ecommerce as integer)   as nr_pedido_ecommerce,
		(select Max(ledd.cd_setor)
			from log_exportacao_docto led (index idx_docto_ambiente)
			inner join log_exportacao_docto_det ledd (index pk_log_exportacao_docto_det)
			on ledd.nr_atualizacao_log = led.nr_atualizacao
		where led.cd_filial = pe.cd_filial
			and led.nr_nf = cast(pe.nr_pedido as decimal)
			and led.de_especie = cast(coalesce(pea.id_rede_ecommerce, 'FA') as varchar(3))
			and led.de_serie = cast((Case when lc.cd_conta_fluxo_caixa in (172, 205) then 'A' else 'M' end) as varchar(3))
				 and ledd.id_tipo_log = 'E'
				 and (led.id_tipo_docto = :ps_tipo_venda or :ps_tipo_venda is null)
				 and led.cd_ambiente_sap = :ps_ambiente_sap) as cd_setor
						
from pedido_ecommerce pe (index idx_filial_dh_inclusao)

Inner join filial f (index pk_filial) 	on f.cd_filial = pe.cd_filial

Inner join pedido_ecommerce_auxiliar pea (index pk_pedido_ecommerce_auxiliar)
	on pea.cd_filial_ecommerce = pe.cd_filial_ecommerce
   and pea.nr_pedido = pe.nr_pedido

Inner join caixa cx (index idx_filial_tipo)
	on cx.cd_filial = pe.cd_filial+0
	and cx.id_caixa_geral = 'S'

Inner join controle_caixa cc (index idx_data_caixa)
  on cx.cd_caixa = cc.cd_caixa+''

Inner join lancamento_caixa lc (index pk_lancamento_caixa)
	on lc.cd_caixa = cc.cd_caixa+''
   and lc.nr_controle_caixa 	= cc.nr_controle_caixa+0
	and lc.nr_documento = cast(pe.nr_pedido as varchar)

Left outer join integracao_sap ifv (index pk_integracao_sap)
	on ifv.cd_empresa = 1000
	and ifv.cd_tabela  = 'FINALIZADORA_VENDA'
	and ifv.cd_chave_legado = pe.cd_forma_pagamento

Left Outer Join integracao_sap ifil (index pk_integracao_sap)
	on ifil.cd_empresa = 1000
	and ifil.cd_tabela = 'FILIAL'
	and ifil.cd_chave_legado = cast(pe.cd_filial as varchar)

 where   ( pe.cd_filial 	= :pi_filial or :pi_filial is null)
    and  cc.dh_movimentacao_caixa  between :pdt_inicio and :pdt_fim	
	and pe.dh_inclusao between dateadd(dd, -3, :pdt_inicio) and dateadd(dd, 10,:pdt_fim)
	and pe.id_pagamento not in (3,19) 
	and (cx.cd_filial = :pi_filial or :pi_filial is null)
	and lc.cd_conta_fluxo_caixa not in (172, 205)
	and lc.id_estorno in ('N','X')
    and pe.nr_pedido_ecommerce is null 

Union

 Select  pe.cd_filial										as filial_syb,   
		f.nm_fantasia										as filial_fantasia,
		ifil.cd_chave_sap 									as cd_filial_sap,
		cast(pe.nr_pedido as decimal)					as nr_nf,  
		cast(coalesce(pea.id_rede_ecommerce, 'FA') as varchar(3))  	as de_especie,   
		'A'	                                            				as de_serie,    
          (Case :ps_tipo_venda when  'PED' then 'PEDIDO'  End) as tpo_lancto, 
 		'E'+cast(pe.id_pagamento as varchar(2))	as tpo_operacao,
		cast(null as integer)								as nr_ecf, 
		cast(null as decimal)                                  as nr_operacao_ecf,
		pea.dh_credito          				        			as dh_movtacao_cx,      
		pe.dh_inclusao        								as dh_emissao,  
		coalesce(pe.vl_total,0)			        			as vl_total_nf,   
		coalesce(pe.dh_cancelamento,cast(null as datetime))	as dh_cancelamento, 
		cast(null as integer)								as cd_convenio, 
	    cast(pe.nr_pedido_ecommerce as integer)  as nr_pedido_ecommerce,
		(select Max(ledd.cd_setor)
			from log_exportacao_docto led (index idx_docto_ambiente)
			inner join log_exportacao_docto_det ledd (index pk_log_exportacao_docto_det)
			on ledd.nr_atualizacao_log = led.nr_atualizacao
		where led.cd_filial =pe.cd_filial
			and led.nr_nf = cast(pe.nr_pedido as decimal)
			and led.de_especie = cast(coalesce(pea.id_rede_ecommerce, 'FA') as varchar(3))
			and led.de_serie = 'A'
				 and ledd.id_tipo_log = 'E'
				 and (led.id_tipo_docto = :ps_tipo_venda or :ps_tipo_venda is null)
				 and led.cd_ambiente_sap = :ps_ambiente_sap) as cd_setor

from pedido_ecommerce pe (index idx_filial_dh_inclusao)
Inner join filial f (index pk_filial) 	on f.cd_filial = pe.cd_filial
Inner join pedido_ecommerce_auxiliar pea (index pk_pedido_ecommerce_auxiliar)
	on pea.cd_filial_ecommerce = pe.cd_filial_ecommerce
   and pea.nr_pedido = pe.nr_pedido
Left outer join integracao_sap ifv (index pk_integracao_sap)
	on ifv.cd_empresa = 1000
	and ifv.cd_tabela  = 'FINALIZADORA_VENDA'
	and ifv.cd_chave_legado = case when pe.nr_pedido_ecommerce is not null then pe.cd_tipo_pagamento else pe.cd_forma_pagamento end
Left Outer Join integracao_sap ifil (index pk_integracao_sap)
	on ifil.cd_empresa = 1000
	and ifil.cd_tabela = 'FILIAL'
	and ifil.cd_chave_legado = cast(pe.cd_filial as varchar)
Left Outer Join cliente cli (index idx_nr_cpf_cgc)
	on cli.nr_cpf_cgc = pe.nr_cpf_cgc
Left Outer Join cliente_ecommerce cle
	on cle.nr_cpf_cgc = pe.nr_cpf_cgc
 where pea.dh_credito between :pdt_inicio and dateadd(dd, 1,:pdt_fim)
	and pe.dh_inclusao between dateadd(dd, -3, :pdt_inicio) and dateadd(dd, 10, :pdt_fim)
	and (pe.cd_filial = :pi_filial or :pi_filial is null)
	and pe.id_pagamento in (3,19) 
	and (cli.cd_cliente_sap is not null or (coalesce(cle.dh_exportacao_sap,pea.dh_exportacao_cliente_sap) is not null
    and (dateadd(mi,-30,getdate()) > coalesce(cle.dh_exportacao_sap, pea.dh_exportacao_cliente_sap))))

order by  1,11,4


" arguments=(("pdt_inicio", date),("pdt_fim", date),("pi_filial", number),("ps_tipo_venda", string),("ps_ambiente_sap", string)) )
