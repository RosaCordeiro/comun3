table(column=(type=long updatewhereclause=yes name=mapa_resumo_ecf_filial_syb dbname="mapa_resumo_ecf.filial_syb" dbalias="n.filial_syb" )
 column=(type=char(40) updatewhereclause=yes name=filial_fantasia dbname="filial_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=cd_filial_sap dbname="cd_filial_sap" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="mapa_resumo_ecf.de_especie" dbalias="n.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="mapa_resumo_ecf.de_serie" dbalias="n.de_serie" )
 column=(type=char(9) updatewhereclause=yes name=tpo_lancto dbname="tpo_lancto" )
 column=(type=char(30) updatewhereclause=yes name=tpo_operacao dbname="tpo_operacao" )
 column=(type=long updatewhereclause=yes name=nr_ecf dbname="mapa_resumo_ecf.nr_ecf" dbalias="n.nr_ecf" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_operacao_ecf dbname="nr_operacao_ecf" )
 column=(type=datetime updatewhereclause=yes name=dh_movtacao_cx dbname="mapa_resumo.dh_movtacao_cx" dbalias="mr.dh_movtacao_cx" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="mapa_resumo.dh_emissao" dbalias="mr.dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="dh_cancelamento" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="cd_convenio" )
 column=(type=long updatewhereclause=yes name=nr_pedido_ecommerce dbname="nr_pedido_ecommerce" )
 column=(type=char(5) updatewhereclause=yes name=cd_setor dbname="cd_setor" )
 retrieve="Select 	n.cd_filial 							as filial_syb,  
			f.nm_fantasia						as filial_fantasia,
			ifil.cd_chave_sap 					as cd_filial_sap,
			cast(n.nr_ecf as decimal)		as nr_nf, 
			n.de_especie 						as de_especie,  
			n.de_serie							as de_serie, 
			(Case :ps_tipo_venda when 'RZ' then 'REDU$$HEX2$$c700c300$$ENDHEX$$O Z' else  :ps_tipo_venda End) 	as tpo_lancto,  
			cast( null as char)		 			as tpo_operacao,
			n.nr_ecf  							as nr_ecf, 
			cast(n.nr_mapa   as decimal)	as nr_operacao_ecf,
			mr.dh_emissao						as dh_movtacao_cx,      
			mr.dh_emissao						as dh_emissao,  
			coalesce(n.vl_contabil, 0) 		as vl_total_nf,  
			cast(null as datetime)				as dh_cancelamento, 
			cast(null as integer) 				as cd_convenio, 
			cast(null as integer) 				as nr_pedido_ecommerce,
			(select Max(ledd.cd_setor)
				from log_exportacao_docto led (index idx_docto_ambiente)
			inner join log_exportacao_docto_det ledd (index pk_log_exportacao_docto_det)
				on ledd.nr_atualizacao_log = led.nr_atualizacao
			where led.cd_filial = n.cd_filial
				and led.nr_nf = cast(n.nr_ecf as decimal)
				and led.de_especie = n.de_especie
				and led.de_serie = n.de_serie
				and ledd.id_tipo_log = 'E'
				and (led.id_tipo_docto = :ps_tipo_venda or :ps_tipo_venda is null)
				and led.cd_ambiente_sap = :ps_ambiente_sap) as cd_setor															

from mapa_resumo mr
inner join mapa_resumo_ecf n on n.cd_filial = mr.cd_filial and n.nr_mapa = mr.nr_mapa and n.de_especie = mr.de_especie and n.de_serie = mr.de_serie
inner join filial f (index pk_filial) 	on f.cd_filial = n.cd_filial 	
left outer join integracao_sap ifil (index pk_integracao_sap) on ifil.cd_tabela = 'FILIAL' and ifil.cd_empresa = 1000 and ifil.cd_chave_legado = cast(mr.cd_filial as varchar)

 where   ( n.cd_filial 	= :pi_filial or :pi_filial is null)
    and  mr.dh_emissao  between :pdt_inicio  and :pdt_fim	 

order by 1,11,5,4 	 

	

" arguments=(("pdt_inicio", date),("pdt_fim", date),("pi_filial", number),("ps_tipo_venda", string),("ps_ambiente_sap", string)) )
