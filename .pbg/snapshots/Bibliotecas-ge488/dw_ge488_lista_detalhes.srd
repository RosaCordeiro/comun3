 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_cofins dbname="nfe_reprocessada_item.vl_bc_cofins" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_cofins dbname="nfe_reprocessada_item.vl_cofins" )
 column=(type=char(1) updatewhereclause=yes name=id_divergencia dbname="id_divergencia" )
 retrieve="SELECT	a.de_chave_acesso,   
			a.nr_item,   
			a.cd_produto,  
			a.cd_produto as cd_produto_original,
			case when b.cd_produto is null then
					a.de_produto_xml
				else
					b.de_produto+' : '+b.de_apresentacao_estoque
			end as de_produto, 
			a.de_codigo_barras,   
			a.cd_cest,   
			a.vl_produto,   
			a.vl_desconto,   
			a.vl_frete,   
			a.vl_seguro,   
			a.vl_outros,   
			a.cd_unid_comercial,   
			a.qt_comercial,   
			a.cd_cfop,   
			a.cd_cst_tributacao,   
			a.cd_cst_origem,   
			a.pc_reducao_icms,   
			a.vl_bc_icms,   
			a.pc_icms,   
			a.vl_icms,   
			a.id_motivo_desoneracao_icms,
			a.vl_icms_desonerado,
			a.vl_bc_fcp,   
			a.pc_fcp,   
			a.vl_fcp,   
			a.pc_mva_st,   
			a.vl_bc_icms_st,   
			a.pc_reducao_icms_st,   
			a.pc_icms_st,   
			a.vl_icms_st,   
			a.vl_bc_fcp_st,   
			a.pc_fcp_st,   
			a.vl_fcp_st,   
			a.vl_icms_retido,
			a.vl_bc_icms_st_retido,   
			a.pc_icms_st_retido,   
			a.vl_icms_st_retido,   
			a.vl_bc_fcp_st_retido,   
			a.pc_fcp_st_retido,   
			a.vl_fcp_st_retido,   
			a.cd_cst_ipi,   
			a.vl_bc_ipi,   
			a.pc_ipi,   
			a.vl_ipi,   
			a.cd_cst_pis,   
			a.pc_pis,   
			a.vl_bc_pis,   
			a.vl_pis,   
			a.cd_cst_cofins,   
			a.pc_cofins,   
			a.vl_bc_cofins,   
			a.vl_cofins,
			case when a.cd_produto is null then 'S' else 'N' end as id_divergencia 
FROM nfe_reprocessada_item  a
left join produto_geral b on b.cd_produto = a.cd_produto
where a.de_chave_acesso = :de_chave_acesso" arguments=(("de_chave_acesso", string))  sort="nr_item A " )
