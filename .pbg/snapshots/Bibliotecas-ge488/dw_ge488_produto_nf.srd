where ne.de_chave_acesso = :chave_acesso
	and exists (select 1 from nfe_reprocessada_item i1 where i1.de_chave_acesso = ne.de_chave_acesso and i1.cd_produto = i.cd_produto)" arguments=(("chave_acesso", string))  sort="id_informado_nf A de_produto A " )
