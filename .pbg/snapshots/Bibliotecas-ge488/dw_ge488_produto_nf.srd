table(column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(102) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="de_codigo_barras" )
 column=(type=char(1) updatewhereclause=yes name=id_informado_nf dbname="id_informado_nf" )
 retrieve="select pg.cd_produto, pg.de_produto||': '||pg.de_apresentacao_venda as de_produto, pg.de_codigo_barras, 'N' as id_informado_nf
from nf_compra n (index idx_chave_acesso)
inner join item_nf_compra i (index pk_item_nf_compra)
	on i.cd_filial = n.cd_filial
	and i.nr_nf = n.nr_nf
	and i.de_especie = n.de_especie
	and i.de_serie = n.de_serie
	and i.cd_fornecedor = n.cd_fornecedor
inner join produto_geral pg (index pk_produto_geral)
	on pg.cd_produto = i.cd_produto
where n.de_chave_acesso = :chave_acesso
	and not exists (select 1 from nfe_reprocessada_item i1 where i1.de_chave_acesso = n.de_chave_acesso and i1.cd_produto = i.cd_produto)

union

select pg.cd_produto, pg.de_produto||': '||pg.de_apresentacao_venda as de_produto, pg.de_codigo_barras, 'N' as id_informado_nf
from nf_transferencia_nfe ne (index idx_chave_acesso)
inner join nf_transferencia n (index pk_nf_transferencia)
	on n.cd_filial_origem = ne.cd_filial_origem
	and n.nr_nf = ne.nr_nf
	and n.de_serie = ne.de_serie
	and n.de_especie = ne.de_especie
inner join item_nf_transferencia i (index pk_item_nf_transferencia)
	on i.cd_filial_origem = n.cd_filial_origem
	and i.nr_nf = n.nr_nf
	and i.de_especie = n.de_especie
	and i.de_serie = n.de_serie
inner join produto_geral pg (index pk_produto_geral)
	on pg.cd_produto = i.cd_produto
where ne.de_chave_acesso = :chave_acesso
	and not exists (select 1 from nfe_reprocessada_item i1 where i1.de_chave_acesso = ne.de_chave_acesso and i1.cd_produto = i.cd_produto)

union

select pg.cd_produto, pg.de_produto||': '||pg.de_apresentacao_venda as de_produto, pg.de_codigo_barras, 'N' as id_informado_nf
from nf_diversa_nfe ne (index idx_chave_acesso)
inner join nf_diversa n (index pk_nf_diversa)
	on n.cd_filial_origem = ne.cd_filial_origem
	and n.nr_nf = ne.nr_nf
	and n.de_serie = ne.de_serie
	and n.de_especie = ne.de_especie
inner join item_nf_diversa i (index pk_item_nf_diversa)
	on i.cd_filial_origem = n.cd_filial_origem
	and i.nr_nf = n.nr_nf
	and i.de_especie = n.de_especie
	and i.de_serie = n.de_serie
inner join produto_geral pg (index pk_produto_geral)
	on pg.cd_produto = i.cd_produto
where ne.de_chave_acesso = :chave_acesso
	and not exists (select 1 from nfe_reprocessada_item i1 where i1.de_chave_acesso = ne.de_chave_acesso and i1.cd_produto = i.cd_produto)

union

select pg.cd_produto, pg.de_produto||': '||pg.de_apresentacao_venda as de_produto, pg.de_codigo_barras, 'S' as id_informado_nf
from nf_compra n (index idx_chave_acesso)
