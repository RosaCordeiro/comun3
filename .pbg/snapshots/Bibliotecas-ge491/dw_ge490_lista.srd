table(column=(type=long updatewhereclause=yes name=cd_tabela dbname="tabela_interface_sap.cd_tabela" dbalias="tis.cd_tabela" )
 column=(type=char(40) updatewhereclause=yes name=nm_tabela dbname="tabela_interface_sap.nm_tabela" dbalias="tis.nm_tabela" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="log_exportacao_sap.nr_atualizacao" dbalias="ls.nr_atualizacao" )
 column=(type=char(40) updatewhereclause=yes name=cd_chave dbname="log_exportacao_sap.cd_chave" dbalias="ls.cd_chave" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="log_exportacao_sap.cd_filial" dbalias="ls.cd_filial" )
 column=(type=char(1) updatewhereclause=yes name=id_status_integracao dbname="log_exportacao_sap.id_status_integracao" dbalias="ls.id_status_integracao" )
 column=(type=datetime updatewhereclause=yes name=dh_exportacao dbname="log_exportacao_sap.dh_exportacao" dbalias="ls.dh_exportacao" )
 column=(type=char(255) updatewhereclause=yes name=de_erro dbname="log_exportacao_sap.de_erro" dbalias="ls.de_erro" )
 column=(type=datetime updatewhereclause=yes name=dh_documento dbname="log_exportacao_sap.dh_documento" dbalias="ls.dh_documento" )
 column=(type=char(1) updatewhereclause=yes name=id_processa dbname="id_processa" values="	S/	N" )
 retrieve="Select tis.cd_tabela, tis.nm_tabela, ls.nr_atualizacao, ls.cd_chave, ls.cd_filial,
    ls.id_status_integracao, ls.dh_exportacao, ls.de_erro, ls.dh_documento,
    'N' as id_processa
from log_exportacao_sap ls
    inner join tipo_log_exportacao_sap_nf tn on (tn.id_tipo_nf = ls.id_tipo_nf)
    inner join tabela_interface_sap tis on (tis.cd_tabela = tn.cd_tabela)
where tis.id_situacao = 'A'

UNION

select ti.cd_tabela, ti.nm_tabela,
        	pd.nr_pedido_distribuidora as nr_atualizacao, 
		'Pedido: ' || convert(varchar, pd.nr_pedido_distribuidora) as cd_chave, 
		pd.cd_filial,
		pd.id_exportacao_sap as id_status_integracao,
        	pd.dh_exportacao_sap as dh_exportacao, 
		pd.de_erro_envio_sap as de_erro, 
		pd.dh_emissao as dh_documento,
        'N' as id_processa
from pedido_distribuidora pd
    inner join tabela_interface_sap ti on (ti.cd_tabela = 45)
where pd.dh_exportacao_sap is not null"  sort="nm_tabela A nr_atualizacao D " )
