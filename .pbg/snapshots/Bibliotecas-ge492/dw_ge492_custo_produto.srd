table(column=(type=long updatewhereclause=yes name=cd_filial dbname="log_exportacao_sap.cd_filial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="log_exportacao_sap_historico.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_estoque_produto dbname="log_exportacao_sap_historico.qt_estoque_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_documento dbname="log_exportacao_sap_historico.vl_documento" )
 column=(type=char(40) updatewhereclause=yes name=cd_filial_sap dbname="cd_filial_sap" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" )
 column=(type=char(200) updatewhereclause=yes name=de_erro dbname="log_exportacao_sap_historico.de_erro" )
 retrieve="select ls.cd_filial, lh.cd_produto, lh.qt_estoque_produto, lh.vl_documento,
		(Select ip.cd_chave_sap from integracao_sap ip where ip.cd_tabela = 'FILIAL' and ip.cd_chave_legado = Convert(varchar,ls.cd_filial)) as cd_filial_sap,
		pg.cd_produto_sap, lh.de_erro
from log_exportacao_sap ls
	inner join log_exportacao_sap_historico lh on (lh.nr_atualizacao = ls.nr_atualizacao)
	inner join produto_geral pg on (pg.cd_produto = lh.cd_produto)
Where 1=1" )
