table(column=(type=char(40) updatewhereclause=yes name=cd_chave dbname="log_exportacao_sap.cd_chave" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_nf dbname="log_exportacao_sap.id_tipo_nf" )
 column=(type=char(80) updatewhereclause=yes name=de_tipo_nf dbname="tipo_log_exportacao_sap_nf.de_tipo_nf" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="log_exportacao_sap.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_razao_social dbname="filial.nm_razao_social" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="log_exportacao_sap.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="log_exportacao_sap.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="log_exportacao_sap.de_serie" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="log_exportacao_sap.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=fornecedor_nm_razao_social dbname="fornecedor.nm_razao_social" )
 column=(type=datetime updatewhereclause=yes name=dh_exportacao dbname="log_exportacao_sap.dh_exportacao" )
 column=(type=datetime updatewhereclause=yes name=dh_importacao dbname="log_exportacao_sap.dh_importacao" )
 column=(type=char(20) updatewhereclause=yes name=nr_documento_sap dbname="log_exportacao_sap.nr_documento_sap" )
 column=(type=long updatewhereclause=yes name=nr_lancamento_caixa dbname="log_exportacao_sap.nr_lancamento_caixa" )
 column=(type=char(3) updatewhereclause=yes name=cd_ambiente_sap dbname="log_exportacao_sap.cd_ambiente_sap" )
 column=(type=datetime updatewhereclause=yes name=dh_estornado_sap dbname="log_exportacao_sap.dh_estornado_sap" )
 column=(type=char(100) updatewhereclause=yes name=de_erro dbname="log_exportacao_sap.de_erro" )
 column=(type=char(20) updatewhereclause=yes name=nr_documento_sap_estornado dbname="log_exportacao_sap.nr_documento_sap_estornado" )
 column=(type=char(50) updatewhereclause=yes name=cd_chave_interface dbname="log_exportacao_sap.cd_chave_interface" )
 column=(type=char(10) updatewhereclause=yes name=id_status_integracao dbname="id_status_integracao" )
 retrieve="select l.cd_chave, 
		 l.id_tipo_nf, 
		ti.de_tipo_nf,
	    l.cd_filial,
		 f.nm_razao_social,
		 l.nr_nf,
		 l.de_especie,
		 l.de_serie,
		 l.cd_fornecedor,
		 fo.nm_razao_social,
		 l.dh_exportacao,
		 l.dh_importacao,
		 l.nr_documento_sap,
		 l.nr_lancamento_caixa,
		 l.cd_ambiente_sap,
		 l.dh_estornado_sap,
		 l.de_erro,
		 l.nr_documento_sap_estornado,
		 l.cd_chave_interface,
		 (CASE l.id_status_integracao
			WHEN 'C' THEN 'COLOCADO'
			WHEN  'E' THEN 'ERRO'
			WHEN  'P' THEN 'PROCESSADO'
			WHEN  'D' THEN 'CANCELADO'
			WHEN  'I' THEN 'INTEGRADO'
			ELSE l.id_status_integracao
		END) id_status_integracao
from log_exportacao_sap l 
left outer join filial f on l.cd_filial = f.cd_filial
left outer join fornecedor fo on fo.cd_fornecedor_sap = l.cd_fornecedor
left outer join tipo_log_exportacao_sap_nf ti on ti.id_tipo_nf = l.id_tipo_nf
where l.nr_atualizacao	= :anr_atualizacao


" arguments=(("anr_atualizacao", number)) )
