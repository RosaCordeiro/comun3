table(column=(type=long updatewhereclause=yes name=cd_tabela dbname="cd_tabela" )
 column=(type=char(133) updatewhereclause=yes name=de_tabela dbname="de_tabela" )
 column=(type=char(40) updatewhereclause=yes name=nm_tabela dbname="nm_tabela" )
 column=(type=char(32) updatewhereclause=yes name=nr_atualizacao dbname="nr_atualizacao" )
 column=(type=char(100) updatewhereclause=yes name=cd_chave dbname="cd_chave" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(1) updatewhereclause=yes name=id_status_integracao dbname="id_status_integracao" )
 column=(type=datetime updatewhereclause=yes name=dh_exportacao dbname="dh_exportacao" )
 column=(type=char(255) updatewhereclause=yes name=de_erro dbname="de_erro" )
 column=(type=datetime updatewhereclause=yes name=dh_documento dbname="dh_documento" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=char(1) updatewhereclause=yes name=id_processa dbname="id_processa" values="	S/	N" )
 column=(type=char(5) updatewhereclause=yes name=id_tipo_nf dbname="id_tipo_nf" )
 column=(type=char(100) updatewhereclause=yes name=de_tipo dbname="de_tipo" )
 column=(type=long updatewhereclause=yes name=cd_modelo_exportacao_sap dbname="cd_modelo_exportacao_sap" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=char(20) updatewhereclause=yes name=nr_documento_sap dbname="nr_documento_sap" )
 column=(type=char(50) updatewhereclause=yes name=cd_chave_interface dbname="cd_chave_interface" )
 retrieve="	SELECT 
		tis.cd_tabela, 
		cast(tis.cd_tabela as varchar) + ' - '  + tis.de_tabela as de_tabela, 
		tis.nm_tabela, 
		cast(ls.nr_atualizacao as varchar) as nr_atualizacao, 
		ls.cd_chave, 
		ls.cd_filial,
		ls.id_status_integracao, 
		ls.dh_exportacao, 
		ls.de_erro, 
		ls.dh_documento, 
		cd_produto, 
		cd_fornecedor,
    	'N' as id_processa, 
		ls.id_tipo_nf, 
		tn.de_tipo_nf as de_tipo,
		tis.cd_modelo_exportacao_sap,
		ls.nr_nf as nr_nf, 
		ls.de_especie as de_especie, 
		ls.de_serie as de_serie, 
		ls.nr_documento_sap as nr_documento_sap, 
		ls.cd_chave_interface as cd_chave_interface
	FROM 
		log_exportacao_sap ls
   INNER JOIN
		tipo_log_exportacao_sap_nf tn ON tn.id_tipo_nf = ls.id_tipo_nf
   INNER JOIN 
		tabela_interface_sap tis ON tis.cd_tabela = tn.cd_tabela
	WHERE
		tis.id_situacao = 'A'

	UNION

	SELECT
		tis.cd_tabela, 
		cast(tis.cd_tabela as varchar) + ' - '  + tis.de_tabela as de_tabela, 
		tis.nm_tabela, 
		le.nr_exportacao, 
		le.cd_chave, 
		null,
		le.id_situacao_exportacao, 
		le.dh_inclusao, 
		le.de_erro, 
		le.dh_inclusao, 
		null, 
		null,
		'N' as id_processa, 
		cast(te.cd_tipo_exportacao as char(5)), 
		te.de_tipo_exportacao,
		tis.cd_modelo_exportacao_sap,
		0 as nr_nf, 
		'' as de_especie, 
		'' as de_serie, 
		'' as nr_documento_sap, 
		'' as cd_chave_interface
	FROM
		log_exportacao le
   INNER JOIN
		tipo_exportacao te ON te.cd_tipo_exportacao = le.cd_tipo_exportacao
   INNER JOIN
		tabela_interface_sap tis ON tis.cd_tabela = te.cd_tabela_interface_sap
	WHERE
		tis.id_situacao = 'A'

	UNION

	SELECT
		tis.cd_tabela, 
		cast(tis.cd_tabela as varchar) + ' - '  + tis.de_tabela as de_tabela, 
		tis.nm_tabela,
      cast(pd.nr_pedido_distribuidora as varchar) as nr_atualizacao, 
		'Pedido: ' || convert(varchar, pd.nr_pedido_distribuidora) as cd_chave, 
		pd.cd_filial,
		pd.id_exportacao_sap as id_status_integracao,
      pd.dh_exportacao_sap as dh_exportacao, 
		pd.de_erro_envio_sap as de_erro, 
		pd.dh_emissao as dh_documento, 
		null, 
		pd.cd_distribuidora,
      'N' as id_processa, 
		'' as id_tipo_nf, 
		'PEDIDO DISTRIBUIDORA' de_tipo,
		tis.cd_modelo_exportacao_sap,
		0 as nr_nf, 
		'' as de_especie, 
		'' as de_serie, 
		'' as nr_documento_sap, 
		'' as cd_chave_interface
	FROM 
		pedido_distribuidora pd
  	INNER JOIN 
		tabela_interface_sap tis ON tis.cd_tabela = 450
	WHERE
		pd.dh_exportacao_sap is null

	UNION

	SELECT 
		tis.cd_tabela, 
		cast(tis.cd_tabela as varchar) + ' - '  + tis.de_tabela as de_tabela, 
		tis.nm_tabela,
      cast(pd.nr_pedido_sap as varchar) as nr_atualizacao, 
		'Pedido: ' || convert(varchar, pd.nr_pedido_sap) as cd_chave, 
		pd.cd_filial,
		pd.id_exportacao_sap as id_status_integracao,
      pd.dh_envio_sap as dh_exportacao, 
		pd.de_erro_envio_sap as de_erro, 
		pd.dh_emissao as dh_documento, null, pd.cd_distribuidora,
      'N' as id_processa, 
		'' as id_tipo_nf, 
		'' de_tipo,
		tis.cd_modelo_exportacao_sap,
		0 nr_nf, 
		'' de_especie, 
		'' de_serie, 
		'' nr_documento_sap, 
		'' cd_chave_interface
	FROM 
		pedido_empurrado pd
   INNER JOIN
		tabela_interface_sap tis ON tis.cd_tabela = 450
	WHERE 
		pd.dh_envio_sap is not null"  sort="nm_tabela A nr_atualizacao D " )
