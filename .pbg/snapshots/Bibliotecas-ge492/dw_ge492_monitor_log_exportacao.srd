 column=(type=datetime update=yes updatewhereclause=yes name=dh_envio_webservice dbname="log_exportacao.dh_envio_webservice" dbalias="le.dh_envio_webservice" )
 column=(type=char(255) update=yes updatewhereclause=yes name=de_retorno_webservice dbname="log_exportacao.de_retorno_webservice" dbalias="le.de_retorno_webservice" )
 column=(type=char(255) update=yes updatewhereclause=yes name=de_erro dbname="log_exportacao.de_erro" dbalias="le.de_erro" )
 column=(type=char(60) updatewhereclause=yes name=cd_varchar6 dbname="log_exportacao_extra.cd_varchar6" dbalias="lee.cd_varchar6" )
 column=(type=char(60) updatewhereclause=yes name=cd_varchar7 dbname="log_exportacao_extra.cd_varchar7" dbalias="lee.cd_varchar7" )
 column=(type=char(60) updatewhereclause=yes name=cd_varchar8 dbname="log_exportacao_extra.cd_varchar8" dbalias="lee.cd_varchar8" )
 column=(type=char(60) updatewhereclause=yes name=cd_varchar9 dbname="log_exportacao_extra.cd_varchar9" dbalias="lee.cd_varchar9" )
 retrieve="SELECT
	le.nr_exportacao,
	le.cd_empresa,
	le.cd_chave,
	le.dh_inclusao,
	le.cd_tipo_exportacao,
	le.id_situacao_exportacao,
	le.id_situacao_retorno,
	le.cd_ambiente,
	le.cd_integer1,
	le.cd_integer2,
	le.cd_integer3,
	le.cd_integer4,
	le.cd_integer5,
	le.cd_varchar1,
	le.cd_varchar2,
	le.cd_varchar3,
	le.cd_varchar4,
	le.cd_varchar5,
	le.cd_datetime1,
	le.cd_datetime2,
	le.cd_datetime3,
	le.cd_datetime4,
	le.cd_datetime5,
	le.dh_envio_webservice,
	le.de_retorno_webservice,
	le.de_erro,
	lee.cd_varchar6,
	lee.cd_varchar7,
	lee.cd_varchar8,
	lee.cd_varchar9
FROM 
	log_exportacao le
LEFT JOIN
	log_exportacao_extra lee
	ON lee.nr_exportacao = le.nr_exportacao
WHERE
	le.nr_exportacao	= :anr_exportacao" arguments=(("anr_exportacao", string)) )
