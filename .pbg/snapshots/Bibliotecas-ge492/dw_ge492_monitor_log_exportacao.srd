table(column=(type=char(32) update=yes updatewhereclause=yes name=nr_exportacao dbname="log_exportacao.nr_exportacao" dbalias="le.nr_exportacao" )
 column=(type=long update=yes updatewhereclause=yes name=cd_empresa dbname="log_exportacao.cd_empresa" dbalias="le.cd_empresa" )
 column=(type=char(100) update=yes updatewhereclause=yes name=cd_chave dbname="log_exportacao.cd_chave" dbalias="le.cd_chave" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inclusao dbname="log_exportacao.dh_inclusao" dbalias="le.dh_inclusao" )
 column=(type=long update=yes updatewhereclause=yes name=cd_tipo_exportacao dbname="log_exportacao.cd_tipo_exportacao" dbalias="le.cd_tipo_exportacao" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao_exportacao dbname="log_exportacao.id_situacao_exportacao" dbalias="le.id_situacao_exportacao" values="PENDENTE	C/PROCESSADO	P/ERRO	E/CANCELADO	X/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao_retorno dbname="log_exportacao.id_situacao_retorno" dbalias="le.id_situacao_retorno" values="AGUARDANDO RETORNO	C/PROCESSADO	P/N$$HEX1$$c300$$ENDHEX$$O UTILIZADO	N/" )
