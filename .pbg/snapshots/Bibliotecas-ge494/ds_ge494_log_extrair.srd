table(column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="log_migracao_filial_sap.cd_filial" )
 column=(type=char(10) update=yes updatewhereclause=yes name=nr_matricula dbname="log_migracao_filial_sap.nr_matricula" )
 column=(type=char(200) update=yes updatewhereclause=yes name=de_mensagem dbname="log_migracao_filial_sap.de_mensagem" )
 column=(type=long updatewhereclause=yes name=cd_promocao_sap dbname="log_migracao_filial_sap.cd_promocao_sap" )
 column=(type=long updatewhereclause=yes name=cd_promocao_legado dbname="log_migracao_filial_sap.cd_promocao_legado" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="log_migracao_filial_sap.cd_produto" )
 column=(type=char(10) updatewhereclause=yes name=de_valor_legado dbname="log_migracao_filial_sap.de_valor_legado" )
 column=(type=char(10) updatewhereclause=yes name=de_valor_sap dbname="log_migracao_filial_sap.de_valor_sap" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_movimento dbname="log_migracao_filial_sap.dh_movimento" )
 retrieve="  SELECT	l.cd_filial,   
         	l.nr_matricula,   
         	l.de_mensagem,
			l.cd_promocao_sap,
			l.cd_promocao_legado,
			l.cd_produto, 
			l.de_valor_legado, 
			l.de_valor_sap,
         	l.dh_movimento  
    FROM log_migracao_filial_sap   l
where l.cd_filial = :filial
	and l.dh_movimento >= :movimento
" arguments=(("filial", number),("movimento", datetime)) )
