table(column=(type=decimal(0) update=yes updatewhereclause=yes key=yes identity=yes name=nr_bloqueio dbname="pedido_filial_bloqueio.nr_bloqueio" dbalias="p.nr_bloqueio" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_tipo_bloqueio dbname="pedido_filial_bloqueio.id_tipo_bloqueio" dbalias="p.id_tipo_bloqueio" initial="M" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_pedido dbname="pedido_filial_bloqueio.dh_pedido" dbalias="p.dh_pedido" )
 column=(type=char(200) update=yes updatewhereclause=yes name=de_motivo_bloqueio dbname="pedido_filial_bloqueio.de_motivo_bloqueio" dbalias="p.de_motivo_bloqueio" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="pedido_filial_bloqueio.dh_inclusao" dbalias="p.dh_inclusao" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_inclusao dbname="pedido_filial_bloqueio.nr_matricula_inclusao" dbalias="p.nr_matricula_inclusao" )
 column=(type=char(49) updatewhereclause=yes name=de_usuario dbname="de_usuario" )
 column=(type=datetime updatewhereclause=yes name=dh_pedido_anterior dbname="pedido_filial_bloqueio.dh_pedido_anterior" dbalias="p.dh_pedido_anterior" )
 column=(type=char(200) updatewhereclause=yes name=de_motivo_bloqueio_anterior dbname="pedido_filial_bloqueio.de_motivo_bloqueio_anterior" dbalias="p.de_motivo_bloqueio_anterior" )
 retrieve="  SELECT  p.nr_bloqueio,
			 p.id_tipo_bloqueio,   
			  p.dh_pedido,   
			  p.de_motivo_bloqueio,   
			  p.dh_inclusao,   
			  p.nr_matricula_inclusao,
			  p.nr_matricula_inclusao +  ' : ' +  u.nm_usuario de_usuario,
			p.dh_pedido dh_pedido_anterior,
		 p.de_motivo_bloqueio de_motivo_bloqueio_anterior
    FROM pedido_filial_bloqueio   p
left outer join usuario u
	on u.nr_matricula = p.nr_matricula_inclusao
where p.id_tipo_bloqueio = 'M'
  and p.dh_pedido is not null

" update="pedido_filial_bloqueio" updatewhere=0 updatekeyinplace=no )
