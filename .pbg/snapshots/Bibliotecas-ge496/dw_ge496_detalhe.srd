table(column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_distribuidora_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_distribuidora_produto.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_atendida dbname="pedido_distribuidora_produto.qt_atendida" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="pedido_distribuidora_produto.qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_falta dbname="qt_falta" )
 column=(type=long updatewhereclause=yes name=nr_pedido_empurrado dbname="pedido_distribuidora_produto.nr_pedido_empurrado" )
 column=(type=long updatewhereclause=yes name=qt_estoque_disponivel_distrib dbname="pedido_distribuidora_produto.qt_estoque_disponivel_distrib" )
 column=(type=char(50) updatewhereclause=yes name=de_motivo_rejeicao dbname="pedido_distribuidora_produto.de_motivo_rejeicao" )
 retrieve="select  pp.cd_produto,
		 g.de_produto || ' : ' || g.de_apresentacao_venda as de_produto,
		 g.vl_fator_conversao,
		 pp.qt_pedida,
		 pp.qt_atendida,
		 pp.qt_faturada,
		 (pp.qt_pedida - pp.qt_faturada) as qt_falta,
		 pp.nr_pedido_empurrado,
		 pp.qt_estoque_disponivel_distrib,
		 pp.de_motivo_rejeicao
from pedido_distribuidora p
	inner join pedido_distribuidora_produto pp
		on pp.cd_filial = p.cd_filial
		and pp.nr_pedido_distribuidora = p.nr_pedido_distribuidora
	inner join filial f
		on f.cd_filial = p.cd_filial
	inner join cidade c
		on c.cd_cidade = f.cd_cidade
	inner join fornecedor fo
		on fo.cd_fornecedor = p.cd_distribuidora
	inner join produto_geral g
		on g.cd_produto = pp.cd_produto
where p.cd_filial = :filial
	and p.nr_pedido_distribuidora = :pedido
	and ((p.id_situacao = 'C' and pp.qt_atendida < pp.qt_pedida) or (p.id_situacao in ('J', 'X')) or (p.id_situacao = 'F' and pp.qt_faturada < pp.qt_pedida))" arguments=(("filial", number),("pedido", number))  sort="de_produto A " )
