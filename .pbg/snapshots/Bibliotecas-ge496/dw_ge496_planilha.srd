table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_distribuidora.cd_filial" dbalias="p.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="filial.nr_cgc" dbalias="f.nr_cgc" )
 column=(type=char(20) updatewhereclause=yes name=cd_filial_distribuidora dbname="filial_distribuidora.cd_filial_distribuidora" dbalias="fd.cd_filial_distribuidora" )
 column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="pedido_distribuidora.cd_distribuidora" dbalias="p.cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia_distrib dbname="fornecedor.nm_fantasia" dbalias="fo.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="pedido_distribuidora.nr_pedido_distribuidora" dbalias="p.nr_pedido_distribuidora" )
 column=(type=char(1) updatewhereclause=yes name=pedido_distribuidora_id_situacao dbname="pedido_distribuidora.id_situacao" dbalias="p.id_situacao" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_distribuidora.dh_emissao" dbalias="p.dh_emissao" )
 column=(type=long updatewhereclause=yes name=nr_pedido_empurrado dbname="pedido_distribuidora_produto.nr_pedido_empurrado" dbalias="pp.nr_pedido_empurrado" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_distribuidora_produto.cd_produto" dbalias="pp.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="g.vl_fator_conversao" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_distribuidora dbname="distribuidora_produto.cd_produto_distribuidora" dbalias="d.cd_produto_distribuidora" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" dbalias="g.de_codigo_barras" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_distribuidora_produto.qt_pedida" dbalias="pp.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_atendida dbname="pedido_distribuidora_produto.qt_atendida" dbalias="pp.qt_atendida" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="pedido_distribuidora_produto.qt_faturada" dbalias="pp.qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_falta dbname="qt_falta" )
 column=(type=long updatewhereclause=yes name=qt_estoque_disponivel_distrib dbname="pedido_distribuidora_produto.qt_estoque_disponivel_distrib" dbalias="pp.qt_estoque_disponivel_distrib" )
 column=(type=char(50) updatewhereclause=yes name=de_motivo_rejeicao dbname="pedido_distribuidora_produto.de_motivo_rejeicao" dbalias="pp.de_motivo_rejeicao" )
 column=(type=char(50) updatewhereclause=yes name=de_motivo_rejeicao_pedido dbname="pedido_distribuidora.de_motivo_rejeicao_pedido" dbalias="p.de_motivo_rejeicao_pedido" )
 retrieve="select p.cd_filial,
		 f.nm_fantasia,
		 f.nr_cgc,
		 fd.cd_filial_distribuidora,
		 p.cd_distribuidora,
		 fo.nm_fantasia,
		 p.nr_pedido_distribuidora,
		 p.id_situacao,
		 p.dh_emissao,
		 pp.nr_pedido_empurrado,
		 pp.cd_produto,
		 g.de_produto || ' : ' || g.de_apresentacao_venda as de_produto,
		 g.vl_fator_conversao,
		 d.cd_produto_distribuidora,
		 g.de_codigo_barras,
		 pp.qt_pedida,
		 pp.qt_atendida,
		 pp.qt_faturada,
		 (pp.qt_pedida - pp.qt_faturada) as qt_falta,
		 pp.qt_estoque_disponivel_distrib,
		 pp.de_motivo_rejeicao,
		 p.de_motivo_rejeicao as de_motivo_rejeicao_pedido
from pedido_distribuidora p
	inner join pedido_distribuidora_produto pp
		on pp.cd_filial = p.cd_filial
		and pp.nr_pedido_distribuidora = p.nr_pedido_distribuidora
	inner join filial f
		on f.cd_filial = p.cd_filial
	inner join cidade c
		on c.cd_cidade = f.cd_cidade
	inner join fornecedor fo
		on fo.cd_fornecedor = p.cd_distribuidora
	inner join produto_geral g
		on g.cd_produto = pp.cd_produto
	inner join filial_distribuidora fd
		on fd.cd_filial = p.cd_filial
		and fd.cd_distribuidora = p.cd_distribuidora
	inner join distribuidora_produto d
		on d.cd_distribuidora = p.cd_distribuidora
		and d.cd_unidade_federacao = c.cd_unidade_federacao
		and d.cd_produto = pp.cd_produto
where p.dh_emissao between :inicio and :termino
and p.id_tipo_pedido = '2'
and ((p.id_situacao = 'C' and pp.qt_atendida < pp.qt_pedida) or (p.id_situacao in ('J', 'X')) or (p.id_situacao = 'F' and pp.qt_faturada < pp.qt_pedida))" arguments=(("inicio", date),("termino", date))  sort="de_produto A " )
