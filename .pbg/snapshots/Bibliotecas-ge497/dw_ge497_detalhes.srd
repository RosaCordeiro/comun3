table(column=(type=char(3) updatewhereclause=yes name=de_banco dbname="de_banco" )
 column=(type=decimal(0) updatewhereclause=yes identity=yes name=nr_exportacao dbname="nr_exportacao" )
 column=(type=char(20) updatewhereclause=yes name=de_tipo_documento dbname="de_tipo_documento" )
 column=(type=datetime updatewhereclause=yes name=dh_exportacao dbname="dh_exportacao" )
 column=(type=char(255) updatewhereclause=yes name=de_erro_cabecalho dbname="de_erro_cabecalho" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_status_integracao dbname="id_status_integracao" values="ERRO	E/INTEGRADO	I/REENVIADO	R/N$$HEX1$$c300$$ENDHEX$$O EXPORTADO N	N/SOLIC. REENVIO	X/PENDENTE	P/REENVIADO	C/" )
 column=(type=char(1) updatewhereclause=yes name=id_estornado_excluido dbname="id_estornado_excluido" )
 column=(type=date updatewhereclause=yes name=budat dbname="budat" )
 column=(type=date updatewhereclause=yes name=bldat dbname="bldat" )
 column=(type=char(10) updatewhereclause=yes name=belnr dbname="belnr" )
 column=(type=char(20) updatewhereclause=yes name=sap_nf dbname="sap_nf" )
 column=(type=long updatewhereclause=yes name=docnum dbname="docnum" )
 column=(type=long updatewhereclause=yes name=nfnum dbname="nfnum" )
 column=(type=char(20) updatewhereclause=yes name=belnr_estorno dbname="belnr_estorno" )
 retrieve="Select distinct
		'SYB' as de_banco,
		a.nr_exportacao,
		Case de_tipo_docto when 'RE'  then 'NF de Servi$$HEX1$$e700$$ENDHEX$$o' else  de_tipo_docto  End as de_tipo_documento,
		a.dh_exportacao,
		coalesce(a.de_observacao, ' ') as de_erro_cabecalho,
		'N' as id_selecionar,
		a.id_status as id_status_integracao,
		'' id_estornado_excluido,
		a.budat,
		a.bldat,
		a.belnr,
		coalesce(coalesce(dc.awref_rev, substring(dc.awkey,1,len(dc.awkey)-4)),'') as sap_nf,
		n.docnum,
		n2.nfnum,
		CASE WHEN coalesce(dc.awref_rev,'')<>'' THEN substring(dc.awkey,1,len(dc.awkey)-4) ELSE '' END as belnr_estorno

from lote_exporta_sap_mult					a
left outer join lote_exporta_sap_mult_item b on b.nr_exportacao	= a.nr_exportacao
left outer join bkpf dc         on dc.mandt = a.mandt and dc.belnr  = a.belnr and coalesce(dc.id_substituida, 'N')='N'
left outer join j_1bnfdoc_1 n   on n.mandt  = a.mandt and n.belnr   = substring(dc.awkey,1,len(dc.awkey)-4) and coalesce(n.id_substituida, 'N')='N'
left outer join j_1bnfdoc_2 n2  on n2.mandt = n.mandt and n2.docnum = n.docnum and n2.nr_sequencial = n.nr_sequencial

WHERE a.nr_exportacao is not null

" )
