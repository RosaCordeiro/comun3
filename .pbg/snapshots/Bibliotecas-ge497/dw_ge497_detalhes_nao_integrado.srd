table(column=(type=char(3) updatewhereclause=yes name=de_banco dbname="de_banco" )
 column=(type=long updatewhereclause=yes name=nr_exportacao dbname="nr_exportacao" )
 column=(type=char(13) updatewhereclause=yes name=de_tipo_documento dbname="de_tipo_documento" )
 column=(type=date updatewhereclause=yes name=dh_exportacao dbname="dh_exportacao" )
 column=(type=char(1) updatewhereclause=yes name=de_erro_cabecalho dbname="de_erro_cabecalho" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_status_integracao dbname="id_status_integracao" values="Com Erro	E/Integrado Mult	I/Processado	P/Pendente	C/Substitu$$HEX1$$ed00$$ENDHEX$$do	X/Pedido de Estorno 	A/N$$HEX1$$e300$$ENDHEX$$o integrado Mult	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_estornado_excluido dbname="id_estornado_excluido" )
 column=(type=date updatewhereclause=yes name=budat dbname="budat" )
 column=(type=date updatewhereclause=yes name=bldat dbname="bldat" )
 column=(type=char(10) updatewhereclause=yes name=belnr dbname="bkpf.belnr" )
 retrieve="Select	'SYB' as de_banco,
		null as nr_exportacao,
		Case a.blart when 'RE'  then 'NF de Servi$$HEX1$$e700$$ENDHEX$$o' else a.blart  End as de_tipo_documento,
		cast(null as date) as dh_exportacao,
		''  as de_erro_cabecalho,
		'N' as id_selecionar,
		'N' as id_status_integracao,
		''  as id_estornado_excluido,
         cast(a.budat as date) as budat,
		cast(a.bldat as date) as bldat,
         a.belnr	 

FROM bkpf a

WHERE  a.id_status = 'C'
       and coalesce(a.id_substituida, 'N')='N'
       " )
