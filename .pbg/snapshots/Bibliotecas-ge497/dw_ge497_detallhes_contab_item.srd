table(column=(type=long updatewhereclause=yes name=cd_filial dbname="lote_exporta_sap_mult_item.cd_filial" )
 column=(type=datetime updatewhereclause=yes name=dh_contabil dbname="lote_exporta_sap_mult_item.dh_contabil" )
 column=(type=long updatewhereclause=yes name=cd_conta_debito dbname="cd_conta_debito" )
 column=(type=long updatewhereclause=yes name=cd_conta_credito dbname="cd_conta_credito" )
 column=(type=char(1) updatewhereclause=yes name=id_natureza dbname="lote_exporta_sap_mult_item.id_natureza" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_contabil dbname="lote_exporta_sap_mult_item.vl_contabil" )
 column=(type=char(255) updatewhereclause=yes name=de_observacao dbname="lote_exporta_sap_mult_item.de_observacao" )
 column=(type=long updatewhereclause=yes name=cd_centro_custo dbname="lote_exporta_sap_mult_item.cd_centro_custo" )
 column=(type=char(3) updatewhereclause=yes name=mandt dbname="lote_exporta_sap_mult_item.mandt" )
 column=(type=char(4) updatewhereclause=yes name=bukrs dbname="lote_exporta_sap_mult_item.bukrs" )
 column=(type=char(10) updatewhereclause=yes name=belnr dbname="lote_exporta_sap_mult_item.belnr" )
 column=(type=long updatewhereclause=yes name=gjahr dbname="lote_exporta_sap_mult_item.gjahr" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="lote_exporta_sap_mult_item.nr_sequencial" )
 column=(type=char(4) updatewhereclause=yes name=gsber dbname="lote_exporta_sap_mult_item.gsber" )
 column=(type=long updatewhereclause=yes name=id_status dbname="id_status" )
 retrieve="Select 	li.cd_filial, 
			li.dh_contabil, 
			case when li.id_natureza = 'D' then li.cd_conta_contabil else 0 end as cd_conta_debito, 
			case when li.id_natureza = 'C' then li.cd_conta_contabil else 0 end as cd_conta_credito,
			li.id_natureza,
			li.vl_contabil,
			li.de_observacao,
			li.cd_centro_custo,
			li.mandt,      
			li.bukrs,	     	
			li.belnr,        	
			li.gjahr,        	
			li.nr_sequencial	,
			li.gsber,
             case when le.id_status = 'E' then 1 else null end as id_status
from lote_exporta_sap_mult_item li
Inner join lote_exporta_sap_mult le
	on le.nr_exportacao 	= li.nr_exportacao
where li.nr_exportacao 	= :pl_nr_exportacao
/*and    li.cd_filial 			= :pl_cd_filial */" arguments=(("pl_nr_exportacao", number)) )
