table(column=(type=long updatewhereclause=yes name=cd_condicao_crediario dbname="cd_condicao_crediario" )
 column=(type=char(255) updatewhereclause=yes name=de_condicao_crediario dbname="de_condicao_crediario" )
 retrieve="SELECT cd_condicao_crediario, de_condicao_crediario
	FROM (
		SELECT 0 as cd_condicao_crediario,  'SELECIONE A CONDI$$HEX2$$c700c300$$ENDHEX$$O' as de_condicao_crediario FROM parametro where id_parametro = '1'
		Union
		SELECT cd_condicao_crediario, de_condicao_crediario  
		    FROM condicao_venda_crediario  
		WHERE id_ativa = 'S'
			AND id_somente_clube in ('1','3') 
	 ) AS x
	ORDER BY ( Case  when cd_condicao_crediario = 0 Then 'A' ELSE 'Z' End ), de_condicao_crediario" )
