table(column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="cd_cliente" )
 column=(type=char(14) updatewhereclause=yes name=nr_cpf_cgc dbname="nr_cpf_cgc" )
 column=(type=datetime updatewhereclause=yes name=dh_entrega_marcada dbname="dh_entrega_marcada" )
 column=(type=char(60) updatewhereclause=yes name=de_endereco dbname="de_endereco" )
 column=(type=char(150) updatewhereclause=yes name=de_referencia_entrega dbname="de_referencia_entrega" )
 column=(type=char(20) updatewhereclause=yes name=de_bairro dbname="de_bairro" )
 column=(type=char(20) updatewhereclause=yes name=nr_telefone dbname="nr_telefone" )
 column=(type=char(60) updatewhereclause=yes name=nm_cliente dbname="nm_cliente" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep dbname="nr_cep" )
 column=(type=char(30) updatewhereclause=yes name=nm_cidade dbname="nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cd_unidade_federacao" )
 column=(type=char(40) updatewhereclause=yes name=de_complemento dbname="de_complemento" )
 column=(type=char(6) updatewhereclause=yes name=nr_endereco dbname="nr_endereco" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_frete dbname="vl_frete" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_frete_calculado dbname="vl_frete_calculado" )
 retrieve="Select Aux.*
from
(
select pe.cd_cliente as cd_cliente,
		cl.nr_cpf_cgc as nr_cpf_cgc,
		pe.dh_entrega_marcada as dh_entrega_marcada,   
         pe.de_endereco_entrega as de_endereco,   
         pe.de_referencia_entrega,   
         pe.de_bairro_entrega as de_bairro,   
         pe.nr_telefone_entrega as nr_telefone,   
         pe.nm_cliente_entrega as nm_cliente,   
         pe.nr_cep_entrega as nr_cep,   
         pe.nm_cidade_entrega as nm_cidade,   
         pe.cd_uf_entrega as cd_unidade_federacao ,   
         pe.de_complemento_endereco as de_complemento,   
         pe.nr_endereco_entrega as nr_endereco,
		pe.vl_taxa_entrega as vl_frete ,
		pe.vl_taxa_entrega_calculada as vl_frete_calculado
    FROM pedido_disque_entrega pe
		inner join cliente cl on (cl.cd_cliente = pe.cd_cliente)
Where pe.cd_filial = :pl_cd_filial
and pe.nr_pedido_disque = :pl_nr_pedido
) Aux" arguments=(("pl_cd_filial", number),("pl_nr_pedido", number)) )
