table(column=(type=long updatewhereclause=yes name=nr_sequencial dbname="p.nr_sequencial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="p.cd_produto" )
 column=(type=char(8190) updatewhereclause=no name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="p.qt_pedida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="p.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="p.pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_praticado dbname="p.vl_preco_praticado" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_tabela dbname="p.pc_desconto_tabela" )
 column=(type=char(1) updatewhereclause=yes name=id_alteracao_preco dbname="p.id_alteracao_preco" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_desconto dbname="p.id_tipo_desconto" )
 column=(type=long updatewhereclause=yes name=nr_requisicao_manip dbname="p.nr_requisicao_manip" )
 column=(type=long updatewhereclause=yes name=cd_promocao_sos dbname="p.cd_promocao_sos" )
 column=(type=long updatewhereclause=yes name=nr_campanha dbname="p.nr_campanha" )
 column=(type=long updatewhereclause=yes name=cd_desconto_extra dbname="p.cd_desconto_extra" )
 column=(type=char(10) updatewhereclause=yes name=nr_etiqueta_prestes dbname="p.nr_etiqueta_prestes" )
 column=(type=char(1) updatewhereclause=yes name=id_prestes_avulso dbname="p.id_prestes_avulso" )
 column=(type=long updatewhereclause=yes name=cd_convenio_saude dbname="p.cd_convenio_saude" )
 column=(type=long updatewhereclause=yes name=pedido_disque_entrega_produto_nr_contrato dbname="p.nr_contrato" )
 column=(type=char(1) updatewhereclause=yes name=pedido_disque_entrega_produto_id_usado_vinculada dbname="p.id_usado_vinculada" )
 column=(type=long updatewhereclause=yes name=pedido_disque_entrega_produto_cd_promocao_vinculada dbname="p.cd_promocao_vinculada" )
 column=(type=char(20) updatewhereclause=yes name=pedido_disque_entrega_produto_nr_vale_desconto dbname="p.nr_vale_desconto" )
 retrieve="  SELECT  p.nr_sequencial,   
         p.cd_produto,  
		g.de_produto || ' : ' || g.de_apresentacao_venda as de_produto, 
         p.qt_pedida,   
         p.vl_preco_unitario,   
         p.pc_desconto,   
         p.vl_preco_praticado,   
         p.pc_desconto_tabela,   
         p.id_alteracao_preco,   
         p.id_tipo_desconto,   
         p.nr_requisicao_manip,   
         p.cd_promocao_sos,   
         p.nr_campanha,   
         p.cd_desconto_extra,   
         p.nr_etiqueta_prestes,   
         p.id_prestes_avulso,   
         p.cd_convenio_saude,   
         p.nr_contrato,   
         p.id_usado_vinculada,   
         p.cd_promocao_vinculada,   
         p.nr_vale_desconto  
    FROM pedido_disque_entrega_produto p
		inner join produto_geral g
			on g.cd_produto = p.cd_produto
WHERE p.nr_pedido_disque = :pedido
" arguments=(("pedido", number)) )
