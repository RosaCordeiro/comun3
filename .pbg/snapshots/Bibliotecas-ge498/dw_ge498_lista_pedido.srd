table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_disque_entrega.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_pedido_disque dbname="pedido_disque_entrega.nr_pedido_disque" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_disque_entrega.dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_pedido dbname="pedido_disque_entrega.vl_total_pedido" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="pedido_disque_entrega.id_situacao" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_venda dbname="pedido_disque_entrega.id_tipo_venda" )
 column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="pedido_disque_entrega.cd_cliente" )
 column=(type=char(20) updatewhereclause=yes name=nr_telefone_entrega dbname="pedido_disque_entrega.nr_telefone_entrega" )
 column=(type=char(60) updatewhereclause=yes name=nm_cliente_entrega dbname="pedido_disque_entrega.nm_cliente_entrega" )
 column=(type=char(40) updatewhereclause=yes name=cliente_nm_cliente dbname="cliente.nm_cliente" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_impressao dbname="pedido_disque_entrega.dh_impressao" )
 column=(type=char(255) updatewhereclause=yes name=id_refaturado dbname="id_refaturado" )
 retrieve="select p.cd_filial,	
		p.nr_pedido_disque,   
		p.dh_emissao,
		p.vl_total_pedido,   
		p.id_situacao,   
		p.id_tipo_venda,
		p.cd_cliente,
		p.nr_telefone_entrega,	
		p.nm_cliente_entrega, 
		c.nm_cliente,
		f.nm_fantasia,
		p.dh_impressao,
		'N' as id_refaturado
from	pedido_disque_entrega  p
	inner join cliente c
		on c.cd_cliente = p.cd_cliente
	inner join filial f
		on f.cd_filial = p.cd_Filial" )
