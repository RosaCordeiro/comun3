table(column=(type=long updatewhereclause=yes name=nr_sequencial dbname="pedido_disque_entrega_pagamento.nr_sequencial" dbalias=".nr_sequencial" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pagamento dbname="pedido_disque_entrega_pagamento.vl_pagamento" dbalias=".vl_pagamento" )
 column=(type=char(2) updatewhereclause=yes name=cd_forma_pagamento dbname="pedido_disque_entrega_pagamento.cd_forma_pagamento" dbalias=".cd_forma_pagamento" )
 column=(type=long updatewhereclause=yes name=nr_parcelas_cartao dbname="pedido_disque_entrega_pagamento.nr_parcelas_cartao" dbalias=".nr_parcelas_cartao" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="pedido_disque_entrega_pagamento.cd_convenio" dbalias=".cd_convenio" )
 column=(type=long updatewhereclause=yes name=cd_condicao_convenio dbname="pedido_disque_entrega_pagamento.cd_condicao_convenio" dbalias=".cd_condicao_convenio" )
 column=(type=long updatewhereclause=yes name=cd_condicao_crediario dbname="pedido_disque_entrega_pagamento.cd_condicao_crediario" dbalias=".cd_condicao_crediario" )
 column=(type=long updatewhereclause=yes name=nr_parcelas_clube_prazo dbname="pedido_disque_entrega_pagamento.nr_parcelas_clube_prazo" dbalias=".nr_parcelas_clube_prazo" )
 column=(type=char(8190) updatewhereclause=yes name=de_forma_pagamento dbname="de_forma_pagamento" )
 retrieve="  SELECT nr_sequencial,
		vl_pagamento,   
         cd_forma_pagamento,   
         nr_parcelas_cartao,   
         cd_convenio,   
         cd_condicao_convenio,   
         cd_condicao_crediario,   
         nr_parcelas_clube_prazo,
		Case cd_forma_pagamento 
			When 'DI' then 'DINHEIRO' 
			When 'CP' then 'CART$$HEX1$$c300$$ENDHEX$$O CR$$HEX1$$c900$$ENDHEX$$DITO' 
			When 'CA' then 'CART$$HEX1$$c300$$ENDHEX$$O D$$HEX1$$c900$$ENDHEX$$BITO' 
			End as de_forma_pagamento
    FROM pedido_disque_entrega_pagamento   
" )
