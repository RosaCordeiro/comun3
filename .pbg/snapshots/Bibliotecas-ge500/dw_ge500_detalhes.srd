table(column=(type=char(3) updatewhereclause=yes name=de_banco dbname="de_banco" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=decimal(0) updatewhereclause=yes identity=yes name=nr_atualizacao dbname="nr_atualizacao" )
 column=(type=char(13) updatewhereclause=yes name=de_tipo_documento dbname="de_tipo_documento" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(10) updatewhereclause=yes name=nr_documento_sap dbname="nr_documento_sap" )
 column=(type=long updatewhereclause=yes name=nr_documento_sap_estornado dbname="nr_documento_sap_estornado" )
 column=(type=datetime updatewhereclause=yes name=dh_exportacao dbname="dh_exportacao" )
 column=(type=datetime updatewhereclause=yes name=dh_documento dbname="dh_documento" )
 column=(type=char(1) updatewhereclause=yes name=dh_estornado_sap dbname="dh_estornado_sap" )
 column=(type=char(255) updatewhereclause=yes name=de_erro_cabecalho dbname="de_erro_cabecalho" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_status_integracao dbname="id_status_integracao" )
 column=(type=long updatewhereclause=yes name=qt_erros_itens dbname="qt_erros_itens" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_nf dbname="id_tipo_nf" initial="T" )
 column=(type=char(1) updatewhereclause=yes name=id_estornado_excluido dbname="id_estornado_excluido" )
 column=(type=char(2) updatewhereclause=yes name=nftype dbname="nftype" )
 column=(type=long updatewhereclause=yes name=docnum dbname="docnum" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="nr_sequencial" )
 column=(type=char(4) updatewhereclause=yes name=filial_sap dbname="filial_sap" )
 column=(type=char(3) updatewhereclause=yes name=mandt dbname="mandt" )
 column=(type=char(13) updatewhereclause=yes name=sit_log dbname="sit_log" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_log dbname="id_situacao_log" )
 column=(type=datetime updatewhereclause=yes name=dta_lancto dbname="dta_lancto" )
 column=(type=char(11) updatewhereclause=yes name=observacao dbname="observacao" )
 retrieve="Select distinct
		'SYB' as de_banco,
		f.cd_filial as cd_filial,
		f.nm_fantasia,
		lem.nr_atualizacao as nr_atualizacao,   
		(Case jdoc2.nftype when 'S1' then 'ENERGIA' 
                           when 'SE' then 'ENERGIA NF3e'
                           when 'SR' then 'NF SERVI$$HEX1$$c700$$ENDHEX$$O'    
                           when 'T1' then 'TELEFONE'
                           when 'U1' then 'COMUNICA$$HEX2$$c700c300$$ENDHEX$$O'
                           when 'FK' then 'FRETE'
                           when 'CX' then 'FRETE OSS'
									when 'SY' then 'NF SERVI$$HEX1$$c700$$ENDHEX$$O CD' End) as de_tipo_documento,
		CASE WHEN jdoc2.nfnum > 0 THEN jdoc2.nfnum ELSE cast(jdoc2.nfenum as int) END as nr_nf,
		jdoc.belnr      as nr_documento_sap,
		0 as nr_documento_sap_estornado,
		lem.dh_exportacao   	as dh_exportacao, 
		jdoc.docdat         		as dh_documento,
		''                  			as dh_estornado_sap,
		coalesce(lem.de_log,'')		as de_erro_cabecalho,
		'N'                 			as id_selecionar,
		'P'                 			as id_status_integracao,
		0                  			as qt_erros_itens,
		jdoc2.nftype        			as id_tipo_nf,
		''                 			as	id_estornado_excluido,
		jdoc2.nftype,
		jdoc2.docnum   		as docnum,
		jdoc2.nr_sequencial	as nr_sequencial,
  		jdoc.branch				as filial_sap,
		jdoc.mandt				as mandt,
		(Case coalesce(lem.id_situacao_log,'C')
                  when 'X' then 'EXCLU$$HEX1$$cd00$$ENDHEX$$DO' 
                  when 'I'  then 'INTEGRADO'   
				when 'R'  then 'REVISAR'  
                   else 'N$$HEX1$$c300$$ENDHEX$$O INTEGRADO' End) as sit_log,
         coalesce(lem.id_situacao_log,'C') as id_situacao_log,
         jdoc2.pstdat  			as dta_lancto,
        (Case coalesce(jdoc.cancel,'N') when 'X'  then 'ESTORNADO'
			Else 
				Case when coalesce(jdoc.id_substituida,'N')='S' then 'SUBSTITUIDA' else '' end
		  End)	 as observacao   
FROM j_1bnfdoc_1 jdoc
INNER JOIN j_1bnfdoc_2  jdoc2  ON jdoc2.mandt  = jdoc.mandt and jdoc2.docnum = jdoc.docnum and jdoc2.nr_sequencial = jdoc.nr_sequencial
INNER JOIN integracao_sap isap ON isap.cd_tabela = 'FILIAL' and isap.cd_empresa = :pi_empresa AND isap.cd_chave_sap = jdoc.branch
INNER JOIN filial f 	ON f.cd_filial  = cast(isap.cd_chave_legado as int)
LEFT OUTER JOIN log_exportacao_mult lem ON lem.mandt = jdoc.mandt and lem.docnum = jdoc.docnum and lem.nr_sequencial = jdoc.nr_sequencial
WHERE jdoc.bukrs           = cast(:pi_empresa as char)
   /*AND coalesce(jdoc.id_substituida, 'N')='N'*/

" arguments=(("pi_empresa", number))  sort="cd_filial A nr_atualizacao A " )
