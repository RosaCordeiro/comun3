 column=(type=datetime update=yes updatewhereclause=yes name=dh_ataulizacao_fa dbname="a_categoria_ecommerce_site.dh_ataulizacao_fa" dbalias="a.dh_ataulizacao_fa" )
 retrieve="  SELECT a.cd_categoria,   
         a.name,   
         a.fathercategoryid,   
         a.title,   
         a.description,   
         a.keywords,   
         a.isactive,   
         a.lomadeecampaigncode,   
         a.adwordsremarketingcode,   
         a.showinstorefront,   
         a.showbrandfilter,   
         a.activestorefrontlink,   
         a.globalcategoryid,   
         a.stockkeepingunitselectionmode,   
         a.score,   
         a.linkid,   
         a.haschildren,   
         a.dh_atualizacao_pp,   
         a.dh_ataulizacao_fa  
    FROM a_categoria_ecommerce_site  a   
order by a.cd_categoria asc
" update="a_categoria_ecommerce_site" updatewhere=1 updatekeyinplace=no )
