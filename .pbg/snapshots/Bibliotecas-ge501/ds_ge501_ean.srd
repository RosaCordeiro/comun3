table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="pg.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=cd_ean dbname="cd_ean" )
 column=(type=char(1) updatewhereclause=yes name=id_atualizacao dbname="id_atualizacao" )
 column=(type=char(10) updatewhereclause=yes name=cd_sku dbname="ecommerce_prd.cd_sku" dbalias="ep.cd_sku" )
 column=(type=decimal(0) updatewhereclause=yes identity=yes name=nr_atualizacao dbname="nr_atualizacao" )
 retrieve="Select pg.cd_produto, Aux.cd_ean, Aux.id_atualizacao, ep.cd_sku, Aux.nr_atualizacao
from 
(
  Select convert(int, substring(de_chave,1,10) ) as cd_produto, substring(de_chave,14,100) as cd_ean, id_atualizacao, nr_atualizacao
    From log_exportacao_ecommerce  l
   Where l.id_processado = 'P' 
 	 and l.nm_tabela = 'EAN'
	 and l.cd_filial_ecommerce = :pl_cd_filial
	 and l.id_ecommerce = :ps_id_ecommerce
) Aux inner join produto_geral pg on (pg.cd_produto = Aux.cd_produto)
		inner join ecommerce_prd ep on (ep.cd_produto = pg.cd_produto
														and ep.id_ecommerce = :ps_id_ecommerce
														and ep.id_rede_filial = :ps_rede)
Where ep.cd_produto_ecommerce is not null
	and ep.cd_sku is not null
order by Aux.nr_atualizacao" arguments=(("ps_id_ecommerce", string),("pl_cd_filial", number),("ps_rede", string)) )
