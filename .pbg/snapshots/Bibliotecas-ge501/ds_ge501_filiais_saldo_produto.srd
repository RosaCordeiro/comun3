table(column=(type=long updatewhereclause=yes name=cd_filial dbname="ecommerce_prd_filial.cd_filial" dbalias="ep.cd_filial" )
 column=(type=long updatewhereclause=yes name=qt_saldo dbname="qt_saldo" )
 column=(type=long updatewhereclause=yes name=qt_saldo_distribuidora dbname="qt_saldo_distribuidora" )
 retrieve="select ep.cd_filial, 
coalesce(ep.qt_saldo_filial,0) - coalesce(ep.qt_saldo_pendente,0) - coalesce(ep.qt_saldo_transferencia,0) - coalesce(ep.qt_saldo_prestes,0) as qt_saldo,
coalesce(ep.qt_saldo_distribuidora,0) as qt_saldo_distribuidora
from ecommerce_prd_filial ep 
		inner join ecommerce_rede_filial er on er.id_ecommerce = ep.id_ecommerce and er.id_rede_filial = ep.id_rede_filial and er.cd_filial = ep.cd_filial
where ep.id_ecommerce = :ps_id_ecommerce
and ep.id_rede_filial = :ps_rede_filial
and ep.cd_produto = :pl_cd_produto 
and ep.qt_saldo > 0 
and er.id_situacao = 'A'" arguments=(("ps_id_ecommerce", string),("ps_rede_filial", string),("pl_cd_produto", number)) )
