table(column=(type=char(20) updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_ecommerce.nr_pedido_ecommerce" dbalias="x1.nr_pedido_ecommerce" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_pedido dbname="pedido_ecommerce_auxiliar.id_tipo_pedido" dbalias="x2.id_tipo_pedido" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_ecommerce dbname="pedido_ecommerce_auxiliar.id_rede_ecommerce" dbalias="x2.id_rede_ecommerce" )
 column=(type=long updatewhereclause=yes name=cd_seller dbname="pedido_ecommerce_auxiliar.cd_seller" dbalias="x2.cd_seller" )
 retrieve="select x1.nr_pedido_ecommerce, x2.id_tipo_pedido, x2.id_rede_ecommerce, x2.cd_seller
from pedido_ecommerce x1
	inner join pedido_ecommerce_auxiliar x2 on x2.nr_pedido = x1.nr_pedido
	inner join pedido_ecommerce_baixa x3 on x3.nr_pedido_ecommerce = x1.nr_pedido_ecommerce and x3.id_ecommerce = x1.id_ecommerce
where x1.id_ecommerce = '2' 
and x1.id_situacao not in ('X','G') 
and x1.cd_tipo_pagamento <> 'BOLETO BRADESCO REGISTRADO' 
and DATEDIFF(minute, x3.dh_baixa, x3.dh_importacao) > 20
and x1.dh_compra > '20220712'  " )
