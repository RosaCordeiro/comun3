table(column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="cd_distribuidora" )
 column=(type=long updatewhereclause=yes name=qt_estoque_disponivel dbname="qt_estoque_disponivel" )
 column=(type=long updatewhereclause=yes name=nr_prior_atend_ped_empurrado dbname="nr_prior_atend_ped_empurrado" )
 retrieve="select cd_distribuidora, qt_estoque_disponivel, nr_prior_atend_ped_empurrado
from 
(
	Select   d.cd_distribuidora, d.qt_estoque_disponivel, ec.nr_prior_atend_ped_empurrado
	From distribuidora_produto d
	Inner join fornecedor f
		on f.cd_fornecedor = d.cd_distribuidora
	Inner join filial_distribuidora fd
		on fd.cd_distribuidora = d.cd_distribuidora
	inner join filial fi
		on fi.cd_filial = fd.cd_filial
	inner join cidade ci
		on ci.cd_cidade = fi.cd_cidade
	inner join ecommerce_distrib ec
		on ec.id_ecommerce = '2'
		and ec.cd_distribuidora = d.cd_distribuidora
	    and ec.cd_filial = fd.cd_filial
	Where  fd.cd_filial = :pl_cd_filial
	  and d.cd_produto = :pl_cd_produto
	  and coalesce(f.id_atende_pedido_ecommerce, 'N') = 'S'
	  and coalesce(f.id_situacao, 'A') = 'A'
	  and fd.id_situacao = 'A'
	  and ( 
			( coalesce(ec.id_estoque_maior_10dias, 'N') = 'S' and coalesce(d.id_estoque_maior_10dias, 'N') = 'S' )
		or ( coalesce(ec.id_estoque_maior_10dias, 'N') = 'N' )
			)
	  and d.cd_unidade_federacao = ci.cd_unidade_federacao
	  and d.qt_estoque_disponivel >= ec.qt_minima_estoque
	  and ec.dh_inicio_saldo <= cast(getdate() as date)
	  and ec.dh_termino_saldo >= cast(getdate() as date)
	
	union
	
	select fo.cd_fornecedor, sa.qt_saldo_final as qt_estoque_disponivel, ec.nr_prior_atend_ped_empurrado
	from fornecedor fo
	inner join filial fi
		on fi.cd_filial = 534
	inner join saldo_produto sa
		on sa.cd_filial = fi.cd_filial
		and sa.dh_saldo = fi.dh_ultimo_saldo
	inner join ecommerce_distrib ec
		on ec.id_ecommerce = '2'
		and ec.cd_distribuidora = fo.cd_fornecedor
		and ec.cd_filial = :pl_cd_filial -- necess$$HEX1$$e100$$ENDHEX$$rio ser a filial que esta sendo atualizada
	where fo.cd_fornecedor = '053404705'
	  and coalesce(fo.id_atende_pedido_ecommerce, 'N') = 'S'
	  and sa.cd_produto = :pl_cd_produto
	  and sa.qt_saldo_final >= ec.qt_minima_estoque
	  and ec.dh_inicio_saldo <= cast(getdate() as date)
	  and ec.dh_termino_saldo >= cast(getdate() as date)
) as tudo
order by nr_prior_atend_ped_empurrado
" arguments=(("pl_cd_filial", number),("pl_cd_produto", number)) )
