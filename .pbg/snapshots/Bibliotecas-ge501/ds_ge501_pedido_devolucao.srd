table(column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_ecommerce.nr_pedido" dbalias="p.nr_pedido" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_ecommerce.cd_filial" dbalias="p.cd_filial" )
 column=(type=datetime updatewhereclause=yes name=dh_faturado dbname="pedido_ecommerce.dh_faturado" dbalias="p.dh_faturado" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_ecommerce dbname="id_rede_ecommerce" )
 column=(type=char(20) updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_ecommerce.nr_pedido_ecommerce" dbalias="p.nr_pedido_ecommerce" )
 column=(type=long updatewhereclause=yes name=cd_filial_ecommerce dbname="pedido_ecommerce.cd_filial_ecommerce" dbalias="p.cd_filial_ecommerce" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_devolucao_venda.vl_total_nf" dbalias="nd.vl_total_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_recebimento dbname="nf_devolucao_venda.dh_recebimento" dbalias="nd.dh_recebimento" )
 column=(type=long updatewhereclause=yes name=cd_filial_nf dbname="nf_devolucao_venda.cd_filial_nf" dbalias="nd.cd_filial_nf" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_devolucao_venda.nr_nf" dbalias="nd.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_devolucao_venda.de_especie" dbalias="nd.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_devolucao_venda.de_serie" dbalias="nd.de_serie" )
 column=(type=char(1) updatewhereclause=yes name=id_origem_nf dbname="nf_devolucao_venda.id_origem_nf" dbalias="nd.id_origem_nf" )
 column=(type=char(10) updatewhereclause=yes name=id_pedido_equilibrium dbname="pedido_ecommerce_auxiliar.id_pedido_equilibrium" dbalias="a.id_pedido_equilibrium" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_entrega dbname="tipo_entrega_ecommerce.id_tipo_entrega" dbalias="te.id_tipo_entrega" )
 retrieve="   SELECT	p.nr_pedido, 
				p.cd_filial,
			p.dh_faturado,
			Coalesce(a.id_rede_ecommerce, 'FA') as id_rede_ecommerce,
			p.nr_pedido_ecommerce,
			p.cd_filial_ecommerce,
			nd.vl_total_nf,
			dateadd( HOUR, 3, nd.dh_recebimento) dh_emissao,
			nd.dh_recebimento,
			nd.cd_filial cd_filial_nf,
			nd.nr_nf,
			nd.de_especie,
			nd.de_serie,
			nd.id_origem_nf,
			a.id_pedido_equilibrium,
			te.id_tipo_entrega
    FROM pedido_ecommerce p
		inner join pedido_ecommerce_auxiliar a ON ( a.cd_filial_ecommerce = p.cd_filial_ecommerce
	  														  and a.nr_pedido = p.nr_pedido )
		inner join ecommerce_rede_filial ef on ( ef.cd_filial = p.cd_filial_ecommerce and ef.id_ecommerce = p.id_ecommerce and ef.id_situacao = 'A' )
		inner join nf_venda nv on (nv.cd_filial_ecommerce = p.cd_filial_ecommerce
									and nv.nr_pedido_ecommerce = p.nr_pedido)
		inner join nf_devolucao_venda nd on ( nd.cd_filial_venda = nv.cd_filial
														and nd.nr_nf_venda = nv.nr_nf
														and nd.de_especie_venda = nv.de_especie
														and nd.de_serie_venda	= nv.de_serie)
		left join tipo_entrega_ecommerce te ON (te.cd_tipo_entrega = p.cd_tipo_entrega)
   WHERE ef.id_rede_filial = :ps_id_rede
     AND p.dh_compra > dbo.adddate( 'day', -90, getdate( ) )
	AND p.nr_pedido > 999999
	AND p.nr_pedido_ecommerce is not null
	and p.nr_pedido_drogaexpress is not null
    and coalesce(a.id_ignorar_integracao_status, 'N') = 'N'
    //and p.id_situacao = 'X'
    and a.dh_devolucao is null
	and nv.dh_cancelamento is null
	and nd.dh_cancelamento is null
    and p.dh_faturado is not null
  	and p.dh_compra >= '2020/09/10'" arguments=(("ps_id_rede", string))  sort="cd_filial A " )
