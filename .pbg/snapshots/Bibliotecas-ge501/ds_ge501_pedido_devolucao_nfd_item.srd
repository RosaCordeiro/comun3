table(column=(type=char(10) updatewhereclause=yes name=cd_sku dbname="ecommerce_prd.cd_sku" dbalias="e.cd_sku" )
 column=(type=long updatewhereclause=yes name=qt_devolvida dbname="item_nf_devolucao_venda.qt_devolvida" dbalias="i.qt_devolvida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco dbname="vl_preco" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_devolucao_venda.cd_produto" dbalias="i.cd_produto" )
 retrieve="select 	e.cd_sku,
			i.qt_devolvida, 
			cast(round(round(i.vl_preco_unitario * ((100 - i.pc_desconto) / 100), 2) * ((100 - n.pc_desconto) / 100), 2)  as decimal(7,2)) vl_preco,
			i.cd_produto
from item_nf_devolucao_venda i
inner join nf_devolucao_venda n
	on n.cd_filial = i.cd_filial
	and n.nr_nf		= i.nr_nf
	and n.de_especie = i.de_especie
	and n.de_serie = i.de_serie
	and n.id_origem_nf = i.id_origem_nf
inner join filial f
	on f.cd_filial = n.cd_filial_venda
left outer join ecommerce_prd e
	on e.id_ecommerce = '2'
	and e.id_rede_filial = f.id_rede_filial
	and e.cd_produto = i.cd_produto
where i.cd_filial = :filial
  and i.de_especie = :especie
 and i.de_serie = :serie
and i.id_origem_nf = :origem_nf
  and i.nr_nf = :nota" arguments=(("filial", number),("nota", number),("especie", string),("serie", string),("origem_nf", string)) )
