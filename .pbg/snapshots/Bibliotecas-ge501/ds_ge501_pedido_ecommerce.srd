table(column=(type=char(20) updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_ecommerce_baixa.nr_pedido_ecommerce" dbalias="pb.nr_pedido_ecommerce" )
 column=(type=long updatewhereclause=yes name=cd_filial_ecommerce dbname="pedido_ecommerce.cd_filial_ecommerce" dbalias="pe.cd_filial_ecommerce" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_ecommerce.nr_pedido" dbalias="pe.nr_pedido" )
 column=(type=char(9) updatewhereclause=yes name=id_situacao dbname="pedido_ecommerce.id_situacao" dbalias="pe.id_situacao" )
 column=(type=datetime updatewhereclause=yes name=dh_importacao dbname="pedido_ecommerce_baixa.dh_importacao" dbalias="pb.dh_importacao" )
 column=(type=datetime updatewhereclause=yes name=dh_baixa dbname="pedido_ecommerce_baixa.dh_baixa" dbalias="pb.dh_baixa" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_pedido dbname="pedido_ecommerce_baixa.id_tipo_pedido" dbalias="pb.id_tipo_pedido" )
 retrieve="select pb.nr_pedido_ecommerce, pe.cd_filial_ecommerce, pe.nr_pedido, pe.id_situacao, pb.dh_importacao, pb.dh_baixa, pb.id_tipo_pedido
from pedido_ecommerce_baixa pb
     left join pedido_ecommerce pe on (pe.nr_pedido_ecommerce = pb.nr_pedido_ecommerce
	 								and exists(select 1 
														from pedido_ecommerce_auxiliar pa 
													where pa.cd_filial_ecommerce = pe.cd_filial_ecommerce 
														and pa.nr_pedido = pe.nr_pedido 
														and (case when pa.id_rede_ecommerce = 'MP' Then 'DC' Else pa.id_rede_ecommerce End) = pb.id_rede_filial))  
where pb.dh_importacao is null
	and pb.id_ecommerce = :ps_id_ecommerce
	and pb.id_rede_filial = :ps_id_rede

UNION

select pb.nr_pedido_ecommerce, pe.cd_filial_ecommerce, pe.nr_pedido, pe.id_situacao, pb.dh_importacao, pb.dh_baixa, pb.id_tipo_pedido
from pedido_ecommerce_baixa pb
   left join pedido_ecommerce pe on (pe.nr_pedido_ecommerce = pb.nr_pedido_ecommerce
	 								and exists(select 1 
														from pedido_ecommerce_auxiliar pa 
													where pa.cd_filial_ecommerce = pe.cd_filial_ecommerce 
														and pa.nr_pedido = pe.nr_pedido 
														and (case when pa.id_rede_ecommerce = 'MP' Then 'DC' Else pa.id_rede_ecommerce End) = pb.id_rede_filial)) 
where pb.dh_importacao is not null
	and pb.de_observacao = 'PEDIDO INCOMPLETO'
	and pb.dh_importacao >  dbo.adddate( 'day', -3, getdate( ) )
	and datepart(hour, getdate()) = 8
	and pb.id_ecommerce = :ps_id_ecommerce
	and pb.id_rede_filial = :ps_id_rede" arguments=(("ps_id_ecommerce", string),("ps_id_rede", string))  sort="dh_baixa A " )
