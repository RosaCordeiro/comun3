table(column=(type=long updatewhereclause=yes name=cd_filial_ecommerce dbname="pedido_ecommerce.cd_filial_ecommerce" dbalias="pe.cd_filial_ecommerce" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_ecommerce.nr_pedido" dbalias="pe.nr_pedido" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="pedido_ecommerce_entrega.nr_sequencial" dbalias="pee.nr_sequencial" )
 column=(type=char(60) updatewhereclause=yes name=nm_transportadora dbname="pedido_ecommerce_entrega.nm_transportadora" dbalias="pee.nm_transportadora" )
 column=(type=char(50) updatewhereclause=yes name=de_objeto dbname="pedido_ecommerce_entrega.de_objeto" dbalias="pee.de_objeto" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_entrega dbname="tipo_entrega_ecommerce.id_tipo_entrega" dbalias="te.id_tipo_entrega" )
 column=(type=char(20) updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_ecommerce.nr_pedido_ecommerce" dbalias="pe.nr_pedido_ecommerce" )
 column=(type=char(1) updatewhereclause=yes name=id_comunicacao_pendente dbname="pedido_ecommerce_entrega.id_comunicacao_pendente" dbalias="pee.id_comunicacao_pendente" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="pedido_ecommerce_entrega.id_situacao" dbalias="pee.id_situacao" )
 column=(type=char(13) updatewhereclause=yes name=de_codigo_rastreamento_correio dbname="pedido_ecommerce.de_codigo_rastreamento_correio" dbalias="pe.de_codigo_rastreamento_correio" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_pedido dbname="pedido_ecommerce_auxiliar.id_tipo_pedido" dbalias="pex.id_tipo_pedido" )
 retrieve="select pe.cd_filial_ecommerce , pe.nr_pedido , pee.nr_sequencial, pee.nm_transportadora, pee.de_objeto, te.id_tipo_entrega, pe.nr_pedido_ecommerce, pee.id_comunicacao_pendente, pee.id_situacao,
	pe.de_codigo_rastreamento_correio, pex.id_tipo_pedido
from pedido_ecommerce_entrega pee
	inner join pedido_ecommerce pe on (pe.cd_filial_ecommerce = pe.cd_filial_ecommerce and pe.nr_pedido = pee.nr_pedido)
	inner join pedido_ecommerce_auxiliar pex on (pex.cd_filial_ecommerce = pe.cd_filial_ecommerce and pex.nr_pedido = pe.nr_pedido)
	inner join tipo_entrega_ecommerce te on (te.cd_tipo_entrega = pe.cd_tipo_entrega)
where pe.id_ecommerce = :ps_id_ecommerce
and pe.cd_filial = :pl_cd_filial_hub
and pe.id_situacao in ('C','M','E','F') 
and pe.dh_faturado is not null
and ( pee.id_situacao = 'A' or ( pee.id_situacao = 'F' and pee.id_comunicacao_pendente = 'S' ) )
and te.id_tipo_entrega in ('TOT','ECT','JAD')
" arguments=(("ps_id_ecommerce", string),("pl_cd_filial_hub", number)) )
