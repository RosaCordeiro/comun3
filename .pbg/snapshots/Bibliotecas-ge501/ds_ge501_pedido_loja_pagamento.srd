table(column=(type=decimal(2) updatewhereclause=yes name=vl_forma_pagamento dbname="pedido_ecommerce_auxiliar.vl_forma_pagamento" dbalias="a.vl_forma_pagamento" )
 column=(type=long updatewhereclause=yes name=nr_parcelas dbname="pedido_ecommerce.nr_parcelas" dbalias="p.nr_parcelas" )
 column=(type=char(20) updatewhereclause=yes name=nr_comprovante_cartao_credito dbname="pedido_ecommerce_auxiliar.nr_comprovante_cartao_credito" dbalias="a.nr_comprovante_cartao_credito" )
 column=(type=char(20) updatewhereclause=yes name=nr_autorizacao_cartao_credito dbname="pedido_ecommerce_auxiliar.nr_autorizacao_cartao_credito" dbalias="a.nr_autorizacao_cartao_credito" )
 column=(type=char(40) updatewhereclause=yes name=nm_administradora_cartao dbname="pedido_ecommerce_auxiliar.nm_administradora_cartao" dbalias="a.nm_administradora_cartao" )
 column=(type=char(10) updatewhereclause=yes name=cd_estabelecimento_cartao dbname="pedido_ecommerce_auxiliar.cd_estabelecimento_cartao" dbalias="a.cd_estabelecimento_cartao" )
 column=(type=char(20) updatewhereclause=yes name=nr_cartao_credito dbname="pedido_ecommerce_auxiliar.nr_cartao_credito" dbalias="a.nr_cartao_credito" )
 column=(type=char(50) updatewhereclause=yes name=cd_forma_pagamento dbname="pedido_ecommerce.cd_forma_pagamento" dbalias="p.cd_forma_pagamento" )
 column=(type=char(50) updatewhereclause=yes name=cd_tipo_pagamento dbname="pedido_ecommerce.cd_tipo_pagamento" dbalias="p.cd_tipo_pagamento" )
 retrieve="select a.vl_forma_pagamento,
		p.nr_parcelas,
		a.nr_comprovante_cartao_credito,
		a.nr_autorizacao_cartao_credito,
		a.nm_administradora_cartao,
		a.cd_estabelecimento_cartao,
		a.nr_cartao_credito,
		p.cd_forma_pagamento,
		p.cd_tipo_pagamento 
from pedido_ecommerce p
	inner join pedido_ecommerce_auxiliar a on a.cd_filial_ecommerce = p.cd_filial_ecommerce and a.nr_pedido = p.nr_pedido 
where p.nr_pedido = :pl_nr_pedido
and p.cd_filial_ecommerce = :pl_cd_filial

UNION ALL

select vl_forma_pagamento_2, 
		nr_parcelas_2 , 
		nr_comp_cartao_credito_2 , 
		nr_autoriz_cartao_credito_2 ,
		nm_administradora_cartao_2 , 
		cd_estabelecimento_cartao_2 , 
		nr_cartao_credito_2 , 
		cd_forma_pagamento_2 , 
		cd_tipo_pagamento_2  
from pedido_ecommerce_auxiliar 
where nr_pedido = :pl_nr_pedido
and cd_filial_ecommerce = :pl_cd_filial
and nm_administradora_cartao_2 is not null
and vl_forma_pagamento_2 > 0" arguments=(("pl_cd_filial", number),("pl_nr_pedido", number)) )
