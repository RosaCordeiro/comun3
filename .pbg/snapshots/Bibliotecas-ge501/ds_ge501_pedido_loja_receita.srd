table(column=(type=long update=yes updatewhereclause=yes name=cd_filial_ecommerce dbname="pedido_ecommerce_prd_receita.cd_filial_ecommerce" dbalias="pr.cd_filial_ecommerce" )
 column=(type=long update=yes updatewhereclause=yes name=nr_pedido dbname="pedido_ecommerce_prd_receita.nr_pedido" dbalias="pr.nr_pedido" )
 column=(type=char(10) update=yes updatewhereclause=yes name=cd_produto_ecommerce dbname="pedido_ecommerce_prd_receita.cd_produto_ecommerce" dbalias="pr.cd_produto_ecommerce" )
 column=(type=long update=yes updatewhereclause=yes name=nr_sequencial dbname="pedido_ecommerce_prd_receita.nr_sequencial" dbalias="pr.nr_sequencial" )
 column=(type=char(60) update=yes updatewhereclause=yes name=nm_cliente dbname="pedido_ecommerce_prd_receita.nm_cliente" dbalias="pr.nm_cliente" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_nascimento dbname="pedido_ecommerce_prd_receita.dh_nascimento" dbalias="pr.dh_nascimento" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_sexo dbname="pedido_ecommerce_prd_receita.id_sexo" dbalias="pr.id_sexo" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_endereco dbname="pedido_ecommerce_prd_receita.de_endereco" dbalias="pr.de_endereco" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_endereco dbname="pedido_ecommerce_prd_receita.nr_endereco" dbalias="pr.nr_endereco" )
 column=(type=char(20) update=yes updatewhereclause=yes name=de_complemento dbname="pedido_ecommerce_prd_receita.de_complemento" dbalias="pr.de_complemento" )
 column=(type=char(20) update=yes updatewhereclause=yes name=de_bairro dbname="pedido_ecommerce_prd_receita.de_bairro" dbalias="pr.de_bairro" )
 column=(type=char(30) update=yes updatewhereclause=yes name=nm_cidade dbname="pedido_ecommerce_prd_receita.nm_cidade" dbalias="pr.nm_cidade" )
 column=(type=char(8) update=yes updatewhereclause=yes name=nr_cep dbname="pedido_ecommerce_prd_receita.nr_cep" dbalias="pr.nr_cep" )
 column=(type=char(2) update=yes updatewhereclause=yes name=cd_unidade_federacao dbname="pedido_ecommerce_prd_receita.cd_unidade_federacao" dbalias="pr.cd_unidade_federacao" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_doc_identificacao dbname="pedido_ecommerce_prd_receita.nr_doc_identificacao" dbalias="pr.nr_doc_identificacao" )
 column=(type=char(10) update=yes updatewhereclause=yes name=de_orgao_emissor_rg dbname="pedido_ecommerce_prd_receita.de_orgao_emissor_rg" dbalias="pr.de_orgao_emissor_rg" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_fone dbname="pedido_ecommerce_prd_receita.nr_fone" dbalias="pr.nr_fone" )
 column=(type=char(30) update=yes updatewhereclause=yes name=nr_token dbname="pedido_ecommerce_prd_receita.nr_token" dbalias="pr.nr_token" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_ecommerce_produto.cd_produto" dbalias="pp.cd_produto" )
 retrieve="  SELECT pr.cd_filial_ecommerce,   
         pr.nr_pedido,   
         pr.cd_produto_ecommerce,   
         pr.nr_sequencial,   
         pr.nm_cliente,   
         pr.dh_nascimento,   
         pr.id_sexo,   
         pr.de_endereco,   
         pr.nr_endereco,   
         pr.de_complemento,   
         pr.de_bairro,   
         pr.nm_cidade,   
         pr.nr_cep,   
         pr.cd_unidade_federacao,   
         pr.nr_doc_identificacao,   
         pr.de_orgao_emissor_rg,   
         pr.nr_fone,   
         pr.nr_token,
		pp.cd_produto  
    FROM pedido_ecommerce_prd_receita pr
		inner join pedido_ecommerce_produto pp on ( pp.cd_filial_ecommerce = pr.cd_filial_ecommerce
																and pp.nr_pedido = pr.nr_pedido
																and pp.cd_produto_ecommerce = pr.cd_produto_ecommerce )
where pr.cd_filial_ecommerce = :pl_cd_filial
and pr.nr_pedido = :pl_nr_pedido" arguments=(("pl_cd_filial", number),("pl_nr_pedido", number)) )
