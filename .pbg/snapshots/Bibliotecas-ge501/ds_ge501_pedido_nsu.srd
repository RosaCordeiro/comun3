table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_ecommerce.cd_filial" dbalias="p.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=de_codigo_transacao dbname="pedido_ecommerce_auxiliar.de_codigo_transacao" dbalias="x.de_codigo_transacao" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_ecommerce.nr_pedido" dbalias="p.nr_pedido" )
 column=(type=char(20) updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_ecommerce.nr_pedido_ecommerce" dbalias="p.nr_pedido_ecommerce" )
 column=(type=long updatewhereclause=yes name=cd_filial_ecommerce dbname="pedido_ecommerce_auxiliar.cd_filial_ecommerce" dbalias="x.cd_filial_ecommerce" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_ecommerce dbname="pedido_ecommerce_auxiliar.id_rede_ecommerce" dbalias="x.id_rede_ecommerce" )
 column=(type=datetime updatewhereclause=yes name=dh_compra dbname="pedido_ecommerce.dh_compra" dbalias="p.dh_compra" )
 column=(type=char(50) updatewhereclause=yes name=cd_tipo_pagamento dbname="pedido_ecommerce.cd_tipo_pagamento" dbalias="p.cd_tipo_pagamento" )
 column=(type=decimal(2) updatewhereclause=yes name=pedido_ecommerce_vl_total dbname="pedido_ecommerce.vl_total" dbalias="p.vl_total" )
 column=(type=long updatewhereclause=yes name=cd_seller dbname="pedido_ecommerce_auxiliar.cd_seller" dbalias="x.cd_seller" )
 column=(type=datetime updatewhereclause=yes name=dh_faturado dbname="pedido_ecommerce.dh_faturado" dbalias="p.dh_faturado" )
 column=(type=char(20) updatewhereclause=yes name=nr_comprovante_cartao_credito dbname="pedido_ecommerce_auxiliar.nr_comprovante_cartao_credito" dbalias="x.nr_comprovante_cartao_credito" )
 column=(type=char(20) updatewhereclause=yes name=nr_comp_cartao_credito_2 dbname="pedido_ecommerce_auxiliar.nr_comp_cartao_credito_2" dbalias="x.nr_comp_cartao_credito_2" )
 retrieve="select p.cd_filial, x.de_codigo_transacao , p.nr_pedido, p.nr_pedido_ecommerce, x.cd_filial_ecommerce,
	x.id_rede_ecommerce,
	p.dh_compra, p.cd_tipo_pagamento, p.vl_total, x.cd_seller, p.dh_faturado, x.nr_comprovante_cartao_credito, x.nr_comp_cartao_credito_2
from pedido_ecommerce p
inner join pedido_ecommerce_auxiliar x
	on x.cd_filial_ecommerce = p.cd_filial_ecommerce
	and x.nr_pedido = p.nr_pedido
where p.dh_compra >= (select dateadd(day, -60, dh_movimentacao) from parametro where id_parametro = '1')
and p.id_ecommerce = '2' 
 and p.nr_pedido_ecommerce is not null
    and p.nr_pedido_ecommerce not in ('1050760717217-01')
  and x.de_codigo_transacao is not null
  and x.nr_autorizacao_cartao_credito is not null
  and x.nr_nsu_host is null
  and p.id_situacao in ('M',  'F', 'D', 'C', 'E')
  and x.dh_atualizacao_site <= dateadd(mi,-3, getdate())
  and x.id_rede_ecommerce =:rede
 and coalesce(x.id_ignorar_integracao_status, 'N') = 'N'
 and (x.id_tipo_pedido is null or x.id_tipo_pedido not in ('GTM','MGZ') )

union 

select p.cd_filial, x.de_codigo_transacao , p.nr_pedido, p.nr_pedido_ecommerce, x.cd_filial_ecommerce,
	x.id_rede_ecommerce,
	p.dh_compra, p.cd_tipo_pagamento, p.vl_total, x.cd_seller, p.dh_faturado, x.nr_comprovante_cartao_credito,  x.nr_comp_cartao_credito_2
from pedido_ecommerce p
inner join pedido_ecommerce_auxiliar x
	on x.cd_filial_ecommerce = p.cd_filial_ecommerce
	and x.nr_pedido = p.nr_pedido
where p.dh_compra >= (select dateadd(day, -30, dh_movimentacao) from parametro where id_parametro = '1')
and p.id_ecommerce = '2' 
  and p.nr_pedido_ecommerce is not null
    and p.nr_pedido_ecommerce not in ('1050760717217-01')
  and x.de_codigo_transacao is not null
  and x.nr_autorizacao_cartao_credito is not null
  and x.nr_nsu_host is null
  and p.id_situacao = 'X'
  and p.dh_faturado is not null
  and x.dh_atualizacao_site <= dateadd(mi,-3, getdate())
  and x.id_rede_ecommerce =:rede
and coalesce(x.id_ignorar_integracao_status, 'N') = 'N'
 and (x.id_tipo_pedido is null or x.id_tipo_pedido not in ('GTM','MGZ') )" arguments=(("rede", string))  sort="cd_filial_ecommerce A " )
