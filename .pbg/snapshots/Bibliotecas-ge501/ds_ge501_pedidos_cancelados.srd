table(column=(type=char(20) updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_ecommerce.nr_pedido_ecommerce" dbalias="x1.nr_pedido_ecommerce" )
 column=(type=long updatewhereclause=yes name=cd_filial_ecommerce dbname="pedido_ecommerce.cd_filial_ecommerce" dbalias="x1.cd_filial_ecommerce" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_ecommerce.nr_pedido" dbalias="x1.nr_pedido" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_ecommerce dbname="pedido_ecommerce_auxiliar.id_rede_ecommerce" dbalias="x2.id_rede_ecommerce" )
 column=(type=long updatewhereclause=yes name=cd_seller dbname="pedido_ecommerce_auxiliar.cd_seller" dbalias="x2.cd_seller" )
 retrieve="select x1.nr_pedido_ecommerce, x1.cd_filial_ecommerce, x1.nr_pedido, x2.id_rede_ecommerce, x2.cd_seller
from pedido_ecommerce x1
	inner join pedido_ecommerce_auxiliar x2 on x2.cd_filial_ecommerce = x1.cd_filial_ecommerce and x2.nr_pedido = x1.nr_pedido
where x1.id_situacao = 'X'
and x1.dh_compra between :pdh_inicio and :pdh_fim
and x2.id_rede_ecommerce = :ps_rede
and x2.de_motivo_cancelamento_pedido is null" arguments=(("ps_rede", string),("pdh_inicio", datetime),("pdh_fim", datetime)) )
