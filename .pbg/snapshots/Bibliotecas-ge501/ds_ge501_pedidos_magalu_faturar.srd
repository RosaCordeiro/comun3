table(column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_ecommerce.nr_pedido" )
 column=(type=char(20) updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_ecommerce.nr_pedido_ecommerce" )
 column=(type=char(9) updatewhereclause=yes name=id_situacao dbname="pedido_ecommerce.id_situacao" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_venda.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_venda.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_venda.de_serie" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_venda_nfe.de_chave_acesso" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_venda.dh_emissao" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_venda.cd_filial" )
 retrieve="select pe.nr_pedido, pe.nr_pedido_ecommerce, pe.id_situacao, nv.nr_nf , nv.de_especie , nv.de_serie , ne.de_chave_acesso , nv.dh_emissao , nv.cd_filial 
from pedido_ecommerce pe 
	inner join pedido_ecommerce_auxiliar pa on pa.nr_pedido = pe.nr_pedido 
	inner join nf_venda nv on nv.nr_pedido_ecommerce = pe.nr_pedido and nv.cd_filial_ecommerce = pe.cd_filial_ecommerce 
	left join nf_venda_nfe ne on ne.cd_filial = nv.cd_filial and ne.nr_nf = nv.nr_nf and ne.de_especie = nv.de_especie and ne.de_serie = nv.de_serie 
where pe.nr_pedido > 603030111
and pe.nr_pedido_ecommerce in (
