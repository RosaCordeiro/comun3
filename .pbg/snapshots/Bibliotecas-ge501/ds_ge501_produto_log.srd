table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="pg.cd_produto" )
 column=(type=long updatewhereclause=yes name=cd_marca_ecommerce dbname="produto_geral.cd_marca_ecommerce" dbalias="pg.cd_marca_ecommerce" )
 column=(type=char(10) updatewhereclause=yes name=cd_produto_ecommerce dbname="ecommerce_prd.cd_produto_ecommerce" dbalias="ep.cd_produto_ecommerce" )
 column=(type=long updatewhereclause=yes name=cd_categoria_ecommerce dbname="produto_central.cd_categoria_ecommerce" dbalias="pc.cd_categoria_ecommerce" )
 column=(type=char(10) updatewhereclause=yes name=cd_sku dbname="ecommerce_prd.cd_sku" dbalias="ep.cd_sku" )
 column=(type=char(1) updatewhereclause=yes name=id_manipulado dbname="id_manipulado" )
 column=(type=char(70) updatewhereclause=yes name=de_descricao_manip dbname="de_descricao_manip" )
 column=(type=char(100) updatewhereclause=yes name=de_tag_title dbname="ecommerce_prd.de_tag_title" dbalias="ep.de_tag_title" )
 column=(type=char(200) updatewhereclause=yes name=de_tag_description dbname="ecommerce_prd.de_tag_description" dbalias="ep.de_tag_description" )
 retrieve="Select pg.cd_produto, pg.cd_marca_ecommerce, ep.cd_produto_ecommerce, pc.cd_categoria_ecommerce, ep.cd_sku, 'N' id_manipulado, '' de_descricao_manip, ep.de_tag_title, ep.de_tag_description
from 
(
  Select distinct convert(int,de_chave) as cd_produto
    From log_exportacao_ecommerce  l
   Where  l.id_processado = 'P' 
 	 and l.nm_tabela = 'PRODUTO_GERAL'
	 and l.cd_filial_ecommerce = :pl_cd_filial
	 and l.id_ecommerce = :ps_id_ecommerce
      and l.de_chave not like 'OR%'
) Aux inner join produto_geral pg on (pg.cd_produto = Aux.cd_produto)
		inner join produto_central pc on (pc.cd_produto = pg.cd_produto)
		left join ecommerce_prd ep on (ep.cd_produto = pg.cd_produto
														and ep.id_ecommerce = :ps_id_ecommerce
														and ep.id_rede_filial = :ps_rede)
where pg.cd_subcategoria <> '901001001' -- INTERFACE SAP
	
union

Select  ep.nr_requisicao_manip cd_produto, er.cd_marca_manip as cd_marca_ecommerce, ep.cd_produto_ecommerce,  er.cd_categoria_manip as cd_categoria_ecommerce, ep.cd_sku, 'S' id_manipulado, ep.de_descricao_manip, ep.de_tag_title, ep.de_tag_description
from
(
	Select distinct convert(int,ltrim(substring(de_chave, 3, 10))) as cd_produto
	From log_exportacao_ecommerce  l
	Where  l.id_processado = 'P' 
	 and l.nm_tabela = 'PRODUTO_GERAL'
	 and l.cd_filial_ecommerce = :pl_cd_filial
	 and l.id_ecommerce = :ps_id_ecommerce
	 and l.de_chave like 'OR%'
) aux inner join ecommerce_prd ep 
			on ep.nr_requisicao_manip = aux.cd_produto
		   and ep.id_ecommerce = :ps_id_ecommerce
   		   and ep.id_rede_filial = :ps_rede
		inner join ecommerce_rede er
			on er.id_ecommerce = ep.id_ecommerce
			and er.id_rede_filial = ep.id_rede_filial
where coalesce(ep.id_manipulado, 'N') = 'S'

" arguments=(("ps_id_ecommerce", string),("pl_cd_filial", number),("ps_rede", string))  sort="cd_produto A " )
