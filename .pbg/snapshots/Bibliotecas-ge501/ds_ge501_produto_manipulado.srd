table(column=(type=char(1) update=yes updatewhereclause=yes name=id_ecommerce dbname="ecommerce_prd.id_ecommerce" dbalias="ep.id_ecommerce" )
 column=(type=char(2) update=yes updatewhereclause=yes name=id_rede_filial dbname="ecommerce_prd.id_rede_filial" dbalias="ep.id_rede_filial" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="ecommerce_prd.cd_produto" dbalias="ep.cd_produto" )
 column=(type=char(10) update=yes updatewhereclause=yes name=cd_produto_ecommerce dbname="ecommerce_prd.cd_produto_ecommerce" dbalias="ep.cd_produto_ecommerce" )
 column=(type=char(10) update=yes updatewhereclause=yes name=cd_sku dbname="ecommerce_prd.cd_sku" dbalias="ep.cd_sku" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_requisicao_manip dbname="ecommerce_prd.vl_requisicao_manip" dbalias="ep.vl_requisicao_manip" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_atualizacao_manip dbname="ecommerce_prd.dh_atualizacao_manip" dbalias="ep.dh_atualizacao_manip" )
 column=(type=char(70) updatewhereclause=yes name=de_url_imagem_manip dbname="ecommerce_rede.de_url_imagem_manip" dbalias="er.de_url_imagem_manip" )
 column=(type=char(40) updatewhereclause=yes name=de_nome_imagem_manip dbname="ecommerce_rede.de_nome_imagem_manip" dbalias="er.de_nome_imagem_manip" )
 column=(type=long updatewhereclause=yes name=nr_requisicao_manip dbname="ecommerce_prd.nr_requisicao_manip" dbalias="ep.nr_requisicao_manip" )
 column=(type=char(70) updatewhereclause=yes name=de_descricao_manip dbname="ecommerce_prd.de_descricao_manip" dbalias="ep.de_descricao_manip" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_altura_cm dbname="ecommerce_rede.qt_altura_cm" dbalias="er.qt_altura_cm" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_profundidade_cm dbname="ecommerce_rede.qt_profundidade_cm" dbalias="er.qt_profundidade_cm" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_largura_cm dbname="ecommerce_rede.qt_largura_cm" dbalias="er.qt_largura_cm" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_grama dbname="ecommerce_rede.qt_peso_grama" dbalias="er.qt_peso_grama" )
 column=(type=char(1) updatewhereclause=yes name=id_possui_imagem dbname="id_possui_imagem" )
 retrieve="  SELECT ep.id_ecommerce,   
         ep.id_rede_filial,   
         ep.cd_produto,   
         ep.cd_produto_ecommerce,   
         ep.cd_sku,   
         ep.vl_requisicao_manip,   
         ep.dh_atualizacao_manip,
		er. de_url_imagem_manip,
		er.de_nome_imagem_manip ,
		ep.nr_requisicao_manip,
		ep.de_descricao_manip,
		er.qt_altura_cm, 
		er.qt_profundidade_cm, 
		er.qt_largura_cm, 
		er.qt_peso_grama,
		coalesce(ep.id_possui_imagem, 'N') id_possui_imagem
    FROM ecommerce_prd ep   
inner join ecommerce_rede er 
	on er.id_ecommerce = ep.id_ecommerce
	and er.id_rede_filial = ep.id_rede_filial
where coalesce(ep.id_manipulado, 'N') = 'S'
	and ep.dh_atualizacao_manip is null
	and ep.cd_sku is not null
     and ep.id_ecommerce = :ecommerce
	and ep.id_rede_filial = :rede_filial
" arguments=(("ecommerce", string),("rede_filial", string)) )
