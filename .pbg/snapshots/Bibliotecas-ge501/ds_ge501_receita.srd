 retrieve="  SELECT nr_sequencial,   
         id_ecommerce,   
         id_rede_filial,   
         de_endereco_email,   
         nm_cliente,   
         nr_cpf_cgc,   
         de_observacao,   
         nr_telefone,   
         nm_arquivo_receita,   
         id_receita,   
         dh_inclusao_site,   
         dh_inclusao,   
         dh_receita_integrada  
    FROM ecommerce_manip_receita   
	where dh_receita_integrada is null
" update="ecommerce_manip_receita" updatewhere=0 updatekeyinplace=yes )
