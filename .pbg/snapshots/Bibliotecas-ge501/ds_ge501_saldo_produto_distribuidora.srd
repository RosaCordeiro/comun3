table(column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_saldo dbname="qt_saldo" )
 retrieve="Select Aux.cd_produto, Sum(Aux.qt_saldo) as qt_saldo
From
(
 Select d.cd_produto, 
    COALESCE( d.qt_estoque_disponivel , 0 ) * COALESCE( g.vl_fator_conversao, 1 ) as qt_saldo
 From distribuidora_produto d
 	Inner join fornecedor f
 		on f.cd_fornecedor = d.cd_distribuidora
 	Inner join filial_distribuidora fd
 		on fd.cd_distribuidora = d.cd_distribuidora
 	Inner join produto_geral g
 		on g.cd_produto = d.cd_produto
	inner join ecommerce_distrib ec
		on ec.id_ecommerce = '2'
		and ec.cd_distribuidora = d.cd_distribuidora
		and ec.cd_filial = fd.cd_filial
 Where  fd.cd_filial = :pl_cd_filial
 	and d.cd_unidade_federacao = :ps_cd_uf
	and d.cd_distribuidora <> '053404705'
	and ( 
			( coalesce(ec.id_estoque_maior_10dias, 'N') = 'S' and coalesce(d.id_estoque_maior_10dias, 'N') = 'S' )
		or ( coalesce(ec.id_estoque_maior_10dias, 'N') = 'N' )
		)
	and coalesce(f.id_atende_pedido_ecommerce, 'N') = 'S'
 	and coalesce(f.id_situacao, 'A') = 'A'
 	and fd.id_situacao = 'A'
 	and d.id_situacao	 = 'A'
	and d.qt_estoque_disponivel >= ec.qt_minima_estoque
	and ec.dh_inicio_saldo <= cast(getdate() as date)
	and ec.dh_termino_saldo >= cast(getdate() as date)
	And ( ( :ps_id_rede = 'DC' and g.id_liberado_ecommerce_dc = 'S' ) 
	or ( :ps_id_rede = 'PP' and g.id_liberado_ecommerce_pp = 'S' ) 
	or ( :ps_id_rede = 'FA' and g.id_liberado_ecommerce = 'S' )
	or ( :ps_id_rede = 'MP' and g.id_liberado_ecommerce_mp = 'S' ) )
	and left(g.de_produto,2) <> 'ZZ'
	and not exists (select 1
					from pedido_filial_bloqueio x			
					where x.id_tipo_bloqueio = 'D'
						and x.cd_filial is null
						and x.cd_distribuidora = d.cd_distribuidora 
						and x.dh_pedido is null
						and x.nr_dia_semana is null
						and x.cd_uf = d.cd_unidade_federacao
						and x.dh_inicio_bloqueio <= (select dh_movimentacao from parametro where id_parametro = '1')
						and x.dh_termino_bloqueio >= (select dh_movimentacao from parametro where id_parametro = '1') )
) Aux
group by Aux.cd_produto" arguments=(("pl_cd_filial", number),("ps_cd_uf", string),("ps_id_rede", string)) )
