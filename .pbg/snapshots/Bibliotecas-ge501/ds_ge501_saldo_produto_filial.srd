table(column=(type=date updatewhereclause=yes name=dh_saldo dbname="dh_saldo" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=decimal(0) updatewhereclause=yes name=qt_saldo_final dbname="qt_saldo_final" )
 column=(type=char(255) updatewhereclause=yes name=id_enviado_site dbname="id_enviado_site" )
 retrieve="Select Aux1.dh_saldo, Aux1.cd_produto, 
		( Aux1.qt_saldo_final - coalesce(Aux2.qt_saldo_reserva,0) ) as qt_saldo_final,
		Aux1.id_enviado_site
from
(
	select s.dh_saldo, s.cd_produto, 
			s.qt_saldo_final,
			'N' as id_enviado_site
	from saldo_produto s
		inner join produto_geral pg on (pg.cd_produto = s.cd_produto)
	where s.dh_saldo = :pdt_saldo
		and ((s.id_atualizado_site = 'N' or (s.id_atualizado_site is null and s.qt_saldo_final > 0) ) or pg.cd_produto in (select cd_produto from vw_saldo_produto_pendente v where v.tipo_movimento = 'TRANSF. FILIAL' OR v.tipo_movimento = 'RESERVA CLIENTE'))
		and pg.cd_grupo_psico is null
		and left(pg.de_produto,2) <> 'ZZ'
		and left(pg.cd_subcategoria,1) <> '5'
		and (  
			(:ps_id_rede = 'DC' and pg.id_liberado_ecommerce_dc = 'S' ) 
		or (:ps_id_rede = 'PP' and pg.id_liberado_ecommerce_pp = 'S' ) 
		 or (:ps_id_rede = 'FA' and pg.id_liberado_ecommerce = 'S' )
		or (:ps_id_rede = 'MP' and pg.id_liberado_ecommerce_mp = 'S' )
			)
	) Aux1 
		left join (
						SELECT v.cd_produto, COALESCE( SUM( v.qt_saldo ), 0 ) qt_saldo_reserva
						FROM vw_saldo_produto_pendente v
						inner join produto_geral pg
							on pg.cd_produto = v.cd_produto
						WHERE ( v.tipo_movimento = 'TRANSF. FILIAL' OR v.tipo_movimento = 'RESERVA CLIENTE' )
							and pg.cd_grupo_psico is null
							and left(pg.de_produto,2) <> 'ZZ'
							and left(pg.cd_subcategoria,1) <> '5'
							and (  
								(:ps_id_rede = 'DC' and pg.id_liberado_ecommerce_dc = 'S' ) 
							or (:ps_id_rede = 'PP' and pg.id_liberado_ecommerce_pp = 'S' ) 
							 or (:ps_id_rede = 'FA' and pg.id_liberado_ecommerce = 'S' )
							or (:ps_id_rede = 'MP' and pg.id_liberado_ecommerce_mp = 'S' )
								)
						group by v.cd_produto

				) Aux2 on (Aux2.cd_produto = Aux1.cd_produto)" arguments=(("pdt_saldo", date),("ps_id_rede", string))  sort="cd_produto A " )
