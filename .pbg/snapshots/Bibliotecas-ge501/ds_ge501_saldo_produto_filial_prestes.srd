table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_preste_a_vencer.cd_produto" dbalias="p.cd_produto" )
 column=(type=decimal(0) updatewhereclause=yes name=qt_prestes dbname="qt_prestes" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" dbalias="pg.cd_grupo_psico" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="saldo_produto.qt_saldo_final" dbalias="s.qt_saldo_final" )
 retrieve="select p.cd_produto, count(*) qt_prestes, pg.cd_grupo_psico, s.qt_saldo_final
from produto_preste_a_vencer p
inner join produto_geral pg
on pg.cd_produto = p.cd_produto
inner join saldo_produto s
on s.cd_produto = pg.cd_produto
and s.dh_saldo = :p_dh_saldo
where p.cd_filial_inclusao = :p_filial
and p.dh_validade < (select cast(substring(to_char(dh_movimentacao,'YYYY-MM-DD'),1,7)+'-01' as date) + interval '6 month' from parametro where id_parametro = '1')
and p.dh_validade >= (select cast(substring(to_char(dh_movimentacao,'YYYY-MM-DD'),1,7)+'-01' as date) - interval '6 month' from parametro where id_parametro = '1')
and p.id_situacao = 'A'
and left(pg.cd_subcategoria,1) in ( '1', '2', '3', '4')
and s.qt_saldo_final > 0
and ( (:p_id_rede_filial = 'DC' and pg.id_liberado_ecommerce_dc = 'S' ) or
(:p_id_rede_filial = 'PP' and pg.id_liberado_ecommerce_pp = 'S' ) or
(:p_id_rede_filial = 'FA' and pg.id_liberado_ecommerce = 'S' ))
group by p.cd_produto, pg.cd_grupo_psico, s.qt_saldo_final" arguments=(("p_dh_saldo", date),("p_filial", number),("p_id_rede_filial", string)) )
