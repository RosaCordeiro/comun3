table(column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_solicitada dbname="qt_solicitada" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="cd_grupo_psico" )
 column=(type=long updatewhereclause=yes name=qt_saldo_filial dbname="qt_saldo_filial" )
 retrieve="select Aux.cd_produto, sum(Aux.qt_solicitada) as qt_solicitada , Aux.cd_grupo_psico, Aux.qt_saldo_filial 
FROM 
(
	select rep.cd_produto, 
		sum(rep.qt_solicitada) as qt_solicitada, 
		pg.cd_grupo_psico, epf.qt_saldo_filial 
	from dbo.retirada_estoque re
		inner join dbo.retirada_estoque_produto rep on rep.cd_filial = re.cd_filial 
													and rep.nr_retirada_estoque  = re.nr_retirada_estoque 
		inner join ecommerce_prd_filial epf on epf.id_ecommerce = '2'
											and epf.id_rede_filial = :ps_id_rede_filial
											and epf.cd_filial = re.cd_filial 
											and epf.cd_produto = rep.cd_produto 
		inner join produto_geral pg on pg.cd_produto = rep.cd_produto 
	where re.cd_filial = :pl_cd_filial
	and re.id_situacao in ('S')
	and re.id_tipo_retirada <> 'E'
	and rep.qt_solicitada > 0
	and left(pg.cd_subcategoria,1) in ( '1', '2', '3', '4')
	and ( (:ps_id_rede_filial = 'DC' and pg.id_liberado_ecommerce_dc = 'S' ) 
		or (:ps_id_rede_filial = 'PP' and pg.id_liberado_ecommerce_pp = 'S' ) 
		or (:ps_id_rede_filial = 'FA' and pg.id_liberado_ecommerce = 'S' ))
	group by rep.cd_produto,  pg.cd_grupo_psico, epf.qt_saldo_filial 

	UNION ALL

	select rep.cd_produto, 
		sum(rep.qt_aprovada) as qt_solicitada, 
		pg.cd_grupo_psico, epf.qt_saldo_filial 
	from dbo.retirada_estoque re
		inner join dbo.retirada_estoque_produto rep on rep.cd_filial = re.cd_filial 
													and rep.nr_retirada_estoque  = re.nr_retirada_estoque 
		inner join ecommerce_prd_filial epf on epf.id_ecommerce = '2'
											and epf.id_rede_filial = :ps_id_rede_filial
											and epf.cd_filial = re.cd_filial 
											and epf.cd_produto = rep.cd_produto 
		inner join produto_geral pg on pg.cd_produto = rep.cd_produto 
	where re.cd_filial = :pl_cd_filial
	and re.id_situacao in ('A')
	and re.id_tipo_retirada <> 'E'
	and rep.qt_aprovada > 0
	and left(pg.cd_subcategoria,1) in ( '1', '2', '3', '4')
	and ( (:ps_id_rede_filial = 'DC' and pg.id_liberado_ecommerce_dc = 'S' ) 
		or (:ps_id_rede_filial = 'PP' and pg.id_liberado_ecommerce_pp = 'S' ) 
		or (:ps_id_rede_filial = 'FA' and pg.id_liberado_ecommerce = 'S' ))
	and re.dh_termino >= convert(date, getdate())
	group by rep.cd_produto,  pg.cd_grupo_psico, epf.qt_saldo_filial 
) Aux
group by Aux.cd_produto, Aux.cd_grupo_psico, Aux.qt_saldo_filial
order by Aux.cd_produto" arguments=(("pl_cd_filial", number),("ps_id_rede_filial", string)) )
