table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="pg.cd_produto" )
 column=(type=char(10) updatewhereclause=yes name=cd_sku dbname="ecommerce_prd.cd_sku" dbalias="ep.cd_sku" )
 column=(type=long updatewhereclause=yes name=qt_saldo_atualizar dbname="qt_saldo_atualizar" )
 column=(type=char(1) updatewhereclause=yes name=id_controlado dbname="id_controlado" )
 retrieve="select pg.cd_produto, ep.cd_sku, 1 qt_saldo_atualizar, Case when pg.cd_grupo_psico is null Then 'N' Else 'S' End as id_controlado
from produto_geral pg
	inner join ecommerce_prd  ep on ( ep.cd_produto = pg.cd_produto
											 and ep.id_ecommerce = :ps_id_ecommerce
											 and ep.id_rede_filial = :ps_id_rede )
where coalesce(ep.qt_saldo, 0) = 0
  and  ( left(pg.de_produto,2) <> 'ZZ' and pg.cd_grupo_psico is null )
  and coalesce(ep.id_manipulado, 'N') = 'N'
and ( (select count(*) 
                from ecommerce_prd_filial a
                    inner join ecommerce_rede_filial er on (er.id_ecommerce = a.id_ecommerce and er.cd_filial = a.cd_filial and er.id_rede_filial = a.id_rede_filial )
                where a.id_ecommerce = ep.id_ecommerce
                and a.cd_produto = ep.cd_produto
                and er.id_situacao = 'A'
                and (a.qt_saldo > 0 or a.qt_saldo_distribuidora > 0)
                and a.id_rede_filial in (ep.id_rede_filial )
                and er.cd_filial_hub is not null
			  and er.cd_filial_hub not in ( 539,339,672) ) > 0
    Or (select count(*) 
                from ecommerce_prd_filial a
                    inner join ecommerce_rede_filial er on (er.id_ecommerce = a.id_ecommerce and er.cd_filial = a.cd_filial and er.id_rede_filial = a.id_rede_filial )
                where a.id_ecommerce = ep.id_ecommerce
                and a.cd_produto = ep.cd_produto
                and er.id_situacao = 'A'
                and (a.qt_saldo > 0 or a.qt_saldo_distribuidora > 0) 
                and a.id_rede_filial in (ep.id_rede_filial )) >= 30 )
        
UNION

select pg.cd_produto, ep.cd_sku, 0 qt_saldo_atualizar , Case when pg.cd_grupo_psico is null Then 'N' Else 'S' End as id_controlado
from produto_geral pg
	inner join ecommerce_prd  ep on ( ep.cd_produto = pg.cd_produto
											 and ep.id_ecommerce = :ps_id_ecommerce
											 and ep.id_rede_filial = :ps_id_rede )
where coalesce(ep.qt_saldo, 0) = 1
  and  ( left(pg.de_produto,2) <> 'ZZ' and pg.cd_grupo_psico is null )
  and coalesce(ep.id_manipulado, 'N') = 'N'
and (select count(*) 
            from ecommerce_prd_filial a
                inner join ecommerce_rede_filial er on (er.id_ecommerce = a.id_ecommerce and er.cd_filial = a.cd_filial and er.id_rede_filial = a.id_rede_filial )
            where a.id_ecommerce = ep.id_ecommerce
            and a.cd_produto = ep.cd_produto
            and er.id_situacao = 'A'
            and (a.qt_saldo > 0 or a.qt_saldo_distribuidora > 0)
            and a.id_rede_filial in (ep.id_rede_filial )
            and er.cd_filial_hub is not null 
		   and er.cd_filial_hub not in (539, 339,672) ) = 0
and (select count(*) 
            from ecommerce_prd_filial a
                inner join ecommerce_rede_filial er on (er.id_ecommerce = a.id_ecommerce and er.cd_filial = a.cd_filial and er.id_rede_filial = a.id_rede_filial )
            where a.id_ecommerce = ep.id_ecommerce
            and a.cd_produto = ep.cd_produto
            and er.id_situacao = 'A'
            and (a.qt_saldo > 0 or a.qt_saldo_distribuidora > 0)
            and a.id_rede_filial in (ep.id_rede_filial ) ) < 30
        
Union

select pg.cd_produto, ep.cd_sku, 0 qt_saldo_atualizar ,Case when pg.cd_grupo_psico is null Then 'N' Else 'S' End as id_controlado
from produto_geral pg
	inner join ecommerce_prd  ep on ( ep.cd_produto = pg.cd_produto
											 and ep.id_ecommerce = :ps_id_ecommerce
											 and ep.id_rede_filial = :ps_id_rede )
where coalesce(ep.qt_saldo, 0) = 1
  and ( left(pg.de_produto,2) = 'ZZ' or pg.cd_grupo_psico is not null )
  and coalesce(ep.id_manipulado, 'N') = 'N'
  and Coalesce((select count(*) 
                from ecommerce_prd_filial a
                    inner join ecommerce_rede_filial er on (er.id_ecommerce = a.id_ecommerce and er.cd_filial = a.cd_filial and er.id_rede_filial = a.id_rede_filial )
                where a.id_ecommerce = ep.id_ecommerce
                and a.cd_produto = ep.cd_produto
                and er.id_situacao = 'A'
                and (a.qt_saldo > 0 or a.qt_saldo_distribuidora > 0)
                and a.id_rede_filial in (ep.id_rede_filial ) ),0) = 0 

Union

select pg.cd_produto, ep.cd_sku, 1 qt_saldo_atualizar ,Case when pg.cd_grupo_psico is null Then 'N' Else 'S' End as id_controlado
from produto_geral pg
	inner join ecommerce_prd  ep on ( ep.cd_produto = pg.cd_produto
											 and ep.id_ecommerce = :ps_id_ecommerce
											 and ep.id_rede_filial = :ps_id_rede )
where coalesce(ep.qt_saldo, 0) = 0
  and  ( left(pg.de_produto,2) = 'ZZ' or pg.cd_grupo_psico is not null or coalesce(ep.id_manipulado, 'N') = 'S' ) 
  and Coalesce((select count(*) 
                from ecommerce_prd_filial a
                    inner join ecommerce_rede_filial er on (er.id_ecommerce = a.id_ecommerce and er.cd_filial = a.cd_filial and er.id_rede_filial = a.id_rede_filial )
                where a.id_ecommerce = ep.id_ecommerce
                and a.cd_produto = ep.cd_produto
                and er.id_situacao = 'A'
                and (a.qt_saldo > 0 or a.qt_saldo_distribuidora > 0) 
                and a.id_rede_filial in (ep.id_rede_filial ) ),0) > 0 
" arguments=(("ps_id_ecommerce", string),("ps_id_rede", string)) )
