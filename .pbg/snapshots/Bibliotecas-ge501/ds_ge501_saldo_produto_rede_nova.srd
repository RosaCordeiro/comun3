table(column=(type=long updatewhereclause=yes name=cd_produto dbname="ecommerce_prd.cd_produto" dbalias="ep.cd_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" dbalias="pg.id_situacao" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" dbalias="pg.cd_grupo_psico" )
 column=(type=long updatewhereclause=yes name=qt_saldo_filial_referencia dbname="qt_saldo_filial_referencia" )
 column=(type=long updatewhereclause=yes name=qt_saldo_filial_base dbname="qt_saldo_filial_base" )
 column=(type=long updatewhereclause=yes name=qt_saldo_pend_filial_base dbname="qt_saldo_pend_filial_base" )
 column=(type=long updatewhereclause=yes name=qt_saldo_distrib_referencia dbname="qt_saldo_distrib_referencia" )
 column=(type=long updatewhereclause=yes name=qt_saldo_cd_original dbname="qt_saldo_cd_original" )
 column=(type=char(1) updatewhereclause=yes name=id_inativar_atualizacao_saldo dbname="id_inativar_atualizacao_saldo" )
 column=(type=long updatewhereclause=yes name=qt_minima_estoque dbname="qt_minima_estoque" )
 retrieve="select ep.cd_produto, 
		pg.id_situacao, 
		pg.cd_grupo_psico,
		coalesce(epf1.qt_saldo, 0) as qt_saldo_filial_referencia,
		coalesce(epf2.qt_saldo_filial, 0) as qt_saldo_filial_base,
		coalesce(epf2.qt_saldo_pendente, 0) + coalesce(epf2.qt_saldo_transferencia, 0) + coalesce(epf2.qt_saldo_prestes, 0) as qt_saldo_pend_filial_base,
		coalesce(epf1.qt_saldo_distribuidora, 0) as qt_saldo_distrib_referencia,
		coalesce(se.qt_saldo,0) as qt_saldo_cd_original,
		coalesce(epf1.id_inativar_atualizacao_saldo, 'N') as id_inativar_atualizacao_saldo,
		(select coalesce(qt_minima_estoque, 0) from ecommerce_distrib ec where ec.id_ecommerce = ep.id_ecommerce and ec.cd_distribuidora = '053404705' and ec.cd_filial = :pl_filial_base) as qt_minima_estoque
from ecommerce_prd ep 
inner join produto_geral pg on pg.cd_produto = ep.cd_produto
inner join ecommerce_rede_filial ef on ef.id_ecommerce = ep.id_ecommerce and ef.id_rede_filial = ep.id_rede_filial and ef.cd_filial = :pl_filial
inner join saldo_produto_ecommerce se on se.cd_filial_ecommerce = 534 and se.cd_filial = 534 and se.cd_produto = pg.cd_produto
left join ecommerce_prd_filial epf1 on ep.id_ecommerce = epf1.id_ecommerce and ep.id_rede_filial = epf1.id_rede_filial and ep.cd_produto = epf1.cd_produto and epf1.cd_filial = :pl_filial 
left join ecommerce_prd_filial epf2 on epf2.id_ecommerce = ep.id_ecommerce and epf2.id_rede_filial = :ps_rede_filial_base and epf2.cd_produto = ep.cd_produto and epf2.cd_filial = :pl_filial_base
where ep.id_ecommerce = :ps_ecommerce
  and ep.id_rede_filial = :ps_rede
  and left(pg.cd_subcategoria,1) in ( '1', '2', '3', '4')
  and coalesce(epf1.id_inativar_atualizacao_saldo, 'N') = 'N'
  and se.dh_atualizacao > coalesce(epf1.dh_atualizacao_saldo_distrib,'20230101')
  and (ef.cd_filial_hub > 0 or coalesce(epf1.qt_saldo_distribuidora,-1) <> se.qt_saldo )
 order by ep.cd_produto" arguments=(("ps_ecommerce", string),("pl_filial", number),("ps_rede", string),("pl_filial_base", number),("ps_rede_filial_base", string)) )
