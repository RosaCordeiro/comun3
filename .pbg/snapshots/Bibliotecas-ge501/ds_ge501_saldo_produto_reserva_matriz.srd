table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="pg.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="saldo_produto.qt_saldo_final" dbalias="s.qt_saldo_final" )
 column=(type=long updatewhereclause=yes name=qt_saldo_reserva dbname="qt_saldo_reserva" )
 retrieve="Select pg.cd_produto, s.qt_saldo_final, sum(aux.qt_saldo_reserva) as qt_saldo_reserva
from
(
select re.cd_produto, re.qt_produto as qt_saldo_reserva
from reserva_estoque_produto re
where re.id_ativa = 'S'
and re.dt_termino_reserva >= convert(date,getdate())
and re.cd_filial = :pl_cd_filial

UNION ALL

	Select pp.cd_produto, pp.qt_pedida as qt_saldo_reserva
	From pedido_ecommerce p
	inner join pedido_ecommerce_produto pp
		on pp.cd_filial_ecommerce = p.cd_filial_ecommerce and pp.nr_pedido = p.nr_pedido
	where p.dh_compra >= dateadd(dd,-30, getdate())
		 and p.id_situacao in ( 'A', 'G' )
		and p.cd_filial = :pl_cd_filial
) aux
    inner join produto_geral pg on pg.cd_produto = aux.cd_produto
    inner join saldo_produto s on s.cd_produto = pg.cd_produto
							and s.cd_filial = :pl_cd_filial
                                and s.dh_saldo = :pdt_saldo
where left(pg.cd_subcategoria,1) in ( '1', '2', '3', '4')
and ( 	(:ps_id_rede = 'DC' and pg.id_liberado_ecommerce_dc = 'S' ) or
		(:ps_id_rede = 'PP' and pg.id_liberado_ecommerce_pp = 'S' ) or 
		(:ps_id_rede = 'FA' and pg.id_liberado_ecommerce = 'S' ) or
		(:ps_id_rede = 'MP' and pg.id_liberado_ecommerce_mp = 'S' ))
group by pg.cd_produto, s.qt_saldo_final" arguments=(("pl_cd_filial", number),("ps_id_rede", string),("pdt_saldo", date))  sort="cd_produto A " )
