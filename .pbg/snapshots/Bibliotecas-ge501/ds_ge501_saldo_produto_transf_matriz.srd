table(column=(type=long updatewhereclause=yes name=cd_produto dbname="saldo_produto.cd_produto" dbalias="s.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="saldo_produto.qt_saldo_final" dbalias="s.qt_saldo_final" )
 column=(type=long updatewhereclause=yes name=qt_saldo_transf dbname="qt_saldo_transf" )
 column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="nf_transferencia.cd_filial_origem" dbalias="n.cd_filial_origem" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_transferencia.nr_nf" dbalias="n.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_transferencia.de_especie" dbalias="n.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_transferencia.de_serie" dbalias="n.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_recebimento dbname="nf_transferencia.dh_recebimento" dbalias="n.dh_recebimento" )
 retrieve="select s.cd_produto, s.qt_saldo_final, coalesce(sum(qt_transferida),0) as qt_saldo_transf, n.cd_filial_origem, n.nr_nf, n.de_especie, n.de_serie, n.dh_recebimento
from nf_transferencia n
inner join item_nf_transferencia i
	on i.cd_filial_origem = n.cd_filial_origem
	and i.nr_nf = n.nr_nf
	and i.de_especie = n.de_especie
	and i.de_serie = n.de_serie
inner join produto_geral pg on pg.cd_produto = i.cd_produto
inner join saldo_produto s on s.cd_produto = pg.cd_produto
                            and s.cd_filial = :pl_cd_filial
                            and s.dh_saldo = :pdt_saldo
where n.cd_filial_destino = :pl_cd_filial
  and n.dh_movimentacao_caixa >= dateadd( dd, -30, getdate() )
  and n.dh_cancelamento is null
  and ( n.dh_recebimento is null or n.dh_recebimento >= dateadd( dd, -2, getdate() ) )
  and left(pg.cd_subcategoria,1) in ( '1', '2', '3', '4')
  and (  
      (:ps_id_rede = 'DC' and pg.id_liberado_ecommerce_dc = 'S' ) 
   or (:ps_id_rede = 'PP' and pg.id_liberado_ecommerce_pp = 'S' ) 
   or (:ps_id_rede = 'FA' and pg.id_liberado_ecommerce = 'S' )
   or (:ps_id_rede = 'MP' and pg.id_liberado_ecommerce_mp = 'S' )
  )
group by s.cd_produto, s.qt_saldo_final, n.cd_filial_origem, n.nr_nf, n.de_especie, n.de_serie, n.dh_recebimento" arguments=(("ps_id_rede", string),("pl_cd_filial", number),("pdt_saldo", date)) )
