table(column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_existe dbname="id_existe" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=qt_saldo_cd dbname="qt_saldo_cd" )
 retrieve="select Aux.cd_produto, Aux.id_existe, (dbo.saldo_atual_estoque_central(0, Aux.cd_produto, 'S') * Aux.vl_fator_conversao) as qt_saldo_cd
from
(
select pg.cd_produto, pg.vl_fator_conversao, (case when se.cd_produto > 0 then 'S' else 'N' End) as id_existe
from movimento_estoque me
inner join produto_geral pg on pg.cd_produto = me.cd_produto
left join saldo_produto_ecommerce se on se.cd_filial_ecommerce = 534 and se.cd_filial = 534 and se.cd_produto = pg.cd_produto
where me.cd_filial_movimento = 534 
and me.dh_movimento = :pdh_movimento
and me.dh_inclusao > :pdh_atualizacao
and left(pg.cd_subcategoria,1) in ( '1', '2', '3', '4')
and ( left(pg.de_produto,2) <> 'ZZ' and pg.cd_grupo_psico is null ) 
and exists ( select 1 from ecommerce_prd ep where ep.id_ecommerce = :ps_ecommerce and ep.cd_produto = pg.cd_produto and ep.cd_produto_ecommerce is not null and ep.cd_sku is not null)	 	

Union	

select pg.cd_produto, pg.vl_fator_conversao, (case when se.cd_produto > 0 then 'S' else 'N' End) as id_existe
from pedido_empurrado p
inner join pedido_empurrado_produto pp on pp.cd_filial = p.cd_filial and pp.nr_pedido_empurrado = p.nr_pedido_empurrado
inner join produto_geral pg on pg.cd_produto = pp.cd_produto 
left join saldo_produto_ecommerce se on se.cd_filial_ecommerce = 534 and se.cd_filial = 534 and se.cd_produto = pg.cd_produto
where p.cd_distribuidora = '053404705'
and p.id_situacao not in ('F', 'X')
and COALESCE(p.id_tipo_pedido, 'X') in ('E','U','F')
and p.dh_inclusao > :pdh_atualizacao
and left(pg.cd_subcategoria,1) in ( '1', '2', '3', '4')
and exists ( select 1 from ecommerce_prd ep where ep.id_ecommerce = :ps_ecommerce and ep.cd_produto = pg.cd_produto and ep.cd_produto_ecommerce is not null and ep.cd_sku is not null)	

Union	

select pg.cd_produto, pg.vl_fator_conversao, (case when se.cd_produto > 0 then 'S' else 'N' End) as id_existe
from wms_lista_separacao ls
inner join wms_lista_separacao_produto lp on lp.cd_filial = ls.cd_filial
	and lp.nr_pedido_distribuidora = ls.nr_pedido_distribuidora
	and lp.nr_volume = ls.nr_volume
inner join produto_geral pg on pg.cd_produto = lp.cd_produto 
left join saldo_produto_ecommerce se on se.cd_filial_ecommerce = 534 and se.cd_filial = 534 and se.cd_produto = pg.cd_produto
where ls.dh_geracao > :pdh_atualizacao
and ls.dh_atualizacao_mov_estoque is null
and lp.qt_pedida > 0
and left(pg.cd_subcategoria,1) in ( '1', '2', '3', '4')
and exists ( select 1 from ecommerce_prd ep where ep.id_ecommerce = :ps_ecommerce and ep.cd_produto = pg.cd_produto and ep.cd_produto_ecommerce is not null and ep.cd_sku is not null)

Union

select pg.cd_produto, pg.vl_fator_conversao, (case when se.cd_produto > 0 then 'S' else 'N' End) as id_existe
from distribuidora_produto dp
inner join produto_geral pg on pg.cd_produto = dp.cd_produto 
left join saldo_produto_ecommerce se on se.cd_filial_ecommerce = 534 and se.cd_filial = 534 and se.cd_produto = pg.cd_produto
where dp.cd_distribuidora <> '053404705'
and COALESCE(dp.dh_atualizacao_estoque,dp.dh_atualizacao_distribuidora) > :pdh_atualizacao
and exists ( select 1 from ecommerce_prd ep where ep.id_ecommerce = :ps_ecommerce and ep.cd_produto = pg.cd_produto and ep.cd_produto_ecommerce is not null and ep.cd_sku is not null)
and ( left(pg.de_produto,2) <> 'ZZ' and pg.cd_grupo_psico is null ) 
and left(pg.cd_subcategoria,1) in ( '1', '2', '3', '4')	
) Aux
Order by Aux.cd_produto" arguments=(("ps_ecommerce", string),("pdh_atualizacao", datetime),("pdh_movimento", date)) )
