table(column=(type=char(10) updatewhereclause=yes name=cd_sku dbname="ecommerce_prd.cd_sku" )
 column=(type=char(1) updatewhereclause=yes name=id_permitir_assinatura dbname="id_permitir_assinatura" )
 retrieve="select ep.cd_sku, coalesce(ep.id_permitir_assinatura,'N') as id_permitir_assinatura
from ecommerce_prd ep
	inner join produto_geral pg on pg.cd_produto = ep.cd_produto
where ep.id_ecommerce = :ps_id_ecommerce
and ep.id_rede_filial = :ps_id_rede
and ep.cd_sku is not null
and pg.cd_grupo_psico is null
and left(pg.de_produto,2) <> 'ZZ' 
and coalesce(pg.id_geladeira,'N') = 'N'
and coalesce(ep.id_manipulado,'N') = 'N'" arguments=(("ps_id_ecommerce", string),("ps_id_rede", string)) )
