table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="pg.cd_produto" )
 column=(type=char(10) updatewhereclause=yes name=cd_produto_ecommerce dbname="ecommerce_prd.cd_produto_ecommerce" dbalias="ep.cd_produto_ecommerce" )
 column=(type=char(10) updatewhereclause=yes name=cd_sku dbname="ecommerce_prd.cd_sku" dbalias="ep.cd_sku" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_altura_cm dbname="produto_geral.qt_altura_cm" dbalias="pg.qt_altura_cm" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_profundidade_cm dbname="produto_geral.qt_profundidade_cm" dbalias="pg.qt_profundidade_cm" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_largura_cm dbname="produto_geral.qt_largura_cm" dbalias="pg.qt_largura_cm" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_grama dbname="qt_peso_grama" )
 column=(type=char(100) updatewhereclause=yes name=de_descricao_internet dbname="produto_geral.de_descricao_internet" dbalias="pg.de_descricao_internet" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" dbalias="pg.cd_grupo_psico" )
 column=(type=char(1) updatewhereclause=yes name=id_manipulado dbname="id_manipulado" )
 column=(type=char(9) updatewhereclause=yes name=cd_subcategoria dbname="produto_geral.cd_subcategoria" dbalias="pg.cd_subcategoria" )
 column=(type=char(1) updatewhereclause=yes name=id_geladeira dbname="id_geladeira" )
 column=(type=char(1) updatewhereclause=yes name=id_permitir_assinatura dbname="ecommerce_prd.id_permitir_assinatura" dbalias="ep.id_permitir_assinatura" )
 retrieve="Select pg.cd_produto, 
		ep.cd_produto_ecommerce, 
		ep.cd_sku, 
		pg.qt_altura_cm, 
		pg.qt_profundidade_cm, 
		pg.qt_largura_cm, 
		pg.qt_peso_grama * 1000 as qt_peso_grama , 
		pg.de_descricao_internet, 
		pg.cd_grupo_psico, 
		'N' id_manipulado, 
		pg.cd_subcategoria,
		Case When (left(pg.de_produto,2) = 'ZZ' or coalesce(id_geladeira,'N') = 'S') then 'S' Else 'N' End as id_geladeira,
		ep.id_permitir_assinatura
from 
(
  Select distinct convert(int,de_chave) as cd_produto
    From log_exportacao_ecommerce  l
   Where l.id_processado = 'P' 
 	 and l.nm_tabela = 'SKU'
	 and l.cd_filial_ecommerce = :pl_cd_filial
	 and l.id_ecommerce = :ps_id_ecommerce
	 and l.de_chave not like 'OR%'
) Aux inner join produto_geral pg on (pg.cd_produto = Aux.cd_produto)
		inner join ecommerce_prd ep on (ep.cd_produto = pg.cd_produto
														and ep.id_ecommerce = :ps_id_ecommerce
														and ep.id_rede_filial = :ps_rede)
Where ep.cd_produto_ecommerce is not null
	
union

Select ep.nr_requisicao_manip cd_produto, 
		ep.cd_produto_ecommerce,  
		ep.cd_sku, 
		er.qt_altura_cm, 
		er.qt_profundidade_cm, 
		er.qt_largura_cm, 
		er.qt_peso_grama * 1000 as qt_peso_grama, 
		ep.de_descricao_manip as de_descricao_internet, 
		'' cd_grupo_psico, 
		'S' id_manipulado, 
		'N' as id_geladeira, 
		null,
		ep.id_permitir_assinatura
from
(
	Select distinct convert(int,ltrim(substring(de_chave, 3, 10))) as cd_produto
	From log_exportacao_ecommerce  l
	Where  l.id_processado = 'P' 
	 and l.nm_tabela = 'SKU'
	 and l.cd_filial_ecommerce = :pl_cd_filial
	 and l.id_ecommerce = :ps_id_ecommerce
	 and l.de_chave like 'OR%'
) aux inner join ecommerce_prd ep 
			on ep.nr_requisicao_manip = aux.cd_produto
		   and ep.id_ecommerce = :ps_id_ecommerce
   		   and ep.id_rede_filial = :ps_rede
		inner join ecommerce_rede er
			on er.id_ecommerce = ep.id_ecommerce
			and er.id_rede_filial = ep.id_rede_filial
where coalesce(ep.id_manipulado, 'N') = 'S'
	and ep.cd_produto_ecommerce is not null

" arguments=(("ps_id_ecommerce", string),("pl_cd_filial", number),("ps_rede", string))  sort="cd_produto_ecommerce A " )
