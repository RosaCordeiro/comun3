type cb_60 from commandbutton within w_ge501_vtex
integer x = 3150
integer y = 740
integer width = 805
integer height = 92
integer taborder = 90
boolean bringtotop = true
integer textsize = -8
integer weight = 400
fontcharset fontcharset = ansi!
fontpitch fontpitch = variable!
fontfamily fontfamily = swiss!
string facename = "Verdana"
string text = "Conveniado PBM"
end type

event clicked;string ls_token
Long ll_status_code
String ls_status_text
string ls_xml
string ls_url	
string ls_retorno,ls_json_programas,ls_json_retorno	
string ls_log
string ls_codigo, ls_nome
long ll_cd_convenio
long ll_existe

OleObject lole_SrvHTTP	
uo_ge073_json luo_json

Try
	ls_url = 'http://acessohml.funcionalmais.com/AutorizadorOmniChannelExterno/REST/api/Programa/ConsultarBaseProgramasProdutosComUrl?CNPJ=84683481041604'
	ls_token = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ0aXBvIjoiZnhfdXNlciIsInVzZXIiOiJ3c2Vjb21fZGV2X2NsYW1lZCIsInNlcnZpY2UiOiJBdXRvcml6YWRvck9tbmlDaGFubmVsIiwibmJmIjoxNjUyMTg0MjQyLCJleHAiOjE2NTIyNzA2NDIsImlhdCI6MTY1MjE4NDI0Mn0.KOci6VQIVYklg1ihgv1nJgOiA4sgxAdGQZe1OiXH7F8'
	ll_cd_convenio = 52349
	
	if not isvalid(w_aguarde) then open(w_aguarde)
	
	luo_json = create uo_ge073_json
	
	IF Not IsValid(lole_SrvHTTP) THEN
		
		lole_SrvHTTP = CREATE oleobject
		lole_SrvHTTP.ConnectToNewObject("MSXML2.SERVERXMLHTTP.6.0")
		
	End If
	
	lole_SrvHTTP.open ('GET', ls_url, false) 
	
	if Not IsValid(lole_SrvHTTP) THEN Return -1
	
	lole_SrvHTTP.setRequestHeader("ApiKey", ls_token ) 
	lole_SrvHTTP.setRequestHeader("Origem", "16") 
	
	lole_SrvHTTP.send('') 
		
	//Get response 
	ls_status_text = lole_SrvHTTP.StatusText 
	ll_status_code = lole_SrvHTTP.Status 
	
	ls_retorno = String( lole_SrvHTTP.ResponseText )
	
	Choose Case ll_status_code
		
		Case 200
			//Tudo certo
			ls_log = ''
		
		
			luo_json.of_divide_grupo_json_tag_vtex(ref ls_retorno, 'Programas', ref ls_json_programas, 'Errors')
			
			Do While luo_json.of_divide_grupo_json_completo(Ref ls_json_programas, Ref ls_json_retorno,'{') 
				
				ls_codigo = luo_json.of_busca_conteudo_campo_vtex( ls_json_retorno, 'CodigoPrograma')
				ls_nome = luo_json.of_busca_conteudo_campo_vtex( ls_json_retorno, 'NomePrograma')
				
				w_aguarde.title = ls_codigo + ' - ' + ls_nome
				
				if ls_codigo <> '' and not isnull(ls_codigo) Then
					
					select count(*)
					into :ll_existe
					from conveniado_pbm
					where cd_convenio = :ll_cd_convenio
					and cd_conveniado_pbm = :ls_codigo;
					
					if sqlca.sqlcode = -1 then
							ls_log = sqlca.sqlerrtext
							sqlca.of_rollback( )
							return -1
						end if
					
					if ll_existe = 0 or isnull(ll_existe) Then
					
						Insert into conveniado_pbm(cd_convenio, cd_conveniado_pbm, nm_conveniado_pbm)
						values(:ll_cd_convenio, :ls_codigo, :ls_nome);
						
						if sqlca.sqlcode = -1 then
							ls_log = sqlca.sqlerrtext
							sqlca.of_rollback( )
							return -1
						end if
						
						sqlca.of_commit( )
					ENd if
					
				End if

			Loop	
		
		
		Case 500
			//Erro - Tratamento de erro
			
			ls_log = ls_retorno
			
			ls_retorno = ''
			return -1
			
		Case Else
			
			ls_retorno = ''
			ls_log = ls_status_text
			return -1
			
	End Choose
	
CATCH (runtimeerror er)   
	ls_log = er.GetMessage()
	return -1
	
Finally
	
	if isvalid( lole_SrvHTTP ) then destroy( lole_SrvHTTP )
	
	if isvalid(w_aguarde) then Close(w_aguarde)
	
	if ls_log <> '' and not isnull(ls_log) then messagebox('Atencao', ls_log)
	
ENd Try

return 1

end event

