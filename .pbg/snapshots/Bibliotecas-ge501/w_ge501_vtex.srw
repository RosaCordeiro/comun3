boolean enabled = false
string text = "Modal Liquid"
end type

event clicked;long ll_linhas, ll_for, ll_cd_filial
string ls_cd_sku
string ls_json, ls_log
string ls_url

dc_uo_ds_base lds_dados

ls_url = 'api/catalog/pvt/stockkeepingunit/'

uo_ge501_comum luo_comum

lds_dados = create dc_uo_ds_base
luo_comum = create uo_ge501_comum

lds_dados.of_changedataobject( 'ds_ge501_produto_modal' )

ll_linhas = lds_dados.retrieve( )

luo_comum.of_parametros_ecommerce( '2', 'DC', ref ll_cd_filial, ref ls_log)

Open(w_Aguarde)
w_Aguarde.Title = "Atualizando Modal Type"
w_Aguarde.uo_Progress.of_SetMax(ll_Linhas)

for ll_for = 1 to ll_linhas
	
	ls_cd_sku = lds_dados.object.cd_sku[ll_for]
	
	w_Aguarde.Title = "Atualizando Modal Type: " + ls_cd_sku
	
	luo_comum.of_get( ls_url + ls_cd_sku, ref ls_json, ref ls_log)
	
	if ls_log <> '' and not isnull(ls_log) then
		Close(w_Aguarde)
		messagebox('Atencao', ls_log)
		return -1
	ENd if
	
 	ls_json = gf_replace(ls_json, "CHEMICALS", "LIQUID",1)
	
	luo_comum.of_put( ls_json, ls_url + ls_cd_sku, ref ls_json, ref ls_log)
	
	if ls_log <> '' and not isnull(ls_log) then
		Close(w_Aguarde)
		messagebox('Atencao', ls_log)
		return -1
	ENd if
	
	w_aguarde.uo_progress.of_setprogress(ll_for)	
Next
Close(w_Aguarde)
Messagebox('Atencao','Processo concluido com sucesso.')
end event

