type cb_categoria from commandbutton within w_ge501_vtex
integer x = 2144
integer y = 132
integer width = 905
integer height = 100
integer taborder = 30
boolean bringtotop = true
integer textsize = -8
integer weight = 400
fontcharset fontcharset = ansi!
fontpitch fontpitch = variable!
fontfamily fontfamily = swiss!
string facename = "Verdana"
boolean enabled = false
string text = "Importar Categoria Drogaria"
end type

event clicked;Long ll_Linhas
Long ll_Linha
Long ll_Cat
Long ll_Cat_Pai
Long ll_cd_filial


String ls_Cat
String ls_log
String ls_retorno


try
	
	dc_uo_ds_base lds
	lds = Create dc_uo_ds_base
	
	uo_ge501_comum luo_comum_vtex
	luo_comum_vtex = create uo_ge501_comum
	
	//Carrega os parametros e busca o c$$HEX1$$f300$$ENDHEX$$digo da filial vinculado a rede.
	if Not luo_comum_vtex.of_parametros_ecommerce('2', 'DC', ref ll_cd_filial, ref ls_log ) Then 
		MessageBox("Ate$$HEX2$$e700e300$$ENDHEX$$o", iif(Isnull(ls_log), '', ls_log))
		Return
	End If
	
	If Not lds.of_ChangeDataObject("ds_ge501_categoria_ec_erp") Then Return
	
	ll_Linhas = lds.Retrieve()
	
	Open(w_Aguarde)
	w_aguarde.uo_progress.of_setmax(ll_Linhas)
			
	For ll_Linha = 1 To ll_Linhas
		
		ll_Cat 		= lds.Object.cd_categoria[ll_Linha]
		ls_Cat 		= lds.Object.de_categoria[ll_Linha]
		ll_Cat_Pai 	= lds.Object.cd_categoria_pai[ll_Linha]	
		
		ls_retorno = ''
		ls_log = ''
		
		//Busca as informa$$HEX2$$e700f500$$ENDHEX$$es do pedido no Ecommerce.
		luo_comum_vtex.of_get('api/catalog/pvt/category/' + String(ll_Cat) , ref ls_retorno, ref ls_log )
		luo_comum_vtex.is_json = ls_retorno	
		
		if ls_log <> '' and not isnull(ls_log) Then
			Messagebox("Erro", ls_log)
			Return 
		end if
		
		If Not wf_carrega_categoria(ls_retorno, ll_Cat) Then Return
	
		w_aguarde.uo_progress.of_setprogress(ll_Linha)
	Next
	
finally
	Destroy(lds)
	
	Close(w_Aguarde)
end try

end event

type cb_2 from commandbutton within w_ge501_vtex
integer x = 2144
integer y = 232
integer width = 905
integer height = 100
integer taborder = 40
boolean bringtotop = true
integer textsize = -8
integer weight = 400
fontcharset fontcharset = ansi!
fontpitch fontpitch = variable!
fontfamily fontfamily = swiss!
string facename = "Verdana"
boolean enabled = false
string text = "Cadastra Categoria Drogaria PP"
end type

event clicked;Long ll_Linhas
Long ll_Linha
Long ll_Cat
Long ll_cd_filial

String ls_log
String ls_retorno

string ls_valor
String ls_Name
String ls_Title
String ls_Description
String ls_Keywords
String ls_IsActive
String ls_LomadeeCampaignCode
String ls_AdWordsRemarketingCode
String ls_ShowInStoreFront
String ls_ShowBrandFilter
String ls_ActiveStoreFrontLink
String ls_GlobalCategoryId
String ls_StockKeepingUnitSelectionMode
String ls_Score
String ls_LinkId
String ls_HasChildren
String ls_ID
String ls_FatherCategoryId
String ls_JSON

String ls_Erro

String ls_Rede

ls_Rede = 'FA'

/////////
////////
// ALTERAR A REDE / DE PARA DA DESCRI$$HEX2$$c700c300$$ENDHEX$$O // APPEND WHERE
////////
////////

try
	
	dc_uo_ds_base lds
	lds = Create dc_uo_ds_base
	
	uo_ge501_comum luo_comum_vtex
	luo_comum_vtex = create uo_ge501_comum
	
	//Carrega os parametros e busca o c$$HEX1$$f300$$ENDHEX$$digo da filial vinculado a rede.
	if Not luo_comum_vtex.of_parametros_ecommerce('2', ls_Rede, ref ll_cd_filial, ref ls_log ) Then 
		MessageBox("Ate$$HEX2$$e700e300$$ENDHEX$$o", iif(Isnull(ls_log), '', ls_log))
		Return
	End If
	
	If Not lds.of_ChangeDataObject("ds_ge501_categoria_ec_erp_carga") Then Return
	
	If ls_Rede = 'PP' Then
		lds.of_AppendWhere("a.dh_atualizacao_pp is null")
	ElseIF ls_Rede = 'FA' Then
		lds.of_AppendWhere("a.dh_ataulizacao_fa is null")
	Else
		MessageBox('Aten$$HEX2$$e700e300$$ENDHEX$$o', 'Rede n$$HEX1$$e300$$ENDHEX$$o prevista.')
		Return
	End If
		
	ll_Linhas = lds.Retrieve()
	
	If ll_Linhas > 5 Then
		ll_Linhas = 5
	End If
	
	Open(w_Aguarde)
	w_aguarde.uo_progress.of_setmax(ll_Linhas)
				
	For ll_Linha = 1 To ll_Linhas
	
							
		ls_ID = String(lds.Object.cd_categoria	[ll_Linha])
		
		// A categoria j$$HEX1$$e100$$ENDHEX$$ esta na plataforma - MEDICAMENTO
		If ls_ID = '1' Then 
			w_aguarde.uo_progress.of_setprogress(ll_Linha)
			Continue
		End If
		
		If ls_ID = '136' Then
			ls_ID = '136'
		End If
				
		ls_Name										= lds.Object.name				[ll_Linha]
		ls_FatherCategoryId						= String(lds.Object.fathercategoryid[ll_Linha])
		ls_Title										= lds.Object.title									[ll_Linha]
		ls_Description								= lds.Object.description							[ll_Linha]	
		ls_Keywords									= lds.Object.keywords							[ll_Linha]
		ls_IsActive									= lds.Object.isactive								[ll_Linha]
		ls_LomadeeCampaignCode				= lds.Object.lomadeecampaigncode			[ll_Linha]
		ls_AdWordsRemarketingCode			= lds.Object.adwordsremarketingcode		[ll_Linha]
		ls_ShowInStoreFront						= lds.Object.showinstorefront					[ll_Linha]
		ls_ShowBrandFilter						= lds.Object.showbrandfilter					[ll_Linha]
		ls_ActiveStoreFrontLink					= lds.Object.activestorefrontLink				[ll_Linha]
		ls_GlobalCategoryId						= lds.Object.globalcategoryid					[ll_Linha]
		ls_StockKeepingUnitSelectionMode		= lds.Object.stockkeepingunitselectionmode	[ll_Linha]
		ls_Score										= lds.Object.score									[ll_Linha]
		ls_LinkId										= lds.Object.linkid									[ll_Linha]
		ls_HasChildren								= lds.Object.haschildren							[ll_Linha]
		
		If ls_Rede = 'PP' Then
			ls_Description = gf_replace(ls_Description, 'Drogaria Catarinense', 'Pre$$HEX1$$e700$$ENDHEX$$o Popular', 0)
		ElseIF ls_Rede = 'FA' Then
			ls_Description = gf_replace(ls_Description, 'na  Drogaria Catarinense', 'no Farmagora', 0)
			ls_Description = gf_replace(ls_Description, 'na Drogaria Catarinense', 'no Farmagora', 0)
			ls_Description = gf_replace(ls_Description, 'Drogaria Catarinense', 'Farmagora', 0)
		Else
			MessageBox('Aten$$HEX2$$e700e300$$ENDHEX$$o', 'Rede n$$HEX1$$e300$$ENDHEX$$o prevista - Atualizar a descri$$HEX2$$e700e300$$ENDHEX$$o.')
			Return
		End If
		
		If ls_FatherCategoryId = '0' Then
			ls_FatherCategoryId = 'null'
		End If
					
		ls_JSON = 	'{' + & 
						'"Name": "' + ls_Name + '", ' +  &
						'"Keywords": "' +  ls_Keywords + '", ' +  &
						'"Title": "' + ls_Title + '", ' +  &
						'"Description": "' + ls_Description + '", ' +  &
						'"AdWordsRemarketingCode": "' +  ls_AdWordsRemarketingCode + '",' + &						
						'"LomadeeCampaignCode": "' + ls_LomadeeCampaignCode + '",' + &
						'"FatherCategoryId": ' + ls_FatherCategoryId + ',' + &						
						'"GlobalCategoryId": ' + ls_GlobalCategoryId + ',' + &	
						'"ShowInStoreFront": ' + ls_ShowInStoreFront + ',' + &
						'"IsActive": ' +  ls_IsActive + ',' + &
						'"ActiveStoreFrontLink": ' + ls_ActiveStoreFrontLink + ',' + &
						'"ShowBrandFilter": ' + ls_ShowBrandFilter + ',' + &
						'"Score": ' +  ls_Score + ',' + &
						'"StockKeepingUnitSelectionMode": "' +  ls_StockKeepingUnitSelectionMode +  '"' + &
						'}'
						
		ls_retorno = ''
		ls_log = ''
					
		luo_comum_vtex.is_json = ls_json
		if not luo_comum_vtex.of_post( ls_json, 'api/catalog/pvt/category', ref ls_retorno, ref ls_Log ) Then return
		
		if ls_log <> '' and not isnull(ls_log) Then
			Messagebox("Erro", ls_log)
			Return 
		end if
		
		If ls_retorno = ls_ID Then
			
			ll_Cat = Long(ls_ID)
			
			If ls_Rede = 'PP' Then
				
				update a_categoria_ecommerce_site
				set dh_atualizacao_pp = getdate()
				where cd_categoria = :ll_Cat
				Using SqlCa;
				
				If SqlCa.SqlCode = -1 Then
					ls_Erro = 'Erro ao atualizar a data de atualiza$$HEX2$$e700e300$$ENDHEX$$o - ' + sqlca.sqlerrtext
					Sqlca.of_RollBack();
					return 
				End If
				
				SqlCa.of_Commit();
									
			ElseIF ls_Rede = 'FA' Then
				
				update a_categoria_ecommerce_site
				set dh_ataulizacao_fa = getdate()
				where cd_categoria = :ll_Cat
				Using SqlCa;
				
				If SqlCa.SqlCode = -1 Then
					ls_Erro = 'Erro ao atualizar a data de atualiza$$HEX2$$e700e300$$ENDHEX$$o - ' + sqlca.sqlerrtext
					Sqlca.of_RollBack();
					return 
				End If
				
				SqlCa.of_Commit();
				
			Else
				MessageBox('Aten$$HEX2$$e700e300$$ENDHEX$$o', 'Rede n$$HEX1$$e300$$ENDHEX$$o prevista - Atualizar a tabela a_categoria_ecommerce_site.')
				Return
			End If
		Else
			MessageBox('Aten$$HEX2$$e700e300$$ENDHEX$$o', 'O ID ' + iif(isnull(ls_retorno), '', ls_retorno) +  ' da categoria criada no SITE esta diferente do ERP ' + iif(isnull(ls_ID), '', ls_ID) )							
		End If
					
		w_aguarde.uo_progress.of_setprogress(ll_Linha)
	Next
	
finally
	Destroy(lds)
	
	Close(w_Aguarde)
end try

end event

