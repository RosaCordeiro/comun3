event clicked;Long lvl_Filial
String ls_Rede

If Not IsNull(sle_filial.text) and sle_filial.text <> '' Then
	If Not Isnumber(sle_filial.text) Then
		Messagebox("Aten$$HEX2$$e700e300$$ENDHEX$$o", "N$$HEX1$$e300$$ENDHEX$$o $$HEX1$$e900$$ENDHEX$$ numero " + sle_filial.text +  ".")
		Return
	End If
End If

uo_ge501_saldo_filial luo_saldo
string ls_log

luo_saldo = create uo_ge501_saldo_filial

lvl_Filial = Long(sle_filial.text)

select id_rede_filial 
Into :ls_Rede
From filial
where cd_filial = :lvl_Filial
using SqlCa;

If MessageBox("Aten$$HEX2$$e700e300$$ENDHEX$$o", "Confirma a atualiza$$HEX2$$e700e300$$ENDHEX$$o de saldo da filial " + STring(lvl_Filial) + " ?", Question!, YesNo!, 2) = 1 Then
	if not luo_saldo.of_processa_atualizacao_saldo(ls_Rede, lvl_Filial) then
		messagebox('Aten$$HEX2$$e700e300$$ENDHEX$$o', 'Erro')
		return
	else
		messagebox('Aten$$HEX2$$e700e300$$ENDHEX$$o', 'Tudo certo')
	end if
End If

