//if ll_Categoria = 0 Then 

If al_categoria = 136 or al_categoria = 152 Then
	ll_Categoria = al_categoria
End If	

destroy(	luo_gera_json )

 INSERT INTO a_categoria_ecommerce_site  
         ( cd_categoria,   
           name,   
           fathercategoryid,   
           title,   
           description,   
           keywords,   
           isactive,   
           lomadeecampaigncode,   
           adwordsremarketingcode,   
           showinstorefront,   
           showbrandfilter,   
           activestorefrontlink,   
           globalcategoryid,   
           stockkeepingunitselectionmode,   
           score,   
           linkid,   
           haschildren )  
  VALUES (:ll_Categoria,   
           :ls_Name,   
           :ll_FatherCategoryId,   
           :ls_title,   
           :ls_description,   
           :ls_keywords,   
           :ls_isactive,   
           :ls_lomadeecampaigncode,   
           :ls_adwordsremarketingcode,   
           :ls_showinstorefront,   
           :ls_showbrandfilter,   
           :ls_activestorefrontlink,   
           :ls_globalcategoryid,   
           :ls_stockkeepingunitselectionmode,   
           :ls_score,   
           :ls_linkid,   
           :ls_haschildren)
Using SqlCa;

If SqlCa.Sqlcode = -1 Then
	SqlCa.of_MsgDbError("Erro ao inserir o registro na tabela a_categoria_ecommerce_site")
	SqlCa.of_rollback( )
	Return False
End If

SqlCa.of_Commit();
			  
return true
end function

public function boolean wf_conecta_filial (long pl_cd_filial, ref string ps_log);String ls_Odbc

if not isvalid(ivo_Odbc) then
	ivo_Odbc = Create dc_uo_odbc
end if

if not isvalid(itr_Filial) Then 
	itr_Filial	= Create dc_uo_Transacao
	itr_Filial.ivs_DataBase = 'ANYWHERE'
end if

if not isvalid(ivo_Conecta_Odbc) Then
	ivo_Conecta_Odbc = Create uo_transacao_online
end if

ivo_Conecta_Odbc.of_inclui_odbc( pl_cd_filial )
ls_Odbc = ivo_Odbc.of_Localiza( pl_cd_filial )

If itr_Filial.of_IsConnected( ) Then
	itr_Filial.of_Disconnect( )
End If

if itr_Filial.of_Connect( ls_Odbc, gvo_aplicacao.is_ComputerName , false) = False Then
	ps_log = 'N$$HEX1$$e300$$ENDHEX$$o foi poss$$HEX1$$ed00$$ENDHEX$$vel estabelecer conex$$HEX1$$e300$$ENDHEX$$o com a Filial: ' + string(pl_cd_filial) 
	return false
end if

Return True
end function

public function boolean wf_desconecta_filial ();if Not isvalid(itr_filial) Then return true

If itr_Filial.of_IsConnected( ) Then
	itr_Filial.of_Disconnect( )
End If

return true
end function

public function boolean wf_faturar_magalu (string ps_nr_pedido, string ps_json, ref string ps_retorno, ref string ps_log);string ls_usuario = 'precopopularapi'
string ls_senha = 'xci5Rt3hefbCY7Qdx6vv'
string ls_url = 'https://in.integracommerce.com.br/api/Order'
string ls_status_text
string ls_Retorno_Api
string ls_token

long ll_status_code

oleobject lole_SrvHTTP, lole_Send
uo_ge501_comum luo_comum

Try

	luo_comum = create uo_ge501_comum

	luo_comum.of_gerar_token_magalu( ref ls_token, ref ps_log)

	//ls_token = 'eyJraWQiOiI2VERTaF9XcHp0VldSZG9DVlZ6emZyZng5OFFQTERUZ1lWSzlBQmdmZUxZIiwiYWxnIjoiUlMyNTYifQ..hGshcH8koGUZY3VNocDpeJuc--BqVWeQDz6KjTBo6O3o0NpyT2PlqSsriJJo0vEWKzdfWiDH-tPjCukew2WrKkrF0rj1jNvIbw8jvfQ7IKmONcZnHGyX32jYaEdW4hxVc6NyL72iEE4K-02ZPMkDj_zn56aWShccBAYCWvl9R6I'

	lole_SrvHTTP = CREATE oleobject
	lole_SrvHTTP.ConnectToNewObject("MSXML2.SERVERXMLHTTP.6.0")
	
	lole_Send = CREATE oleobject
	lole_Send.ConnectToNewObject("Msxml2.DOMDocument.6.0")

	lole_SrvHTTP.open ('PUT', ls_url, false, ls_usuario, ls_senha) 
	
	if Not IsValid(lole_SrvHTTP) THEN Return false
			
	lole_SrvHTTP.SetRequestHeader("content-type", "application/json")
	lole_SrvHTTP.setRequestHeader("Authorization", 'Bearer ' + ls_token)
	lole_SrvHTTP.setOption(2,'13056') 
	
	Try
		lole_SrvHTTP.send(ps_json) 
	CATCH (RuntimeError e) 
		ps_log = this.classname( ) + '~nFun$$HEX2$$e700e300$$ENDHEX$$o: of_consulta_pedido_magalu ~nErro: ' + e.getMessage()
		Return false
	END TRY 
	
	//Get response 
	ls_status_text = lole_SrvHTTP.StatusText 
	ll_status_code = lole_SrvHTTP.Status 
	
	ls_Retorno_Api = String( lole_SrvHTTP.ResponseText )
	
	if ll_status_code <> 200 then
		
		ps_log = ls_status_text
		return false
	Else
		
		ps_retorno = ls_retorno_api
		
	End if
	
Finally
	destroy(luo_comum)
	
End Try

return true
end function

