Long ll_Id_Servico
long ll_linhas, ll_for

dc_uo_ds_base lds_dados

lds_dados = create dc_uo_ds_base
lds_dados.of_changedataobject( 'dw_teste_pedidos')

ll_linhas = lds_dados.retrieve( )

if ll_linhas < 0 Then
	messagebox('Aten$$HEX2$$e700e300$$ENDHEX$$o','Erro')
	return -1
end if


// Consulta o id_servico, que eh utilizado na reserva de etiquetas

try

	for ll_for = 1 to ll_linhas
	
		ll_Id_Servico = 0
		ls_Nr_Etiqueta = ''
		
		ll_nr_pedido = lds_dados.object.nr_pedido[ll_for]
		ls_nm_transportadora = lds_dados.object.nm_transportadora[ll_for]
		ll_filial_ecommerce = lds_dados.object.cd_filial_ecommerce[ll_for]
		ll_cd_tipo = long(lds_dados.object.cd_tipo_entrega[ll_for])
		
		SELECT id_servico
		INTO :ll_Id_Servico
		FROM ecommerce_servico_postagem
		WHERE de_servico = :ls_nm_transportadora
		USING SqlCa;
		
		If SqlCa.SqlCode = -1 Then
			ls_log = 'Fun$$HEX2$$e700e300$$ENDHEX$$o: of_reserva_etiqueta_correio. ' + 'Problemas ao consultar a tabela "ecommerce_servico_postagem":  ' + sqlca.sqlerrtext 
			Return -1
		End If
				
		SELECT nr_etiqueta_com_dig
			INTO :ls_Nr_Etiqueta
			 FROM ecommerce_reserva_etiqueta
		  WHERE nr_pedido = :ll_nr_pedido
			USING sqlCa;
			
		Choose Case SqlCa.SqlCode
			Case -1
				ls_log = 'Fun$$HEX2$$e700e300$$ENDHEX$$o: of_reserva_etiqueta_correio. ' + 'Problemas ao consultar a tabela "ecommerce_reserva_etiqueta":  ' + sqlca.sqlerrtext
				Return -1
				
			Case 0
				//ps_log = "Pedido: " + String(il_nr_pedido) + " | j$$HEX1$$e100$$ENDHEX$$ possui etiqueta reservada."
				//Return False	
				Return 1
		End Choose
		
		SELECT	TOP 1 cd_seq_etiqueta,
					nr_etiqueta_com_dig
			INTO :ll_Cd_Seq_Etiqueta,
					:ls_Nr_Etiqueta
			 FROM ecommerce_reserva_etiqueta
		  WHERE nr_pedido IS NULL
				AND id_servico =:ll_Id_Servico
		ORDER BY cd_seq_etiqueta ASC;	
			
		If SqlCa.SqlCode = -1 Then
			ls_log = 'Fun$$HEX2$$e700e300$$ENDHEX$$o: of_reserva_etiqueta_correio. ' + 'Problemas ao consultar a tabela "ecommerce_reserva_etiqueta":  ' + sqlca.sqlerrtext
			Return -1
		End If						
		
		If ll_Cd_Seq_Etiqueta <=0 Then
			ls_log = 'Fun$$HEX2$$e700e300$$ENDHEX$$o: of_reserva_etiqueta_correio. ' + 'N$$HEX1$$e300$$ENDHEX$$o foi encontrada etiqueta dispon$$HEX1$$ed00$$ENDHEX$$vel para o pedido.'
			Return -1
		End If
		
		UPDATE ecommerce_reserva_etiqueta
				SET nr_pedido 	= :ll_nr_pedido,
					cd_filial_ecommerce = :ll_filial_ecommerce
			WHERE cd_seq_etiqueta = :ll_Cd_Seq_Etiqueta
			 Using SqlCa;
		 
		If SqlCa.SqlCode = -1 Then
			ls_log = 'Fun$$HEX2$$e700e300$$ENDHEX$$o: of_reserva_etiqueta_correio. ' + 'Problemas ao atualizar registro na tabela "ecommerce_reserva_etiqueta":  ' + sqlca.sqlerrtext
			Return -1
		End If	
		
		If Sqlca.SQLNRows <> 1 Then
			ls_log ='Fun$$HEX2$$e700e300$$ENDHEX$$o: of_reserva_etiqueta_correio; ' + 'N$$HEX1$$e300$$ENDHEX$$o atualizou a quantidade esperada de registros'
			return -1
		End If
		
		ls_rastreio = 'https://portalpostal.com.br/sro.jsp?sro=' + ls_Nr_Etiqueta
		
		UPDATE pedido_ecommerce
				SET de_codigo_rastreamento_correio = :ls_Nr_Etiqueta, de_url_rastreio = :ls_rastreio, nm_transportadora = :ls_nm_transportadora, cd_tipo_entrega = :ll_cd_tipo
			WHERE cd_filial_ecommerce = :ll_filial_ecommerce
			  AND nr_pedido = :ll_nr_Pedido
			 Using SqlCa;
			 
		If SqlCa.SqlCode = -1 Then
			ls_log ='Fun$$HEX2$$e700e300$$ENDHEX$$o: of_reserva_etiqueta_correio. ' + 'Problemas ao atualizar registro na tabela "pedido_ecommerce":  ' + sqlca.sqlerrtext
			Return -1
		End If	
		
		If Sqlca.SQLNRows <> 1 Then
			ls_log = 'Fun$$HEX2$$e700e300$$ENDHEX$$o: of_reserva_etiqueta_correio 2; ' + 'N$$HEX1$$e300$$ENDHEX$$o atualizou a quantidade esperada de registros'
			return -1
		End If
		
		sqlca.of_commit( )
		
	Next

Finally
	if ls_log <> '' and not isnull(ls_log) Then
		sqlca.of_rollback( )
		messagebox('Aten$$HEX2$$e700e300$$ENDHEX$$o',ls_log)
	else
		sqlca.of_commit( )
		messagebox('Aten$$HEX2$$e700e300$$ENDHEX$$o','Tudo certo')
	end if
End Try

Return 1

end event

