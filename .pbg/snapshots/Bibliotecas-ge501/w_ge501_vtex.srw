public function boolean wf_importa_descricao (string as_arquivo);Boolean lb_Sucesso = True

Long ll_Linha
Long ll_Linhas

String ls_Produto
String ls_Descricao
String ls_Erro
String lvs_Registro

Integer lvi_Arquivo
Integer lvi_Status

Try
	dc_uo_excel lo_Excel
	lo_Excel = Create dc_uo_excel
	
	Open(w_Aguarde)
	w_Aguarde.Title = "Lendo a planilha..."
	
	lvi_Arquivo = FileOpen('S:\Projetos\VTEX\descricao_csv' , LineMode!, Write!, LockWrite!, Replace!, EncodingUTF8!)
	
	// Refer$$HEX1$$ea00$$ENDHEX$$ncia o Arquivo 
	If ( lo_Excel.uo_Referencia_Objeto_Excel(as_Arquivo) ) Then
		// Coluna de Refer$$HEX1$$ea00$$ENDHEX$$ncia
		ll_Linhas = lo_Excel.uo_Verifica_Tamanho_Arquivo("A") 
		
		If ll_Linhas > 0 Then
			w_Aguarde.uo_Progress.of_SetMax(ll_Linhas)
					
			For ll_Linha = 1 To ll_Linhas
				
				ls_Produto = String(lo_Excel.uo_Lendo_Dados(ll_Linha, "A") )
				ls_Descricao = wf_replace(String(lo_Excel.uo_Lendo_Dados(ll_Linha, "B")))
				
				lvs_Registro = ls_Produto + ';' + ls_Descricao
				
				INSERT INTO a_sergio_prd_desc ( cd_produto, de_principal_internet )  
				VALUES ( :ls_Produto,   :ls_Descricao)  ;
				
				If SqlCa.SqlCode = -1 Then
					ls_Erro = SQLCA.SQLErrText
					SqlCa.of_RollBack()
					MessageBox("Erro", ls_Erro)
				End If
				
				Sqlca.of_Commit();
							

//				create table a_sergio_prd_desc (
//						cd_produto           varchar(10)                    not null,
//						de_principal_internet text                           null,
//						constraint pk_a_sergio_prd_desc primary key (cd_produto)
//					)
//					;

				lvi_Status = FileWrite(lvi_Arquivo, lvs_Registro)
				
				w_aguarde.uo_progress.of_setprogress(ll_Linha)	
			Next
			
			FileClose(lvi_Arquivo)
			FileMove('S:\Projetos\VTEX\descricao_csv','S:\Projetos\VTEX\descricao_csv' +'.CSV')
			
			MessageBox("Aten$$HEX2$$e700e300$$ENDHEX$$o", "Terminou.")
			
//			If lb_Sucesso Then
//				SqlCa.of_Commit();
//				MessageBox("Aten$$HEX2$$e700e300$$ENDHEX$$o", "Terminou.")
//			Else
//				SqlCa.of_RollBack();
//			End If
			
		Else
			MessageBox("Aten$$HEX2$$e700e300$$ENDHEX$$o", "A planilha est$$HEX1$$e100$$ENDHEX$$ em branco.")
			Return False
		End If
	End If
	
Finally
	

	
	Close(w_Aguarde)
	If IsValid(lo_Excel) Then Destroy(lo_Excel)
End Try
Return True
end function

public function string wf_replace (string as_original);String ls_Retorno, ls_Enter

Long ll_Pos

ls_Enter = char(13)+char(10)

ls_Retorno = gf_replace(as_original, '"', '', 0)
//ls_Retorno = gf_replace(ls_Retorno, '<p>', '', 0)
//ls_Retorno = gf_replace(ls_Retorno, '</p>', '', 0)
ls_Retorno = gf_replace(ls_Retorno, "~n", '', 0)

ll_Pos = lastpos(ls_Retorno, '<br><br>')

//encontrou o caractere no final da string
If Mid(ls_Retorno, ll_Pos + 8) = '' Then
//	pega a string sem o caractere
	ls_Retorno = Mid(ls_Retorno, 1, ll_Pos -1 ) 	
End If

ls_Retorno = gf_replace(ls_Retorno, "<br><br>", ls_Enter + ls_Enter, 0)
//ls_Retorno = gf_replace(ls_Retorno, "<br><br>", ls_Enter + ls_Enter, 0)

ls_Retorno = gf_replace(ls_Retorno, "</p><p>", ls_Enter, 0)

ll_Pos = pos(ls_Retorno, '<br>')
//encontrou o caractere no final da string
If Mid(ls_Retorno, ll_Pos + 4) = '' Then
	ls_Retorno = gf_replace(as_original, '<br>', '', 0)
End If

ls_Retorno = gf_retira_caracteres_especiais_html(ls_Retorno)

ls_Retorno = gf_replace(ls_Retorno, '<p>', '', 0)
ls_Retorno = gf_replace(ls_Retorno, '</p>', '', 0)

ls_Retorno = gf_replace(ls_Retorno, '<br />', '', 0)

ls_Retorno = gf_replace(ls_Retorno, '"', '', 0)

ls_Retorno = gf_replace(ls_Retorno, 'L$$HEX3$$e200ac202221$$ENDHEX$$Or$$HEX1$$e900$$ENDHEX$$al', 'L$$HEX1$$1920$$ENDHEX$$Or$$HEX1$$e900$$ENDHEX$$al', 0)

