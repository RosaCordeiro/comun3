event clicked;string ls_log, ls_erro
string ls_Endereco_Ftp = '10.0.4.30'
string ls_Usuario_Ftp = 'nfe'
string ls_Senha_Ftp = 'nfe@2017'
string ls_Modelo
string ls_Cnpj_Origem
string ls_chave_acesso = '35230884683481041604550010006378381231319081'
string ls_Ano, ls_Mes, ls_Dia
string ls_Diretorio
string ls_Arquivo
string ls_Diretorio_Xml = 'C:\Teste\'
string ls_Arquivo_Aux
string ls_arquivo_xml
string ls_retorno

boolean lbl_xml

string ls_xml

long ll_Filial = 454
long ll_arquivo
long ll_retorno

date ldt_emissao = date('2023-08-30')

dc_uo_Ftp lo_Ftp
dc_uo_zip lo_zip

Try

	lo_Ftp = Create dc_uo_Ftp
	
	If Not lo_Ftp.of_Conecta_Ftp("", ls_Endereco_Ftp, ls_Usuario_Ftp, ls_Senha_Ftp,ref ls_Erro ) Then
		ls_log = "Erro ao buscar o arquivo via ftp: " + ls_Erro
		Return -1
	End If
	
	ls_Modelo = Mid(ls_chave_acesso, 21, 2)
	ls_Cnpj_Origem	= Mid(ls_chave_acesso, 7, 14)
	
	Choose Case ls_Modelo
		Case '59' 
			ls_Ano		= String(Year(ldt_emissao))
			ls_Mes		= Right("0"+String(Month(ldt_emissao)), 2)
			ls_Dia			= Right("0"+String(Day(ldt_emissao)), 2)
			ls_Diretorio	= ls_Ano+"/"+ls_Mes+"/"+ls_Dia+"/"+String(ll_Filial, "0000")
			ls_Arquivo	= 'AD'+ls_chave_acesso+".xml.zip"
		Case '65' 	
			ls_Ano		= String(Year(ldt_emissao))
			ls_Mes		= Right("0"+String(Month(ldt_emissao)), 2)
			ls_Dia			= Right("0"+String(Day(ldt_emissao)), 2)
			ls_Diretorio	= ls_Ano+"/"+ls_Mes+"/"+ls_Dia+"/"+String(ll_Filial, "0000")
			ls_Arquivo	= ls_chave_acesso+"-nfce.xml.zip"
		Case Else
			ls_Ano		= "Ano_"+String(Year(ldt_emissao))
			ls_Mes		= "Mes_"+Right("0"+String(Month(ldt_emissao)), 2)
			ls_Dia			= "Dia_"+Right("0"+String(Day(ldt_emissao)), 2)
			ls_Diretorio	= ls_Ano+"/"+ls_Mes+"/"+ls_Dia+"/"+ls_Cnpj_Origem
			ls_Arquivo	= ls_chave_acesso+"-nfe.xml"
	End Choose
	
	If lo_Ftp.of_Ftp_Set_Dir(ls_Diretorio, Ref ls_Erro) = -1 Then 
		MessageBox("Erro", "Erro ao buscar o arquivo via ftp: "+ls_Erro )
		Return  -1	
	End If
	
	If not lo_Ftp.of_Ftp_GetFile(ls_Arquivo, ls_Diretorio_Xml+ls_Arquivo, Ref ls_Erro) Then
		MessageBox("Erro", "Erro ao buscar o arquivo via ftp: "+ls_Erro )
		Return -1
	End If
	
	
	//Recebe o valor arquivo
	ls_Arquivo_Aux = ls_Arquivo
	
	//Se for arquivo compactado
	If Upper(Right(ls_Arquivo, 3))="ZIP" Then
		//Verifica se objeto ZIP j$$HEX1$$e100$$ENDHEX$$ est$$HEX1$$e100$$ENDHEX$$ criado
		If Not IsValid(lo_zip) Then lo_zip = Create dc_uo_zip
		
		//Novo arquivo XML
		ls_Arquivo_Aux = Mid(ls_Arquivo, 1, Len(ls_Arquivo) -4)
		
		//Se o arquivo ZIP j$$HEX1$$e100$$ENDHEX$$ existir ele exclui
		If FileExists(ls_Diretorio_Xml+ls_Arquivo_Aux) Then FileDelete(ls_Diretorio_Xml+ls_Arquivo_Aux)
		
		//Verifica se o arquivo existe
		If FileExists(ls_Diretorio_Xml+ls_Arquivo) Then 
			lo_zip.Of_UnZip_Origem( ls_Diretorio_Xml+ls_Arquivo )
			lo_zip.Of_UnZip_Destino( ls_Diretorio_Xml )
			lo_zip.Of_UnZip( True )
		End If
	End If
	
	//Retorna o arquivo XML
	ls_arquivo_xml = ls_Diretorio_Xml+ls_Arquivo_Aux
	
	ll_arquivo = FileOpen(ls_arquivo_xml, LineMode!)
	
	Do while ll_retorno <> -100
	
		ll_retorno = FileReadEx(ll_arquivo, ls_retorno)
		
		ls_xml = ls_xml + ls_retorno
	
	Loop
	
//	ls_xml = string(lbl_xml)
	
	FileClose(ll_arquivo)
	
Finally
	
	destroy(lo_zip)
	destroy(lo_ftp)
	
End Try
end event

type cb_68 from commandbutton within w_ge501_vtex
integer x = 3150
integer y = 1440
integer width = 805
integer height = 92
integer taborder = 160
boolean bringtotop = true
integer textsize = -8
integer weight = 400
fontcharset fontcharset = ansi!
fontpitch fontpitch = variable!
fontfamily fontfamily = swiss!
string facename = "Verdana"
string text = "Magalu - Faturar"
end type

event clicked;string ls_json
string ls_nr_pedido
string ls_serie
string ls_chave
string ls_xml
string ls_log
string ls_retorno, ls_nr_pedido_ecommerce

long ll_nr_nf
long ll_for
long ll_cd_filial
long ll_linhas
long ll_file
long ll_nr_pedido

datetime ldt_nota

uo_ge501_pedido_status luo_status

dc_uo_ds_base lds_dados

lds_dados = create dc_uo_ds_base

lds_dados.of_changedataobject( 'ds_ge501_pedidos_magalu' )

luo_status = create uo_ge501_pedido_status

luo_status.of_carrega_parametros_ftp( ref ls_log)

if ls_log <> '' and not isnull(ls_log) then
	messagebox('Erro', ls_log)
	return -1
ENd if

ll_linhas = lds_dados.retrieve( )

Try

	ll_file = FileOpen('C:\Teste\Pedidos.txt',LineMode!,Write!)

	Open(w_Aguarde)
	w_Aguarde.Title = "Atualizando Faturado Magalu"
	w_Aguarde.uo_Progress.of_SetMax(ll_Linhas)
	
	for ll_for = 1 to ll_linhas
	
		setnull(ls_nr_pedido)
		setnull(ll_nr_nf)
		setnull(ls_serie)
		setnull(ls_chave)
		setnull(ldt_nota)
		setnull(ll_cd_filial)
		setnull(ls_xml)
	
		ls_nr_pedido_ecommerce = lds_dados.object.nr_pedido_ecommerce[ll_for]
		ll_nr_pedido = lds_dados.object.nr_pedido[ll_for]
		
		ll_nr_nf = lds_dados.object.nr_nf[ll_for]
		ls_serie = lds_dados.object.de_serie[ll_for]
		ls_chave = lds_dados.object.de_chave_acesso[ll_for]
		ldt_nota = lds_dados.object.dh_emissao[ll_for]
		ll_cd_filial = lds_dados.object.cd_filial[ll_for]
		
		ls_nr_pedido = 'LU-' + mid(ls_nr_pedido_ecommerce, 1, len(ls_nr_pedido_ecommerce) - 3)
	
		luo_status.of_busca_nfe_xml( ll_cd_filial, ls_chave, date(ldt_nota), ref ls_xml, ref ls_log)
	
		if ls_log <> '' and not isnull(ls_log) then
			messagebox('Erro', ls_log)
			return -1
		ENd if
	
		ls_xml = gf_replace(ls_xml, '"', "'",0)
	
		ls_json = '{' + &
					'"IdOrder": "' + ls_nr_pedido + '", ' + &
					'"OrderStatus": "INVOICED", ' + &
					'"InvoicedNumber": "' + string(ll_nr_nf) + '", ' + & 
					'"InvoicedLine": ' + ls_serie + ', ' + & 
					'"InvoicedIssueDate": "' + String(ldt_nota,'yyyy-mm-dd hh:mm:ss') + '", ' + &
					'"InvoicedKey": "' + ls_chave + '", ' + &
					'"InvoicedDanfeXml": "' + ls_xml + '"}'
	
		sleep(0.5)
	
		parent.wf_faturar_magalu( ls_nr_pedido, ls_json, ref ls_retorno, ref ls_log)
		
		if ls_log <> '' and not isnull(ls_log) then
			messagebox('Erro', string(ll_nr_pedido) + ' - ' + ls_log)
			return -1
		ENd if
		
		w_aguarde.uo_progress.of_setprogress(ll_for)	
		
		FileWrite(ll_file, string(ll_nr_pedido))
		
	next
	
Finally
	Close(w_aguarde)
	FileClose(ll_file)
	
End Try
end event

type cb_69 from commandbutton within w_ge501_vtex
integer x = 3150
integer y = 1540
integer width = 805
integer height = 92
integer taborder = 170
boolean bringtotop = true
integer textsize = -8
integer weight = 400
fontcharset fontcharset = ansi!
fontpitch fontpitch = variable!
fontfamily fontfamily = swiss!
