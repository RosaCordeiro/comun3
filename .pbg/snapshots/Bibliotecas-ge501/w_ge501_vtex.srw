event clicked;long ll_nr_pedido, ll_nr_pedido_antigo
string ls_erro
boolean lb_sucesso = false
Try

	ll_nr_pedido_antigo = 602541557

	Declare sp_pedido Procedure for sp_proximo_pedido_ecommerce
		@proximo_sequencial_retorno  = :ll_nr_pedido OUTPUT,
		@mensagem_retorno = :ls_erro OUTPUT
	USING SQLCA;
	
	Execute sp_pedido;
	
	If SQLCA.sqlcode = -1 then 
		messagebox('Atencao', 'Erro ao executar a procedure "sp_proximo_pedido_ecommerce": ~n' + SQLCA.sqlerrtext )
		return -1
	end if
	
	Fetch sp_pedido Into :ll_nr_pedido, :ls_erro;
	
	Close sp_pedido;
	
	if ls_erro <> '' and not isnull(ls_erro) Then
		messagebox('Atencao', 'Erro ao executar a procedure "sp_proximo_pedido_ecommerce": ~n' + ls_erro)
		return -1
	end if
	
	lb_sucesso = True
	
	ll_nr_pedido = ll_nr_pedido
	
//	update pedido_ecommerce
//	set id_situacao = 'X', dh_cancelamento = getdate()
//	where nr_pedido = :ll_nr_pedido_antigo;
//	
//	insert into
	
Finally
	if lb_sucesso = True Then
		SQlca.of_commit( )
	ELse
		sqlca.of_rollback( )
	End if
ENd Try

end event

