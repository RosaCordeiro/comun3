type cb_55 from commandbutton within w_ge501_vtex
integer x = 1166
integer y = 2108
integer width = 887
integer height = 92
integer taborder = 170
boolean bringtotop = true
integer textsize = -8
integer weight = 400
fontcharset fontcharset = ansi!
fontpitch fontpitch = variable!
fontfamily fontfamily = swiss!
string facename = "Verdana"
boolean enabled = false
string text = "Motivo cancelamento"
end type

event clicked;long ll_cd_filial_ecommerce, ll_for, ll_linhas, ll_nr_pedido 
string ls_rede_filial, ls_nr_pedido, ls_retorno, ls_motivo
string ls_Log
datetime ldh_inicio, ldh_fim

uo_ge501_comum luo_comum
dc_uo_ds_base lds_dados
uo_ge073_json luo_gera_json

Try

	lds_dados = create dc_uo_ds_base
	
	luo_comum = create uo_ge501_comum
	luo_gera_json = Create uo_ge073_json 
	
	lds_dados.of_changedataobject( 'ds_ge501_pedidos_cancelados')
	
	ls_rede_filial = 'DC'
	ldh_inicio = Datetime( Date ( '01/01/2022' ), Time( '00:00' ) )
	ldh_fim = Datetime( Date ( '31/01/2022' ), Time( '23:59:59' ) )
	
	ll_linhas = lds_dados.retrieve(ls_rede_filial, ldh_inicio, ldh_fim)
	
	if Not luo_comum.of_parametros_ecommerce('2', ls_rede_filial, ref ll_cd_filial_ecommerce, ref ls_Log ) Then return -1
	
	if not isvalid(w_Ge501_Aguarde) Then Open(w_Ge501_Aguarde)
	
	w_Ge501_Aguarde.uo_progress.of_setmax(ll_Linhas)
	
	for ll_for = 1 to ll_linhas
		
		ls_motivo = ''
		
		ls_nr_pedido = lds_dados.object.nr_pedido_ecommerce[ll_for]
		ll_cd_filial_ecommerce = lds_dados.object.cd_filial_ecommerce[ll_for]
		ll_nr_pedido = lds_dados.object.nr_pedido[ll_for]
		
		w_Ge501_Aguarde.Title = "Vtex - Atualizando Motivo de Cancelamento - "  + String(ll_for)  + " de " + STring(ll_Linhas)
		w_Ge501_Aguarde.st_msg.Text = "Pedido: " + ls_nr_pedido + ' ['+ls_rede_filial + ']'
		
		if not luo_comum.of_get( 'api/oms/pvt/orders/' + ls_nr_pedido , ref ls_retorno, ref ls_log ) then return -1
			
		ls_motivo =  luo_gera_json.of_busca_conteudo_campo_vtex(ls_retorno, 'cancelReason')
		
		if ls_motivo <> '' and not isnull(ls_motivo) Then
		
			ls_motivo = upper(ls_motivo)
		
			Update pedido_ecommerce_auxiliar
			set de_motivo_cancelamento_pedido = :ls_motivo
			where cd_filial_ecommerce = :ll_cd_filial_ecommerce
			and nr_pedido = :ll_nr_pedido;
			
			if sqlca.sqlcode = -1 then
				ls_log = sqlca.sqlerrtext
				sqlca.of_rollback( )
				return -1
			ENd if
			
			sqlca.of_commit( )
			
		ENd if
		w_Ge501_Aguarde.uo_progress.of_setprogress(ll_for)	
	Next

Finally
	
	destroy(luo_comum)
	destroy(lds_dados)
	destroy(luo_gera_json)
	
	if isvalid(w_Ge501_Aguarde) Then Close(w_Ge501_Aguarde)
	
	if ls_log <> '' and not isnull(ls_log) then 
		messagebox('Aten$$HEX1$$e700$$ENDHEX$$ao',ls_log)
	Else
		messagebox('Atencao', 'OK. Pedidos processados: ' + string(ll_linhas) )
	End if
	
ENd try
end event

type cb_56 from commandbutton within w_ge501_vtex
integer x = 2158
integer y = 2032
integer width = 827
integer height = 92
integer taborder = 180
boolean bringtotop = true
integer textsize = -8
integer weight = 400
fontcharset fontcharset = ansi!
fontpitch fontpitch = variable!
fontfamily fontfamily = swiss!
string facename = "Verdana"
boolean enabled = false
string text = "Carga Pre$$HEX1$$e700$$ENDHEX$$o"
end type

event clicked;long ll_linhas, ll_for
long ll_cd_produto
long ll_cd_filial
long ll_cd_filial_preco
long ll_contador

String ls_Log
String ls_rede
string ls_id_ecommerce

decimal ldc_desconto_filial, ldc_desconto_clube, ldc_desconto_ecommerce, ldc_preco_normal, ldc_preco_liquido

dc_uo_ds_base lds_dados
uo_ge501_comum luo_comum_vtex
uo_produto luo_produto 

try 
	ls_id_ecommerce = '2'	
	ls_rede = 'PP'
	
	Open(w_Aguarde)

	luo_comum_vtex = create uo_ge501_comum
	
	luo_produto = create uo_produto
	
	// Considera somente promo$$HEX2$$e700f500$$ENDHEX$$es liberadas para o e-commerce
	luo_produto.is_somente_liberado_ecommerce = 'S'

	lds_dados = create dc_uo_ds_base
	
	if not lds_dados.of_changedataobject( 'ds_ge501_preco_carga' ) Then
		ls_log = 'N$$HEX1$$e300$$ENDHEX$$o foi poss$$HEX1$$ed00$$ENDHEX$$vel instanciar a seguinte datawindow: ds_ge501_preco_carga'
		return -1
	end if
	
	//Carrega os parametros e busca o c$$HEX1$$f300$$ENDHEX$$digo da filial vinculado a rede.
	if Not luo_comum_vtex.of_parametros_ecommerce(ls_id_ecommerce, ls_rede, ref ll_cd_filial, ref ls_log ) Then return -1

	ll_cd_filial_preco = luo_comum_vtex.il_cd_filial_preco
	
	ll_linhas = lds_dados.retrieve(ls_id_ecommerce, ls_rede)
	
	if ll_linhas < 0 Then
		ls_log = 'Problemas ao consultar o banco de dados na seguinte datawindow: ds_ge501_preco_carga'
		return -1
	end if
	
	w_aguarde.uo_progress.of_setmax(ll_Linhas)
	
	ll_contador=0
	
	for ll_for = 1 to ll_linhas
		
		w_Aguarde.Title = "Atualizando PRE$$HEX1$$c700$$ENDHEX$$O no eCommerce - [" + ls_rede +  "] - "  + String(ll_for)  + " de " + STring(ll_Linhas)
		
		ll_cd_produto = lds_dados.object.cd_produto[ll_for]
		
		luo_Produto.of_Localiza_Codigo_Interno(ll_cd_Produto)
		
		If Not luo_Produto.Localizado Then 
			ls_log = 'Produto n$$HEX1$$e300$$ENDHEX$$o encontrado na base de dados: ' + string(ll_cd_produto)
			return -1
		end if
		
		//Busca o pre$$HEX1$$e700$$ENDHEX$$o normal do produto.
		ldc_preco_normal = luo_produto.of_preco_venda_filial_matriz( ll_cd_filial_preco )
		
		//Busca o desconto
		ldc_desconto_filial = luo_produto.of_desconto_filial( ll_cd_filial_preco )
		
		//Se for rede DC, verifica se tem desconto clube.
		if ls_rede = 'DC' or ls_rede = 'PP' Then
			ldc_desconto_clube = luo_produto.of_desconto_clube_filial( ll_cd_filial_preco )
		else
			ldc_desconto_clube = 0
		end if
		
		//Verifica se possui desconto na filial ecommerce.
		ldc_desconto_ecommerce = luo_produto.of_desconto_filial( ll_cd_filial, 'F')

		//Utiliza o maior desconto
		if ldc_desconto_clube > ldc_desconto_filial Then
			ldc_desconto_filial = ldc_desconto_clube
		end if
		
		if ldc_desconto_ecommerce > ldc_desconto_filial Then
			ldc_desconto_filial = ldc_desconto_ecommerce
		end if
		
		//Calcula o pre$$HEX1$$e700$$ENDHEX$$o l$$HEX1$$ed00$$ENDHEX$$quido.
		if ldc_desconto_filial > 0 Then
			ldc_preco_liquido = Round( ldc_preco_normal - ( ldc_preco_normal * ( ldc_desconto_filial / 100 )), 2)
		else
			ldc_preco_liquido = ldc_preco_normal
		end if
		
		Update ecommerce_prd
		set vl_preco = :ldc_preco_normal, vl_preco_promocao = :ldc_preco_liquido
		where id_ecommerce = :ls_id_ecommerce
		and id_rede_filial = :ls_rede
		and cd_produto = :ll_cd_produto;
		
		if sqlca.sqlcode = -1 then
			gf_ge501_RollBack(SQLCA)
			ls_log = 'Problemas ao atualizar a tabela ecommerce_prd: ' + sqlca.sqlerrtext
			return -1
		end if
		
		ll_contador++
		
		if ll_contador >= 100 then
			ll_contador = 0
			If Not gf_ge501_commit(SQLCA) Then Return -1
		ENd if
		
		w_aguarde.uo_progress.of_setprogress(ll_for)
		
	next

	If Not gf_ge501_commit(SQLCA) Then Return -1

Finally
	
	destroy(lds_dados)
	destroy(luo_comum_vtex)
	destroy(luo_produto)
	
	Close(w_Aguarde)
	
	if ls_log <> '' and not isnull(ls_log) Then
		messagebox('Atencao', ls_log)
	ENd if
	
End try

return -1
end event

type cb_57 from commandbutton within w_ge501_vtex
integer x = 3150
integer y = 640
integer width = 805
integer height = 92
integer taborder = 100
boolean bringtotop = true
integer textsize = -8
integer weight = 700
fontcharset fontcharset = ansi!
fontpitch fontpitch = variable!
fontfamily fontfamily = swiss!
string facename = "Verdana"
string text = "Gerar nr_pedido"
end type

event clicked;long ll_nr_pedido
string ls_erro
boolean lb_sucesso = false
Try

	Declare sp_pedido Procedure for sp_proximo_pedido_ecommerce
		@proximo_sequencial_retorno  = :ll_nr_pedido OUTPUT,
		@mensagem_retorno = :ls_erro OUTPUT
	USING SQLCA;
	
	Execute sp_pedido;
	
	If SQLCA.sqlcode = -1 then 
		messagebox('Atencao', 'Erro ao executar a procedure "sp_proximo_pedido_ecommerce": ~n' + SQLCA.sqlerrtext )
		return -1
	end if
	
	Fetch sp_pedido Into :ll_nr_pedido, :ls_erro;
	
	Close sp_pedido;
	
	if ls_erro <> '' and not isnull(ls_erro) Then
		messagebox('Atencao', 'Erro ao executar a procedure "sp_proximo_pedido_ecommerce": ~n' + ls_erro)
		return -1
	end if
	
	lb_sucesso = True
	
	ll_nr_pedido = ll_nr_pedido
	
Finally
	if lb_sucesso = True Then
		SQlca.of_commit( )
	ELse
		sqlca.of_rollback( )
	End if
ENd Try

end event

