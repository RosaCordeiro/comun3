ll_Filial_Site = 495
ls_Rede = 'DC'
ls_Valor_Venda = '18687' // 186,87

ls_Cod_Transacao = '9AF488DEC9A5468BA5B19B6705273BE7'

uo_ge501_comum luo_comum_vtex

luo_comum_vtex = Create uo_ge501_comum

try
	//Carrega os parametros e busca o c$$HEX1$$f300$$ENDHEX$$digo da filial vinculado a rede.
	if Not luo_comum_vtex.of_parametros_ecommerce_filial(ll_Filial_Site, ls_Rede, '2', ref ls_log ) Then return
		
	ls_Json = '{"value":' + ls_Valor_Venda + '}'
	
	luo_comum_vtex.is_url = gf_replace(luo_comum_vtex.is_url, 'myvtex.com', 'vtexpayments.com.br', 0 )
					
	luo_comum_vtex.of_post(ls_Json, 'api/pvt/transactions/' + ls_Cod_Transacao + '/cancellation-request' , ref ls_retorno, ref ls_log ) 
	
	If ls_Log <> '' and not isnull(ls_Log) Then 
		MessageBox("Erro", ls_Log)
		Return
	End If
					
	//If Not IsNull(ls_retorno) and Trim(ls_retorno) <> '' Then
finally
 Destroy luo_comum_vtex
end try



end event

