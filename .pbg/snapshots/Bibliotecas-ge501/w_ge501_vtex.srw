event clicked;string ls_token, ls_log, ls_nr_pedido, ls_json, ls_retorno
long ll_pos1, ll_pos2, ll_linhas, ll_for, ll_count
string ls_de_url_rastreio, ls_id_rastreio, ls_status, ls_link_rastreio
datetime ldh_faturado,ldh_entrega

boolean lb_entrega = True

dc_uo_ds_base lds_dados

uo_ge073_json luo_json

//uo_ge501_comum luo_comum

//luo_comum = create uo_ge501_comum

//luo_comum.of_gerar_token_magalu( ref ls_token, ref ls_log)

luo_json = create uo_ge073_json

lds_dados = create dc_uo_ds_base

lds_dados.of_changedataobject( 'ds_ge501_pedidos_magalu' )

ll_linhas = lds_dados.retrieve( )

uo_ge501_pedido_ecommerce luo_pedido

luo_pedido = create uo_ge501_pedido_ecommerce

Open(w_Aguarde)
w_Aguarde.Title = "Atualizando Faturado Magalu"
w_Aguarde.uo_Progress.of_SetMax(ll_Linhas)

ll_count = 0

for ll_for = 1 to ll_linhas

	ls_json = ''
	ls_log = ''
	ls_link_rastreio = ''
	
	//ls_nr_pedido = '1271170680668127-01'
	ls_nr_pedido = lds_dados.object.nr_pedido_ecommerce[ll_for]
	ls_de_url_rastreio = lds_dados.object.de_url_rastreio[ll_for]
	ls_id_rastreio = lds_dados.object.id_rastreio[ll_for]
	ldh_faturado = lds_dados.object.dh_faturado[ll_for]
	ldh_entrega = lds_dados.object.dh_entrega[ll_for]
	
	if lb_entrega = false and (ls_id_rastreio = '' or isnull(ls_id_rastreio)) then 
		w_aguarde.uo_progress.of_setprogress(ll_for)	
		Continue
	End if
	
	//sleep(1)
	
	luo_pedido.of_consulta_pedido_magalu( ls_nr_pedido, ref ls_json, ref ls_log)
	
	ll_count++
	
	if ll_count >= 5 then
		sleep(1)
		ll_count = 0
	ENd if
	
	if ls_log <> '' and not isnull(ls_log) then
		Close(w_Aguarde)
		messagebox('Erro', ls_log)
		return -1
	ENd if
	
	ls_status = luo_json.of_busca_conteudo_campo_vtex( ls_json, 'OrderStatus')
	
//	if ls_status <> 'INVOICED' then 
//		w_aguarde.uo_progress.of_setprogress(ll_for)	
//		Continue
//	End if
	
	
	if lb_entrega = true Then
		if ls_status = 'INVOICED' or ls_status = 'DELIVERED' or ls_status = 'CANCELED' then 
			w_aguarde.uo_progress.of_setprogress(ll_for)	
			Continue
		End if
	Else
		if ls_status = 'SHIPPED' or ls_status = 'DELIVERED' or ls_status = 'CANCELED' then 
			w_aguarde.uo_progress.of_setprogress(ll_for)	
			Continue
		End if
	
	ENd if

	if lb_entrega = True Then
		
		ll_pos1 = pos(ls_json, '"OrderStatus":')
		
		ll_pos2 = pos(ls_json, ',', ll_pos1)
		
		if ll_pos1 > 0 and ll_pos2 > 0 then
			ls_json = gf_replace(ls_json, mid(ls_json, ll_pos1, ll_pos2 - ll_pos1),	'"OrderStatus": "DELIVERED"',1)
		ENd if
		
		ll_pos1 = pos(ls_json, '"DeliveredDate":')
		
		ll_pos2 = pos(ls_json, ',', ll_pos1)
		
		if ll_pos1 > 0 and ll_pos2 > 0 then
			ls_json = gf_replace(ls_json, mid(ls_json, ll_pos1, ll_pos2 - ll_pos1),	'"DeliveredDate": "' + String(ldh_entrega,'yyyy-mm-dd hh:mm:ss') + '"',1)
		ENd if
		
	Else
	
		ll_pos1 = pos(ls_json, '"OrderStatus":')
		
		ll_pos2 = pos(ls_json, ',', ll_pos1)
		
		if ll_pos1 > 0 and ll_pos2 > 0 then
			ls_json = gf_replace(ls_json, mid(ls_json, ll_pos1, ll_pos2 - ll_pos1),	'"OrderStatus": "SHIPPED"',1)
		ENd if
		
		if ls_de_url_rastreio <> '' and not isnull(ls_de_url_rastreio) then
		
			ls_link_rastreio = luo_json.of_busca_conteudo_campo_vtex( ls_json, 'ShippedTrackingUrl')
		
			ll_pos1 = pos(ls_json, '"ShippedTrackingUrl":')
			
			if ls_link_rastreio = '' or isnull(ls_link_rastreio) then
				ll_pos2 = pos(ls_json, ',', ll_pos1)
			Else
				ll_pos2 = pos(ls_json, '",', ll_pos1)
				if ll_pos2 > 0 then
					ll_pos2++
				ENd if
			End if
			
			if ll_pos1 > 0 and ll_pos2 > 0 then
				ls_json = gf_replace(ls_json, mid(ls_json, ll_pos1, ll_pos2 - ll_pos1),	'"ShippedTrackingUrl": "' + ls_de_url_rastreio + '"',1)
			ENd if
			
		End if
		
		if ls_id_rastreio <> '' and not isnull(ls_id_rastreio) then
	
			ll_pos1 = pos(ls_json, '"ShippedTrackingProtocol":')
			
			ll_pos2 = pos(ls_json, ',', ll_pos1)
			
			if ll_pos1 > 0 and ll_pos2 > 0 then
				ls_json = gf_replace(ls_json, mid(ls_json, ll_pos1, ll_pos2 - ll_pos1),	'"ShippedTrackingProtocol": "' + ls_id_rastreio + '"',1)
			ENd if
			
		ENd if
		
		ll_pos1 = pos(ls_json, '"ShippedCarrierDate":')
		
		ll_pos2 = pos(ls_json, ',', ll_pos1)
		
		if ll_pos1 > 0 and ll_pos2 > 0 then
			ls_json = gf_replace(ls_json, mid(ls_json, ll_pos1, ll_pos2 - ll_pos1),	'"ShippedCarrierDate": "' + String(ldh_faturado,'yyyy-mm-dd hh:mm:ss') + '"',1)
		ENd if
		
	ENd if
	
	parent.wf_faturar_magalu( ls_nr_pedido, ls_json, ref ls_retorno, ref ls_log)
	
	if ls_log <> '' and not isnull(ls_log) then
		Close(w_Aguarde)
		messagebox('Erro', ls_log)
		return -1
	ENd if
	
	w_aguarde.uo_progress.of_setprogress(ll_for)	
	
Next

Close(w_Aguarde)

//ShippedTrackingUrl
//ShippedTrackingProtocol
//ShippedCarrierDate


end event

