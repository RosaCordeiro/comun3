table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_central.cd_produto" dbalias="c.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" dbalias="g.id_situacao" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="dh_inclusao" )
 column=(type=char(40) updatewhereclause=yes name=nm_responsavel dbname="nm_responsavel" )
 retrieve="Select	c.cd_produto,
		g.de_produto || ' : ' || g.de_apresentacao_venda As de_produto,
		g.id_situacao,
		(Select max(z.dh_alteracao)
			From historico_alteracao_tabela z
			Where z.nm_tabela = 'PRODUTO_CENTRAL'
				And z.nm_coluna = 'ID_DESCONSIDERA_SALDO_CD'
				And z.id_alteracao = 'A'
				And Cast(z.de_chave As int) = c.cd_produto) As dh_inclusao,
		(Select Distinct u.nm_usuario
			From historico_alteracao_tabela As x
				Inner Join usuario As u
					On u.nr_matricula = x.nr_matric_alteracao
			Where x.nm_tabela = 'PRODUTO_CENTRAL'
				And x.nm_coluna = 'ID_DESCONSIDERA_SALDO_CD'
				And x.id_alteracao = 'A'
				And Cast(x.de_chave As int) = c.cd_produto
				And x.dh_alteracao = (Select max(x.dh_alteracao)
												From historico_alteracao_tabela x
												Where x.nm_tabela = 'PRODUTO_CENTRAL'
													And x.nm_coluna = 'ID_DESCONSIDERA_SALDO_CD'
													And x.id_alteracao = 'A'
													And Cast(x.de_chave As int) = c.cd_produto)) As nm_responsavel
From produto_central As c
	Inner Join produto_geral As g
		On g.cd_produto = c.cd_produto
Where c.id_desconsidera_saldo_cd = 'S'"  sort="de_produto A " )
