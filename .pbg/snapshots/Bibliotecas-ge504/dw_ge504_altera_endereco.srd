table(column=(type=char(8) updatewhereclause=yes name=nr_cep dbname="pedido_ecommerce_endereco.nr_cep" )
 column=(type=char(100) updatewhereclause=yes name=de_bairro dbname="pedido_ecommerce_endereco.de_bairro" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf dbname="pedido_ecommerce_endereco.cd_uf" )
 column=(type=char(6) updatewhereclause=yes name=nr_endereco dbname="pedido_ecommerce_endereco.nr_endereco" )
 column=(type=char(100) updatewhereclause=yes name=de_complemento dbname="pedido_ecommerce_endereco.de_complemento" )
 column=(type=char(100) updatewhereclause=yes name=de_endereco dbname="pedido_ecommerce_endereco.de_endereco" )
 column=(type=char(50) updatewhereclause=yes name=de_cidade dbname="pedido_ecommerce_endereco.de_cidade" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep_novo dbname="nr_cep_novo" )
 column=(type=char(100) updatewhereclause=yes name=de_bairro_novo dbname="de_bairro_novo" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf_novo dbname="cd_uf_novo" )
 column=(type=char(6) updatewhereclause=yes name=nr_endereco_novo dbname="nr_endereco_novo" )
 column=(type=char(100) updatewhereclause=yes name=de_complemento_novo dbname="de_complemento_novo" )
 column=(type=char(100) updatewhereclause=yes name=de_endereco_novo dbname="de_endereco_novo" )
 column=(type=char(50) updatewhereclause=yes name=de_cidade_novo dbname="de_cidade_novo" )
 column=(type=char(20) updatewhereclause=yes name=nr_pedido_ecommerce dbname="nr_pedido_ecommerce" )
 column=(type=char(20) updatewhereclause=yes name=nr_comprovante_cartao_credito dbname="pedido_ecommerce_auxiliar.nr_comprovante_cartao_credito" )
 column=(type=char(20) updatewhereclause=yes name=nr_autorizacao_cartao_credito dbname="pedido_ecommerce_auxiliar.nr_autorizacao_cartao_credito" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_ecommerce.cd_filial" )
 column=(type=char(11) updatewhereclause=yes name=nr_pedido_drogaexpress dbname="pedido_ecommerce.nr_pedido_drogaexpress" )
 column=(type=char(9) updatewhereclause=yes name=id_situacao dbname="pedido_ecommerce.id_situacao" )
 retrieve="Select pe.nr_cep, pe.de_bairro, pe.cd_uf, pe.nr_endereco, pe.de_complemento, pe.de_endereco, pe.de_cidade,
	cast('' as varchar(8)) as nr_cep_novo, 
	cast('' as varchar(100))  as de_bairro_novo, 
	cast('' as varchar(2))  as cd_uf_novo,
	cast('' as varchar(6))  as nr_endereco_novo,
	cast('' as varchar(100))  as de_complemento_novo,
	cast('' as varchar(100))  as de_endereco_novo,
	cast('' as varchar(50))  as de_cidade_novo,
	(Select pe2.nr_pedido_ecommerce 
		from pedido_ecommerce pe2 
		where pe2.cd_filial_ecommerce = pe.cd_filial_ecommerce 
		and pe2.nr_pedido = pe.nr_pedido) as nr_pedido_ecommerce,
		pa.nr_comprovante_cartao_credito, 
 		pa.nr_autorizacao_cartao_credito,
		pd.cd_filial,
		pd.nr_pedido_drogaexpress,
		pd.id_situacao
from pedido_ecommerce_endereco pe
	inner join pedido_ecommerce pd on pd.cd_filial_ecommerce = pe.cd_filial_ecommerce and pd.nr_pedido = pe.nr_pedido
	left join pedido_ecommerce_auxiliar pa on pa.cd_filial_ecommerce = pe.cd_filial_ecommerce and pa.nr_pedido = pe.nr_pedido
Where pe.nr_pedido = :pl_nr_pedido
and pe.cd_filial_ecommerce = :pl_cd_filial
and pe.cd_tipo_endereco = 2

			" arguments=(("pl_nr_pedido", number),("pl_cd_filial", number)) )
