 retrieve="SELECT	nr_pedido			AS nr_pedido,
			nm_cliente_ent		AS nm_cliente_ent,
			nm_transportadora	AS nm_transp_orig,
			nm_transportadora	AS nm_transportadora,
			cd_filial_ecommerce  AS cd_filial_ecommerce,
			cd_tipo_entrega
FROM pedido_ecommerce
WHERE cd_filial_ecommerce = :filial_ecommerce
	and nr_pedido = :pedido
			" update="pedido_ecommerce" updatewhere=0 updatekeyinplace=yes arguments=(("pedido", number),("filial_ecommerce", number)) )
