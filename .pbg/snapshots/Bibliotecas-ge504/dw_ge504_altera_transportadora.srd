 column=(type=char(30) update=yes updatewhereclause=yes name=nm_transportadora dbname="pedido_ecommerce.nm_transportadora" dbalias=".nm_transportadora" values="PAC	PAC/RETIRAR NA LOJA	RETIRAR NA LOJA/SEDEX	SEDEX/TOTAL EXPRESS	TOTAL EXPRESS/ARM$$HEX1$$c100$$ENDHEX$$RIO INTELIGENTE	ARM$$HEX1$$c100$$ENDHEX$$RIO INTELIGENTE/" )
