table(column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_ecommerce.nr_pedido" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente_ent dbname="pedido_ecommerce.nm_cliente_ent" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="pedido_ecommerce.nm_cliente" )
 column=(type=char(6) updatewhereclause=yes name=nr_endereco_ent dbname="nr_endereco_ent" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf_ent dbname="cd_uf_ent" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep_ent dbname="nr_cep_ent" )
 column=(type=char(100) updatewhereclause=yes name=de_referencia_ent dbname="de_referencia_ent" )
 column=(type=char(20) updatewhereclause=yes name=nr_fone_ent dbname="pedido_ecommerce.nr_fone_ent" )
 column=(type=char(20) updatewhereclause=yes name=nr_fone_contato_ent dbname="pedido_ecommerce.nr_fone_contato_ent" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_frete dbname="pedido_ecommerce.id_tipo_frete" )
 column=(type=char(30) updatewhereclause=yes name=nm_transportadora dbname="pedido_ecommerce.nm_transportadora" )
 column=(type=long updatewhereclause=yes name=nr_prazo_entrega dbname="pedido_ecommerce.nr_prazo_entrega" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_subtotal dbname="pedido_ecommerce.vl_subtotal" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_embalagem dbname="pedido_ecommerce.vl_embalagem" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_frete dbname="pedido_ecommerce.vl_frete" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto dbname="pedido_ecommerce.vl_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_valecompra dbname="pedido_ecommerce.vl_valecompra" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total dbname="pedido_ecommerce.vl_total" )
 column=(type=char(50) updatewhereclause=yes name=cd_tipo_pagamento dbname="pedido_ecommerce.cd_tipo_pagamento" )
 column=(type=char(50) updatewhereclause=yes name=cd_forma_pagamento dbname="pedido_ecommerce.cd_forma_pagamento" )
 column=(type=char(100) updatewhereclause=yes name=de_endereco_ent dbname="de_endereco_ent" )
 column=(type=char(100) updatewhereclause=yes name=de_complemento_ent dbname="de_complemento_ent" )
 column=(type=char(100) updatewhereclause=yes name=de_bairro_ent dbname="de_bairro_ent" )
 column=(type=char(50) updatewhereclause=yes name=de_cidade_ent dbname="de_cidade_ent" )
 column=(type=char(14) updatewhereclause=yes name=cpf dbname="pedido_ecommerce.cpf" )
 column=(type=char(14) updatewhereclause=yes name=cgc dbname="pedido_ecommerce.cgc" )
 column=(type=char(100) updatewhereclause=yes name=de_endereco_email dbname="pedido_ecommerce.de_endereco_email" )
 column=(type=char(20) updatewhereclause=yes name=nr_nsu_host dbname="pedido_ecommerce_auxiliar.nr_nsu_host" )
 column=(type=datetime updatewhereclause=yes name=dh_confirmacao_faturamento dbname="pedido_ecommerce_auxiliar.dh_confirmacao_faturamento" )
 column=(type=char(73) updatewhereclause=yes name=de_filial dbname="de_filial" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="filial.nr_cgc" )
 column=(type=long updatewhereclause=yes name=nr_parcelas dbname="pedido_ecommerce.nr_parcelas" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_parcela dbname="vl_parcela" )
 column=(type=char(20) updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_ecommerce.nr_pedido_ecommerce" )
 column=(type=char(20) updatewhereclause=yes name=nr_cartao_credito dbname="pedido_ecommerce_auxiliar.nr_cartao_credito" )
 column=(type=char(49) updatewhereclause=yes name=nm_resp_cancelamento dbname="nm_resp_cancelamento" )
 column=(type=char(100) updatewhereclause=yes name=de_motivo_cancelamento_pedido dbname="pedido_ecommerce_auxiliar.de_motivo_cancelamento_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="pedido_ecommerce.dh_cancelamento" )
 column=(type=char(11) updatewhereclause=yes name=nr_pedido_drogaexpress dbname="pedido_ecommerce.nr_pedido_drogaexpress" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="pedido_ecommerce.dh_inclusao" )
 column=(type=char(10) updatewhereclause=yes name=nr_pedido_ifood dbname="nr_pedido_ifood" )
 column=(type=datetime updatewhereclause=yes name=dh_compra dbname="pedido_ecommerce.dh_compra" )
 column=(type=long updatewhereclause=yes name=cd_seller dbname="pedido_ecommerce_auxiliar.cd_seller" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_ecommerce dbname="pedido_ecommerce_auxiliar.id_rede_ecommerce" )
 column=(type=char(100) updatewhereclause=yes name=cd_url_integracao dbname="ecommerce_rede_filial.cd_url_integracao" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_entrega dbname="tipo_entrega_ecommerce.id_tipo_entrega" )
 retrieve="   SELECT pe.nr_pedido,   
       pe.nm_cliente_ent, 
		 pe.nm_cliente, 
       Coalesce(pe.nr_endereco_ent, pee.nr_endereco) as nr_endereco_ent,
       Coalesce(pe.cd_uf_ent, pee.cd_uf) as cd_uf_ent,   
       Coalesce(pe.nr_cep_ent, pee.nr_cep) as nr_cep_ent,   
       Coalesce(pe.de_referencia_ent, pee.de_referencia_ent) as de_referencia_ent,
       pe.nr_fone_ent,   
       pe.nr_fone_contato_ent,   
       pe.id_tipo_frete,   
       pe.nm_transportadora,   
       pe.nr_prazo_entrega,   
       pe.vl_subtotal,   
	   pe.vl_embalagem,   
       pe.vl_frete,   
       pe.vl_desconto,   
       pe.vl_valecompra,   
       pe.vl_total,   
       pe.cd_tipo_pagamento,   
       pe.cd_forma_pagamento,   
       Coalesce(pe.de_endereco_ent, pee.de_endereco) as de_endereco_ent,
       Coalesce(pe.de_complemento_ent, pee.de_complemento) as de_complemento_ent,  
       Coalesce(pe.de_bairro_ent, pee.de_bairro) as de_bairro_ent,
       Coalesce(pe.de_cidade_ent, pee.de_cidade) as de_cidade_ent,   
       pe.nr_cpf_cgc cpf,
	   pe.nr_cpf_cgc cgc,
	   pe.de_endereco_email,
	   pa.nr_nsu_host,
	   pa.dh_confirmacao_faturamento,
       cast(pe.cd_filial as varchar) + ' - ' + f.nm_fantasia de_filial,
	   f.nr_cgc,
	    pe.nr_parcelas,
		cast(round(pe.vl_total / pe.nr_parcelas, 2) as decimal(7,2)) vl_parcela,
	  pe.nr_pedido_ecommerce,
      pa.nr_cartao_credito,
	  (CASE WHEN pe.nr_matric_alteracao_situacao is not null THEN pe.nr_matric_alteracao_situacao + ' - ' + u.nm_usuario ELSE '' END) nm_resp_cancelamento,
	  pa.de_motivo_cancelamento_pedido,
	pe.dh_cancelamento,
	pe.nr_pedido_drogaexpress,
	pe.dh_inclusao,
	(CASE WHEN pe.id_ecommerce = '3' THEN  pe.nr_pedido_ecommerce_seq ELSE null END) as nr_pedido_ifood,
	pe.dh_compra,
	pa.cd_seller,
	pa.id_rede_ecommerce,
	er.cd_url_integracao,
	tec.id_tipo_entrega
    FROM pedido_ecommerce pe
	left outer join filial f 
			on f.cd_filial	= pe.cd_filial	
	left outer join usuario u
		on u.nr_matricula = pe.nr_matric_alteracao_situacao
        left join pedido_ecommerce_endereco pee on ( pee.cd_filial_ecommerce = pe.cd_filial_ecommerce
                                                    and pee.nr_pedido = pe.nr_pedido
                                                    and pee.cd_tipo_endereco = 2 )
		left join pedido_ecommerce_auxiliar pa on (pa.cd_filial_ecommerce = pe.cd_filial_ecommerce
																	and pa.nr_pedido = pe.nr_pedido )
		left outer join ecommerce_rede_filial er
				on er.id_ecommerce  = pe.id_ecommerce
				and er.id_rede_filial = pa.id_rede_ecommerce
				and er.cd_filial = pa.cd_seller
		left join tipo_entrega_ecommerce tec on tec.cd_tipo_entrega = pe.cd_tipo_entrega" )
