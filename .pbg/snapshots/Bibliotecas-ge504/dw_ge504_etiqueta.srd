 retrieve="  SELECT p.nr_pedido,
 		 p.nm_cliente_ent,   
         RTRIM(convert(char(60), p.de_endereco_ent)) as de_endereco_ent,
		 p.nr_endereco_ent,
         p.de_complemento_ent,   
         p.de_bairro_ent,   
         p.de_cidade_ent,
		 p.cd_uf_ent,   
         p.nr_cep_ent, 
			p.nm_transportadora
    FROM pedido_ecommerce p



" update="pedido_ecommerce" updatewhere=0 updatekeyinplace=no )
