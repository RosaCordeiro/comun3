table(column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=long update=yes updatewhereclause=yes name=nr_pedido dbname="nr_pedido" )
 column=(type=date update=yes updatewhereclause=yes name=dh_compra dbname="dh_compra" )
 column=(type=time updatewhereclause=yes name=hr_compra dbname="hr_compra" )
 column=(type=date updatewhereclause=yes name=dh_cancelamento dbname="dh_cancelamento" )
 column=(type=char(15) updatewhereclause=yes name=vl_recuperado dbname="vl_recuperado" )
 column=(type=char(9) update=yes updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=char(30) updatewhereclause=yes name=nm_transportadora dbname="nm_transportadora" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep_ent dbname="nr_cep_ent" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pedido dbname="vl_pedido" )
 column=(type=char(13) updatewhereclause=yes name=de_codigo_rastreamento_correio dbname="de_codigo_rastreamento_correio" )
 column=(type=char(1) updatewhereclause=yes name=id_selecao dbname="id_selecao" values="	S/	N" )
 column=(type=long updatewhereclause=yes name=cd_filial_ecommerce dbname="cd_filial_ecommerce" )
 column=(type=char(11) updatewhereclause=yes name=nr_pedido_drogaexpress dbname="nr_pedido_drogaexpress" )
 column=(type=char(1) updatewhereclause=yes name=id_refaturado dbname="id_refaturado" )
 column=(type=char(100) updatewhereclause=yes name=de_motivo_refaturamento dbname="de_motivo_refaturamento" )
 column=(type=date updatewhereclause=yes name=dh_refaturamento dbname="dh_refaturamento" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_refaturamento dbname="nr_matricula_refaturamento" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_ecommerce dbname="id_rede_ecommerce" )
 column=(type=char(20) updatewhereclause=yes name=nr_pedido_ecommerce dbname="nr_pedido_ecommerce" )
 column=(type=char(30) updatewhereclause=yes name=nr_pedido_tela dbname="nr_pedido_tela" )
 column=(type=char(1) updatewhereclause=yes name=id_plataforma dbname="id_plataforma" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_entrega dbname="de_tipo_entrega" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_entrega dbname="id_tipo_entrega" )
 column=(type=char(130) updatewhereclause=yes name=de_url_rastreio dbname="de_url_rastreio" )
 column=(type=char(50) updatewhereclause=yes name=cd_tipo_pagamento dbname="cd_tipo_pagamento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_valecompra dbname="vl_valecompra" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total dbname="vl_total" )
 column=(type=long updatewhereclause=yes name=qt_dias dbname="qt_dias" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_entrega dbname="id_tipo_entrega" )
 column=(type=char(10) updatewhereclause=yes name=nr_pedido_ifood dbname="nr_pedido_ifood" )
 column=(type=long updatewhereclause=yes name=cd_seller dbname="cd_seller" )
 column=(type=char(10) updatewhereclause=yes name=id_pedido_equilibrium dbname="id_pedido_equilibrium" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_seller dbname="id_rede_seller" )
 column=(type=char(20) updatewhereclause=yes name=nr_nsu_host dbname="nr_nsu_host" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_pedido dbname="id_tipo_pedido" )
 column=(type=char(30) updatewhereclause=yes name=nm_ecommerce dbname="nm_ecommerce" )
 column=(type=char(40) updatewhereclause=yes name=nr_pedido_plataforma dbname="nr_pedido_plataforma" )
 retrieve="  SELECT p.cd_filial,   
         f.nm_fantasia,   
         p.nr_pedido,  
		 //convert(char(10),p.dh_compra,103) as 'dh_compra',
		cast(p.dh_compra as date) as dh_compra,
		cast(p.dh_compra as time) as hr_compra,
		//convert(char(10),p.dh_cancelamento,103) as 'dh_cancelamento',        
		cast(p.dh_cancelamento as date) as dh_cancelamento,
         convert(char(15), p.vl_total) vl_recuperado,   
         p.id_situacao,   
         p.nm_transportadora,
		 p.nr_cep_ent,
	     0.00 vl_pedido,
		p.de_codigo_rastreamento_correio,
		'N' as id_selecao,
		p.cd_filial_ecommerce,
		p.nr_pedido_drogaexpress,
		p.id_refaturado,
		p.de_motivo_refaturamento,
		cast(p.dh_refaturamento as date) as dh_refaturamento,
		p.nr_matricula_refaturamento,
		Coalesce(a.id_rede_ecommerce, f.id_rede_filial) as id_rede_ecommerce,
		p.nr_pedido_ecommerce,
		coalesce(p.nr_pedido_ecommerce, cast(p.nr_pedido  as varchar)) nr_pedido_tela,
		CAse When p.nr_pedido_ecommerce is null Then '1' Else p.id_ecommerce End as id_plataforma,
		te.de_tipo_entrega,
		te.id_tipo_entrega,
		p.de_url_rastreio,
		p.cd_tipo_pagamento,
		p.vl_valecompra,
		p.vl_total,
		datediff(dd, p.dh_compra, getdate()) qt_dias,
		te.id_tipo_entrega,
		(CASE WHEN p.id_ecommerce = '3' THEN  p.nr_pedido_ecommerce_seq ELSE null END) as nr_pedido_ifood,
		a.cd_seller,
		a.id_pedido_equilibrium,
		coalesce(f2.id_rede_filial,f.id_rede_filial) as id_rede_seller,
		a.nr_nsu_host,
		a.id_tipo_pedido,
		ec.nm_ecommerce,
		a.nr_pedido_plataforma
FROM pedido_ecommerce p
INNER JOIN ecommerce ec on ec.id_ecommerce = p.id_ecommerce
INNER JOIN filial f
	ON f.cd_filial = p.cd_filial  
LEFT OUTER JOIN pedido_ecommerce_auxiliar a
	ON a.cd_filial_ecommerce 	= p.cd_filial_ecommerce
	AND a.nr_pedido 				= p.nr_pedido   
LEFT OUTER JOIN filial f2
	ON f2.cd_filial = a.cd_seller
LEFT OUTER JOIN tipo_entrega_ecommerce te
	ON te.cd_tipo_entrega = p.cd_tipo_entrega


"  sort="id_situacao A nr_pedido A " )
