table(column=(type=decimal(2) updatewhereclause=yes name=vl_forma_pagamento dbname="vl_forma_pagamento" )
 column=(type=long updatewhereclause=yes name=nr_parcelas dbname="nr_parcelas" )
 column=(type=char(20) updatewhereclause=yes name=nr_comprovante_cartao_credito dbname="nr_comprovante_cartao_credito" )
 column=(type=char(20) updatewhereclause=yes name=nr_autorizacao_cartao_credito dbname="nr_autorizacao_cartao_credito" )
 column=(type=char(40) updatewhereclause=yes name=nm_administradora_cartao dbname="nm_administradora_cartao" )
 column=(type=char(10) updatewhereclause=yes name=cd_estabelecimento_cartao dbname="cd_estabelecimento_cartao" )
 column=(type=char(20) updatewhereclause=yes name=nr_cartao_credito dbname="nr_cartao_credito" )
 column=(type=char(50) updatewhereclause=yes name=cd_forma_pagamento dbname="cd_forma_pagamento" )
 column=(type=char(50) updatewhereclause=yes name=cd_tipo_pagamento dbname="cd_tipo_pagamento" )
 column=(type=char(50) updatewhereclause=yes name=nr_nsu_host dbname="nr_nsu_host" )
 column=(type=datetime updatewhereclause=yes name=dh_confirmacao_faturamento dbname="dh_confirmacao_faturamento" )
 column=(type=char(50) updatewhereclause=yes name=cd_autorizacao_cd dbname="cd_autorizacao_cd" )
 column=(type=char(40) updatewhereclause=yes name=nm_administradora_cartao dbname="nm_administradora_cartao" )
 retrieve="select coalesce(a.vl_forma_pagamento, p.vl_total) as vl_forma_pagamento,
		p.nr_parcelas,
		a.nr_comprovante_cartao_credito,
		a.nr_autorizacao_cartao_credito,
		a.nm_administradora_cartao,
		a.cd_estabelecimento_cartao,
		a.nr_cartao_credito,
		p.cd_forma_pagamento,
		p.cd_tipo_pagamento,
		Case When p.cd_tipo_pagamento = 'PIX ECOMMERCE' Then a.cd_autorizacao_cd Else a.nr_nsu_host End as nr_nsu_host,
		a.dh_confirmacao_faturamento,
		a.cd_autorizacao_cd,a.nm_administradora_cartao
from pedido_ecommerce p
	inner join pedido_ecommerce_auxiliar a on a.cd_filial_ecommerce = p.cd_filial_ecommerce and a.nr_pedido = p.nr_pedido 
where p.nr_pedido = :pl_nr_Pedido
and p.cd_filial_ecommerce = :pl_cd_filial
and a.vl_forma_pagamento > 0

UNION ALL

select vl_forma_pagamento_2, 
		nr_parcelas_2 , 
		nr_comp_cartao_credito_2 , 
		nr_autoriz_cartao_credito_2 ,
		nm_administradora_cartao_2 , 
		cd_estabelecimento_cartao_2 , 
		nr_cartao_credito_2 , 
		cd_forma_pagamento_2 , 
		cd_tipo_pagamento_2 ,
		nr_nsu_host_2,
		dh_confirmacao_faturamento,
		cd_autorizacao_cd,nm_administradora_cartao
from pedido_ecommerce_auxiliar 
where nr_pedido = :pl_nr_Pedido
and cd_filial_ecommerce = :pl_cd_filial
and nm_administradora_cartao_2 is not null
and vl_forma_pagamento_2 > 0

UNION ALL

select vl_forma_pagamento, 
		nr_parcelas, 
		nr_comp_cartao_credito, 
		nr_autoriz_cartao_credito,
		nm_administradora_cartao, 
		cd_estabelecimento_cartao, 
		nr_cartao_credito, 
		cd_forma_pagamento, 
		cd_tipo_pagamento,
		nr_nsu_host,
		null,
		null,null
from pedido_ecommerce_pagamento
where nr_pedido = :pl_nr_Pedido
and cd_filial_ecommerce = :pl_cd_filial
and vl_forma_pagamento > 0" arguments=(("pl_cd_filial", number),("pl_nr_pedido", number)) )
