table(column=(type=long updatewhereclause=yes name=nr_pedido dbname="nr_pedido" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="qt_pedida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco dbname="vl_preco" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_promocao dbname="vl_preco_promocao" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 retrieve="  SELECT pedido_ecommerce_produto.nr_pedido,   
         pedido_ecommerce_produto.cd_produto,   
         pedido_ecommerce_produto.qt_pedida,   
         pedido_ecommerce_produto.vl_preco,   
         pedido_ecommerce_produto.vl_preco_promocao ,
			pedido_ecommerce_produto.pc_desconto ,
		coalesce(pedido_ecommerce_produto.nm_produto,  produto_geral.de_produto + ' : '+ produto_geral.de_apresentacao_venda) de_produto
    FROM pedido_ecommerce_produto,   
         produto_geral  
   WHERE ( produto_geral.cd_produto = pedido_ecommerce_produto.cd_produto )    
" )
