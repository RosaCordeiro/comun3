 retrieve="select pe.cd_filial_ecommerce,
		pe.nr_pedido,   
		pe.nr_pedido_ecommerce,
		pe.dh_compra,   
		pe.dh_atualizacao,   
		pe.id_situacao,   
		pe.cd_cliente,   
		pe.nm_cliente,   
		pe.de_endereco_email,   
		pe.nr_cpf_cgc,   
		pe.nr_inscricao_estadual,   
		pe.id_fisica_juridica,   
		pe.id_sexo,   
		pe.dh_nascimento,   
		pe.nm_contato,   
		pe.de_endereco,   
		pe.nr_endereco,   
		pe.de_complemento,   
		pe.de_bairro,   
		pe.de_cidade,   
		pe.cd_uf,   
		pe.nr_cep,   
		pe.de_pais,   
		pe.nr_fone,   
		pe.nr_fone_contato,   
		pe.nm_cliente_ent,   
		pee.de_endereco as de_endereco_ent,   
		pee.nr_endereco as nr_endereco_ent,   
		pee.de_complemento as de_complemento_ent,   
		pee.de_bairro as de_bairro_ent,   
		pee.de_cidade as de_cidade_ent,   
		pee.cd_uf as cd_uf_ent,   
		pee.nr_cep as nr_cep_ent,   
		pee.de_referencia_ent,   
		pee.de_pais as de_pais_ent,   
		pe.nr_fone_ent,   
		pe.nr_fone_contato_ent,   
		pe.de_observacao,   
		pe.id_tipo_frete,   
		pe.nm_transportadora,   
		pe.nr_prazo_entrega,   
		pe.nm_regiao_entrega,   
		pe.vl_subtotal,   
		pe.vl_embalagem,   
		pe.vl_frete,   
		pe.vl_desconto,   
		pe.vl_valecompra,   
		pe.vl_total,   
		pe.nr_parcelas,   
		pe.vl_entrada,   
		pe.vl_parcela,   
		pe.vl_indexador,   
		pe.cd_boleto_parcelado,   
		pe.cd_tipo_pagamento,   
		pe.cd_forma_pagamento,   
		pe.cd_origem,   
		pe.cd_cupom_desconto,   
		pe.de_promocao,
		pe.cd_filial,
		pe.nr_pedido_drogaexpress,
		pe.dh_inclusao,
		pe.id_pagamento,
		pe.nr_boleto_bancario,
		px.id_cpf_nf
from pedido_ecommerce pe
inner join filial f
	on f.cd_filial = pe.cd_filial_ecommerce
	left join pedido_ecommerce_endereco pee on (pee.cd_filial_ecommerce = pe.cd_filial_ecommerce 
																	and pee.nr_pedido = pe.nr_pedido
																	and pee.cd_tipo_endereco = 2)
	left join pedido_ecommerce_auxiliar px on (px.cd_filial_ecommerce = pe.cd_filial_ecommerce 
																	and px.nr_pedido = pe.nr_pedido)
where pe.nr_pedido_drogaexpress is null
and pe.id_situacao in ('A','X')
and coalesce(f.id_sistema_novo,'N') = 'N'
and pe.id_ecommerce = :ps_id_ecommerce
and f.id_rede_filial = :rede
and f.cd_filial = :pl_cd_filial
and pe.dh_compra > dbo.adddate( 'day', -30, getdate( ) )
order by pe.cd_filial" arguments=(("ps_id_ecommerce", string),("rede", string),("pl_cd_filial", number)) )
