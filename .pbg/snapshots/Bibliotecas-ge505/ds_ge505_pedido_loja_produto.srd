 column=(type=long update=yes updatewhereclause=yes name=nr_requisicao_manip dbname="pedido_ecommerce_produto.nr_requisicao_manip" )
 retrieve="select cd_filial_ecommerce,
		nr_pedido,   
		cd_produto_ecommerce, 
		nr_sequencial,
		qt_pedida,   
		nm_produto,   
		cd_produto,   
		cd_fornecedor,   
		vl_preco, 	 	
		vl_preco_promocao,
		dh_inicio_promocao,   
		dh_termino_promocao,
		nr_requisicao_manip
from pedido_ecommerce_produto
where cd_filial_ecommerce = :pl_cd_filial
and nr_pedido = :pl_nr_pedido" update="pedido_ecommerce_produto" updatewhere=1 updatekeyinplace=no arguments=(("pl_cd_filial", number),("pl_nr_pedido", number)) )
