table(column=(type=long update=yes updatewhereclause=yes name=cd_filial_ecommerce dbname="pedido_ecommerce.cd_filial_ecommerce" dbalias="pe.cd_filial_ecommerce" )
 column=(type=long update=yes updatewhereclause=yes name=nr_pedido dbname="pedido_ecommerce.nr_pedido" dbalias="pe.nr_pedido" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="pedido_ecommerce.cd_filial" dbalias="pe.cd_filial" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_ecommerce.nr_pedido_ecommerce" dbalias="pe.nr_pedido_ecommerce" )
 column=(type=char(9) updatewhereclause=yes name=id_situacao dbname="pedido_ecommerce.id_situacao" dbalias="pe.id_situacao" )
 column=(type=char(1) updatewhereclause=yes name=id_sistema_novo dbname="id_sistema_novo" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 retrieve="select pe.cd_filial_ecommerce, 
		pe.nr_pedido, 
		pe.cd_filial, 
		pe.nr_pedido_ecommerce, 
		pe.id_situacao,
		coalesce(f.id_sistema_novo, 'N') as id_sistema_novo, 
		coalesce(nv.nr_nf,0) as nr_nf
from pedido_ecommerce pe
	inner join filial f on pe.cd_filial = f.cd_filial
	left join nf_venda nv on nv.nr_pedido_ecommerce = pe.nr_pedido
where pe.id_ecommerce = :ps_id_ecommerce
and pe.cd_filial = :pl_cd_filial
and pe.dh_compra > dbo.adddate( 'day', -30, getdate( ) )
and pe.dh_faturado is null
and ( 
	( pe.id_situacao in ('A','P') and coalesce(f.id_sistema_novo,'N') = 'N' )
	Or
	( pe.id_situacao in ('F') and coalesce(f.id_sistema_novo,'N') = 'S' )
	Or
	( pe.id_situacao in ('P') and coalesce(f.id_sistema_novo,'N') = 'S' and coalesce(nv.nr_nf,0) > 0 )
	)
order by pe.cd_filial" arguments=(("ps_id_ecommerce", string),("pl_cd_filial", number)) )
