table(column=(type=long updatewhereclause=yes name=cd_promocao dbname="promocao_vencimento.cd_promocao" )
 column=(type=char(40) updatewhereclause=yes name=nm_promocao dbname="promocao_vencimento.nm_promocao" )
 column=(type=char(40) updatewhereclause=yes name=grupo_de_grupo dbname="grupo.de_grupo" )
 column=(type=date updatewhereclause=yes name=dh_inicio dbname="promocao_vencimento.dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="promocao_vencimento.dh_termino" )
 column=(type=char(1) updatewhereclause=yes name=cd_grupo dbname="grupo.cd_grupo" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="promocao_vencimento.pc_desconto" )
 retrieve="  SELECT cd_promocao,
         nm_promocao,
         de_grupo,
         dh_inicio,
         dh_termino,
         grupo.cd_grupo,
         pc_desconto
    FROM promocao_vencimento,
         parametro,
         grupo
   WHERE ( parametro.dh_movimentacao >= promocao_vencimento.dh_inicio )
     AND ( promocao_vencimento.dh_termino is null or promocao_vencimento.dh_termino >= parametro.dh_movimentacao )
     AND ( grupo.cd_grupo = promocao_vencimento.cd_grupo )"  sort="nm_promocao A " )
