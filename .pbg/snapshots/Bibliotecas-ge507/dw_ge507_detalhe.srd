table(column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="vw_wms_endereco.cd_endereco" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_endereco_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_saldo_erp dbname="saldo_produto.qt_saldo_erp" )
 column=(type=long updatewhereclause=yes name=qt_saldo_flow dbname="qt_saldo_flow" )
 column=(type=long updatewhereclause=yes name=qt_saldo_pulmao dbname="qt_saldo_pulmao" )
 column=(type=long updatewhereclause=yes name=qt_saldo_cd dbname="qt_saldo_cd" )
 retrieve="select	e.cd_endereco,
		p.cd_produto,
		g.de_produto || ' : ' || g.de_apresentacao_estoque as de_produto,
		s.qt_saldo_final as qt_saldo_erp,

        (select coalesce(sum(lo.qt_saldo), 0)
          from wms_localizacao lo
            inner join vw_wms_endereco ve
              on ve.cd_endereco = lo.cd_endereco
          where ve.id_flow_rack = 'S'
          and ve.id_utiliza_saldo = 'S'
    		and lo.cd_produto = p.cd_produto) as qt_saldo_flow,

         (select coalesce(sum(lo.qt_saldo * lo.qt_caixa_padrao), 0)
          from wms_localizacao lo
            inner join vw_wms_endereco ve
              on ve.cd_endereco = lo.cd_endereco
          where ve.id_flow_rack = 'N'
          and ve.id_utiliza_saldo = 'S'
     	and lo.cd_produto = p.cd_produto) as qt_saldo_pulmao,

  
      (select coalesce(sum(lo.qt_saldo), 0)
         from wms_localizacao lo
          inner join vw_wms_endereco ve
            on ve.cd_endereco = lo.cd_endereco
         where ve.id_flow_rack = 'S'
         and ve.id_utiliza_saldo = 'S'
      	and lo.cd_produto = p.cd_produto) 

		+
  
        (select coalesce(sum(lo.qt_saldo * lo.qt_caixa_padrao), 0)
         from wms_localizacao lo
          inner join vw_wms_endereco ve
            on ve.cd_endereco = lo.cd_endereco
         where ve.id_flow_rack = 'N'
         and ve.id_utiliza_saldo = 'S'
       	and lo.cd_produto = p.cd_produto) as qt_saldo_cd

from vw_wms_endereco e
left join wms_endereco_produto p on p.cd_endereco = e.cd_endereco
left outer join saldo_produto s on s.cd_filial = 534
                            and s.cd_produto = p.cd_produto
                            and s.dh_saldo = '20201101'
inner join produto_geral g
  on g.cd_produto = p.cd_produto
where e.id_flow_rack_bairro = 'S'
	and e.cd_esteira = :esteira" arguments=(("esteira", number))  sort="de_produto A " )
