table(column=(type=long updatewhereclause=yes name=cd_esteira dbname="vw_wms_endereco.cd_esteira" )
 column=(type=char(20) updatewhereclause=yes name=de_esteira dbname="wms_esteira.de_esteira" )
 column=(type=long updatewhereclause=yes name=vl_volume dbname="vl_volume" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo dbname="vl_custo" )
 column=(type=long updatewhereclause=yes name=qt_ocupado dbname="qt_ocupado" )
 column=(type=long updatewhereclause=yes name=qt_vazio dbname="qt_vazio" )
 retrieve="select e.cd_esteira,
       es.de_esteira,
       isnull ( sum ( l.qt_saldo),0) as vl_volume,
       isnull ( sum( s.vl_custo_medio * l.qt_saldo) , 0 ) as vl_custo,

       (select count( distinct f.cd_endereco )
        From wms_endereco f
        where f.cd_bairro in ('0', '2', '8')
          and f.id_flow_rack = 'S'
          and f.cd_esteira = e.cd_esteira
          and f.cd_endereco in ( select cd_endereco from wms_localizacao )) as qt_ocupado,

       (select count( distinct f.cd_endereco )
        From wms_endereco f
        where f.cd_bairro in ('0', '2', '8')
          and f.id_flow_rack = 'S'
          and f.cd_esteira = e.cd_esteira
          and f.cd_endereco not in ( select cd_endereco from wms_localizacao )) as qt_vazio

from vw_wms_endereco e
left join wms_endereco_produto p on p.cd_endereco = e.cd_endereco
left join wms_localizacao l on l.cd_endereco = e.cd_endereco
inner join saldo_produto s on s.cd_filial = 534
                            and s.cd_produto = p.cd_produto
                            and s.dh_saldo = :saldo
inner join wms_esteira es on es.cd_esteira = e.cd_esteira
where e.id_flow_rack_bairro = 'S'
group by e.cd_esteira,
         es.de_esteira" arguments=(("saldo", date))  sort="de_esteira A " )
