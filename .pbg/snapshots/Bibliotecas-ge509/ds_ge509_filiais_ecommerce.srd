table(column=(type=long updatewhereclause=yes name=cd_filial dbname="ecommerce_rede_filial.cd_filial" dbalias="erf.cd_filial" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_filial dbname="ecommerce_rede_filial.id_rede_filial" dbalias="erf.id_rede_filial" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao_saldo dbname="ecommerce_rede_filial.dh_atualizacao_saldo" dbalias="erf.dh_atualizacao_saldo" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="ecommerce_rede_filial.id_situacao" dbalias="erf.id_situacao" )
 column=(type=long updatewhereclause=yes name=nr_dia_carga_completa dbname="ecommerce_rede_filial.nr_dia_carga_completa" dbalias="erf.nr_dia_carga_completa" )
 column=(type=datetime updatewhereclause=yes name=dh_carga_saldo_completa dbname="ecommerce_rede_filial.dh_carga_saldo_completa" dbalias="erf.dh_carga_saldo_completa" )
 column=(type=datetime updatewhereclause=yes name=dh_proxima_carga_saldo_comp dbname="ecommerce_rede_filial.dh_proxima_carga_saldo_comp" dbalias="erf.dh_proxima_carga_saldo_comp" )
 column=(type=char(1) updatewhereclause=yes name=id_sistema_novo dbname="id_sistema_novo" )
 retrieve="select erf.cd_filial, erf.id_rede_filial, erf.dh_atualizacao_saldo, erf.id_situacao, erf.nr_dia_carga_completa, erf.dh_carga_saldo_completa, erf.dh_proxima_carga_saldo_comp, coalesce(f.id_sistema_novo,'N') as id_sistema_novo
from ecommerce_rede_filial erf
inner join ecommerce_rede er 
	on er.id_ecommerce = erf.id_ecommerce
	and er.id_rede_filial = erf.id_rede_filial
inner join filial f on f.cd_filial = erf.cd_filial
where erf.id_ecommerce = :ps_id_ecommerce
	and er.id_situacao = 'A'
	and erf.id_situacao = 'A'
order by erf.cd_filial asc" arguments=(("ps_id_ecommerce", string)) )
