table(column=(type=char(1) updatewhereclause=yes name=id_fisica_juridica dbname="pedido_ecommerce.id_fisica_juridica" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep_ent dbname="pedido_ecommerce.nr_cep_ent" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_ecommerce_produto.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_ecommerce_produto.qt_pedida" )
 column=(type=char(100) updatewhereclause=yes name=de_descricao_internet dbname="produto_geral.de_descricao_internet" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_altura_cm dbname="produto_geral.qt_altura_cm" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_largura_cm dbname="produto_geral.qt_largura_cm" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_profundidade_cm dbname="produto_geral.qt_profundidade_cm" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_grama dbname="produto_geral.qt_peso_grama" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_produto dbname="id_tipo_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco dbname="pedido_ecommerce_produto.vl_preco" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_calculado dbname="vl_total_calculado" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_ecommerce.cd_filial" )
 retrieve="select pe.id_fisica_juridica, 
		pe.nr_cep_ent, 
		pp.cd_produto,
		pp.qt_pedida,
		pg.de_descricao_internet, 
		pg.qt_altura_cm, 
		pg.qt_largura_cm, 
		pg.qt_profundidade_cm,
		pg.qt_peso_grama,
		substring(pg.cd_subcategoria, 1,1) as id_tipo_produto,
		pp.vl_preco_promocao as vl_preco,
		pe.vl_subtotal - pe.vl_desconto as vl_total_calculado,
		pe.cd_filial
from pedido_ecommerce pe
	inner join pedido_ecommerce_produto pp on ( pp.cd_filial_ecommerce = pe.cd_filial_ecommerce
															   and pp.nr_pedido = pe.nr_pedido )
	inner join produto_geral pg on (pg.cd_produto = pp.cd_produto)
where pe.nr_pedido = :pl_nr_pedido
and pe.cd_filial_ecommerce = :pl_cd_filial" arguments=(("pl_cd_filial", number),("pl_nr_pedido", number)) )
