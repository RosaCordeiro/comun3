 column=(type=char(15) updatewhereclause=yes name=nr_cpf_pbm dbname="pedido_ecommerce_auxiliar.nr_cpf_pbm" dbalias="pa.nr_cpf_pbm" )
 retrieve="select pe.cd_filial_ecommerce,
		pe.nr_pedido,   
		pe.nr_pedido_ecommerce,
		pe.dh_compra,   
		pe.dh_atualizacao,   
		pe.id_situacao,   
		pe.cd_cliente,   
		pe.nm_cliente,   
		pe.de_endereco_email,   
		pe.nr_cpf_cgc,   
		pe.nr_inscricao_estadual,   
		pe.id_fisica_juridica,   
		pe.id_sexo,   
		pe.dh_nascimento,   
		pe.nm_contato,   
		pe.de_endereco,   
		pe.nr_endereco,   
		pe.de_complemento,   
		pe.de_bairro,   
		pe.de_cidade,   
		pe.cd_uf,   
		pe.nr_cep,   
		pe.de_pais,   
		pe.nr_fone,   
		pe.nr_fone_contato,   
		pe.nm_cliente_ent,   
		pee.de_endereco as de_endereco_ent,   
		pee.nr_endereco as nr_endereco_ent,   
		pee.de_complemento as de_complemento_ent,   
		pee.de_bairro as de_bairro_ent,   
		pee.de_cidade as de_cidade_ent,   
		pee.cd_uf as cd_uf_ent,   
		pee.nr_cep as nr_cep_ent,   
		pee.de_referencia_ent,   
		pee.de_pais as de_pais_ent,   
		pee.cd_cidade,
		pe.nr_fone_ent,   
		pe.nr_fone_contato_ent,   
		pe.de_observacao,   
		pe.id_tipo_frete,   
		pe.nm_transportadora,   
		pe.nr_prazo_entrega,   
		pe.nm_regiao_entrega,   
		pe.vl_subtotal,   
		pe.vl_embalagem,   
		pe.vl_frete,   
		pe.vl_desconto,   
		pe.vl_valecompra,   
		pe.vl_total,   
		pe.nr_parcelas,   
		pe.vl_entrada,   
		pe.vl_parcela,   
		pe.vl_indexador,   
		pe.cd_boleto_parcelado,   
		pe.cd_tipo_pagamento,   
		pe.cd_forma_pagamento,   
		pe.cd_origem,   
		pe.cd_cupom_desconto,   
		pe.de_promocao,
		pe.cd_filial,
		pe.nr_pedido_drogaexpress,
		pe.dh_inclusao,
		pe.id_pagamento,
		pe.nr_boleto_bancario,
		pa.nm_administradora_cartao,
		pa.cd_estabelecimento_cartao,
		pa.nr_cartao_credito,
		pa.nr_comprovante_cartao_credito,
		pa.nr_autorizacao_cartao_credito,
		coalesce(pa.id_exige_nfse, 'N') id_exige_nfse,
		pa.cd_seller,
		pa.id_rede_ecommerce,
		pe.nr_vending_machine,
		pa.id_tipo_pedido,
		pa.nr_psp_recebedor,
		pa.cd_autorizacao_cd,
		pa.id_tipo_uso_cd,
		te.id_tipo_entrega,
		pa.nr_nsu_host,
		pa.nr_cpf_pbm
from pedido_ecommerce pe
inner join pedido_ecommerce_auxiliar pa on (pa.cd_filial_ecommerce = pe.cd_filial_ecommerce and pa.nr_pedido = pe.nr_pedido)
inner join pedido_ecommerce_endereco pee on (pee.cd_filial_ecommerce = pe.cd_filial_ecommerce and pee.nr_pedido = pe.nr_pedido and pee.cd_tipo_endereco = 2)
inner join ecommerce_rede_filial erf on erf.id_ecommerce = pe.id_ecommerce and erf.id_rede_filial = pa.id_rede_ecommerce and erf.cd_filial_hub = pe.cd_filial 
inner join filial f on ( f.cd_filial = pe.cd_filial )
left join tipo_entrega_ecommerce te on ( te.cd_tipo_entrega = pe.cd_tipo_entrega )
 where  pe.id_situacao in ( 'A', 'G' )
   and coalesce(f.id_sistema_novo,'N') = 'N'
   and pe.nr_pedido_drogaexpress is null
   and pe.nr_pedido_ecommerce is not null
   and coalesce(pe.id_ecommerce, '1') = :ps_id_ecommerce
   and pe.dh_compra <= dateadd(mi,-4, getdate())
   and pa.id_rede_ecommerce = :ps_id_rede
	and erf.cd_filial = :pl_cd_filial
order by pe.cd_filial" arguments=(("ps_id_ecommerce", string),("ps_id_rede", string),("pl_cd_filial", number)) )
