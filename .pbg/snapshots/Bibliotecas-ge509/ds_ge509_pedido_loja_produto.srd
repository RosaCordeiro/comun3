 column=(type=long update=yes updatewhereclause=yes name=qt_pedida dbname="pedido_ecommerce_produto.qt_pedida" )
 column=(type=char(100) update=yes updatewhereclause=yes name=nm_produto dbname="pedido_ecommerce_produto.nm_produto" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="pedido_ecommerce_produto.cd_produto" )
 column=(type=char(9) update=yes updatewhereclause=yes name=cd_fornecedor dbname="pedido_ecommerce_produto.cd_fornecedor" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_preco dbname="pedido_ecommerce_produto.vl_preco" )
