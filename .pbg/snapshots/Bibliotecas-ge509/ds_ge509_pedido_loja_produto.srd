 column=(type=decimal(4) updatewhereclause=yes name=pc_desconto dbname="pedido_ecommerce_produto.pc_desconto" )
 column=(type=char(1) updatewhereclause=yes name=id_campanha_exclusiva_pbm dbname="pedido_ecommerce_produto.id_campanha_exclusiva_pbm" )
 column=(type=char(20) updatewhereclause=yes name=nr_campanha_pbm dbname="pedido_ecommerce_produto.nr_campanha_pbm" )
 column=(type=long updatewhereclause=yes name=cd_pbm dbname="pedido_ecommerce_produto.cd_pbm" )
 column=(type=char(1) updatewhereclause=yes name=id_usa_desconto_pbm dbname="pedido_ecommerce_produto.id_usa_desconto_pbm" )
 column=(type=char(20) updatewhereclause=yes name=cd_conveniado_pbm dbname="pedido_ecommerce_produto.cd_conveniado_pbm" )
 column=(type=char(20) updatewhereclause=yes name=nr_autorizacao_pbm dbname="pedido_ecommerce_produto.nr_autorizacao_pbm" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_regra_pbm dbname="pedido_ecommerce_produto.cd_produto_regra_pbm" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_maximo_pbm dbname="pedido_ecommerce_produto.vl_preco_maximo_pbm" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_reposicao_pbm dbname="pedido_ecommerce_produto.vl_reposicao_pbm" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_altura_cm dbname="produto_geral.qt_altura_cm" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_largura_cm dbname="produto_geral.qt_largura_cm" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_profundidade_cm dbname="produto_geral.qt_profundidade_cm" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_grama dbname="produto_geral.qt_peso_grama" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_produto dbname="id_tipo_produto" )
 retrieve="select pp.cd_filial_ecommerce,
		pp.nr_pedido,   
		pp.cd_produto_ecommerce, 
		pp.nr_sequencial,
		pp.qt_pedida,   
		pp.nm_produto,   
		pp.cd_produto,   
		pp.cd_fornecedor,   
		pp.vl_preco, 	 	
		pp.vl_preco_promocao,
		pp.dh_inicio_promocao,   
		pp.dh_termino_promocao,
		pp.nr_requisicao_manip,
		pp.pc_desconto,
		pp.id_campanha_exclusiva_pbm,
		pp.nr_campanha_pbm,
		pp.cd_pbm,
		pp.id_usa_desconto_pbm,
		pp.cd_conveniado_pbm,
		pp.nr_autorizacao_pbm,
		pp.cd_produto_regra_pbm,
		pp.vl_preco_maximo_pbm,
		pp.vl_reposicao_pbm,
		pg.qt_altura_cm, 
		pg.qt_largura_cm, 
		pg.qt_profundidade_cm,
		pg.qt_peso_grama,
		substring(pg.cd_subcategoria, 1,1) as id_tipo_produto
from pedido_ecommerce_produto pp
	inner join produto_geral pg on (pg.cd_produto = pp.cd_produto)
where pp.cd_filial_ecommerce = :pl_cd_filial
and pp.nr_pedido = :pl_nr_pedido" arguments=(("pl_cd_filial", number),("pl_nr_pedido", number))  sort="cd_produto A " )
