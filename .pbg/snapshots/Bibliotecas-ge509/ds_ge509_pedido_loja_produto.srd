table(column=(type=long update=yes updatewhereclause=yes name=cd_filial_ecommerce dbname="pedido_ecommerce_produto.cd_filial_ecommerce" )
 column=(type=long update=yes updatewhereclause=yes name=nr_pedido dbname="pedido_ecommerce_produto.nr_pedido" )
