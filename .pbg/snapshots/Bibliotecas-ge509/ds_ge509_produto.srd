table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="p.cd_produto" )
 column=(type=char(10) updatewhereclause=yes name=cd_produto_ecommerce dbname="ecommerce_prd.cd_produto_ecommerce" dbalias="ep.cd_produto_ecommerce" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_grama dbname="produto_geral.qt_peso_grama" dbalias="p.qt_peso_grama" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_promocao dbname="ecommerce_prd.vl_preco_promocao" dbalias="ep2.vl_preco_promocao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco dbname="ecommerce_prd.vl_preco" dbalias="ep2.vl_preco" )
 column=(type=long updatewhereclause=yes name=qt_saldo_filial dbname="qt_saldo_filial" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" dbalias="p.de_codigo_barras" )
 column=(type=char(1) updatewhereclause=yes name=id_visivel_prd dbname="id_visivel_prd" )
 column=(type=char(1) updatewhereclause=yes name=id_inativar_atualizacao_saldo dbname="id_inativar_atualizacao_saldo" )
 retrieve="Select p.cd_produto, 
		ep.cd_produto_ecommerce,
		p.qt_peso_grama,
		ep2.vl_preco_promocao,
		ep2.vl_preco,
		coalesce(epf.qt_saldo_filial, 0) - coalesce(epf.qt_saldo_pendente, 0) - coalesce(epf.qt_saldo_transferencia, 0) - coalesce(epf.qt_saldo_prestes, 0) as qt_saldo_filial,
		p.de_codigo_barras,
		coalesce(ep.id_visivel_prd,'S') as id_visivel_prd,
		(select epf3.id_inativar_atualizacao_saldo from ecommerce_prd_filial epf3 where epf3.id_ecommerce = erf2.id_ecommerce and epf3.id_rede_filial = erf2.id_rede_filial and epf3.cd_filial = erf2.cd_filial and epf3.cd_produto= epf.cd_produto) as id_inativar_atualizacao_saldo
from
(
Select distinct convert(integer, de_chave) as cd_produto, l.cd_filial_ecommerce
 From log_exportacao_ecommerce  l
Where  l.id_processado = 'P' 
 and l.nm_tabela = 'PRODUTO_GERAL'
 and l.id_ecommerce = :ps_id_ecommerce
and l.cd_filial_ecommerce = :pl_cd_filial_ecommerce
) Aux inner join produto_geral p on (p.cd_produto = Aux.cd_produto)
		inner join ecommerce_prd_filial epf on (epf.id_ecommerce = '2'
											and epf.id_rede_filial = :ps_rede_filial
											and epf.cd_filial = :pl_cd_filial_ecommerce
											and epf.cd_produto  = p.cd_produto )
		inner join ecommerce_rede_filial erf on erf.id_ecommerce = epf.id_ecommerce and erf.id_rede_filial = epf.id_rede_filial and erf.cd_filial = epf.cd_filial
		inner join ecommerce_rede_filial erf2 on erf2.id_ecommerce = epf.id_ecommerce and erf2.cd_filial = erf.cd_filial_hub
		inner join ecommerce_prd ep2 on (ep2.id_ecommerce = '2' and ep2.id_rede_filial = :ps_rede_filial and ep2.cd_produto = p.cd_produto)
		left join ecommerce_prd ep on (ep.id_ecommerce = :ps_id_ecommerce and ep.id_rede_filial = :ps_rede_filial and ep.cd_produto = p.cd_produto)
Where left(p.de_produto,2) <> 'ZZ' 
and p.cd_grupo_psico is null

UNION

select epf.cd_produto,
		ep2.cd_produto_ecommerce,
		p.qt_peso_grama,
		ep.vl_preco_promocao,
		ep.vl_preco,
		coalesce(epf.qt_saldo_filial, 0) - coalesce(epf.qt_saldo_pendente, 0) - coalesce(epf.qt_saldo_transferencia, 0) - coalesce(epf.qt_saldo_prestes, 0) as qt_saldo_filial,
		p.de_codigo_barras,
		coalesce(ep2.id_visivel_prd,'S') as id_visivel_prd,
		(select epf3.id_inativar_atualizacao_saldo from ecommerce_prd_filial epf3 where epf3.id_ecommerce = erf2.id_ecommerce and epf3.id_rede_filial = erf2.id_rede_filial and epf3.cd_filial = erf2.cd_filial and epf3.cd_produto= epf.cd_produto) as id_inativar_atualizacao_saldo
from ecommerce_prd_filial epf
	inner join ecommerce_rede_filial erf on erf.id_ecommerce = epf.id_ecommerce and erf.id_rede_filial = epf.id_rede_filial and erf.cd_filial = epf.cd_filial  
	inner join ecommerce_rede_filial erf2 on erf2.id_ecommerce = epf.id_ecommerce and erf2.cd_filial = erf.cd_filial_hub
	inner join ecommerce_prd ep on (ep.id_ecommerce = epf.id_ecommerce 
								and ep.id_rede_filial = epf.id_rede_filial
								and ep.cd_produto  = epf.cd_produto )
	inner join produto_geral p on (p.cd_produto = ep.cd_produto)
	left join ecommerce_prd ep2 on (ep2.id_ecommerce = :ps_id_ecommerce
								and ep2.id_rede_filial = ep.id_rede_filial
								and ep2.cd_produto = ep.cd_produto)
	left join ecommerce_prd_filial epf2 on (epf2.id_ecommerce = ep2.id_ecommerce
										and epf2.id_rede_filial = epf.id_rede_filial
										and epf2.cd_filial = epf.cd_filial 
										and epf2.cd_produto  = epf.cd_produto )
where epf.id_ecommerce = '2'
and epf.id_rede_filial = :ps_rede_filial
and epf.cd_filial = :pl_cd_filial_ecommerce
and left(p.de_produto,2) <> 'ZZ' 
and p.cd_grupo_psico is null
and (
	(epf2.dh_atualizacao is null and epf.qt_saldo_filial > 0)
	or ( epf2.dh_atualizacao is not null and epf.dh_atualizacao > epf2.dh_atualizacao )
	)" arguments=(("ps_id_ecommerce", string),("ps_rede_filial", string),("pl_cd_filial_ecommerce", number)) )
