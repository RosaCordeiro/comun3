table(column=(type=char(36) updatewhereclause=yes name=nr_id dbname="nr_id" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=cd_tipo_log dbname="cd_tipo_log" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="dh_inicio" )
 column=(type=long updatewhereclause=yes name=nr_tolerancia dbname="nr_tolerancia" )
 column=(type=char(100) updatewhereclause=yes name=de_processo dbname="de_processo" )
 column=(type=long updatewhereclause=yes name=nr_tempo dbname="nr_tempo" )
 column=(type=char(20) updatewhereclause=yes name=de_host dbname="de_host" )
 column=(type=char(30) updatewhereclause=yes name=de_tipo dbname="de_tipo" )
 column=(type=char(50) updatewhereclause=yes name=de_tarefa dbname="de_tarefa" )
 column=(type=char(1) updatewhereclause=yes name=id_ecommerce dbname="id_ecommerce" )
 column=(type=char(30) updatewhereclause=yes name=nm_ecommerce dbname="nm_ecommerce" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_filial dbname="id_rede_filial" )
 retrieve="Select *
from
(
select el.nr_id, el.cd_filial, el.cd_tipo_log, el.dh_inicio, t.nr_tolerancia/60  as nr_tolerancia, el.de_processo, datediff(mi,el.dh_inicio,getdate( )) as nr_tempo, af.de_host, et.de_tipo, t.de_tarefa, el.id_ecommerce,
	(select ec.nm_ecommerce from ecommerce ec where ec.id_ecommerce = el.id_ecommerce) as nm_ecommerce,
	(select f.id_rede_filial from filial f where f.cd_filial = el.cd_filial) as id_rede_filial
from ecommerce_log_historico el
	inner join ecommerce_log_tipo et on (et.cd_tipo = el.cd_tipo_log)
	left join tarefa t on (t.cd_tipo_log_ecommerce = el.cd_tipo_log and t.id_ecommerce = el.id_ecommerce)
	left join agenda_tarefa af on (af.cd_tarefa = t.cd_tarefa)
where el.dh_termino is null
and el.id_situacao = 'C'
and el.de_processo is not null
and af.de_host = :ps_host
and el.de_host = :ps_host
and t.nr_tolerancia > 0
and t.id_situacao = 'A'
and af.id_situacao = 'A'
) Aux
Where Aux.nr_tempo > Aux.nr_tolerancia" arguments=(("ps_host", string)) )
