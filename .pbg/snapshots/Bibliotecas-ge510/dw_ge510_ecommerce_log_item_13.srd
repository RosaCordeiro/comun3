table(column=(type=long updatewhereclause=yes name=cd_filial dbname="ecommerce_log_item.cd_filial" dbalias="ei.cd_filial" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="ecommerce_log_item.nr_atualizacao" dbalias="ei.nr_atualizacao" )
 column=(type=long updatewhereclause=yes name=nr_item dbname="ecommerce_log_item.nr_item" dbalias="ei.nr_item" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="ecommerce_log_item.cd_fornecedor" dbalias="ei.cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=cd_filial_pedido dbname="ecommerce_log_item.cd_filial_pedido" dbalias="ei.cd_filial_pedido" )
 column=(type=char(20) updatewhereclause=yes name=id_metodo_api dbname="ecommerce_log_item.id_metodo_api" dbalias="ei.id_metodo_api" )
 column=(type=char(32768) updatewhereclause=no name=de_json dbname="ecommerce_log_item.de_json" dbalias="ei.de_json" )
 column=(type=char(255) updatewhereclause=yes name=de_retorno_site dbname="ecommerce_log_item.de_retorno_site" dbalias="ei.de_retorno_site" )
 column=(type=char(255) updatewhereclause=yes name=de_retorno_usuario dbname="ecommerce_log_item.de_retorno_usuario" dbalias="ei.de_retorno_usuario" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 retrieve="  SELECT ei.cd_filial,   
         ei.nr_atualizacao,   
         ei.nr_item,   
        	 ei.cd_fornecedor,
		 ei.cd_filial_pedido,
         ei.id_metodo_api,   
         ei.de_json,   
         ei.de_retorno_site,   
         ei.de_retorno_usuario,
		Case When ( de_retorno_usuario is null or de_retorno_usuario = '' ) Then 'P' Else 'E' End as id_situacao
    FROM ecommerce_log el
		inner join ecommerce_log_item ei on (ei.cd_filial = el.cd_filial
														and ei.nr_atualizacao = el.nr_atualizacao)
Where ei.cd_filial = :pl_cd_filial
	and ei.nr_atualizacao = :pl_nr_atualizacao" arguments=(("pl_cd_filial", number),("pl_nr_atualizacao", number))  sort="nr_item A " )
