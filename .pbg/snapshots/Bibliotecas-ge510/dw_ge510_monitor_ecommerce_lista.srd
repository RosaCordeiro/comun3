table(column=(type=long updatewhereclause=yes name=cd_filial dbname="ecommerce_log.cd_filial" dbalias="el.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="fi.nm_fantasia" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="ecommerce_log.nr_atualizacao" dbalias="el.nr_atualizacao" )
 column=(type=char(1) updatewhereclause=yes name=id_ecommerce dbname="ecommerce_log.id_ecommerce" dbalias="el.id_ecommerce" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_filial dbname="ecommerce_log.id_rede_filial" dbalias="el.id_rede_filial" )
 column=(type=long updatewhereclause=yes name=cd_tipo dbname="ecommerce_log.cd_tipo" dbalias="el.cd_tipo" )
 column=(type=char(30) updatewhereclause=yes name=de_tipo dbname="ecommerce_log_tipo.de_tipo" dbalias="et.de_tipo" )
 column=(type=char(40) updatewhereclause=yes name=cd_chave dbname="ecommerce_log.cd_chave" dbalias="el.cd_chave" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="ecommerce_log.dh_inclusao" dbalias="el.dh_inclusao" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio_envio dbname="ecommerce_log.dh_inicio_envio" dbalias="el.dh_inicio_envio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_envio dbname="ecommerce_log.dh_termino_envio" dbalias="el.dh_termino_envio" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="ecommerce_log.id_situacao" dbalias="el.id_situacao" )
 column=(type=char(255) updatewhereclause=yes name=de_mensagem dbname="ecommerce_log.de_mensagem" dbalias="el.de_mensagem" )
 column=(type=long updatewhereclause=yes name=qt_item_enviado_site dbname="ecommerce_log.qt_item_enviado_site" dbalias="el.qt_item_enviado_site" )
 column=(type=char(1) updatewhereclause=yes name=id_processa dbname="id_processa" values="	S/	N" )
 retrieve="  SELECT el.cd_filial, 
		 fi.nm_fantasia,
         el.nr_atualizacao,   
         el.id_ecommerce,   
         el.id_rede_filial,   
         el.cd_tipo,
		 et.de_tipo,   
         el.cd_chave,   
         el.dh_inclusao,   
         el.dh_inicio_envio,   
         el.dh_termino_envio,   
         el.id_situacao,   
         el.de_mensagem,   
         el.qt_item_enviado_site ,
		'N' as id_processa 
    FROM ecommerce_log el
		left join filial fi on (fi.cd_filial = el.cd_filial)
		inner join ecommerce_log_tipo et on (et.cd_tipo = el.cd_tipo)
"  sort="nr_atualizacao D " )
