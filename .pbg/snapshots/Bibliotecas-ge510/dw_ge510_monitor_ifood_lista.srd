table(column=(type=long updatewhereclause=yes name=cd_filial dbname="ecommerce_log_resumo.cd_filial" dbalias="er.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_tipo_log dbname="ecommerce_log_resumo.cd_tipo_log" dbalias="er.cd_tipo_log" )
 column=(type=char(30) updatewhereclause=yes name=de_tipo dbname="ecommerce_log_tipo.de_tipo" dbalias="et.de_tipo" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="ecommerce_log_resumo.id_situacao" dbalias="er.id_situacao" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao_log dbname="ecommerce_log_resumo.nr_atualizacao_log" dbalias="er.nr_atualizacao_log" )
 retrieve="select er.cd_filial, f.nm_fantasia, er.cd_tipo_log, et.de_tipo, er.id_situacao, er.nr_atualizacao_log
from ecommerce_log_resumo er
    left join filial f on (f.cd_filial = er.cd_filial)
    inner join ecommerce_log_tipo et on (et.cd_tipo = er.cd_tipo_log)
where er.id_ecommerce = :ps_id_ecommerce
and er.cd_tipo_log = :pl_cd_tipo
and (er.cd_tipo_log = 7 or exists (select * from ecommerce_rede_filial ef
							 where ef.cd_filial = er.cd_filial
								and ef.id_ecommerce = er.id_ecommerce
								and ef.id_situacao = 'A') )" arguments=(("ps_id_ecommerce", string),("pl_cd_tipo", number))  sort="id_situacao A cd_filial A " )
