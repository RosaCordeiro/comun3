compute(band=detail alignment="0" expression="Case( cd_tipo_log
When 1 then 'Interface respons$$HEX1$$e100$$ENDHEX$$vel pelo cadastro de marcas'
When 2 then 'Interface respons$$HEX1$$e100$$ENDHEX$$vel pelo cadastro de produtos'
When 3 then 'Interface respons$$HEX1$$e100$$ENDHEX$$vel por atualiza$$HEX2$$e700f500$$ENDHEX$$es no cadastro do produto'
When 4 then 'Interface respons$$HEX1$$e100$$ENDHEX$$vel por atualizar o pre$$HEX1$$e700$$ENDHEX$$o dos produtos'
When 5 then 'Interface respons$$HEX1$$e100$$ENDHEX$$vel por atualizar o saldo dos produtos de acordo com as filiais'
When 6 then 'Interface respons$$HEX1$$e100$$ENDHEX$$vel por atualizar o c$$HEX1$$f300$$ENDHEX$$digo EAN dos produtos'
When 7 then 'Interface respons$$HEX1$$e100$$ENDHEX$$vel por monitorar altera$$HEX2$$e700f500$$ENDHEX$$es de status dos pedidos na plataforma ecommerce'
When 8 then 'Interface respons$$HEX1$$e100$$ENDHEX$$vel por importar os pedidos da plataforma ecommerce para a matriz'
When 9 then 'Interface respons$$HEX1$$e100$$ENDHEX$$vel por enviar os pedidos para as filiais'
When 10 then ''
When 11 then ''
When 12 then '' 
When 13 then 'Interface respons$$HEX1$$e100$$ENDHEX$$vel por monitorar altera$$HEX2$$e700f500$$ENDHEX$$es de status do pedido na matriz/filiais e atualizar na plataforma ecommerce'
When 14 then ''
When 15 then 'Interface respons$$HEX1$$e100$$ENDHEX$$vel por importar informa$$HEX2$$e700f500$$ENDHEX$$es de pagamento dos pedidos da plataforma ecommerce '
When 16 then 'Interface respons$$HEX1$$e100$$ENDHEX$$vel por monitorar as informa$$HEX2$$e700f500$$ENDHEX$$es de rastreamento dos pedidos'
When 17 then ''
When 19 then 'Interface respons$$HEX1$$e100$$ENDHEX$$vel por realizar o cancelamento de pedidos'
When 20 then 'Interface respons$$HEX1$$e100$$ENDHEX$$vel por realizar a devolu$$HEX2$$e700e300$$ENDHEX$$o de pedidos')"border="0" color="0" x="69" y="104" height="52" width="215" format="[GENERAL]" html.valueishtml="0"  name=c_tipo_obs visible="0"  font.face="Verdana" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="16777215" background.transparency="0" background.gradient.color="8421504" background.gradient.transparency="0" background.gradient.angle="0" background.brushmode="0" background.gradient.repetition.mode="0" background.gradient.repetition.count="0" background.gradient.repetition.length="100" background.gradient.focus="0" background.gradient.scale="100" background.gradient.spread="100" tooltip.backcolor="134217752" tooltip.delay.initial="0" tooltip.delay.visible="32000" tooltip.enabled="0" tooltip.hasclosebutton="0" tooltip.icon="0" tooltip.isbubble="0" tooltip.maxwidth="0" tooltip.textcolor="134217751" tooltip.transparency="0" transparency="0" )
