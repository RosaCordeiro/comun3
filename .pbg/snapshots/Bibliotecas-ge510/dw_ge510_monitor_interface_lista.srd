table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=cd_tipo_log dbname="cd_tipo_log" )
 column=(type=char(30) updatewhereclause=yes name=de_tipo dbname="de_tipo" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="dh_termino" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao_log dbname="nr_atualizacao_log" )
 column=(type=long updatewhereclause=yes name=nr_tempo dbname="nr_tempo" )
 column=(type=long updatewhereclause=yes name=cd_tipo_log_tarefa dbname="cd_tipo_log_tarefa" )
 column=(type=char(1) updatewhereclause=yes name=id_utiliza_gototem dbname="id_utiliza_gototem" )
 column=(type=long updatewhereclause=yes name=nr_intervalo_tarefa dbname="nr_intervalo_tarefa" )
 retrieve="
Select Aux.*, (Case ag.id_tipo_intervalo 
		when 'H' then ag.nr_intervalo * 60 
		when 'M' then ag.nr_intervalo
		Else ag.nr_intervalo End) as nr_intervalo_tarefa
from
(
select er.cd_filial, er.cd_tipo_log, 
	et.de_tipo,	
	er.dh_inicio, er.dh_termino, er.id_situacao, er.nr_atualizacao_log,
	datediff(mi,er.dh_inicio,getdate( )) as nr_tempo, 
    ( Case er.cd_tipo_log 
       When 1 then 2 
       When 3 then 2 
       When 8 then 7
       When 9 then 7
       When 15 then 13
       When 16 then 13
       else er.cd_tipo_log end) as cd_tipo_log_tarefa,
	erf.id_utiliza_gototem
from ecommerce_log_resumo er
    inner join ecommerce_log_tipo et on (et.cd_tipo = er.cd_tipo_log)
	inner join ecommerce_rede_filial erf on ( erf.cd_filial = er.cd_filial and erf.id_ecommerce = er.id_ecommerce  ) 
    left join tarefa ta on ( ta.cd_tipo_log_ecommerce = et.cd_tipo and ta.id_ecommerce = er.id_ecommerce and ta.id_situacao = 'A' )
where erf.id_rede_filial = :ps_rede
	and er.id_ecommerce = :ps_id_ecommerce
	and er.cd_tipo_log not in ( 5, 10 )
) Aux inner join tarefa ta on (ta.cd_tipo_log_ecommerce = Aux.cd_tipo_log_tarefa and ta.id_ecommerce = :ps_id_ecommerce)
      inner join agenda_tarefa ag on (ag.cd_tarefa = ta.cd_tarefa)
Where ta.id_situacao = 'A'
and ag.id_situacao = 'A'" arguments=(("ps_rede", string),("ps_id_ecommerce", string))  sort="de_tipo A " )
