table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_filial dbname="id_rede_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_tipo_log dbname="cd_tipo_log" )
 column=(type=char(30) updatewhereclause=yes name=de_tipo dbname="de_tipo" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="dh_termino" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao_log dbname="nr_atualizacao_log" )
 column=(type=long updatewhereclause=yes name=nr_tempo dbname="nr_tempo" )
 column=(type=long updatewhereclause=yes name=cd_tipo_log_tarefa dbname="cd_tipo_log_tarefa" )
 column=(type=decimal(0) updatewhereclause=yes name=cd_grupo dbname="cd_grupo" )
 column=(type=char(7) updatewhereclause=yes name=cd_grupo_execucao_tarefa dbname="cd_grupo_execucao_tarefa" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_intervalo dbname="id_tipo_intervalo" )
 column=(type=long updatewhereclause=yes name=nr_intervalo dbname="nr_intervalo" )
 column=(type=long updatewhereclause=yes name=nr_intervalo_tarefa dbname="nr_intervalo_tarefa" )
 retrieve="Select Aux.*, (Case Aux.id_tipo_intervalo 
		when 'H' then Aux.nr_intervalo * 60 
		when 'M' then Aux.nr_intervalo
		Else Aux.nr_intervalo End) as nr_intervalo_tarefa
from
(
select er.cd_filial, f.id_rede_filial, f.nm_fantasia, er.cd_tipo_log, et.de_tipo, er.dh_inicio, er.dh_termino, er.id_situacao, er.nr_atualizacao_log,
	datediff(mi,er.dh_inicio,getdate( )) as nr_tempo, 
    er.cd_tipo_log as cd_tipo_log_tarefa,
    Cast(right(ta.de_parametro,3) as numeric) as cd_grupo,
    ef.cd_grupo_execucao_tarefa,
    ag.id_tipo_intervalo,
    ag.nr_intervalo
from ecommerce_log_resumo er
    inner join ecommerce_log_tipo et on (et.cd_tipo = er.cd_tipo_log)
    inner join filial f on ( f.cd_filial = er.cd_filial ) 
    inner join ecommerce_rede_filial ef on (ef.id_ecommerce = er.id_ecommerce and ef.cd_filial = er.cd_filial and ef.id_rede_filial = f.id_rede_filial and ef.id_situacao = 'A')
    inner join tarefa ta on ( ta.cd_tipo_log_ecommerce = et.cd_tipo and ta.id_ecommerce = er.id_ecommerce and ta.id_situacao = 'A' and convert(int, ef.cd_grupo_execucao_tarefa) = convert(int, right(ta.de_parametro,3)) )
    inner join agenda_tarefa ag on (ag.cd_tarefa = ta.cd_tarefa)
where  er.id_ecommerce = :ps_id_ecommerce
    and er.cd_tipo_log = 5
    and ta.id_situacao = 'A'
    and ag.id_situacao = 'A'
) Aux " arguments=(("ps_id_ecommerce", string))  sort="cd_filial A " )
