table(column=(type=char(2) updatewhereclause=yes name=cd_canal_venda dbname="resumo_venda_canal.cd_canal_venda" dbalias="r.cd_canal_venda" )
 column=(type=char(8) updatewhereclause=yes name=desc_modo_entrega dbname="desc_modo_entrega" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda dbname="vl_venda" )
 column=(type=long updatewhereclause=yes name=qtd_cliente dbname="qtd_cliente" )
 retrieve="select  r.cd_canal_venda,		
		case when r.cd_tipo_entrega <> 1 Then 'ENTREGA' ELSE 'RETIRADA' end as desc_modo_entrega,	
		coalesce(sum(r.vl_venda_avista + r.vl_venda_cartao_debito + r.vl_venda_cheque_avista + r.vl_venda_crediario + r.vl_venda_convenio + r.vl_venda_conta_corrente + r.vl_venda_cartao_credito + r.vl_venda_cheque_aprazo - r.vl_devolucao_venda),0) as vl_venda,
         coalesce(sum(r.qt_cliente_venda - r.qt_cliente_devolucao),0) as qtd_cliente         
From  resumo_venda_canal r
inner join filial f on f.cd_filial  =  r.cd_filial 
inner join tipo_entrega_ecommerce t on t.cd_tipo_entrega = r.cd_tipo_entrega
where  r.dh_resumo  between :dt_inicio and :dt_fim
group by r.cd_canal_venda, 
			case when r.cd_tipo_entrega <> 1 Then 'ENTREGA' ELSE 'RETIRADA' end 
      " arguments=(("dt_inicio", date),("dt_fim", date))  sort="cd_canal_venda A " )
