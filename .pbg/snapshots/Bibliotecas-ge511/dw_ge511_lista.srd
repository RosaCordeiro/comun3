table(column=(type=char(2) updatewhereclause=yes key=yes name=cd_canal_venda dbname="canal_venda.cd_canal_venda" dbalias="a.cd_canal_venda" )
 column=(type=char(30) updatewhereclause=yes name=de_canal_venda dbname="canal_venda.de_canal_venda" dbalias="a.de_canal_venda" )
 column=(type=char(8) updatewhereclause=yes name=desc_modo_entrega dbname="desc_modo_entrega" )
 column=(type=decimal(2) updatewhereclause=yes name=vlr_dia dbname="Vlr_dia" )
 column=(type=long updatewhereclause=yes name=qtd_cliente_dia dbname="Qtd_cliente_dia" )
 column=(type=decimal(2) updatewhereclause=yes name=part_dia dbname="Part_Dia" )
 column=(type=decimal(2) updatewhereclause=yes name=evo_dia dbname="Evo_Dia" )
 column=(type=decimal(2) updatewhereclause=yes name=vlr_mes dbname="Vlr_mes" )
 column=(type=long updatewhereclause=yes name=qtd_cliente_mes dbname="Qtd_cliente_mes" )
 column=(type=decimal(2) updatewhereclause=yes name=part_mes dbname="Part_Mes" )
 column=(type=decimal(2) updatewhereclause=yes name=evo_mes dbname="Evo_Mes" )
 column=(type=decimal(2) updatewhereclause=yes name=vlr_ano dbname="Vlr_ano" )
 column=(type=long updatewhereclause=yes name=qtd_cliente_ano dbname="Qtd_cliente_ano" )
 column=(type=decimal(2) updatewhereclause=yes name=part_ano dbname="Part_Ano" )
 column=(type=decimal(2) updatewhereclause=yes name=evo_ano dbname="Evo_Ano" )
 column=(type=decimal(2) updatewhereclause=yes name=vlr_ano_anterior dbname="Vlr_ano_anterior" )
 column=(type=decimal(2) updatewhereclause=yes name=vlr_ano_dia_anterior dbname="Vlr_ano_dia_anterior" )
 column=(type=decimal(2) updatewhereclause=yes name=vlr_ano_mes_anterior dbname="Vlr_ano_mes_anterior" )
 column=(type=long updatewhereclause=yes name=nr_mes dbname="Nr_mes" )
 column=(type=long updatewhereclause=yes name=nr_dia dbname="Nr_dia" )
 column=(type=long updatewhereclause=yes name=nr_ano dbname="Nr_ano" )
 column=(type=char(1) updatewhereclause=yes name=nm_mes dbname="Nm_mes" )
 retrieve="select 
	  a.cd_canal_venda, 
	  a.de_canal_venda, 
      'ENTREGA'  as desc_modo_entrega, 
	   0.00 Vlr_dia,     
	   0 as Qtd_cliente_dia,	
	   0.00 Part_Dia,	 
	   0.00 Evo_Dia,	
       0.00 Vlr_mes,     
	   0 as Qtd_cliente_mes,
       0.00 Part_Mes,
	  0.00 Evo_Mes,
      0.00 Vlr_ano,      
  	  0 as Qtd_cliente_ano,
  	  0.00 Part_Ano,
	  0.00 Evo_Ano,
	  0.00 Vlr_ano_anterior,
  	  0.00 Vlr_ano_dia_anterior,
   	  0.00 Vlr_ano_mes_anterior,     
	  0 as Nr_mes,
	  0 as Nr_dia,
	  0 as Nr_ano,
	  '' as Nm_mes
From canal_venda a
where coalesce(id_situacao, 'A') = 'A'
UNION ALL 
select 
	  a.cd_canal_venda, 
	  a.de_canal_venda, 
      'RETIRADA'  as desc_modo_entrega,       
      0.00 Vlr_dia,     
	   0 as Qtd_cliente_dia,	
	   0.00 Part_Dia,	 
	   0.00 Evo_Dia,	 
       0.00 Vlr_mes,     
	   0 as Qtd_cliente_mes,
       0.00 Part_Mes,
	  0.00 Evo_Mes,
      0.00 Vlr_ano,      
  	  0 as Qtd_cliente_ano,
  	  0.00 Part_Ano,
	  0.00 Evo_Ano,
	  0.00 Vlr_ano_anterior,
  	  0.00 Vlr_ano_dia_anterior,
   	  0.00 Vlr_ano_mes_anterior,     
	  0 as Nr_mes,
	  0 as Nr_dia,
	  0 as Nr_ano,
	  '' as Nm_mes	
From canal_venda a
where coalesce(id_situacao, 'A') = 'A'

" update="canal_venda" updatewhere=0 updatekeyinplace=no  sort="cd_canal_venda A desc_modo_entrega A " )
