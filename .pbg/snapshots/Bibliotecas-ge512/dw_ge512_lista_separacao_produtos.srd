table(column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="wms_lista_separacao_produto.cd_endereco" dbalias="pp.cd_endereco" )
 column=(type=long updatewhereclause=yes name=qtd dbname="wms_lista_separacao_produto.qtd" dbalias="pp.qtd" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_lista_separacao_produto.cd_produto" dbalias="pp.cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=ean dbname="produto_geral.ean" dbalias="pg.ean" )
 column=(type=char(103) updatewhereclause=yes name=descricao dbname="descricao" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_distribuidora.nr_pedido" dbalias="p.nr_pedido" )
 column=(type=long updatewhereclause=yes name=nr_volume dbname="wms_lista_separacao.nr_volume" dbalias="s.nr_volume" )
 column=(type=char(1) updatewhereclause=yes name=id_vigiado dbname="id_vigiado" )
 column=(type=char(6) updatewhereclause=yes name=de_endereco_flow_rack dbname="vw_wms_endereco.de_endereco_flow_rack" dbalias="vw.de_endereco_flow_rack" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" dbalias="pg.cd_grupo_psico" )
 retrieve="Select  pp.cd_endereco_localizacao as cd_endereco,
        pp.qt_pedida as qtd,    
        pp.cd_produto as cd_produto, 
        pg.de_codigo_barras as ean,        
        (pg.de_produto + ' : ' +  pg.de_apresentacao_estoque) as descricao,
	     p.nr_pedido_distribuidora as nr_pedido,
	     s.nr_volume, 
		coalesce(pc.id_vigiado, 'N') as id_vigiado	,
		vw.de_endereco_flow_rack,
		pg.cd_grupo_psico
From pedido_distribuidora p
Inner join wms_lista_separacao	s 	 on s.cd_filial					= p.cd_filial
 	and s.nr_pedido_distribuidora = p.nr_pedido_distribuidora
Inner join wms_lista_separacao_produto pp on  pp.cd_filial 					= s.cd_filial 
	and pp.nr_pedido_distribuidora  = s.nr_pedido_distribuidora
	and pp.nr_volume						= s.nr_volume
Inner join  wms_esteira	e	on e.cd_esteira	= s.cd_esteira
Inner join  produto_geral pg on pg.cd_produto  = pp.cd_produto
Inner join produto_central pc on pc.cd_produto = pg.cd_produto
Inner join  vw_wms_endereco vw on vw.cd_endereco  = pp.cd_endereco_localizacao
Where   p.cd_distribuidora				= '053404705'
   and s.cd_tipo_volume = 1
   and pp.qt_pedida >0
   and s.dh_cancelamento is null
   and s.dh_exportacao is null      /// integracao -  exportacao   
   and e.id_utiliza_pick_light = 'S'     /// configuracao
	and p.cd_filial =:al_filial
	and p.nr_pedido_distribuidora  =:al_pedido
	and s.nr_volume  =:al_volume
order by pp.cd_endereco_localizacao


" arguments=(("al_filial", number),("al_pedido", number),("al_volume", number)) )
