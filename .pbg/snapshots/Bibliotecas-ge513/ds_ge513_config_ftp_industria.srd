 retrieve="Select cd_exportacao,   
         de_endereco_ftp,   
         de_usuario_ftp,   
         de_senha_ftp,   
         dh_ultima_exportacao,   
         nr_ultimo_seq_arquivo,   
         id_periodicidade,
		coalesce(id_envia_arquivo_ftp, 'N') id_envia_arquivo_ftp,
		coalesce(id_protocolo_sftp, 'N') id_protocolo_sftp
From controle_exportacao_arquivos  
where cd_exportacao = :ps_Processo
" update="controle_exportacao_arquivos" updatewhere=1 updatekeyinplace=no arguments=(("ps_processo", string)) )
