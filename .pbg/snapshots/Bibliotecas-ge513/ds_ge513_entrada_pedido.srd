table(column=(type=char(7) updatewhereclause=yes name=cd_tipo dbname="cd_tipo" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="nr_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_pedido dbname="dh_pedido" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=datetime updatewhereclause=yes name=dh_entrada dbname="dh_entrada" )
 column=(type=char(14) updatewhereclause=yes name=cnpj_solic dbname="cnpj_solic" )
 column=(type=char(14) updatewhereclause=yes name=cnpj_forn dbname="cnpj_forn" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="de_chave_acesso" )
 column=(type=char(1) updatewhereclause=yes name=id_pbm dbname="id_pbm" )
 retrieve="select tudo.cd_tipo, 
		tudo.cd_filial, 
		tudo.nr_pedido, 
		tudo.dh_pedido, 
		tudo.id_situacao,  
		tudo.dh_entrada, 
		tudo.cnpj_solic, 
		cnpj_forn,
		tudo.de_chave_acesso,
		tudo.id_pbm		  
from 
(
	select 	distinct n.cd_filial, 
				pc.nr_pedido, 
				pc.dh_pedido,
				pc.id_situacao,
				n.dh_movimentacao_caixa dh_entrada,
				fi.nr_cgc cnpj_solic,
				fo.nr_cgc cnpj_forn,
				'PEDCENT' cd_tipo,
				n.de_chave_acesso,
				coalesce(pc.id_pbm, 'N') id_pbm
	from nf_compra n
	inner join pedido_central pc
		on pc.nr_pedido = n.nr_pedido_central
	inner join filial fi
		on fi.cd_filial = n.cd_filial
	inner join fornecedor fo
		on fo.cd_fornecedor = n.cd_fornecedor
	where dh_movimentacao_caixa = :data_movto
	  and n.cd_filial = :filial
	
	union
	
	select 	distinct n.cd_filial, 
				pd.nr_pedido_distribuidora nr_pedido, 
				pd.dh_emissao dh_pedido,
				pd.id_situacao,
				n.dh_movimentacao_caixa dh_entrada,
				fi.nr_cgc cnpj_solic,
				fo.nr_cgc cnpj_forn,
				'PEDDIST' cd_tipo,
				n.de_chave_acesso,
				'N' id_pbm
	from nf_compra n
	inner join pedido_distribuidora pd
		on pd.cd_filial = n.cd_filial
		and pd.nr_pedido_distribuidora = n.nr_pedido_distribuidora
	inner join filial fi
		on fi.cd_filial = n.cd_filial
	inner join fornecedor fo
		on fo.cd_fornecedor = n.cd_fornecedor
	where dh_movimentacao_caixa = :data_movto
	  and n.cd_filial = :filial
) as tudo
order by tudo.cd_tipo" arguments=(("data_movto", date),("filial", number)) )
