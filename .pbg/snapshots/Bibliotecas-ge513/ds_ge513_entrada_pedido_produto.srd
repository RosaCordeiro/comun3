table(column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" dbalias="g.de_codigo_barras" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_compra.cd_produto" dbalias="i.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 retrieve="select  g.de_codigo_barras,
		 i.cd_produto,
		 g.de_produto + ' : ' + de_apresentacao_venda de_produto,
		 sum((CASE WHEN n.cd_filial = 534 THEN (i.qt_faturada * g.vl_fator_conversao) ELSE  i.qt_faturada END)) qt_faturada
from nf_compra n
inner join item_nf_compra i
	on i.cd_filial = n.cd_filial
	and i.cd_fornecedor = n.cd_fornecedor
	and i.nr_nf		= n.nr_nf
	and i.de_especie  = n.de_especie
	and i.de_serie	 = n.de_serie
inner join produto_geral g
	on g.cd_produto = i.cd_produto 
inner join pedido_central p 
	on p.nr_pedido  = n.nr_pedido_central	
where n.cd_filial = :filial
  and p.nr_pedido = :pedido
  and n.dh_movimentacao_caixa = :data_movto
  and :tipo_pedido = 'PEDCENT'
group by g.de_codigo_barras,
		 	i.cd_produto,
		 	g.de_produto + ' : ' + de_apresentacao_venda

union

select  g.de_codigo_barras,
		 i.cd_produto,
		 g.de_produto + ' : ' + de_apresentacao_venda de_produto,
		 sum((CASE WHEN n.cd_filial = 534 THEN (i.qt_faturada * g.vl_fator_conversao) ELSE  i.qt_faturada END)) qt_faturada
from nf_compra n
inner join item_nf_compra i
	on i.cd_filial = n.cd_filial
	and i.cd_fornecedor = n.cd_fornecedor
	and i.nr_nf		= n.nr_nf
	and i.de_especie  = n.de_especie
	and i.de_serie	 = n.de_serie
inner join produto_geral g
	on g.cd_produto = i.cd_produto 
inner join pedido_distribuidora p 
	on p.cd_filial = n.cd_filial
	and p.nr_pedido_distribuidora  = n.nr_pedido_distribuidora
where n.cd_filial = :filial
  and p.nr_pedido_distribuidora = :pedido
  and n.dh_movimentacao_caixa = :data_movto
  and :tipo_pedido = 'PEDDIST'
group by g.de_codigo_barras,
		 	i.cd_produto,
		 	g.de_produto + ' : ' + de_apresentacao_venda
	" arguments=(("filial", number),("pedido", number),("data_movto", date),("tipo_pedido", string)) )
