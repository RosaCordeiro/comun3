table(column=(type=long updatewhereclause=yes name=cd_produto dbname="saldo_produto.cd_produto" dbalias="s.cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" dbalias="g.de_codigo_barras" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_saldo_original dbname="saldo_produto.qt_saldo_original" dbalias="s.qt_saldo_original" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="g.vl_fator_conversao" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_saldo_final dbname="qt_saldo_final" )
 column=(type=datetime updatewhereclause=yes name=dh_ultimo_movimento dbname="saldo_produto.dh_ultimo_movimento" dbalias=".dh_ultimo_movimento" )
 column=(type=long updatewhereclause=yes name=tamanhoean dbname="TamanhoEan" )
 retrieve="select 	s.cd_produto, 
			g.de_codigo_barras, 
			g.de_produto + ' : ' + de_apresentacao_venda de_produto,
			s.qt_saldo_final qt_saldo_original,
			g.vl_fator_conversao,
			(CASE WHEN s.cd_filial = 534 THEN s.qt_saldo_final * g.vl_fator_conversao ELSE  s.qt_saldo_final END) qt_saldo_final,
			dh_ultimo_movimento,
			Len(g.de_codigo_barras) as TamanhoEan			
from saldo_produto s
Inner join produto_geral g
	on g.cd_produto = s.cd_produto
where s.cd_filial in (:pl_cd_filial)
  and s.dh_saldo = :pdt_saldo
  and s.qt_saldo_final > 0
  and g.cd_grupo_produto <> 5 -- Retirado Grupo Almox.  
  and g.cd_produto not in (723786,711392,711451,711466) --- Retirado os produtos Chamado:1306276
order by g.de_produto, de_apresentacao_venda


" arguments=(("pl_cd_filial", number),("pdt_saldo", date))  sort="cd_produto A " )
