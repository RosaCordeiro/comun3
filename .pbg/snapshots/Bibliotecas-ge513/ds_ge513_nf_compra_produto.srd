table(column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="fornecedor.nr_cgc" dbalias="fo.nr_cgc" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(1) updatewhereclause=yes name=flag dbname="flag" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_compra.cd_produto" dbalias="i.cd_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_faturada dbname="item_nf_compra.qt_faturada" dbalias="i.qt_faturada" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_compra.vl_preco_unitario" dbalias="i.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="item_nf_compra.pc_icms" dbalias="i.pc_icms" )
 column=(type=decimal(19) updatewhereclause=yes name=vl_icms dbname="vl_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="item_nf_compra.pc_desconto" dbalias="i.pc_desconto" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_desconto dbname="vl_desconto" )
 column=(type=char(2) updatewhereclause=yes name=uf_fornecedor dbname="cidade.UF_Fornecedor" dbalias="cfo.UF_Fornecedor" )
 column=(type=char(2) updatewhereclause=yes name=uf_loja dbname="cidade.UF_Loja" dbalias="fcid.UF_Loja" )
 retrieve="select  n.dh_movimentacao_caixa, 
		 fo.nr_cgc,
		 n.nr_nf,
		 (CASE i.cd_situacao_tributaria
		 	/*ICMS NORMAL*/		WHEN '00' THEN '1' 
			/*ICMS NORMAL RED*/	WHEN '02' THEN '1' 
			/*ISENTO*/					WHEN '04' THEN '1'
											WHEN '05' THEN '1'
											WHEN '51' THEN '1'
			/*ST PG ANTERIOMTE*/	WHEN '06' THEN '2' 
			/*ST*/						WHEN '01' THEN '3' 
											WHEN '03' THEN '3' 
											WHEN '31' THEN '3' 
			/*ST REDUZIDA*/			WHEN '07' THEN '3' 
			ELSE '9'
		 END) flag,
		 i.cd_produto,
		 i.qt_faturada,
		 i.vl_preco_unitario,
		 i.pc_icms,
		 round(i.vl_icms, 2) vl_icms,
		 i.pc_desconto,
		 round(i.vl_preco_unitario * (coalesce(i.pc_desconto, 0) / 100), 2) vl_desconto,
          cfo.cd_unidade_federacao as UF_Fornecedor,
		 fcid.cd_unidade_federacao as UF_Loja
from nf_compra n (index idx_filial_data_movimento)
inner join item_nf_compra i
	on i.cd_filial = n.cd_filial
	and i.cd_fornecedor = n.cd_fornecedor
	and i.nr_nf		= n.nr_nf
	and i.de_especie = n.de_especie
	and i.de_serie	= n.de_serie
inner join fornecedor fo
	on fo.cd_fornecedor = n.cd_fornecedor
inner join cidade cfo on cfo.cd_cidade  = fo.cd_cidade 
inner join filial f on f.cd_filial  =  n.cd_filial
inner join cidade fcid on fcid.cd_cidade  = f.cd_cidade 
where n.cd_filial =  :pl_cd_filial
   and n.dh_movimentacao_caixa = :pdh_movimento
   and n.cd_filial <> 534 
   and coalesce(fo.id_uso_consumo, 'N') = 'N'

union all

select n.dh_movimentacao_caixa,
		 fo.nr_cgc,
		 n.nr_nf,
		 (CASE i.cd_situacao_tributaria
		 	/*ICMS NORMAL*/		WHEN '00' THEN '1' 
			/*ICMS NORMAL RED*/	WHEN '02' THEN '1' 
			/*ISENTO*/					WHEN '04' THEN '1'
											WHEN '05' THEN '1'
											WHEN '51' THEN '1'
			/*ST PG ANTERIOMTE*/	WHEN '06' THEN '2' 
			/*ST*/						WHEN '01' THEN '3' 
											WHEN '03' THEN '3' 
											WHEN '31' THEN '3' 
			/*ST REDUZIDA*/			WHEN '07' THEN '3' 
			ELSE '9'
		 END) flag,
		 i.cd_produto,
		 i.qt_transferida * g.vl_fator_conversao qt_transferida,
		 round(i.vl_custo_unitario / g.vl_fator_conversao, 2) vl_custo_unitario,
		 i.pc_icms,
		 round(i.vl_icms / ( i.qt_transferida * g.vl_fator_conversao) , 2) vl_icms,
		 0 pc_desconto,
		 0 vl_desconto,
          cfo.cd_unidade_federacao as UF_Fornecedor,
		 fcid.cd_unidade_federacao as UF_Loja
from nf_transferencia n (index idx_data_filial_destino)
inner join item_nf_transferencia i
	on i.cd_filial_origem = n.cd_filial_origem
  and i.nr_nf	= n.nr_nf
  and i.de_especie = n.de_especie
  and i.de_serie = n.de_serie
inner join filial fo
	on fo.cd_filial = n.cd_filial_origem
inner join cidade cfo on cfo.cd_cidade  = fo.cd_cidade 
inner join filial f on f.cd_filial  =  n.cd_filial_destino
inner join cidade fcid on fcid.cd_cidade  = f.cd_cidade
inner join produto_geral g
	on g.cd_produto = i.cd_produto
where n.cd_filial_origem = 534
   and n.dh_movimentacao_caixa = :pdh_movimento
   and n.cd_filial_destino = :pl_cd_filial
   and coalesce(n.id_almoxarifado, 'N') = 'N'  " arguments=(("pdh_movimento", date),("pl_cd_filial", number)) )
