HA$PBExportHeader$ds_ge513_nf_venda_produto.srd
release 12;
datawindow(units=0 timer_interval=0 color=1073741824 brushmode=0 transparency=0 gradient.angle=0 gradient.color=8421504 gradient.focus=0 gradient.repetition.count=0 gradient.repetition.length=100 gradient.repetition.mode=0 gradient.scale=100 gradient.spread=100 gradient.transparency=0 picture.blur=0 picture.clip.bottom=0 picture.clip.left=0 picture.clip.right=0 picture.clip.top=0 picture.mode=0 picture.scale.x=100 picture.scale.y=100 picture.transparency=0 processing=0 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.background=no print.preview.background=no print.preview.outline=yes hidegrayline=no showbackcoloronxp=no picture.file="" )
header(height=0 color="536870912" transparency="0" gradient.color="8421504" gradient.transparency="0" gradient.angle="0" brushmode="0" gradient.repetition.mode="0" gradient.repetition.count="0" gradient.repetition.length="100" gradient.focus="0" gradient.scale="100" gradient.spread="100" )
summary(height=0 color="536870912" transparency="0" gradient.color="8421504" gradient.transparency="0" gradient.angle="0" brushmode="0" gradient.repetition.mode="0" gradient.repetition.count="0" gradient.repetition.length="100" gradient.focus="0" gradient.scale="100" gradient.spread="100" )
footer(height=0 color="536870912" transparency="0" gradient.color="8421504" gradient.transparency="0" gradient.angle="0" brushmode="0" gradient.repetition.mode="0" gradient.repetition.count="0" gradient.repetition.length="100" gradient.focus="0" gradient.scale="100" gradient.spread="100" )
detail(height=824 color="536870912" transparency="0" gradient.color="8421504" gradient.transparency="0" gradient.angle="0" brushmode="0" gradient.repetition.mode="0" gradient.repetition.count="0" gradient.repetition.length="100" gradient.focus="0" gradient.scale="100" gradient.spread="100" )
table(column=(type=datetime updatewhereclause=yes name=dh_transacao dbname="dh_transacao" )
 column=(type=char(20) updatewhereclause=yes name=ean1 dbname="produto_geral.EAN1" dbalias="g.EAN1" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="g.cd_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_bruto dbname="item_nf_venda.vl_preco_bruto" dbalias="i.vl_preco_bruto" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_liquido dbname="vl_liquido" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="qt_vendida" )
 retrieve="select n.dh_movimentacao_caixa as dh_transacao, 
		g.de_codigo_barras as EAN1,
		g.de_produto + ' : ' + de_apresentacao_venda as de_produto, 
		g.cd_produto,
		i.vl_preco_unitario as vl_preco_bruto,
		round(i.vl_preco_praticado * (100 - coalesce(pc_desconto, 0)) / 100, 2) as vl_liquido,  
		sum(i.qt_vendida) as qt_vendida			
from nf_venda n (index idx_data_filial)
inner join item_nf_venda i
	on i.cd_filial = n.cd_filial
	and i.nr_nf	= n.nr_nf
	and i.de_especie = n.de_especie
	and i.de_serie	= n.de_serie
inner join produto_geral g
	on g.cd_produto = i.cd_produto
where n.dh_movimentacao_caixa = :pdh_movimento
  and n.dh_cancelamento is Null 
  and n.nr_nf_anexa is Null 
  and n.cd_filial = :pl_cd_filial
and g.cd_grupo_produto <> 8
group by n.dh_movimentacao_caixa, 
			g.de_codigo_barras,
			g.de_produto,
			g.cd_produto,
			g.de_apresentacao_venda, 
			i.vl_preco_unitario,
			round(i.vl_preco_praticado * (100 - coalesce(pc_desconto, 0)) / 100, 2)
order by g.de_produto, g.de_apresentacao_venda" arguments=(("pdh_movimento", date),("pl_cd_filial", number)) )
htmltable(border="1" )
