table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="nr_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_previsao_entrega dbname="dh_previsao_entrega" )
 column=(type=char(14) updatewhereclause=yes name=cnpj_solic dbname="cnpj_solic" )
 column=(type=char(14) updatewhereclause=yes name=cnpj_forn dbname="cnpj_forn" )
 column=(type=char(3) updatewhereclause=yes name=tipo_estab dbname="tipo_estab" )
 column=(type=long updatewhereclause=yes name=tipo_pedido dbname="tipo_pedido" )
 column=(type=char(7) updatewhereclause=yes name=cd_tipo dbname="cd_tipo" )
 column=(type=char(1) updatewhereclause=yes name=id_pbm dbname="id_pbm" )
 retrieve="select tudo.cd_filial, 
		tudo.nr_pedido, 
		tudo.dh_emissao, 
		tudo.dh_previsao_entrega, 
		tudo.cnpj_solic,
		tudo.cnpj_forn,
		tudo.tipo_estab,
		tudo.tipo_pedido,
		tudo.cd_tipo	,
		tudo.id_pbm	 
from 
(
	select 	p.cd_filial, 
				p.nr_pedido_distribuidora nr_pedido, 
				p.dh_emissao, 
				dateadd(day, 1, p.dh_emissao) dh_previsao_entrega,
				f.nr_cgc cnpj_solic,
				fo.nr_cgc cnpj_forn,
				'PDV' tipo_estab,
				1 tipo_pedido,
				'PEDDIST' cd_tipo,
			    'N' id_pbm
	from pedido_distribuidora p
	inner join filial f
		on f.cd_filial = p.cd_filial
	inner join fornecedor fo
		on fo.cd_fornecedor = p.cd_distribuidora
	where p.dh_emissao = :pdt_data
	  and p.id_situacao not in ('N', 'X', 'J')
	  and coalesce(p.id_pedido_almoxarifado, 'N') = 'N'
	  and p.cd_filial <> 534
	
	union
	
	select p.cd_filial, 
			 p.nr_pedido nr_pedido, 
			 p.dh_pedido, 
			 p.dh_previsao_entrega,
			 f.nr_cgc cnpj_solic,
			 fo.nr_cgc cnpj_forn,
			 (CASE WHEN p.cd_filial = 534 THEN 'CD' ELSE 'PDV' END) tipo_estab,
			 (CASE WHEN p.cd_filial = 534 THEN  2 ELSE 1 END) tipo_pedido,
			 'PEDCENT' cd_tipo,
			coalesce(p.id_pbm, 'N') id_pbm
	from pedido_central p
	inner join filial f 
		on f.cd_filial = p.cd_filial
	inner join fornecedor fo
		on fo.cd_fornecedor = p.cd_fornecedor
	where p.dh_pedido = :pdt_data
		and p.id_situacao <> 'X'
) as tudo
Where ( 
			( :pl_cd_filial = 0 and tudo.cd_filial not in (534, 1, 2) ) 
		or ( :pl_cd_filial = tudo.cd_filial )
		) 
order by tudo.cd_filial, tudo.nr_pedido" arguments=(("pdt_data", date),("pl_cd_filial", number)) )
