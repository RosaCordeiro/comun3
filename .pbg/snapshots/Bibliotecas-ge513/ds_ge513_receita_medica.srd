table(column=(type=datetime updatewhereclause=yes name=dh_receita dbname="dh_receita" )
 column=(type=char(1) updatewhereclause=yes name=id_registro_prescritor dbname="id_registro_prescritor" )
 column=(type=char(8) updatewhereclause=yes name=nr_registro_prescritor dbname="nr_registro_prescritor" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf_prescritor dbname="cd_uf_prescritor" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=long updatewhereclause=yes name=nr_nsr dbname="nr_nsr" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="qt_vendida" )
 column=(type=char(60) updatewhereclause=yes name=produto_geral_de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="de_apresentacao_venda" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="de_codigo_barras" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="id_lei_generico" )
 column=(type=long updatewhereclause=yes name=cd_cidade dbname="cd_cidade" )
 column=(type=char(1) updatewhereclause=yes name=id_produto_substituido dbname="id_produto_substituido" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="nr_cgc" )
 retrieve="  SELECT nf_venda.dh_movimentacao_caixa as dh_receita,   
         receita.id_registro_prescritor,   
         receita.nr_registro_prescritor,   
         receita.cd_uf_prescritor,   
         receita.id_situacao,   
         receita.cd_filial,   
         receita.nr_nf,   
         receita.de_especie,   
         receita.de_serie,   
         receita.nr_nsr,   
         receita_produto.cd_produto,   
         receita_produto.qt_vendida,   
         produto_geral.de_produto,   
         produto_geral.de_apresentacao_venda,   
         produto_geral.de_codigo_barras,   
         produto_central.id_lei_generico,   
         filial.cd_cidade,   
         receita.id_produto_substituido ,
         filial.nr_cgc
    FROM receita,   
         receita_produto,   
         produto_geral,   
         produto_central,   
         filial,
			nf_venda
   WHERE ( receita.nr_nf = nf_venda.nr_nf ) and
			( receita.cd_filial = nf_venda.cd_filial ) and
			( receita.de_serie = nf_venda.de_serie ) and
			( receita.de_especie = nf_venda.de_especie ) and
			( receita.nr_receita = receita_produto.nr_receita ) and
         ( receita.cd_filial  = receita_produto.cd_filial  ) and
         ( receita.id_registro_prescritor = 'M' ) and
         ( receita_produto.cd_produto = produto_geral.cd_produto ) and
         ( produto_central.cd_produto = produto_geral.cd_produto ) and
         ( produto_geral.id_situacao = 'A' ) and
         ( filial.cd_filial = receita.cd_filial ) and
         ( nf_venda.dh_movimentacao_caixa between :pd_periodo_de and :pd_periodo_ate ) and
		len(cast(cast(receita.nr_registro_prescritor as dec) as varchar)) < 8" arguments=(("pd_periodo_de", date),("pd_periodo_ate", date))  sort="cd_filial A dh_receita A nr_nf A " )
