table(column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(2) updatewhereclause=yes name=cd_caixa dbname="cd_caixa" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_venda_nfe.de_chave_acesso" dbalias="e.de_chave_acesso" )
 column=(type=char(2) updatewhereclause=yes name=cd_canal_venda dbname="cd_canal_venda" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_liquido dbname="vl_total_liquido" )
 column=(type=char(2) updatewhereclause=yes name=cd_forma_pagamento dbname="cd_forma_pagamento" )
 retrieve="select n.nr_nf, 
	n.de_serie,
	n.de_especie,
	right(n.cd_caixa,2) as cd_caixa,
	e.de_chave_acesso,
	n.cd_canal_venda,
	---n.dh_emissao, 
	case when cast(n.dh_emissao as date) > cast(n.dh_movimentacao_caixa as date) then n.dh_movimentacao_caixa else n.dh_emissao end  as dh_emissao,   
	n.vl_total_nf as vl_total_liquido,
	n.cd_forma_pagamento
from nf_venda n (index idx_data_filial)
left outer join nf_venda_nfe e
	on e.cd_filial = n.cd_filial
	and e.nr_nf	= n.nr_nf
	and e.de_especie = n.de_especie
	and e.de_serie = n.de_serie
where n.dh_movimentacao_caixa = :pdt_movimento
  and n.dh_cancelamento is Null 
  and n.nr_nf_anexa is Null 
  and n.cd_filial = :pl_cd_filial

" arguments=(("pdt_movimento", date),("pl_cd_filial", number)) )
