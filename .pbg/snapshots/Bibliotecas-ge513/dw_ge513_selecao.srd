 column=(type=char(1) updatewhereclause=yes name=id_check dbname="id_check" values="	S/	N" )
 retrieve="Select cd_exportacao,   
         de_endereco_ftp,   
         de_usuario_ftp,   
         de_senha_ftp,   
         dh_ultima_exportacao,   
         nr_ultimo_seq_arquivo,   
         id_periodicidade,
         id_situacao,
         de_exportacao, 
		Case id_situacao when 'A' then 'S' else 'N' End as id_check
From controle_exportacao_arquivos  
where id_situacao = 'A'" update="controle_exportacao_arquivos" updatewhere=1 updatekeyinplace=no )
