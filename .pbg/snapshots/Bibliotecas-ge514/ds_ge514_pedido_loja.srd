table(column=(type=long updatewhereclause=yes name=cd_filial_ecommerce dbname="pedido_ecommerce.cd_filial_ecommerce" dbalias="pe.cd_filial_ecommerce" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_ecommerce.nr_pedido" dbalias="pe.nr_pedido" )
 column=(type=char(20) updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_ecommerce.nr_pedido_ecommerce" dbalias="pe.nr_pedido_ecommerce" )
 column=(type=datetime updatewhereclause=yes name=dh_compra dbname="pedido_ecommerce.dh_compra" dbalias="pe.dh_compra" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao dbname="pedido_ecommerce.dh_atualizacao" dbalias="pe.dh_atualizacao" )
 column=(type=char(9) updatewhereclause=yes name=id_situacao dbname="pedido_ecommerce.id_situacao" dbalias="pe.id_situacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_subtotal dbname="pedido_ecommerce.vl_subtotal" dbalias="pe.vl_subtotal" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total dbname="pedido_ecommerce.vl_total" dbalias="pe.vl_total" )
 column=(type=long updatewhereclause=yes name=nr_parcelas dbname="pedido_ecommerce.nr_parcelas" dbalias="pe.nr_parcelas" )
 column=(type=char(50) updatewhereclause=yes name=cd_tipo_pagamento dbname="pedido_ecommerce.cd_tipo_pagamento" dbalias="pe.cd_tipo_pagamento" )
 column=(type=char(50) updatewhereclause=yes name=cd_forma_pagamento dbname="pedido_ecommerce.cd_forma_pagamento" dbalias="pe.cd_forma_pagamento" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_ecommerce.cd_filial" dbalias="pe.cd_filial" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="pedido_ecommerce.dh_inclusao" dbalias="pe.dh_inclusao" )
 column=(type=long updatewhereclause=yes name=id_pagamento dbname="pedido_ecommerce.id_pagamento" dbalias="pe.id_pagamento" )
 column=(type=char(40) updatewhereclause=yes name=nm_administradora_cartao dbname="pedido_ecommerce_auxiliar.nm_administradora_cartao" dbalias="pa.nm_administradora_cartao" )
 column=(type=char(10) updatewhereclause=yes name=cd_estabelecimento_cartao dbname="pedido_ecommerce_auxiliar.cd_estabelecimento_cartao" dbalias="pa.cd_estabelecimento_cartao" )
 column=(type=char(20) updatewhereclause=yes name=nr_cartao_credito dbname="pedido_ecommerce_auxiliar.nr_cartao_credito" dbalias="pa.nr_cartao_credito" )
 column=(type=char(20) updatewhereclause=yes name=nr_comprovante_cartao_credito dbname="pedido_ecommerce_auxiliar.nr_comprovante_cartao_credito" dbalias="pa.nr_comprovante_cartao_credito" )
 column=(type=char(20) updatewhereclause=yes name=nr_autorizacao_cartao_credito dbname="pedido_ecommerce_auxiliar.nr_autorizacao_cartao_credito" dbalias="pa.nr_autorizacao_cartao_credito" )
 column=(type=long updatewhereclause=yes name=nr_vending_machine dbname="pedido_ecommerce.nr_vending_machine" dbalias="pe.nr_vending_machine" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_filial dbname="filial.id_rede_filial" dbalias="f.id_rede_filial" )
 retrieve="select pe.cd_filial_ecommerce,
		pe.nr_pedido,   
		pe.nr_pedido_ecommerce,
		pe.dh_compra,   
		pe.dh_atualizacao,   
		pe.id_situacao,   
		pe.vl_subtotal,    
		pe.vl_total,   
		pe.nr_parcelas,           
		pe.cd_tipo_pagamento,   
		pe.cd_forma_pagamento,       
		pe.cd_filial,
		pe.dh_inclusao,
		pe.id_pagamento,
		pa.nm_administradora_cartao,
		pa.cd_estabelecimento_cartao,
		pa.nr_cartao_credito,
		pa.nr_comprovante_cartao_credito,
		pa.nr_autorizacao_cartao_credito,
		pe.nr_vending_machine,
		f.id_rede_filial
from pedido_ecommerce pe
    inner join pedido_ecommerce_auxiliar pa on (pa.cd_filial_ecommerce = pe.cd_filial_ecommerce
                                               and pa.nr_pedido = pe.nr_pedido)
    inner join filial f on (f.cd_filial = pe.cd_filial)
where ( pe.nr_pedido_drogaexpress is null or pe.nr_pedido_drogaexpress = '' )
and pe.nr_pedido_ecommerce is not null
and pe.id_situacao = 'A'
and coalesce(pe.id_ecommerce, '1') = :ps_id_ecommerce
order by pe.cd_filial" arguments=(("ps_id_ecommerce", string)) )
htmltable(border="1" )
