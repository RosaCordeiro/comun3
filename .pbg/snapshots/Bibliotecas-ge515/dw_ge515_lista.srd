table(column=(type=long update=yes updatewhereclause=yes name=nr_vending_machine dbname="vending_machine.nr_vending_machine" dbalias="v.nr_vending_machine" )
 column=(type=char(10) update=yes updatewhereclause=yes name=cd_maquina_vmpay dbname="vending_machine.cd_maquina_vmpay" dbalias="v.cd_maquina_vmpay" )
 column=(type=char(10) update=yes updatewhereclause=yes name=cd_local_vmpay dbname="vending_machine.cd_local_vmpay" dbalias="v.cd_local_vmpay" )
 column=(type=char(30) updatewhereclause=yes name=de_local_vmpay dbname="vending_machine.de_local_vmpay" dbalias="v.de_local_vmpay" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="vending_machine.cd_filial" dbalias="v.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_patrimonio dbname="vending_machine.nr_patrimonio" dbalias="v.nr_patrimonio" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="vending_machine.id_situacao" dbalias="v.id_situacao" )
 column=(type=char(30) update=yes updatewhereclause=yes name=nr_serie dbname="vending_machine.nr_serie" dbalias="v.nr_serie" )
 column=(type=long update=yes updatewhereclause=yes name=cd_cidade dbname="vending_machine.cd_cidade" dbalias="v.cd_cidade" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_telefone dbname="vending_machine.nr_telefone" dbalias="v.nr_telefone" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_endereco dbname="vending_machine.de_endereco" dbalias="v.de_endereco" )
 column=(type=long update=yes updatewhereclause=yes name=nr_endereco dbname="vending_machine.nr_endereco" dbalias="v.nr_endereco" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_complemento dbname="vending_machine.de_complemento" dbalias="v.de_complemento" )
 column=(type=char(20) update=yes updatewhereclause=yes name=de_bairro dbname="vending_machine.de_bairro" dbalias="v.de_bairro" )
 column=(type=char(8) update=yes updatewhereclause=yes name=nr_cep dbname="vending_machine.nr_cep" dbalias="v.nr_cep" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_atualizacao dbname="vending_machine.dh_atualizacao" dbalias="v.dh_atualizacao" )
 column=(type=char(10) update=yes updatewhereclause=yes name=cd_cliente_vmpay dbname="vending_machine.cd_cliente_vmpay" dbalias="v.cd_cliente_vmpay" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" dbalias="c.nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" dbalias="c.cd_unidade_federacao" )
 retrieve="SELECT 	 v.nr_vending_machine,
			 v.cd_maquina_vmpay,
			 v.cd_local_vmpay,
			 v.de_local_vmpay,
			 v.cd_filial,
			 f.nm_fantasia,
			 v.nr_patrimonio,
			 v.id_situacao,
			 v.nr_serie,
			 v.cd_cidade,
			 v.nr_telefone,
			 v.de_endereco,
			 v.nr_endereco,
			 v.de_complemento,
			 v.de_bairro,
			 v.nr_cep,
			 v.dh_atualizacao,
			 v.cd_cliente_vmpay,
			 c.nm_cidade,
			 c.cd_unidade_federacao
FROM vending_machine v
 INNER JOIN cidade c
		ON c.cd_cidade = v.cd_cidade
 LEFT OUTER JOIN filial f
		on f.cd_filial = v.cd_filial" )
