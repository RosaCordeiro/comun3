table(column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="wms_lista_separacao.nr_pedido_distribuidora" dbalias="wls.nr_pedido_distribuidora" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" dbalias="f.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_volume dbname="wms_lista_separacao.nr_volume" dbalias="wls.nr_volume" )
 column=(type=char(20) updatewhereclause=yes name=wms_integracao_picking_nr_picking dbname="wms_integracao_picking.nr_picking" dbalias="wip.nr_picking" )
 retrieve="SELECT wls.nr_pedido_distribuidora,    
			f.cd_filial,   			
			wls.nr_volume,
			wip.nr_picking
FROM wms_integracao_picking wip
INNER JOIN wms_lista_separacao wls 
        ON  wip.cd_filial  = wls.cd_filial
        AND wip.nr_pedido_distribuidora  = wls.nr_pedido_distribuidora
        AND wip.nr_volume  = wls.nr_volume
INNER JOIN filial f ON wip.cd_filial = f.cd_filial
WHERE wip.cd_integracao = '1'
	AND wls.dh_exportacao is not null
    AND wip.cd_tipo = 'E'
    AND NOT EXISTS(SELECT 1 
							FROM wms_integracao_picking wip2 
							WHERE wip2.cd_filial  = wip.cd_filial
								AND wip2.nr_pedido_distribuidora  = wip.nr_pedido_distribuidora
								AND wip2.nr_volume  = wip.nr_volume
								AND wip.cd_tipo = 'I') " arguments=(("dt_emissao_de", date),("dt_emissao_ate", date))  sort="nr_pedido_distribuidora A nr_volume A " )
