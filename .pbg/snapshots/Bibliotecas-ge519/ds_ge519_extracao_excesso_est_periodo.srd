table(column=(type=datetime update=yes updatewhereclause=yes key=yes name=dh_pedido dbname="resumo_reposicao_estoque_exce.dh_pedido" dbalias="r.dh_pedido" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="resumo_reposicao_estoque_exce.cd_filial" dbalias="r.cd_filial" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="resumo_reposicao_estoque_exce.cd_produto" dbalias="r.cd_produto" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=qt_demanda_diaria dbname="resumo_reposicao_estoque_exce.qt_demanda_diaria" dbalias="r.qt_demanda_diaria" )
 column=(type=long update=yes updatewhereclause=yes name=qt_dias_cobertura dbname="resumo_reposicao_estoque_exce.qt_dias_cobertura" dbalias="r.qt_dias_cobertura" )
