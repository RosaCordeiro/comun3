 column=(type=long update=yes updatewhereclause=yes name=qt_estoque_minimo dbname="resumo_reposicao_estoque_exce.qt_estoque_minimo" dbalias="r.qt_estoque_minimo" )
 column=(type=long update=yes updatewhereclause=yes name=qt_estoque_filial dbname="resumo_reposicao_estoque_exce.qt_estoque_filial" dbalias="r.qt_estoque_filial" )
 column=(type=char(1) update=yes updatewhereclause=yes name=cd_classe_reposicao dbname="resumo_reposicao_estoque_exce.cd_classe_reposicao" dbalias="r.cd_classe_reposicao" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_custo_unitario dbname="resumo_reposicao_estoque_exce.vl_custo_unitario" dbalias="r.vl_custo_unitario" )
 column=(type=long updatewhereclause=yes name=qt_dias_ult_entrada dbname="qt_dias_ult_entrada" )
 retrieve="Select	r.dh_pedido,
		r.cd_filial,
		r.cd_produto,
		r.qt_demanda_diaria,
		r.qt_dias_cobertura,
		r.qt_estoque_base,
		r.qt_estoque_minimo,
		r.qt_estoque_filial,
		r.cd_classe_reposicao,
		r.vl_custo_unitario,		
		0 As qt_dias_ult_entrada
From resumo_reposicao_estoque_exce r
Where r.dh_pedido = :inicio
" update="resumo_reposicao_estoque_exce" updatewhere=1 updatekeyinplace=no arguments=(("inicio", date))  sort="dh_pedido A cd_filial A cd_produto A " )
