table(column=(type=char(1) updatewhereclause=yes name=de_localizacao dbname="de_localizacao" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_vending_machine dbname="vending_machine.nr_vending_machine" )
 column=(type=char(10) update=yes updatewhereclause=yes name=cd_maquina_vmpay dbname="vending_machine.cd_maquina_vmpay" )
 column=(type=char(10) update=yes updatewhereclause=yes name=cd_local_vmpay dbname="vending_machine.cd_local_vmpay" )
 column=(type=char(30) update=yes updatewhereclause=yes name=de_local_vmpay dbname="vending_machine.de_local_vmpay" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="vending_machine.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_filial dbname="nm_filial" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_patrimonio dbname="vending_machine.nr_patrimonio" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="vending_machine.id_situacao" initial="A" values="ATIVA	A/INATIVA	I/" )
 column=(type=char(30) update=yes updatewhereclause=yes name=nr_serie dbname="vending_machine.nr_serie" )
 column=(type=long update=yes updatewhereclause=yes name=cd_cidade dbname="vending_machine.cd_cidade" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="nm_cidade" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_telefone dbname="vending_machine.nr_telefone" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_endereco dbname="vending_machine.de_endereco" )
 column=(type=long update=yes updatewhereclause=yes name=nr_endereco dbname="vending_machine.nr_endereco" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_complemento dbname="vending_machine.de_complemento" )
 column=(type=char(20) update=yes updatewhereclause=yes name=de_bairro dbname="vending_machine.de_bairro" )
 column=(type=char(8) update=yes updatewhereclause=yes name=nr_cep dbname="vending_machine.nr_cep" )
 retrieve=" SELECT '' de_localizacao,
			v.nr_vending_machine,   
         v.cd_maquina_vmpay,   
         v.cd_local_vmpay,   
         v.de_local_vmpay,   
         v.cd_filial,   
		(Select f.nm_fantasia from filial f where f.cd_filial = v.cd_filial) as nm_filial,
         v.nr_patrimonio,   
         v.id_situacao,   
         v.nr_serie,   
         v.cd_cidade,   
		(Select c.nm_cidade from cidade c where c.cd_cidade = v.cd_cidade) as nm_cidade,
         v.nr_telefone,   
         v.de_endereco,   
         v.nr_endereco,   
         v.de_complemento,   
         v.de_bairro,   
         v.nr_cep 
    FROM vending_machine v
	where v.nr_vending_machine = :pl_nr_vending_machine
" update="vending_machine" updatewhere=0 updatekeyinplace=yes arguments=(("pl_nr_vending_machine", number)) )
