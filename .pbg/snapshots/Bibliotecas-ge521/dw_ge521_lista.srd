table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=char(60) updatewhereclause=yes name=nm_destino dbname="nm_destino" )
 column=(type=char(21) updatewhereclause=yes name=tipo dbname="tipo" )
 retrieve="  SELECT nf.cd_filial_origem as cd_filial,
			nf.nr_nf,
			nf.de_serie,
			nf.de_especie,
			nf.dh_movimentacao_caixa,
			CAST(f.cd_filial as varchar(4)) || ' - ' || f.nm_fantasia as nm_destino,
			'TRANSFER$$HEX1$$ca00$$ENDHEX$$NCIA SA$$HEX1$$cd00$$ENDHEX$$DA' as tipo
FROM nf_transferencia nf (index idx_data_filial_origem)
INNER JOIN filial f
	ON f.cd_filial = nf.cd_filial_destino
WHERE nf.dh_movimentacao_caixa between :dt_inicio and :dt_termino
	AND NOT EXISTS (SELECT nr_atualizacao 
							FROM log_exportacao_mult ex1 
							WHERE ex1.cd_filial = nf.cd_filial_origem
								AND ex1.nr_nf = nf.nr_nf
								AND ex1.de_serie = nf.de_serie
								AND ex1.de_especie = nf.de_especie
								AND ex1.dh_importacao is not null
								AND ex1.id_tipo_nf = 'ST')

UNION 

 SELECT nf.cd_filial_origem,
			nf.nr_nf,
			nf.de_serie,
			nf.de_especie,
			nf.dh_movimentacao_caixa,
			CAST(f.cd_filial as varchar(4)) || ' - ' || f.nm_fantasia as nm_destino,
			'TRANSFER$$HEX1$$ca00$$ENDHEX$$NCIA ENTRADA' as tipo
FROM nf_transferencia nf (index idx_data_filial_origem)
INNER JOIN filial f
	ON f.cd_filial = nf.cd_filial_destino
WHERE nf.dh_movimentacao_caixa between :dt_inicio and :dt_termino
	AND nf.dh_cancelamento is null
	AND NOT EXISTS (SELECT nr_atualizacao 
							FROM log_exportacao_mult ex1 
							WHERE ex1.cd_filial = nf.cd_filial_origem
								AND ex1.nr_nf = nf.nr_nf
								AND ex1.de_serie = nf.de_serie
								AND ex1.de_especie = nf.de_especie
								AND ex1.dh_importacao is not null
								AND ex1.id_tipo_nf = 'ET')
	and not exists (select nf.cd_filial_origem, nf.nr_nf 
						from nf_transferencia_sinistrada ns1
						where ns1.cd_filial_origem = nf.cd_filial_origem
							and ns1.nr_nf	 = nf.nr_nf
							and ns1.de_especie = nf.de_especie
							and ns1.de_serie	 = nf.de_serie)

UNION

  SELECT nf.cd_filial_origem,
			nf.nr_nf,
			nf.de_serie,
			nf.de_especie,
			nf.dh_movimentacao_caixa,
			nf.nm_destinatario as nm_destino,
			'DIVERSA SA$$HEX1$$cd00$$ENDHEX$$DA' as tipo
FROM nf_diversa nf (index idx_data_movimento)
WHERE nf.dh_movimentacao_caixa between :dt_inicio and :dt_termino
	AND nf.cd_natureza_operacao > 5000
	AND NOT EXISTS (SELECT nr_atualizacao 
							FROM log_exportacao_mult ex1 
							WHERE ex1.cd_filial = nf.cd_filial_origem
								AND ex1.nr_nf = nf.nr_nf
								AND ex1.de_serie = nf.de_serie
								AND ex1.de_especie = nf.de_especie
								AND ex1.dh_importacao is not null
								AND ex1.id_tipo_nf = 'SD')

UNION 

 SELECT nf.cd_filial_origem,
			nf.nr_nf,
			nf.de_serie,
			nf.de_especie,
			nf.dh_movimentacao_caixa,
			nf.nm_destinatario as nm_destino,
			'DIVERSA ENTRADA' as tipo
FROM nf_diversa nf (index idx_data_movimento)
LEFT OUTER JOIN filial f 
	ON f.nr_cgc = nf.nr_cgc_cpf
   AND f.id_situacao = 'A'
WHERE nf.dh_movimentacao_caixa between :dt_inicio and :dt_termino
	AND ((nf.cd_natureza_operacao < 5000 and nf.cd_natureza_operacao <> 1601)or((f.cd_filial is not null) and (nf.dh_cancelamento is null) and (f.cd_filial <> nf.cd_filial_origem)))
	AND NOT EXISTS (SELECT nr_atualizacao 
							FROM log_exportacao_mult ex1 
							WHERE ex1.cd_filial = nf.cd_filial_origem
								AND ex1.nr_nf = nf.nr_nf
								AND ex1.de_serie = nf.de_serie
								AND ex1.de_especie = nf.de_especie
								AND ex1.dh_importacao is not null
								AND ex1.id_tipo_nf = 'ED')

UNION

 SELECT nf.cd_filial,
			nf.nr_nf,
			nf.de_serie,
			nf.de_especie,
			nf.dh_movimentacao_caixa,
			f.nm_fantasia as nm_destino,
			'COMPRA' as tipo
FROM nf_compra nf (index idx_data_fornecedor)
INNER JOIN fornecedor f
	ON f.cd_fornecedor = nf.cd_fornecedor
WHERE nf.dh_movimentacao_caixa between :dt_inicio and :dt_termino
	AND nf.de_especie = 'NFE'
	AND NOT EXISTS (SELECT nr_atualizacao 
							FROM log_exportacao_mult ex1 
							WHERE ex1.cd_filial = nf.cd_filial
								AND ex1.nr_nf = nf.nr_nf
								AND ex1.de_serie = nf.de_serie
								AND ex1.de_especie = nf.de_especie
								AND ex1.cd_fornecedor = nf.cd_fornecedor
								AND ex1.dh_importacao is not null
								AND ex1.id_tipo_nf = 'CO')

UNION

 SELECT nf.cd_filial,
			nf.nr_nf,
			nf.de_serie,
			nf.de_especie,
			nf.dh_movimentacao_caixa,
			c.nm_cliente as nm_destino,
			case nf.de_especie when 'NFE' then 'VENDA ANEXA' when 'NFC' then 'VENDA NFCe' when 'CF' then 'VENDA CUPOM' when 'SAT' then 'VENDA SAT' when 'RPS' then 'VENDA SERVI$$HEX1$$c700$$ENDHEX$$O' end as tipo
FROM nf_venda nf (index idx_data_filial)
INNER JOIN filial f 
	on f.cd_filial = nf.cd_filial
INNER JOIN cidade ci
	on ci.cd_cidade = f.cd_cidade
LEFT OUTER JOIN cliente c
	on c.cd_cliente = nf.cd_cliente
LEFT OUTER JOIN nf_venda_nfe e
	on e.cd_filial = nf.cd_filial
	and e.nr_nf = nf.nr_nf
	and e.de_especie = nf.de_especie
	and e.de_serie = nf.de_serie
WHERE nf.dh_movimentacao_caixa between :dt_inicio and :dt_termino
	AND ( ((nf.de_especie = 'CF') AND (ci.cd_unidade_federacao <> 'SC')) or (nf.de_especie <> 'CF'))
	AND ( ((nf.de_especie = 'SAT') AND (e.id_situacao is not null)) or (nf.de_especie <> 'SAT'))
	AND NOT EXISTS (SELECT nr_atualizacao 
							FROM log_exportacao_mult ex1 
							WHERE ex1.cd_filial = nf.cd_filial
								AND ex1.nr_nf = nf.nr_nf
								AND ex1.de_serie = nf.de_serie
								AND ex1.de_especie = nf.de_especie
								AND ex1.dh_importacao is not null
								AND ex1.id_tipo_nf = 'VD')
UNION

 SELECT nf.cd_filial,
			nf.nr_nf,
			nf.de_serie,
			nf.de_especie,
			nf.dh_movimentacao_caixa,
			c.nm_cliente as nm_destino,
			'DEVOLU$$HEX2$$c700c300$$ENDHEX$$O VENDA' as tipo
FROM nf_devolucao_venda nf (index idx_dh_movimentacao_caixa)
LEFT OUTER JOIN cliente c
	on c.cd_cliente = nf.cd_cliente
WHERE nf.dh_movimentacao_caixa between :dt_inicio and :dt_termino
	AND NOT EXISTS (SELECT nr_atualizacao 
							FROM log_exportacao_mult ex1 
							WHERE ex1.cd_filial = nf.cd_filial
								AND ex1.nr_nf = nf.nr_nf
								AND ex1.de_serie = nf.de_serie
								AND ex1.de_especie = nf.de_especie
								AND ex1.dh_importacao is not null
								AND ex1.id_tipo_nf = 'DV')

UNION

 SELECT nf.cd_filial,
			nf.nr_nf,
			nf.de_serie,
			nf.de_especie,
			nf.dh_movimentacao_caixa,
			f.nm_fantasia as nm_destino,
			'DEVOLU$$HEX2$$c700c300$$ENDHEX$$O COMPRA' as tipo
FROM nf_devolucao_compra nf  (index idx_dh_movimentacao_caixa)
INNER JOIN fornecedor f
	ON f.cd_fornecedor = nf.cd_fornecedor
WHERE nf.dh_movimentacao_caixa between :dt_inicio and :dt_termino
	AND NOT EXISTS (SELECT nr_atualizacao 
							FROM log_exportacao_mult ex1 
							WHERE ex1.cd_filial = nf.cd_filial
								AND ex1.nr_nf = nf.nr_nf
								AND ex1.de_serie = nf.de_serie
								AND ex1.de_especie = nf.de_especie
								AND ex1.dh_importacao is not null
								AND ex1.id_tipo_nf = 'DC')
UNION

 SELECT me.cd_filial,
			me.nr_mapa,
			me.de_serie,
			me.de_especie,
			mp.dh_emissao,
			'ECF: '||Cast(me.nr_ecf as varchar(6)) as nm_destino,
			'MAPA RESUMO' as tipo
FROM mapa_resumo mp
INNER JOIN mapa_resumo_ecf me
	ON me.cd_filial = mp.cd_filial
   AND me.nr_mapa = mp.nr_mapa
   AND me.de_serie = mp.de_serie
   AND me.de_especie = mp.de_especie
WHERE mp.dh_emissao between :dt_inicio and :dt_termino
	AND me.vl_contabil > 0
	AND me.nr_ecf > 0
	AND NOT EXISTS (SELECT nr_atualizacao 
							FROM log_exportacao_mult ex1 
							WHERE ex1.cd_filial = me.cd_filial
								AND ex1.nr_nf = me.nr_mapa
								AND ex1.de_serie = me.de_serie
								AND ex1.cd_fornecedor = Cast(me.nr_ecf as varchar(6))
								AND ex1.dh_importacao is not null
								AND ex1.de_especie = 'MR'
								AND ex1.id_tipo_nf = 'MR')" arguments=(("dt_inicio", datetime),("dt_termino", datetime)) )
