table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_ecommerce.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_vending_machine dbname="pedido_ecommerce.nr_vending_machine" )
 column=(type=char(30) updatewhereclause=yes name=de_local_vmpay dbname="vending_machine.de_local_vmpay" )
 column=(type=datetime updatewhereclause=yes name=dh_compra dbname="pedido_ecommerce.dh_compra" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_ecommerce_produto.cd_produto" )
 column=(type=char(100) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total dbname="pedido_ecommerce.vl_total" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_ecommerce_produto.qt_pedida" )
 retrieve="select pe.cd_filial, 
        f.nm_fantasia,
        pe.nr_vending_machine, 
        vm.de_local_vmpay, 
        pe.dh_compra, 
        pp.cd_produto,
		g.de_produto + g.de_apresentacao_venda as de_produto,
        pe.vl_total,
		pp.qt_pedida
from pedido_ecommerce pe
    inner join filial f on f.cd_filial = pe.cd_filial 
inner join pedido_ecommerce_produto pp
	on pp.cd_filial_ecommerce = pe.cd_filial_ecommerce
	and pp.nr_pedido = pe.nr_pedido
inner join produto_geral g
	on g.cd_produto = pp.cd_produto
inner join vending_machine vm on (vm.nr_vending_machine = pe.nr_vending_machine)
where pe.id_ecommerce = :ps_id_ecommerce
	and pp.cd_produto = :pl_cd_produto
	and pe.dh_compra between :pdh_inicio and :pdh_fim" arguments=(("ps_id_ecommerce", string),("pl_cd_produto", number),("pdh_inicio", datetime),("pdh_fim", datetime))  sort="dh_compra A " )
