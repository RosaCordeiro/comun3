table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=id_bloq_exame dbname="id_bloq_exame" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_bloq_vacina dbname="id_bloq_vacina" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_bloq_clinicarx dbname="id_bloq_clinicarx" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_bloq_anticorpo dbname="id_bloq_anticorpo" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(40) updatewhereclause=yes name=vl_parametro dbname="parametro_loja.vl_parametro" )
 column=(type=char(1) updatewhereclause=yes name=id_bloq_exame_old dbname="id_bloq_exame_old" )
 column=(type=char(1) updatewhereclause=yes name=id_bloq_vacina_old dbname="id_bloq_vacina_old" )
 column=(type=char(1) updatewhereclause=yes name=id_bloq_clinicarx_old dbname="id_bloq_clinicarx_old" )
 column=(type=char(1) updatewhereclause=yes name=id_bloq_anticorpo_old dbname="id_bloq_anticorpo_old" )
 retrieve="Select	f.cd_filial,
		f.nm_fantasia,		
		'' As id_bloq_exame,
		'' As id_bloq_vacina,
		'' As id_bloq_clinicarx,
		'' As id_bloq_anticorpo,
		p.vl_parametro,
		'' As id_bloq_exame_old,
		'' As id_bloq_vacina_old,
		'' As id_bloq_clinicarx_old,
		'' As id_bloq_anticorpo_old
From filial As f
	Inner join parametro_odbc As o
		On o.cd_filial = f.cd_filial
	Inner Join parametro_loja As p
		On p.cd_filial = f.cd_filial
		And p.cd_parametro = 'CD_CATEGORIA_PRD_MOVIMENTACAO_BLOQUEADA'
Where f.id_situacao = 'A'
And f.cd_filial <> 534"  sort="cd_filial A " )
