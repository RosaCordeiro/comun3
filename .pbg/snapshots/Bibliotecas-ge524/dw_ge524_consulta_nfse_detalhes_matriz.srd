table(column=(type=char(30) updatewhereclause=yes name=nr_nf_servico dbname="nf_servico.nr_nf_servico" dbalias="ns.nr_nf_servico" )
 column=(type=char(10) updatewhereclause=yes name=de_serie_nfse dbname="nf_servico.de_serie_nfse" dbalias="ns.de_serie_nfse" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_servico.dh_emissao" dbalias="ns.dh_emissao" )
 column=(type=char(40) updatewhereclause=yes name=nr_protocolo dbname="nf_servico.nr_protocolo" dbalias="ns.nr_protocolo" )
 column=(type=char(20) updatewhereclause=yes name=cd_codigo_verificacao dbname="nf_servico.cd_codigo_verificacao" dbalias="ns.cd_codigo_verificacao" )
 column=(type=datetime updatewhereclause=yes name=dh_envio dbname="nf_servico.dh_envio" dbalias="ns.dh_envio" )
 column=(type=datetime updatewhereclause=yes name=dh_retorno dbname="nf_servico.dh_retorno" dbalias="ns.dh_retorno" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_operador dbname="nf_servico.nr_matricula_operador" dbalias="ns.nr_matricula_operador" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="u.nm_usuario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total dbname="nf_servico.vl_total" dbalias="ns.vl_total" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_iss dbname="nf_servico.vl_bc_iss" dbalias="ns.vl_bc_iss" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_aliquota_iss dbname="nf_servico.pc_aliquota_iss" dbalias="ns.pc_aliquota_iss" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_iss dbname="nf_servico.vl_iss" dbalias="ns.vl_iss" )
 column=(type=char(14) updatewhereclause=yes name=nr_cpf_cgc dbname="nf_servico.nr_cpf_cgc" dbalias="ns.nr_cpf_cgc" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="nf_servico.nm_razao_social" dbalias="ns.nm_razao_social" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nf_servico.nm_fantasia" dbalias="ns.nm_fantasia" )
 column=(type=char(15) updatewhereclause=yes name=nr_inscricao_estadual dbname="nf_servico.nr_inscricao_estadual" dbalias="ns.nr_inscricao_estadual" )
 column=(type=char(15) updatewhereclause=yes name=nr_inscricao_municipal dbname="nf_servico.nr_inscricao_municipal" dbalias="ns.nr_inscricao_municipal" )
 column=(type=char(40) updatewhereclause=yes name=de_endereco dbname="nf_servico.de_endereco" dbalias="ns.de_endereco" )
 column=(type=char(6) updatewhereclause=yes name=nr_endereco dbname="nf_servico.nr_endereco" dbalias="ns.nr_endereco" )
 column=(type=char(30) updatewhereclause=yes name=de_complemento dbname="nf_servico.de_complemento" dbalias="ns.de_complemento" )
 column=(type=char(30) updatewhereclause=yes name=de_bairro dbname="nf_servico.de_bairro" dbalias="ns.de_bairro" )
 column=(type=long updatewhereclause=yes name=cd_cidade dbname="nf_servico.cd_cidade" dbalias="ns.cd_cidade" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep dbname="nf_servico.nr_cep" dbalias="ns.nr_cep" )
 column=(type=char(16) updatewhereclause=yes name=nr_telefone dbname="nr_telefone" )
 column=(type=char(100) updatewhereclause=yes name=de_email dbname="nf_servico.de_email" dbalias="ns.de_email" )
 column=(type=char(150) updatewhereclause=yes name=de_retorno dbname="nf_servico.de_retorno" dbalias="ns.de_retorno" )
 column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" dbalias="c.nm_cidade" )
 column=(type=char(1000) updatewhereclause=yes name=de_link_visualizacao_nfse dbname="nf_servico.de_link_visualizacao_nfse" dbalias="ns.de_link_visualizacao_nfse" )
 retrieve="Select 	ns.nr_nf_servico,
			ns.de_serie_nfse, 
			ns.dh_emissao,
			ns.nr_protocolo,
			ns.cd_codigo_verificacao,
			ns.dh_envio,
			ns.dh_retorno,
			ns.nr_matricula_operador,	
			u.nm_usuario,
   		ns.vl_total,
			ns.vl_bc_iss,
			ns.pc_aliquota_iss,
			ns.vl_iss,
			ns.nr_cpf_cgc,
			ns.nm_razao_social,
			ns.nm_fantasia,
			ns.nr_inscricao_estadual,
			ns.nr_inscricao_municipal,
			ns.de_endereco,
			ns.nr_endereco,
			ns.de_complemento,
			ns.de_bairro,
			ns.cd_cidade,
			ns.nr_cep,
			'(' + ns.nr_ddd + ') ' + ns.nr_telefone as nr_telefone,
			ns.de_email,
			ns.de_retorno,
			c.nm_cidade,
			ns.de_link_visualizacao_nfse
From nf_servico ns
	left join cidade c on c.cd_cidade = ns.cd_cidade
	left join usuario u
		on u.nr_matricula = ns.nr_matricula_operador
where ns.cd_filial = :pl_cd_filial
		and ns.nr_nf = :pl_nr_nf
		and ns.de_especie = :ps_especie
		and ns.de_serie = :ps_serie" arguments=(("pl_cd_filial", number),("pl_nr_nf", number),("ps_especie", string),("ps_serie", string)) )
