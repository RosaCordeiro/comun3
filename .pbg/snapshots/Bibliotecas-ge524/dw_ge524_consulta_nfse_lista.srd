table(column=(type=char(20) updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_drogaexpress.nr_pedido_ecommerce" dbalias="p.nr_pedido_ecommerce" )
 column=(type=char(11) updatewhereclause=yes name=nr_pedido_drogaexpress dbname="pedido_drogaexpress.nr_pedido_drogaexpress" dbalias="p.nr_pedido_drogaexpress" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_drogaexpress.dh_emissao" dbalias="p.dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_pedido dbname="pedido_drogaexpress.vl_total_pedido" dbalias="p.vl_total_pedido" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_manipulado dbname="vl_manipulado" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_venda.nr_nf" dbalias="n.nr_nf" )
 column=(type=long updatewhereclause=yes name=nr_nf_servico dbname="nf_servico.nr_nf_servico" dbalias="ns.nr_nf_servico" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao_nfse dbname="nf_servico.dh_emissao" dbalias="ns.dh_emissao" )
 column=(type=char(255) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=char(40) updatewhereclause=yes name=id_nfse dbname="nf_servico.id_nfse" dbalias="ns.id_nfse" )
 column=(type=char(40) updatewhereclause=yes name=nr_protocolo dbname="nf_servico.nr_protocolo" dbalias="ns.nr_protocolo" )
 column=(type=char(40) updatewhereclause=yes name=cd_verificacao dbname="nf_servico.cd_verificacao" dbalias="ns.cd_verificacao" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_venda.cd_filial" dbalias="n.cd_filial" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_venda.de_especie" dbalias="n.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_venda.de_serie" dbalias="n.de_serie" )
 column=(type=char(14) updatewhereclause=yes name=nr_cnpj_prestador dbname="filial.nr_cnpj_prestador" dbalias="f.nr_cnpj_prestador" )
 column=(type=char(8190) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" values="	S/	N" )
 column=(type=char(40) updatewhereclause=yes name=nr_protocolo_cancelamento dbname="nf_servico.nr_protocolo_cancelamento" dbalias="ns.nr_protocolo_cancelamento" )
 retrieve="Select p.nr_pedido_ecommerce_site nr_pedido_ecommerce,
		p.nr_pedido_drogaexpress,
		p.dh_emissao,
		p.vl_total_pedido,
		(select sum(round(qt_pedida * vl_preco_praticado, 2)) from produto_pedido_drogaexpress pp where pp.nr_pedido_drogaexpress = p.nr_pedido_drogaexpress and pp.cd_produto = 684431) vl_manipulado,
		n.nr_nf,
		ns.nr_nf_servico,
		ns.dh_emissao,
		Case When ns.id_situacao is null then 'P' else ns.id_situacao End as id_situacao,
		ns.id_nfse,
		ns.nr_protocolo,
		ns.cd_verificacao,
		n.cd_filial,
		n.de_especie,
		n.de_serie,
		f.nr_cgc  as nr_cnpj_prestador,
		'N' as id_selecionar,
		ns.nr_protocolo_cancelamento
From pedido_drogaexpress p
	inner join nf_venda n
		on n.cd_filial_ecommerce = p.cd_filial_ecommerce
		and n.nr_pedido_ecommerce = p.nr_pedido_ecommerce
	left join nf_servico ns
		on ns.cd_filial = n.cd_filial
		and ns.nr_nf = n.nr_nf
		and ns.de_especie = n.de_especie
		and ns.de_serie = n.de_serie
	left join filial f on f.cd_filial = ns.cd_filial
where p.id_exige_nfse = 'S'
   and n.dh_cancelamento is null
   and n.nr_nf_anexa is null

UNION

Select p.nr_pedido_ecommerce_site nr_pedido_ecommerce,
		p.nr_pedido_drogaexpress,
		p.dh_emissao,
		p.vl_total_pedido,
		(select sum(round(qt_pedida * vl_preco_praticado, 2)) from produto_pedido_drogaexpress pp where pp.nr_pedido_drogaexpress = p.nr_pedido_drogaexpress and pp.cd_produto = 684431) vl_manipulado,
		n.nr_nf,
		ns.nr_nf_servico,
		ns.dh_emissao,
		Case When ns.id_situacao = 'X' Then 'X' Else 'C' End as id_situacao,
		ns.id_nfse,
		ns.nr_protocolo,
		ns.cd_verificacao,
		n.cd_filial,
		n.de_especie,
		n.de_serie,
		f.nr_cgc  as nr_cnpj_prestador,
		'N' as id_selecionar,
		ns.nr_protocolo_cancelamento
From pedido_drogaexpress p
	inner join nf_venda n
		on n.cd_filial_ecommerce = p.cd_filial_ecommerce
		and n.nr_pedido_ecommerce = p.nr_pedido_ecommerce
	inner join nf_servico ns
		on ns.cd_filial = n.cd_filial
		and ns.nr_nf = n.nr_nf
		and ns.de_especie = n.de_especie
		and ns.de_serie = n.de_serie
	left join filial f on f.cd_filial = ns.cd_filial
where p.id_exige_nfse = 'S'
   and n.dh_cancelamento is not null
   and n.nr_nf_anexa is null"  sort="dh_emissao A " )
