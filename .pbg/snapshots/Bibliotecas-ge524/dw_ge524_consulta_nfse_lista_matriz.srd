table(column=(type=char(40) updatewhereclause=yes name=nr_pedido_ecommerce dbname="pedido_ecommerce.nr_pedido_ecommerce" dbalias="p.nr_pedido_ecommerce" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_ecommerce.nr_pedido" dbalias="p.nr_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_compra dbname="pedido_ecommerce.dh_compra" dbalias="p.dh_compra" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_pedido dbname="pedido_ecommerce.vl_total_pedido" dbalias="p.vl_total_pedido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_manipulado dbname="vl_manipulado" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_venda.nr_nf" dbalias="n.nr_nf" )
 column=(type=char(30) updatewhereclause=yes name=nr_nf_servico dbname="nf_servico.nr_nf_servico" dbalias="ns.nr_nf_servico" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao_nfse dbname="nf_servico.dh_emissao" dbalias="ns.dh_emissao" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=char(40) updatewhereclause=yes name=id_nfse dbname="nf_servico.id_nfse" dbalias="ns.id_nfse" )
 column=(type=char(40) updatewhereclause=yes name=nr_protocolo dbname="nf_servico.nr_protocolo" dbalias="ns.nr_protocolo" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_venda.cd_filial" dbalias="n.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_filial dbname="nm_filial" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_venda.de_especie" dbalias="n.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_venda.de_serie" dbalias="n.de_serie" )
 column=(type=char(10) updatewhereclause=yes name=cd_servico dbname="nf_servico.cd_servico" dbalias="ns.cd_servico" )
 column=(type=char(250) updatewhereclause=yes name=de_servico dbname="nf_servico.de_servico" dbalias="ns.de_servico" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_iss dbname="nf_servico.vl_iss" dbalias="ns.vl_iss" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_aliquota_iss dbname="nf_servico.pc_aliquota_iss" dbalias="ns.pc_aliquota_iss" )
 column=(type=char(40) updatewhereclause=yes name=cd_verificacao dbname="nf_servico.cd_verificacao" dbalias="ns.cd_verificacao" )
 column=(type=char(14) updatewhereclause=yes name=nr_cnpj_prestador dbname="filial.nr_cnpj_prestador" dbalias="f.nr_cnpj_prestador" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" values="	S/	N" )
 retrieve="Select p.nr_pedido_ecommerce,
		p.nr_pedido,
		p.dh_compra,
		p.vl_total as vl_total_pedido,
		(select sum(round(qt_pedida * vl_preco_promocao, 2)) from pedido_ecommerce_produto pp where pp.cd_filial_ecommerce = p.cd_filial_ecommerce and pp.nr_pedido = p.nr_pedido and pp.cd_produto = 684431) as vl_manipulado,
		n.nr_nf,
		ns.nr_nf_servico,
		ns.dh_emissao,
		Case When ns.id_situacao is null then 'P' else ns.id_situacao End as id_situacao,
		ns.id_nfse,
		ns.nr_protocolo,
		n.cd_filial,
		(Select f.nm_fantasia from filial f where f.cd_filial = n.cd_filial) as nm_filial,
		n.de_especie,
		n.de_serie,
		ns.cd_servico,
		ns.de_servico,
		ns.vl_iss,
		ns.pc_aliquota_iss,
		ns.cd_verificacao,
		f.nr_cgc as nr_cnpj_prestador,
		'N' as id_selecionar
From pedido_ecommerce p
	inner join nf_venda n
		on n.cd_filial_ecommerce = p.cd_filial_ecommerce
		and n.nr_pedido_ecommerce = p.nr_pedido
    inner join pedido_ecommerce_auxiliar px on px.cd_filial_ecommerce = p.cd_filial_ecommerce and px.nr_pedido = p.nr_pedido
	left join nf_servico ns
		on ns.cd_filial = n.cd_filial
		and ns.nr_nf = n.nr_nf
		and ns.de_especie = n.de_especie
		and ns.de_serie = n.de_serie
	left join filial f on f.cd_filial = ns.cd_filial
where px.id_exige_nfse = 'S'
   and n.de_especie <> 'RPS'
   and n.nr_nf_anexa is null

UNION

Select p.nr_pedido_ecommerce,
		p.nr_pedido,
		n.dh_movimentacao_caixa as dh_compra,
		n.vl_total_nf as vl_total_pedido,
		(select sum(round(qt_pedida * vl_preco_promocao, 2)) from pedido_ecommerce_produto pp where pp.cd_filial_ecommerce = p.cd_filial_ecommerce and pp.nr_pedido = p.nr_pedido and pp.cd_produto = 684431) as vl_manipulado,
		n.nr_nf,
		ns.nr_nf_servico,
		ns.dh_emissao,
		Case When ns.id_situacao is null then 'P' else ns.id_situacao End as id_situacao,
		ns.id_nfse,
		ns.nr_protocolo,
		n.cd_filial,
		(Select f.nm_fantasia from filial f where f.cd_filial = n.cd_filial) as nm_filial,
		n.de_especie,
		n.de_serie,
		ns.cd_servico,
		ns.de_servico,
		ns.vl_iss,
		ns.pc_aliquota_iss,
		ns.cd_verificacao,
		f.nr_cgc as nr_cnpj_prestador,
		'N' as id_selecionar
From nf_venda n
inner join nf_servico ns
	on ns.cd_filial = n.cd_filial
	and ns.nr_nf = n.nr_nf
	and ns.de_especie = n.de_especie
	and ns.de_serie = n.de_serie
inner join filial f 
	on f.cd_filial = ns.cd_filial
left outer join pedido_ecommerce p 
		on p.cd_filial_ecommerce = n.cd_filial_ecommerce
		and p.nr_pedido = n.nr_pedido_ecommerce
left outer join pedido_ecommerce_auxiliar px 
	on px.cd_filial_ecommerce = p.cd_filial_ecommerce 
	and px.nr_pedido = p.nr_pedido
where n.de_especie = 'RPS'
   and n.nr_nf_anexa is null
" )
