table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_pedido_drogaexpress.cd_produto" )
 column=(type=char(255) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="produto_pedido_drogaexpress.qt_pedida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_tabela dbname="produto_pedido_drogaexpress.vl_preco_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_tabela dbname="produto_pedido_drogaexpress.pc_desconto_tabela" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_praticado dbname="produto_pedido_drogaexpress.vl_preco_praticado" )
 retrieve="Select p.cd_produto,
		coalesce(p.de_produto, g.de_produto + ':'  + de_apresentacao_venda) de_produto,
		p.qt_pedida,
		p.vl_preco_tabela,
		p.pc_desconto_tabela,
		p.vl_preco_praticado
From produto_pedido_drogaexpress p
inner join produto_geral g
	on g.cd_produto = p.cd_produto
where p.nr_pedido_drogaexpress = :ps_nr_pedido
order by coalesce(p.de_produto, g.de_produto + ':'  + de_apresentacao_venda),  p.nr_sequencial

" arguments=(("ps_nr_pedido", string)) )
