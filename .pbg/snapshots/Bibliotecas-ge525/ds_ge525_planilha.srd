table(column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="dh_inclusao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_inc_produto dbname="nr_matricula_inc_produto" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_inc_produto dbname="nm_usuario_inc_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionado dbname="id_selecionado" )
 column=(type=char(1) updatewhereclause=yes name=id_informa_lote_acordo dbname="id_informa_lote_acordo" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao_lote dbname="dh_inclusao_lote" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula dbname="nr_matricula" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_inc_lote dbname="nm_usuario_inc_lote" )
 column=(type=long updatewhereclause=yes name=cd_procedimento_acordo dbname="cd_procedimento_acordo" )
 column=(type=char(50) updatewhereclause=yes name=de_procedimento_acordo dbname="de_procedimento_acordo" )
 retrieve="Select	d.cd_distribuidora,
		f.nm_fantasia,
		d.cd_produto,
		g.de_produto + ' : ' + g.de_apresentacao_venda As de_produto,
		d.dh_inclusao,
		d.nr_matricula as nr_matricula_inc_produto,
		u.nm_usuario as nm_usuario_inc_produto,
		'N' As id_selecionado,
		Coalesce(f.id_informa_lote_acordo, 'S') As id_informa_lote_acordo,
		g.id_situacao,
		v.nr_lote,
		v.dh_inclusao as dh_inclusao_lote,
		v.nr_matricula,
		u2.nm_usuario as nm_usuario_inc_lote,
         coalesce(d.cd_procedimento_acordo,0) as cd_procedimento_acordo, 
		coalesce(d1.de_procedimento_acordo, 'SEM PROCEDIMENTO DEFINIDO') as de_procedimento_acordo 
From distribuidora_acordo_devolucao As d
	Inner Join fornecedor As f
		On f.cd_fornecedor = d.cd_distribuidora
	Inner Join produto_geral As g
		On g.cd_produto = d.cd_produto
	Left Outer Join usuario As u
		On u.nr_matricula = d.nr_matricula
	Left Outer Join distribuidora_acordo_validade As v
		On v.cd_distribuidora = d.cd_distribuidora
		And v.cd_produto = d.cd_produto
	Left Outer Join usuario As u2
		On u2.nr_matricula = v.nr_matricula
     Left Outer Join distribuidora_proced_acordo d1
		On d1.cd_procedimento_acordo = d.cd_procedimento_acordo 
Where (f.id_situacao Is Null Or f.id_situacao = 'A')"  sort="de_produto A nm_fantasia A " )
