table(column=(type=char(47) updatewhereclause=yes name=usuario dbname="usuario" )
 column=(type=char(19) updatewhereclause=yes name=nm_coluna dbname="nm_coluna" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao dbname="dh_alteracao" )
 column=(type=char(50) updatewhereclause=yes name=de_alteracao_de dbname="de_alteracao_de" )
 column=(type=char(50) updatewhereclause=yes name=de_alteracao_para dbname="de_alteracao_para" )
 column=(type=char(9) updatewhereclause=yes name=tipo dbname="tipo" )
 retrieve="select (b.nr_matricula+'-'+b.nm_usuario) as usuario, 
case a.nm_coluna 
          when 'CD_DISTRIBUIDORA' THEN 'MANUT. PROCEDIMENTO'
          when 'CD_PROCEDIMENTO_ACORDO' THEN 'MOTIVO ALTERACAO'
          end as nm_coluna,
          a.dh_alteracao , 
           case when a.nm_coluna = 'CD_DISTRIBUIDORA' then c.de_procedimento_acordo else '' end as de_alteracao_de ,          
          case when a.nm_coluna = 'CD_DISTRIBUIDORA' then c1.de_procedimento_acordo else '' end as de_alteracao_para ,
  case   a.id_alteracao 
  	when 'I' then 'INCLUSAO'
	when 'A' then 'ALTERACAO'
	when 'E' then 'EXCLUSAO'  end as tipo 
from dbo.historico_alteracao_tabela a
inner join usuario b on a.nr_matric_alteracao  = b.nr_matricula 
left join dbo.distribuidora_proced_acordo  c on c.cd_procedimento_acordo  =  cast (a.de_alteracao_de as int ) 
left join dbo.distribuidora_proced_acordo  c1 on c1.cd_procedimento_acordo  =  cast (a.de_alteracao_para as int )
where nm_tabela  = 'DISTRIBUIDORA_ACORDO_DEVOLUCAO'
and de_chave=:as_chave
" arguments=(("as_chave", string))  sort="dh_alteracao D " )
