table(column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="dh_inclusao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula dbname="nr_matricula" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="nm_usuario" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionado dbname="id_selecionado" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_informa_lote_acordo dbname="id_informa_lote_acordo" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="id_situacao" values="ATIVO	A/INATIVO	I/PENDENTE	P/" )
 column=(type=char(1) updatewhereclause=yes name=id_distribuidora dbname="id_distribuidora" )
 column=(type=char(50) updatewhereclause=yes name=de_procedimento_acordo dbname="de_procedimento_acordo" )
 column=(type=long updatewhereclause=yes name=cd_procedimento_acordo dbname="cd_procedimento_acordo" )
 retrieve="Select	d.cd_distribuidora,
		f.nm_fantasia,
		d.cd_produto,
		g.de_produto + ' : ' + g.de_apresentacao_venda As de_produto,
		d.dh_inclusao,
		d.nr_matricula,
		u.nm_usuario,
		'N' As id_selecionado,
		Coalesce(f.id_informa_lote_acordo, 'S') As id_informa_lote_acordo,
		g.id_situacao,
		coalesce(f.id_distribuidora, 'N') id_distribuidora,
		Coalesce(d1.de_procedimento_acordo,'SEM PROCEDIMENTO DEFINIDO') as de_procedimento_acordo,
         d.cd_procedimento_acordo
From distribuidora_acordo_devolucao As d
	Inner Join fornecedor As f
		On f.cd_fornecedor = d.cd_distribuidora
	Inner Join produto_geral As g
		On g.cd_produto = d.cd_produto
	Left Outer Join usuario As u
		On u.nr_matricula = d.nr_matricula
    Left  Join distribuidora_proced_acordo d1 on d1.cd_procedimento_acordo =  d.cd_procedimento_acordo
Where (f.id_situacao Is Null Or f.id_situacao = 'A')"  sort="de_produto A nm_fantasia A " )
