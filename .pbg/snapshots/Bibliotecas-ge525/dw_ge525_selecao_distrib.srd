table(column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionado dbname="id_selecionado" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionado_ant dbname="id_selecionado_ant" )
 column=(type=char(1) updatewhereclause=yes name=id_possui_lote dbname="id_possui_lote" )
 column=(type=char(1) updatewhereclause=yes name=id_informa_lote_acordo dbname="id_informa_lote_acordo" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_distribuidora dbname="id_distribuidora" values="	S/	N" )
 column=(type=long updatewhereclause=yes name=cd_procedimento_acordo dbname="cd_procedimento_acordo" )
 column=(type=long updatewhereclause=yes name=cd_procedimentoant dbname="cd_procedimentoant" )
 retrieve="Select	f.cd_fornecedor As cd_distribuidora,
		f.nm_fantasia,
		(Case
			when (Select Count(*)
				From distribuidora_acordo_devolucao As d
			Where d.cd_distribuidora = f.cd_fornecedor
			And d.cd_produto = :produto) > 0 Then 'S'
			Else 'N'
		End) As id_selecionado,

		(Case
			when (Select Count(*)
				From distribuidora_acordo_devolucao As d
			Where d.cd_distribuidora = f.cd_fornecedor
			And d.cd_produto = :produto) > 0 Then 'S'
			Else 'N'
		End) As id_selecionado_ant,

		(Case
			when (Select Count(*)
				From distribuidora_acordo_validade As d
			Where d.cd_distribuidora = f.cd_fornecedor
			And d.cd_produto = :produto) > 0 Then 'S'
			Else 'N'
		End) As id_possui_lote,
		Coalesce(f.id_informa_lote_acordo, 'S') As id_informa_lote_acordo,
		f.id_distribuidora,
		
         Case when (Select Count(*)
						From distribuidora_acordo_devolucao As d
					Where d.cd_distribuidora = f.cd_fornecedor
						And d.cd_produto = :produto) > 0 Then ( Select d1.cd_procedimento_acordo 
								                                                   From distribuidora_acordo_devolucao As d
                                              								      inner join distribuidora_proced_acordo d1 on d1.cd_procedimento_acordo  = d.cd_procedimento_acordo 
								                                                   Where d.cd_distribuidora = f.cd_fornecedor
								                                         And d.cd_produto = :produto)  	Else 0   	End As cd_procedimento_acordo,
		Case when (Select Count(*)
						From distribuidora_acordo_devolucao As d
					Where d.cd_distribuidora = f.cd_fornecedor
						And d.cd_produto = :produto) > 0 Then ( Select d1.cd_procedimento_acordo 
								  From distribuidora_acordo_devolucao As d
								  inner join distribuidora_proced_acordo d1 on d1.cd_procedimento_acordo  = d.cd_procedimento_acordo 
								  Where d.cd_distribuidora = f.cd_fornecedor
								  And d.cd_produto = :produto)  
		Else 0   	End As cd_procedimentoant
From fornecedor As f
Where (f.id_situacao Is Null Or f.id_situacao = 'A')
	And (f.id_distribuidora = 'S' Or Exists(Select 1
													From distribuidora_acordo_devolucao dad
													Where dad.cd_distribuidora = f.cd_fornecedor))" arguments=(("produto", number))  sort="nm_fantasia A " )
