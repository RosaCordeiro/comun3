table(column=(type=char(2) updatewhereclause=yes name=cd_uf dbname="ect_localidade.cd_uf" dbalias="ecl.cd_uf" )
 column=(type=char(72) updatewhereclause=yes name=de_localidade dbname="ect_localidade.de_localidade" dbalias="ecl.de_localidade" )
 column=(type=long updatewhereclause=yes key=yes name=nr_bairro dbname="ect_bairro.nr_bairro" dbalias="ecb.nr_bairro" )
 column=(type=char(72) updatewhereclause=yes name=de_bairro dbname="ect_bairro.de_bairro" dbalias="ecb.de_bairro" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_frete dbname="ect_bairro.vl_frete" dbalias="ecb.vl_frete" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_alteracao_frete dbname="ect_bairro.nr_matricula_alteracao_frete" dbalias="ecb.nr_matricula_alteracao_frete" )
 retrieve="select ecl.cd_uf,
         ecl.de_localidade,
         ecb.nr_bairro,
         ecb.de_bairro,
         ecb.vl_frete,
		ecb.nr_matricula_alteracao_frete
from ect_localidade ecl
inner join ect_bairro ecb
 on ecb.nr_localidade = ecl.nr_localidade
inner join cidade cid
 on cid.nr_localidade_ect = ecl.nr_localidade" update="ect_bairro" updatewhere=1 updatekeyinplace=yes  sort="cd_uf A de_localidade A de_bairro A " )
