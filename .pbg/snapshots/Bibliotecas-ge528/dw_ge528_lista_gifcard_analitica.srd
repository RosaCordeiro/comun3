table(column=(type=long updatewhereclause=yes name=cd_filial dbname="venda_cartao_gift.cd_filial" dbalias="a.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=char(60) updatewhereclause=yes name=nm_cartao dbname="cartao_gift.nm_cartao" dbalias="c.nm_cartao" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="venda_cartao_gift.nr_sequencial" dbalias="a.nr_sequencial" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao dbname="venda_cartao_gift.dh_movimentacao" dbalias="a.dh_movimentacao" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_comissao dbname="venda_cartao_gift.id_tipo_comissao" dbalias="a.id_tipo_comissao" values="DIGITAL	D/POSA	P/" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_comissao_posa dbname="cartao_gift_comissao.pc_comissao_posa" dbalias="b.pc_comissao_posa" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_comissao_digital dbname="cartao_gift_comissao.pc_comissao_digital" dbalias="b.pc_comissao_digital" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_transacao dbname="venda_cartao_gift.vl_transacao" dbalias="a.vl_transacao" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_receber dbname="vl_receber" )
 column=(type=char(30) updatewhereclause=yes name=gift_nr_cartao dbname="venda_cartao_gift.nr_cartao" dbalias="a.nr_cartao" )
 column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="venda_cartao_gift.cd_caixa" dbalias="a.cd_caixa" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="venda_cartao_gift.nr_controle_caixa" dbalias="a.nr_controle_caixa" )
 column=(type=long updatewhereclause=yes name=nr_lancamento_caixa dbname="venda_cartao_gift.nr_lancamento_caixa" dbalias="a.nr_lancamento_caixa" )
 column=(type=char(3) updatewhereclause=yes name=id_estorno dbname="id_estorno" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="d.nm_usuario" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_operador dbname="venda_cartao_gift.nr_matricula_operador" dbalias="a.nr_matricula_operador" )
 retrieve="select  a.cd_filial, 
      	 f.nm_fantasia,	  
		c.nm_cartao,
		a.nr_sequencial,
         a.dh_movimentacao, 
         a.id_tipo_comissao ,    
         b.pc_comissao_posa,
         b.pc_comissao_digital,
		a.vl_transacao,
		case when a.id_tipo_comissao  = 'D'   
			then ((vl_transacao * pc_comissao_digital)/100)
			else ((vl_transacao * pc_comissao_posa )/100) end as vl_receber,
		a.nr_cartao,
		a.cd_caixa,
		a.nr_controle_caixa,
		a.nr_lancamento_caixa,
		case when lc.id_estorno = 'X' then 'SIM' else 'N$$HEX1$$c300$$ENDHEX$$O' end as id_estorno,
		d.nm_usuario,
		a.nr_matricula_operador
from   venda_cartao_gift  a
left join cartao_gift_comissao b
    on b.cd_cartao = a.cd_cartao
inner join cartao_gift c
    on c.cd_cartao = a.cd_cartao        
inner join usuario d 
    on a.nr_matricula_operador = d.nr_matricula
left join lancamento_caixa lc
	on lc.cd_caixa = a.cd_caixa
	and lc.nr_controle_caixa = a.nr_controle_caixa
	and lc.nr_lancamento = a.nr_lancamento_caixa
inner join filial f 
	on f.cd_filial  = a.cd_filial
where  a.dh_movimentacao     between :dt_inicio  and :dt_fim
" arguments=(("dt_inicio", datetime),("dt_fim", datetime))  sort="dh_movimentacao A cd_filial A " )
