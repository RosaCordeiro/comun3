table(column=(type=long updatewhereclause=yes name=nr_id dbname="nr_id" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="dh_inicio" )
 column=(type=long updatewhereclause=yes name=nr_tolerancia dbname="nr_tolerancia" )
 column=(type=long updatewhereclause=yes name=nr_processo dbname="nr_processo" )
 column=(type=long updatewhereclause=yes name=nr_tempo dbname="nr_tempo" )
 column=(type=char(20) updatewhereclause=yes name=de_host dbname="de_host" )
 column=(type=char(50) updatewhereclause=yes name=de_tarefa dbname="de_tarefa" )
 retrieve="Select *
from
(
select eht.nr_id, eht.dh_inicio, t.nr_tolerancia/60  as nr_tolerancia, eht.nr_processo, datediff(mi,eht.dh_inicio,getdate( )) as nr_tempo, af.de_host,t.de_tarefa
from log_historico_tarefa eht
	left join tarefa t on (t.cd_tarefa = eht.cd_tarefa)
	left join agenda_tarefa af on (af.cd_tarefa = t.cd_tarefa)
where eht.dh_termino is null
and eht.nr_processo is not null
and eht.de_host = :ps_host
and t.nr_tolerancia > 0
and t.id_situacao = 'A'
and af.id_situacao = 'A'
and eht.cd_tarefa = :pi_tarefa
) Aux
Where Aux.nr_tempo > Aux.nr_tolerancia" arguments=(("ps_host", string),("pi_tarefa", number)) )
