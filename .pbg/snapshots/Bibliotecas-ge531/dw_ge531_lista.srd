table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=id_usa_poo_sitef dbname="id_usa_poo_sitef" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(40) updatewhereclause=yes name=vl_minimo_parametro dbname="vl_minimo_parametro" )
 column=(type=char(40) updatewhereclause=yes name=id_disque_entrega dbname="id_disque_entrega" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pedido_minimo_isento_frete dbname="vl_pedido_minimo_isento_frete" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_ped_min_isento_frete_ant dbname="vl_ped_min_isento_frete_ant" )
 retrieve="Select	f.cd_filial,
		f.nm_fantasia,
		Coalesce((Select p.vl_parametro From parametro_loja p Where p.cd_filial = f.cd_filial And p.cd_parametro = 'ID_USA_POO_SITEF'), 'N') As id_usa_poo_sitef,
		Coalesce((Select p.vl_parametro From parametro_loja p Where p.cd_filial = f.cd_filial And p.cd_parametro = 'VL_PEDIDO_MINIMO_ISENTO_FRETE'), '9999,00') As vl_minimo_parametro,
		Coalesce((Select p.vl_parametro From parametro_loja p Where p.cd_filial = f.cd_filial And p.cd_parametro = 'ID_DISQUE_ENTREGA' and p.vl_parametro = 'S'), 'N') As id_disque_entrega,
		0.00 As vl_pedido_minimo_isento_frete,
		0.00 As vl_ped_min_isento_frete_ant
From filial As f
	Inner Join parametro_odbc As o
		On o.cd_filial = f.cd_filial
Where f.id_situacao = 'A'
	And f.id_aberta = 'S'"  sort="nm_fantasia A " )
