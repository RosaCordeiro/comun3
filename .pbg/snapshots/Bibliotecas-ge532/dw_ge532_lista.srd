table(column=(type=char(40) updatewhereclause=yes name=nm_cidade dbname="cidade.nm_cidade" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cidade.cd_unidade_federacao" )
 column=(type=char(8) updatewhereclause=yes name=nr_cep dbname="ect_logradouro.nr_cep" )
 column=(type=char(100) updatewhereclause=yes name=de_logradouro dbname="ect_logradouro.de_logradouro" )
 column=(type=long updatewhereclause=yes name=nr_localidade dbname="ect_logradouro.nr_localidade" )
 column=(type=long updatewhereclause=yes name=nr_bairro dbname="ect_bairro.nr_bairro" )
 column=(type=char(72) updatewhereclause=yes name=de_bairro dbname="ect_bairro.de_bairro" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_frete dbname="ect_bairro.vl_frete" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 retrieve="select c.nm_cidade,
		c.cd_unidade_federacao, 
		l.nr_cep, 
		l.de_logradouro,
		l.nr_localidade, 
		b.nr_bairro, 
		b.de_bairro,
		b.vl_frete,
		dbo.uf_filial_parametro() as cd_filial
from ect_bairro b
inner join ect_logradouro l
    on l.nr_bairro = b.nr_bairro
inner join cidade c 
    on c.nr_localidade_ect = l.nr_localidade
where b.vl_frete > 0

Union all

select c.nm_cidade,
		c.cd_unidade_federacao, 
		a.nr_cep, 
		a.de_localidade as de_logradouro,
		a.nr_localidade, 
		b.nr_bairro, 
		b.de_bairro,
		b.vl_frete,
		dbo.uf_filial_parametro() as cd_filial
	from ect_localidade a
	inner join ect_bairro b 
			on b.nr_localidade = a.nr_localidade 
	inner join cidade c 
    on c.nr_localidade_ect = a.nr_localidade
where not exists ( select * from ect_logradouro l where l.nr_bairro = b.nr_bairro ) 
	and a.nr_cep is not null
order by 4
"  sort="nm_cidade A " )
