table(column=(type=datetime update=yes updatewhereclause=yes name=dh_alteracao dbname="historico_frete_bairro_filial.dh_alteracao" dbalias="h.dh_alteracao" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="historico_frete_bairro_filial.cd_filial" dbalias="h.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long update=yes updatewhereclause=yes name=nr_sequencial dbname="historico_frete_bairro_filial.nr_sequencial" dbalias="h.nr_sequencial" )
 column=(type=long update=yes updatewhereclause=yes name=nr_bairro dbname="historico_frete_bairro_filial.nr_bairro" dbalias="h.nr_bairro" )
 column=(type=char(72) updatewhereclause=yes name=de_bairro dbname="ect_bairro.de_bairro" dbalias="e.de_bairro" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_frete_de dbname="historico_frete_bairro_filial.vl_frete_de" dbalias="h.vl_frete_de" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vl_frete_para dbname="historico_frete_bairro_filial.vl_frete_para" dbalias="h.vl_frete_para" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_alteracao dbname="historico_frete_bairro_filial.nr_matricula_alteracao" dbalias="h.nr_matricula_alteracao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="u.nm_usuario" )
 retrieve="SELECT 	h.dh_alteracao,   
			h.cd_filial,  
			f.nm_fantasia, 
			h.nr_sequencial,   
			h.nr_bairro, 
			e.de_bairro,  
			h.vl_frete_de,   
			h.vl_frete_para, 
			h.nr_matricula_alteracao,
			u.nm_usuario
 FROM historico_frete_bairro_filial h
INNER JOIN filial f
    ON f.cd_filial = h.cd_filial  
INNER JOIN ect_bairro e
	ON e.nr_bairro = h.nr_bairro
INNER JOIN cidade cid
	ON cid.cd_cidade = f.cd_cidade
INNER JOIN parametro_loja p
	ON p.cd_filial = h.cd_filial
  AND p.cd_parametro = 'ID_DISQUE_ENTREGA'
LEFT OUTER JOIN usuario u
	ON u.nr_matricula = h.nr_matricula_alteracao
WHERE p.vl_parametro = 'S'
ORDER BY h.dh_alteracao, h.cd_filial, e.de_bairro

" )
