table(column=(type=char(9) update=yes updatewhereclause=yes name=cd_distribuidora dbname="distribuidora_produto.cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_distribuidora dbname="fornecedor.nm_razao_distribuidora" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="distribuidora_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(2) update=yes updatewhereclause=yes name=cd_unidade_federacao dbname="distribuidora_produto.cd_unidade_federacao" )
 column=(type=long updatewhereclause=yes name=qt_estoque_disponivel dbname="qt_estoque_disponivel" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_alteracao_situacao dbname="distribuidora_produto.dh_alteracao_situacao" )
 column=(type=char(40) updatewhereclause=yes name=de_alteracao_situacao dbname="distribuidora_produto.de_alteracao_situacao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_alteracao_situacao dbname="distribuidora_produto.nr_matric_alteracao_situacao" )
 column=(type=datetime updatewhereclause=yes name=dh_alteracao_situacao_termino dbname="distribuidora_produto.dh_alteracao_situacao_termino" )
 column=(type=char(40) updatewhereclause=yes name=usuario_nm_usuario dbname="usuario.nm_usuario" )
 retrieve="Select	d.cd_distribuidora,
		fd.nm_razao_social As nm_razao_distribuidora,
		d.cd_produto,
		g.de_produto + ' : ' + g.de_apresentacao_estoque As de_produto,
		d.cd_unidade_federacao,
		Coalesce(d.qt_estoque_disponivel, 0) As qt_estoque_disponivel,
		d.dh_alteracao_situacao,
		d.de_alteracao_situacao,
		d.nr_matric_alteracao_situacao,
		d.dh_alteracao_situacao_termino ,
		u.nm_usuario
From distribuidora_produto d
	inner join fornecedor fd
		on  fd.cd_fornecedor = d.cd_distribuidora
	inner join produto_geral g
		on g.cd_produto = d.cd_produto
	inner join distribuidora_uf df
		on df.cd_distribuidora = d.cd_distribuidora
		and df.cd_unidade_federacao = d.cd_unidade_federacao
	left join usuario u
		on u.nr_matricula = d.nr_matric_alteracao_situacao
		where d.id_situacao = 'B' 
	and d.dh_alteracao_situacao >= :inicio
	and d.dh_alteracao_situacao <= :termino
" arguments=(("inicio", datetime),("termino", datetime)) )
