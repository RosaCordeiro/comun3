table(column=(type=datetime updatewhereclause=yes name=dh_pedido dbname="dh_pedido" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="distribuidora_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_saldo_distrib dbname="qt_saldo_distrib" )
 column=(type=long updatewhereclause=yes name=qt_venda dbname="qt_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_ruptura dbname="pc_ruptura" )
 retrieve="select distinct dh_pedido = convert(datetime, '2099-01-01'), 
       d.cd_produto,
       g.de_produto || ' : ' || g.de_apresentacao_venda as de_produto,
       qt_saldo_distrib = 0,
       qt_venda = 0,
       pc_ruptura = 0.00
  from distribuidora_produto d
 inner join fornecedor f on f.cd_fornecedor = d.cd_distribuidora
 inner join produto_geral g on g.cd_produto = d.cd_produto
 inner join cidade c on c.cd_cidade = f.cd_cidade
 where f.id_situacao = 'A'
	and d.id_situacao = 'A'
	and f.id_distribuidora = 'S'
   and (select coalesce(sum(x.qt_venda - x.qt_devolucao_venda), 0) 
			 from resumo_movto_estq_prd x (index idx_data_produto)
			inner join filial fi on fi.cd_filial = x.cd_filial
			inner join cidade ci on ci.cd_cidade  = fi.cd_cidade
			where x.dh_resumo between :inicio and :termino
			  and x.cd_produto = d.cd_produto) > 0

" arguments=(("inicio", date),("termino", date)) )
