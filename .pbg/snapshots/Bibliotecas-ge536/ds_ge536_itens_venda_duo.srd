table(column=(type=long updatewhereclause=yes name=cd_filial dbname="venda_dermaclub_produto.cd_filial" dbalias="v.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="venda_dermaclub_produto.nr_nf" dbalias="v.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="venda_dermaclub_produto.de_especie" dbalias="v.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="venda_dermaclub_produto.de_serie" dbalias="v.de_serie" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="venda_dermaclub_produto.cd_produto" dbalias="v.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="qt_vendida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="venda_dermaclub_produto.vl_preco_unitario" dbalias="v.vl_preco_unitario" )
 column=(type=decimal(24) updatewhereclause=yes name=vl_praticado dbname="vl_praticado" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_total_praticado dbname="vl_total_praticado" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_desconto_dermaclub dbname="vl_desconto_dermaclub" )
 column=(type=long updatewhereclause=yes name=nr_campanha dbname="venda_dermaclub_produto.nr_campanha" dbalias="v.nr_campanha" )
 column=(type=char(1) updatewhereclause=yes name=id_dermaclub dbname="venda_dermaclub_produto.id_dermaclub" dbalias="v.id_dermaclub" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" dbalias="p.de_codigo_barras" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_total_desconto dbname="vl_total_desconto" )
 retrieve="SELECT
    v.cd_filial,
    v.nr_nf,
    v.de_especie,
    v.de_serie,
    v.cd_produto,
    SUM(v.qt_vendida)                                                                                            		AS qt_vendida,
    v.vl_preco_unitario,
    ( ( ( SUM(v.vl_praticado) * SUM(v.qt_vendida) ) / COUNT(*) ) / SUM(v.qt_vendida) )		AS vl_praticado,
    ( ( SUM(v.vl_praticado) * SUM(v.qt_vendida) ) / COUNT(*) )									AS vl_total_praticado,
    round((SUM(v.vl_desconto_dermaclub) / SUM(v.qt_vendida)), 2)         						AS vl_desconto_dermaclub,
    v.nr_campanha,
    v.id_dermaclub,
    p.de_codigo_barras,
    ( ( v.vl_preco_unitario * SUM(v.qt_vendida) ) - ( ( SUM(v.vl_praticado) * SUM(v.qt_vendida) ) / COUNT(*) ) ) AS vl_total_desconto
FROM venda_dermaclub_produto v
    INNER JOIN produto_geral p ON p.cd_produto = v.cd_produto
WHERE cd_filial =  :pl_filial
	AND nr_nf =:pl_nf
	AND de_especie = :ps_especie
	AND de_serie= :ps_serie   
GROUP BY
    v.cd_filial,
    v.nr_nf,
    v.de_especie,
    v.de_serie,
    v.cd_produto,
    v.vl_preco_unitario,
    v.nr_campanha,
    v.id_dermaclub,
    p.de_codigo_barras" arguments=(("pl_filial", number),("pl_nf", number),("ps_especie", string),("ps_serie", string)) )
