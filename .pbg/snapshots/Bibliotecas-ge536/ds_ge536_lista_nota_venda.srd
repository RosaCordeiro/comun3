table(column=(type=char(40) updatewhereclause=yes name=nr_cgc dbname="filial.nr_cgc" dbalias="fv.nr_cgc" )
 column=(type=char(2) updatewhereclause=yes name=cd_canal_venda dbname="cd_canal_venda" )
 column=(type=long updatewhereclause=yes name=nr_nsu_transacao dbname="venda_dermaclub.nr_nsu_transacao" dbalias="v.nr_nsu_transacao" )
 column=(type=long updatewhereclause=yes name=cd_filial_venda dbname="venda_dermaclub.cd_filial_venda" dbalias="v.cd_filial_venda" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="venda_dermaclub.nr_nf" dbalias="v.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="venda_dermaclub.de_especie" dbalias="v.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="venda_dermaclub.de_serie" dbalias="v.de_serie" )
 column=(type=char(15) updatewhereclause=yes name=nr_cpf_cgc dbname="cliente.nr_cpf_cgc" dbalias="c.nr_cpf_cgc" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_venda dbname="nf_venda.id_tipo_venda" dbalias="n.id_tipo_venda" )
 column=(type=char(2) updatewhereclause=yes name=cd_forma_pagamento dbname="nf_venda.cd_forma_pagamento" dbalias="n.cd_forma_pagamento" )
 retrieve="Select	fv.nr_cgc,
		'01' As cd_canal_venda,
		v.nr_nsu_transacao,
		v.cd_filial As cd_filial_venda,
		v.nr_nf,
		v.de_especie,
		v.de_serie,
		c.nr_cpf_cgc,
		n.id_tipo_venda,
		n.cd_forma_pagamento
From venda_dermaclub As v
	Inner Join nf_venda As n
		On n.cd_filial = v.cd_filial
		And n.nr_nf = v.nr_nf
		And n.de_especie = v.de_especie
		And n.de_serie = v.de_serie
	Inner Join filial As fv
		On fv.cd_filial = v.cd_filial
	Inner Join cliente As c
		On c.cd_cliente = n.cd_cliente
Where (v.id_enviada Is Null Or v.id_enviada = 'N')
	And n.dh_cancelamento Is Null
	And n.nr_pedido_ecommerce Is Null
	And coalesce(n.id_sistema_novo, 'N') <> 'S'

Union

Select	(Select vl_parametro From parametro_loja Where cd_parametro = 'NR_CNPJ_ECOMMERCE_DERMACLUB' And cd_filial = v.cd_filial) As nr_cgc,
		'02' As cd_canal_venda,
		v.nr_nsu_transacao,
		v.cd_filial As cd_filial_venda,
		v.nr_nf,
		v.de_especie,
		v.de_serie,
		c.nr_cpf_pbm As nr_cpf_cgc,
		n.id_tipo_venda,
		n.cd_forma_pagamento
From venda_dermaclub As v
	Inner Join nf_venda As n
		On n.cd_filial = v.cd_filial
		And n.nr_nf = v.nr_nf
		And n.de_especie = v.de_especie
		And n.de_serie = v.de_serie
	Inner Join filial As fv
		On fv.cd_filial = v.cd_filial
	Inner Join pedido_ecommerce_auxiliar As c
		On c.nr_pedido = n.nr_pedido_ecommerce
Where (v.id_enviada Is Null Or v.id_enviada = 'N')
	And n.dh_cancelamento Is Null
	And n.nr_pedido_ecommerce Is Not Null" )
