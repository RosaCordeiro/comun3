table(column=(type=char(1) updatewhereclause=yes name=id_tipo dbname="id_tipo" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc_dev dbname="filial.nr_cgc_dev" dbalias="fd.nr_cgc_dev" )
 column=(type=long updatewhereclause=yes name=nr_nsu_transacao dbname="venda_dermaclub.nr_nsu_transacao" dbalias="v.nr_nsu_transacao" )
 column=(type=long updatewhereclause=yes name=cd_filial_venda dbname="venda_dermaclub.cd_filial_venda" dbalias="v.cd_filial_venda" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="venda_dermaclub.nr_nf" dbalias="v.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="venda_dermaclub.de_especie" dbalias="v.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="venda_dermaclub.de_serie" dbalias="v.de_serie" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="venda_dermaclub_produto.cd_produto" dbalias="p.cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" dbalias="g.de_codigo_barras" )
 column=(type=long updatewhereclause=yes name=qt_devolvida dbname="item_nf_devolucao_venda.qt_devolvida" dbalias="i.qt_devolvida" )
 retrieve="Select	'D' As id_tipo,
		fd.nr_cgc As nr_cgc_dev,
		v.nr_nsu_transacao,
		v.cd_filial As cd_filial_venda,
		v.nr_nf,
		v.de_especie,
		v.de_serie,
		p.cd_produto,
		g.de_codigo_barras,
		i.qt_devolvida
From venda_dermaclub As v
	Inner Join venda_dermaclub_produto As p
		On p.cd_filial = v.cd_filial
		And p.nr_nf = v.nr_nf
		And p.de_especie = v.de_especie
		And p.de_serie = v.de_serie
	Inner Join nf_devolucao_venda As d
		On d.cd_filial_venda = v.cd_filial
		And d.nr_nf_venda = v.nr_nf
		And d.de_especie_venda = v.de_especie
		And d.de_serie_venda = v.de_serie
	Inner Join item_nf_devolucao_venda As i
		On i.cd_filial = d.cd_filial
		And i.nr_nf = d.nr_nf
		And i.de_especie = d.de_especie
		And i.de_serie = d.de_serie
		And i.cd_produto = p.cd_produto
	Inner Join produto_geral As g
		On g.cd_produto = p.cd_produto
	Inner Join filial As fd
		On fd.cd_filial = d.cd_filial
Where (v.id_devolucao_venda_enviada Is Null Or v.id_devolucao_venda_enviada = 'N')
	And d.dh_cancelamento Is Null
	And coalesce(d.id_sistema_novo, 'N') <> 'S'

Union

Select	'C' As id_tipo,
		fv.nr_cgc As nr_cgc_dev,
		v.nr_nsu_transacao,
		v.cd_filial As cd_filial_venda,
		v.nr_nf,
		v.de_especie,
		v.de_serie,
		p.cd_produto,
		g.de_codigo_barras,
		p.qt_vendida As qt_devolvida
From venda_dermaclub As v
	Inner Join venda_dermaclub_produto As p
		On p.cd_filial = v.cd_filial
		And p.nr_nf = v.nr_nf
		And p.de_especie = v.de_especie
		And p.de_serie = v.de_serie
	Inner Join nf_venda As n
		On n.cd_filial = v.cd_filial
		And n.nr_nf = v.nr_nf
		And n.de_especie = v.de_especie
		And n.de_serie = v.de_serie
	Inner Join produto_geral As g
		On g.cd_produto = p.cd_produto
	Inner Join filial As fv
		On fv.cd_filial = v.cd_filial
Where (v.id_devolucao_venda_enviada Is Null Or v.id_devolucao_venda_enviada = 'N')
	And n.dh_cancelamento Is Not Null
	And coalesce(n.id_sistema_novo, 'N') <> 'S'"  sort="nr_cgc_dev A nr_nf A " )
