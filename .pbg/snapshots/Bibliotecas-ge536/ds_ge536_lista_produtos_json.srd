table(column=(type=long updatewhereclause=yes name=nr_campanha dbname="dermaclub_campanha.nr_campanha" dbalias="c.nr_campanha" )
 column=(type=char(250) updatewhereclause=yes name=de_msg_cupom dbname="dermaclub_campanha.de_msg_cupom" dbalias="c.de_msg_cupom" )
 column=(type=char(2) updatewhereclause=yes name=cd_uf dbname="dermaclub_campanha.cd_uf" dbalias="c.cd_uf" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="codigo_barras_produto.cd_produto" dbalias="cb.cd_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto dbname="dermaclub_produto.vl_desconto" dbalias="p.vl_desconto" )
 column=(type=long updatewhereclause=yes name=cd_pbm dbname="pbm.cd_pbm" dbalias="pb.cd_pbm" )
 retrieve="Select	c.nr_campanha,
		c.de_msg_cupom,
		c.cd_uf,
		cb.cd_produto,
		p.vl_desconto,
		pb.cd_pbm
From dermaclub_campanha As c
	Inner Join dermaclub_produto As p
		On p.nr_campanha = c.nr_campanha
	Inner Join codigo_barras_produto As cb
		On cb.de_codigo_barras = p.de_codigo_barras
	Inner Join pbm As pb
		On coalesce(pb.cd_uf, '') = coalesce(c.cd_uf, '')
Where c.cd_canal_venda In ('TD', '01')
	And pb.id_tipo = 'D'

Union

Select c.nr_campanha,
		c.de_msg_cupom,
		c.cd_uf,
		cb.cd_produto,
		0.00 As vl_desconto,
		pb.cd_pbm
From dermaclub_campanha As c
	Inner Join dermaclub_desc_progressivo As p
		On p.nr_campanha = c.nr_campanha
	Inner Join codigo_barras_produto As cb
		On cb.de_codigo_barras = p.de_codigo_barras
	Inner Join pbm As pb
		On coalesce(pb.cd_uf, '') = coalesce(c.cd_uf, '')
Where c.cd_canal_venda In ('TD', '01')
	And pb.id_tipo = 'D'"  sort="nr_campanha A cd_produto A vl_desconto D " )
