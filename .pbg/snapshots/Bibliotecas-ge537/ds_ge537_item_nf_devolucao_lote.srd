table(column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="nf_devolucao_compra_prd_lote.cd_filial" dbalias="ndcpl.cd_filial" )
 column=(type=long update=yes updatewhereclause=yes name=nr_nf dbname="nf_devolucao_compra_prd_lote.nr_nf" dbalias="ndcpl.nr_nf" )
 column=(type=char(3) update=yes updatewhereclause=yes name=de_especie dbname="nf_devolucao_compra_prd_lote.de_especie" dbalias="ndcpl.de_especie" )
