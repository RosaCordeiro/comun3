 column=(type=char(20) update=yes updatewhereclause=yes name=nr_lote dbname="nf_devolucao_compra_prd_lote.nr_lote" dbalias="ndcpl.nr_lote" )
 column=(type=long update=yes updatewhereclause=yes name=qt_lote dbname="nf_devolucao_compra_prd_lote.qt_lote" dbalias="ndcpl.qt_lote" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_validade dbname="nf_devolucao_compra_prd_lote.dh_validade" dbalias="ndcpl.dh_validade" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="nf_devolucao_compra_produto.cd_produto" dbalias="ndcp.cd_produto" )
 retrieve="SELECT
	ndcpl.cd_filial,
	ndcpl.nr_nf,
	ndcpl.de_especie,
	ndcpl.de_serie,
	ndcpl.nr_item,
	ndcpl.nr_lote,
	ndcpl.qt_lote,
	ndcpl.dh_validade,
	ndcp.cd_produto
FROM
	nf_devolucao_compra_prd_lote	ndcpl
INNER JOIN
	nf_devolucao_compra_produto ndcp
	ON ndcpl.cd_filial	= ndcp.cd_filial
	AND ndcpl.nr_nf		= ndcp.nr_nf
	AND ndcpl.de_especie	= ndcp.de_especie
	AND ndcpl.de_serie	= ndcp.de_serie
	AND ndcpl.nr_item 	= ndcp.nr_item 
WHERE
	ndcpl.cd_filial		= :acd_filial
	AND ndcpl.nr_nf		= :anr_nf
	AND ndcpl.de_especie	= :ade_especie
	AND ndcpl.de_serie	= :ade_serie
	AND ndcpl.nr_item		= COALESCE(:anr_item, ndcpl.nr_item)" arguments=(("anr_nf", number),("ade_especie", string),("ade_serie", string),("acd_filial", number),("anr_item", number)) )
