table(column=(type=long updatewhereclause=yes name=qt_separada dbname="wms_transferencia_estoque_prd.qt_separada" dbalias="wtep.qt_separada" )
 column=(type=long updatewhereclause=yes name=qt_caixa_padrao dbname="wms_transferencia_estoque_prd.qt_caixa_padrao" dbalias="wtep.qt_caixa_padrao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_transferencia_estoque_prd.cd_produto" dbalias="wtep.cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="wms_transferencia_estoque_prd.nr_lote" dbalias="wtep.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="wms_transferencia_estoque_prd.dh_validade" dbalias="wtep.dh_validade" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="wms_transferencia_estoque.cd_filial_destino" dbalias="wte.cd_filial_destino" )
 retrieve="select 
	wtep.qt_separada,
	wtep.qt_caixa_padrao,
	wtep.cd_produto,
	wtep.nr_lote,
	wtep.dh_validade,
	wte.cd_filial_destino
from 
	dbo.wms_transferencia_estoque wte
inner join 
	dbo.wms_transferencia_estoque_prd wtep
	on wte.nr_transferencia = wtep.nr_transferencia 
where 
	wte.nr_pedido_distribuidora = :anr_pedido_distribuidora
	and wte.cd_filial_origem  = :acd_filial" arguments=(("anr_pedido_distribuidora", number),("acd_filial", number)) )
