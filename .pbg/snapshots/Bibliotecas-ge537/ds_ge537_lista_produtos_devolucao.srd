table(column=(type=long updatewhereclause=yes name=cd_produto dbname="nf_devolucao_compra_produto.cd_produto" dbalias="ndcp.cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="nf_devolucao_compra_prd_lote.nr_lote" dbalias="ndcpl.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="nf_devolucao_compra_prd_lote.dh_validade" dbalias="ndcpl.dh_validade" )
 column=(type=long updatewhereclause=yes name=qt_lote dbname="nf_devolucao_compra_prd_lote.qt_lote" dbalias="ndcpl.qt_lote" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" dbalias="pg.cd_grupo_psico" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="nf_devolucao_compra.cd_fornecedor" dbalias="ndc.cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=nr_nf_compra dbname="nf_devolucao_compra.nr_nf_compra" dbalias="ndc.nr_nf_compra" )
 column=(type=char(3) updatewhereclause=yes name=de_especie_compra dbname="nf_devolucao_compra.de_especie_compra" dbalias="ndc.de_especie_compra" )
 column=(type=char(3) updatewhereclause=yes name=de_serie_compra dbname="nf_devolucao_compra.de_serie_compra" dbalias="ndc.de_serie_compra" )
 column=(type=long updatewhereclause=yes name=cd_motivo_devolucao dbname="nf_devolucao_compra.cd_motivo_devolucao" dbalias="ndc.cd_motivo_devolucao" )
 column=(type=long updatewhereclause=yes name=nr_agrupamento_dev_compra dbname="nf_devolucao_compra.nr_agrupamento_dev_compra" dbalias="ndc.nr_agrupamento_dev_compra" )
 retrieve="	select ndcp.cd_produto,
			 ndcpl.nr_lote,
			 ndcpl.dh_validade,
			 ndcpl.qt_lote, 
			 pg.cd_grupo_psico,
			 ndc.cd_fornecedor, 
			 ndc.nr_nf_compra, 
			 ndc.de_especie_compra, 
			 ndc.de_serie_compra,
			 ndc.cd_motivo_devolucao,
			 ndc.nr_agrupamento_dev_compra
	  from nf_devolucao_compra ndc
	 inner join nf_devolucao_compra_produto ndcp 
				on ndcp.cd_filial 	= ndc.cd_filial 
			  and ndcp.nr_nf			= ndc.nr_nf 
			  and ndcp.de_especie 	= ndc.de_especie
			  and ndcp.de_serie		= ndc.de_serie
	 inner join nf_devolucao_compra_prd_lote ndcpl 
				on ndcpl.cd_filial 	= ndc.cd_filial 
			  and ndcpl.nr_nf 		= ndc.nr_nf  
			  and ndcpl.de_especie 	= ndc.de_especie  
			  and ndcpl.de_serie 	= ndc.de_serie  
			  and ndcpl.nr_item 		= ndcp.nr_item
	 inner join produto_geral pg 
				on pg.cd_produto	= ndcp.cd_produto
	 where ndc.cd_filial 	= :acd_filial
		and ndc.nr_nf 			= :anr_nf
		and ndc.de_especie 	= :ade_especie
		and ndc.de_serie 		= :ade_serie" arguments=(("acd_filial", number),("anr_nf", number),("ade_especie", string),("ade_serie", string)) )
