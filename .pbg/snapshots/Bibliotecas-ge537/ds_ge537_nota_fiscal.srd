table(column=(type=char(3) updatewhereclause=yes name=mandt dbname="mandt" )
 column=(type=long updatewhereclause=yes name=docnum dbname="j_1bnfdoc_1.docnum" dbalias="jdoc.docnum" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="j_1bnfdoc_1.nr_sequencial" dbalias="jdoc.nr_sequencial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(1) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="nr_cgc" )
 column=(type=char(4) updatewhereclause=yes name=cd_filial_sap dbname="j_1bnfdoc_1.cd_filial_sap" dbalias="jdoc.cd_filial_sap" )
 column=(type=char(10) updatewhereclause=yes name=cd_fornecedor_sap dbname="j_1bnfdoc_2.cd_fornecedor_sap" dbalias="jdoc2.cd_fornecedor_sap" )
 column=(type=char(10) updatewhereclause=yes name=cd_parceiro_sap dbname="j_1bnfdoc_2.cd_parceiro_sap" dbalias="jdoc2.cd_parceiro_sap" )
 column=(type=char(16384) updatewhereclause=yes name=modelo dbname="modelo" )
 column=(type=char(1) updatewhereclause=yes name=id_substituida dbname="j_1bnfdoc_1.id_substituida" dbalias="jdoc.id_substituida" )
 column=(type=char(1) updatewhereclause=yes name=id_estornado dbname="j_1bnfdoc_1.id_estornado" dbalias="jdoc.id_estornado" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_nf dbname="j_1bnfdoc_2.id_tipo_nf" dbalias="jdoc2.id_tipo_nf" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="j_1bnfdoc_1.id_situacao" dbalias="jdoc.id_situacao" )
 column=(type=char(44) updatewhereclause=yes name=nr_chave_acesso dbname="nr_chave_acesso" )
 column=(type=long updatewhereclause=yes name=qt_volume dbname="j_1bnfdoc_1.qt_volume" dbalias="jdoc.qt_volume" )
 column=(type=char(3) updatewhereclause=yes name=de_especie_volume dbname="j_1bnfdoc_2.de_especie_volume" dbalias="jdoc2.de_especie_volume" )
 column=(type=long updatewhereclause=yes name=nr_nota_chave_acesso dbname="nr_nota_chave_acesso" )
 column=(type=char(10) updatewhereclause=yes name=nr_documento_sap dbname="j_1bnfdoc_1.nr_documento_sap" dbalias="jdoc.nr_documento_sap" )
 column=(type=long updatewhereclause=yes name=nr_ano_documento_sap dbname="j_1bnfdoc_1.nr_ano_documento_sap" dbalias="jdoc.nr_ano_documento_sap" )
 column=(type=datetime updatewhereclause=yes name=credat dbname="j_1bnfdoc_1.credat" dbalias="jdoc.credat" )
 column=(type=char(6) updatewhereclause=yes name=cretim dbname="j_1bnfdoc_1.cretim" dbalias="jdoc.cretim" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_liquido dbname="j_1bnfdoc_1.qt_peso_liquido" dbalias="jdoc.qt_peso_liquido" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_bruto dbname="j_1bnfdoc_1.qt_peso_bruto" dbalias="jdoc.qt_peso_bruto" )
 column=(type=long updatewhereclause=yes name=docref dbname="j_1bnfdoc_1.docref" dbalias="jdoc.docref" )
 column=(type=char(15) updatewhereclause=yes name=nr_protocolo_envio dbname="nr_protocolo_envio" )
 column=(type=datetime updatewhereclause=yes name=dh_envio dbname="dh_envio" )
 column=(type=char(1) updatewhereclause=yes name=doc_finalidade dbname="j_1bnfdoc_1.doc_finalidade" dbalias="jdoc.doc_finalidade" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc_dest dbname="j_1bnfdoc_1.nr_cgc_dest" dbalias="jdoc.nr_cgc_dest" )
 column=(type=char(73) updatewhereclause=yes name=de_nome_dest dbname="de_nome_dest" )
 column=(type=char(18) updatewhereclause=yes name=nr_ie_dest dbname="j_1bnfdoc_2.nr_ie_dest" dbalias=".nr_ie_dest" )
 column=(type=char(3) updatewhereclause=yes name=cd_status_nfe dbname="j_1bnfdoc_1.cd_status_nfe" dbalias="jdoc.cd_status_nfe" )
 retrieve="	select top 50 jdoc.mandt,
			 jdoc.docnum,
			 jdoc.nr_sequencial,
			 coalesce(cast(jdoc2.nfenum as int), jdoc2.nfnum) as nr_nf,
			 RIGHT(coalesce(jdoc2.series, coalesce(jactive.serie, 'U')), 1) as de_serie,
			 cast('NFE' as char(3)) as de_especie,
			 cast(jdoc2.pstdat as DateTime) as dh_movimentacao_caixa,   
			 cast(jdoc.docdat as DateTime) as dh_emissao,   
			 coalesce(jdoc.nftot_alt, jdoc2.nftot) as vl_total_nf,
			 (case jdoc.cgc when '00000000000000' then 
			     jdoc.cpf 
			  else 
				  jdoc.cgc 
			  end) as nr_cgc,
			 jdoc.branch as cd_filial_sap,
			 jdoc2.parid as cd_fornecedor_sap,
			 jdoc2.parid as cd_parceiro_sap,
			 Replicate('0', (2 - len(cast( coalesce(jdoc2.model,90) as varchar)))) + cast(coalesce(jdoc2.model,90) as varchar(2)) as modelo,
			 jdoc.id_substituida,
			 jdoc.cancel as id_estornado,
			 jdoc2.nftype as id_tipo_nf,
			 jdoc.docstat as id_situacao,
			 jactive.regio || jactive.nfyear || jactive.nfmonth || jactive.stcd1 || cast(jactive.model as char(2)) || jactive.serie || jactive.nfnum9 || jactive.docnum9 || jactive.cdv as nr_chave_acesso,
			 jdoc.anzpk as qt_volume,
			 jdoc2.shpunt as de_especie_volume,
			 coalesce(cast(jactive.nfnum9 as int), 0) as nr_nota_chave_acesso,
			 jdoc.belnr as nr_documento_sap,
			 jdoc.gjahr as nr_ano_documento_sap,
			 jdoc.credat,
		    jdoc.cretim,
			 jdoc.brgew as qt_peso_liquido,
			 jdoc.brgew as qt_peso_bruto,
			 jdoc.docref,
			 CASE WHEN jdoc.code = '102' and jactive.authcod is null
			 	THEN jdoc.authcod 
			 	ELSE jactive.authcod 
			end as nr_protocolo_envio,
			 CASE WHEN jdoc.code = '102' and jactive.authdate is null
				 THEN jdoc.authdate 
				 ELSE jactive.authdate
			end as dh_envio,
			 jdoc.doctyp   as doc_finalidade,
			 jdoc.cgc  as nr_cgc_dest,
			 jdoc2.name1 + ' - ' + jdoc2.name2 as de_nome_dest,
			 stains as nr_ie_dest,
			 jdoc.code as cd_status_nfe
	  from j_1bnfdoc_1 as jdoc inner join j_1bnfdoc_2 as jdoc2 on jdoc2.mandt				= jdoc.mandt and 
																					  jdoc2.docnum 		 	= jdoc.docnum and 
																					  jdoc2.nr_sequencial 	= jdoc.nr_sequencial
										left outer join j_1bnfe_active as jactive on jactive.mandt				= jdoc.mandt and 
																								   jactive.docnum 		 	= jdoc.docnum and 
																								   jactive.nr_sequencial 	= jdoc.nr_sequencial
		left outer join filial fi on fi.nr_cgc = jdoc.cgc
	  where jdoc2.nftype		in ('A1', 'YP', 'YB', 'ZA', 'Z6', 'YC', 'YA', 'YU', 'ZI', 'ZS', 'Z4', 'ZV', 'ZF', 'ZM', 'ZJ', 'Z2', 'YY', 'YH', 'LE', 'SM', 'SC', 'RC', 'S5', 'CM') and
			  jdoc.dh_inclusao >= '20210813' and
			  jdoc.id_substituida = 'N' and
			  Coalesce(fi.cd_filial, 0) <> 1 and
			  Coalesce(fi.id_situacao, 'A') = 'A'
 order by jdoc.mandt, 
			coalesce(fi.nr_prioridade_faturamento, 1),
		    jdoc.docnum asc, 
		    jdoc.nr_sequencial" )
