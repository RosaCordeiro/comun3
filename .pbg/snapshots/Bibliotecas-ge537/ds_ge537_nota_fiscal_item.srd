				j.lppbrt,
				j.lppnet,
				j.maktx,
				j.matkl,
				j.matnr as cd_produto_sap,
				j.matorg as cd_cst_origem,
				j.matuse,
				j.meins,
				j.meins_trib,
				j.menge as qt_produto,
				j.menge_trib,
				j.modbc,
				j.modbcst,
