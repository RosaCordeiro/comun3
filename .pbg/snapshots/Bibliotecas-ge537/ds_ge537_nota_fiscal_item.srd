				j.netwr,
				j.netwrt,
				j.nfci,
				j.nfdis,
				j.nffre,
				j.nficmsdeson,
				j.nfins,
				j.nfnet,
				j.nfnett,
				coalesce(j.nfnet - j.nfdis, 0) as vl_total_item,
				coalesce(j.nfoth, 0) as nfoth,
				j.nfpri as vl_preco_unitario,
				j.nitemped,
				j.nplnr,
				j.nprocesso,
				j.nrecopi,
				j.num_item,
				j.ownpro,
				j.pfcpstret,
				j.picmsefet,
				j.pipidevol,
				j.prctr,
				j.predbcefet,
				j.pst,
				j.ps_psp_pnr,
				j.p_mvast,
				j.qselo,
				j.refitm,
				j.refitm_prev,
				j.refkey,
				j.refkey_prev,
				j.reftyp,
				j.reftyp_prev,
				j.segment,
				j.spcsto,
				j.srvnr,
				j.statit,
				j.ststcl_vicmsdeson,
				j.subtavr,
				j.subtvalp,
				j.taxlw1,
				j.taxlw2,
				j.taxlw3,
				j.taxlw4,
				j.taxlw5,
				j.taxsi2,
				j.taxsi3,
				j.taxsi4 as cd_cst_cofins,
				j.taxsi5 as cd_cst_pis,
				case j.taxsit when 'A' then '41' when 'B' then '51' else j.taxsit||'0' end as cd_cst_tributacao, 
				j.tax_info_source,
				j.tax_rate,
				j.tmiss,
				j.utrib,
				j.vbcefet,
				j.vbcfcpstret,
				j.vbcstdest,
				j.vbcstret,
				j.vdespadu,
				j.vfcpstret,
				j.vicmsdeson,
				j.vicmsdif,
				j.vicmsefet,
				j.vicmsstdest,
				j.vicmsstret,
				j.vicmssubstituto,
				j.viof,
				j.vtottrib,
				j.werks,
				j.xped,
				j.xprod,
				coalesce(j.nfoth_alt, 0) nfoth_alt,
				j.cclasstrib,
				j.cst,
				j.cclasstribreg,
				j.cstreg
		 from j_1bnflin j
	   where j.mandt 				= :ps_mandt and 
			   j.docnum 			= :pl_docnum and 
				j.nr_sequencial 	= :pl_sequencial" arguments=(("ps_mandt", string),("pl_docnum", number),("pl_sequencial", number)) )
