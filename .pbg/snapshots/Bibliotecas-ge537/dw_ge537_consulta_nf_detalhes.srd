table(column=(type=char(11) updatewhereclause=yes name=cd_forn_cliente dbname="cd_forn_cliente" )
 column=(type=char(40) updatewhereclause=yes name=nm_forn_cliente dbname="nm_forn_cliente" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="j_1bnfdoc_2.vl_total_nf" dbalias="jdoc2.vl_total_nf" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="de_chave_acesso" )
 column=(type=char(5000) updatewhereclause=yes name=cd_filial_sap dbname="cd_filial_sap" )
 column=(type=char(120) updatewhereclause=yes name=nm_filial dbname="nm_filial" )
 column=(type=char(120) updatewhereclause=yes name=de_motivo_devolucao dbname="de_motivo_devolucao" )
 column=(type=char(2) updatewhereclause=yes name=nftype dbname="j_1bnfdoc_2.nftype" dbalias="jdoc2.nftype" )
 column=(type=long updatewhereclause=yes name=docref dbname="j_1bnfdoc_1.docref" dbalias="jdoc.docref" )
 column=(type=decimal(2) updatewhereclause=yes name=nftot_alt dbname="j_1bnfdoc_1.nftot_alt" dbalias="jdoc.nftot_alt" )
 column=(type=char(3) updatewhereclause=yes name=mandt dbname="j_1bnfdoc_1.mandt" dbalias="jdoc.mandt" )
 column=(type=long updatewhereclause=yes name=docnum dbname="j_1bnfdoc_1.docnum" dbalias="jdoc.docnum" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="j_1bnfdoc_1.nr_sequencial" dbalias="jdoc.nr_sequencial" )
 retrieve="	select coalesce(f.cd_fornecedor, c.cd_cliente) cd_forn_cliente,
			 //dbo.removeZerosEsquerda( jdoc2.parid) as cd_fornecedor_sap,
//			 cast('' as varchar(120)) as nm_fornecedor,
			 coalesce(f.nm_fantasia, c.nm_cliente) nm_forn_cliente,
			 coalesce(cast(jdoc2.nfenum as int), jdoc2.nfnum) as nr_nf,
			 cast('NFE' as char(3)) as de_especie,
			 coalesce(jdoc2.series, 'U') as de_serie,
			 cast(jdoc2.pstdat as DateTime) as dh_movimentacao_caixa,
			 jdoc2.nftot as vl_total_nf,
			 jactive.regio || jactive.nfyear || jactive.nfmonth || jactive.stcd1 || cast(jactive.model as char(2)) || jactive.serie || jactive.nfnum9 || jactive.docnum9 || jactive.cdv as de_chave_acesso,
			  dbo.removeZerosEsquerda(jdoc.branch) as cd_filial_sap,
			 cast('' as varchar(120)) as nm_filial,
			 cast('' as varchar(120)) as de_motivo_devolucao,
			 jdoc2.nftype,
			 jdoc.docref,
			 jdoc.nftot_alt,
			 jdoc.mandt,
		    jdoc.docnum,
		    jdoc.nr_sequencial
	  from j_1bnfdoc_1 as jdoc inner join j_1bnfdoc_2 as jdoc2 on jdoc2.mandt				= jdoc.mandt and 
																					  jdoc2.docnum 		 	= jdoc.docnum and 
																					  jdoc2.nr_sequencial 	= jdoc.nr_sequencial
										left outer join j_1bnfe_active as jactive on jactive.mandt				= jdoc.mandt and 
																									jactive.docnum 		 	= jdoc.docnum and 
																									jactive.nr_sequencial 	= jdoc.nr_sequencial
										left outer join fornecedor as f on f.cd_fornecedor_sap =  dbo.removeZerosEsquerda(jdoc2.parid)
										left outer join cliente as c on c.cd_cliente_sap =  dbo.removeZerosEsquerda(jdoc2.parid)										
	 where jdoc.mandt 			= :amandt and
		    jdoc.docnum 			= :adocnum and
		    jdoc.nr_sequencial	= :anr_sequencial" arguments=(("amandt", string),("adocnum", number),("anr_sequencial", number)) )
