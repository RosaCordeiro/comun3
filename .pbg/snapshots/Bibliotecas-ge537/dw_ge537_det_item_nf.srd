table(column=(type=char(30) updatewhereclause=yes name=contrato dbname="j_1bnflin.contrato" dbalias="j.contrato" )
 column=(type=char(5000) updatewhereclause=yes name=cd_produto_sap dbname="cd_produto_sap" )
 column=(type=char(40) updatewhereclause=yes name=de_produto_sap dbname="j_1bnflin.de_produto_sap" dbalias="j.de_produto_sap" )
 column=(type=char(1) updatewhereclause=yes name=cd_situacao_tributaria dbname="j_1bnflin.cd_situacao_tributaria" dbalias="j.cd_situacao_tributaria" )
 column=(type=long updatewhereclause=yes name=qt_devolvida dbname="j_1bnflin.qt_devolvida" dbalias="j.qt_devolvida" )
 column=(type=decimal(6) updatewhereclause=yes name=vl_preco_unitario dbname="j_1bnflin.vl_preco_unitario" dbalias="j.vl_preco_unitario" )
 column=(type=decimal(25) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=long updatewhereclause=yes key=yes name=itmnum dbname="j_1bnflin.itmnum" dbalias="j.itmnum" )
 column=(type=char(30) updatewhereclause=yes name=contrato dbname="j_1bnflin.contrato" dbalias="j.contrato" )
 column=(type=char(15) updatewhereclause=yes name=nr_pedido dbname="j_1bnflin.nr_pedido" dbalias="j.nr_pedido" )
 column=(type=decimal(2) updatewhereclause=yes name=nfnett_alt dbname="j_1bnflin.nfnett_alt" dbalias="j.nfnett_alt" )
 column=(type=decimal(2) updatewhereclause=yes name=nfoth_alt dbname="j_1bnflin.nfoth_alt" dbalias="j.nfoth_alt" )
 column=(type=char(3) updatewhereclause=yes key=yes name=mandt dbname="j_1bnflin.mandt" dbalias="j.mandt" )
 column=(type=long updatewhereclause=yes key=yes name=docnum dbname="j_1bnflin.docnum" dbalias="j.docnum" )
 column=(type=long updatewhereclause=yes key=yes name=nr_sequencial dbname="j_1bnflin.nr_sequencial" dbalias="j.nr_sequencial" )
 column=(type=long updatewhereclause=yes name=itmnum dbname="j_1bnflin.itmnum" dbalias="j.itmnum" )
 retrieve="	select j.contrato,
		    dbo.removeZerosEsquerda(j.matnr) as cd_produto_sap,
			 j.maktx as de_produto_sap,
			 j.taxsit as cd_situacao_tributaria,
			 j.menge as qt_devolvida,
			 j.nfpri as vl_preco_unitario,
			 j.netdis/j.nfpri as pc_desconto,
			 j.itmnum,
			 j.contrato,
			 j.xped as nr_pedido,
			 j.nfnett_alt, 
			 j.nfoth_alt,
			 j.mandt,
			 j.docnum,
			 j.nr_sequencial,
			 j.itmnum
	  from j_1bnflin j
	 where j.mandt				= :amandt and
		    j.docnum			= :adocnum and
			 j.nr_sequencial 	= :anr_sequencial" update="j_1bnflin" updatewhere=0 updatekeyinplace=no arguments=(("amandt", string),("adocnum", number),("anr_sequencial", number)) )
