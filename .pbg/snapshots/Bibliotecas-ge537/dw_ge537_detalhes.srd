table(column=(type=char(3) updatewhereclause=yes name=de_banco dbname="de_banco" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" dbalias="f.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=docnum dbname="j_1bnfdoc_1.docnum" dbalias="jdoc.docnum" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_documento dbname="categoria_nf_sap.de_tipo_documento" dbalias="ca.de_tipo_documento" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(10) updatewhereclause=yes name=nr_documento_sap dbname="j_1bnfdoc_1.nr_documento_sap" dbalias="jdoc.nr_documento_sap" )
 column=(type=long updatewhereclause=yes name=nr_documento_sap_estornado dbname="nr_documento_sap_estornado" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="j_1bnfdoc_1.dh_inclusao" dbalias="jdoc.dh_inclusao" )
 column=(type=datetime updatewhereclause=yes name=dh_documento dbname="j_1bnfdoc_1.dh_documento" dbalias="jdoc.dh_documento" )
 column=(type=char(1) updatewhereclause=yes name=dh_estornado_sap dbname="dh_estornado_sap" )
 column=(type=char(1) updatewhereclause=yes name=de_erro_cabecalho dbname="de_erro_cabecalho" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_status_integracao dbname="id_status_integracao" )
 column=(type=long updatewhereclause=yes name=qt_erros_itens dbname="qt_erros_itens" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_nf dbname="id_tipo_nf" )
 column=(type=char(1) updatewhereclause=yes name=id_estornado_excluido dbname="id_estornado_excluido" )
 column=(type=char(2) updatewhereclause=yes name=nftype dbname="j_1bnfdoc_2.nftype" dbalias="jdoc2.nftype" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="j_1bnfdoc_2.nr_sequencial" dbalias="jdoc2.nr_sequencial" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="nr_cgc" )
 column=(type=char(4) updatewhereclause=yes name=filial_sap dbname="j_1bnfdoc_1.filial_sap" dbalias="jdoc.filial_sap" )
 column=(type=char(10) updatewhereclause=yes name=cd_fornecedor_sap dbname="j_1bnfdoc_2.cd_fornecedor_sap" dbalias="jdoc2.cd_fornecedor_sap" )
 column=(type=char(3) updatewhereclause=yes name=mandt dbname="j_1bnfdoc_1.mandt" dbalias="jdoc.mandt" )
 column=(type=char(13) updatewhereclause=yes name=sit_log dbname="sit_log" )
 column=(type=char(1) updatewhereclause=yes name=id_status dbname="id_status" )
 column=(type=datetime updatewhereclause=yes name=dta_lancto dbname="j_1bnfdoc_2.dta_lancto" dbalias="jdoc2.dta_lancto" )
 column=(type=char(212) updatewhereclause=yes name=observacao dbname="observacao" )
 column=(type=char(2) updatewhereclause=yes name=nftype dbname="j_1bnfdoc_2.nftype" dbalias=".nftype" )
 retrieve="select distinct
		 'SYB' as de_banco,
		 f.cd_filial as cd_filial,
		 f.nm_fantasia,
		 jdoc.docnum,   
		 ca.de_categoria as de_tipo_documento,
		 coalesce(cast(jdoc2.nfenum as int), jdoc2.nfnum) as nr_nf,
		 coalesce(jdoc2.series, 'U') as de_serie,
		 cast('NFE' as char(3)) as de_especie,
		 jdoc.belnr as nr_documento_sap,
		 0 as nr_documento_sap_estornado,
		 jdoc.dh_inclusao as dh_inclusao, 
		 jdoc.docdat as dh_documento,
		 '' as dh_estornado_sap,
		 '' as de_erro_cabecalho,
		 'N' as id_selecionar,
		 'P' as id_status_integracao,
		 0 as qt_erros_itens,
		 '' as id_tipo_nf,
		 '' as	id_estornado_excluido,
       jdoc2.nftype,
		 jdoc2.nr_sequencial	as nr_sequencial,
		 (case jdoc.cgc when '00000000000000' then 
			     jdoc.cpf 
			  else 
				  jdoc.cgc 
			  end) as nr_cgc,
  		 jdoc.branch				as filial_sap,
		 jdoc2.parid as cd_fornecedor_sap,
   	 jdoc.mandt				as mandt,
		 (Case coalesce(jdoc.id_status,'C') when 'E' then 'ERRO' 
                  									  when 'P' then 'FINALIZADO'   
                                               else 'N$$HEX1$$c300$$ENDHEX$$O INTEGRADO' End) as sit_log,
       coalesce(jdoc.id_status,'C') as id_status,
       jdoc2.pstdat as dta_lancto,
       (Case coalesce(jdoc.cancel,'N') when 'X' then 'Estornado - ' + coalesce(jdoc.de_log,'')
													else coalesce(jdoc.de_log,'') End) as observacao  ,
	nftype
  from j_1bnfdoc_1 jdoc inner join j_1bnfdoc_2  jdoc2 on jdoc2.mandt 			= jdoc.mandt and 
																			jdoc2.docnum 			= jdoc.docnum and 
																			jdoc2.nr_sequencial 	= jdoc.nr_sequencial
								inner join integracao_sap isap on isap.cd_tabela 		= 'FILIAL' and 
																			 isap.cd_empresa 		= 1000 and 
																			 isap.cd_chave_sap 	= jdoc.branch
								inner join filial f on f.cd_filial = cast(isap.cd_chave_legado as int)
								left outer join categoria_nf_sap ca on (ca.cd_categoria = jdoc2.nftype)
 where jdoc.bukrs           					= cast(:pi_empresa as char) 
	and coalesce(jdoc.id_substituida, 'N')	= 'N'

" arguments=(("pi_empresa", number))  sort="docnum D " )
