 retrieve="SELECT '{' + 
           + ' ‾"fecha‾": '  + '‾"' + CAST( vda.dh_emissao AS VARCHAR(30) ) + '‾", '  
		   + ' ‾"numero‾": ' + '‾"' + CAST( vda.nr_nf AS VARCHAR(15) ) + '‾", ' 
		   + ' ‾"descuentoTotal‾": ' +  CAST(vda.vl_total_produtos - ( abs(vl_preco_unitario - vl_preco_praticado) / qt_vendida ) AS VARCHAR(20) ) + ', ' 
		   + ' ‾"recargoTotal‾": ' +  CAST( abs(vl_preco_unitario - vl_preco_praticado) AS VARCHAR(20) )  + ', '
		   + ' ‾"codigoMoneda‾": ' + '‾"986‾", '
		   + ' ‾"cotizacion‾": ' + '0.00, '
		   + ' ‾"total‾": ' +  CAST(( abs(vl_preco_unitario - vl_preco_praticado) / qt_vendida ) + abs(vl_preco_unitario - vl_preco_praticado) AS VARCHAR(20) ) + ', '
		   + ' ‾"cancelation‾": ' + 'false, '
		   + ' ‾"documentoCliente‾": ' + 'null, '
		   + ' ‾"codigoCanalVenta‾": ' + '0, '
		   + ' ‾"detalhes‾": ' 
		   + ' [ { '
		         + ' ‾"codigoArticulo‾": ' + '‾"' + CAST(inv.cd_produto AS VARCHAR(15) ) + '‾", '
				 + ' ‾"codigobBarras‾": ' + '‾"' + CAST(( select count(1) from codigo_barras_produto where  cd_produto = inv.cd_produto and id_principal_sap = 'S' ) AS VARCHAR(50) ) + '‾", '
				 + ' ‾"descriptionArticulo‾": ' + '‾"' + CAST(( select de_produto from produto_geral where cd_produto = inv.cd_produto ) AS VARCHAR(100) ) + '‾", '
				 + ' ‾"cantidad‾": ' + CAST(inv.qt_vendida AS VARCHAR(10) ) + ', '
				 + ' ‾"importeUnit$$HEX1$$e100$$ENDHEX$$rio‾": ' + CAST(inv.vl_preco_unitario AS VARCHAR(20) ) + ', '
				 + ' ‾"importe‾": ' + CAST(inv.vl_preco_unitario AS VARCHAR(20) ) + ', '
				 + ' ‾"descuento‾": ' + CAST(( vl_preco_praticado * inv.qt_vendida ) AS VARCHAR(20) ) + ', '
				 + ' ‾"recargo‾": ' + '0.00, '
           + ' } ], '
		   + ' ‾"pagos‾": ' 
		   + ' [ { '  
		         + ' ‾"codigoTipoPago‾": ' + CAST(vda.cd_forma_pagamento AS VARCHAR(15) ) + ', '                     -- Fazer um de para
				 + ' ‾"codigoMoneda‾": ' + '‾"986‾", '
				 + ' ‾"importe‾": ' + CAST(( select sum(vl_total_nf) from nf_venda where cd_filial = 149 and nr_nf = 6047126 ) AS VARCHAR(20) ) + ', '
				 + ' ‾"cotizacion‾": ' + '0.00, '
				 + ' ‾"documentoCliente‾": ' + 'null, '
                 + ' ‾"bin‾": ' + 'null, '
				 + ' ‾"numeroAutorizacion‾": ' + 'null, '
				 + ' ‾"ultimosDigitosTarjeta‾": ' + 'null, '
				 + ' ‾"codigoTarjeta‾": ' + 'null, '
				 + ' ‾"importe‾": ' + 'null '
		   + ' } ] ' +
       '}'   JSON
FROM item_nf_venda inv
  , nf_venda vda
WHERE vda.cd_filial = inv.cd_filial
  AND vda.nr_nf     = inv.nr_nf
  AND inv.cd_filial = 149
  AND inv.nr_nf     = 6047126   
" )
