table(column=(type=char(15) updatewhereclause=yes name=codigoarticulo dbname="codigoArticulo" )
 column=(type=char(50) updatewhereclause=yes name=codigobarras dbname="codigoBarras" )
 column=(type=char(1) updatewhereclause=yes name=codigobarras dbname="" )
 column=(type=char(10) updatewhereclause=yes name=cantidad dbname="cantidad" )
 column=(type=char(18) updatewhereclause=yes name=importeunitario dbname="importeUnitario" )
 column=(type=char(18) updatewhereclause=yes name=importe dbname="importe" )
 column=(type=char(18) updatewhereclause=yes name=descuento dbname="descuento" )
 column=(type=char(18) updatewhereclause=yes name=recargo dbname="recargo" )
 column=(type=decimal(2) updatewhereclause=yes name=valor dbname="valor" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="item_nf_venda.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_praticado dbname="item_nf_venda.vl_preco_praticado" )
 retrieve=" SELECT   CAST(inv.cd_produto AS VARCHAR(15) ) codigoArticulo
           ,   CAST( cbp.de_codigo_barras AS VARCHAR(50) )    codigoBarras
	      , ''
	      , CAST(inv.qt_vendida AS VARCHAR(10) )    cantidad
          ,  CAST( CAST( round(inv.vl_preco_unitario ,2) AS NUMERIC(18,2) ) AS VARCHAR(18) )  importeUnitario
	     ,  CAST( CAST( round(( round(vl_preco_praticado,2) * round(qt_vendida,2) ),2)  AS NUMERIC(18,2) ) AS VARCHAR(18) )  importe
	     ,  CAST( CAST ( ( (round(vl_preco_unitario,2) - round(vl_preco_praticado,2)) * round(qt_vendida,2))  AS NUMERIC(18,2 ) ) AS VARCHAR(18) ) descuento
         , CAST( 0.00 AS VARCHAR(18) )  recargo
         ,   ( round(vl_preco_praticado,2) * round(qt_vendida,2) ) valor
         , vl_preco_unitario
         , vl_preco_praticado
              FROM item_nf_venda inv noholdlock LEFT JOIN central.dbo.codigo_barras_produto cbp noholdlock ON inv.cd_produto   = cbp.cd_produto AND
                                                                                                                 id_principal_sap = 'S'                    AND
                                                                                                                 id_principal        = 'S'
                                              
                                                                                                                  
             WHERE nr_nf =:pl_nr_nf
               AND cd_filial =:pl_cd_filial
               AND de_especie =:ps_de_especie
               AND de_serie =:ps_de_serie   
" arguments=(("pl_cd_filial", number),("pl_nr_nf", number),("ps_de_especie", string),("ps_de_serie", string)) )
