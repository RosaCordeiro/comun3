table(column=(type=char(32) update=yes updatewhereclause=yes name=cd_chave_movimento dbname="cd_chave_movimento" )
 column=(type=char(50) updatewhereclause=yes name=id_lote dbname="id_lote" )
 column=(type=decimal(0) updatewhereclause=yes identity=yes name=nr_atualizacao dbname="nr_atualizacao" )
 column=(type=char(40) updatewhereclause=yes name=cd_chave dbname="cd_chave" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(30) updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_envio dbname="id_tipo_envio" )
 column=(type=datetime updatewhereclause=yes name=dh_envio dbname="dh_envio" )
 column=(type=char(1) updatewhereclause=yes name=log_exportacao_scanntech_id_situacao dbname="id_situacao" )
 column=(type=char(200) updatewhereclause=yes name=de_erro dbname="de_erro" )
 column=(type=char(6) updatewhereclause=yes name=nr_arquivo dbname="nr_arquivo" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=char(18) updatewhereclause=yes name=total dbname="total" )
 column=(type=char(2) updatewhereclause=yes name=codigotipopago dbname="codigoTipoPago" )
 column=(type=char(20) updatewhereclause=yes name=importe dbname="importe" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_produtos dbname="vl_total_produtos" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelado dbname="dh_cancelado" )
 column=(type=decimal(2) updatewhereclause=yes name=valor dbname="valor" )
 column=(type=char(2) updatewhereclause=yes name=cd_form_pagto dbname="log_exportacao_scanntech.cd_form_pagto" dbalias=".cd_form_pagto" )
 retrieve="  SELECT top 300 les.cd_chave_movimento,
         les.id_lote,   
         les.nr_atualizacao,   
         les.cd_chave,   
         les.cd_filial,   
         str_replace ( Convert(varchar(10), les.dh_movimentacao_caixa ,121) , '/','-') + 'T' + Convert(varchar(10), les.dh_movimentacao_caixa ,8) + '.000-0300' dh_movimentacao_caixa,   
         les.id_tipo_envio,   
         les.dh_envio,   
         les.id_situacao,   
         les.de_erro,   
         les.nr_arquivo,   
         les.nr_nf,   
         les.de_especie,   
         les.de_serie,   
         CAST( round(ISNULL(vl_total_nf + vl_desconto_nf,0),2) AS VARCHAR(18) ) total,   
         CAST ( CASE WHEN cd_forma_pagamento IN ( 'DI' , 'CV', 'CC','MF','CR' ) THEN 9 
                             WHEN cd_forma_pagamento = 'CP' THEN 10 
                             WHEN cd_forma_pagamento IN ( 'HA', 'HP') THEN 11 
                             WHEN cd_forma_pagamento = 'CA' THEN 13
                             ELSE 0 END AS VARCHAR(2) ) codigoTipoPago,   
         CAST( CAST(round(ISNULL(vl_total_nf + vl_desconto_nf ,0),2) AS NUMERIC(18,2) ) AS VARCHAR(20) ) importe,   
         les.pc_desconto,   
         les.vl_total_produtos,   
         les.vl_total_nf,   
         les.dh_cancelado,   
         round(ISNULL(vl_total_nf,0),2) valor  ,
         cd_forma_pagamento    cd_form_pagto
    FROM log_exportacao_scanntech les  noholdlock
   WHERE ( les.id_situacao = 'P' ) 
       AND ( les.id_tipo_envio = 'V' ) 
       AND ( les.de_especie IN ('CF','NFC','SAT', 'NFE')  )
       AND ( les.cd_filial = :pl_cd_filial  ) 
       AND les.cd_chave_movimento is null 
       AND les.id_lote is null
       AND ( les.dh_movimentacao_caixa BETWEEN :pdh_data_1 AND :pdh_data_2  )   
ORDER BY les.cd_filial ASC
             ,  les.nr_nf ASC   
" arguments=(("pl_cd_filial", number),("pdh_data_1", datetime),("pdh_data_2", datetime)) )
