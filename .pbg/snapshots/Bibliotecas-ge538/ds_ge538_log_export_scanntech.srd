table(column=(type=datetime updatewhereclause=yes name=datamovimento dbname="log_exportacao_scanntech.DataMovimento" dbalias=".DataMovimento" )
 column=(type=char(10) updatewhereclause=yes name=tipo dbname="Tipo" )
 column=(type=long updatewhereclause=yes name=qtd dbname="QTD" )
 retrieve="SELECT dh_movimentacao_caixa as DataMovimento
     , case id_tipo_envio when 'F' then 'Fechamento' else 'Venda' end as Tipo
     , count(*) as QTD
  FROM log_exportacao_scanntech
 WHERE id_situacao = 'P'
 AND dh_movimentacao_caixa >= DATEADD(DAY, -5, :adt_param)
 GROUP BY dh_movimentacao_caixa
        , id_tipo_envio
        " arguments=(("adt_param", datetime)) )
