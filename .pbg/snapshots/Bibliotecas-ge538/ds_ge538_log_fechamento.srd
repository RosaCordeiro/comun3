table(column=(type=char(18) updatewhereclause=yes name=montoventaliquida dbname="montoVentaLiquida" )
 column=(type=char(18) updatewhereclause=yes name=montocancelaciones dbname="montoCancelaciones" )
 column=(type=long updatewhereclause=yes name=cantidadmovimientos dbname="cantidadMovimientos" )
 column=(type=datetime updatewhereclause=yes name=fechaventas dbname="fechaVentas" )
 column=(type=long updatewhereclause=yes name=cantidadcancelaciones dbname="cantidadCancelaciones" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 retrieve="
SELECT CAST( A.VALOR AS VARCHAR(18) )  montoVentaLiquida
          , CAST( ISNULL(round(B.VALOR,2), 0)  AS VARCHAR(18) ) montoCancelaciones
          ,  ( A.CONTADOR + ISNULL(B.CONTADOR,0) ) cantidadMovimientos
          ,   A.dh_movimentacao_caixa fechaVentas
          , ISNULL(B.CONTADOR,0) cantidadCancelaciones
          , A.cd_filial
 FROM (
         SELECT 'VENDAS'        TIPO
              , v.cd_filial     cd_filial
              , SUM(round(v.vl_total_nf + v.vl_desconto_nf ,2))  VALOR  //-+ v.vl_desconto_nf
              , COUNT(v.nr_nf)       CONTADOR
              , v.dh_movimentacao_caixa
           FROM log_exportacao_scanntech v
          WHERE v.cd_filial = :pl_cd_filial
             AND v.dh_movimentacao_caixa BETWEEN :pdt_fechamento1 AND :pdt_fechamento2
            AND v.de_especie IN ('CF','NFC','SAT', 'NFE')
            AND v.dh_cancelado is null
            AND v.id_tipo_envio = 'V'
            AND v.id_situacao = 'S'
          GROUP BY v.cd_filial, v.dh_movimentacao_caixa ) A  LEFT JOIN
       ( SELECT 'CANCELAMENTOS' TIPO
               , v.cd_filial     cd_filial
               , sum(round(v.vl_total_nf + v.vl_desconto_nf ,2))   VALOR  // + v.vl_desconto_nf
               , COUNT(v.nr_nf)       CONTADOR
               , v.dh_movimentacao_caixa
            FROM log_exportacao_scanntech v
           WHERE v.cd_filial = :pl_cd_filial
               AND v.dh_movimentacao_caixa BETWEEN :pdt_fechamento1 AND :pdt_fechamento2
               AND v.de_especie in ('CF','NFC', 'SAT', 'NFE')
               AND v.dh_cancelado <> null
               AND v.id_tipo_envio = 'V'
               AND v.id_situacao = 'S' 
           GROUP BY v.cd_filial, v.dh_movimentacao_caixa ) B  ON A.dh_movimentacao_caixa = B.dh_movimentacao_caixa AND
                                                                                           A.cd_filial                          = B.cd_filial
" arguments=(("pl_cd_filial", number),("pdt_fechamento1", datetime),("pdt_fechamento2", datetime)) )
