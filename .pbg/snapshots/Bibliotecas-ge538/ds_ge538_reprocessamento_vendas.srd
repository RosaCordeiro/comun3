table(column=(type=long updatewhereclause=yes name=cd_filial dbname="log_exportacao_scanntech.cd_filial" dbalias=".cd_filial" )
 column=(type=char(6) updatewhereclause=yes name=log_exportacao_scanntech_loja_cd_filial_scanntech dbname="log_exportacao_scanntech_loja.cd_filial_scanntech" dbalias=".cd_filial_scanntech" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="filial.nm_fantasia" dbalias=".nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="log_exportacao_scanntech.dh_movimentacao_caixa" dbalias=".dh_movimentacao_caixa" )
 column=(type=datetime updatewhereclause=yes name=log_exportacao_scanntech_dh_envio dbname="log_exportacao_scanntech.dh_envio" dbalias=".dh_envio" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="log_exportacao_scanntech.id_situacao" dbalias=".id_situacao" )
 column=(type=datetime updatewhereclause=yes name=log_exportacao_scanntech_dh_cancelado dbname="log_exportacao_scanntech.dh_cancelado" dbalias=".dh_cancelado" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="log_exportacao_scanntech.nr_nf" dbalias=".nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=log_exportacao_scanntech_de_especie dbname="log_exportacao_scanntech.de_especie" dbalias=".de_especie" )
 column=(type=char(3) updatewhereclause=yes name=log_exportacao_scanntech_de_serie dbname="log_exportacao_scanntech.de_serie" dbalias=".de_serie" )
 column=(type=char(200) updatewhereclause=yes name=log_exportacao_scanntech_de_erro dbname="log_exportacao_scanntech.de_erro" dbalias=".de_erro" )
 column=(type=char(2) updatewhereclause=yes name=log_exportacao_scanntech_cd_forma_pagamento dbname="log_exportacao_scanntech.cd_forma_pagamento" dbalias=".cd_forma_pagamento" )
 column=(type=char(2) updatewhereclause=yes name=id_tipo_envio dbname="log_exportacao_scanntech.id_tipo_envio" dbalias=".id_tipo_envio" )
 column=(type=char(1) updatewhereclause=yes name=id_processado dbname="id_processado" )
 retrieve="  SELECT log_exportacao_scanntech.cd_filial,   
         log_exportacao_scanntech_loja.cd_filial_scanntech,   
         filial.nm_fantasia,   
         log_exportacao_scanntech.dh_movimentacao_caixa,   
         log_exportacao_scanntech.dh_envio,   
         log_exportacao_scanntech.id_situacao,   
         log_exportacao_scanntech.dh_cancelado,   
         log_exportacao_scanntech.nr_nf,   
         log_exportacao_scanntech.de_especie,   
         log_exportacao_scanntech.de_serie,   
         log_exportacao_scanntech.de_erro,   
         log_exportacao_scanntech.cd_forma_pagamento,   
         log_exportacao_scanntech.id_tipo_envio,
         (CASE WHEN  log_exportacao_scanntech.id_situacao = 'S'  THEN 'S' 
                              ELSE 'N' 
                      END )  id_processado
  FROM log_exportacao_scanntech  INNER JOIN filial ON  filial.cd_filial = log_exportacao_scanntech.cd_filial       
                                   LEFT JOIN  log_exportacao_scanntech_loja  ON  log_exportacao_scanntech.cd_filial = log_exportacao_scanntech_loja.cd_filial   
   WHERE  log_exportacao_scanntech.dh_movimentacao_caixa BETWEEN :pdt_data1 AND :pdt_data2
       AND log_exportacao_scanntech.id_tipo_envio = 'V'
       AND log_exportacao_scanntech.id_situacao = 'P' 
order by  log_exportacao_scanntech.id_situacao asc, log_exportacao_scanntech.cd_filial asc 
" arguments=(("pdt_data1", datetime),("pdt_data2", datetime)) )
