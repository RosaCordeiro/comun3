table(column=(type=char(10) updatewhereclause=yes name=nr_recebimento dbname="recebimento_sap.nr_recebimento" dbalias="r.nr_recebimento" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="recebimento_sap.dh_emissao" dbalias="r.dh_emissao" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="fornecedor.cd_fornecedor" dbalias="f.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" dbalias="f.nm_razao_social" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="recebimento_sap.nr_pedido" dbalias="r.nr_pedido" )
 column=(type=char(1) updatewhereclause=yes name=id_status dbname="recebimento_sap.id_status" dbalias="r.id_status" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="recebimento_sap.id_situacao" dbalias="r.id_situacao" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="recebimento_sap.de_chave_acesso" dbalias="r.de_chave_acesso" )
 column=(type=char(10) updatewhereclause=yes name=id_situacao_descricao dbname="id_situacao_descricao" )
 column=(type=datetime updatewhereclause=yes name=dh_integrada dbname="recebimento_sap.dh_integrada" dbalias="r.dh_integrada" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" values="	S/	N" )
 column=(type=datetime updatewhereclause=yes name=dh_recebimento dbname="recebimento_sap.dh_recebimento" dbalias="r.dh_recebimento" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso_alterada dbname="recebimento_sap.de_chave_acesso_alterada" dbalias="r.de_chave_acesso_alterada" )
 retrieve="select r.nr_recebimento,
		 r.dh_inclusao as dh_emissao,
		 f.cd_fornecedor,
		 f.nm_razao_social,
		 r.nr_pedido,
		 r.id_status,
		 r.id_situacao,
		 r.de_chave_acesso,
		 (Case r.id_situacao when 'C' then 'PENDENTE' 
                           when 'P' then 'FINALIZADO'    
								   when 'X' then 'CANCELADO'   	
									when 'E' then 'ERRO' End) as id_situacao_descricao,
		 r.dh_nf_agend_ent_integrada as dh_integrada,
		 'N' as id_selecionar,
		 r.dh_recebimento,
		 r.de_chave_acesso_alterada
  from recebimento_sap as r inner join fornecedor as f on f.cd_fornecedor = r.cd_fornecedor 
 where 1 = 1" arguments=(("pi_empresa", number)) )
