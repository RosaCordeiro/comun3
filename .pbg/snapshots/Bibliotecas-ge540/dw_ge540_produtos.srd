table(column=(type=long updatewhereclause=yes name=nr_item dbname="recebimento_sap_item.nr_item" dbalias="ri.nr_item" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="recebimento_sap_item.cd_produto" dbalias="ri.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="recebimento_sap_item.qt_recebida" dbalias="ri.qt_recebida" )
 column=(type=char(4) updatewhereclause=yes name=cd_unidade_medida dbname="recebimento_sap_item.cd_unidade_medida" dbalias="ri.cd_unidade_medida" )
 column=(type=char(10) updatewhereclause=yes name=nr_recebimento dbname="recebimento_sap_item.nr_recebimento" dbalias="ri.nr_recebimento" )
 retrieve="select ri.nr_item,
		 ri.cd_produto,
		 pg.de_produto + ' : ' + pg.de_apresentacao_estoque as de_produto,
		 ri.qt_recebida,
		 ri.cd_unidade_medida,
		 ri.nr_recebimento
  from recebimento_sap_item as ri inner join produto_geral as pg on ri.cd_produto = pg.cd_produto
 where ri.nr_recebimento	= :as_nr_recebimento
" arguments=(("as_nr_recebimento", string)) )
