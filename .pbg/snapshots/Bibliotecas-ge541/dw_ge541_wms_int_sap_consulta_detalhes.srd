table(column=(type=datetime updatewhereclause=yes name=dh_envio_sap dbname="wms_int_sap.dh_envio_sap" dbalias="w.dh_envio_sap" )
 column=(type=datetime updatewhereclause=yes name=dh_retorno_sap dbname="wms_int_sap.dh_retorno_sap" dbalias="w.dh_retorno_sap" )
 column=(type=char(20) updatewhereclause=yes name=nr_documento_sap dbname="wms_int_sap.nr_documento_sap" dbalias="w.nr_documento_sap" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="wms_int_sap.nr_nf" dbalias="w.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="wms_int_sap.de_especie" dbalias="w.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="wms_int_sap.de_serie" dbalias="w.de_serie" )
 column=(type=char(9) updatewhereclause=yes name=cd_transportadora dbname="wms_int_sap.cd_transportadora" dbalias="w.cd_transportadora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="transportadora.nm_fantasia" dbalias="t.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_agrupamento_dev_compra dbname="wms_int_sap.nr_agrupamento_dev_compra" dbalias="w.nr_agrupamento_dev_compra" )
 column=(type=decimal(3) updatewhereclause=yes name=qt_peso_liquido dbname="wms_int_sap.qt_peso_liquido" dbalias="w.qt_peso_liquido" )
 column=(type=char(20) updatewhereclause=yes name=de_especie_volume dbname="wms_int_sap.de_especie_volume" dbalias="w.de_especie_volume" )
 column=(type=char(20) updatewhereclause=yes name=nr_volume dbname="wms_int_sap.nr_volume" dbalias="w.nr_volume" )
 column=(type=char(20) updatewhereclause=yes name=de_marca_volume dbname="wms_int_sap.de_marca_volume" dbalias="w.de_marca_volume" )
 column=(type=long updatewhereclause=yes name=qt_volume dbname="wms_int_sap.qt_volume" dbalias="w.qt_volume" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo_devolucao dbname="motivo_devolucao_compra.de_motivo_devolucao" dbalias="m.de_motivo_devolucao" )
 column=(type=char(250) updatewhereclause=yes name=de_dados_adicionais dbname="wms_int_sap.de_dados_adicionais" dbalias="w.de_dados_adicionais" )
 column=(type=char(50) updatewhereclause=yes name=cd_chave_interface dbname="wms_int_sap.cd_chave_interface" dbalias="w.cd_chave_interface" )
 column=(type=char(10) updatewhereclause=yes name=cd_chave dbname="cd_chave" )
 column=(type=char(100) updatewhereclause=yes name=de_erro dbname="de_erro" )
 column=(type=long updatewhereclause=yes name=cd_motivo_devolucao dbname="motivo_devolucao_compra.cd_motivo_devolucao" dbalias="m.cd_motivo_devolucao" )
 retrieve="	select w.dh_envio_sap,
			 w.dh_retorno_sap, 
			 w.nr_documento_sap, 
			 w.nr_nf, 
			 w.de_especie, 
			 w.de_serie, 
		    w.cd_transportadora, 
			 t.nm_fantasia, 
			 w.nr_agrupamento_dev_compra, 
			 w.qt_peso_liquido, 
			 w.de_especie_volume, 
			 w.nr_volume, 
			 w.de_marca_volume, 
			 w.qt_volume, 
			 m.de_motivo_devolucao,
		    w.de_dados_adicionais,
			 w.cd_chave_interface,
			 convert(varchar(10), w.nr_integracao) as cd_chave,
			 cast('' as varchar(100)) as de_erro,
			m.cd_motivo_devolucao
     from wms_int_sap w left outer join motivo_devolucao_compra m on m.cd_motivo_devolucao = w.cd_motivo_devolucao
							   left outer join transportadora t on t.cd_transportadora = cast(w.cd_transportadora as integer)
	 where w.nr_integracao	= :anr_integracao" arguments=(("anr_integracao", number)) )
