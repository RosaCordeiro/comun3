table(column=(type=decimal(0) updatewhereclause=yes name=nr_integracao dbname="nr_integracao" )
 column=(type=long updatewhereclause=yes name=cd_tipo dbname="cd_tipo" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(10) updatewhereclause=yes name=id_situacao_descricao dbname="id_situacao_descricao" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="dh_inclusao" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo dbname="de_tipo" )
 column=(type=char(50) updatewhereclause=yes name=cd_chave_interface dbname="cd_chave_interface" )
 column=(type=long updatewhereclause=yes name=qt_produtos dbname="qt_produtos" )
 retrieve="select w.nr_integracao, 
		 w.cd_tipo, 
		 f.cd_fornecedor, 
		 f.nm_fantasia, 
		w.nr_nf,
	    (Case w.id_situacao when 'I' then 'INTEGRADO' 
                          when 'C' then 'COLOCADO'    
                          when 'E' then 'ERRO'
					    when 'X' then 'CANCELADO'
								  when 'P' then 'PROCESSADO' End) as id_situacao_descricao,
		 w.id_situacao, 
		 w.dh_inclusao,
		 tipo.de_tipo,
		 w.cd_chave_interface,
		 (select count(*) from wms_int_sap_detalhe x where x.nr_integracao = w.nr_integracao) qt_produtos
  from wms_int_sap w 
  left outer join fornecedor f on f.cd_fornecedor = w.cd_fornecedor
  left outer join wms_tipo_documento_int_sap tipo on tipo.cd_tipo = w.cd_tipo
 where 1 = 1" )
