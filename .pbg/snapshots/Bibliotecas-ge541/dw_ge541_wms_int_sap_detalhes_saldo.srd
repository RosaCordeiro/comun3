table(column=(type=datetime updatewhereclause=yes name=dh_envio_sap dbname="wms_int_sap.dh_envio_sap" dbalias="w.dh_envio_sap" )
 column=(type=datetime updatewhereclause=yes name=dh_retorno_sap dbname="wms_int_sap.dh_retorno_sap" dbalias="w.dh_retorno_sap" )
 column=(type=char(4) updatewhereclause=yes name=cd_deposito dbname="wms_int_sap.cd_deposito" dbalias="w.cd_deposito" )
 column=(type=char(3) updatewhereclause=yes name=id_somente_com_saldo dbname="id_somente_com_saldo" )
 column=(type=char(10) updatewhereclause=yes name=cd_chave dbname="cd_chave" )
 column=(type=char(100) updatewhereclause=yes name=de_erro dbname="de_erro" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="p.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="p.de_produto" )
 retrieve="	select w.dh_envio_sap,
			 w.dh_retorno_sap,
			 w.cd_deposito,
			 case w.id_somente_com_saldo when 'S' then 'Sim' else 'N$$HEX1$$e300$$ENDHEX$$o' end as id_somente_com_saldo,
			 convert(varchar(10), w.nr_integracao) as cd_chave,
			 cast('' as varchar(100)) as de_erro,
			 p.cd_produto,
			 p.de_produto
     from wms_int_sap w left outer join produto_geral p on p.cd_produto	= w.cd_produto
	 where w.nr_integracao	= :anr_integracao" arguments=(("anr_integracao", number)) )
