table(column=(type=long updatewhereclause=yes name=nr_sequencial dbname="nr_sequencial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="cd_produto_sap" )
 column=(type=char(100) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="nr_lote" )
 column=(type=long updatewhereclause=yes name=qt_lote dbname="qt_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_fabricacao dbname="dh_fabricacao" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="dh_validade" )
 column=(type=char(2) updatewhereclause=yes name=desc_situacao dbname="desc_situacao" )
 column=(type=char(1) updatewhereclause=yes name=id_reajustado dbname="id_reajustado" )
 column=(type=long updatewhereclause=yes name=qt_nf_dev dbname="qt_nf_dev" )
 retrieve="SELECT     wisd.nr_sequencial,
           wisd.cd_produto,
		  pg.cd_produto_sap,
           pg.de_produto + pg.de_apresentacao_estoque de_produto,
           wisd.nr_lote,
           wisd.qt_lote,
           wisd.dh_fabricacao,
           wisd.dh_validade,
           CASE
                      WHEN ndcp.cd_produto NOT IN
                                 (
                                        SELECT xndcp.cd_produto
                                        FROM   nf_devolucao_compra_produto xndcp
                                        WHERE  xndcp.nr_nf = wis.nr_nf
                                        AND    xndcp.de_especie = wis.de_especie
                                        AND    xndcp.de_serie = wis.de_serie
                                        AND    xndcp.cd_filial= wis.cd_filial
                                        AND    xndcp.cd_produto = wisd.cd_produto ) THEN 'FP' -- falta produto
                      WHEN
                                 (		SELECT   Sum(zndcp.qt_devolvida)
                                          FROM     nf_devolucao_compra_produto zndcp
                                          WHERE    zndcp.nr_nf = wis.nr_nf
                                          AND      zndcp.de_especie = wis.de_especie
                                          AND      zndcp.de_serie = wis.de_serie
                                          AND      zndcp.cd_produto = wisd.cd_produto
                                          GROUP BY zndcp.cd_produto ) 
                                 <>
                                 (		SELECT   Sum(xwisd.qt_lote)
                                          FROM     wms_int_sap_detalhe xwisd
                                          WHERE    xwisd.nr_integracao = wis.nr_integracao
                                          AND      xwisd.cd_produto = wisd.cd_produto
                                          GROUP BY xwisd.cd_produto ) THEN 'DP' --- diverg$$HEX1$$ea00$$ENDHEX$$ncia qt Produto
                      ELSE 'SD'                                             --- sem diverg$$HEX1$$ea00$$ENDHEX$$ncia
           END AS desc_situacao,
			coalesce(wisd.id_reajustado, 'N') id_reajustado,
			coalesce((		SELECT   Sum(yndcp.qt_devolvida)
                                          FROM     nf_devolucao_compra_produto yndcp
                                          WHERE    yndcp.nr_nf = wis.nr_nf
                                          AND      yndcp.de_especie = wis.de_especie
                                          AND      yndcp.de_serie = wis.de_serie
                                          AND      yndcp.cd_produto = wisd.cd_produto
                                          AND 	   yndcp.nr_item = wisd.nr_sequencial 
                                          GROUP BY yndcp.cd_produto ), 0) as qt_nf_dev
FROM       wms_int_sap_detalhe wisd
INNER JOIN produto_geral pg
ON         pg.cd_produto = wisd.cd_produto
INNER JOIN wms_int_sap wis
ON         wis.nr_integracao = wisd.nr_integracao
LEFT JOIN  dbo.nf_devolucao_compra_produto ndcp
ON         ndcp.nr_nf = wis.nr_nf
AND        ndcp.de_especie = wis.de_especie
AND        ndcp.de_serie = wis.de_serie
AND        ndcp.cd_filial = wis.cd_filial
AND 	   	ndcp.nr_item = wisd.nr_sequencial 
AND        ndcp.cd_produto = wisd.cd_produto
WHERE wisd.nr_integracao	= :anr_integracao
" arguments=(("anr_integracao", number)) )
