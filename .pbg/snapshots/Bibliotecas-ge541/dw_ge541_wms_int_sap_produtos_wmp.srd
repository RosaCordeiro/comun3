table(column=(type=long updatewhereclause=yes name=nr_sequencial dbname="wms_int_sap_detalhe.nr_sequencial" )
 column=(type=char(4) updatewhereclause=yes name=cd_deposito_sap_entrada dbname="wms_int_sap_detalhe.cd_deposito_sap_entrada" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_int_sap_detalhe.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_lote dbname="qt_lote" )
 column=(type=long updatewhereclause=yes name=qt_saldo_legado dbname="qt_saldo_legado" )
 column=(type=long updatewhereclause=yes name=qt_diferenca dbname="qt_diferenca" )
 retrieve="select w.nr_sequencial,
		 w.cd_deposito_sap_entrada,
		 w.cd_produto,
		 coalesce(w.de_erro,pg.de_produto||' : '||coalesce(pg.de_apresentacao_estoque,'')) as de_produto,
		 coalesce(w.qt_lote,0) as qt_lote,
		 coalesce(w.qt_saldo_legado,0) as qt_saldo_legado,
		 coalesce(w.qt_lote,0) - coalesce(w.qt_saldo_legado,0) as qt_diferenca
  from wms_int_sap_detalhe w 
  inner join produto_geral pg on pg.cd_produto = w.cd_produto
 where w.nr_integracao	= :anr_integracao" arguments=(("anr_integracao", number)) )
