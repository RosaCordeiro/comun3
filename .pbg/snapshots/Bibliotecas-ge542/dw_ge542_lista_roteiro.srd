table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="roteiro_parametro.cd_filial" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=id_parametro dbname="roteiro_parametro.id_parametro" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_horario_corte dbname="roteiro_parametro.dh_horario_corte" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_horario_saida dbname="roteiro_parametro.dh_horario_saida" )
 column=(type=char(40) update=yes updatewhereclause=yes name=de_parametro dbname="roteiro_parametro.de_parametro" )
 column=(type=long update=yes updatewhereclause=yes name=qt_limite_pedido dbname="roteiro_parametro.qt_limite_pedido" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="roteiro_parametro.id_situacao" initial="A" values="ATIVO	A/INATIVO	I/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_tipo dbname="roteiro_parametro.id_tipo" initial="F" values="POR DEMANDA	D/HORARIO FIXO	F/" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inicio dbname="roteiro_parametro.dh_inicio" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_termino dbname="roteiro_parametro.dh_termino" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_dia_entrega dbname="roteiro_parametro.id_dia_entrega" initial="1" values="SEGUNDA A SEXTA	1/S$$HEX1$$c100$$ENDHEX$$BADO	2/DOMINGO	3/" )
 column=(type=char(60) update=yes updatewhereclause=yes name=de_observacao dbname="roteiro_parametro.de_observacao" )
 retrieve="  SELECT cd_filial,
		id_parametro,   
		dh_horario_corte,   
         dh_horario_saida,   
         de_parametro,      
         qt_limite_pedido,
		id_situacao,
		id_tipo,
		dh_inicio,
		dh_termino,
 		id_dia_entrega,
		de_observacao
    FROM roteiro_parametro
WHERE cd_filial = :filial
" update="roteiro_parametro" updatewhere=0 updatekeyinplace=no arguments=(("filial", number)) )
