table(column=(type=long updatewhereclause=yes key=yes name=cd_tabela dbname="tabela_interface_sap.cd_tabela" )
 column=(type=char(100) updatewhereclause=yes name=de_tabela dbname="tabela_interface_sap.de_tabela" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="tabela_interface_sap.id_situacao" values="Ativo	A/Inativo	I/" )
 column=(type=char(2) updatewhereclause=yes name=cd_sistema dbname="tabela_interface_sap.cd_sistema" )
 retrieve="select t.cd_tabela,
		 t.de_tabela,
		 t.id_situacao,
		 t.cd_sistema
  from tabela_interface_sap t
 where id_integra_legado = 'S' and
		 coalesce(id_tabela_pai, 'N') = 'S' and
       id_subida_descida = :atipo and
		 coalesce(cd_sistema, '') = coalesce(:acd_sistema, cd_sistema, '')" update="tabela_interface_sap" updatewhere=0 updatekeyinplace=no arguments=(("atipo", string),("acd_sistema", string)) )
