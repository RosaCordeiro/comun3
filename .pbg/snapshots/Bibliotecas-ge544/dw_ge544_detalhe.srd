table(column=(type=datetime updatewhereclause=yes name=dh_registro dbname="log_integracao_derm_prd.dh_registro" )
 column=(type=char(15) updatewhereclause=yes name=de_codigo_barras dbname="log_integracao_derm_prd.de_codigo_barras" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="codigo_barras_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_desconto dbname="log_integracao_derm_prd.vl_desconto" )
 column=(type=char(250) updatewhereclause=yes name=de_erro dbname="log_integracao_derm_prd.de_erro" )
 column=(type=char(1) updatewhereclause=yes name=id_relacionado dbname="id_relacionado" )
 retrieve="Select	l.dh_registro,
		l.de_codigo_barras,
		c.cd_produto,
		Case c.de_codigo_barras
			When Null Then l.de_produto
			Else g.de_produto + ' : ' + g.de_apresentacao_venda
		End As de_produto,
		l.vl_desconto,
		l.de_erro,
		(Case When c.cd_produto Is Null Then 'N' Else 'S' End) As id_relacionado
From log_integracao_derm_prd As l
	Left Outer Join codigo_barras_produto As c
		On c.de_codigo_barras = l.de_codigo_barras
	Left Outer Join produto_geral As g
		On g.cd_produto = c.cd_produto
Where l.nr_atualizacao_transacao = :nr_atualizacao" arguments=(("nr_atualizacao", number))  sort="id_relacionado D de_produto A " )
