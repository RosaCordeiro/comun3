table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=date updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(30) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="de_chave_acesso" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="nm_razao_social" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="cd_natureza_operacao" )
 column=(type=date updatewhereclause=yes name=dt_vencimento dbname="dt_vencimento" )
 column=(type=char(1) updatewhereclause=yes name=id_notifica_loja dbname="id_notifica_loja" )
 column=(type=char(1) updatewhereclause=yes name=de_natureza_operacao dbname="de_natureza_operacao" )
 retrieve="select distinct
		tudo.cd_filial,
		tudo.nm_fantasia,
		tudo.dh_emissao,
		tudo.nr_nf,
		tudo.de_serie,
		'NFE' as de_especie,
		Coalesce(x.vl_nf,0) as vl_total_nf,
		tudo.de_chave_acesso,
		tudo.cd_fornecedor,
		tudo.nm_razao_social as nm_razao_social,
		tudo.cd_natureza_operacao,
		tudo.dt_vencimento,
		tudo.id_notifica_loja,
		'' as de_natureza_operacao
 from (
select	 f.cd_filial,
		f.nm_fantasia,
		n.dh_emissao,
		cast(substring(n.de_chave_acesso, 26, 9) as int) as nr_nf,
		Cast(cast(substring(n.de_chave_acesso, 23, 3) as int) as char) as de_serie,
		'NFE' as de_especie,
		n.vl_nf as vl_total_nf,
		n.de_chave_acesso,
		fn.cd_fornecedor,
		fn.nm_razao_social,
		Coalesce ((select max(cd_natureza_operacao) from nfe_destinadas where de_chave_acesso = n.de_chave_acesso) , (select max(cd_natureza_operacao) from nfe_indexacao_item where id_nf = n.de_chave_acesso )) as cd_natureza_operacao,
		Cast (Dateadd(day, qt_dias_vencimento, n.dh_emissao) as date) as dt_vencimento,
         '' id_notifica_loja		
from nfe_destinadas n
inner join filial f
	on f.nr_cgc = n.nr_cgc_destino
inner join parametro_odbc p
	on p.cd_filial = f.cd_filial
inner join fornecedor fn
	on fn.nr_cgc = n.nr_cgc_origem
left join condicao_pagamento_parcela cp
	on cp.cd_condicao = fn.cd_condicao_pagamento
where  	n.dh_emissao between :inicio and :termino
		and not exists (select * from nf_compra x where x.de_chave_acesso = n.de_chave_acesso)
		and not exists (select * from nfe_destinadas y where y.de_chave_acesso = n.de_chave_acesso and y.id_situacao_nf = '3')
		and n.id_tipo_nf = '1'
		and f.cd_filial <> 534
		and (fn.id_situacao = 'A' or fn.id_situacao is null)
union
select  f.cd_filial,
		f.nm_fantasia, 
		cast(n.dh_emissao as date) As dh_emissao,
		n.nr_nf,
		n.de_serie,
		n.de_especie,
		n.vl_total_nf,
		n.id_nf as de_chave_acesso,
		fn.cd_fornecedor,
		fn.nm_razao_social as nm_razao_social,
		Coalesce ((select max(cd_natureza_operacao) from nfe_destinadas where de_chave_acesso = n.id_nf) , (select max(cd_natureza_operacao) from nfe_indexacao_item where id_nf = n.id_nf  )) as cd_natureza_operacao,
		Cast (Dateadd(day, qt_dias_vencimento, n.dh_emissao) as date) as dt_vencimento,
		 '' id_notifica_loja
from nfe_indexacao n
inner join filial f
	on f.nr_cgc = n.cgc_destino
inner join parametro_odbc p
	on p.cd_filial = f.cd_filial
inner join fornecedor fn
	on fn.nr_cgc = n.cgc_origem
left join condicao_pagamento_parcela cp
	on cp.cd_condicao = fn.cd_condicao_pagamento 
where	n.dh_emissao between :inicio and :termino
		and not exists (select * from nf_compra x where x.de_chave_acesso = n.id_nf)
		and not exists (select * from nfe_destinadas y where y.de_chave_acesso = n.id_nf and y.id_situacao_nf = '3')
		and (n.id_finnfe = '1' or n.id_finnfe is null)
		and f.cd_filial <> 534
		and (fn.id_situacao = 'A' or fn.id_situacao is null) )  as tudo	
left outer join nfe_destinadas x
on x.de_chave_acesso = tudo.de_chave_acesso

" arguments=(("inicio", datetime),("termino", datetime))  sort="cd_filial A dt_vencimento A " )
