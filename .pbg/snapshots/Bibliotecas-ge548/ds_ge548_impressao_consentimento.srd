table(column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="cliente.nm_cliente" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_filial dbname="filial.id_rede_filial" )
 column=(type=char(8190) updatewhereclause=yes name=nr_cpf_cgc dbname="nr_cpf_cgc" )
 column=(type=char(1) updatewhereclause=yes name=id_sms dbname="id_sms" )
 column=(type=char(1) updatewhereclause=yes name=id_email dbname="id_email" )
 column=(type=char(1) updatewhereclause=yes name=id_whatsapp dbname="id_whatsapp" )
 column=(type=char(1) updatewhereclause=yes name=id_ligacao dbname="id_ligacao" )
 column=(type=char(1) updatewhereclause=yes name=id_correspondencia dbname="id_correspondencia" )
 column=(type=char(1) updatewhereclause=yes name=id_redes dbname="id_redes" )
 column=(type=char(1) updatewhereclause=yes name=id_pesquisa dbname="id_pesquisa" )
 column=(type=char(1) updatewhereclause=yes name=id_medicamento dbname="id_medicamento" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="nm_cliente" )
 column=(type=char(14) updatewhereclause=yes name=cliente_nr_cpf_cgc dbname="cliente.nr_cpf_cgc" )
 column=(type=char(255) updatewhereclause=yes name=nm_rede_filial dbname="nm_rede_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="filial.nm_razao_social" )
 column=(type=char(8190) updatewhereclause=no name=de_endereco dbname="de_endereco" )
 column=(type=char(8190) updatewhereclause=no name=localidade dbname="localidade" )
 retrieve="select  c.nm_cliente,
		f.id_rede_filial,
		(Case When CHAR_LENGTH(c.nr_cpf_cgc) = '11' Then LEFT(c.nr_cpf_cgc, 3) || '******' || RIGHT(c.nr_cpf_cgc, 2) Else LEFT(c.nr_cpf_cgc, 3) || '******' || RIGHT(c.nr_cpf_cgc, 6) End) as nr_cpf_cgc,
		Cast('N' as varchar(1)) as id_sms,
		Cast('N' as varchar(1)) as id_email,
		Cast('N' as varchar(1)) as id_whatsapp,
		Cast('N' as varchar(1)) as id_ligacao,
		Cast('N' as varchar(1)) as id_correspondencia,
		Cast('N' as varchar(1)) as id_redes,
		Cast('N' as varchar(1)) as id_pesquisa,
		Cast('N' as varchar(1)) as id_medicamento,
		(CASE WHEN c.nm_social is not null AND TRIM(c.nm_social) <> '' THEN c.nm_social ELSE c.nm_cliente END) as nm_cliente,
		c.nr_cpf_cgc,
		( CASE f.id_rede_filial
							WHEN 'DC' then 'Drogaria Catarinense'
							WHEN 'FA' then 'Farmagora'
							WHEN 'MP' then 'Drogaria Catarinense Manipula$$HEX2$$e700e300$$ENDHEX$$o'
							WHEN 'PP' then 'Farm$$HEX1$$e100$$ENDHEX$$cia Pre$$HEX1$$e700$$ENDHEX$$o Popular'
							WHEN	 'PF' then 'Prof$$HEX1$$f300$$ENDHEX$$rmula'
							ELSE f.id_rede_filial
						END ) as nm_rede_filial,
		f.nm_razao_social, 
		f.de_endereco || ', ' || f.nr_endereco as de_endereco,
		f.de_bairro || ' - ' || cid.nm_cidade || ' - ' || cid.cd_unidade_federacao AS localidade
from cliente c
	inner join filial f
		on f.cd_filial = dbo.uf_filial_parametro()
	inner join cidade cid
		ON cid.cd_cidade = f.cd_cidade
where c.cd_cliente =:cliente
" arguments=(("cliente", string)) )
