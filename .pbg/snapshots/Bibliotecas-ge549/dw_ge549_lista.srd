table(column=(type=datetime updatewhereclause=yes key=yes name=dh_pedido dbname="corte_pedido_resumo.dh_pedido" )
 column=(type=long updatewhereclause=yes name=qt_total_pedido dbname="qt_total_pedido" )
 column=(type=long updatewhereclause=yes name=qt_total_corte dbname="qt_total_corte" )
 column=(type=long updatewhereclause=yes name=qt_corte_normal dbname="qt_corte_normal" )
 column=(type=long updatewhereclause=yes name=qt_corte_atendido dbname="qt_corte_atendido" )
 column=(type=long updatewhereclause=yes name=qtde_total dbname="qtde_total" )
 retrieve="select dh_pedido, 
		Coalesce(qt_total_pedido,0) as qt_total_pedido,
		Coalesce(qt_total_corte,0) as qt_total_corte,
		Coalesce(qt_corte_normal,0) as qt_corte_normal,
		Coalesce(qt_corte_atendido,0) as qt_corte_atendido,
		Coalesce((qt_corte_normal + qt_corte_atendido),0) as qtde_total
from corte_pedido_resumo 
where dh_pedido between :dt_inicio and :dt_termino" update="corte_pedido_resumo" updatewhere=0 updatekeyinplace=no arguments=(("dt_inicio", date),("dt_termino", date))  sort="dh_pedido A " )
