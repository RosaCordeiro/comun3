table(column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="nr_pedido_distribuidora" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" dbalias="f.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_volume dbname="wms_lista_separacao.nr_volume" dbalias="w.nr_volume" )
 column=(type=long updatewhereclause=yes name=wms_lista_separacao_cd_esteira dbname="wms_lista_separacao.cd_esteira" dbalias="w.cd_esteira" )
 column=(type=datetime updatewhereclause=yes name=pedido_distribuidora_dh_emissao dbname="pedido_distribuidora.dh_emissao" dbalias="pd.dh_emissao" )
 retrieve="SELECT pd.nr_pedido_distribuidora
     , f.cd_filial
     , w.nr_volume
     , w.cd_esteira
     , pd.dh_emissao
FROM pedido_distribuidora pd
INNER JOIN filial f ON pd.cd_filial = f.cd_filial
INNER JOIN wms_lista_separacao w  ON f.cd_filial = w.cd_filial AND w.nr_pedido_distribuidora = pd.nr_pedido_distribuidora
INNER JOIN wms_esteira         we ON we.cd_esteira = w.cd_esteira
WHERE pd.dh_emissao between :pdh_data1 and :pdh_data2
  AND pd.id_situacao not in ('J', 'X')
  AND we.id_utiliza_esteira_autom = 'S'
 AND f.cd_filial  in (13)
 AND NOT EXISTS (SELECT id_integracao 
							FROM wms_integracao_esteira wie 
							WHERE wie.cd_filial = pd.cd_filial 
								AND wie.nr_pedido_distribuidora = pd.nr_pedido_distribuidora 
								AND wie.nr_volume = w.nr_volume 
								AND wie.id_integracao = 1 )
ORDER BY pd.nr_pedido_distribuidora asc 
" arguments=(("pdh_data1", datetime),("pdh_data2", datetime)) )
