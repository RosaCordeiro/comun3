table(column=(type=long updatewhereclause=yes name=i_invnumber dbname="wms_lista_separacao.i_invnumber" dbalias="a.i_invnumber" )
 column=(type=long updatewhereclause=yes name=i_numfilial dbname="filial.i_numfilial" dbalias="c.i_numfilial" )
 column=(type=long updatewhereclause=yes name=i_prioridade dbname="filial.i_prioridade" dbalias="c.i_prioridade" )
 column=(type=char(20) updatewhereclause=yes name=i_articletype dbname="wms_esteira.i_articletype" dbalias="f.i_articletype" )
 column=(type=char(40) updatewhereclause=yes name=i_filial dbname="filial.i_filial" dbalias="c.i_filial" )
 column=(type=long updatewhereclause=yes name=i_numbacia dbname="filial.i_numbacia" dbalias="c.i_numbacia" )
 column=(type=char(40) updatewhereclause=yes name=i_endclient dbname="filial.i_endclient" dbalias="c.i_endclient" )
 column=(type=char(40) updatewhereclause=yes name=i_cidclient dbname="cidade.i_cidclient" dbalias="d.i_cidclient" )
 column=(type=char(8) updatewhereclause=yes name=i_cepclient dbname="filial.i_cepclient" dbalias="c.i_cepclient" )
 column=(type=char(40) updatewhereclause=yes name=i_ufclient dbname="unidade_federacao.i_ufclient" dbalias="uf.i_ufclient" )
 column=(type=long updatewhereclause=yes name=i_numrota dbname="filial.i_numrota" dbalias="c.i_numrota" )
 column=(type=char(10) updatewhereclause=yes name=i_dataorder dbname="i_dataorder" )
 column=(type=datetime updatewhereclause=yes name=i_dataimporder dbname="i_dataimporder" )
 column=(type=decimal(0) updatewhereclause=yes name=i_tubarcode dbname="wms_lista_separacao.i_tubarcode" dbalias="a.i_tubarcode" )
 column=(type=long updatewhereclause=yes name=i_numvolume dbname="wms_lista_separacao.i_numvolume" dbalias="a.i_numvolume" )
 column=(type=long updatewhereclause=yes name=i_numvoltotal dbname="i_numvoltotal" )
 retrieve="SELECT a.nr_pedido_distribuidora           	as i_invnumber                                   -- Pedido             
     , c.cd_filial                          			as i_numfilial                                   --NumeroLoja
	, c.nr_prioridade_faturamento                           			as i_prioridade             
     , f.de_esteira                         			as i_articletype                                 --NomeEsteira
     , c.nm_fantasia                        		as i_filial                                      --NomeLoja
     , c.nr_ordem_bacia               			as i_numbacia     --Nr_Ordem_Bacia
     , c.de_endereco                       		as i_endclient                                   --EnderecoLoja
     , d.nm_cidade                          		as i_cidclient                                   --CidadeLoja
     , c.nr_cep                             			as i_cepclient                                   --CepLoja
     --, d.cd_unidade_federacao               	as i_ufclient                                    --UFLoja
	, uf.nm_unidade_federacao               	as i_ufclient                                    --UFLoja
     , c.nr_rota_entrega                    		as i_numrota                                     --Rota
	, CONVERT(VARCHAR(10), pd.dh_emissao, 103) 	as i_dataorder  
	, CONVERT(DATETIME, GETDATE(), 103) 			as i_dataimporder
     , a.nr_chave_volume                    		as i_tubarcode                                   --ChaveEtiqueta_CODIGO_BARRAS_ETIQUETA,	  
     , a.nr_volume                         			as i_numvolume                                   --NumeroDoVolume
 	 , (select count(wls.nr_volume) 
 	      from wms_lista_separacao wls
 	   	 where wls.cd_filial =  a.cd_filial 
 	   	   AND   wls.nr_pedido_distribuidora = a.nr_pedido_distribuidora) as i_numvoltotal  --Total_volumes
from   wms_lista_separacao a
inner join filial c 
		on 	c.cd_filial  = a.cd_filial 
inner join cidade d 
		on 	d.cd_cidade  = c.cd_cidade 
inner join unidade_federacao uf
		on uf.cd_unidade_federacao = d.cd_unidade_federacao
inner join wms_esteira f 
			on f.cd_esteira  = a.cd_esteira 			
inner join pedido_distribuidora pd
			on pd.cd_filial  = a.cd_filial 
			AND pd.nr_pedido_distribuidora  = a.nr_pedido_distribuidora
where   a.cd_filial  =:pl_cd_filial		
AND 	a.nr_pedido_distribuidora  =:pl_nr_pedido_distribuidora
AND 	a.nr_volume  =:pl_nr_volume
AND 	f.id_utiliza_esteira_autom = 'S'
AND NOT EXISTS (SELECT * 
							FROM wms_integracao_esteira wie 
							WHERE wie.cd_filial = a.cd_filial 
								AND wie.nr_pedido_distribuidora = a.nr_pedido_distribuidora 
								AND wie.nr_volume = a.nr_volume 
								AND wie.id_integracao = 1 )
--Verificar parametro da loja id esteira automatica" arguments=(("pl_cd_filial", number),("pl_nr_pedido_distribuidora", number),("pl_nr_volume", number)) )
