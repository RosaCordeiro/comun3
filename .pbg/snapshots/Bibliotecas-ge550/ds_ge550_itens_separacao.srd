table(column=(type=long updatewhereclause=yes name=pedido dbname="wms_lista_separacao.Pedido" )
 column=(type=long updatewhereclause=yes name=numeroloja dbname="filial.NumeroLoja" )
 column=(type=char(40) updatewhereclause=yes name=nomeloja dbname="filial.NomeLoja" )
 column=(type=char(20) updatewhereclause=yes name=nomeesteira dbname="wms_esteira.NomeEsteira" )
 column=(type=long updatewhereclause=yes name=rota dbname="filial.Rota" )
 column=(type=long updatewhereclause=yes name=numerodovolume dbname="wms_lista_separacao.NumeroDoVolume" )
 column=(type=long updatewhereclause=yes name=i_codigo dbname="wms_lista_separacao_produto.i_codigo" )
 column=(type=char(20) updatewhereclause=yes name=i_descricao dbname="i_descricao" )
 column=(type=char(20) updatewhereclause=yes name=wms_tipo_volume_nmtipovolume dbname="wms_tipo_volume.NmTipoVolume" )
 column=(type=date updatewhereclause=yes name=dt_pedido dbname="DT_pedido" )
 column=(type=long updatewhereclause=yes name=i_numvolume dbname="wms_lista_separacao.i_numvolume" )
 column=(type=long updatewhereclause=yes name=i_numvoltotal dbname="i_numvoltotal" )
 column=(type=long updatewhereclause=yes name=i_qtdd dbname="wms_lista_separacao_produto.i_qtdd" )
 column=(type=char(90) updatewhereclause=yes name=camposcodigobarraslista dbname="CamposCodigoBarrasLista" )
 column=(type=char(10) updatewhereclause=yes name=de_endereco_reduzido dbname="vw_wms_endereco.de_endereco_reduzido" )
 column=(type=char(6) updatewhereclause=yes name=i_endereco dbname="vw_wms_endereco.i_endereco" )
 column=(type=char(10) updatewhereclause=yes name=i_station dbname="i_station" )
 column=(type=char(20) updatewhereclause=yes name=i_ean dbname="i_ean" )
 column=(type=long updatewhereclause=yes name=wnr_ordem_separacao_flow dbname="wms_rua.nr_ordem_separacao_flow" )
 column=(type=char(2) updatewhereclause=yes name=cd_rua dbname="vw_wms_endereco.cd_rua" )
 column=(type=long updatewhereclause=yes name=nr_ordem_separacao_flow dbname="wms_endereco.nr_ordem_separacao_flow" )
 column=(type=char(3) updatewhereclause=yes name=cd_predio dbname="vw_wms_endereco.cd_predio" )
 column=(type=char(1) updatewhereclause=yes name=cd_andar dbname="vw_wms_endereco.cd_andar" )
 retrieve="select a.nr_pedido_distribuidora as Pedido
     , c.cd_filial as NumeroLoja
     , c.nm_fantasia as NomeLoja
     , f.de_esteira as NomeEsteira
     , c.nr_rota_entrega as Rota
     , a.nr_volume as NumeroDoVolume
     , a1.cd_produto                                       as i_codigo                             --CodigoProduto
     , substring(c1.de_produto + ' : ' +  c1.de_apresentacao_estoque,1,20) as i_descricao                          --De_produto
     , v.de_tipo_volume                                    as NmTipoVolume
     , cast(a.dh_geracao as date)                          as DT_pedido
     , a.nr_volume                                         as i_numvolume                          --NumeroDoVolume
     , (select count(wls.nr_volume) 
 	      from wms_lista_separacao wls
 	     where wls.cd_filial =  a.cd_filial 
 	   	   and   wls.nr_pedido_distribuidora = a.nr_pedido_distribuidora)       as i_numvoltotal                                                    --Total_volumes
     , a1.qt_pedida                                                         as i_qtdd                                                           --Qtde_Pedida, 
     ,(cast(c.cd_filial as char)  + cast(a.nr_pedido_distribuidora as char) + cast(a.nr_volume as char)) as CamposCodigoBarrasLista
     , v2.de_endereco_reduzido
     , v2.de_endereco_flow_rack                                                                          as i_endereco 
     ,( Select wr.cd_end_esteira_auto
		From wms_rua wr
		Inner Join wms_endereco we
			ON we.cd_rua = wr.cd_rua 
			and we.cd_endereco = a1.cd_endereco_localizacao
		Inner Join wms_endereco_esteira_auto weea
			ON weea.cd_end_esteira_auto = wr.cd_end_esteira_auto ) i_station
     , ( select de_codigo_barras from produto_geral where cd_produto = a1.cd_produto ) i_ean,
r.nr_ordem_separacao_flow,
v2.cd_rua,
x.nr_ordem_separacao_flow,
v2.cd_predio,
v2.cd_andar
from   wms_lista_separacao a
inner join wms_lista_separacao_produto a1
		on a1.cd_filial  = a.cd_filial 
		and a1.nr_pedido_distribuidora  = a.nr_pedido_distribuidora 
		and a1.nr_volume = a.nr_volume
inner join produto_geral c1
		on c1.cd_produto  = a1.cd_produto
inner join filial c 
		on c.cd_filial  = a.cd_filial 
inner join wms_esteira f 
		on f.cd_esteira  = a.cd_esteira 			
inner join wms_tipo_volume v 
		on v.cd_tipo_volume  = a.cd_tipo_volume 
inner join vw_wms_endereco v2 	
		on v2.cd_endereco 	= a1.cd_endereco_localizacao
inner join wms_endereco x 
		on x.cd_endereco = a1.cd_endereco_localizacao
inner join wms_rua r 
		on r.cd_rua = x.cd_rua
where   a.cd_filial  =:pl_cd_filial 		
and 	a.nr_pedido_distribuidora  =:pl_nr_pedido_distribuidora
and 	a.nr_volume  =:pl_nr_volume
and 	f.id_utiliza_esteira_autom = 'S'
" arguments=(("pl_cd_filial", number),("pl_nr_pedido_distribuidora", number),("pl_nr_volume", number))  sort="numeroloja A numerodovolume A wnr_ordem_separacao_flow A cd_rua A nr_ordem_separacao_flow A cd_predio A cd_andar A " )
