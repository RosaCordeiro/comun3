table(column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="wms_lista_separacao.nr_pedido_distribuidora" )
 column=(type=datetime updatewhereclause=yes name=dh_geracao dbname="wms_lista_separacao.dh_geracao" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_volume dbname="wms_lista_separacao.nr_volume" )
 column=(type=long updatewhereclause=yes name=cd_esteira dbname="wms_lista_separacao.cd_esteira" )
 column=(type=char(100) updatewhereclause=yes name=ds_integracao dbname="wms_integracao_esteira.ds_integracao" )
 column=(type=long updatewhereclause=yes name=id_integracao dbname="wms_integracao_esteira.id_integracao" )
 column=(type=long updatewhereclause=yes name=nr_rota_entrega dbname="filial.nr_rota_entrega" )
 column=(type=long updatewhereclause=yes name=nr_prioridade_faturamento dbname="filial.nr_prioridade_faturamento" )
 column=(type=char(1) updatewhereclause=yes name=selecao dbname="Selecao" values="	S/	N" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="wms_integracao_esteira.dh_inclusao" )
 column=(type=char(20) updatewhereclause=yes name=nr_picking dbname="wms_integracao_esteira.nr_picking" )
 retrieve="SELECT wls.nr_pedido_distribuidora,   
			wls.dh_geracao,   
			f.nm_fantasia,   
			f.cd_filial,   			
			wls.nr_volume,
			wls.cd_esteira,			
			wie.ds_integracao,
			wie.id_integracao,
			f.nr_rota_entrega,
			f.nr_prioridade_faturamento,
			'N' As Selecao,
			wie.dh_inclusao,
			wie.nr_picking
FROM wms_integracao_esteira wie
INNER JOIN wms_lista_separacao wls 
        ON  wie.cd_filial  = wls.cd_filial
        AND wie.nr_pedido_distribuidora  = wls.nr_pedido_distribuidora
        AND wie.nr_volume  = wls.nr_volume
INNER JOIN filial f 
			ON wie.cd_filial = f.cd_filial
INNER JOIN wms_tipo_volume v 
			ON v.cd_tipo_volume = wls.cd_tipo_volume
INNER JOIN pedido_distribuidora p 
			on p.nr_pedido_distribuidora  = wls.nr_pedido_distribuidora 
			and p.cd_filial  =  wls.cd_filial
WHERE   p.dh_emissao between :dt_emissao_de and :dt_emissao_ate




" arguments=(("dt_emissao_de", date),("dt_emissao_ate", date))  sort="dh_geracao A nr_pedido_distribuidora A nr_volume A " )
