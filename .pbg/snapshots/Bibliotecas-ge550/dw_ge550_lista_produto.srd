table(column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_lista_separacao_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="wms_lista_separacao_produto.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_separada dbname="wms_lista_separacao_produto.qt_separada" )
 column=(type=char(8) updatewhereclause=yes name=de_endereco dbname="de_endereco" )
 column=(type=datetime updatewhereclause=yes name=dtafinalizacao dbname="wms_lista_separacao_produto.DtaFinalizacao" )
 column=(type=char(10) updatewhereclause=yes name=i_station dbname="i_station" )
 retrieve="SELECT   ps.cd_produto,
		  	p.de_produto + ' : ' +  p.de_apresentacao_estoque as de_produto, 
            	ps.qt_pedida,
			ps.qt_separada,
              case when ls.cd_tipo_volume = 1 then
                   v.de_endereco_flow_rack  
                else
                   v.de_endereco_pulmao
              end de_endereco,
			 ps.dh_conferencia as DtaFinalizacao,
			( Select wr.cd_end_esteira_auto
				From wms_rua wr
				Inner Join wms_endereco we
					ON we.cd_rua = wr.cd_rua 
					and we.cd_endereco = ps.cd_endereco_localizacao
				Inner Join wms_endereco_esteira_auto weea
					ON weea.cd_end_esteira_auto = wr.cd_end_esteira_auto ) as i_station
FROM wms_lista_separacao ls
INNER JOIN  wms_lista_separacao_produto ps on  ps.cd_filial = ls.cd_filial
		and ps.nr_pedido_distribuidora = ls.nr_pedido_distribuidora
		and ps.nr_volume = ls.nr_volume 
INNER JOIN produto_geral p 		ON p.cd_produto 	= ps.cd_produto
INNER JOIN produto_central c 		ON c.cd_produto 	= p.cd_produto
INNER JOIN  vw_wms_endereco v 	on v.cd_endereco 	= ps.cd_endereco_localizacao
INNER  JOIN vw_classificacao_produto cp on  cp.cd_subcategoria = p.cd_subcategoria
WHERE ps.cd_filial 					= :cd_filial
AND ps.nr_pedido_distribuidora 	= :nr_pedido
AND ps.nr_volume 					= :nr_volume" arguments=(("cd_filial", number),("nr_pedido", number),("nr_volume", number)) )
