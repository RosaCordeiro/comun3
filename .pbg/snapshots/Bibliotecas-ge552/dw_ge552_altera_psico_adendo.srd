table(column=(type=long updatewhereclause=yes name=cd_produto dbname="vw_grupo_psico_adendo.cd_produto" )
 column=(type=char(103) update=yes updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico_real dbname="vw_grupo_psico_adendo.cd_grupo_psico_real" )
 column=(type=char(2) update=yes updatewhereclause=yes name=cd_grupo_psico_adendo dbname="vw_grupo_psico_adendo.cd_grupo_psico_adendo" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico_adendo_old dbname="vw_grupo_psico_adendo.cd_grupo_psico_adendo_old" )
 retrieve="Select	v.cd_produto,
		g.de_produto || ' : ' || g.de_apresentacao_venda As de_produto,
		v.cd_grupo_psico_real,
		v.cd_grupo_psico_adendo,
		v.cd_grupo_psico_adendo As cd_grupo_psico_adendo_old
From vw_grupo_psico_adendo As v
	Inner Join produto_geral As g
		On g.cd_produto = v.cd_produto
Where v.cd_produto = :produto" arguments=(("produto", number)) )
