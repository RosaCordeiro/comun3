table(column=(type=long updatewhereclause=yes name=cd_produto dbname="vw_grupo_psico_adendo.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico_real dbname="vw_grupo_psico_adendo.cd_grupo_psico_real" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico_adendo dbname="vw_grupo_psico_adendo.cd_grupo_psico_adendo" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" )
 retrieve="Select v.cd_produto,
		 g.de_produto || ' : ' || g.de_apresentacao_venda As de_produto,
		 v.cd_grupo_psico_real,
		 v.cd_grupo_psico_adendo,
		 g.id_situacao
From vw_grupo_psico_adendo As v
	Inner Join produto_geral As g
		On g.cd_produto = v.cd_produto
Where g.cd_grupo_psico Is Not Null
	And g.cd_grupo_psico <> 'W'"  sort="de_produto A " )
