table(column=(type=long updatewhereclause=yes key=yes name=cd_filial dbname="filial.cd_filial" dbalias="f.cd_filial" )
 column=(type=char(3) updatewhereclause=yes name=filial_id_24horas dbname="ID_24HORAS" )
 column=(type=char(3) updatewhereclause=yes name=filial_id_manipulacao dbname="ID_MANIPULACAO" )
 column=(type=char(3) updatewhereclause=yes name=cd_ifood_filial dbname="CD_IFOOD_FILIAL" )
 column=(type=char(3) updatewhereclause=yes name=id_afere_pressao dbname="ID_AFERE_PRESSAO" )
 column=(type=char(3) updatewhereclause=yes name=id_afere_temperatura dbname="ID_AFERE_TEMPERATURA" )
 column=(type=char(3) updatewhereclause=yes name=id_aplica_injetaveis dbname="ID_APLICA_INJETAVEIS" )
 column=(type=char(3) updatewhereclause=yes name=id_aplica_vacina dbname="ID_APLICA_VACINA" )
 column=(type=char(3) updatewhereclause=yes name=id_armario_inteligente dbname="ID_ARMARIO_INTELIGENTE" )
 column=(type=char(3) updatewhereclause=yes name=id_disque_entrega dbname="ID_DISQUE_ENTREGA" )
 column=(type=char(3) updatewhereclause=yes name=id_estacionamento dbname="ID_ESTACIONAMENTO" )
 column=(type=char(3) updatewhereclause=yes name=id_furo_auricular dbname="ID_FURO_AURICULAR" )
 column=(type=char(3) updatewhereclause=yes name=id_loja_beauty_club dbname="ID_LOJA_BEAUTY_CLUB" )
 column=(type=char(3) updatewhereclause=yes name=id_possui_vidalink dbname="ID_POSSUI_VIDALINK" )
 column=(type=char(3) updatewhereclause=yes name=id_receita_digital dbname="ID_RECEITA_DIGITAL" )
 column=(type=char(3) updatewhereclause=yes name=id_retirada_em_loja dbname="ID_RETIRADA_EM_LOJA" )
 column=(type=char(3) updatewhereclause=yes name=id_revisao_medicamento dbname="ID_REVISAO_MEDICAMENTO" )
 column=(type=char(3) updatewhereclause=yes name=id_teste_covid dbname="ID_TESTE_COVID" )
 column=(type=char(3) updatewhereclause=yes name=id_teste_glicemia dbname="ID_TESTE_GLICEMIA" )
 retrieve=" SELECT  f.cd_filial,
			(CASE f.id_24horas WHEN 'S' THEN 'Sim' ELSE 'N$$HEX1$$e300$$ENDHEX$$o' END) AS 'ID_24HORAS',			
			(CASE f.id_manipulacao WHEN 'S' THEN 'Sim' ELSE 'N$$HEX1$$e300$$ENDHEX$$o' END) AS 'ID_MANIPULACAO',
			(Case (SELECT vl_parametro From parametro_loja p Where cd_parametro Like '%CD_IFOOD_FILIAL%' 				AND p.cd_filial = f.cd_filial) When  'S' Then 'Sim' Else 'N$$HEX1$$e300$$ENDHEX$$o' END) AS 'CD_IFOOD_FILIAL',
			(Case (SELECT vl_parametro From parametro_loja p Where cd_parametro Like '%ID_AFERE_PRESSAO%' 				AND p.cd_filial = f.cd_filial) When  'S' Then 'Sim' Else 'N$$HEX1$$e300$$ENDHEX$$o' END) AS 'ID_AFERE_PRESSAO',
			(Case (SELECT vl_parametro From parametro_loja p Where cd_parametro Like '%ID_AFERE_TEMPERATURA%' 		AND p.cd_filial = f.cd_filial) When  'S' Then 'Sim' Else 'N$$HEX1$$e300$$ENDHEX$$o' END) AS 'ID_AFERE_TEMPERATURA',
			(Case (SELECT vl_parametro From parametro_loja p Where cd_parametro Like '%ID_APLICA_INJETAVEIS%' 			AND p.cd_filial = f.cd_filial) When  'S' Then 'Sim' Else 'N$$HEX1$$e300$$ENDHEX$$o' END) AS 'ID_APLICA_INJETAVEIS',
			(Case (SELECT vl_parametro From parametro_loja p Where cd_parametro Like '%ID_APLICA_VACINA%' 				AND p.cd_filial = f.cd_filial) When  'S' Then 'Sim' Else 'N$$HEX1$$e300$$ENDHEX$$o' END) AS 'ID_APLICA_VACINA',
			(Case (SELECT vl_parametro From parametro_loja p Where cd_parametro Like '%ID_ARMARIO_INTELIGENTE%' 	AND p.cd_filial = f.cd_filial) When  'S' Then 'Sim' Else 'N$$HEX1$$e300$$ENDHEX$$o' END) AS 'ID_ARMARIO_INTELIGENTE',
			(Case (SELECT vl_parametro From parametro_loja p Where cd_parametro Like '%ID_DISQUE_ENTREGA%' 			AND p.cd_filial = f.cd_filial) When  'S' Then 'Sim' Else 'N$$HEX1$$e300$$ENDHEX$$o' END) AS 'ID_DISQUE_ENTREGA',
			(Case (SELECT vl_parametro From parametro_loja p Where cd_parametro Like '%ID_ESTACIONAMENTO%' 			AND p.cd_filial = f.cd_filial) When  'S' Then 'Sim' Else 'N$$HEX1$$e300$$ENDHEX$$o' END) AS 'ID_ESTACIONAMENTO',
			(Case (SELECT vl_parametro From parametro_loja p Where cd_parametro Like '%ID_FURO_AURICULAR%' 			AND p.cd_filial = f.cd_filial) When  'S' Then 'Sim' Else 'N$$HEX1$$e300$$ENDHEX$$o' END) AS 'ID_FURO_AURICULAR',
			(Case (SELECT vl_parametro From parametro_loja p Where cd_parametro Like '%ID_LOJA_BEAUTY_CLUB%' 			AND p.cd_filial = f.cd_filial) When  'S' Then 'Sim' Else 'N$$HEX1$$e300$$ENDHEX$$o' END) AS 'ID_LOJA_BEAUTY_CLUB',
			(Case (SELECT vl_parametro From parametro_loja p Where cd_parametro Like '%ID_POSSUI_VIDALINK%' 			AND p.cd_filial = f.cd_filial) When  'S' Then 'Sim' Else 'N$$HEX1$$e300$$ENDHEX$$o' END) AS 'ID_POSSUI_VIDALINK',
			(Case (SELECT vl_parametro From parametro_loja p Where cd_parametro Like '%ID_RECEITA_DIGITAL%'				AND p.cd_filial = f.cd_filial) When  'S' Then 'Sim' Else 'N$$HEX1$$e300$$ENDHEX$$o' END) AS 'ID_RECEITA_DIGITAL',
			(Case (SELECT vl_parametro From parametro_loja p Where cd_parametro Like '%ID_RETIRADA_EM_LOJA%' 		AND p.cd_filial = f.cd_filial) When  'S' Then 'Sim' Else 'N$$HEX1$$e300$$ENDHEX$$o' END) AS 'ID_RETIRADA_EM_LOJA',
			(Case (SELECT vl_parametro From parametro_loja p Where cd_parametro Like '%ID_REVISAO_MEDICAMENTO%' 	AND p.cd_filial = f.cd_filial) When  'S' Then 'Sim' Else 'N$$HEX1$$e300$$ENDHEX$$o' END) AS 'ID_REVISAO_MEDICAMENTO',
			(Case (SELECT vl_parametro From parametro_loja p Where cd_parametro Like '%ID_TESTE_COVID%' 				AND p.cd_filial = f.cd_filial) When  'S' Then 'Sim' Else 'N$$HEX1$$e300$$ENDHEX$$o' END) AS 'ID_TESTE_COVID',
			(Case (SELECT vl_parametro From parametro_loja p Where cd_parametro Like '%ID_TESTE_GLICEMIA%' 			AND p.cd_filial = f.cd_filial) When  'S' Then 'Sim' Else 'N$$HEX1$$e300$$ENDHEX$$o' END) AS 'ID_TESTE_GLICEMIA'
FROM filial f
Where f.id_aberta = 'S'
	And cd_filial not in (1,2,534)" update="filial" updatewhere=0 updatekeyinplace=no )
