table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(102) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="qt_vendida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_praticado dbname="vl_preco_praticado" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_custo dbname="vl_total_custo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_bruto dbname="vl_total_bruto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_liquido dbname="vl_total_liquido" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_comissao dbname="vl_comissao" )
 column=(type=decimal(28) updatewhereclause=yes name=vl_icms dbname="vl_icms" )
 column=(type=decimal(46) updatewhereclause=yes name=vl_pis_cofins dbname="vl_pis_cofins" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_margem_liquida dbname="vl_margem_liquida" )
 retrieve="select 	n.cd_filial, 
			n.nr_nf, 
			n.de_especie, 
			n.de_serie, 
			n.dh_movimentacao_caixa, 
			i.cd_produto, 
			pg.de_produto||': '||pg.de_apresentacao_venda as de_produto, 
			i.qt_vendida, 
			i.vl_preco_unitario,
			i.vl_preco_praticado, 
			(me.qt_movimento * me.vl_custo_unitario) as vl_total_custo,
			(i.qt_vendida * i.vl_preco_unitario) as vl_total_bruto,
			(i.qt_vendida * i.vl_preco_praticado) as vl_total_liquido,
			round((i.qt_vendida * i.vl_preco_praticado) * (i.pc_comissao_extra / 100),2) as vl_comissao,
			(case coalesce(i.cd_cst_tributacao,substring(i.cd_situacao_tributaria,2,1)||'0') 
					when '60' then coalesce(me.vl_custo_gerencial,0) - coalesce(me.vl_custo_unitario,0)
					when '10' then coalesce(me.vl_custo_gerencial,0) - coalesce(me.vl_custo_unitario,0)
					when '00' then round(round(i.qt_vendida * i.vl_preco_praticado * (1 - n.pc_desconto/100),2) * i.pc_icms / 100, 2)
				else 0.00 end) as vl_icms,
		 	(case when coalesce(hp.id_situacao_pis_cofins, pg.id_situacao_pis_cofins) = 'T' then /* Produto possui PIS/COFINS tributado? */
					Case when cast(pdp.vl_parametro as date) <= n.dh_movimentacao_caixa then /* A partir dessa data o PIS/COFINS come$$HEX1$$e700$$ENDHEX$$ou a ser analisado na rentabilidade */
						Case pcp.vl_parametro /* Metodo calculo PIS/COFINS */ 
							when '1' then /* Metodo 1: Calcula PIS/COFINS pelo valor de venda */
								round(round(i.qt_vendida * i.vl_preco_praticado * (1 - n.pc_desconto/100),2) * ( cast(pac.vl_parametro as numeric(9,6)) + cast(pap.vl_parametro as numeric(9,6)))/100, 2)
							when '2' then /* Metodo 2: Calcula PIS/COFINS pelo valor de venda (sem ICMS) */
								round((round(i.qt_vendida * i.vl_preco_praticado * (1 - n.pc_desconto/100),2) - (me.vl_custo_gerencial - me.vl_custo_unitario)) * ( cast(pac.vl_parametro as numeric(9,6)) + cast(pap.vl_parametro as numeric(9,6)))/100, 2)
							when '3' then /* Metodo 3: Calcula PIS/COFINS pelo valor agregado, venda menos CMV gerencial (sem ICMS na base D$$HEX1$$e900$$ENDHEX$$bito PIS/COFINS) */
								round((round(i.qt_vendida * i.vl_preco_praticado * (1 - n.pc_desconto/100),2) - me.vl_custo_gerencial ) * ( cast(pac.vl_parametro as numeric(9,6)) + cast(pap.vl_parametro as numeric(9,6)))/100, 2)
							when '4' then /* Metodo 4: Calcula PIS/COFINS pelo valor agregado, venda menos CMV (ICMS comp$$HEX1$$f500$$ENDHEX$$e base d$$HEX1$$e900$$ENDHEX$$bito PIS COFINS) */
								round((round(i.qt_vendida * i.vl_preco_praticado * (1 - n.pc_desconto/100),2) - me.vl_custo_unitario ) * ( cast(pac.vl_parametro as numeric(9,6)) + cast(pap.vl_parametro as numeric(9,6)))/100, 2)
							when '5' then /* Metodo 5: Calcula PIS/COFINS pela entrada, baseado no CMV (sem ICMS na base) */
								round(me.vl_custo_unitario / (1 - (cast(pac.vl_parametro as numeric(9,6)) + cast(pap.vl_parametro as numeric(9,6))) / 100) * 
								(cast(pac.vl_parametro as numeric(9,6)) + cast(pap.vl_parametro as numeric(9,6)))/100, 2)
							Else /* Anteriormente a 10/2024 era utilizado um parametro zerado */
						round(round(i.qt_vendida * i.vl_preco_praticado * (1 - n.pc_desconto/100),2) * (cast(p.vl_parametro as numeric(9,6)) / 100), 2) end
					End
				else 0
			  	end) as vl_pis_cofins,
			//(i.qt_vendida * i.vl_preco_praticado) - round((i.qt_vendida * i.vl_preco_praticado) * (i.pc_comissao_extra / 100),2) - (me.qt_movimento * me.vl_custo_unitario) as vl_margem_liquida
			0.00 /*tratado na tela post_retrieve()*/ as vl_margem_liquida
from nf_venda n 
inner join item_nf_venda i (index pk_item_nf_venda)
	on i.cd_filial = n.cd_filial+0
	and i.nr_nf = n.nr_nf+0
	and i.de_especie = n.de_especie
	and i.de_serie = n.de_serie
inner join produto_geral pg  (index pk_produto_geral)
	on pg.cd_produto = i.cd_produto+0
inner join movimento_estoque me (index idx_nota)
	on me.cd_filial_movimento = n.cd_filial
	and me.nr_nf = n.nr_nf
	and me.de_especie = n.de_especie
	and me.de_serie = n.de_serie
	and me.cd_produto = i.cd_produto
	and me.dh_movimento = n.dh_movimentacao_caixa
	and coalesce(me.nr_sequencial,1) = i.nr_sequencial
left outer join parametro_geral pcp      
	on pcp.cd_parametro 	        = 'ID_CALCULO_PIS_COFINS'
left outer join parametro_geral pdp
	on pdp.cd_parametro 	        = 'DH_INICIO_OPERACAO_PIS_COFINS'
left outer join parametro_geral pap
	on pap.cd_parametro 	        = 'PC_COFINS'
left outer join parametro_geral pac
	on pac.cd_parametro 	        = 'PC_PIS'
left outer join parametro_geral p
	on p.cd_parametro 	        = 'PC_PIS_COFINS_RENTABILIDADE'
left outer join historico_produto hp
	on 	hp.cd_produto		= pg.cd_produto
	and 	hp.dh_historico	= CONVERT( CHAR(6), n.dh_movimentacao_caixa, 112 ) + '01'
where n.dh_movimentacao_caixa between :dt_inicio and :dt_fim
	and n.cd_filial > 0
	and n.nr_nf_anexa is null
" arguments=(("dt_inicio", date),("dt_fim", date))  sort="vl_margem_liquida A dh_movimentacao_caixa A cd_filial A " )
