table(column=(type=decimal(0) updatewhereclause=yes name=nr_etiqueta dbname="wms_etiqueta_produto.nr_etiqueta" dbalias="e.nr_etiqueta" )
 column=(type=char(20) updatewhereclause=yes name=nm_bairro dbname="nm_bairro" )
 column=(type=char(1) updatewhereclause=yes name=cd_bairro dbname="cd_bairro" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="wms_localizacao.cd_endereco" dbalias="w.cd_endereco" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_localizacao.cd_produto" dbalias="w.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="wms_localizacao.nr_lote" dbalias="w.nr_lote" )
 column=(type=long updatewhereclause=yes name=qt_caixa_padrao dbname="wms_localizacao.qt_caixa_padrao" dbalias="w.qt_caixa_padrao" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="wms_localizacao.dh_validade" dbalias="w.dh_validade" )
 column=(type=long updatewhereclause=yes name=qt_saldo dbname="wms_localizacao.qt_saldo" dbalias="w.qt_saldo" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="wms_localizacao.nr_sequencial" dbalias="w.nr_sequencial" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco_flow_rack dbname="cd_endereco_flow_rack" )
 column=(type=char(6) updatewhereclause=yes name=de_endereco_flow_rack dbname="de_endereco_flow_rack" )
 column=(type=char(1) updatewhereclause=yes name=id_bairro_flow dbname="id_bairro_flow" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_comprador dbname="produto_central.nr_matricula_comprador" dbalias="pc.nr_matricula_comprador" )
 column=(type=char(40) updatewhereclause=yes name=nm_comprador dbname="usuario.nm_comprador" dbalias="u.nm_comprador" )
 column=(type=char(3) updatewhereclause=yes name=id_endereco_bloqueado dbname="id_endereco_bloqueado" )
 column=(type=char(1) updatewhereclause=yes name=id_movimenta_avaria dbname="vw_wms_endereco.id_movimenta_avaria" dbalias="v.id_movimenta_avaria" )
 column=(type=char(3) updatewhereclause=yes name=id_bloqueado dbname="id_bloqueado" )
 retrieve="select		e.nr_etiqueta,	
 			case when 	v.cd_bairro = 'A' AND v.id_tipo_segregado = 'R' then 'SEGREG. RECEBIMENTO' Else v.nm_bairro end as nm_bairro,
			coalesce(v.cd_bairro, '') as cd_bairro,
			w.cd_endereco, 
			w.cd_produto, 
			g.de_produto + ' : ' +  g.de_apresentacao_estoque as de_produto, 
			w.nr_lote, 
			w.qt_caixa_padrao, 
			w.dh_validade, 
			w.qt_saldo,
			w.nr_sequencial,
			/*(	select vwe.cd_endereco 
					from wms_endereco_produto wep
					inner join vw_wms_endereco vwe on vwe.cd_endereco = wep.cd_endereco
					where wep.cd_produto = w.cd_produto and wep.nr_lote= w.nr_lote) as cd_endereco_flow_rack,*/
			case when g.cd_grupo_psico is  null then (	select b.cd_endereco
																	from wms_endereco_produto a
																	inner join vw_wms_endereco b on b.cd_endereco = a.cd_endereco  
																	where a.cd_produto = w.cd_produto
																	and b.id_flow_rack = 'S')
												 else		
                                                       ( case when convert(varchar, getdate(), 112)>=(select convert(varchar,cast (vl_parametro as date),112) from parametro_geral where cd_parametro='DH_INICIO_PADPICKING_LOTE') 
																and  coalesce(g.id_geladeira,'N')  =  'N'  Then (
                                                                        select     b.cd_endereco
    																	from wms_endereco_produto a
    																	inner join vw_wms_endereco b on b.cd_endereco = a.cd_endereco and b.cd_endereco = w.cd_endereco 
    																	where a.cd_produto = w.cd_produto 	and a.nr_lote = w.nr_lote  
																	    and b.id_flow_rack = 'S' ) else (
                                                                            		select b.de_endereco_flow_rack
        																	from wms_endereco_produto a
        																	inner join vw_wms_endereco b on b.cd_endereco = a.cd_endereco and b.cd_endereco = w.cd_endereco 
        																	where a.cd_produto = w.cd_produto and coalesce(a.nr_lote, case when (select count(*) from wms_localizacao wl2 where wl2.cd_endereco = b.cd_endereco and wl2.cd_produto = a.cd_produto) <= 1 then w.nr_lote else null end) = w.nr_lote
        																	and b.id_flow_rack = 'S') end )
             end  as cd_endereco_flow_rack,
			case when g.cd_grupo_psico is  null then (	select b.de_endereco_flow_rack
																	from wms_endereco_produto a
																	inner join vw_wms_endereco b on b.cd_endereco = a.cd_endereco  
																	where a.cd_produto = w.cd_produto
																	and b.id_flow_rack = 'S')
												 else		
                                                       ( case when convert(varchar, getdate(), 112)>=(select convert(varchar,cast (vl_parametro as date),112) from parametro_geral where cd_parametro='DH_INICIO_PADPICKING_LOTE') 
																and  coalesce(g.id_geladeira,'N')  =  'N'  Then (
                                                                        select     b.de_endereco_flow_rack
    																	from wms_endereco_produto a
    																	inner join vw_wms_endereco b on b.cd_endereco = a.cd_endereco and b.cd_endereco = w.cd_endereco 
    																	where a.cd_produto = w.cd_produto 	and a.nr_lote = w.nr_lote  
																	    and b.id_flow_rack = 'S' ) else (
                                                                            		select b.de_endereco_flow_rack
        																	from wms_endereco_produto a
        																	inner join vw_wms_endereco b on b.cd_endereco = a.cd_endereco and b.cd_endereco = w.cd_endereco 
        																	where a.cd_produto = w.cd_produto and coalesce(a.nr_lote, case when (select count(*) from wms_localizacao wl2 where wl2.cd_endereco = b.cd_endereco and wl2.cd_produto = a.cd_produto) <= 1 then w.nr_lote else null end) = w.nr_lote
        																	and b.id_flow_rack = 'S') end )
             end  as de_endereco_flow_rack,
			case when  (v.cd_bairro = '0') or (v.cd_bairro = '8') or (v.cd_bairro = '2') then
					'S'
				else
					'N'
			end as id_bairro_flow,
			pc.nr_matricula_comprador,
			u.nm_usuario as nm_comprador,
			(SELECT dbo.wms_retorna_end_bloqueado(w.cd_endereco)) as id_endereco_bloqueado,
			v.id_movimenta_avaria,
			CASE 
				  WHEN w.id_bloqueado = 'S' THEN 'SIM'
				  WHEN w.id_bloqueado = 'N' THEN 'N$$HEX1$$c300$$ENDHEX$$O'
			END AS id_bloqueado
from wms_localizacao w
inner join produto_geral g on g.cd_produto = w.cd_produto
inner join produto_central pc on pc.cd_produto  = g.cd_produto
left outer join usuario as u on u.nr_matricula = pc.nr_matricula_comprador
inner join vw_wms_endereco v on v.cd_endereco = w.cd_endereco
inner join wms_bairro b on b.cd_bairro = v.cd_bairro
left join wms_etiqueta_produto e on e.cd_produto = w.cd_produto
											and e.qt_caixa_padrao = w.qt_caixa_padrao
											and e.nr_lote = w.nr_lote
											and e.dh_validade = w.dh_validade
where  w.cd_produto is not null and b.cd_filial = :cd_filial " arguments=(("cd_filial", number))  sort="nm_bairro A de_produto A " )
