table(column=(type=long update=yes updatewhereclause=yes name=cd_mensagem dbname="mensagem_email_sistema.cd_mensagem" )
 column=(type=char(2) update=yes updatewhereclause=yes name=cd_sistema dbname="mensagem_email_sistema.cd_sistema" )
 column=(type=char(100) updatewhereclause=yes name=de_assunto dbname="mensagem_email_sistema.de_assunto" )
 column=(type=char(100) updatewhereclause=yes name=de_mensagem dbname="mensagem_email_sistema.de_mensagem" )
 column=(type=char(100) updatewhereclause=yes name=de_observacao dbname="mensagem_email_sistema.de_observacao" )
 column=(type=char(10) updatewhereclause=yes name=cd_procedimento dbname="mensagem_email_sistema.cd_procedimento" )
 retrieve="  SELECT  DISTINCT 
			a.cd_mensagem,
			a.cd_sistema,
			a.de_assunto,
			a.de_mensagem,
			a.de_observacao,
			a.cd_procedimento
FROM mensagem_email_sistema a
	Inner Join mensagem_email_sistema_usuario b
		On b.cd_mensagem = a.cd_mensagem" )
