table(column=(type=long updatewhereclause=yes name=codigo dbname="produto_reforco_pedido.CODIGO" dbalias="pp.CODIGO" )
 column=(type=char(103) updatewhereclause=yes name=nome_produto dbname="NOME_PRODUTO" )
 column=(type=char(15) updatewhereclause=yes name=tipo_reforco dbname="TIPO_REFORCO" )
 column=(type=datetime updatewhereclause=yes name=produto_reforco_pedido_data_inclusao dbname="produto_reforco_pedido.DATA_INCLUSAO" dbalias="pp.DATA_INCLUSAO" )
 column=(type=char(49) updatewhereclause=yes name=responsavel dbname="RESPONSAVEL" )
 retrieve="  SELECT   pp.cd_produto CODIGO, 
		pg.de_produto || ' : ' || pg.de_apresentacao_venda As NOME_PRODUTO,
         CASE WHEN pp.id_tipo_reforco = 'D' THEN 'DISTRIBUIDORA' 
                  ELSE 'ESTOQUE CENTRAL'
 		END TIPO_REFORCO,
         pp.dh_inclusao DATA_INCLUSAO,
         pp.nr_matricula_inclusao + ~" - ~" + uo.nm_usuario RESPONSAVEL
  FROM produto_reforco_pedido   pp,
		   produto_geral pg,
		   usuario           uo
WHERE pp.cd_produto = pg.cd_produto
    AND pp.nr_matricula_inclusao = uo.nr_matricula
"  sort="nome_produto A " )
