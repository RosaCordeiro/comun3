table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="produto_reforco_pedido.cd_produto" )
 column=(type=char(1) update=yes updatewhereclause=yes key=yes name=id_tipo_reforco dbname="produto_reforco_pedido.id_tipo_reforco" values="DISTRIBUIDORA	D/ESTOQUE CENTRAL	E/" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_inclusao dbname="produto_reforco_pedido.nr_matricula_inclusao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inclusao dbname="produto_reforco_pedido.dh_inclusao" )
 column=(type=char(1) updatewhereclause=yes name=seleciona dbname="seleciona" initial="N" values="	S/	N" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 retrieve="  SELECT   pp.cd_produto, 
         pp.id_tipo_reforco,   
         pp.nr_matricula_inclusao,   
         pp.dh_inclusao,
		'' seleciona,
         pg.de_produto || ' : ' || pg.de_apresentacao_venda As de_produto
  FROM produto_reforco_pedido pp INNER JOIN produto_geral pg ON pp.cd_produto = pg.cd_produto         
" update="produto_reforco_pedido" updatewhere=0 updatekeyinplace=no )
