table(column=(type=char(8) updatewhereclause=yes name=cd_endereco_localizacao dbname="wms_lista_separacao_produto.cd_endereco_localizacao" dbalias="wl.cd_endereco_localizacao" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_lista_separacao_produto.cd_produto" dbalias="wl.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_saldo_utilizado dbname="qt_saldo_utilizado" )
 retrieve="SELECT wl.cd_endereco_localizacao, wl.cd_produto, sum(wl.qt_pedida) qt_saldo_utilizado 
From pedido_distribuidora pd 
Inner join wms_lista_separacao w on w.cd_filial = pd.cd_filial  and w.nr_pedido_distribuidora = pd.nr_pedido_distribuidora 
Inner join wms_lista_separacao_produto wl on wl.cd_filial = w.cd_filial  and wl.nr_pedido_distribuidora = w.nr_pedido_distribuidora and wl.nr_volume = w.nr_volume 
Where pd.cd_distribuidora  = '053404705'
	And pd.dh_emissao >= ( select dateadd(dd, -2, :adt_data))  
	And w.dh_termino_conferencia is null
	And w.cd_esteira = 3
	and w.dh_cancelamento is null
     and w.cd_tipo_volume = 1
group by wl.cd_endereco_localizacao, wl.cd_produto" arguments=(("adt_data", date))  sort="cd_produto A " )
