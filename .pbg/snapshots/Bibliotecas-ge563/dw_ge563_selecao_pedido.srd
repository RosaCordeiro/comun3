table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_distribuidora.cd_filial" dbalias="p.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_distribuidora.nr_pedido_distribuidora" dbalias="p.nr_pedido_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_filial dbname="filial.nm_filial" dbalias="v.nm_filial" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_distribuidora.dh_emissao" dbalias="p.dh_emissao" )
 column=(type=char(60) updatewhereclause=yes name=de_rota dbname="rota_entrega.de_rota" dbalias="c.de_rota" )
 column=(type=char(1) updatewhereclause=yes name=id_processar dbname="id_processar" values="	S/	N" )
 retrieve="SELECT	distinct  	p.cd_filial, 
						p.nr_pedido_distribuidora,
						v.nm_fantasia as nm_filial,   
						p.dh_emissao  ,  
						c.de_rota ,
						'S' id_processar
FROM pedido_distribuidora   p
inner join filial v on v.cd_filial = p.cd_filial
left join rota_entrega   c on c.nr_rota  = v.nr_rota_entrega 
where p.id_situacao = 'S'
    and coalesce(p.id_pedido_almoxarifado, 'N') = 'N'
    and p.cd_distribuidora = '053404705'
	and p.dh_picking_controlado is null 
	and p.dh_emissao  = :adt_data
	and not exists  ( select *  from wms_lista_separacao   a  where a.cd_filial  = p.cd_filial 	and a.nr_pedido_distribuidora  = p.nr_pedido_distribuidora 	and a.cd_esteira  = 3 and a.cd_tipo_volume = 1) 							
     and exists (select 1 from pedido_distribuidora_produto pp
				   inner join produto_geral  g on g.cd_produto = pp.cd_produto
				   where pp.cd_filial = p.cd_filial
					  and pp.nr_pedido_distribuidora = p.nr_pedido_distribuidora and COALESCE(g.id_geladeira, 'N') = 'N' 
					  and (g.cd_grupo_psico is not null or exists (select * from dbo.wms_endereco_produto w where w.cd_esteira = 3 and w.cd_produto = pp.cd_produto)))
    
order by c.nr_rota, v.cd_filial" arguments=(("adt_data", date))  sort="cd_filial A " )
