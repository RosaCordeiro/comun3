table(column=(type=char(9) update=yes updatewhereclause=yes name=cd_fornecedor dbname="fornecedor_divisao.cd_fornecedor" dbalias="f.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" dbalias="o.nm_fantasia" )
 column=(type=long update=yes updatewhereclause=yes name=nr_divisao dbname="fornecedor_divisao.nr_divisao" dbalias="f.nr_divisao" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_divisao dbname="fornecedor_divisao.nm_divisao" dbalias="f.nm_divisao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="u.nm_usuario" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionar dbname="id_selecionar" values="	S/	N" )
 column=(type=char(91) updatewhereclause=yes name=de_divisao dbname="de_divisao" )
 retrieve="SELECT	f.cd_fornecedor,
			o.nm_fantasia,
			f.nr_divisao,
			f.nm_divisao,
			u.nm_usuario,
			'N' id_selecionar,
			Cast(f.nr_divisao As Char(5)) + ' - ' + f.nm_divisao + ' | ' +  u.nm_usuario de_divisao
FROM fornecedor_divisao As f
	Inner Join usuario As u
		On u.nr_matricula = f.nr_matricula_comprador
	Inner Join fornecedor As o
		On o.cd_fornecedor = f.cd_fornecedor
Where f.cd_fornecedor = :fornecedor" arguments=(("fornecedor", string))  sort="nm_usuario A " )
