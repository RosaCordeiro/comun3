table(column=(type=long updatewhereclause=yes name=item_nf_venda_cd_filial dbname="item_nf_venda.cd_filial" )
 column=(type=long updatewhereclause=yes name=item_nf_venda_nr_nf dbname="item_nf_venda.nr_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_venda.dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=nf_venda_dh_cancelamento dbname="nf_venda.dh_cancelamento" )
 column=(type=char(3) updatewhereclause=yes name=item_nf_venda_de_especie dbname="item_nf_venda.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=item_nf_venda_de_serie dbname="item_nf_venda.de_serie" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="item_nf_venda.cd_produto" )
 column=(type=char(255) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="item_nf_venda.qt_vendida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_praticado dbname="item_nf_venda.vl_preco_praticado" )
 column=(type=char(6) updatewhereclause=yes name=nr_matric_operador dbname="nf_venda.nr_matric_operador" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 retrieve="Select inf.cd_filial,
		 inf.nr_nf,
		 nf.dh_emissao,
		 nf.dh_cancelamento,
		 inf.de_especie,
		 inf.de_serie,
 		 inf.cd_produto,
		 pg.de_produto + ' : ' + pg.de_apresentacao_estoque de_produto,
		 inf.qt_vendida,
		 inf.vl_preco_praticado,
		 nf.nr_matric_operador,
		 u.nm_usuario
From item_nf_venda inf
Inner Join nf_venda nf
		On  nf.nr_nf = inf.nr_nf
		And nf.de_especie 	= inf.de_especie
		And nf.de_serie 	= inf.de_serie
		And nf.cd_filial = inf.cd_filial
Inner Join produto_geral pg
	On pg.cd_produto = inf.cd_produto
Inner Join usuario u
	On u.nr_matricula = nf.nr_matric_operador
where exists (	select *
					from produto_geral pg
						inner join subcategoria sc
							on sc.cd_subcategoria = pg.cd_subcategoria
						inner join categoria c
							on c.cd_categoria = sc.cd_categoria
						where inf.cd_produto = pg.cd_produto
							and pg.cd_produto_sap is not null
							and pg.id_situacao = 'A'
							and (pg.cd_grupo_produto = 8 Or sc.cd_categoria in ('206040','206041'))
							and pg.cd_produto not in (740554, 740555,740556))
and  nf.cd_filial = dbo.uf_Filial_Parametro()
and nf.dh_emissao   between :dt_inicio  and :dt_fim" arguments=(("dt_inicio", datetime),("dt_fim", datetime)) )
