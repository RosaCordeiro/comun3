table(column=(type=char(9) update=yes updatewhereclause=yes name=cd_distribuidora dbname="produto_compra_desbloqueio.cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="produto_compra_desbloqueio.cd_produto" )
 column=(type=char(101) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(2) update=yes updatewhereclause=yes name=cd_unidade_federacao dbname="produto_compra_desbloqueio.cd_unidade_federacao" )
 column=(type=char(2) update=yes updatewhereclause=yes name=id_rede_filial dbname="produto_compra_desbloqueio.id_rede_filial" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_desbloqueio dbname="produto_compra_desbloqueio.cd_desbloqueio" )
 column=(type=char(40) updatewhereclause=yes name=nm_unidade_federacao dbname="unidade_federacao.nm_unidade_federacao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inicio dbname="produto_compra_desbloqueio.dh_inicio" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_termino dbname="produto_compra_desbloqueio.dh_termino" )
 column=(type=char(1) updatewhereclause=yes name=id_aplicado dbname="produto_compra_desbloqueio.id_aplicado" )
 retrieve="SELECT p.cd_distribuidora as cd_distribuidora,
		 f.nm_fantasia as nm_fantasia,
       p.cd_produto as cd_produto, 
		 pg.de_produto + ' ' + pg.de_apresentacao_estoque as de_produto,
       p.cd_unidade_federacao as cd_unidade_federacao,
		 p.id_rede_filial as id_rede_filial,
		 p.cd_desbloqueio as cd_desbloqueio,
		 u.nm_unidade_federacao as nm_unidade_federacao,
		 p.dh_inicio as dh_inicio,
		 p.dh_termino as dh_termino,
		 p.id_aplicado
  FROM produto_compra_desbloqueio p
 left outer join fornecedor f        on f.cd_fornecedor = p.cd_distribuidora
 left outer join produto_geral pg    on pg.cd_produto   = p.cd_produto
 left outer join unidade_federacao u on u.cd_unidade_federacao = p.cd_unidade_federacao" update="produto_compra_desbloqueio" updatewhere=0 updatekeyinplace=yes )
