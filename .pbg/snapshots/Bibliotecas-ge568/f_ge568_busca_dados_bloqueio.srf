global function boolean f_ge568_busca_dados_bloqueio (long al_cd_produto, string as_cd_grupo, string as_cd_uf, string as_id_rede_filial, string as_id_lei_generico, ref long al_cd_bloqueio, ref decimal adc_limite, ref string as_mensagem)
