table(column=(type=char(255) updatewhereclause=yes name=de_observacao dbname="pbm_produto.de_observacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_industria dbname="pbm_produto.nm_industria" )
 column=(type=char(8190) updatewhereclause=yes name=id_utiliza_cartao_consumidor dbname="id_utiliza_cartao_consumidor" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_utiliza_cpf dbname="pbm_produto.id_utiliza_cpf" values="	0/	0" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_minimo dbname="pbm_produto.pc_desconto_minimo" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_maximo dbname="pbm_produto.pc_desconto_maximo" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_novo_paciente dbname="pbm_produto.pc_desconto_novo_paciente" initial="0" )
 column=(type=long updatewhereclause=yes name=qt_desconto_maximo dbname="pbm_produto.qt_desconto_maximo" )
 retrieve="  SELECT pro.de_observacao,
		pro.nm_industria,
		Case when coalesce(pro.id_utiliza_cartao_consumidor, 'N') = 'M' then 'S' else 'N' end as id_utiliza_cartao_consumidor,
		pro.id_utiliza_cpf,
		pro.pc_desconto_minimo,
		pro.pc_desconto_maximo,
		pro.pc_desconto_novo_paciente,
		pro.qt_desconto_maximo 
    FROM pbm_produto pro
   WHERE pro.cd_pbm		= :pbm
	  AND pro.cd_produto = :produto" arguments=(("pbm", number),("produto", number)) )
