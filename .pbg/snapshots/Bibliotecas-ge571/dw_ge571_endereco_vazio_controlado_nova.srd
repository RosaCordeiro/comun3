table(column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_endereco_produto.cd_produto" dbalias="a.cd_produto" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="wms_endereco_produto.cd_endereco" dbalias="a.cd_endereco" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="wms_endereco_produto.nr_lote" dbalias="a.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="wms_endereco_produto.dh_inclusao" dbalias="a.dh_inclusao" )
 retrieve="-------------------- PRODUTOS CONTROLADOS   ---------------------------
--- Lista todos os registros na wms_endereco_produto
--  N$$HEX1$$c300$$ENDHEX$$O pode ter saldo no Flow
-- N$$HEX1$$c300$$ENDHEX$$O pode ter movimentacao
-- N$$HEX1$$c300$$ENDHEX$$O pode ter abastecimento
-- N$$HEX1$$c300$$ENDHEX$$O pode ter saldo no Segregado: Retirada de Excesso//RET. EXCESSO
-- N$$HEX1$$c300$$ENDHEX$$O pode estar em processo de separacao no momento de exclusao
-- N$$HEX1$$c300$$ENDHEX$$O pode ter saldo no bairro que esta com o campo : id_bloq_exclusao_end_controlado = ~"S~"
Select a.cd_produto , 
		a.cd_endereco 	,
		a.nr_lote,
		a.dh_inclusao
From   wms_endereco_produto a
Inner join vw_wms_endereco b on b.cd_endereco  =a.cd_endereco 
Inner join produto_geral c on c.cd_produto  = a.cd_produto 
Inner join produto_central d on d.cd_produto  = a.cd_produto 
Where c.cd_grupo_psico is not null
And   a.nr_lote is not null   
And   a.cd_esteira  = 3 
and not exists (		select l.cd_produto, l.nr_lote, l.dh_validade
						from wms_bairro b
						inner join wms_endereco e on e.cd_bairro = b.cd_bairro
						inner join wms_localizacao l on l.cd_endereco = e.cd_endereco
						where b.id_flow_rack = 'S'
						  and b.id_utiliza_saldo = 'S'
						  and l.cd_produto = a.cd_produto
						  and l.nr_lote 		= a.nr_lote)
and not exists  ( select * 
				from wms_movimentacao m
				where m.cd_produto  = a.cd_produto
				and   m.nr_lote  = a.nr_lote )  
and not exists  ( select  *
				  from wms_abastecimento_flow_rack abst
				  where abst.cd_produto  = a.cd_produto 
				  	and abst.nr_lote  = a.nr_lote )  
and  not  exists ( 	select  x1.cd_produto, x1.nr_lote, x1.dh_validade
					from 	wms_localizacao x1
					where   x1.cd_endereco 		=  'B900200A'					
					and     x1.cd_produto 		= a.cd_produto
					 and    x1.nr_lote 				= a.nr_lote  ) 	
and  not  exists ( 	select  x2.cd_produto, x2.nr_lote, x2.dh_validade  
						from 	wms_localizacao x2
						where   x2.cd_endereco 		=  'B900600A'					
						and     x2.cd_produto 		= a.cd_produto
						 and    x2.nr_lote 				= a.nr_lote) 	
and not exists (select * 
					from wms_lista_separacao wls 
					inner join dbo.wms_lista_separacao_produto wlsp 
								      on wlsp.cd_filial = wls.cd_filial 
								      and wlsp.nr_pedido_distribuidora = wls.nr_pedido_distribuidora 
				   where wls.cd_filial > 0
			       and wls.dh_geracao >= dateadd(day, -5, getdate())
			       and wls.cd_esteira = 3
			       and wls.dh_termino_conferencia is null
			       and wls.dh_cancelamento is null
			       and wlsp.cd_produto = a.cd_produto
			       and wlsp.cd_endereco_localizacao = a.cd_endereco)
and not exists ( select l1.cd_produto, l1.nr_lote, l1.dh_validade
					from wms_bairro b1
					inner join wms_endereco e1 on e1.cd_bairro = b1.cd_bairro
					inner join wms_localizacao l1 on l1.cd_endereco = e1.cd_endereco
					where  b1.id_bloq_excl_end_controlado='S' 
					and l1.cd_produto = a.cd_produto
					and l1.nr_lote    = a.nr_lote)




"  sort="cd_produto A " )
