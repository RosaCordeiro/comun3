table(column=(type=char(1) updatewhereclause=yes name=id_selecionado dbname="id_selecionado" values="	S/	N" )
 column=(type=char(66) updatewhereclause=yes name=nm_campo_clamed dbname="nm_campo_clamed" )
 column=(type=char(43) updatewhereclause=yes name=nm_campo_distrib dbname="nm_campo_distrib" )
 column=(type=char(10) updatewhereclause=yes name=de_label dbname="de_label" )
 retrieve="select id_selecionado = ~"S~"
     , nm_campo_clamed = ~"TODOS~"
     , nm_campo_distrib = ~"TODOS~"
     , de_label = ~"TODOS~"
 union
 select id_selecionado = ~"N~"
      , nm_campo_clamed = ~"coalesce(g.nr_classificacao_fiscal, -1)~"
      , nm_campo_distrib = ~"coalesce(d.ncm_produto, -1)~"
      , de_label = ~"NCM~"
  union
 select id_selecionado = ~"N~"
      , nm_campo_clamed = ~"coalesce(g.id_situacao, 'NULL')~"
      , nm_campo_distrib = ~"coalesce(d.id_situacao, 'NULL')~"
      , de_label = ~"SITUA$$HEX2$$c700c300$$ENDHEX$$O~"
  union
 select id_selecionado = ~"N~"
      , nm_campo_clamed = ~"coalesce(g.cd_cest, '0')~"
      , nm_campo_distrib = ~"coalesce(convert(varchar, d.cd_cest), '0')~"
      , de_label = ~"CEST~"
  union
 select id_selecionado = ~"N~"
      , nm_campo_clamed = ~"coalesce(t.cd_cst_tributacao, 'NULL')~"
      , nm_campo_distrib = ~"coalesce(substring(d.cd_cst, 2, 2), 'NULL')~"
      , de_label = ~"CST~"
  union
 select id_selecionado = ~"N~"
      , nm_campo_clamed = ~"coalesce(ti.pc_icms, 0)~"
      , nm_campo_distrib = ~"coalesce(d.pc_icms_st, 0)~"
      , de_label = ~"ICMS ST(%)~"
  union
 select id_selecionado = ~"N~"
      , nm_campo_clamed = ~"coalesce(tpfm.pc_mva, 0)~"
      , nm_campo_distrib = ~"coalesce(d.pc_mva, 0)~"
      , de_label = ~"MVA(%)~"
  union
 select id_selecionado = ~"N~"
      , nm_campo_clamed = ~"coalesce(g.cd_st_origem, NULL)~"
      , nm_campo_distrib = ~"coalesce(substring(d.cd_cst, 1, 1), NULL)~"
      , de_label = ~"ORIGEM~"
  union
 select id_selecionado = ~"N~"
      , nm_campo_clamed = ~"coalesce(round(u.vl_preco_venda_maximo/g.vl_fator_conversao,2), 0)~"
      , nm_campo_distrib = ~"coalesce(d.vl_pmc, 0)~"
      , de_label = ~"VL. PMC~"
" )
