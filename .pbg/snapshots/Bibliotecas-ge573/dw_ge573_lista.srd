table(column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(101) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="de_codigo_barras" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="cd_fornecedor_usual" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia_fornecedor dbname="nm_fantasia_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="nm_usuario" )
 column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cd_unidade_federacao" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_distribuidora dbname="cd_produto_distribuidora" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_preco_utilizado dbname="vl_preco_utilizado" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_utilizado dbname="pc_desconto_utilizado" )
 column=(type=char(1) updatewhereclause=yes name=id_icms_st dbname="id_icms_st" )
 column=(type=long updatewhereclause=yes name=ncm_clamed dbname="ncm_clamed" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_clamed dbname="id_situacao_clamed" )
 column=(type=char(7) updatewhereclause=yes name=cd_cest_clamed dbname="cd_cest_clamed" )
 column=(type=char(1) updatewhereclause=yes name=cd_origem_clamed dbname="cd_origem_clamed" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_clamed dbname="cd_cst_clamed" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_st_clamed dbname="pc_icms_st_clamed" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_mva_clamed dbname="pc_mva_clamed" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_pmc_clamed dbname="vl_pmc_clamed" )
 column=(type=long updatewhereclause=yes name=ncm_distrib dbname="ncm_distrib" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_distrib dbname="id_situacao_distrib" )
 column=(type=char(7) updatewhereclause=yes name=cd_cest_distrib dbname="cd_cest_distrib" )
 column=(type=char(1) updatewhereclause=yes name=cd_origem_distrib dbname="cd_origem_distrib" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_distrib dbname="cd_cst_distrib" )
 column=(type=char(3) updatewhereclause=yes name=cd_origem_e_cst_arquivo_preco dbname="cd_origem_e_cst_arquivo_preco" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_st_distrib dbname="pc_icms_st_distrib" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_mva_distrib dbname="pc_mva_distrib" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pmc_distrib dbname="vl_pmc_distrib" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao_distribuidora dbname="dh_atualizacao_distribuidora" )
 column=(type=char(1) updatewhereclause=yes name=id_divergente_ncm dbname="id_divergente_ncm" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_divergente_cest dbname="id_divergente_cest" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_divergente_origem dbname="id_divergente_origem" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_divergente_cst dbname="id_divergente_cst" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_divergente_icmsst dbname="id_divergente_icmsst" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_divergente_mva dbname="id_divergente_mva" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_divergente_pmc dbname="id_divergente_pmc" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_divergente_situacao dbname="id_divergente_situacao" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 retrieve="select d.cd_produto, 
		 g.de_produto + ' ' + g.de_apresentacao_estoque as de_produto,
 		 g.de_codigo_barras,
		 g.cd_fornecedor_usual,
 		 fr.nm_fantasia nm_fantasia_fornecedor,
 		 uc.nm_usuario, 
		 d.cd_distribuidora,
		 fo.nm_fantasia,
		 d.cd_unidade_federacao,
		 d.cd_produto_distribuidora,
		 case when d.cd_distribuidora  = par.cd_distribuidora_estoque
		      then ((IsNull(d.vl_preco_novo, d.vl_preco_atual) *0.05) + IsNull(d.vl_preco_novo, d.vl_preco_atual))    
		      else  IsNull(d.vl_preco_novo, d.vl_preco_atual) 
		      end  as vl_preco_utilizado,
		 IsNull(d.pc_desconto_novo, d.pc_desconto_atual) as pc_desconto_utilizado,
		 t.id_icms_st ,
		 g.nr_classificacao_fiscal as ncm_clamed,
		 g.id_situacao as id_situacao_clamed,
		 coalesce(g.cd_cest, '0') as cd_cest_clamed,
       	g.cd_st_origem as cd_origem_clamed,
		 t.cd_cst_tributacao as cd_cst_clamed,
		 ti.pc_icms as pc_icms_st_clamed,
		 coalesce(tpfm.pc_mva, 0.00)  as pc_mva_clamed,
		 round(u.vl_preco_venda_maximo/g.vl_fator_conversao,2) as vl_pmc_clamed,
		d.ncm_produto as ncm_distrib,
		d.id_situacao as id_situacao_distrib,
		cast(d.cd_cest as varchar(7)) as cd_cest_distrib,
      	case when len(ltrim(rtrim(coalesce(d.cd_cst, '')))) = 3 then substring(d.cd_cst, 1, 1)
		else null
		end as cd_origem_distrib,
		case when len(ltrim(rtrim(coalesce(d.cd_cst, '')))) = 3 then substring(d.cd_cst, 2, 2)
		else null
		end as cd_cst_distrib,
		d.cd_cst as cd_origem_e_cst_arquivo_preco,
		d.pc_icms_st as pc_icms_st_distrib,
		d.pc_mva  as pc_mva_distrib,
		d.vl_pmc as vl_pmc_distrib,
       	d.dh_atualizacao_distribuidora as dh_atualizacao_distribuidora,
		case when coalesce(g.nr_classificacao_fiscal, -1) <> coalesce(d.ncm_produto, -1) then 'S' else 'N' end id_divergente_ncm,
		case when coalesce(g.cd_cest, '0') <> coalesce(convert(varchar, d.cd_cest), '0') then 'S' else 'N' end id_divergente_cest,
		case when coalesce(g.cd_st_origem, NULL) <> coalesce(substring(d.cd_cst, 1, 1), NULL) then 'S' else 'N' end id_divergente_origem,
		case when coalesce(t.cd_cst_tributacao, 'NULL') <> coalesce(substring(d.cd_cst, 2, 2), 'NULL') then 'S' else 'N' end id_divergente_cst,
		case when coalesce(ti.pc_icms, 0) <> coalesce(d.pc_icms_st, 0) then 'S' else 'N' end id_divergente_icmsst,
		case when coalesce(tpfm.pc_mva, 0) <> coalesce(d.pc_mva, 0) then 'S' else 'N' end id_divergente_mva,
		case when coalesce(round(u.vl_preco_venda_maximo/g.vl_fator_conversao,2), 0) <> coalesce(d.vl_pmc, 0) then 'S' else 'N' end id_divergente_pmc,
		case when coalesce(g.id_situacao, 'NULL') <> coalesce(d.id_situacao, 'NULL') then 'S' else 'N' end id_divergente_situacao
from distribuidora_produto d
	inner join produto_geral g                      on g.cd_produto = d.cd_produto 
	inner join fornecedor fr on fr.cd_fornecedor = g.cd_fornecedor_usual
	inner join produto_uf u                         on u.cd_produto = d.cd_produto                          and u.cd_unidade_federacao = d.cd_unidade_federacao 
	inner join tributacao_icms t                    on t.cd_tributacao_icms = u.cd_tributacao_icms 
	inner join tipo_icms ti                         on ti.cd_tipo_icms = u.cd_tipo_icms
	inner join fornecedor fo                        on fo.cd_fornecedor = d.cd_distribuidora
	inner join distribuidora_uf duf                 on duf.cd_distribuidora = d.cd_distribuidora            and duf.cd_unidade_federacao = d.cd_unidade_federacao
	inner join produto_central c                    on c.cd_produto = d.cd_produto
	left outer join usuario uc on uc.nr_matricula  = c.nr_matricula_comprador 
	left outer join tributa_produtos_farm_mva tpfm on tpfm.cd_tributacao_produto = u.cd_tributacao_produto and tpfm.pc_icms = u.pc_icms_compra_preco,
	parametro par
 where par.id_parametro = '1'
	and d.cd_unidade_federacao <> 'BA'
	and d.cd_distribuidora <> '053404705'
	and CAST(stuff(fo.nr_layout_ped_eletronico_sap, charindex( '.', fo.nr_layout_ped_eletronico_sap ), 1, null) as Integer) >= 128
	and (select count(*)
			from filial_distribuidora fd
				inner join filial fi on fi.cd_filial = fd.cd_filial 
				inner join cidade ci on ci.cd_cidade = fi.cd_cidade 
			where fd.cd_distribuidora = d.cd_distribuidora 
				and ci.cd_unidade_federacao = d.cd_unidade_federacao
				and fi.id_pedido_centralizado = 'S'
				and fi.id_situacao = 'A'
				and fd.id_situacao = 'A') > 0
" )
