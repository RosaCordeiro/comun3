table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia_distribuidora dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="nr_pedido" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_pedido dbname="id_situacao_pedido" )
 column=(type=char(200) updatewhereclause=yes name=de_log dbname="de_log" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="de_chave_acesso" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao dbname="dh_movimentacao" )
 column=(type=char(20) updatewhereclause=yes name=cd_filial_distribuidora dbname="cd_filial_distribuidora" )
 column=(type=decimal(0) updatewhereclause=yes identity=yes name=nr_log dbname="nr_log" )
 column=(type=char(1) updatewhereclause=yes name=log_importacao_nf_ped_elet_id_resolvido dbname="id_resolvido" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionado dbname="id_selecionado" initial="N" values="	S/	N" )
 column=(type=char(200) update=yes updatewhereclause=yes name=de_situacao dbname="de_situacao" )
 column=(type=char(1) updatewhereclause=yes name=id_loja dbname="id_loja" )
 column=(type=char(2) update=yes updatewhereclause=yes name=id_situacao dbname="id_situacao" values="PENDENTE TI	PT/PROBLEMA	PR/" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso_destinadas dbname="de_chave_acesso_destinadas" )
 column=(type=datetime updatewhereclause=yes name=dh_consumo_indev_dest dbname="dh_consumo_indev_dest" )
 column=(type=datetime updatewhereclause=yes name=dh_ultimo_nsu dbname="dh_ultimo_nsu" )
 column=(type=datetime updatewhereclause=yes name=dh_importacao dbname="dh_importacao" )
 retrieve="SELECT DISTINCT 
	linpe.cd_filial,
	f.nm_fantasia,
	linpe.cd_distribuidora,
	fo.nm_fantasia,
	linpe.nr_nf,
	linpe.dh_emissao,
	linpe.nr_pedido,
	pd.id_situacao as id_situacao_pedido,
	linpe.de_log,
	linpe.de_chave_acesso,
	linpe.dh_movimentacao,
	fd.cd_filial_distribuidora,
	linpe.nr_log,
	Coalesce(linpe.id_resolvido, ~"N~") As id_resolvido,
	~"~" As id_selecionado,
	linpe.de_situacao,
	linpe.id_loja,
	linpe.id_situacao,
	nd.de_chave_acesso as de_chave_acesso_destinadas,
	(select CAST(SUBSTRING(pl.vl_parametro, 7, 4) + '-' +SUBSTRING(pl.vl_parametro, 4, 2) + '-' +SUBSTRING(pl.vl_parametro, 1, 2) + ' ' +SUBSTRING(pl.vl_parametro, 12, 8) AS DATETIME) from parametro_loja pl where pl.cd_parametro = 'DH_FIM_CONSUMO_INDEVIDO_DEST' and pl.cd_filial = linpe.cd_filial and ISDATE(pl.vl_parametro) = 1) as dh_consumo_indev_dest,
	nsu.dh_ultimo_nsu,
	linpe.dh_importacao
FROM 
	log_importacao_nf_ped_elet AS linpe
LEFT OUTER JOIN 
	pedido_distribuidora pd
	ON pd.cd_filial	= linpe.cd_filial
	AND pd.cd_distribuidora	= linpe.cd_distribuidora
	AND pd.nr_pedido_distribuidora	= linpe.nr_pedido
LEFT OUTER JOIN 
	nfe_destinadas nd
	ON nd.de_chave_acesso = linpe.de_chave_acesso
LEFT OUTER JOIN 
	filial AS f
	ON f.cd_filial = linpe.cd_filial
LEFT OUTER JOIN 
	fornecedor AS fo
	ON fo.cd_fornecedor = linpe.cd_distribuidora
LEFT OUTER JOIN 
	filial_distribuidora AS fd
	ON fd.cd_filial	=linpe.cd_filial
	AND fd.cd_distribuidora	= linpe.cd_distribuidora
LEFT OUTER JOIN (SELECT
							max(ndnh.dh_registro) as dh_ultimo_nsu, 
							ndnh.cd_filial
						FROM
							nfe_destinadas_nsu_historico ndnh
						WHERE
							ndnh.dh_registro >= cast(getdate() as date)
						GROUP BY
							ndnh.cd_filial) as nsu
	ON nsu.cd_filial = linpe.cd_filial
WHERE NOT EXISTS (SELECT 1 FROM nf_compra AS n WHERE n.de_chave_acesso = linpe.de_chave_acesso)
	AND NOT EXISTS (SELECT * FROM nf_compra_pendente AS n WHERE n.de_chave_acesso = linpe.de_chave_acesso)
	AND NOT EXISTS (SELECT * FROM nfe_compra_pendente AS n WHERE n.de_chave_acesso = linpe.de_chave_acesso)
	AND NOT EXISTS (SELECT * FROM nfe_destinadas n WHERE n.de_chave_acesso = linpe.de_chave_acesso and n.id_situacao_nf in ('2', '3'))
	AND  NOT EXISTS (SELECT * FROM nfe_destinadas n WHERE n.de_chave_acesso = linpe.de_chave_acesso and n.id_tipo_nf = '0') -- NOTA ENTRADA
	AND  NOT EXISTS (SELECT * FROM nfe_destinadas n WHERE n.de_chave_acesso = linpe.de_chave_acesso and n.id_finnfe = '2') -- NOTA COMPLEMENTAR
	AND  NOT EXISTS (SELECT * FROM nfe_indexacao n WHERE n.id_nf = linpe.de_chave_acesso and n.id_finnfe = '2') -- NOTA COMPLEMENTAR
	AND  NOT EXISTS (SELECT 1 FROM log_exclusao_nf_compra n WHERE  n.de_chave_acesso = linpe.de_chave_acesso and n.id_reimportada = 'N') -- NOTA EXCLUIDA
	AND linpe.dh_movimentacao >= :dt_inicio
	AND linpe.dh_movimentacao <= :dt_termino
	AND linpe.de_log NOT LIKE ('ESTA NF JA EST$$HEX1$$c100$$ENDHEX$$ VINCULADA AO PEDIDO%')
	AND linpe.de_log NOT LIKE ('ESSA NOTA FOI EMITIDA COMO NOTA DE ENTRADA.')
	AND linpe.cd_filial <> 1
ORDER BY 
	linpe.cd_distribuidora,
	linpe.dh_emissao,
	linpe.cd_filial" arguments=(("dt_inicio", datetime),("dt_termino", datetime)) )
