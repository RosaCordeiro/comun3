table(column=(type=char(30) updatewhereclause=yes name=base_dados dbname="base_dados" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="saldo_produto.cd_produto" dbalias="s.cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="pg.cd_produto_sap" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="saldo_produto.cd_filial" dbalias="s.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=cd_filial_sap dbname="integracao_sap.cd_filial_sap" dbalias="is2.cd_filial_sap" )
 column=(type=char(9) updatewhereclause=yes name=ambiente_wms dbname="AMBIENTE_WMS" )
 column=(type=char(4) updatewhereclause=yes name=deposito_sap dbname="DEPOSITO_SAP" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="pg.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_estoque dbname="produto_geral.de_apresentacao_estoque" dbalias="pg.de_apresentacao_estoque" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="pg.de_apresentacao_venda" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" dbalias="pg.cd_grupo_psico" )
 column=(type=char(40) updatewhereclause=yes name=de_grupo dbname="vw_classificacao_produto.de_grupo" dbalias="vcp.de_grupo" )
 column=(type=char(40) updatewhereclause=yes name=de_subgrupo dbname="vw_classificacao_produto.de_subgrupo" dbalias="vcp.de_subgrupo" )
 column=(type=char(40) updatewhereclause=yes name=de_subcategoria dbname="vw_classificacao_produto.de_subcategoria" dbalias="vcp.de_subcategoria" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="pg.vl_fator_conversao" )
 column=(type=char(3) updatewhereclause=yes name=unidade_medida dbname="unidade_medida" )
 column=(type=long updatewhereclause=yes name=ncm dbname="produto_geral.NCM" dbalias="pg.NCM" )
 column=(type=char(13) updatewhereclause=yes name=de_registro_ms dbname="produto_geral.de_registro_ms" dbalias="pg.de_registro_ms" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="saldo_produto.qt_saldo_final" dbalias="s.qt_saldo_final" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_medio dbname="saldo_produto.vl_custo_medio" dbalias="s.vl_custo_medio" )
 retrieve="select db_name() base_dados,
		 s.cd_produto,
		 pg.cd_produto_sap,
		 s.cd_filial, 
		 is2.cd_chave_sap as cd_filial_sap,
		 (CASE WHEN cd_filial = 1 THEN 'SEGREGADO' WHEN cd_filial  = 534 THEN 'LIBERADO' ELSE 'LOJA' END) AMBIENTE_WMS,
		 (CASE WHEN cd_filial = 1 THEN '0002' WHEN cd_filial  = 534 THEN '0001' ELSE '0005' END) DEPOSITO_SAP,
		 pg.de_produto,
		 pg.de_apresentacao_estoque ,
		 pg.de_apresentacao_venda,
		 pg.cd_grupo_psico,
		 vcp.de_grupo,
		 vcp.de_subgrupo,
		 vcp.de_subcategoria,
		 pg.vl_fator_conversao,
		 (CASE WHEN pg.vl_fator_conversao = 1 THEN pg.cd_unidade_medida_venda ELSE 'CXU' END) unidade_medida,
		 pg.nr_classificacao_fiscal NCM,
		 pg.de_registro_ms,
		 s.qt_saldo_final,
		 s.vl_custo_medio 
  from dbo.saldo_produto s
 inner join dbo.produto_geral pg on pg.cd_produto = s.cd_produto 
 inner join dbo.vw_classificacao_produto vcp on vcp.cd_subcategoria  = pg.cd_subcategoria 
 inner join dbo.integracao_sap is2 on is2.cd_chave_legado = cast(s.cd_filial as varchar)
								 			 and is2.cd_tabela = 'FILIAL'
 where ((is2.cd_chave_sap	in (:acd_filiais) and :atodas_filiais = 'N') or :atodas_filiais = 'S')
   and s.dh_saldo 		= :adh_saldo
   and s.qt_saldo_final <> 0
 order by s.cd_produto, 
			 s.cd_filial" arguments=(("acd_filiais", stringlist),("adh_saldo", date),("atodas_filiais", string)) )
