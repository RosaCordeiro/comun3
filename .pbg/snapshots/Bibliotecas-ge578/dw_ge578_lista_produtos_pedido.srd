table(column=(type=char(2) updatewhereclause=yes name=cd_situacao_trib_faturamento dbname="cd_situacao_trib_faturamento" )
 column=(type=char(8) updatewhereclause=yes name=cd_local_estocagem dbname="produto_central.cd_local_estocagem" dbalias="pc.cd_local_estocagem" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="pg.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" dbalias="pg.cd_produto_sap" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" dbalias="pg.vl_fator_conversao" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" dbalias="pg.de_codigo_barras" )
 column=(type=char(2) updatewhereclause=yes name=cd_grupo_psico dbname="produto_geral.cd_grupo_psico" dbalias="pg.cd_grupo_psico" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="qt_estoque_base" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="qt_pedida" initial="1" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo dbname="vl_custo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_gerencial dbname="vl_custo_gerencial" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="pc_icms" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="cd_natureza_operacao" )
 column=(type=char(2) updatewhereclause=yes name=cd_situacao_tributaria dbname="cd_situacao_tributaria" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_st dbname="vl_bc_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms dbname="vl_bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="vl_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_st dbname="pc_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_venda_maximo dbname="vl_preco_venda_maximo" )
 column=(type=decimal(5) updatewhereclause=yes name=pc_reducao_base_st dbname="pc_reducao_base_st" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_mva dbname="pc_mva" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_bc_icms_antecipacao dbname="vl_bc_icms_antecipacao" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_mva_icms_antecipacao dbname="pc_mva_icms_antecipacao" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_icms_antecipacao dbname="pc_icms_antecipacao" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_icms_antecipacao dbname="vl_icms_antecipacao" )
 column=(type=char(1) updatewhereclause=yes name=cd_cst_origem dbname="cd_cst_origem" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_tributacao dbname="cd_cst_tributacao" )
 column=(type=char(1) updatewhereclause=yes name=id_controlado dbname="id_controlado" )
 column=(type=long updatewhereclause=yes name=qt_saldo dbname="qt_saldo" )
 column=(type=char(6) updatewhereclause=yes name=cd_endereco_flow dbname="cd_endereco_flow" )
 column=(type=long updatewhereclause=yes name=qt_separacao dbname="qt_separacao" )
 column=(type=long updatewhereclause=yes name=qt_disponivel dbname="qt_disponivel" )
 column=(type=long updatewhereclause=yes name=qt_saldo_loja dbname="qt_saldo_loja" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_fcp dbname="pc_fcp" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_fcp dbname="vl_fcp" )
 column=(type=long updatewhereclause=yes name=qt_saldo_flow dbname="qt_saldo_flow" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_pis dbname="cd_cst_pis" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_cofins dbname="cd_cst_cofins" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_reducao_base_icms dbname="pc_reducao_base_icms" )
 column=(type=char(1) updatewhereclause=yes name=id_medicamento dbname="id_medicamento" )
 column=(type=char(10) updatewhereclause=yes name=cd_beneficio dbname="cd_beneficio" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_operacao dbname="vl_icms_operacao" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_icms_diferido dbname="pc_icms_diferido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_diferido dbname="vl_icms_diferido" )
 column=(type=long updatewhereclause=yes name=cd_motivo_transf_filial dbname="cd_motivo_transf_filial" )
 column=(type=char(1) updatewhereclause=yes name=cd_mod_bc_st dbname="cd_mod_bc_st" )
 retrieve="  SELECT	space(2) cd_situacao_trib_faturamento,
			pc.cd_local_estocagem,
			pg.cd_produto,   
			pg.de_produto + ~" : ~" + pg.de_apresentacao_estoque de_produto, 
			pg.cd_produto_sap,
			pg.vl_fator_conversao,
			pg.de_codigo_barras,
			pg.cd_grupo_psico,
			0			qt_estoque_base,
			0        qt_pedida,
			000.00   vl_custo,
			000.00	vl_custo_gerencial,
			000.00   pc_icms,
			0        cd_natureza_operacao,  
			space(2) cd_situacao_tributaria,
			000.00 vl_bc_icms_st,
			000.00 vl_icms_st,
			000.00 vl_bc_icms,
			000.00 vl_icms,
			000.00 pc_icms_st,
			000.00 vl_preco_venda_maximo,
			000.00000 pc_reducao_base_st,
			000.0000 pc_mva,
			000.0000 vl_bc_icms_antecipacao,
			000.0000 pc_mva_icms_antecipacao,
			000.0000 pc_icms_antecipacao,
			000.0000 vl_icms_antecipacao,
			space(1) cd_cst_origem,
			space(2) cd_cst_tributacao,
			'N' id_controlado,
			0 as qt_saldo,
			space(6) cd_endereco_flow,
			0 qt_separacao,
			0 qt_disponivel,
			0 qt_saldo_loja,
			0.00	pc_fcp,
			0.00	vl_fcp,
			0 qt_saldo_flow,
			space(2) cd_cst_pis,
			space(2) cd_cst_cofins,
			000.0000 pc_reducao_base_icms,
			'N' id_medicamento,
			space(10) cd_beneficio,
			000.00 vl_icms_operacao,
			000.0000 pc_icms_diferido,
			000.00 vl_icms_diferido,
			0 cd_motivo_transf_filial,
			space(1) cd_mod_bc_st 
FROM  produto_geral pg,
          produto_central pc
Where pg.cd_produto = pc.cd_produto"  sort="cd_situacao_trib_faturamento D de_produto A " )
