table(column=(type=long updatewhereclause=yes name=tabela_interface_sap_cd_tabela dbname="tabela_interface_sap.cd_tabela" dbalias="tis.cd_tabela" )
 column=(type=char(100) updatewhereclause=yes name=tabela_interface_sap_nm_tabela dbname="tabela_interface_sap.nm_tabela" dbalias="tis.nm_tabela" )
 column=(type=char(1) updatewhereclause=yes name=tabela_interface_sap_id_situacao dbname="tabela_interface_sap.id_situacao" dbalias="tis.id_situacao" )
 column=(type=char(1) updatewhereclause=yes name=tabela_interface_sap_id_subida_descida dbname="tabela_interface_sap.id_subida_descida" dbalias="tis.id_subida_descida" )
 column=(type=char(4) updatewhereclause=yes name=tabela_interface_sap_cd_modulo_sap dbname="tabela_interface_sap.cd_modulo_sap" dbalias="tis.cd_modulo_sap" )
 column=(type=long updatewhereclause=yes name=erros dbname="erros" )
 column=(type=long updatewhereclause=yes name=pendentes dbname="pendentes" )
 retrieve="		select tis.cd_tabela, 
				 tis.de_tabela nm_tabela, 
				 tis.id_situacao, 
				 tis.id_subida_descida, 
				 tis.cd_modulo_sap, 
				 sum((select count(*) 
						  from dbo.log_exportacao_sap les 
						 where les.id_tipo_nf 				= tlesn.id_tipo_nf 
							and les.id_status_integracao 	= 'E')) as erros,
				 sum((select count(*) 
						  from dbo.log_exportacao_sap les 
						 where les.id_tipo_nf 				= tlesn.id_tipo_nf 
							and les.id_status_integracao 	= 'C')) as pendentes
		  from dbo.tabela_interface_sap tis inner join dbo.tipo_log_exportacao_sap_nf tlesn on tlesn.cd_tabela = tis.cd_tabela
		 where tis.id_tabela_pai 		= 'S' 
			and tis.id_situacao 			= 'A' 
			and tis.id_subida_descida	= 'S'
	 group by tis.cd_tabela, 
				 nm_tabela, 
				 tis.id_situacao, 
				 tis.id_subida_descida, 
				 tis.cd_modulo_sap
union 
		select tis.cd_tabela, 
				 tis.de_tabela nm_tabela, 
				 tis.id_situacao, 
				 tis.id_subida_descida, 
				 tis.cd_modulo_sap, 
				 0,
				 0
		  from dbo.tabela_interface_sap tis 
  inner join dbo.tipo_log_exportacao_sap_nf tlesn 
			 on tlesn.cd_tabela = tis.cd_tabela
		 where tis.id_tabela_pai 		= 'S' 
			and tis.id_situacao 			= 'I' 
			and tis.id_subida_descida 	= 'S'
	 group by tis.cd_tabela, 
				 nm_tabela, 
				 tis.id_situacao, 
				 tis.id_subida_descida, 
				 tis.cd_modulo_sap
union
		select tis.cd_tabela, 
				 tis.de_tabela nm_tabela, 
				 tis.id_situacao, 
				 tis.id_subida_descida, 
				 tis.cd_modulo_sap, 
				 sum((select count(*) 
						  from dbo.interface_sap isap 
						 where isap.cd_tabela 	= tis.cd_tabela 
						   and isap.id_situacao 	= 'E')) erros,
				 sum((select count(*) 
						  from dbo.interface_sap isap 
						 where isap.cd_tabela 	= tis.cd_tabela 
						   and isap.id_situacao 	= 'C')) pendentes
		  from dbo.tabela_interface_sap tis 
		 where tis.id_tabela_pai 		= 'S' 
			and tis.id_situacao 			= 'A' 
			and tis.id_subida_descida	= 'D'
	 group by tis.cd_tabela, 
				 nm_tabela, 
				 tis.id_situacao, 
				 tis.id_subida_descida, 
				 tis.cd_modulo_sap
union
		select tis.cd_tabela, 
				 tis.de_tabela nm_tabela, 
				 tis.id_situacao, 
				 tis.id_subida_descida, 
				 tis.cd_modulo_sap, 
				 0,
				 0
		  from dbo.tabela_interface_sap tis 
		 where tis.id_tabela_pai 		= 'S' 
			and tis.id_situacao 			= 'I' 
			and tis.id_subida_descida 	= 'D'
	 group by tis.cd_tabela, 
				 nm_tabela, 
				 tis.id_situacao, 
				 tis.id_subida_descida, 
				 tis.cd_modulo_sap
order by id_situacao, erros  desc, pendentes desc, tis.cd_tabela " )
