table(column=(type=char(40) updatewhereclause=yes name=cd_chave_legado dbname="integracao_sap.cd_chave_legado" )
 column=(type=char(40) updatewhereclause=yes name=cd_chave_sap dbname="integracao_sap.cd_chave_sap" )
 column=(type=char(10) updatewhereclause=yes name=cd_tabela dbname="cd_tabela" )
 retrieve="SELECT
    cd_chave_legado,
    cd_chave_sap,
    'FORNECEDOR' as cd_tabela
FROM integracao_sap
WHERE cd_tabela = 'FORNECEDOR_TXB'
    AND cd_empresa = 1000
UNION
SELECT
    Case when rtrim(coalesce(fo.nr_cgc,''))='' then fo.nr_cpf else fo.nr_cgc end AS cd_chave_legado,
    fo.cd_fornecedor_sap AS cd_chave_sap,
    'FORNECEDOR' AS cd_tabela
FROM fornecedor fo
WHERE coalesce(fo.cd_fornecedor_sap,'') <> ''
    AND Case when rtrim(coalesce(nr_cgc,''))='' then nr_cpf else nr_cgc end <> ''
    AND NOT EXISTS (SELECT 1 FROM filial f1 where f1.nr_cgc = fo.nr_cgc)
    AND NOT EXISTS (SELECT 1 FROM integracao_sap isp1 WHERE isp1.cd_empresa = 1000 
and isp1.cd_tabela = 'FORNECEDOR_PRD' and isp1.cd_chave_legado = fo.nr_cgc)
" )
