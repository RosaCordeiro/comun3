table(column=(type=char(4) updatewhereclause=yes name=empresa dbname="empresa" )
 column=(type=char(6) updatewhereclause=yes name=periodo dbname="periodo" )
 column=(type=number updatewhereclause=yes name=chave dbname="chave" )
 column=(type=char(40) updatewhereclause=yes name=filial dbname="integracao_sap.filial" )
 column=(type=char(10) updatewhereclause=yes name=docdat dbname="docdat" )
 column=(type=char(10) updatewhereclause=yes name=pstdat dbname="pstdat" )
 column=(type=char(10) updatewhereclause=yes name=pagdat dbname="pagdat" )
 column=(type=char(12) updatewhereclause=yes name=docnum dbname="docnum" )
 column=(type=number updatewhereclause=yes name=itmnum dbname="itmnum" )
 column=(type=char(0) updatewhereclause=yes name=doctyp dbname="doctyp" )
 column=(type=char(3) updatewhereclause=yes name=series dbname="m3_seriedocto.series" )
 column=(type=char(0) updatewhereclause=yes name=material dbname="material" )
 column=(type=char(0) updatewhereclause=yes name=cfop dbname="cfop" )
 column=(type=char(0) updatewhereclause=yes name=ncm dbname="ncm" )
 column=(type=char(1) updatewhereclause=yes name=tiposaida dbname="tiposaida" )
 column=(type=char(10) updatewhereclause=yes name=codguia dbname="codguia" )
 column=(type=char(40) updatewhereclause=yes name=valcont dbname="valcont" )
 column=(type=char(40) updatewhereclause=yes name=irrate dbname="irrate" )
 column=(type=char(40) updatewhereclause=yes name=irbase dbname="irbase" )
 column=(type=char(40) updatewhereclause=yes name=irtaval dbname="irtaval" )
 column=(type=char(40) updatewhereclause=yes name=divisao dbname="integracao_sap.divisao" )
 column=(type=char(0) updatewhereclause=yes name=codpgto dbname="codpgto" )
 column=(type=char(2) updatewhereclause=yes name=tprenext dbname="tprenext" )
 column=(type=char(0) updatewhereclause=yes name=formatribut dbname="formatribut" )
 column=(type=char(0) updatewhereclause=yes name=rifontepg dbname="rifontepg" )
 column=(type=char(0) updatewhereclause=yes name=tpserv dbname="tpserv" )
 column=(type=char(0) updatewhereclause=yes name=cod_pais dbname="cod_pais" )
 column=(type=char(0) updatewhereclause=yes name=classtrib dbname="classtrib" )
 column=(type=char(0) updatewhereclause=yes name=razao dbname="razao" )
 column=(type=char(1) updatewhereclause=yes name=tipo_parceiro dbname="tipo_parceiro" )
 column=(type=char(0) updatewhereclause=yes name=id_parceiro dbname="id_parceiro" )
 column=(type=char(0) updatewhereclause=yes name=parceiro_ocasional dbname="parceiro_ocasional" )
 column=(type=char(20) updatewhereclause=yes name=cpf_cnpj dbname="cpf_cnpj" )
 column=(type=char(120) updatewhereclause=yes name=nome_companhia dbname="mtmg_ident.nome_companhia" )
 column=(type=char(3) updatewhereclause=yes name=relacao_benef dbname="relacao_benef" )
 column=(type=char(0) updatewhereclause=yes name=endereco dbname="endereco" )
 column=(type=char(0) updatewhereclause=yes name=numero dbname="numero" )
 column=(type=char(0) updatewhereclause=yes name=dds_complend dbname="dds_complend" )
 column=(type=char(0) updatewhereclause=yes name=bairro_distrito dbname="bairro_distrito" )
 column=(type=char(0) updatewhereclause=yes name=cep dbname="cep" )
 column=(type=char(0) updatewhereclause=yes name=uf_contribuinte dbname="uf_contribuinte" )
 column=(type=char(0) updatewhereclause=yes name=codigodopais dbname="codigodopais" )
 column=(type=char(0) updatewhereclause=yes name=telefone dbname="telefone" )
 column=(type=char(0) updatewhereclause=yes name=domfiscal dbname="domfiscal" )
 column=(type=char(0) updatewhereclause=yes name=caixa_postal dbname="caixa_postal" )
 column=(type=char(0) updatewhereclause=yes name=email dbname="email" )
 retrieve="SELECT  '1000' as Empresa,
        '12' || TO_CHAR(a.datavctosal, 'YYYY') as Periodo,
        row_number() OVER (ORDER BY (trim(to_char(COALESCE(DF.NROCONTRATO,0),'0000'))||trim(to_char(E.NRODOCTO,'000000')))) as Chave,
        r.CD_CHAVE_SAP as filial,
        to_char(a.dataemi,'dd.mm.yyyy') as docdat,
        to_char(a.datavctosal,'dd.mm.yyyy') as pstdat,
        to_char(a.datavctosal,'dd.mm.yyyy') as pagdat,   
        trim(to_char(COALESCE(DF.NROCONTRATO,0), '0000'))||trim(to_char(E.NRODOCTO,'000000')) as docnum,
        10 as itmnum,
        '' as doctyp,
        m1.codigo as series,
        '' as material,
        '' as cfop,
        '' as ncm,
        'D' as tiposaida,
        CASE WHEN xxx.codreceita='3208' THEN '320806' ELSE xxx.codreceita END as codguia,
        replace(to_char(coalesce(A.valori,0) + coalesce(xxx.valcofinsret, 0) + coalesce(xxx.valpisret, 0) + coalesce(xxx.valcsll, 0) + coalesce(xxx.valirrf_pagto, 0)),',','.') as valcont,
        replace(to_char(xxx.aliquota),',','.') as irrate,
        replace(to_char(xxx.baseimposto),',','.') as irbase,
        replace(to_char(xxx.valirrf_pagto),',','.') as irtaval,
        r.CD_CHAVE_SAP as Divisao,
        '' as CodPgto,
        Case substr(f.fd,7,1) when 'J' then 'PJ' else 'PF' End as tprenext,
        '' as formatribut,
        '' as rifontepg,
        '' as tpserv,
        '' as cod_pais,
        '' as classtrib,
        '' as Razao,
        'V' as Tipo_Parceiro,
        '' as ID_Parceiro,
        '' as Parceiro_Ocasional,
        replace(replace(replace(f.identificacao,'-',''),'/',''),'.','') as cpf_cnpj,
        f.nome as Nome_Companhia,
        '500' as Relacao_Benef,
        '' as Endereco,
        '' as Numero,
        '' as Dds_ComplEnd,
        '' as Bairro_Distrito,
        '' as CEP,
        '' as UF_Contribuinte,
        '' as CodigodoPais,
        '' as Telefone,
        '' as domfiscal,
        '' as Caixa_Postal,
        '' as Email
FROM m3_parcpa a
INNER JOIN m3_movfin c ON c.id = a.ida
INNER JOIN m3_integra d ON d.id = c.idf_integra
INNER JOIN m3_docto e ON e.id = d.idf_docto
INNER JOIN mtmg_ident f ON f.id = e.idf_ident
INNER JOIN m3_tipdoc g ON g.id = e.idf_tpdocto
INNER JOIN m3_padraodoc h ON h.id = g.idf_padraodocto
INNER JOIN m3_filial i ON i.id = e.idf_filial
INNER JOIN m3_fornecpa l ON l.ida = a.id
INNER JOIN m3_fornec m ON m.id = l.idf_fornec
INNER JOIN M3_SERIEDOCTO m1 ON m1.id = e.idf_seriedocto
LEFT OUTER JOIN M3_DOCTODEFIS df ON df.ida = e.id
LEFT OUTER JOIN INTEGRACAO_SAP r on r.CD_EMPRESA = :p_empresa_sap and r.CD_TABELA = 'FILIAL' and r.CD_CHAVE_LEGADO = i.CODIGO
LEFT OUTER JOIN m3_formapagto s on s.id = a.idf_formapagto
LEFT OUTER JOIN INTEGRACAO_SAP t on t.CD_EMPRESA = :p_empresa_sap and t.CD_TABELA = 'M3_FORMAPAGTO' and t.CD_CHAVE_LEGADO = S.CODIGO
LEFT OUTER JOIN m3_doctoparc u on u.numap = a.numap
LEFT OUTER JOIN integracao_sap_excecao AA on AA.cd_empresa = :p_empresa_sap AND AA.cd_tabela = 'TITULO_PAGAR' AND AA.CD_TIPO = 'TIPO_DOCTO' AND AA.CD_CHAVE = g.codtpdocto
INNER JOIN (select a2.idf_docto, 
                        a1.aliquota,
                        a1.id, 
                        a3.codreceita as codreceita,
                        sum(case when a3.tipo = '7' then a1.VALORIMPOSTO else 0.00 end) as valpisret,
                        sum(case when a3.tipo = '8' then a1.VALORIMPOSTO else 0.00 end) as valcofinsret,
                        sum(case when a3.tipo = '9' then a1.VALORIMPOSTO else 0.00 end) as valcsll,
                        sum(case when a3.tipo = 'G' then a1.VALORIMPOSTO else 0.00 end) as valcsrf,
                        sum(case when a3.tipo = '6' then case when a3.codreceita in ('3208', '9478') then a1.VALORIMPOSTO else 0.00 end else 0.00 end) as valirrf_pagto,
                        sum(case when a3.tipo = '6' then case when a3.codreceita in ('3208', '9478') then 0.00 else a1.VALORIMPOSTO end else 0.00 end) as valirrf_ent,
                        sum(case when a3.tipo = '5' then a1.VALORIMPOSTO else 0.00 end) as valiss,
                        sum(case when a3.tipo = 'B' then a1.VALORIMPOSTO else 0.00 end) as valinss,
                        sum(case when a3.tipo = '2' then a1.VALORIMPOSTO else 0.00 end) as valpis,
                        sum(case when a3.tipo = '3' then a1.VALORIMPOSTO else 0.00 end) as valcofins,
                        sum(BASECALCULO) baseimposto
                from m3_doctotrib a1
                inner join m3_partedocto a2 on a2.id = a1.ida
                inner join m3_imposto a3 on a3.id = a1.idf_imposto
                inner join m3_partedocto b1 on b1.idf_docto = a2.idf_docto 
                inner join m3_cabpadocto b2 on b2.ida = b1.id
                where a3.tipo = '6' --somente IRRF
                    and b2.dataprivencto between :p_data_inicio and :p_data_fim
                group by    a2.idf_docto, 
                            a1.aliquota,
                            a1.id, 
                            a3.codreceita) XXX on XXX.idf_docto = e.id
WHERE ( i.idf_empresa = :p_empresa_mult )
    AND ( coalesce(a.indadtoprov,'F') = 'F' )
    AND ( coalesce(a.indprev,'F') = 'F' )
    AND a.datavctosal between :p_data_inicio and :p_data_fim
    AND g.codtpdocto in ('A-AgruAlug','AgrupAlug','AlugContra','AlugEsta')
    AND f.fd='PessoaFisica'
    AND a.situacao is not null --apenas para utilizar o $$HEX1$$ed00$$ENDHEX$$ndice por data de vencimento
" arguments=(("p_empresa_mult", number),("p_empresa_sap", number),("p_data_inicio", date),("p_data_fim", date)) )
