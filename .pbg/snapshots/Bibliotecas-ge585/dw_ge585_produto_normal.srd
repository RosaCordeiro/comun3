table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_promocao_sos dbname="promocao_sos_produto.cd_promocao_sos" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="promocao_sos_produto.cd_produto" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto dbname="promocao_sos_produto.pc_desconto" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_anterior dbname="promocao_sos_produto.pc_desconto_anterior" initial="0" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_alteracao dbname="promocao_sos_produto.dh_alteracao" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(10) updatewhereclause=yes name=cd_sku_ecommerce dbname="ecommerce_prd.cd_sku_ecommerce" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_simulado dbname="vl_preco_simulado" initial="0" )
 column=(type=decimal(13) updatewhereclause=yes name=vl_preco_venda_atual dbname="vl_preco_venda_atual" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_aux dbname="vl_custo_aux" )
 column=(type=decimal(30) updatewhereclause=yes name=vl_imposto dbname="vl_imposto" )
 column=(type=decimal(26) updatewhereclause=yes name=vl_preco_final dbname="vl_preco_final" )
 column=(type=long updatewhereclause=yes name=cd_promocao_sos_ecommerce dbname="cd_promocao_sos_ecommerce" )
 column=(type=char(1) updatewhereclause=yes name=nm_promocao_sos_ecommerce dbname="nm_promocao_sos_ecommerce" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto_sos_ecommerce dbname="pc_desconto_sos_ecommerce" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_alteracao dbname="promocao_sos_produto.nr_matricula_alteracao" )
 column=(type=decimal(13) updatewhereclause=yes name=pc_rentabilidade dbname="pc_rentabilidade" )
 retrieve="select p.cd_promocao_sos,
       	p.cd_produto,   
       	p.pc_desconto,
       	p.pc_desconto pc_desconto_anterior,
       	p.dh_alteracao,
       	g.de_produto + ' : ' + g.de_apresentacao_venda de_produto,   
		pr.cd_sku cd_sku_ecommerce,
		g.id_situacao,
       	0.01 vl_preco_simulado,
	  	round(u.vl_preco_venda_atual / g.vl_fator_conversao, 2) vl_preco_venda_atual,
	  	//isnull(v.vl_custo_gerencial, 0.00) as vl_custo,
		case when v.vl_custo_gerencial > 0 then v.vl_custo_gerencial else c.vl_custo_gerencial end as vl_custo_aux,
		Round((case when u.cd_tributacao_icms  = '0' then (u.vl_preco_venda_atual / g.vl_fator_conversao) * ((100 - p.pc_desconto) / 100) * (t.pc_icms / 100) else 0 end), 2) as vl_imposto,
		Round((u.vl_preco_venda_atual / g.vl_fator_conversao) * ((100 - p.pc_desconto) / 100), 2) as vl_preco_final,
		0 cd_promocao_sos_ecommerce,
		'' nm_promocao_sos_ecommerce,
		0.00 pc_desconto_sos_ecommerce,
		p.nr_matricula_alteracao,
		round(round(((Round((u.vl_preco_venda_atual / g.vl_fator_conversao) * ((100 - p.pc_desconto) / 100), 2) -
		    (case when v.vl_custo_gerencial > 0 then v.vl_custo_gerencial else c.vl_custo_gerencial end +
		     Round(case when u.cd_tributacao_icms  = '0' then (u.vl_preco_venda_atual / g.vl_fator_conversao) * ((100 - p.pc_desconto) / 100) * (t.pc_icms / 100) else 0 end, 2))) / 
			  Round((u.vl_preco_venda_atual / g.vl_fator_conversao) * ((100 - p.pc_desconto) / 100), 2) ), 4)  * 100, 2) as pc_rentabilidade
from promocao_sos_produto p
	inner join produto_geral g
		on g.cd_produto 					= p.cd_produto
	inner join produto_central c
		on c.cd_produto					= g.cd_produto
	inner join produto_uf u
		on u.cd_produto					= p.cd_produto
	inner join tipo_icms t
		on t.cd_tipo_icms 					= u.cd_tipo_icms
	inner join vw_saldo_atual_produto v
		on v.cd_produto					= p.cd_produto
	left outer join ecommerce_prd pr
		on pr.id_rede_filial = :rede_ecommerce
		and pr.id_ecommerce = '2'
		and pr.cd_produto = p.cd_produto 
where p.cd_promocao_sos 			= :promocao
   and u.cd_unidade_federacao 	= :uf
   and v.cd_filial						= :filial" update="promocao_sos_produto" updatewhere=0 updatekeyinplace=no arguments=(("promocao", number),("uf", string),("filial", number),("rede_ecommerce", string))  sort="de_produto A " )
