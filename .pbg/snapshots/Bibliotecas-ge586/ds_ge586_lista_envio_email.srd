table(column=(type=long update=yes updatewhereclause=yes identity=yes name=nr_solicitacao dbname="resumo_reposicao_estoque_solic.nr_solicitacao" dbalias="a.nr_solicitacao" )
 column=(type=long update=yes updatewhereclause=yes name=cd_filial dbname="resumo_reposicao_estoque_solic.cd_filial" dbalias="a.cd_filial" )
 column=(type=char(136) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(50) updatewhereclause=yes name=de_motivo dbname="resumo_reposicao_estoque_solic.de_motivo" dbalias="a.de_motivo" )
 column=(type=char(49) updatewhereclause=yes name=nm_usuario dbname="nm_usuario" )
 column=(type=long updatewhereclause=yes name=qt_solicitacao dbname="resumo_reposicao_estoque_solic.qt_solicitacao" dbalias="a.qt_solicitacao" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_reposicao dbname="resumo_reposicao_estoque.cd_classe_reposicao" dbalias="x.cd_classe_reposicao" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="resumo_reposicao_estoque.qt_estoque_base" dbalias="x.qt_estoque_base" )
 retrieve="SELECT a.nr_solicitacao,
    a.cd_filial,
    cast(a.cd_produto as varchar) + ' - ' + pg.de_produto + ' : ' +  pg.de_apresentacao_estoque as de_produto,
    a.de_motivo,
    a.nr_matricula_responsavel + ' - ' + u.nm_usuario as nm_usuario,
    a.qt_solicitacao,
    x.cd_classe_reposicao,
    x.qt_estoque_base 
FROM resumo_reposicao_estoque_solic a
    INNER JOIN usuario u ON u.nr_matricula = a.nr_matricula_responsavel
    INNER JOIN produto_geral pg ON pg.cd_produto = a.cd_produto 
    INNER JOIN resumo_reposicao_estoque x ON x.cd_filial = a.cd_filial AND x.cd_produto = a.cd_produto 
WHERE a.id_situacao = 'RS'
    AND a.dh_envio_email IS NULL
    AND a.cd_filial = :al_filial
ORDER BY a.cd_filial,
    a.cd_produto,
    a.nr_matricula_responsavel" arguments=(("al_filial", number)) )
