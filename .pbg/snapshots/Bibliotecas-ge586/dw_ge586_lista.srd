table(column=(type=long updatewhereclause=yes key=yes identity=yes name=nr_solicitacao dbname="resumo_reposicao_estoque_solic.nr_solicitacao" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="resumo_reposicao_estoque_solic.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=cd_chave_sap dbname="integracao_sap.cd_chave_sap" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="resumo_reposicao_estoque_solic.cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="vw_saldo_atual_produto.qt_saldo_final" )
 column=(type=long updatewhereclause=yes name=qt_venda_periodo dbname="qt_venda_periodo" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base_definido dbname="resumo_reposicao_estoque.qt_estoque_base_definido" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="resumo_reposicao_estoque.qt_estoque_base" )
 column=(type=long updatewhereclause=yes name=dias dbname="dias" )
 column=(type=datetime updatewhereclause=yes name=dh_termino_bloqueio dbname="resumo_reposicao_estoque.dh_termino_bloqueio" )
 column=(type=datetime updatewhereclause=yes name=dh_solicitacao dbname="resumo_reposicao_estoque_solic.dh_solicitacao" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_solicitacao dbname="resumo_reposicao_estoque_solic.nr_matricula_solicitacao" )
 column=(type=long updatewhereclause=yes name=qt_solicitacao dbname="resumo_reposicao_estoque_solic.qt_solicitacao" )
 column=(type=long updatewhereclause=yes name=qt_dias_solicitacao dbname="resumo_reposicao_estoque_solic.qt_dias_solicitacao" )
 column=(type=long update=yes updatewhereclause=yes name=qt_aprovado dbname="resumo_reposicao_estoque_solic.qt_aprovado" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_responsavel dbname="resumo_reposicao_estoque_solic.nr_matricula_responsavel" )
 column=(type=char(50) update=yes updatewhereclause=yes name=de_motivo dbname="resumo_reposicao_estoque_solic.de_motivo" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_aprovacao dbname="resumo_reposicao_estoque_solic.dh_aprovacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_aprovacao dbname="usuario.nm_usuario_aprovacao" )
 column=(type=char(2) update=yes updatewhereclause=yes name=id_situacao dbname="resumo_reposicao_estoque_solic.id_situacao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_envio_email dbname="resumo_reposicao_estoque_solic.dh_envio_email" )
 column=(type=char(1) updatewhereclause=yes name=id_aprova_todos dbname="id_aprova_todos" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_aprova_parcial dbname="id_aprova_parcial" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_cancelar dbname="id_cancelar" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_capturar dbname="id_capturar" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_reposicao dbname="resumo_reposicao_estoque.cd_classe_reposicao" )
 column=(type=char(1) updatewhereclause=yes name=id_agrupamento dbname="filial.id_agrupamento" )
 retrieve="SELECT rres.nr_solicitacao, 
	rres.cd_filial, 
	insap.cd_chave_sap,
	f.nm_fantasia,  
	rres.cd_produto, 
	pg.cd_produto_sap,
	pg.de_produto + ' : ' +  pg.de_apresentacao_estoque as de_produto,
	pg.vl_fator_conversao,
	vsap.qt_saldo_final,
	--rre.qt_dias_venda,
	coalesce(rre.qt_venda_periodo, 0) as qt_venda_periodo,
	rre.qt_estoque_base_definido,
	rre.qt_estoque_base, 
	datediff(dd, getdate(), rre.dh_termino_bloqueio) 							As dias, 
	rre.dh_termino_bloqueio, 
	rres.dh_solicitacao, 
	rres.nr_matricula_solicitacao, 
	rres.qt_solicitacao, 
	rres.qt_dias_solicitacao,
	rres.qt_aprovado, 
	rres.nr_matricula_responsavel, 
	rres.de_motivo, 
	rres.dh_aprovacao, 
	ua.nm_usuario as nm_usuario_aprovacao,
	rres.id_situacao, 
	rres.dh_envio_email,
	(CASE WHEN rres.qt_solicitacao = rres.qt_aprovado THEN 'S' ELSE 'N' END) 	AS id_aprova_todos,		
	(CASE WHEN rres.qt_solicitacao <> rres.qt_aprovado and rres.qt_aprovado > 0 THEN 'S' ELSE 'N' END) 	AS id_aprova_parcial,	
	(CASE WHEN rres.id_situacao = 'RS' THEN 'S' ELSE 'N' END) 					AS id_cancelar,
	(CASE WHEN rres.nr_matricula_responsavel Is Null THEN 'N' ELSE 'S' END) 		AS id_capturar,
	rre.cd_classe_reposicao,
     f.id_agrupamento
From resumo_reposicao_estoque_solic rres 
Inner Join produto_geral pg on pg.cd_produto =rres.cd_produto
Inner Join filial f on f.cd_filial = rres.cd_filial 
Inner Join usuario us on us.nr_matricula = rres.nr_matricula_solicitacao 
Left Join usuario ua on ua.nr_matricula = rres.nr_matricula_responsavel 
Inner Join resumo_reposicao_estoque rre on rre.cd_produto = pg.cd_produto and rre.cd_filial = f.cd_filial 
Inner Join vw_saldo_atual_produto vsap on rre.cd_filial = vsap.cd_filial and rre.cd_produto = vsap.cd_produto
Left Join integracao_sap insap on insap.cd_tabela = 'FILIAL' and  insap.cd_chave_legado = cast(f.cd_filial as varchar)
Order By rres.dh_solicitacao, rres.cd_filial, rres.cd_produto" update="resumo_reposicao_estoque_solic" updatewhere=0 updatekeyinplace=no )
