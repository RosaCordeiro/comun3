table(column=(type=date updatewhereclause=yes name=dt_inclusao dbname="dt_inclusao" )
 column=(type=long updatewhereclause=yes name=mes dbname="mes" )
 column=(type=long updatewhereclause=yes name=ano dbname="ano" )
 column=(type=long updatewhereclause=yes name=qtd_caixa_sai_pulmao dbname="qtd_caixa_sai_pulmao" )
 column=(type=long updatewhereclause=yes name=qtd_unidades_entra_flow dbname="qtd_unidades_entra_flow" )
 retrieve="SELECT
	cast(a.dh_inclusao as date) as dt_inclusao,
	--datepart(day, a.dh_inclusao)             AS dia,
    datepart(month, a.dh_inclusao)             AS mes,
    datepart(year, a.dh_inclusao)                AS ano,
    SUM(a.qt_abastecer)                            AS qtd_caixa_sai_pulmao,
    SUM(round(a.qt_abastecer * a.qt_caixa_padrao, 2)) AS qtd_unidades_entra_flow
FROM
    dbo.wms_historico_abast_flow_rack a
    INNER JOIN dbo.produto_geral b ON b.cd_produto = a.cd_produto 
WHERE
    datepart(month, a.dh_inclusao) = :al_mes
	and datepart(year, a.dh_inclusao) = :al_ano
GROUP BY
    --a.cd_produto,
    cast(a.dh_inclusao as date) ,
    datepart(day, a.dh_inclusao),
    datepart(month, a.dh_inclusao),
    datepart(year, a.dh_inclusao)
ORDER BY 
	cast(a.dh_inclusao as date)" arguments=(("al_mes", number),("al_ano", number)) )
