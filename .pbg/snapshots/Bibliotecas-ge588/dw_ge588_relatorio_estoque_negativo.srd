table(column=(type=char(7) updatewhereclause=yes name=data_saldo dbname="data_saldo" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="saldo_produto.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="saldo_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="saldo_produto.qt_saldo_final" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="saldo_produto.vl_custo_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_total dbname="vl_custo_total" )
 retrieve="select 	substring(CONVERT( CHAR(10), s.dh_saldo, 103 ), 4, 7) data_saldo,
			s.cd_filial, 
			f.nm_fantasia,
			s.cd_produto, 
			g.de_produto + ' : ' + g.de_apresentacao_venda de_produto,
			s.qt_saldo_final, 
			s.vl_custo_medio vl_custo_unitario,
			s.vl_custo_medio * s.qt_saldo_final vl_custo_total
from saldo_produto s
inner join filial f on f.cd_filial = s.cd_filial
inner join produto_geral g on g.cd_produto = s.cd_produto
inner join vw_classificacao_produto v on v.cd_subcategoria = g.cd_subcategoria
where s.dh_saldo = :dt_saldo
  and s.qt_saldo_final < 0
  and s.cd_produto  not in (684431,135570, 135562, 693843, 123060, 577625, 700118,700733,700735,707439,712055, 700734,700495,693845,733271,722279,707440, 738062,741023,733631, 738063)
  and v.cd_grupo <> '7' " arguments=(("dt_saldo", datetime))  sort="qt_saldo_final D " )
