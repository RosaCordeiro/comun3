compute(band=detail alignment="0" expression="if((id_situacao_aprovacao='R') or (/*id_situacao_aprovacao='A' and */id_aprovado='N'),
     'R', /* Regra Reprovada */
     if(id_situacao_aprovacao='P', 
          'AP', /* Rel. Aprova$$HEX2$$e700e300$$ENDHEX$$o Pendente */
          if(not isnull(dh_retorno_sap), 
               'S', /* Sincronizada */
               if (id_aprovado='S' and isNull(dh_exportacao), 
                    'A', /* Aprovada/Aguardando Envio */
                    if(id_aprovado='S' and not isNull(dh_exportacao),
                         'E', /* Enviada/Aguardando retorno */
                         ''
                    )
               )
          )
     )
)"border="0" color="33554432" x="5" y="80" height="52" width="55" format="[GENERAL]" html.valueishtml="0"  name=cpt_status visible="0"  font.face="Verdana" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="65535" background.transparency="0" background.gradient.color="8421504" background.gradient.transparency="0" background.gradient.angle="0" background.brushmode="0" background.gradient.repetition.mode="0" background.gradient.repetition.count="0" background.gradient.repetition.length="100" background.gradient.focus="0" background.gradient.scale="100" background.gradient.spread="100" tooltip.backcolor="134217752" tooltip.delay.initial="0" tooltip.delay.visible="32000" tooltip.enabled="0" tooltip.hasclosebutton="0" tooltip.icon="0" tooltip.isbubble="0" tooltip.maxwidth="0" tooltip.textcolor="134217751" tooltip.transparency="0" transparency="0" )
