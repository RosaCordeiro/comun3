table(column=(type=long updatewhereclause=yes name=nr_controle dbname="log_exportacao_j1btax.nr_controle" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_aprovacao dbname="log_exportacao_j1btax.id_situacao_aprovacao" )
 column=(type=char(10) updatewhereclause=yes name=id_imposto dbname="log_exportacao_j1btax.id_imposto" )
 column=(type=char(1) updatewhereclause=yes name=id_aprovado dbname="id_aprovado" values="	S/	N" )
 column=(type=long update=yes updatewhereclause=yes name=nr_item dbname="nr_item" )
 column=(type=char(3) update=yes updatewhereclause=yes name=country dbname="country" )
 column=(type=char(2) update=yes updatewhereclause=yes name=gruop dbname="gruop" )
