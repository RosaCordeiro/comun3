 retrieve="select
	lej.nr_controle,
	lej.id_situacao_aprovacao,
	lej.id_imposto,
	coalesce(leji.id_aprovado, 'N') id_aprovado,
	leji.nr_item,
	leji.country,
	leji.gruop,
	leji.land1,
	leji.shipfrom,
	leji.shipto,
	leji.taxjurcode,
	leji.value,
	leji.value2,
	leji.value3,
	leji.stgrp,
	leji.validfrom,
	leji.validto,
	leji.sur_type,
	leji.rate,
	leji.price,
	leji.base,
	leji.exempt,
	leji.amount,
	leji.factor,
	leji.unit,
	leji.basered1,
	leji.basered2,
	leji.icmsbaser,
	leji.minprice,
	leji.waers,
	leji.minfact,
	leji.surchin,
	leji.fcp_basered1,
	leji.fcp_basered2,
	leji.taxlaw,
	leji.conven100,
	leji.specf_rate,
	leji.specf_base,
	leji.specf_resale,
	leji.partilha_exempt,
	leji.taxrelloc,
	leji.withhold,
	leji.minval_wt,
	leji.rate4dec,
	leji.amount4dec,
	leji.factor4dec,
	leji.minprice_amount,
	leji.minprice_currency,
	leji.minprice_quantity,
	leji.minprice_uom,
	leji.minprice_taxlaw,
	leji.regra,
	leji.dh_exportacao,
	leji.dh_retorno_sap,
	leji.cd_produto_sybase,
	leji.de_produto,
	leji.ncm,
	leji.ncm_situacao,
	leji.ordem_regra_sql
from log_exportacao_j1btax lej
	inner join log_exportacao_j1btax_item leji (index idx_log_exp_j1btax_item_ctr)
		on leji.nr_controle = lej.nr_controle
where lej.nr_controle = :nr_controle" arguments=(("nr_controle", number))  sort="nr_item A " )
