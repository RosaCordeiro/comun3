table(column=(type=decimal(0) updatewhereclause=yes name=nr_controle dbname="nr_controle" )
 column=(type=char(73) updatewhereclause=yes name=nm_tabela dbname="nm_tabela" )
 column=(type=char(50) updatewhereclause=yes name=de_chave_sap dbname="de_chave_sap" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="dh_inclusao" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="id_situacao" values="COLOCADO	C/ERRO	E/PROCESSADO	P/" )
 column=(type=char(255) updatewhereclause=yes name=de_erro dbname="de_erro" )
 column=(type=long updatewhereclause=yes name=qt_regras_recebidas dbname="qt_regras_recebidas" )
 retrieve="Select
	i.nr_controle,
	cast(t.cd_tabela as varchar)||' - '||t.nm_tabela nm_tabela,
	case 	when i.de_chave_sap = '0000000000' 
			then 'SAP'
			else i.de_chave_sap
	end as de_chave_sap,
	i.dh_inclusao,
	i.id_situacao,
	i.de_erro,
	count(distinct it.nr_item) qt_regras_recebidas
From interface_sap i (index idx_situacao)
	inner join tabela_interface_sap t
		on t.cd_tabela = i.cd_tabela
	inner join interface_sap_item it
		on it.nr_controle = i.nr_controle
		and it.cd_coluna = 'CD_AMBIENTE_SAP'
	inner join interface_sap_item ii
		on ii.nr_controle = i.nr_controle
		and ii.nr_item = 1
		and ii.cd_coluna = 'CD_AMBIENTE_SAP'
Where i.cd_tabela in(113,114,115,116,117,118)
	And i.id_situacao in('C','E')
Group by
	i.nr_controle,
	t.cd_tabela,
	t.nm_tabela,
	i.de_chave_sap,
	i.dh_inclusao,
	i.id_situacao,
	i.de_erro"  sort="dh_inclusao D " )
