table(column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="nr_atualizacao" )
 column=(type=char(42) updatewhereclause=yes name=nm_tabela dbname="nm_tabela" )
 column=(type=char(40) updatewhereclause=yes name=cd_chave dbname="cd_chave" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="dh_inclusao" )
 column=(type=long updatewhereclause=yes name=qt_regras_aprovadas dbname="qt_regras_aprovadas" )
 column=(type=char(1) updatewhereclause=yes name=id_status_integracao dbname="id_status_integracao" values="COLOCADO	C/ERRO	E/PROCESSADO	P/" )
 column=(type=char(100) updatewhereclause=yes name=de_erro dbname="de_erro" )
 retrieve="Select
	i.nr_atualizacao,
	cast(t.cd_tabela as varchar)||' - '||substring(t.nm_tabela, 1,9) nm_tabela,
	i.cd_chave,
	i.dh_inclusao,
	count(distinct leji.nr_item) qt_regras_aprovadas,
	i.id_status_integracao,
	i.de_erro
From log_exportacao_sap i (index idx_tipo_nf_log)
	inner join tipo_log_exportacao_sap_nf tnf
		ON tnf.id_tipo_nf  = i.id_tipo_nf
	inner join tabela_interface_sap t
		on t.cd_tabela = tnf.cd_tabela
	inner join log_exportacao_j1btax_item leji (index idx_log_exp_j1btax_item_c_i_a)
		on leji.nr_controle = cast(i.cd_chave as integer)
		and leji.id_aprovado = 'S'
Where i.cd_empresa = 1000
	and i.id_tipo_nf in('IC3','IP3','ISS','PIS','COF','ST3')
	and i.id_tipo_log = 99
	And i.id_status_integracao <> 'P'
group by i.nr_atualizacao,
	t.cd_tabela,
	t.nm_tabela,
	i.cd_chave,
	i.dh_inclusao,
	i.id_status_integracao,
	i.de_erro"  sort="dh_inclusao D " )
