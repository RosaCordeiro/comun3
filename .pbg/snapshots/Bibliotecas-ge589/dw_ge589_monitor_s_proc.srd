table(column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="nr_atualizacao" )
 column=(type=char(9) updatewhereclause=yes name=nm_tabela_btx dbname="nm_tabela_btx" )
 column=(type=char(42) updatewhereclause=yes name=nm_tabela dbname="nm_tabela" )
 column=(type=char(40) updatewhereclause=yes name=cd_chave dbname="cd_chave" )
 column=(type=datetime updatewhereclause=yes name=dh_exportacao dbname="dh_exportacao" )
 column=(type=long updatewhereclause=yes name=qt_regras_enviadas dbname="qt_regras_enviadas" )
 retrieve="Select
	i.nr_atualizacao,
	substring(t.nm_tabela, 1,9) nm_tabela_btx,
	cast(t.cd_tabela as varchar)||' - '||substring(t.nm_tabela, 1,9) nm_tabela,
	i.cd_chave,
	i.dh_exportacao,
	count(distinct leji.nr_item) qt_regras_enviadas
From log_exportacao_sap i (index idx_tipo_nf_log)
	inner join tipo_log_exportacao_sap_nf tnf
		ON tnf.id_tipo_nf  = i.id_tipo_nf
	inner join tabela_interface_sap t
		on t.cd_tabela = tnf.cd_tabela
	inner join log_exportacao_j1btax_item leji (index idx_log_exp_j1btax_item_dh_exp)
		on leji.nr_controle = cast(i.cd_chave as integer)
		and leji.dh_exportacao is not null
Where i.cd_empresa = 1000
	and i.id_tipo_nf in('IC3','IP3','ISS','PIS','COF','ST3')
	and i.id_tipo_log = 99
	And i.id_status_integracao = 'P'
group by i.nr_atualizacao,
	t.cd_tabela,
	t.nm_tabela,
	i.cd_chave,
	i.dh_exportacao"  sort="dh_exportacao D " )
