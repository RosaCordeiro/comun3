table(column=(type=char(6) updatewhereclause=yes name=cd_caixa dbname="lancamento_caixa.cd_caixa" dbalias="lc.cd_caixa" )
 column=(type=long updatewhereclause=yes name=nr_controle_caixa dbname="lancamento_caixa.nr_controle_caixa" dbalias="lc.nr_controle_caixa" )
 column=(type=long updatewhereclause=yes name=nr_lancamento dbname="lancamento_caixa.nr_lancamento" dbalias="lc.nr_lancamento" )
 column=(type=long updatewhereclause=yes name=cd_conta_fluxo_caixa dbname="lancamento_caixa.cd_conta_fluxo_caixa" dbalias="lc.cd_conta_fluxo_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_lancamento dbname="lancamento_caixa.dh_lancamento" dbalias="lc.dh_lancamento" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_lancamento dbname="lancamento_caixa.vl_lancamento" dbalias="lc.vl_lancamento" )
 column=(type=char(50) updatewhereclause=yes name=de_historico dbname="lancamento_caixa.de_historico" dbalias="lc.de_historico" )
 column=(type=char(1) updatewhereclause=yes name=id_estorno dbname="lancamento_caixa.id_estorno" dbalias="lc.id_estorno" )
 column=(type=char(20) updatewhereclause=yes name=nr_documento dbname="lancamento_caixa.nr_documento" dbalias="lc.nr_documento" )
 column=(type=datetime updatewhereclause=yes name=dh_importacao_matriz dbname="lancamento_caixa.dh_importacao_matriz" dbalias="lc.dh_importacao_matriz" )
 retrieve="select distinct lc.cd_caixa,
		lc.nr_controle_caixa,
		lc.nr_lancamento,
		lc.cd_conta_fluxo_caixa,
		lc.dh_lancamento,
		lc.vl_lancamento,
		lc.de_historico,
		lc.id_estorno,
		lc.nr_documento,
		lc.dh_importacao_matriz
from log_exportacao_docto ld
inner join log_exportacao_docto_fin lf1
	on lf1.nr_atualizacao = ld.nr_atualizacao

left outer join nf_venda n
	on n.cd_filial = ld.cd_filial
	and n.nr_nf = ld.nr_nf
	and n.de_especie = ld.de_especie
	and n.de_serie = ld.de_serie

left outer join cartao_comprovante_operacao cco 
	on cco.cd_filial = ld.cd_filial
	and cco.nr_nf = n.nr_nf
	and cco.de_especie = n.de_especie
	and cco.de_serie = n.de_serie

left outer join caixa cx
	on cx.cd_filial = ld.cd_filial
inner join lancamento_caixa lc
	on lc.cd_caixa = cx.cd_caixa
	and lc.vl_lancamento IN (cco.vl_operacao, n.vl_total_produtos)
inner join controle_caixa cc 
	on cc.cd_caixa = lc.cd_caixa
	and cc.nr_controle_caixa = lc.nr_controle_caixa
	and cc.dh_movimentacao_caixa = ld.dh_documento

where ld.cd_ambiente_sap = :p_ambiente
	and ld.dh_documento between :p_data_ini and :p_data_fim
	and ld.cd_filial = :p_filial
	and n.nr_nf = :p_transacoes" arguments=(("p_ambiente", string),("p_data_ini", date),("p_data_fim", date),("p_filial", number),("p_transacoes", decimal)) )
