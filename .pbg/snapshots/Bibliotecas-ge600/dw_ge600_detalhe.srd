table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=char(4) updatewhereclause=yes name=id_tipo_operacao dbname="id_tipo_operacao" )
 column=(type=long updatewhereclause=yes name=qt_parcelas dbname="qt_parcelas" )
 column=(type=char(4) updatewhereclause=yes name=cd_forma_pagto dbname="cd_forma_pagto" )
 column=(type=char(4) updatewhereclause=yes name=cd_condicao_pagto dbname="cd_condicao_pagto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_finalizadora dbname="vl_total_finalizadora" )
 column=(type=char(25) updatewhereclause=yes name=nr_cartao dbname="nr_cartao" )
 column=(type=char(30) updatewhereclause=yes name=nr_autorizacao dbname="nr_autorizacao" )
 column=(type=datetime updatewhereclause=yes name=dh_operacao dbname="dh_operacao" )
 column=(type=datetime updatewhereclause=yes name=dh_credito dbname="dh_credito" )
 column=(type=char(4) updatewhereclause=yes name=cd_banco dbname="cd_banco" )
 column=(type=char(15) updatewhereclause=yes name=nr_agencia dbname="nr_agencia" )
 column=(type=char(18) updatewhereclause=yes name=nr_conta dbname="nr_conta" )
 column=(type=char(40) updatewhereclause=yes name=lf_de_cmc7 dbname="de_cmc7" )
 column=(type=char(15) updatewhereclause=yes name=nr_cheque dbname="nr_cheque" )
 column=(type=char(40) updatewhereclause=yes name=nm_titular dbname="nm_titular" )
 column=(type=char(14) updatewhereclause=yes name=nr_cnpj dbname="nr_cnpj" )
 column=(type=char(11) updatewhereclause=yes name=nr_cpf dbname="nr_cpf" )
 column=(type=char(20) updatewhereclause=yes name=nr_ie dbname="nr_ie" )
 column=(type=char(15) updatewhereclause=yes name=nr_referencia_banco dbname="nr_referencia_banco" )
 column=(type=char(15) updatewhereclause=yes name=nr_boleto dbname="nr_boleto" )
 column=(type=long updatewhereclause=yes name=cd_administradora dbname="cd_administradora" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_comissao dbname="vl_comissao" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_taxa_cartao dbname="pc_taxa_cartao" )
 column=(type=char(30) updatewhereclause=yes name=nr_nsu dbname="nr_nsu" )
 column=(type=char(30) updatewhereclause=yes name=cd_bandeira dbname="cd_bandeira" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="cd_convenio" )
 column=(type=char(60) updatewhereclause=yes name=nm_convenio dbname="nm_convenio" )
 column=(type=char(15) updatewhereclause=yes name=cd_conveniado dbname="cd_conveniado" )
 column=(type=char(60) updatewhereclause=yes name=nm_conveniado dbname="nm_conveniado" )
 column=(type=long updatewhereclause=yes name=nr_parcelas dbname="nr_parcelas" )
 column=(type=char(1) updatewhereclause=yes name=id_razao_especial dbname="id_razao_especial" )
 column=(type=char(1) updatewhereclause=yes name=id_voucher dbname="id_voucher" )
 column=(type=long updatewhereclause=yes name=cd_filial_dev_v dbname="cd_filial_dev_v" )
 column=(type=long updatewhereclause=yes name=nr_nf_dev_v dbname="nr_nf_dev_v" )
 column=(type=char(1) updatewhereclause=yes name=de_especie_dev_v dbname="de_especie_dev_v" )
 column=(type=char(1) updatewhereclause=yes name=de_serie_dev_v dbname="de_serie_dev_v" )
 column=(type=char(1) updatewhereclause=yes name=cd_voucher dbname="cd_voucher" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="nr_sequencial" )
 column=(type=char(60) updatewhereclause=yes name=cd_autorizacao_cd dbname="cd_autorizacao_cd" )
 retrieve="select		le.cd_filial, 
			le.nr_nf, 
			'AJU' as de_especie, 
			le.de_serie, 
			lf.cd_condicao_pagto as id_tipo_operacao,
			lf.qt_parcelas,
			lf.cd_forma_pagto as cd_forma_pagto,
			lf.cd_condicao_pagto,
			lf.vl_total_finalizadora * -1 as vl_total_finalizadora,
			lf.nr_cartao,
			lf.nr_autorizacao,
			lf.dh_operacao,
			lf.dh_credito,
			lf.cd_banco,
			lf.nr_agencia,
			lf.nr_conta,
			lf.de_cmc7,
			lf.nr_cheque,
			lf.nm_titular,
			lf.nr_cnpj,
			lf.nr_cpf,
			lf.nr_ie,
			lf.nr_referencia_banco,
			lf.nr_boleto,
			lf.cd_administradora,
			lf.vl_comissao,
			lf.pc_taxa_cartao * -1 as pc_taxa_cartao,
			lf.nr_nsu,
			lf.cd_bandeira,
			lf.cd_convenio,
			lf.nm_convenio,
			lf.cd_conveniado,
			lf.nm_conveniado,
			lf.nr_parcela as nr_parcelas,
			lf.id_razao_especial,
			'N' as id_voucher,
			cast(null as integer) as cd_filial_dev_v,
			cast(null as integer) as nr_nf_dev_v,
			'' as de_especie_dev_v,
			'' as de_serie_dev_v,
			'' as cd_voucher,
			lf.nr_sequencial as nr_sequencial,
			lf.cd_autorizacao_cd
from log_exportacao_docto le (index idx_data_tipo_filial)
inner join log_exportacao_docto_fin lf (index pk_log_exportacao_docto_fin)
	on lf.nr_atualizacao = le.nr_atualizacao+0
 where le.dh_documento between :dt_inicio and :dt_termino
	and le.cd_filial = :cd_filial
	and lf.nr_atualizacao = :p_nr_atualizacao" filter="vl_total_finalizadora <> 0"arguments=(("dt_inicio", date),("dt_termino", date),("cd_filial", number),("p_nr_atualizacao", decimal))  sort="nr_sequencial A cd_forma_pagto A cd_filial A nr_nf A dh_credito A " )
