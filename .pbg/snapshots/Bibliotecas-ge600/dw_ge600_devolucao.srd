table(column=(type=long updatewhereclause=yes name=nf_devolucao_venda_cd_filial dbname="nf_devolucao_venda.cd_filial" dbalias="d.cd_filial" )
 column=(type=long updatewhereclause=yes name=nf_devolucao_venda_nr_nf dbname="nf_devolucao_venda.nr_nf" dbalias="d.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=nf_devolucao_venda_de_especie dbname="nf_devolucao_venda.de_especie" dbalias="d.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=nf_devolucao_venda_de_serie dbname="nf_devolucao_venda.de_serie" dbalias="d.de_serie" )
 column=(type=char(2) updatewhereclause=yes name=nf_devolucao_venda_id_tipo_venda dbname="nf_devolucao_venda.id_tipo_venda" dbalias="d.id_tipo_venda" )
 column=(type=datetime updatewhereclause=yes name=nf_devolucao_venda_dh_emissao dbname="nf_devolucao_venda.dh_emissao" dbalias="d.dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=nf_devolucao_venda_dh_movimentacao_caixa dbname="nf_devolucao_venda.dh_movimentacao_caixa" dbalias="d.dh_movimentacao_caixa" )
 column=(type=datetime updatewhereclause=yes name=nf_devolucao_venda_dh_importacao_matriz dbname="nf_devolucao_venda.dh_importacao_matriz" dbalias="d.dh_importacao_matriz" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_devolucao_venda_vl_total_produtos dbname="nf_devolucao_venda.vl_total_produtos" dbalias="d.vl_total_produtos" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_devolucao_venda_vl_outras_despesas dbname="nf_devolucao_venda.vl_outras_despesas" dbalias="d.vl_outras_despesas" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_devolucao_venda_vl_total_nf dbname="nf_devolucao_venda.vl_total_nf" dbalias="d.vl_total_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=nf_devolucao_venda_vl_total_nf_bruto dbname="nf_devolucao_venda.vl_total_nf_bruto" dbalias="d.vl_total_nf_bruto" )
 column=(type=char(1) updatewhereclause=yes name=nf_devolucao_venda_id_sistema_novo dbname="nf_devolucao_venda.id_sistema_novo" dbalias="d.id_sistema_novo" )
 retrieve="select distinct d.cd_filial,
		d.nr_nf,
		d.de_especie,
		d.de_serie,
		d.id_tipo_venda,
		d.dh_recebimento as dh_emissao,
		d.dh_movimentacao_caixa,
		d.dh_importacao_matriz,
		d.vl_total_produtos,
		d.vl_outras_despesas,
		d.vl_total_nf_venda as vl_total_nf,
		d.vl_total_nf_bruto,
		d.id_sistema_novo

from log_exportacao_docto ld
inner join log_exportacao_docto_fin lf1
	on lf1.nr_atualizacao = ld.nr_atualizacao

left outer join nf_devolucao_venda d
	on d.cd_filial_venda = ld.cd_filial
	and d.nr_nf_venda = ld.nr_nf
	and d.de_especie_venda = ld.de_especie
	and d.de_serie_venda = ld.de_serie

where ld.cd_ambiente_sap = :p_ambiente
	and ld.dh_documento  between dateadd(dd,-30,:p_data_ini ) and dateadd(dd,30,:p_data_fim)
	and ld.cd_filial = :p_filial
	and (ld.nr_transacao = :p_transacoes  or ld.nr_nf = :p_transacoes ) 

" arguments=(("p_ambiente", string),("p_data_ini", date),("p_data_fim", date),("p_filial", number),("p_transacoes", decimal)) )
