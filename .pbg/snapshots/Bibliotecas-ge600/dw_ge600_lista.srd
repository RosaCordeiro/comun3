table(column=(type=char(2) updatewhereclause=yes name=query dbname="query" )
 column=(type=long updatewhereclause=yes name=status dbname="status" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_log dbname="log_exportacao_docto.id_situacao_log" dbalias="ld.id_situacao_log" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_docto dbname="log_exportacao_docto.id_tipo_docto" dbalias="ld.id_tipo_docto" )
 column=(type=char(100) updatewhereclause=yes name=cd_chave_docto dbname="log_exportacao_docto.cd_chave_docto" dbalias="ld.cd_chave_docto" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="log_exportacao_docto.cd_filial" dbalias="ld.cd_filial" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_nf dbname="log_exportacao_docto.nr_nf" dbalias="ld.nr_nf" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_transacao dbname="log_exportacao_docto.nr_transacao" dbalias="ld.nr_transacao" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="log_exportacao_docto.de_especie" dbalias="ld.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="log_exportacao_docto.de_serie" dbalias="ld.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_exportacao dbname="log_exportacao_docto.dh_exportacao" dbalias="ld.dh_exportacao" )
 column=(type=datetime updatewhereclause=yes name=dh_processamento dbname="log_exportacao_docto.dh_processamento" dbalias="ld.dh_processamento" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="log_exportacao_docto_fin.nr_sequencial" dbalias="lf1.nr_sequencial" )
 column=(type=char(4) updatewhereclause=yes name=cd_forma_pagto dbname="log_exportacao_docto_fin.cd_forma_pagto" dbalias="lf1.cd_forma_pagto" )
 column=(type=char(4) updatewhereclause=yes name=cd_condicao_pagto dbname="log_exportacao_docto_fin.cd_condicao_pagto" dbalias="lf1.cd_condicao_pagto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_finalizadora dbname="log_exportacao_docto_fin.vl_total_finalizadora" dbalias="lf1.vl_total_finalizadora" )
 column=(type=char(1) updatewhereclause=yes name=id_revisado dbname="log_exportacao_docto.id_revisado" dbalias="ld.id_revisado" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_atualizacao dbname="log_exportacao_docto.nr_atualizacao" dbalias="ld.nr_atualizacao" )
 retrieve="select '01' as query,
		case ld.id_situacao_log
			when 'C' then 1
			when 'E' then 2
			when 'V' then 2
			when 'F' then 2
			when 'A' then 3
			when 'P' then 4
			when 'I' then 5
			when 'X' then 6
		else 0 end as status,
		ld.id_situacao_log,
		ld.id_tipo_docto, 
		ld.cd_chave_docto,
		ld.cd_filial,
		ld.nr_nf, 
		ld.nr_transacao,
		ld.de_especie,
		ld.de_serie,
		ld.dh_exportacao,
		ld.dh_processamento,
		lf1.nr_sequencial,
		lf1.cd_forma_pagto,
		lf1.cd_condicao_pagto,
		lf1.vl_total_finalizadora,
		ld.id_revisado,
		ld.nr_atualizacao

from log_exportacao_docto ld
inner join log_exportacao_docto_fin lf1
	on lf1.nr_atualizacao = ld.nr_atualizacao

left outer join nf_venda n
	on n.cd_filial = ld.cd_filial
	and n.nr_nf = ld.nr_nf
	and n.de_especie = ld.de_especie
	and n.de_serie = ld.de_serie

where ld.cd_ambiente_sap = :p_ambiente
	and ld.dh_documento between dateadd(dd,-30,cast(:p_data_ini as date)) and dateadd(dd,30,cast(:p_data_fim as date))
	and ld.cd_filial = :p_filial
	and (ld.nr_transacao = :p_transacoes  or ld.nr_nf = :p_transacoes ) 
			
union all

select '02' as query,
		case ld.id_situacao_log
			when 'C' then 1
			when 'E' then 2
			when 'V' then 2
			when 'F' then 2
			when 'A' then 3
			when 'P' then 4
			when 'I' then 5
			when 'X' then 6
		else 0 end as status,
		ld.id_situacao_log,
		ld.id_tipo_docto, 
		ld.cd_chave_docto,
		ld.cd_filial,
		ld.nr_nf, 
		ld.nr_transacao,
		ld.de_especie,
		ld.de_serie,
		ld.dh_exportacao,
		ld.dh_processamento,
		lf1.nr_sequencial,
		lf1.cd_forma_pagto,
		lf1.cd_condicao_pagto,
		lf1.vl_total_finalizadora,
		ld.id_revisado,
		ld.nr_atualizacao

from log_exportacao_docto ld
inner join log_exportacao_docto_fin lf1
	on lf1.nr_atualizacao = ld.nr_atualizacao

inner join cartao_comprovante_operacao cco 
	on cco.cd_filial = ld.cd_filial
	and charindex(cast(ld.nr_nf as varchar), cco.nr_nsu) > 0
	and cast(cco.dh_operacao as date) between dateadd(dd,-30,cast(ld.dh_documento as date)) and dateadd(dd,30,cast(ld.dh_documento as date))

where ld.cd_ambiente_sap = :p_ambiente
	and ld.dh_documento between :p_data_ini and :p_data_fim
	and ld.cd_filial = :p_filial
	and cco.nr_nf = :p_transacoes
	
order by 11, 12" arguments=(("p_ambiente", string),("p_data_ini", date),("p_data_fim", date),("p_filial", number),("p_transacoes", decimal))  sort="query A " )
