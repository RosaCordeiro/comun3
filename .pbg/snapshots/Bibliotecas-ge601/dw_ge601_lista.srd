table(column=(type=long updatewhereclause=yes key=yes name=nr_pedido_empurrado dbname="pedido_empurrado_produto.nr_pedido_empurrado" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_empurrado.dh_emissao" )
 column=(type=long updatewhereclause=yes key=yes name=cd_filial dbname="pedido_empurrado_produto.cd_filial" )
 column=(type=long updatewhereclause=yes key=yes name=cd_produto dbname="pedido_empurrado_produto.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qtd_pedida dbname="qtd_pedida" )
 column=(type=long updatewhereclause=yes name=qtd_faturada dbname="qtd_faturada" )
 column=(type=long update=yes updatewhereclause=yes name=qt_aprovada dbname="qt_aprovada" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="pedido_empurrado_produto.id_situacao" values="CANCELADO	X/COLOCADO	C/REQUER APROV.	B/FATURADO	F/" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_ant dbname="pedido_empurrado_produto.id_situacao_ant" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="resumo_reposicao_estoque.qt_estoque_base" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="produto_geral.vl_fator_conversao" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_aprovacao dbname="pedido_empurrado_produto.nr_matricula_aprovacao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_aprovacao dbname="pedido_empurrado_produto.dh_aprovacao" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionado dbname="id_selecionado" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=id_cancelar dbname="id_cancelar" initial="N" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=idsituacao dbname="pedido_empurrado_produto.idsituacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_cancelamento dbname="pedido_empurrado_produto.nr_matricula_cancelamento" )
 column=(type=char(40) updatewhereclause=yes name=nm_resp_cancelamento dbname="usuario.nm_resp_cancelamento" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_cancelamento dbname="pedido_empurrado_produto.dh_cancelamento" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_inclusao dbname="pedido_empurrado.nr_matricula_inclusao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_inclusao dbname="usuario.nm_usuario" )
 column=(type=char(1) updatewhereclause=yes name=id_agrupamento dbname="filial.id_agrupamento" )
 column=(type=long updatewhereclause=yes name=qt_venda_periodo dbname="qt_venda_periodo" )
 column=(type=char(1) updatewhereclause=yes name=cd_classe_reposicao dbname="resumo_reposicao_estoque.cd_classe_reposicao" )
 retrieve="select b.nr_pedido_empurrado,
		a.dh_emissao,
		b.cd_filial,
		b.cd_produto,
		d.de_produto + ' : ' +  d.de_apresentacao_estoque as de_produto, 
		coalesce(b.qt_empurrada,0) as qtd_pedida,
		coalesce(b.qt_faturada,0) as qtd_faturada,
		coalesce(b.qt_aprovada,0) as qt_aprovada,
		b.id_situacao as id_situacao,
		b.id_situacao as id_situacao_ant,
		f.qt_estoque_base,
		d.vl_fator_conversao   ,
		b.nr_matricula_aprovacao,
		b.dh_aprovacao, 
		'' as id_selecionado,
		'' as id_cancelar,
		b.id_situacao as idsituacao,
		e.nm_usuario,
		b.nr_matricula_cancelamento,
		uc.nm_usuario as nm_resp_cancelamento,
		b.dh_cancelamento,
		a.nr_matricula_inclusao,
		up.nm_usuario,
         f1.id_agrupamento,
		coalesce(f.qt_venda_periodo, 0) as qt_venda_periodo,
		f.cd_classe_reposicao
from pedido_empurrado a
inner join   pedido_empurrado_produto b
on  a.cd_filial =  b.cd_filial
and a.nr_pedido_empurrado = b.nr_pedido_empurrado
inner join produto_geral d on d.cd_produto = b.cd_produto
inner join usuario up
			on up.nr_matricula = a.nr_matricula_inclusao
left join usuario e on e.nr_matricula = b.nr_matricula_aprovacao
left join resumo_reposicao_estoque f on f.cd_produto = b.cd_produto and f.cd_filial = b.cd_filial
left outer join usuario uc on uc.nr_matricula = b.nr_matricula_cancelamento
inner join filial f1 on f1.cd_filial  =   a.cd_filial 
where a.id_tipo_pedido = 'E'
and coalesce(a.id_reserva_saldo_cd, 'N')='N'

" update="pedido_empurrado_produto" updatewhere=0 updatekeyinplace=no  sort="dh_emissao D cd_filial A nr_pedido_empurrado A " )
