 retrieve="select  cd_filial ,nr_pedido_distribuidora , nr_volume , dh_conferencia_expedicao , nr_matricula_expedicao , dh_insercao  
From    wms_romaneio_conferencia
where   dh_insercao<= dateadd(day, -30, getdate())
order by  dh_insercao, cd_filial


" update="wms_romaneio_conferencia" updatewhere=0 updatekeyinplace=no )
