compute(band=detail alignment="0" expression="CASE (cf_situacao
	WHEN 'ENVIADO P/ SITE'                       THEN 0
	WHEN 'LIBERADOS P/ AGENDAMENTO'  THEN 1
	WHEN 'AGENDAMENTO CANCELADO'     THEN 2
	WHEN 'ERRO AO ENVIAR NF P/ SITE'     THEN 3
	WHEN 'NOTAS NAO ENTREGUES NO CD' THEN 4
	WHEN 'RECUSADA'                                  THEN 5
	WHEN 'DIVERGENTES'                             THEN 6
	WHEN 'CANCELADO SEFAZ'                    THEN 7)"border="0" color="33554432" x="882" y="52" height="48" width="183" format="[GENERAL]" html.valueishtml="0"  name=cf_gravidade_situacao visible="0"  font.face="Verdana" font.height="-7" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="65535" background.transparency="0" background.gradient.color="8421504" background.gradient.transparency="0" background.gradient.angle="0" background.brushmode="0" background.gradient.repetition.mode="0" background.gradient.repetition.count="0" background.gradient.repetition.length="100" background.gradient.focus="0" background.gradient.scale="100" background.gradient.spread="100" tooltip.backcolor="134217752" tooltip.delay.initial="0" tooltip.delay.visible="32000" tooltip.enabled="0" tooltip.hasclosebutton="0" tooltip.icon="0" tooltip.isbubble="0" tooltip.maxwidth="0" tooltip.textcolor="134217751" tooltip.transparency="0" transparency="0" )
compute(band=detail alignment="0" expression="if(not isnull(dh_cancelamento_agendamento),'AGENDAMENTO CANCELADO' , if(qt_nf_cancelada > 0,  'CANCELADO SEFAZ', if(not isnull(dh_envio_site),  'ENVIADO P/ SITE', if(not isnull(de_retorno_webservice), 'ERRO AO ENVIAR NF P/ SITE', if(not isnull(dh_liberacao_agendamento), 'LIBERADOS P/ AGENDAMENTO', if((qt_divergencia_nota > 0) or (qt_divergencia_produto > 0), 'DIVERGENTES', If (Not IsNull (dh_atualizacao), 'RECUSADA', 'NOTAS NAO ENTREGUES NO CD')))))))"border="0" color="33554432" x="229" y="52" height="48" width="622" format="[GENERAL]" html.valueishtml="0"  name=cf_situacao visible="0"  font.face="Verdana" font.height="-7" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="65535" background.transparency="0" background.gradient.color="8421504" background.gradient.transparency="0" background.gradient.angle="0" background.brushmode="0" background.gradient.repetition.mode="0" background.gradient.repetition.count="0" background.gradient.repetition.length="100" background.gradient.focus="0" background.gradient.scale="100" background.gradient.spread="100" tooltip.backcolor="134217752" tooltip.delay.initial="0" tooltip.delay.visible="32000" tooltip.enabled="0" tooltip.hasclosebutton="0" tooltip.icon="0" tooltip.isbubble="0" tooltip.maxwidth="0" tooltip.textcolor="134217751" tooltip.transparency="0" transparency="0" )
ellipse(band=detail x="14" y="8" height="60" width="69"  name=oval_1 visible="1" brush.hatch="6" brush.color="65280~tCASE (cf_gravidade
	WHEN 0 THEN RGB (000, 255, 000) /*verde*/
	WHEN 1 THEN RGB (000, 000, 255) /*azul escuro*/
	WHEN 2 THEN RGB (128, 128, 128) /*cinza*/
	WHEN 3 THEN RGB (255, 255, 000) /*amarelo*/
	WHEN 4 THEN RGB (255, 165, 000) /*laranja*/
	WHEN 5 THEN RGB (170, 070, 000) /*marrom*/
	WHEN 6 THEN RGB (148, 000, 211) /*violeta*/
	WHEN 7 THEN RGB (255, 000, 000) /*vermelho*/
