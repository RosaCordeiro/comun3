table(column=(type=char(3) updatewhereclause=yes name=id_distribuidora dbname="id_distribuidora" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_liberacao_agendamento dbname="dh_liberacao_agendamento" )
 column=(type=char(32768) updatewhereclause=yes name=de_retorno_webservice dbname="de_retorno_webservice" )
 column=(type=datetime updatewhereclause=yes name=dh_envio_site dbname="dh_envio_site" )
 column=(type=long updatewhereclause=yes name=qt_divergencia_nota dbname="qt_divergencia_nota" )
 column=(type=long updatewhereclause=yes name=qt_divergencia_produto dbname="qt_divergencia_produto" )
 column=(type=long updatewhereclause=yes name=qt_nf_cancelada dbname="qt_nf_cancelada" )
 column=(type=char(40) updatewhereclause=yes name=nm_resp_liberacao dbname="nm_resp_liberacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_resp_cancelamento dbname="nm_resp_cancelamento" )
 column=(type=char(100) updatewhereclause=yes name=de_motivo_lib_agendamento dbname="de_motivo_lib_agendamento" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento_agendamento dbname="dh_cancelamento_agendamento" )
 column=(type=datetime updatewhereclause=yes name=leitura_xml dbname="LEITURA_XML" )
 column=(type=long updatewhereclause=yes name=lead_time_minutos dbname="LEAD_TIME_MINUTOS" )
 column=(type=long updatewhereclause=yes name=lead_time_horas dbname="LEAD_TIME_HORAS" )
 column=(type=char(3) updatewhereclause=yes name=entrou_nf dbname="ENTROU_NF" )
 column=(type=char(100) updatewhereclause=yes name=de_motivo_canc_agendamento dbname="de_motivo_canc_agendamento" )
 column=(type=long updatewhereclause=yes name=qt_volumes dbname="qt_volumes" )
 column=(type=char(40) updatewhereclause=yes name=nm_comprador dbname="nm_comprador" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao dbname="dh_atualizacao" )
 column=(type=char(27) updatewhereclause=yes name=de_situacao dbname="de_situacao" )
 retrieve="SELECT
	id_distribuidora,
	nr_nf,
	de_especie,
	de_serie,
	dh_emissao,
	vl_total_nf,
	dh_liberacao_agendamento,
	de_retorno_webservice,
	dh_envio_site,
	qt_divergencia_nota,
	qt_divergencia_produto,
	qt_nf_cancelada,
	nm_resp_liberacao,
	nm_resp_cancelamento,
	de_motivo_lib_agendamento,
	dh_cancelamento_agendamento,
	LEITURA_XML, 
	LEAD_TIME_MINUTOS,
	LEAD_TIME_HORAS,
	ENTROU_NF,
	de_motivo_canc_agendamento,
	qt_volumes,
	nm_comprador,
	dh_atualizacao,
	CASE 
		WHEN dh_cancelamento_agendamento IS NOT NULL                   THEN '2-AGENDAMENTO CANCELADO'
		WHEN qt_nf_cancelada > 0                                       THEN '7-CANCELADO SEFAZ'
		WHEN dh_envio_site IS NOT NULL                                 THEN '0-ENVIADO P/ SITE'
		WHEN de_retorno_webservice IS NOT NULL                         THEN '3-ERRO AO ENVIAR NF P/ SITE'
		WHEN dh_liberacao_agendamento IS NOT NULL                      THEN '1-LIBERADOS P/ AGENDAMENTO'
		WHEN (qt_divergencia_nota > 0) or (qt_divergencia_produto > 0) THEN '6-DIVERGENTES'
		WHEN dh_atualizacao IS NOT NULL                                THEN '5-RECUSADA'
		ELSE                                                                '4-NOTAS NAO ENTREGUES NO CD'
	END AS de_situacao
FROM (
		SELECT
			a.nr_pedido_central,
			a.de_chave_acesso,
			(SELECT CASE WHEN count(*) > 0 THEN 'SIM' ELSE 'N$$HEX1$$c300$$ENDHEX$$O' END
			 FROM fornecedor a1 INNER JOIN cidade b1 ON b1.cd_cidade = a1.cd_cidade INNER JOIN distribuidora_uf c1 ON c1.cd_distribuidora = a1.cd_fornecedor AND c1.cd_unidade_federacao = b1.cd_unidade_federacao
			 WHERE a1.nr_cgc = a.nr_cgc_fornecedor AND c1.id_homologando_pedido = 'N'
			) id_distribuidora,
			a.nr_nf,
			a.de_especie,
			a.de_serie,
			a.dh_emissao,
			a.vl_total_nf,
			a.dh_liberacao_agendamento,
			CAST(a.de_retorno_webservice AS text) AS de_retorno_webservice,
			a.dh_envio_site,
			(SELECT count(*) FROM nf_agendamento_ent_divergencia x WHERE x.de_chave_acesso = a.de_chave_acesso) qt_divergencia_nota,
			(SELECT count(*) FROM nf_agendamento_ent_item_diverg z WHERE z.de_chave_acesso = a.de_chave_acesso) qt_divergencia_produto,
			(SELECT count(*) FROM nfe_destinadas y WHERE y.de_chave_acesso = a.de_chave_acesso AND y.id_situacao_nf = '3') qt_nf_cancelada,
			b.nm_usuario nm_resp_liberacao,
			c.nm_usuario nm_resp_cancelamento,
			a.de_motivo_lib_agendamento,
			a.dh_cancelamento_agendamento,
			n.dh_entrada 'LEITURA_XML', 
			datediff(SS, n.dh_entrada, a.dh_envio_site) / 60 LEAD_TIME_MINUTOS,
			CASE
				WHEN (datediff(SS, n.dh_entrada, a.dh_envio_site) / 60) > 1440 THEN (datediff(SS, n.dh_entrada, a.dh_envio_site) / 60) / 60
				ELSE 0
			END AS LEAD_TIME_HORAS,
			CASE
				WHEN (SELECT count(*) FROM nf_compra_pendente WHERE de_chave_acesso = n.id_nf) + (SELECT count(*) FROM nf_compra WHERE de_chave_acesso = n.id_nf) > 0 THEN 'SIM'
				ELSE 'N$$HEX1$$c300$$ENDHEX$$O'
			END AS ENTROU_NF,
			a.de_motivo_canc_agendamento,
			a.qt_volumes,
			u.nm_usuario AS nm_comprador,
			r.dh_atualizacao
		FROM
			nf_agendamento_ent                        a
		LEFT OUTER JOIN usuario                       b ON b.nr_matricula = a.nr_matricula_lib_agendamento
		LEFT OUTER JOIN usuario                       c ON c.nr_matricula = a.nr_matricula_canc_agendamento
		LEFT OUTER JOIN pedido_central                d ON d.nr_pedido = a.nr_pedido_central
		LEFT OUTER JOIN fornecedor                    e ON e.cd_fornecedor = d.cd_fornecedor
		LEFT OUTER JOIN nfe_indexacao                 n ON n.id_nf = a.de_chave_acesso
		LEFT OUTER JOIN usuario                       u ON u.nr_matricula = d.nr_matricula_cadastramento
		LEFT OUTER JOIN nf_agendamento_ent_msg_recusa r ON r.de_chave_acesso = a.de_chave_acesso
	 ) AG"  sort="nr_nf A " )
