table(column=(type=char(16) updatewhereclause=yes name=nm_processo dbname="Nm_Processo" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_central.nr_pedido" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="pedido_central.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=char(20) updatewhereclause=yes name=cd_fornecedor_sap dbname="fornecedor.cd_fornecedor_sap" )
 column=(type=char(50) updatewhereclause=yes name=de_chave_sap dbname="interface_sap.de_chave_sap" )
 column=(type=datetime updatewhereclause=yes name=datapedido dbname="pedido_central.DataPedido" )
 column=(type=decimal(0) updatewhereclause=yes name=nrcontrolainterface dbname="interface_sap.NrControlaInterface" )
 column=(type=char(24) updatewhereclause=yes name=id_importado dbname="id_importado" )
 column=(type=char(21) updatewhereclause=yes name=de_situacao dbname="de_situacao" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="interface_sap.id_situacao" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="interface_sap.dh_inclusao" )
 column=(type=datetime updatewhereclause=yes name=dh_processamento dbname="interface_sap.dh_processamento" )
 column=(type=char(255) updatewhereclause=yes name=de_erro dbname="interface_sap.de_erro" )
 retrieve="SELECT
	'Pedido de Compra' AS Nm_Processo,
	pc.nr_pedido,
	pc.cd_fornecedor,
	fo.nm_fantasia,	
	fo.cd_fornecedor_sap ,
	isap.de_chave_sap,
	pc.dh_pedido AS DataPedido,
	isap.nr_controle AS NrControlaInterface,
	CASE
		WHEN pc.nr_pedido_sap IS NOT NULL THEN 'PEDIDO CRIADO NO SAP'
		ELSE 'PEDIDO N$$HEX1$$c300$$ENDHEX$$O CRIADO NO SAP'
	END AS id_importado,
	CASE
		WHEN isap.id_situacao = 'C' THEN 'AGUARDANDO IMPORTA$$HEX2$$c700c300$$ENDHEX$$O'
		WHEN isap.id_situacao = 'E' THEN 'ERRO AO IMPORTAR'
		WHEN isap.id_situacao IN ('D', 'X') THEN 'CANCELADA IMPORTA$$HEX2$$c700c300$$ENDHEX$$O'
		WHEN isap.id_situacao = 'P' THEN 'IMPORTADO'
		ELSE 'INV$$HEX1$$c100$$ENDHEX$$LIDO'
	END AS de_situacao,
	isap.id_situacao,		
	isap.dh_inclusao,
	isap.dh_processamento,
	isap.de_erro
  FROM interface_sap isap
	LEFT JOIN pedido_central pc
		   ON pc.nr_pedido_sap = isap.de_chave_sap
	LEFT JOIN fornecedor fo 
		   ON fo.cd_fornecedor = pc.cd_fornecedor
where isap.nr_controle = (SELECT max(nr_controle) FROM interface_sap isap2 WHERE cd_tabela = 92 AND de_chave_sap = isap.de_chave_sap)" )
ellipse(band=detail x="50" y="16" height="84" width="96"  name=oval_sit_import_pedido visible="1" brush.hatch="6" brush.color="65280~tCASE (id_situacao when  'C' THEN RGB (255,255,0) when 'E' THEN RGB (255,0,0) WHEN 'D' then rgb(255, 0, 0) when 'X' then rgb(255, 0, 0) wHEN 'P' THEN rgb (0,255, 0) else rgb (255,0,0))" pen.style="0" pen.width="5" pen.color="8388608"  background.mode="2" background.color="0" background.transparency="0" background.gradient.color="8421504" background.gradient.transparency="0" background.gradient.angle="0" background.brushmode="0" background.gradient.repetition.mode="0" background.gradient.repetition.count="0" background.gradient.repetition.length="100" background.gradient.focus="0" background.gradient.scale="100" background.gradient.spread="100" tooltip.backcolor="134217752" tooltip.delay.initial="0" tooltip.delay.visible="32000" tooltip.enabled="1" tooltip.hasclosebutton="0" tooltip.icon="1" tooltip.isbubble="1" tooltip.maxwidth="1" tooltip.textcolor="134217751" tooltip.tip="~t de_situacao " tooltip.title="Situa$$HEX2$$e700e300$$ENDHEX$$o da interface com o SAP" tooltip.transparency="1" )
