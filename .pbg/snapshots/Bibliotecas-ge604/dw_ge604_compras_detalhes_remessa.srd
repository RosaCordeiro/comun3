table(column=(type=decimal(0) updatewhereclause=yes name=nr_controle dbname="interface_sap.nr_controle" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="interface_sap.id_situacao" )
 column=(type=char(21) updatewhereclause=yes name=de_situacao dbname="de_situacao" )
 column=(type=char(50) updatewhereclause=yes name=de_chave_sap dbname="interface_sap.de_chave_sap" )
 column=(type=char(255) updatewhereclause=yes name=de_erro dbname="interface_sap.de_erro" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="interface_sap.dh_inclusao" )
 column=(type=datetime updatewhereclause=yes name=dh_processamento dbname="interface_sap.dh_processamento" )
 column=(type=char(10) updatewhereclause=yes name=nr_recebimento dbname="recebimento_sap.nr_recebimento" )
 column=(type=datetime updatewhereclause=yes name=dh_recebimento dbname="recebimento_sap.dh_recebimento" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_recebimento dbname="recebimento_sap.id_situacao_recebimento" )
 column=(type=char(21) updatewhereclause=yes name=de_situacao_recebimento dbname="de_situacao_recebimento" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="recebimento_sap.nr_pedido" )
 column=(type=char(10) updatewhereclause=yes name=nr_pedido_sap dbname="recebimento_sap.nr_pedido_sap" )
 retrieve="SELECT
	isap.nr_controle,
	isap.id_situacao,
	CASE
		WHEN isap.id_situacao = 'C' THEN 'AGUARDANDO IMPORTA$$HEX2$$c700c300$$ENDHEX$$O'
		WHEN isap.id_situacao = 'E' THEN 'ERRO AO IMPORTAR'
		WHEN isap.id_situacao in ('D', 'X') THEN 'CANCELADA IMPORTA$$HEX2$$c700c300$$ENDHEX$$O'
		WHEN isap.id_situacao = 'P' THEN 'IMPORTADO'
		ELSE 'INV$$HEX1$$c100$$ENDHEX$$LIDO'
	END as de_situacao,
	isap.de_chave_sap,
	isap.de_erro,
	isap.dh_inclusao,
	isap.dh_processamento,
	rs.nr_recebimento,
	rs.dh_recebimento,
	rs.id_situacao as id_situacao_recebimento,
	CASE
		WHEN rs.id_situacao = 'C' THEN 'AGUARDANDO IMPORTA$$HEX2$$c700c300$$ENDHEX$$O'
		WHEN rs.id_situacao = 'E' THEN 'ERRO AO IMPORTAR'
		WHEN rs.id_situacao in ('D', 'X') THEN 'CANCELADA IMPORTA$$HEX2$$c700c300$$ENDHEX$$O'
		WHEN rs.id_situacao = 'P' THEN 'IMPORTADO'
		ELSE 'INV$$HEX1$$c100$$ENDHEX$$LIDO'
	END AS de_situacao_recebimento,
	rs.nr_pedido,
	rs.nr_pedido_sap
  FROM dbo.interface_sap isap
		INNER JOIN recebimento_sap rs
				ON rs.de_chave_acesso = isap.de_chave_sap
 WHERE isap.nr_controle = (SELECT MAX (isap2.nr_controle)
									  FROM interface_sap isap2
									 WHERE isap2.de_chave_sap = isap.de_chave_sap)"  sort="nr_controle A " )
