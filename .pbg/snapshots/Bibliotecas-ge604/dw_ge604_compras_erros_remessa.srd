table(column=(type=char(10) updatewhereclause=yes name=nr_recebimento dbname="recebimento_sap_log.nr_recebimento" )
 column=(type=long updatewhereclause=yes name=nr_item dbname="recebimento_sap_log.nr_item" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="dh_inclusao" )
 column=(type=char(250) updatewhereclause=yes name=de_log dbname="recebimento_sap_log.de_log" )
 retrieve="SELECT rsl1.nr_recebimento
	  , rsl1.nr_item
	  , MAX (rsl1.dh_inclusao) AS dh_inclusao
	  , rsl1.de_log
  FROM recebimento_sap_log rsl1
 WHERE rsl1.nr_recebimento = :as_nr_recebimento
 GROUP BY rsl1.nr_recebimento
		  , rsl1.nr_item
		  , rsl1.de_log
 ORDER BY nr_item

" arguments=(("as_nr_recebimento", string)) )
