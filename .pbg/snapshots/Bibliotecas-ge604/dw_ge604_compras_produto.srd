table(column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_central_produto.cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="produto_geral.cd_produto_sap" )
 column=(type=char(102) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_central_produto.qt_pedida" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_preco_unitario dbname="pedido_central_produto.vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total dbname="vl_total" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_compra dbname="produto_geral.cd_unidade_medida_compra" )
 retrieve="SELECT pcp.cd_produto, 
	pg.cd_produto_sap,
	pg.de_produto || ': ' || pg.de_apresentacao_estoque as de_produto,
	pcp.qt_pedida,
	pcp.vl_preco_unitario,
	pcp.qt_pedida * pcp.vl_preco_unitario AS vl_total,
	pg.cd_unidade_medida_compra 
FROM
	pedido_central_produto pcp
INNER JOIN produto_geral pg
 ON
	pg.cd_produto = pcp.cd_produto
WHERE pcp.nr_pedido = :an_nr_pedido
ORDER BY pcp.cd_produto
" arguments=(("an_nr_pedido", number)) )
