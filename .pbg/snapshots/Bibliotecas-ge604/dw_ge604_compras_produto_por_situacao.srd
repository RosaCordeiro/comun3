table(column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_central_produto.cd_produto" dbalias="pcp.cd_produto" )
 column=(type=char(102) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_pedida dbname="pedido_central_produto.qt_pedida" dbalias="pcp.qt_pedida" )
 column=(type=long updatewhereclause=yes name=qt_recebida dbname="qt_recebida" )
 column=(type=char(4) updatewhereclause=yes name=cd_unidade_medida dbname="cd_unidade_medida" )
 column=(type=long updatewhereclause=yes name=qt_recebida_original dbname="qt_recebida_original" )
 column=(type=char(4) updatewhereclause=yes name=cd_unidade_medida_original dbname="cd_unidade_medida_original" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="vl_fator_conversao" )
 column=(type=char(27) updatewhereclause=yes name=de_gravidade dbname="de_gravidade" )
 retrieve="SELECT
	pcp.cd_produto,
	pg.de_produto || ': ' || pg.de_apresentacao_estoque AS de_produto,
	pcp.qt_pedida,
	COALESCE (SUM (rec.qt_recebida), 0) AS qt_recebida,
	rec.cd_unidade_medida,
	COALESCE (SUM (rec.qt_recebida_original), 0) AS qt_recebida_original,
	rec.cd_unidade_medida_original,
	rec.vl_fator_conversao,
	CASE COALESCE (SUM (rec.qt_recebida), 0)
		WHEN 0 THEN '3-PEDIDOS MAS N$$HEX1$$c300$$ENDHEX$$O RECEBIDOS'
		WHEN pcp.qt_pedida THEN '0-PRODUTOS SEM DIVERG$$HEX1$$ca00$$ENDHEX$$NCIA' 
		ELSE '2-QUANTIDADE DIVERGENTE'
	END AS de_gravidade
FROM pedido_central_produto pcp
INNER JOIN produto_geral pg
		 ON pg.cd_produto = pcp.cd_produto
LEFT JOIN (
			SELECT
				rs.nr_pedido,
				rsi.cd_produto,
				COALESCE (rsi.qt_recebida, 0) AS qt_recebida,
				rsi.cd_unidade_medida,
				COALESCE (rsi.qt_recebida_original, 0) AS qt_recebida_original,
				rsi.cd_unidade_medida_original,
				rsi.vl_fator_conversao
			FROM recebimento_sap rs
			INNER JOIN dbo.recebimento_sap_item rsi
					 ON rsi.nr_recebimento = rs.nr_recebimento
			WHERE rs.id_situacao = 'P'
		  ) rec
		 ON rec.nr_pedido  = pcp.nr_pedido
		AND rec.cd_produto = pcp.cd_produto
WHERE pcp.nr_pedido = :an_nr_pedido
GROUP BY
	pcp.cd_produto,
	pg.de_produto,
	pg.de_apresentacao_estoque,
	pcp.qt_pedida,
	rec.cd_unidade_medida,
	rec.cd_unidade_medida_original,
	rec.vl_fator_conversao
UNION ALL
SELECT
	rsi.cd_produto,
	pg.de_produto || ': ' || pg.de_apresentacao_estoque AS de_produto,
	0 AS qt_pedida,
	SUM (rsi.qt_recebida) AS qt_recebida,
	rsi.cd_unidade_medida,
	SUM (rsi.qt_recebida_original) AS qt_recebida_original,
	rsi.cd_unidade_medida_original,
	rsi.vl_fator_conversao,
	'1-RECEBIDOS MAS N$$HEX1$$c300$$ENDHEX$$O PEDIDOS' AS de_gravidade
FROM recebimento_sap rs
INNER JOIN dbo.recebimento_sap_item rsi
		 ON rsi.nr_recebimento = rs.nr_recebimento
INNER JOIN produto_geral pg
		 ON pg.cd_produto = rsi.cd_produto
WHERE rs.nr_pedido = :an_nr_pedido
  AND rs.id_situacao = 'P'
  AND NOT EXISTS (
					SELECT 1
					FROM pedido_central_produto pcp
					WHERE pcp.nr_pedido  = rs.nr_pedido
					  AND pcp.cd_produto = rsi.cd_produto
				 )
GROUP BY
	rsi.cd_produto,
	pg.de_produto,
	pg.de_apresentacao_estoque,
	rsi.cd_unidade_medida,
	rsi.cd_unidade_medida_original,
	rsi.vl_fator_conversao

" arguments=(("an_nr_pedido", number))  sort="cd_produto A " )
