table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="pedido_central.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_pedido dbname="pedido_central.dh_pedido" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="pedido_central.nr_pedido" )
 column=(type=char(10) updatewhereclause=yes name=nr_pedido_sap dbname="pedido_central.nr_pedido_sap" )
 column=(type=char(24) updatewhereclause=yes name=id_importado dbname="id_importado" )
 column=(type=char(36) updatewhereclause=yes name=de_gravidade_produtos dbname="de_gravidade_produtos" )
 column=(type=char(36) updatewhereclause=yes name=de_gravidade_agendamento dbname="de_gravidade_agendamento" )
 column=(type=char(36) updatewhereclause=yes name=de_situacao_nf dbname="de_situacao_nf" )
 retrieve="SELECT a.cd_fornecedor,
    b.nm_fantasia,
	a.dh_pedido,
    a.nr_pedido,
    a.nr_pedido_sap,
    CASE WHEN a.nr_pedido_sap IS NOT NULL THEN
            'PEDIDO CRIADO NO SAP'
        ELSE
            'PEDIDO N$$HEX1$$c300$$ENDHEX$$O CRIADO NO SAP'
    END AS id_importado,
	'0-ZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZ' as de_gravidade_produtos,
	'0-ZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZ' as de_gravidade_agendamento,
	'0-ZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZ' as de_situacao_nf
FROM dbo.pedido_central a
    INNER JOIN fornecedor    b ON a.cd_fornecedor = b.cd_fornecedor
    LEFT JOIN interface_sap c ON c.de_chave_sap = a.nr_pedido_sap
                                 AND c.nr_controle = (
                                                    SELECT MAX(nr_controle)
                                                    FROM interface_sap isap2
                                                    WHERE cd_tabela = 92
                                                        AND de_chave_sap = c.de_chave_sap
    )
WHERE
    a.cd_fornecedor = :as_cd_fornecedor
    AND a.dh_pedido >= :adh_pedido" arguments=(("as_cd_fornecedor", string),("adh_pedido", date)) )
