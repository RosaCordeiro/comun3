ellipse(band=detail x="3136" y="8" height="64" width="73"  name=oval_sit_nf visible="1" brush.hatch="6" brush.color="65280~tCase (cf_situacao_nf 
when 5 then RGB (255,0,0) 
when 4 then RGB (255,0,0) 
when 3 then RGB (255,0,0) 
when 2 then RGB (255,255,0) 
