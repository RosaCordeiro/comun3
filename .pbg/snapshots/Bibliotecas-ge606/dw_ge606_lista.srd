table(column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="controle_baixa_xml.de_chave_acesso" dbalias="a.de_chave_acesso" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="controle_baixa_xml.nr_nf" dbalias="a.nr_nf" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="controle_baixa_xml.cd_filial" dbalias="a.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="f.nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="controle_baixa_xml.dh_emissao" dbalias="a.dh_emissao" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="controle_baixa_xml.de_especie" dbalias="a.de_especie" )
