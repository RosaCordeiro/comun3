 column=(type=char(6) updatewhereclause=yes name=nr_matricula_baixa dbname="controle_baixa_xml.nr_matricula_baixa" dbalias="a.nr_matricula_baixa" )
 column=(type=long updatewhereclause=yes name=nr_controle dbname="controle_baixa_xml.nr_controle" dbalias="a.nr_controle" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="controle_baixa_xml.dh_movimentacao_caixa" dbalias="a.dh_movimentacao_caixa" )
 retrieve="select a.de_chave_acesso as de_chave_acesso,
       a.nr_nf as nr_nf,
       a.cd_filial as cd_filial,
       f.nm_fantasia as nm_fantasia,
       a.dh_emissao as dh_emissao,
       a.de_especie as de_especie,
       '' as de_erro,
	  a.de_serie,
	  a.nr_matricula_baixa,
	  a.nr_controle,
	  a.dh_movimentacao_caixa
from controle_baixa_xml a
inner join filial f on f.cd_filial = a.cd_filial" )
