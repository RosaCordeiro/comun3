table(column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="de_chave_acesso" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(2) updatewhereclause=yes name=tipo dbname="tipo" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 retrieve="select de_chave_acesso,
       dh_emissao,
       de_especie,
	  cd_filial,
	  tipo,
	  nr_nf,
	  de_serie,
	  dh_movimentacao_caixa,
	  (select f.nm_fantasia from filial f where f.cd_filial = tmp.cd_filial) as nm_fantasia
from(
select e.de_chave_acesso,
       n.dh_emissao,
       n.de_especie,
	   've' as tipo,
	   n.cd_filial as cd_filial,
	   n.nr_nf,
	   n.de_serie,
	   n.dh_movimentacao_caixa
from dbo.nf_venda n (index idx_data_filial)
inner join dbo.nf_venda_nfe e on e.cd_filial = n.cd_filial
and e.nr_nf = n.nr_nf
and e.de_especie = n.de_especie
and e.de_serie = n.de_serie
where n.dh_movimentacao_caixa >= :p_dth_ini
  and n.dh_movimentacao_caixa <= :p_dth_fim
  and n.dh_cancelamento is null

union

select e.de_chave_acesso,
       n.dh_recebimento,
       n.de_especie,
	   'dv' as tipo,
	   n.cd_filial as cd_filial,
	   n.nr_nf,
	   n.de_serie,
	   n.dh_movimentacao_caixa
from dbo.nf_devolucao_venda n (index idx_dh_movimentacao_caixa)
inner join dbo.nf_devolucao_venda_nfe e on e.cd_filial = n.cd_filial
and e.nr_nf = n.nr_nf
and e.de_especie = n.de_especie
and e.de_serie = n.de_serie
where n.dh_movimentacao_caixa >= :p_dth_ini
  and n.dh_movimentacao_caixa <= :p_dth_fim
  and n.dh_cancelamento is null

union

select e.de_chave_acesso,
       n.dh_emissao,
       n.de_especie,
	   'ts' as tipo,
	   n.cd_filial_origem as cd_filial,
	   n.nr_nf,
	   n.de_serie,
	   n.dh_movimentacao_caixa
from dbo.nf_transferencia n (index idx_filial_origem)
inner join dbo.nf_transferencia_nfe e on e.cd_filial_origem = n.cd_filial_origem
and e.nr_nf = n.nr_nf
and e.de_especie = n.de_especie
and e.de_serie = n.de_serie
where n.dh_movimentacao_caixa >= :p_dth_ini
  and n.dh_movimentacao_caixa <= :p_dth_fim
  and n.dh_cancelamento is null
	 
union

select e.de_chave_acesso,
       n.dh_emissao,
       n.de_especie,
	   'te' as tipo,
	   n.cd_filial_destino as cd_filial,
	   n.nr_nf,
	   n.de_serie,
	   n.dh_movimentacao_caixa
from dbo.nf_transferencia n (index idx_filial_destino)
inner join dbo.nf_transferencia_nfe e on e.cd_filial_origem = n.cd_filial_origem
and e.nr_nf = n.nr_nf
and e.de_especie = n.de_especie
and e.de_serie = n.de_serie
where n.dh_movimentacao_caixa >= :p_dth_ini
  and n.dh_movimentacao_caixa <= :p_dth_fim
  and n.dh_cancelamento is null
	 
union

select n.de_chave_acesso,
       n.dh_emissao,
       n.de_especie,
	   'co' as tipo,
	   n.cd_filial as cd_filial,
	   n.nr_nf,
	   n.de_serie,
	   n.dh_movimentacao_caixa
from dbo.nf_compra n (index idx_filial_data_movimento)
where n.dh_movimentacao_caixa >= :p_dth_ini
  and n.dh_movimentacao_caixa <= :p_dth_fim
	 
union

select distinct n.de_chave_acesso,
       nd.dh_emissao,
       n.de_especie,
	   'ne' as tipo,
	   n.cd_filial as cd_filial,
	   n.nr_nf,
	   n.de_serie,
	   n.dh_movimentacao_caixa
from dbo.log_exclusao_nf_compra n (index idx_filial_data_movimento)
inner join dbo.nfe_destinadas nd on nd.de_chave_acesso = n.de_chave_acesso 
where n.dh_movimentacao_caixa >= :p_dth_ini
  and n.dh_movimentacao_caixa <= :p_dth_fim
  and not exists (select * from dbo.nf_compra x
					 where x.de_chave_acesso = n.de_chave_acesso)
	 
union

select e.de_chave_acesso,
       n.dh_emissao,
       n.de_especie,
	   'dc' as tipo,
	   n.cd_filial as cd_filial,
	   n.nr_nf,
	   n.de_serie,
	   n.dh_movimentacao_caixa
from dbo.nf_devolucao_compra n (index idx_dh_movimentacao_caixa)
inner join dbo.nf_devolucao_compra_nfe e on e.cd_filial = n.cd_filial
and e.nr_nf = n.nr_nf
and e.de_especie = n.de_especie
and e.de_serie = n.de_serie
where n.dh_movimentacao_caixa >= :p_dth_ini
  and n.dh_movimentacao_caixa <= :p_dth_fim
  and n.dh_cancelamento is null

union

select e.de_chave_acesso,
       n.dh_emissao,
       n.de_especie,
	   'di' as tipo,
	   n.cd_filial_origem as cd_filial,
	   n.nr_nf,
	   n.de_serie,
	   n.dh_movimentacao_caixa
from dbo.nf_diversa n (index idx_filial_origem_data)
inner join dbo.nf_diversa_nfe e on e.cd_filial_origem = n.cd_filial_origem
and e.nr_nf = n.nr_nf
and e.de_especie = n.de_especie
and e.de_serie = n.de_serie
where n.dh_movimentacao_caixa >= :p_dth_ini
  and n.dh_movimentacao_caixa <= :p_dth_fim
  and n.dh_cancelamento is null
) tmp where 1=1" arguments=(("p_dth_ini", datetime),("p_dth_fim", datetime))  sort="de_especie A " )
