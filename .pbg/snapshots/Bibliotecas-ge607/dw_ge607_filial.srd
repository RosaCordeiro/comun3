table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(73) updatewhereclause=yes name=nm_filial dbname="nm_filial" )
 retrieve="select
	f.cd_filial,
	f.nm_fantasia +' ('+cast(f.cd_filial as varchar)+')' as nm_filial
from filial f
Left Outer Join parametro_loja pl
	on pl.cd_filial = f.cd_filial
	and pl.cd_parametro = 'DH_INICIO_OPERACAO_SAP'
where CAST(substring(coalesce(pl.vl_parametro,'31/12/2099'),7,4)||'/'||substring(coalesce(pl.vl_parametro,'31/12/2099'),4,2)||'/'||substring(coalesce(pl.vl_parametro,'31/12/2099'),1,2) AS DATE) >  :dh_fim
	and f.id_situacao='A'
" arguments=(("dh_inicio", datetime),("dh_fim", datetime))  sort="cd_filial A " )
