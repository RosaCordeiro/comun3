table(column=(type=char(73) updatewhereclause=yes name=nm_filial dbname="nm_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_exportacao dbname="dh_exportacao" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_nf dbname="id_tipo_nf" values="COMPRA	CO/COMPRA QUIM.	CQ/DEV. COMPRA	DC/DEV. VENDA	DV/VENDA	VD/CUPOM	CF/SA$$HEX1$$cd00$$ENDHEX$$DA DIVERSA	SD/SA$$HEX1$$cd00$$ENDHEX$$DA TRANSF.	ST/ENTR. DIVERSA	ED/ENTR. TRANSF.	ET/" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_docto dbname="id_situacao_docto" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_log dbname="id_situacao_log" )
 column=(type=char(14) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="cd_filial_destino" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="de_chave_acesso" )
 retrieve="select		f.nm_fantasia +' ('+cast(f.cd_filial as varchar)+')' as nm_filial,		   
			nf.nr_nf,
			nf.de_especie,
			nf.de_serie, 
			nf.dh_movimentacao_caixa,
			l.dh_exportacao, 
			coalesce(l.id_tipo_nf,'ST') as id_tipo_nf,
			l.id_situacao_docto,
			l.id_situacao_log,
			'' as cd_fornecedor,
			null as cd_filial_destino,
			ne.de_chave_acesso
from nf_transferencia nf (index idx_data_filial_origem)
Inner Join nf_transferencia_nfe ne (index pk_nf_transferencia_nfe)
	On ne.cd_filial_origem = nf.cd_filial_origem+0
	and ne.nr_nf = nf.nr_nf
	and ne.de_especie = nf.de_especie
	and ne.de_serie = nf.de_serie
Inner Join filial f (index pk_filial)
	On f.cd_filial	 = nf.cd_filial_origem+0
Left Outer Join log_exportacao_mult l  (index idx_log_mult_nf)
	On l.cd_filial = nf.cd_filial_origem
	and l.nr_nf = nf.nr_nf
	and l.de_especie = nf.de_especie
	and l.de_serie = nf.de_serie
	and coalesce(l.id_tipo_nf,'') = 'ST'  //Sa$$HEX1$$ed00$$ENDHEX$$da Transfer$$HEX1$$ea00$$ENDHEX$$ncia
//	and l.id_situacao_log = 'N'
where nf.dh_movimentacao_caixa between :dh_inicio and :dh_fim
  and nf.cd_filial_origem = :p_cd_filial
  and nf.de_especie = 'NFE'

union

select		f.nm_fantasia +' ('+cast(f.cd_filial as varchar)+')' as nm_filial,		   
			nf.nr_nf,
			nf.de_especie,
			nf.de_serie, 
			nf.dh_movimentacao_caixa,
			l.dh_exportacao, 
			coalesce(l.id_tipo_nf, 'ET') as id_tipo_nf,
			l.id_situacao_docto,
			l.id_situacao_log,
			'' as cd_fornecedor,
			case when l.id_tipo_nf = 'ET' then nf.cd_filial_destino else null end as cd_filial_destino,
			ne.de_chave_acesso
from nf_transferencia nf (index idx_data_filial_destino)
Inner Join nf_transferencia_nfe ne (index pk_nf_transferencia_nfe)
	On ne.cd_filial_origem = nf.cd_filial_origem+0
	and ne.nr_nf = nf.nr_nf
	and ne.de_especie = nf.de_especie
	and ne.de_serie = nf.de_serie
Inner Join filial f (index pk_filial)
	On f.cd_filial	 = nf.cd_filial_destino+0
Left Outer Join log_exportacao_mult l  (index idx_log_mult_nf)
	On l.cd_filial = nf.cd_filial_origem
	and l.nr_nf = nf.nr_nf
	and l.de_especie = nf.de_especie
	and l.de_serie = nf.de_serie
	and coalesce(l.id_tipo_nf,'') = 'ET'	//Entrada Transfer$$HEX1$$ea00$$ENDHEX$$ncia
//	and l.id_situacao_log = 'N'
where nf.dh_movimentacao_caixa between :dh_inicio and :dh_fim
	and nf.cd_filial_destino = :p_cd_filial
	and nf.de_especie = 'NFE'
	and nf.dh_cancelamento is null

union

select		f.nm_fantasia +' ('+cast(f.cd_filial as varchar)+')' as nm_filial,		   
			nf.nr_nf,
			nf.de_especie,
			nf.de_serie, 
			nf.dh_movimentacao_caixa,
			l.dh_exportacao, 
			coalesce(l.id_tipo_nf, 'CO') as id_tipo_nf,
			l.id_situacao_docto,
			l.id_situacao_log,
			fo.nr_cgc as cd_fornecedor,
			null as cd_filial_destino,
			nf.de_chave_acesso
from nf_compra nf (index idx_filial_data_movimento)
Inner Join filial f (index pk_filial)
	On f.cd_filial	 = nf.cd_filial+0
Left Outer Join fornecedor fo (index pk_fornecedor)
	on fo.cd_fornecedor = nf.cd_fornecedor
Left Outer Join log_exportacao_mult l  (index idx_log_mult_nf)
	On l.cd_filial = nf.cd_filial
	and l.nr_nf = nf.nr_nf
	and l.de_especie = nf.de_especie
	and l.de_serie = nf.de_serie
	and coalesce(l.id_tipo_nf,'') = 'CO'
//	and l.id_situacao_log = 'N'
where nf.dh_movimentacao_caixa between :dh_inicio and :dh_fim
  and nf.cd_filial = :p_cd_filial
  and nf.de_especie = 'NFE'

union

select		f.nm_fantasia +' ('+cast(f.cd_filial as varchar)+')' as nm_filial,		   
			nf.nr_nf,
			nf.de_especie,
			nf.de_serie, 
			nf.dh_movimentacao_caixa,
			l.dh_exportacao, 
			coalesce(l.id_tipo_nf, 'SD') as id_tipo_nf,
			l.id_situacao_docto,
			l.id_situacao_log,
			'' as cd_fornecedor,
			null as cd_filial_destino,
			ne.de_chave_acesso
from nf_diversa nf (index idx_filial_origem_data)
Inner Join filial f (index pk_filial)
	On f.cd_filial	 = nf.cd_filial_origem+0
Inner Join nf_diversa_nfe ne (index pk_nf_diversa_nfe)
	On ne.cd_filial_origem = nf.cd_filial_origem+0
	and ne.nr_nf = nf.nr_nf
	and ne.de_especie = nf.de_especie
	and ne.de_serie = nf.de_serie
Left Outer Join log_exportacao_mult l  (index idx_log_mult_nf)
	On l.cd_filial = nf.cd_filial_origem
	and l.nr_nf = nf.nr_nf
	and l.de_especie = nf.de_especie
	and l.de_serie = nf.de_serie
	and l.id_tipo_nf = 'SD'
//	and l.id_situacao_log = 'N'
where nf.dh_movimentacao_caixa between :dh_inicio and :dh_fim
	and nf.cd_filial_origem = :p_cd_filial
	and nf.de_especie = 'NFE'
	and ((nf.cd_natureza_operacao > 5000)
		or (nf.cd_filial_destino > 0 and nf.cd_natureza_operacao < 5000 and nf.dh_cancelamento is null))

union

select 	f.nm_fantasia +' ('+cast(f.cd_filial as varchar)+')' as nm_filial,		   
			nf.nr_nf,
			nf.de_especie,
			nf.de_serie, 
			nf.dh_movimentacao_caixa,
			l.dh_exportacao, 
			coalesce(l.id_tipo_nf,'ED') as id_tipo_nf,
			l.id_situacao_docto,
			l.id_situacao_log,
			'' as cd_fornecedor,
			case when nf.cd_natureza_operacao > 5000 then nf.cd_filial_destino else null end as cd_filial_destino,
			ne.de_chave_acesso
from nf_diversa nf (index idx_data_movimento)
Inner Join filial f (index pk_filial)
	On f.cd_filial	 = nf.cd_filial_origem+0
Inner Join nf_diversa_nfe ne (index pk_nf_diversa_nfe)
	On ne.cd_filial_origem = nf.cd_filial_origem+0
	and ne.nr_nf = nf.nr_nf
	and ne.de_especie = nf.de_especie
	and ne.de_serie = nf.de_serie
Left Outer Join log_exportacao_mult l  (index idx_log_mult_nf)
	On l.cd_filial = nf.cd_filial_origem
	and l.nr_nf = nf.nr_nf
	and l.de_especie = nf.de_especie
	and l.de_serie = nf.de_serie
	and l.id_tipo_nf = 'ED'
//	and l.id_situacao_log = 'N'
where nf.dh_movimentacao_caixa between :dh_inicio and :dh_fim
	and nf.cd_filial_destino = :p_cd_filial
	and nf.de_especie = 'NFE'
	and nf.cd_natureza_operacao > 5000 
	and nf.dh_cancelamento is null

union

select 	f.nm_fantasia +' ('+cast(f.cd_filial as varchar)+')' as nm_filial,		   
			nf.nr_nf,
			nf.de_especie,
			nf.de_serie, 
			nf.dh_movimentacao_caixa,
			l.dh_exportacao, 
			coalesce(l.id_tipo_nf,'ED') as id_tipo_nf,
			l.id_situacao_docto,
			l.id_situacao_log,
			'' as cd_fornecedor,
			null as cd_filial_destino,
			ne.de_chave_acesso
from nf_diversa nf (index idx_data_movimento)
Inner Join filial f (index pk_filial)
	On f.cd_filial	 = nf.cd_filial_origem+0
Inner Join nf_diversa_nfe ne (index pk_nf_diversa_nfe)
	On ne.cd_filial_origem = nf.cd_filial_origem+0
	and ne.nr_nf = nf.nr_nf
	and ne.de_especie = nf.de_especie
	and ne.de_serie = nf.de_serie
Left Outer Join log_exportacao_mult l  (index idx_log_mult_nf)
	On l.cd_filial = nf.cd_filial_origem
	and l.nr_nf = nf.nr_nf
	and l.de_especie = nf.de_especie
	and l.de_serie = nf.de_serie
	and l.id_tipo_nf = 'ED'
//	and l.id_situacao_log = 'N'
where nf.dh_movimentacao_caixa between :dh_inicio and :dh_fim
	and nf.cd_filial_origem = :p_cd_filial
	and nf.de_especie = 'NFE'
	and nf.cd_natureza_operacao < 5000

union

select		f.nm_fantasia +' ('+cast(f.cd_filial as varchar)+')' as nm_filial,		   
			nf.nr_nf,
			nf.de_especie,
			nf.de_serie, 
			nf.dh_movimentacao_caixa,
			l.dh_exportacao, 
			coalesce(l.id_tipo_nf,'DC') as id_tipo_nf,
			l.id_situacao_docto,
			l.id_situacao_log,
			fo.nr_cgc as cd_fornecedor,
			null as cd_filial_destino,
			ne.de_chave_acesso
from nf_devolucao_compra nf (index idx_dh_movimentacao_caixa)
Inner Join filial f (index pk_filial)
	On f.cd_filial	 = nf.cd_filial+0
Inner Join nf_devolucao_compra_nfe ne (index pk_nf_devolucao_compra_nfe)
	On ne.cd_filial = nf.cd_filial+0
	and ne.nr_nf = nf.nr_nf
	and ne.de_especie = nf.de_especie
	and ne.de_serie = nf.de_serie
Left Outer Join fornecedor fo
	on fo.cd_fornecedor = nf.cd_fornecedor
Left Outer Join log_exportacao_mult l  (index idx_log_mult_nf)
	On l.cd_filial = nf.cd_filial
	and l.nr_nf = nf.nr_nf
	and l.de_especie = nf.de_especie
	and l.de_serie = nf.de_serie
	and coalesce(l.id_tipo_nf,'') = 'DC'
//	and l.id_situacao_log = 'N'
where nf.dh_movimentacao_caixa between :dh_inicio and :dh_fim
  and nf.cd_filial = :p_cd_filial
  and nf.de_especie = 'NFE'

