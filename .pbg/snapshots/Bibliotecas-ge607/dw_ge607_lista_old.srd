table(column=(type=char(73) updatewhereclause=yes name=nm_filial dbname="nm_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="log_exportacao_mult.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="log_exportacao_mult.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="log_exportacao_mult.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_exportacao dbname="log_exportacao_mult.dh_exportacao" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_nf dbname="log_exportacao_mult.id_tipo_nf" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_docto dbname="log_exportacao_mult.id_situacao_docto" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_log dbname="log_exportacao_mult.id_situacao_log" )
 column=(type=char(14) updatewhereclause=yes name=cd_fornecedor dbname="fornecedor.cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="cd_filial_destino" )
 retrieve="select
	f.nm_fantasia +' ('+cast(l.cd_filial as varchar)+')' as nm_filial,		   
	l.nr_nf,
	l.de_especie,
	l.de_serie, 
	l.dh_exportacao, 
	l.id_tipo_nf,
	l.id_situacao_docto,
	l.id_situacao_log,
	o.nr_cgc as cd_fornecedor,
	case when l.id_tipo_nf = 'ET' then t.cd_filial_destino else null end as cd_filial_destino
from log_exportacao_mult l
Left Outer Join filial f
	On f.cd_filial	 = l.cd_filial
Left Outer Join fornecedor o
	On o.cd_fornecedor = l.cd_fornecedor
Left Outer Join nf_transferencia t
	On t.cd_filial_origem = l.cd_filial
	and t.nr_nf = l.nr_nf
	and t.de_especie = l.de_especie
	and t.de_serie = l.de_serie
where l.dh_exportacao between :dh_inicio and :dh_fim
  and l.de_especie = 'NFE'
  --and l.id_tipo_nf not in('ET') --Transf. Entrada ainda nao
  and l.cd_filial = :p_cd_filial
  and l.id_situacao_log = 'N'
order by l.cd_filial

" arguments=(("dh_inicio", datetime),("dh_fim", datetime),("p_cd_filial", number)) )
