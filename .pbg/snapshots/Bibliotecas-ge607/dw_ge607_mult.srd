 retrieve="select cd_chave_docto, 
	id_tipo_docto,
	cd_filial,
	nr_nf,
	de_especie,
	de_serie,
	cd_fornecedor
from log_exportacao_docto
where cd_ambiente_sap = :p_ambiente
  and cd_integracao = :p_integracao
  and dh_exportacao >= :p_dt_ini
  and id_situacao_log = :p_situacao
  and cd_filial = :p_filial" arguments=(("p_dt_ini", datetime),("p_filial", number),("p_ambiente", string),("p_integracao", string),("p_situacao", string)) )
