 column=(type=long updatewhereclause=yes name=cd_filial dbname="log_exportacao_docto.cd_filial" dbalias=".cd_filial" )
 column=(type=decimal(0) updatewhereclause=yes name=nr_nf dbname="log_exportacao_docto.nr_nf" dbalias=".nr_nf" )
