table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="cd_produto_sap" )
 column=(type=char(103) updatewhereclause=yes name=descricao_produto dbname="descricao_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_fator_conversao dbname="vl_fator_conversao" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="cd_produto_sap" )
 column=(type=long updatewhereclause=yes name=qtde_saldo dbname="qtde_saldo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_unitario dbname="vl_custo_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_total dbname="vl_custo_total" )
 column=(type=date updatewhereclause=yes name=data_saldo dbname="Data_Saldo" )
 retrieve="Select 
	tmp.cd_filial,
	tmp.cd_produto,
	tmp.cd_produto_sap,
	tmp.descricao_produto,
	tmp.vl_fator_conversao,
	tmp.cd_produto_sap,
	tmp.qtde_saldo,
	tmp.vl_custo_unitario,
	tmp.qtde_saldo * tmp.vl_custo_unitario as vl_custo_total,
	Cast(:p_data as date) as Data_Saldo
From
(
Select 
	:p_filial as cd_filial,
	pg.cd_produto,
	pg.cd_produto_sap,
	pg.de_produto||' : '||de_apresentacao_venda as descricao_produto,
	pg.vl_fator_conversao,
	pg.cd_produto_sap,
	dbo.saldo_produto_parcial( :p_filial, :p_data_fim, :p_data, :p_data_ini,  pg.cd_produto) as qtde_saldo,
	sp.vl_custo_medio as vl_custo_unitario
From produto_geral pg
Inner Join dbo.saldo_produto As sp
		On sp.cd_produto = pg.cd_produto
		And sp.cd_filial = :p_filial
		And sp.dh_saldo = :p_data_fim
Where (:p_produto = 0 Or pg.cd_produto = :p_produto)
And pg.id_situacao = 'A'
) tmp Where ((:p_com_saldo = 'S' And tmp.qtde_saldo > 0) Or :p_com_saldo = 'N')" arguments=(("p_filial", number),("p_data_ini", date),("p_data", date),("p_data_fim", date),("p_produto", number),("p_com_saldo", string)) )
