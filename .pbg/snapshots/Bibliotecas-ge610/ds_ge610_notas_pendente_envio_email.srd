table(column=(type=char(1) updatewhereclause=yes name=id_email_para_filial_destino dbname="id_email_para_filial_destino" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="nf_transferencia.cd_filial_destino" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_transferencia_nfe.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_transferencia_nfe.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_transferencia_nfe.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_transferencia_nfe.de_serie" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_transferencia_nfe.de_chave_acesso" )
 column=(type=char(100) updatewhereclause=yes name=de_email dbname="de_email" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_transferencia.dh_emissao" )
 retrieve="select 'S' as id_email_para_filial_destino, b.cd_filial_destino, a.cd_filial_origem as cd_filial, a.nr_nf, a.de_especie, a.de_serie, a.de_chave_acesso,
		case when b.cd_filial_destino = 809 then
				'0790@clamedlocal.com.br'
			else
				right('0000'+cast(b.cd_filial_destino as varchar), 4)+'@clamedlocal.com.br'
		end as de_email,
		b.dh_emissao
from nf_transferencia_nfe a
inner join nf_transferencia b	on   b.cd_filial_origem = a.cd_filial_origem
										and b.nr_nf = a.nr_nf
										and b.de_especie = a.de_especie
										and b.de_serie = a.de_serie

where  a.id_xml_enviado_email is not null
	and coalesce(a.id_xml_enviado_email, '') = 'N'
	and a.cd_filial_origem = 534
	and a.de_chave_acesso is not null
	and b.dh_emissao <  dateadd(mi, -10, getdate()) --menos 10 minutos para dar tempo de salvar o XML no ftp

union

select 'N' as id_email_para_filial_destino, b.cd_filial_destino, a.cd_filial_origem as cd_filial, a.nr_nf, a.de_especie, a.de_serie, a.de_chave_acesso,
		c.de_endereco_email_envio_xml as de_email,
		b.dh_emissao
from nf_transferencia_nfe a
inner join nf_transferencia b	on   b.cd_filial_origem = a.cd_filial_origem
										and b.nr_nf = a.nr_nf
										and b.de_especie = a.de_especie
										and b.de_serie = a.de_serie
inner join fornecedor c on c.cd_fornecedor = a.cd_transportadora
where  a.id_xml_enviado_email is not null
	and coalesce(a.id_xml_enviado_email, '') = 'N'
	and a.cd_filial_origem = 534
	and a.cd_transportadora is not null
	and a.de_chave_acesso is not null
	and b.dh_emissao <  dateadd(mi, -10, getdate()) --menos 10 minutos para dar tempo de salvar o XML no ftp

order by de_chave_acesso" )
