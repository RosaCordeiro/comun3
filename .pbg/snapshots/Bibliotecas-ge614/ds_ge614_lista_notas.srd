table(column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nfe_destinadas.de_chave_acesso" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc_destino dbname="nfe_destinadas.nr_cgc_destino" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_nf dbname="nfe_destinadas.id_situacao_nf" )
 column=(type=char(2) updatewhereclause=yes name=uf dbname="cidade.uf" )
 retrieve="select a.de_chave_acesso,
       a.nr_cgc_destino,
       a.id_situacao_nf,
       c.cd_unidade_federacao as uf
from nfe_destinadas a
inner join filial b    on b.nr_cgc = a.nr_cgc_destino
inner join cidade c    on c.cd_cidade = b.cd_cidade
where b.cd_filial = :cd_filial
and a.dh_emissao >= dateadd(day, -30, getdate())
and not exists (select * from nfe_manifestacao f where a.de_chave_acesso = f.de_chave_acesso  and f.id_evento = '210200') //210200 = Confirmacao da operacao
and id_situacao_nf = '1'  // 1 = autorizadas
and a.nr_cgc_origem = (select nr_cgc from fornecedor where cd_fornecedor = :cd_fornecedor)
and exists (select * from nf_compra g
				where g.cd_filial = :cd_filial
				and g.cd_fornecedor = :cd_fornecedor
				and ((g.nr_pedido_distribuidora is not null  and g.dh_atualizacao_estoque is not null) or g.nr_pedido_distribuidora is null)
				and g.de_chave_acesso = a.de_chave_acesso
				and g.dh_recebido_sap is null)" arguments=(("cd_filial", number),("cd_fornecedor", string)) )
