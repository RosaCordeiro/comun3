table(column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_transferencia.dh_emissao" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_transferencia_nfe.de_chave_acesso" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_transferencia.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_transferencia.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_transferencia.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_transferencia.de_serie" )
 retrieve="select a.dh_emissao,
		b.de_chave_acesso,
		a.cd_filial_origem as cd_filial,
		a.nr_nf,
		a.de_especie,
		a.de_serie
from nf_transferencia a
inner join nf_transferencia_nfe b	on		b.cd_filial_origem 	= a.cd_filial_origem
												and	b.nr_nf					= a.nr_nf
												and	b.de_especie			= a.de_especie
												and	b.de_serie				= a.de_serie
where a.cd_filial_origem = 534
and b.cd_transportadora = :cd_transportadora
and a.de_especie = 'NFE'
and b.id_situacao = 'A'
and a.dh_movimentacao_caixa >=	dateadd(day, -360, getdate())
and a.dh_emissao					<		dateadd(mi, -160, getdate())
and a.dh_movimentacao_caixa >=	'20170220'
and coalesce(id_xml_enviado_ftp_transp, 'N') <> 'S'
and a.nr_pedido_distribuidora is not null 
----and coalesce(a.id_almoxarifado, 'N') <> 'S'
and coalesce(a.id_devolucao, 'N') <> 'S'
and coalesce(b.id_situacao, 'N') = 'A'
and a.dh_cancelamento is null
and a.cd_filial_destino in  (select  distinct cd_filial  From  parametro_loja 	where cd_parametro  = 'ID_FATURAMENTO_SAP'  and   vl_parametro>getdate()) 
union
select a.dh_emissao,
		b.de_chave_acesso,
		a.cd_filial_origem as cd_filial,
		a.nr_nf,
		a.de_especie,
		a.de_serie
from nf_transferencia a
inner join nf_transferencia_nfe b	on		b.cd_filial_origem 	= a.cd_filial_origem
												and	b.nr_nf					= a.nr_nf
												and	b.de_especie			= a.de_especie
												and	b.de_serie				= a.de_serie
where a.cd_filial_origem in (select f.cd_filial
										from filial f
											inner join cidade c
												on c.cd_cidade = f.cd_cidade
										where c.cd_unidade_federacao = 'BA'
											and f.cd_filial = a.cd_filial_origem)
and a.cd_filial_destino = 1
and a.de_especie = 'NFE'
and b.id_situacao = 'A'
and a.dh_movimentacao_caixa >=	dateadd(day, -360, getdate())
and a.dh_emissao					<		dateadd(mi, -160, getdate())
and a.dh_movimentacao_caixa >=	'20170220'
and coalesce(id_xml_enviado_ftp_transp, 'N') <> 'S'
and a.nr_pedido_distribuidora is not null 
----and coalesce(a.id_almoxarifado, 'N') <> 'S'
and coalesce(a.id_devolucao, 'N') <> 'S'
and coalesce(b.id_situacao, 'N') = 'A'
and a.dh_cancelamento is null
and a.cd_filial_destino in  (select  distinct cd_filial  From  parametro_loja 	where cd_parametro  = 'ID_FATURAMENTO_SAP'  and   vl_parametro>getdate()) " arguments=(("cd_transportadora", string)) )
