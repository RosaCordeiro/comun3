table(column=(type=long updatewhereclause=yes identity=yes name=nr_coleta dbname="wms_segregado_coleta.nr_coleta" dbalias="a.nr_coleta" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="wms_segregado_coleta.cd_fornecedor" dbalias="a.cd_fornecedor" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="wms_segregado_coleta.nr_nf" dbalias="a.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="wms_segregado_coleta.de_serie" dbalias="a.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_devolucao_compra.dh_movimentacao_caixa" dbalias="b.dh_movimentacao_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_devolucao_compra.dh_emissao" dbalias="b.dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_envio_email dbname="dh_envio_email" )
 column=(type=char(60) updatewhereclause=yes name=de_email dbname="fornecedor.de_email" dbalias="c.de_email" )
 column=(type=datetime updatewhereclause=yes name=dh_situacao dbname="dh_situacao" )
 column=(type=long updatewhereclause=yes name=nr_divisao dbname="nr_divisao" )
 column=(type=char(40) updatewhereclause=yes name=nm_divisao dbname="nm_divisao" )
 column=(type=char(1) updatewhereclause=yes name=id_distribuidora dbname="id_distribuidora" )
 column=(type=long updatewhereclause=yes name=nr_nf_compra dbname="nf_devolucao_compra.nr_nf_compra" dbalias="b.nr_nf_compra" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_comprador dbname="produto_central.nr_matricula_comprador" dbalias="pc.nr_matricula_comprador" )
 column=(type=char(40) updatewhereclause=yes name=nm_comprador dbname="usuario.nm_comprador" dbalias="u.nm_comprador" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" dbalias="c.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=de_motivo_devolucao dbname="motivo_devolucao_compra.de_motivo_devolucao" dbalias="m.de_motivo_devolucao" )
 retrieve="select distinct a.nr_coleta
     , a.cd_fornecedor
     , a.nr_nf
     , a.de_serie
     , b.dh_movimentacao_caixa
     , b.dh_emissao
     , coalesce(a.dh_envio_email, b.dh_movimentacao_caixa) as dh_envio_email
     , c.de_email
     , coalesce(a.dh_situacao, b.dh_movimentacao_caixa) as dh_situacao
     , coalesce(p.nr_divisao, 0) as nr_divisao
     , coalesce(f.nm_divisao,'') AS nm_divisao
     , coalesce(c.id_distribuidora, 'N') as id_distribuidora
     , b.nr_nf_compra
     , pc.nr_matricula_comprador
     , u.nm_usuario as nm_comprador  
     , c.nm_fantasia
     , m.de_motivo_devolucao as de_motivo_devolucao
  from wms_segregado_coleta a
       inner join fornecedor c on c.cd_fornecedor = a.cd_fornecedor
       inner join nf_devolucao_compra b on b.cd_filial = a.cd_filial
												   and b.nr_nf	= a.nr_nf
												   and b.de_especie = a.de_especie
												   and b.de_serie	= a.de_serie
       inner join nf_devolucao_compra_produto i on i.cd_filial	= b.cd_filial
			          						           and	i.nr_nf = b.nr_nf
												           and	i.de_especie = b.de_especie
												           and i.de_serie = b.de_serie
       left outer join fornecedor_divisao_produto p on p.cd_fornecedor = a.cd_fornecedor
												               and p.cd_produto = i.cd_produto
       left outer join fornecedor_divisao f on f.cd_fornecedor = a.cd_fornecedor
												       and f.nr_divisao = p.nr_divisao
       inner join produto_central pc on pc.cd_produto = i.cd_produto
       left outer join usuario u	on u.nr_matricula = pc.nr_matricula_comprador
       left outer join motivo_devolucao_compra m on m.cd_motivo_devolucao  =  b.cd_motivo_devolucao
where a.id_situacao = 'P'
  --and cast(dateadd(dd, 30, coalesce(a.dh_situacao, b.dh_movimentacao_caixa)) as date) >= cast(getdate() as date)
  and cast(dateadd(dd, 10, coalesce(a.dh_envio_email, b.dh_movimentacao_caixa)) as date) = cast(getdate() as date)
order by a.cd_fornecedor, p.nr_divisao" )
