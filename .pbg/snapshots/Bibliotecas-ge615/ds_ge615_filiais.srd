table(column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="nf_transferencia.cd_filial_destino" dbalias="a.cd_filial_destino" )
 retrieve="Select distinct a.cd_filial_destino
From 	dbo.nf_transferencia a  
Inner Join dbo.item_nf_transferencia b 	
			on a.cd_filial_origem  				= b.cd_filial_origem 
			and a.cd_filial_destino  				= b.cd_filial_destino 
			and a.nr_nf  							= b.nr_nf 
			and a.de_especie  					= b.de_especie 
			and a.de_serie  						= b.de_serie 
Inner Join produto_geral c on c.cd_produto  	= b.cd_produto 			
Inner Join pedido_distribuidora d on d.cd_filial  = a.cd_filial_destino 
			and d.nr_pedido_distribuidora  		  	= a.nr_pedido_distribuidora 
Inner Join dbo.tipo_pedido_distribuidora  e 
	   on d.id_tipo_pedido  = e.id_tipo
Inner Join dbo.pedido_distribuidora_produto f	
		on f.cd_filial  						= d.cd_filial 
		and f.nr_pedido_distribuidora  	=  d.nr_pedido_distribuidora 
		and f.cd_produto  					=  b.cd_produto
Inner Join filial f1 
		on f1.cd_filial  = a.cd_filial_destino 
Where a.dh_movimentacao_caixa =:adt_data
And     a.cd_filial_origem  = 534  
and     e.id_devolucao           = 'S'
and     e.id_faturamento_urgente = 'S'
and     d.dh_exportacao_sap is not null
and     d.id_situacao  = 'F'
and     a.dh_informacao_loja is null
   


" arguments=(("adt_data", date))  sort="cd_filial_destino A " )
