table(column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="cd_filial_destino" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_transferencia.nr_nf" dbalias="a.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_transferencia.de_especie" dbalias="a.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_transferencia.de_serie" dbalias="a.de_serie" )
 column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="nf_transferencia.cd_filial_origem" dbalias="a.cd_filial_origem" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_transferencia.dh_movimentacao_caixa" dbalias="a.dh_movimentacao_caixa" )
 retrieve="Select Top 20 a.cd_filial_destino,  
		a.nr_nf,  
		a.de_especie,
		a.de_serie, 
		a.cd_filial_origem,
		a.dh_movimentacao_caixa 
From   nf_transferencia a
Inner Join filial f on f.cd_filial  =  a.cd_filial_destino 
Inner Join rota_entrega re  on f.nr_rota_entrega  = re.nr_rota
Inner Join parametro pa on pa.cd_filial  =  a.cd_filial_origem
Where a.dh_movimentacao_caixa>=:adt_data
And     a.dh_grava_movto_tribut_saida is null  
And     a.nr_documento_sap is not null   
And    Not  Exists   ( Select *
					  From   movimento_produto_tributacao c
					  Where c.cd_filial_movimento  	= a.cd_filial_origem 
					  And   c.cd_filial  						= a.cd_filial_destino 
					  And   c.nr_nf  						= a.nr_nf 
					  And   c.de_especie  					= a.de_especie 
					  And   c.de_serie  					= a.de_serie 
					  And   c.dh_movimento 				= a.dh_movimentacao_caixa 
					  And   c.cd_tipo_movimento 		= 6)
Order By f.nr_prioridade_faturamento asc, 
		    f.cd_filial, 
		    a.nr_nf  


" arguments=(("adt_data", date)) )
