table(column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=qt_movimento dbname="qt_movimento" )
 column=(type=decimal(4) updatewhereclause=yes name=vl_preco_unitario dbname="vl_preco_unitario" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="pc_icms" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="nr_lote" )
 column=(type=date updatewhereclause=yes name=dh_validade dbname="dh_validade" )
 retrieve="SELECT
	pg.de_produto + ' : ' + pg.de_apresentacao_venda         AS de_produto,
	COALESCE (i2.qt_lote,           i1.qt_lote)              AS qt_movimento,
	COALESCE (i2.vl_preco_unitario, i1.vl_preco_unitario)    AS vl_preco_unitario,
	COALESCE (i2.pc_icms,           i1.pc_icms)              AS pc_icms,
	COALESCE (i2.cd_produto,        i1.cd_produto)           AS cd_produto,
	COALESCE (i2.nr_lote,           i1.nr_lote)              AS nr_lote,
	CAST (COALESCE (i2.dh_validade, i1.dh_validade) AS DATE) AS dh_validade
  FROM
		nf_devolucao_compra nf
		LEFT OUTER JOIN (
								SELECT
									inf.cd_filial,
									inf.nr_nf,
									inf.de_especie,
									inf.de_serie,
									inf.cd_produto,
									COALESCE (infl.qt_lote, inf.qt_devolvida) AS qt_lote,
									infl.nr_lote,
									infl.dh_validade,
									inf.vl_preco_unitario,
									inf.pc_icms
								  FROM
									item_nf_devolucao_compra inf
									LEFT OUTER JOIN item_nf_devolucao_compra_lote infl
													ON  infl.cd_filial  = inf.cd_filial
													AND infl.nr_nf      = inf.nr_nf
													AND infl.de_especie = inf.de_especie
													AND infl.de_serie   = inf.de_serie
													AND infl.cd_produto = inf.cd_produto
		         		) i1				         
						ON  i1.cd_filial  = nf.cd_filial
						AND i1.nr_nf      = nf.nr_nf
						AND i1.de_especie = nf.de_especie
						AND i1.de_serie   = nf.de_serie
		LEFT OUTER JOIN (
								SELECT
									inf.cd_filial,
									inf.nr_nf,
									inf.de_especie,
									inf.de_serie,
									inf.cd_produto,
									COALESCE (infl.qt_lote, inf.qt_devolvida) AS qt_lote,
									infl.nr_lote,
									infl.dh_validade,
									inf.vl_preco_unitario,
									inf.pc_icms
								  FROM
									nf_devolucao_compra_produto inf
									LEFT OUTER JOIN nf_devolucao_compra_prd_lote infl
													ON  infl.cd_filial  = inf.cd_filial
													AND infl.nr_nf      = inf.nr_nf
													AND infl.de_especie = inf.de_especie
													AND infl.de_serie   = inf.de_serie
													AND infl.nr_item    = inf.nr_item
		         		) i2
						ON  i2.cd_filial  = nf.cd_filial
						AND i2.nr_nf      = nf.nr_nf
						AND i2.de_especie = nf.de_especie
						AND i2.de_serie   = nf.de_serie
		LEFT OUTER JOIN produto_geral pg
						ON  pg.cd_produto = COALESCE (i2.cd_produto, i1.cd_produto)
 WHERE nf.cd_filial  = :cd_filial
	AND nf.nr_nf      = :nr_nf
	AND nf.de_especie = :de_especie
	AND nf.de_serie   = :de_serie
 ORDER BY
	cd_produto" arguments=(("cd_filial", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
