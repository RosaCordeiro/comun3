table(column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" dbalias="fo.nm_fantasia" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="nf_devolucao_compra.cd_filial" dbalias="nf.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_devolucao_compra.nr_nf" dbalias="nf.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_devolucao_compra.de_especie" dbalias="nf.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_devolucao_compra.de_serie" dbalias="nf.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_devolucao_compra.dh_emissao" dbalias="nf.dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms dbname="nf_devolucao_compra.vl_bc_icms" dbalias="nf.vl_bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="nf_devolucao_compra.vl_icms" dbalias="nf.vl_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_st dbname="nf_devolucao_compra.vl_bc_icms_st" dbalias="nf.vl_bc_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="nf_devolucao_compra.vl_icms_st" dbalias="nf.vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_produtos dbname="nf_devolucao_compra.vl_total_produtos" dbalias="nf.vl_total_produtos" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_devolucao_compra.vl_total_nf" dbalias="nf.vl_total_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_devolucao_compra.dh_movimentacao_caixa" dbalias="nf.dh_movimentacao_caixa" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_operador dbname="nf_devolucao_compra.nr_matricula_operador" dbalias="nf.nr_matricula_operador" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" dbalias="uo.nm_usuario" )
 column=(type=datetime updatewhereclause=yes name=dh_solicitacao_canc dbname="nf_devolucao_compra.dh_solicitacao_canc" dbalias="nf.dh_solicitacao_canc" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_solic_canc dbname="nf_devolucao_compra.nr_matricula_solic_canc" dbalias="nf.nr_matricula_solic_canc" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_solic_canc dbname="nm_usuario_solic_canc" )
 column=(type=char(44) updatewhereclause=yes name=nfe_de_chave_acesso dbname="nf_devolucao_compra_nfe.de_chave_acesso" dbalias="nfe.de_chave_acesso" )
 column=(type=char(81) updatewhereclause=yes name=motivo_devolucao dbname="motivo_devolucao" )
 retrieve="  SELECT  fo.nm_fantasia,
          nf.cd_filial,
          nf.nr_nf ,
          nf.de_especie ,
          nf.de_serie , 
          nf.dh_emissao ,
          nf.vl_bc_icms ,
          nf.vl_icms , 
          nf.vl_bc_icms_st ,
          nf.vl_icms_st ,
          nf.vl_total_produtos , 
          nf.vl_total_nf ,  
          nf.dh_movimentacao_caixa,
          nf.nr_matricula_operador,
          uo.nm_usuario,
          nf.dh_solicitacao_canc,
          nf.nr_matricula_solic_canc,
          (SELECT uc.nm_usuario FROM usuario uc WHERE uc.nr_matricula = nf.nr_matricula_solic_canc) AS nm_usuario_solic_canc,
          nfe.de_chave_acesso,
          CASE 
          	WHEN mdc.de_motivo_devolucao IS NULL
          		THEN nf.de_motivo_devolucao
          	ELSE
          		CASE 
          			WHEN nf.de_motivo_devolucao IS NULL
          				THEN mdc.de_motivo_devolucao
          			WHEN nf.de_motivo_devolucao = mdc.de_motivo_devolucao
          				THEN mdc.de_motivo_devolucao
          			ELSE
          				 mdc.de_motivo_devolucao || '/' || nf.de_motivo_devolucao
          		END
          	END AS motivo_devolucao
  FROM nf_devolucao_compra nf
INNER JOIN nf_devolucao_compra_nfe nfe
		ON  nfe.cd_filial   = nf.cd_filial
		AND nfe.nr_nf       = nf.nr_nf
		AND nfe.de_especie  = nf.de_especie
		AND nfe.de_serie    = nf.de_serie
INNER JOIN usuario uo
		ON  uo.nr_matricula = nf.nr_matricula_operador
INNER JOIN filial fo
		ON  fo.cd_filial = nf.cd_filial
LEFT OUTER JOIN motivo_devolucao_compra mdc
   		ON  mdc.cd_motivo_devolucao = nf.cd_motivo_devolucao
 WHERE nf.cd_filial    = :cd_filial_origem
	AND nf.nr_nf        = :nr_nf
	AND nf.de_especie   = :de_especie
	AND nf.de_serie     = :de_serie" arguments=(("cd_filial_origem", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
