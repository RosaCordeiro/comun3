table(column=(type=char(40) updatewhereclause=yes name=filial_origem dbname="filial.filial_origem" )
 column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="nf_diversa.cd_filial_origem" )
 column=(type=char(40) updatewhereclause=yes name=filial_destino dbname="filial.filial_destino" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="nf_diversa.cd_filial_destino" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_diversa.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_diversa.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_diversa.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_diversa.dh_emissao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms dbname="nf_diversa.vl_bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms dbname="nf_diversa.vl_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_st dbname="nf_diversa.vl_bc_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_st dbname="nf_diversa.vl_icms_st" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_produtos dbname="nf_diversa.vl_total_produtos" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_diversa.vl_total_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="nf_diversa.dh_cancelamento" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_diversa.dh_movimentacao_caixa" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_operador dbname="nf_diversa.nr_matricula_operador" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 column=(type=datetime updatewhereclause=yes name=dh_solicitacao_canc dbname="nf_diversa.dh_solicitacao_canc" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_solic_canc dbname="nf_diversa.nr_matricula_solic_canc" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario_solic_canc dbname="nm_usuario_solic_canc" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="nf_diversa_nfe.de_chave_acesso" )
 retrieve="  SELECT  fo.nm_fantasia AS filial_origem,
          nf.cd_filial_origem,
          fd.nm_fantasia AS filial_destino,
          nf.cd_filial_destino,
          nf.nr_nf ,
          nf.de_especie ,
          nf.de_serie , 
          nf.dh_emissao ,
          nf.vl_bc_icms ,
          nf.vl_icms , 
          nf.vl_bc_icms_st ,
          nf.vl_icms_st ,
          nf.vl_total_produtos , 
          nf.vl_total_nf ,  
          nf.dh_cancelamento ,
          nf.dh_movimentacao_caixa,
          nf.nr_matricula_operador,
          uo.nm_usuario,
          nf.dh_solicitacao_canc,
          nf.nr_matricula_solic_canc,
          (SELECT uc.nm_usuario FROM usuario uc WHERE uc.nr_matricula = nf.nr_matricula_solic_canc) AS nm_usuario_solic_canc,
          nfe.de_chave_acesso
  FROM filial fo,
       filial fd,     
       nf_diversa nf,
       usuario uo,
       nf_diversa_nfe nfe
 WHERE nf.cd_filial_origem  = fo.cd_filial
	AND nf.cd_filial_destino = fd.cd_filial
	AND nf.cd_filial_origem  = :cd_filial_origem
	AND nf.nr_nf             = :nr_nf
	AND nf.de_especie        = :de_especie
	AND nf.de_serie          = :de_serie
	AND uo.nr_matricula      = nf.nr_matricula_operador
	AND nfe.cd_filial_origem = nf.cd_filial_origem
	AND nfe.nr_nf            = nf.nr_nf
	AND nfe.de_especie       = nf.de_especie
	AND nfe.de_serie         = nf.de_serie
" arguments=(("cd_filial_origem", number),("nr_nf", number),("de_especie", string),("de_serie", string)) )
