table(column=(type=long updatewhereclause=yes key=yes name=nr_nf dbname="nf_devolucao_compra.nr_nf" dbalias="nf.nr_nf" )
 column=(type=char(3) updatewhereclause=yes key=yes name=de_especie dbname="nf_devolucao_compra.de_especie" dbalias="nf.de_especie" )
 column=(type=char(3) updatewhereclause=yes key=yes name=de_serie dbname="nf_devolucao_compra.de_serie" dbalias="nf.de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_devolucao_compra.dh_emissao" dbalias="nf.dh_emissao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_reentrada_mercadoria dbname="nf_devolucao_compra.dh_reentrada_mercadoria" dbalias="nf.dh_reentrada_mercadoria" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="nf_devolucao_compra.dh_cancelamento" dbalias="nf.dh_cancelamento" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="nf_devolucao_compra.cd_fornecedor" dbalias="nf.cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" dbalias="fo.nm_fantasia" )
 column=(type=date updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_devolucao_compra.vl_total_nf" dbalias="nf.vl_total_nf" )
 column=(type=long updatewhereclause=yes key=yes name=cd_filial dbname="nf_devolucao_compra.cd_filial" dbalias="nf.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf_compra dbname="nf_devolucao_compra.nr_nf_compra" dbalias="nf.nr_nf_compra" )
 column=(type=char(3) updatewhereclause=yes name=de_especie_compra dbname="nf_devolucao_compra.de_especie_compra" dbalias="nf.de_especie_compra" )
 column=(type=char(3) updatewhereclause=yes name=de_serie_compra dbname="nf_devolucao_compra.de_serie_compra" dbalias="nf.de_serie_compra" )
 column=(type=long updatewhereclause=yes name=cd_motivo_devolucao dbname="nf_devolucao_compra.cd_motivo_devolucao" dbalias="nf.cd_motivo_devolucao" )
 retrieve="SELECT nf.nr_nf
	  , nf.de_especie
	  , nf.de_serie
	  , nf.dh_emissao
	  , nf.dh_reentrada_mercadoria
	  , nf.dh_cancelamento
	  , nf.cd_fornecedor
	  , fo.nm_fantasia
	  , CAST (nf.dh_movimentacao_caixa AS DATE) AS dh_movimentacao_caixa
	  , nf.vl_total_nf
	  , nf.cd_filial
	  , nf.nr_nf_compra
	  , nf.de_especie_compra
	  , nf.de_serie_compra
	  , nf.cd_motivo_devolucao
  FROM nf_devolucao_compra nf
		 INNER JOIN nf_devolucao_compra_nfe nfe
					ON  nfe.cd_filial   = nf.cd_filial
					AND nfe.nr_nf       = nf.nr_nf
					AND nfe.de_especie  = nf.de_especie
					AND nfe.de_serie    = nf.de_serie
		 INNER JOIN filial fi
					ON fi.cd_filial     = nf.cd_filial
		 INNER JOIN fornecedor fo
					ON fo.cd_fornecedor = nf.cd_fornecedor
		 INNER JOIN nf_compra nfc
					ON  nfc.cd_filial     = nf.cd_filial
					AND nfc.cd_fornecedor = nf.cd_fornecedor
					AND nfc.nr_nf         = nf.nr_nf_compra
					AND nfc.de_especie    = nf.de_especie_compra
					AND nfc.de_serie      = nf.de_serie_compra
 WHERE nf.dh_cancelamento  IS NOT NULL
 ORDER BY
		 nf.nr_nf
	  , nf.de_especie
	  , nf.de_serie" update="nf_devolucao_compra" updatewhere=0 updatekeyinplace=no )
