table(column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_diversa.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="nf_diversa.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="nf_diversa.de_serie" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_diversa.vl_total_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_diversa.dh_emissao" )
 column=(type=char(60) updatewhereclause=yes name=nm_destinatario dbname="nm_destinatario" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_nota dbname="nf_diversa.de_tipo_nota" )
 column=(type=char(1) updatewhereclause=yes name=id_selecionado dbname="id_selecionado" values="	S/	N" )
 retrieve="SELECT nf.nr_nf
	  , nf.de_especie
	  , nf.de_serie
	  , nf.vl_total_nf
	  , nf.dh_emissao
	  , COALESCE (fd.nm_fantasia, nf.nm_destinatario) AS nm_destinatario
	  , nf.de_natureza_operacao AS de_tipo_nota
	  , 'N' AS id_selecionado
  FROM nf_diversa nf
		 INNER JOIN nf_diversa_nfe nfe
					ON  nfe.cd_filial_origem = nf.cd_filial_origem
					AND nfe.nr_nf				 = nf.nr_nf
					AND nfe.de_especie		 = nf.de_especie
					AND nfe.de_serie			 = nf.de_serie
		 LEFT  JOIN filial fd
					ON fd.cd_filial 			 = nf.cd_filial_destino
 WHERE nf.dh_cancelamento  IS NOT NULL
	AND nf.cd_filial_origem = :al_Filial_Origem
 ORDER BY
		 nf.nr_nf
	  , nf.de_especie
	  , nf.de_serie" arguments=(("al_Filial_Origem", number)) )
