table(column=(type=long updatewhereclause=yes key=yes name=nr_nf dbname="nf_transferencia.nr_nf" dbalias="nf.nr_nf" )
 column=(type=char(3) updatewhereclause=yes key=yes name=de_especie dbname="nf_transferencia.de_especie" dbalias="nf.de_especie" )
 column=(type=char(3) updatewhereclause=yes key=yes name=de_serie dbname="nf_transferencia.de_serie" dbalias="nf.de_serie" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_transferencia.vl_total_nf" dbalias="nf.vl_total_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="nf_transferencia.dh_emissao" dbalias="nf.dh_emissao" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia_destino dbname="nm_fantasia_destino" )
 column=(type=long updatewhereclause=yes name=cd_filial_destino dbname="nf_transferencia.cd_filial_destino" dbalias="nf.cd_filial_destino" )
 column=(type=char(14) updatewhereclause=yes name=de_tipo_nota dbname="de_tipo_nota" )
 column=(type=date updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="nf_transferencia.dh_cancelamento" dbalias="nf.dh_cancelamento" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_reentrada_mercadoria dbname="nf_transferencia.dh_reentrada_mercadoria" dbalias="nf.dh_reentrada_mercadoria" )
 column=(type=long updatewhereclause=yes key=yes name=cd_filial_origem dbname="nf_transferencia.cd_filial_origem" dbalias="nf.cd_filial_origem" )
 retrieve="SELECT nf.nr_nf
	  , nf.de_especie
	  , nf.de_serie
	  , nf.vl_total_nf
	  , nf.dh_emissao
	  , CASE WHEN cc.de_centro_custo IS NOT NULL THEN
					cc.de_centro_custo
				ELSE
					fd.nm_fantasia
		 END AS nm_fantasia_destino
	  , nf.cd_filial_destino
	  , CASE WHEN nf.nr_pedido_distribuidora IS     NULL and coalesce (nf.id_almoxarifado, 'N') <> 'S' THEN 'URGENTE'
				WHEN nf.nr_pedido_distribuidora IS NOT NULL and coalesce (nf.id_almoxarifado, 'N') <> 'S' THEN 'NORMAL'
				WHEN nf.nr_pedido_distribuidora IS NOT NULL and coalesce (nf.id_almoxarifado, 'N')  = 'S' THEN 'ALMOXARIFADO'
				WHEN nf.nr_pedido_distribuidora IS     NULL and coalesce (nf.id_almoxarifado, 'N')  = 'S' THEN 'ALMOX. URGENTE'
		 END AS de_tipo_nota
	  , CAST (nf.dh_movimentacao_caixa AS DATE) AS dh_movimentacao_caixa
	  , nf.dh_cancelamento
	  , nf.dh_reentrada_mercadoria
	  , nf.cd_filial_origem
  FROM nf_transferencia nf
		 INNER JOIN nf_transferencia_nfe nfe
					ON  nfe.cd_filial_origem = nf.cd_filial_origem
					AND nfe.nr_nf            = nf.nr_nf
					AND nfe.de_especie       = nf.de_especie
					AND nfe.de_serie         = nf.de_serie
		 INNER JOIN filial fd
					ON fd.cd_filial          = nf.cd_filial_destino
		 LEFT  JOIN centro_custo cc
					ON cc.cd_centro_custo    = nf.cd_centro_custo
 WHERE nf.dh_cancelamento  IS NOT NULL
 ORDER BY
		 nf.nr_nf
	  , nf.de_especie
	  , nf.de_serie" update="nf_transferencia" updatewhere=0 updatekeyinplace=no )
