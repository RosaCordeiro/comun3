 retrieve="SELECT  --para verificar o modo de preenchimento veja no layout REINF registro 4010.
			'1' as indRetif,
			cast('' as varchar(52)) as nrRecibo,
       		TO_CHAR(a.datavctosal, 'MM.YYYY') as perApur,
			'1' as tpAmb,
			'2' as procEmi,
			cast('' as varchar(20)) as verProc,

			--Informa$$HEX2$$e700f500$$ENDHEX$$es de identifica$$HEX2$$e700e300$$ENDHEX$$o do contribuinte.
			'1' as tpInsc,
			substr(replace(replace(replace(k.identificacao,'-',''),'/',''),'.',''), 1, 8) as nrInsc, --CNPJ raiz

			--Informa$$HEX2$$e700f500$$ENDHEX$$es complementares do contribuinte.
			cast('' as varchar(4)) as natJur,

			--Informa$$HEX2$$e700f500$$ENDHEX$$es de identifica$$HEX2$$e700e300$$ENDHEX$$o do estabelecimento.
			'1' as tpInscEstab,
			replace(replace(replace(p.identificacao,'-',''),'/',''),'.','') as nrInscEstab,

			--Identifica$$HEX2$$e700e300$$ENDHEX$$o do benefici$$HEX1$$e100$$ENDHEX$$rio.
			replace(replace(replace(f.identificacao,'-',''),'/',''),'.','') as cpfBenef,
			f.nome as nmBenef,
			cast('' as varchar(8)) as ideEvtAdic,

			--Identifica$$HEX2$$e700e300$$ENDHEX$$o dos dependentes do benefici$$HEX1$$e100$$ENDHEX$$rio identificado em {ideBenef}.
			cast('' as varchar(11)) as cpfDep,
			cast('' as varchar(2)) as relDep,
			cast('' as varchar(30)) as descrDep,

			--Identifica$$HEX2$$e700e300$$ENDHEX$$o do rendimento
			'13002' as natRend, --Natureza de loca$$HEX2$$e700e300$$ENDHEX$$o ou subloca$$HEX2$$e700e300$$ENDHEX$$o
			cast('' as varchar(200)) as observ,

			--Informa$$HEX2$$e700f500$$ENDHEX$$es relativas ao rendimento pago/creditado
			to_char(a.datavctosal,'DD.MM.YYYY') as dtFG,  --data do fato gerador
			to_char(a.dataemi,'DD.MM.YYYY') as compFP, --data competencia
			cast('' as varchar(1)) as indDecTerc,
			replace(to_char(coalesce(A.valori,0) + coalesce(xxx.valcofinsret, 0) + coalesce(xxx.valpisret, 0) + coalesce(xxx.valcsll, 0) + coalesce(xxx.valirrf_pagto, 0)),',','.') as vlrRendBruto,
			replace(to_char(xxx.baseimposto),',','.') as vlrRendTrib,
			replace(to_char(xxx.valirrf_pagto),',','.') as vlrIR,
			cast('' as varchar(1)) as indRRA,
			cast('' as varchar(1)) as indFciScp,
			cast('' as varchar(14)) as nrInscFciScp,
			cast('' as varchar(4)) as percSCP,
			cast('' as varchar(1)) as indJud,
			cast('' as varchar(4)) as paisResidExt,
			cast('' as varchar(10)) as dtEscrCont,
			cast('' as varchar(200)) as observ,

			--Informa$$HEX2$$e700f500$$ENDHEX$$es relativas $$HEX1$$e000$$ENDHEX$$s dedu$$HEX2$$e700f500$$ENDHEX$$es do rendimento tribut$$HEX1$$e100$$ENDHEX$$vel
			cast('' as varchar(2)) as indTpDeducao,
			cast('' as varchar(14)) as vlrDeducao,
			cast('' as varchar(1)) as infoEntid,
			cast('' as varchar(14)) as nrInscPrevComp,
			cast('' as varchar(14)) as vlrPatrocFunp,

			--Informa$$HEX2$$e700e300$$ENDHEX$$o dos dependentes e benefici$$HEX1$$e100$$ENDHEX$$rios da pens$$HEX1$$e300$$ENDHEX$$o aliment$$HEX1$$ed00$$ENDHEX$$cia.
			cast('' as varchar(11)) as cpfDep,
			cast('' as varchar(14)) as vlrDepen,
		
			--Rendimentos isentos ou n$$HEX1$$e300$$ENDHEX$$o tribut$$HEX1$$e100$$ENDHEX$$veis.
			cast('' as varchar(2)) as tpIsencao,
			cast('' as varchar(14)) as vlrIsento,
			cast('' as varchar(100)) as descRendimento,
			cast('' as varchar(10)) as dtLaudo,

			--Informa$$HEX2$$e700f500$$ENDHEX$$es de processos relacionados a n$$HEX1$$e300$$ENDHEX$$o reten$$HEX2$$e700e300$$ENDHEX$$o de tributos ou a dep$$HEX1$$f300$$ENDHEX$$sitos judiciais.
			cast('' as varchar(1)) as tpProcRet,
			cast('' as varchar(21)) as nrProcRet,
			cast('' as varchar(14)) as codSusp,
			cast('' as varchar(14)) as vlrNRetido,
			cast('' as varchar(14)) as vlrDepJud,
			cast('' as varchar(14)) as vlrCmpAnoCal,
			cast('' as varchar(14)) as vlrCmpAnoAnt,
			cast('' as varchar(14)) as vlrRendSusp,

			--Detalhamento das dedu$$HEX2$$e700f500$$ENDHEX$$es com exigibilidade suspensa.
			cast('' as varchar(2)) as indTpDeducao,
			cast('' as varchar(14)) as vlrDedSusp,

			--Informa$$HEX2$$e700e300$$ENDHEX$$o das dedu$$HEX2$$e700f500$$ENDHEX$$es suspensas por dependentes e benefici$$HEX1$$e100$$ENDHEX$$rios da pens$$HEX1$$e300$$ENDHEX$$o aliment$$HEX1$$ed00$$ENDHEX$$cia
			cast('' as varchar(11)) as cpfDep,
			cast('' as varchar(14)) as vlrDepenSusp,

			--Informa$$HEX2$$e700f500$$ENDHEX$$es complementares relativos a Rendimentos Recebidos Acumuladamente RRA
			cast('' as varchar(1)) as tpProcRRA,
			cast('' as varchar(21)) as nrProcRRA,
			cast('' as varchar(1)) as indOrigRec,
			cast('' as varchar(50)) as descRRA,
			cast('' as varchar(4)) as qtdMesesRRA,
			cast('' as varchar(14)) as cnpjOrigRecurso,
			--Detalhamento das despesas com processo judicial
			cast('' as varchar(14)) as vlrDespCustas,
			cast('' as varchar(14)) as vlrDespAdvogados,
			--Identifica$$HEX2$$e700e300$$ENDHEX$$o do advogado.
			cast('' as varchar(1)) as tpInscAdv,
			cast('' as varchar(14)) as nrInscAdv,
			cast('' as varchar(14)) as vlrAdv,

			--Informa$$HEX2$$e700f500$$ENDHEX$$es complementares Demais rendimentos decorrentes de decis$$HEX1$$e300$$ENDHEX$$o judicial
			cast('' as varchar(21)) as nrProc,
			cast('' as varchar(1)) as indOrigRec,
			cast('' as varchar(14)) as cnpjOrigRecurso,
			cast('' as varchar(50)) as descr,
			--Detalhamento das despesas com processo judicial
			cast('' as varchar(14)) as vlrDespCustas,
			cast('' as varchar(14)) as vlrDespAdvogados,
			--Identifica$$HEX2$$e700e300$$ENDHEX$$o do advogado.
			cast('' as varchar(1)) as tpInscAdv,
			cast('' as varchar(14)) as nrInscAdv,
			cast('' as varchar(14)) as vlrAdv,

			--Informa$$HEX2$$e700f500$$ENDHEX$$es complementares relativas a pagamentos a residente fiscal no exterior
			cast('' as varchar(1)) as indNIF,
			cast('' as varchar(30)) as nifBenef,
			cast('' as varchar(2)) as frmTribut,
			--Endere$$HEX1$$e700$$ENDHEX$$o do benefici$$HEX1$$e100$$ENDHEX$$rio residente ou domiciliado no exterior.
			cast('' as varchar(80)) as dscLograd,
			cast('' as varchar(10)) as nrLograd,
			cast('' as varchar(30)) as complem,
			cast('' as varchar(60)) as bairro,
			cast('' as varchar(40)) as cidade,
			cast('' as varchar(40)) as estado,
			cast('' as varchar(12)) as codPostal,
			cast('' as varchar(15)) as telef,

			--Identifica$$HEX2$$e700e300$$ENDHEX$$o da operadora do plano privado coletivo empresarial de assist$$HEX1$$ea00$$ENDHEX$$ncia $$HEX1$$e000$$ENDHEX$$ sa$$HEX1$$fa00$$ENDHEX$$de.
			cast('' as varchar(14)) as nrInsc,
			cast('' as varchar(6)) as regANS,
			cast('' as varchar(14)) as vlrSaude,
			--Informa$$HEX2$$e700e300$$ENDHEX$$o de reembolso do titular do plano de sa$$HEX1$$fa00$$ENDHEX$$de coletivo empresarial
			cast('' as varchar(1)) as tpInsc,
			cast('' as varchar(14)) as nrInsc,
			cast('' as varchar(14)) as vlrReemb,
			cast('' as varchar(14)) as vlrReembAnt,
			--Informa$$HEX2$$e700f500$$ENDHEX$$es de dependente do plano de sa$$HEX1$$fa00$$ENDHEX$$de coletivo empresarial
			cast('' as varchar(14)) as cpfDep,
			cast('' as varchar(14)) as vlrSaude,
			--Informa$$HEX2$$e700e300$$ENDHEX$$o de reembolso do dependente do plano de sa$$HEX1$$fa00$$ENDHEX$$de coletivo empresarial
			cast('' as varchar(1)) as tpInsc,
			cast('' as varchar(14)) as nrInsc,
			cast('' as varchar(14)) as vlrReemb,
			cast('' as varchar(14)) as vlrReembAnt
FROM m3_parcpa a
INNER JOIN m3_movfin c ON c.id = a.ida
INNER JOIN m3_integra d ON d.id = c.idf_integra
INNER JOIN m3_docto e ON e.id = d.idf_docto
INNER JOIN mtmg_ident f ON f.id = e.idf_ident
INNER JOIN m3_tipdoc g ON g.id = e.idf_tpdocto
INNER JOIN m3_padraodoc h ON h.id = g.idf_padraodocto
INNER JOIN m3_filial i ON i.id = e.idf_filial
INNER JOIN mtmg_papelrel j ON j.id = i.ida
INNER JOIN mtmg_ident k ON k.id = j.idf_ident
INNER JOIN m3_fornecpa l ON l.ida = a.id
INNER JOIN m3_fornec m ON m.id = l.idf_fornec
INNER JOIN m3_empresa n ON n.id = i.idf_empresa
INNER JOIN mtmg_papelrel o ON o.id = n.ida
INNER JOIN mtmg_ident p ON p.id = o.idf_ident
INNER JOIN M3_SERIEDOCTO m1 ON m1.id = e.idf_seriedocto
LEFT OUTER JOIN M3_DOCTODEFIS df ON df.ida = e.id
LEFT OUTER JOIN INTEGRACAO_SAP r on r.CD_EMPRESA = :p_empresa_sap and r.CD_TABELA = 'FILIAL' and r.CD_CHAVE_LEGADO = i.CODIGO
LEFT OUTER JOIN m3_formapagto s on s.id = a.idf_formapagto
LEFT OUTER JOIN INTEGRACAO_SAP t on t.CD_EMPRESA = :p_empresa_sap and t.CD_TABELA = 'M3_FORMAPAGTO' and t.CD_CHAVE_LEGADO = S.CODIGO
LEFT OUTER JOIN m3_doctoparc u on u.numap = a.numap
LEFT OUTER JOIN integracao_sap_excecao AA on AA.cd_empresa = :p_empresa_sap AND AA.cd_tabela = 'TITULO_PAGAR' AND AA.CD_TIPO = 'TIPO_DOCTO' AND AA.CD_CHAVE = g.codtpdocto
INNER JOIN (select a2.idf_docto, 
                        a1.aliquota,
                        a1.id, 
                        a3.codreceita as codreceita,
                        sum(case when a3.tipo = '7' then a1.VALORIMPOSTO else 0.00 end) as valpisret,
                        sum(case when a3.tipo = '8' then a1.VALORIMPOSTO else 0.00 end) as valcofinsret,
                        sum(case when a3.tipo = '9' then a1.VALORIMPOSTO else 0.00 end) as valcsll,
                        sum(case when a3.tipo = 'G' then a1.VALORIMPOSTO else 0.00 end) as valcsrf,
                        sum(case when a3.tipo = '6' then case when a3.codreceita in ('3208', '9478') then a1.VALORIMPOSTO else 0.00 end else 0.00 end) as valirrf_pagto,
                        sum(case when a3.tipo = '6' then case when a3.codreceita in ('3208', '9478') then 0.00 else a1.VALORIMPOSTO end else 0.00 end) as valirrf_ent,
                        sum(case when a3.tipo = '5' then a1.VALORIMPOSTO else 0.00 end) as valiss,
                        sum(case when a3.tipo = 'B' then a1.VALORIMPOSTO else 0.00 end) as valinss,
                        sum(case when a3.tipo = '2' then a1.VALORIMPOSTO else 0.00 end) as valpis,
                        sum(case when a3.tipo = '3' then a1.VALORIMPOSTO else 0.00 end) as valcofins,
                        sum(BASECALCULO) baseimposto
                from m3_doctotrib a1
                inner join m3_partedocto a2 on a2.id = a1.ida
                inner join m3_imposto a3 on a3.id = a1.idf_imposto
                inner join m3_partedocto b1 on b1.idf_docto = a2.idf_docto 
                inner join m3_cabpadocto b2 on b2.ida = b1.id
                where a3.tipo = '6' --somente IRRF
                    and b2.dataprivencto between :p_data_inicio and :p_data_fim
                group by    a2.idf_docto, 
                            a1.aliquota,
                            a1.id, 
                            a3.codreceita) XXX on XXX.idf_docto = e.id
WHERE ( i.idf_empresa = :p_empresa_mult )
    AND ( coalesce(a.indadtoprov,'F') = 'F' )
    AND ( coalesce(a.indprev,'F') = 'F' )
    AND a.datavctosal between :p_data_inicio and :p_data_fim
    AND g.codtpdocto in ('A-AgruAlug','AgrupAlug','AlugContra','AlugEsta')
    AND f.fd='PessoaFisica'
    AND a.situacao is not null --apenas para utilizar o $$HEX1$$ed00$$ENDHEX$$ndice por data de vencimento" arguments=(("p_empresa_mult", number),("p_empresa_sap", number),("p_data_inicio", date),("p_data_fim", date)) )
