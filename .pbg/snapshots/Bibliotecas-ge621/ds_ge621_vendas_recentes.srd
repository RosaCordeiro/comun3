table(column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 retrieve="SELECT TOP 1 nfv.dh_movimentacao_caixa
  FROM nf_venda nfv
			INNER JOIN item_nf_venda infv
					ON  nfv.cd_filial  = infv.cd_filial
					AND nfv.nr_nf      = infv.nr_nf
					AND nfv.de_especie = infv.de_especie
					AND nfv.de_serie   = infv.de_serie
 WHERE nfv.cd_filial              = :al_filial
	AND infv.cd_produto            = :al_produto
	AND nfv.dh_movimentacao_caixa >= CASE :as_tipo_reposicao WHEN 'E' THEN :adt_limite_regular WHEN 'S' THEN :adt_limite_sazonal END
	AND NOT EXISTS (
							SELECT 1
							  FROM produto_preste_a_vencer ppv
							 WHERE ppv.nr_nf         = nfv.nr_nf
								AND ppv.de_especie    = nfv.de_especie
								AND ppv.de_serie      = nfv.de_serie
								AND ppv.cd_produto    = infv.cd_produto
								AND ppv.id_tipo_baixa = 'V'
								AND ppv.dh_baixa     >= CASE :as_tipo_reposicao WHEN 'E' THEN :adt_limite_regular WHEN 'S' THEN :adt_limite_sazonal END
						)" arguments=(("al_filial", number),("al_produto", number),("as_tipo_reposicao", string),("adt_limite_regular", date),("adt_limite_sazonal", date)) )
