table(column=(type=char(9) updatewhereclause=yes key=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="nm_razao_social" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=nm_localiza dbname="nm_localiza" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc dbname="nr_cgc" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_distribuidora dbname="id_distribuidora" values="ID distribuidora	S/ID distribuidora	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_permite_nota_sem_pedido dbname="id_permite_nota_sem_pedido" values="Permite entrada sem pedido	S/Permite entrada sem pedido	N" )
 column=(type=char(4) update=yes updatewhereclause=yes name=nr_layout_ped_eletronico_sap dbname="nr_layout_ped_eletronico_sap" )
 column=(type=char(10) update=yes updatewhereclause=yes name=nr_layout_pedido_eletronico dbname="nr_layout_pedido_eletronico" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_projeto_conexao dbname="id_projeto_conexao" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_arquivo_preco_diario dbname="id_arquivo_preco_diario" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(1) updatewhereclause=yes name=id_importacao_nfe dbname="id_importacao_nfe" values="Importa$$HEX2$$e700e300$$ENDHEX$$o NFE	S/Importa$$HEX2$$e700e300$$ENDHEX$$o NFE	N" )
 retrieve="  SELECT fornecedor.cd_fornecedor,   
         fornecedor.nm_razao_social,   
         fornecedor.nm_fantasia,   
         space(40) nm_localiza,   
         fornecedor.nr_cgc,   
         fornecedor.id_distribuidora,   
         fornecedor.id_permite_nota_sem_pedido,   
         fornecedor.nr_layout_ped_eletronico_sap,
			fornecedor.nr_layout_pedido_eletronico,
			fornecedor.id_projeto_conexao,
			fornecedor.id_arquivo_preco_diario,
			fornecedor.id_importacao_nfe
    FROM fornecedor  
   WHERE cd_fornecedor = :cd_fornecedor    
" update="fornecedor" updatewhere=0 updatekeyinplace=no arguments=(("cd_fornecedor", string)) )
