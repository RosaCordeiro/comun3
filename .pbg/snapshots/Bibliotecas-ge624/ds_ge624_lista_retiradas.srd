table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_retirada_estoque dbname="nr_retirada_estoque" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="dh_termino" )
 column=(type=datetime updatewhereclause=yes name=dh_aprovacao dbname="dh_aprovacao" )
 column=(type=char(1) updatewhereclause=yes name=id_aprovado dbname="id_aprovado" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="dh_inclusao" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_retirada dbname="id_tipo_retirada" )
 retrieve="SELECT  a.cd_filial, a.nr_retirada_estoque,
       a.dh_inicio , a.dh_termino,
       a.dh_aprovacao , a.id_aprovado,
       a.dh_inclusao, a.id_tipo_retirada   
from retirada_estoque a
where a.dh_inclusao>=:adt_data_inicio
and a.id_situacao =  'S'
//and a.id_tipo_retirada  in  ('V', 'D')
and a.id_tipo_retirada  in  ('V')
and a.dh_inicio is null 
and a.dh_termino is null 
and a.dh_aprovacao is null 



" arguments=(("adt_data_inicio", date))  sort="cd_filial A nr_retirada_estoque A dh_termino D " )
