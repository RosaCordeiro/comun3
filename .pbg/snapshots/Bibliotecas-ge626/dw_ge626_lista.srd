table(column=(type=long updatewhereclause=yes name=filial_cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=cd_filial_sap dbname="cd_filial_sap" )
 column=(type=char(40) updatewhereclause=yes name=filial_nm_fantasia dbname="nm_fantasia" )
 column=(type=datetime updatewhereclause=yes name=nfe_destinadas_dh_emissao dbname="dh_emissao" )
 column=(type=char(14) updatewhereclause=yes name=nr_cgc_origem dbname="nr_cgc_origem" )
 column=(type=char(100) updatewhereclause=yes name=nm_razao_social_origem dbname="nm_razao_social_origem" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=decimal(2) updatewhereclause=yes name=nfe_destinadas_vl_nf dbname="vl_nf" )
 column=(type=char(44) updatewhereclause=yes name=nfe_destinadas_de_chave_acesso dbname="de_chave_acesso" )
 column=(type=char(7) updatewhereclause=yes name=nfe_destinadas_id_tipo_nf dbname="id_tipo_nf" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_destinada dbname="id_situacao_destinada" )
 column=(type=char(7) updatewhereclause=yes name=nfe_destinadas_id_finnfe dbname="id_finnfe" )
 column=(type=datetime updatewhereclause=yes name=dh_status_sefaz dbname="dh_status_sefaz" )
 column=(type=char(1) updatewhereclause=yes name=nfe_destinadas_id_situacao_nf dbname="id_situacao_nf" )
 column=(type=char(14) updatewhereclause=yes name=de_situacao_nf dbname="de_situacao_nf" )
 column=(type=char(10) updatewhereclause=yes name=nfe_destinadas_id_manifestacao dbname="id_manifestacao" )
 column=(type=char(45) updatewhereclause=yes name=de_manifestacao dbname="de_manifestacao" )
 column=(type=datetime updatewhereclause=yes name=dh_status_clamed dbname="dh_status_clamed" )
 column=(type=char(1) updatewhereclause=yes name=id_status_clamed dbname="id_status_clamed" )
 column=(type=char(23) updatewhereclause=yes name=de_situacao_clamed dbname="de_situacao_clamed" )
 column=(type=char(200) updatewhereclause=yes name=de_mensagem dbname="de_mensagem" )
 retrieve="select cd_filial, 
		cd_filial_sap, 
		nm_fantasia, 	
		dh_emissao,  
		nr_cgc_origem, 
		nm_razao_social_origem, 
		nr_nf, 
		vl_nf, 
		de_chave_acesso, 
		id_tipo_nf, 
		 Case 
		 When Aux.id_situacao_nf = '1' and Aux.id_status_clamed = '3' and Aux.id_manifestacao = '210210' Then '1'
	    When Aux.id_situacao_nf = '1' and Aux.id_status_clamed = '0' Then '1'
		 When Aux.id_situacao_nf = '1' and Aux.id_status_clamed = '4' Then '1'
		 When Aux.id_situacao_nf <> '3' and Aux.id_status_clamed = '3' and coalesce(Aux.id_manifestacao,'') <> '210240' Then '1'
		 When Aux.id_situacao_nf <> '1' and Aux.id_status_clamed <> '1' Then '0'  -- n$$HEX1$$e300$$ENDHEX$$o autorizada e n$$HEX1$$e300$$ENDHEX$$o foi integrada (n$$HEX1$$e300$$ENDHEX$$o $$HEX1$$e900$$ENDHEX$$ problema)
		 When Aux.id_status_clamed = '2' Then '1'
	 	 Else '0' End as id_situacao_destinada, 	 
		id_finnfe, 
		dh_status_sefaz,
		id_situacao_nf, 
		de_situacao_nf, 	
		id_manifestacao,
		de_manifestacao,
		dh_status_clamed, 
	id_status_clamed, 
		Case 
		 When id_status_clamed = '1' Then 'CONFIRMADA'
		 When id_status_clamed = '2' Then 'PENDENTE ATUAL. ESTOQUE'
		 When id_status_clamed = '3' Then 'EXCLUIDA' 
		 When id_status_clamed = '4' and id_situacao_nf = '1' Then 'ERRO IMPORTACAO XML' 
		 When id_status_clamed = '0' Then 'NAO ECONTRADA' ENd as de_situacao_clamed,
			Case When id_status_clamed = '4' and id_situacao_nf = '1' Then de_log 
	      		 When id_status_clamed = '3' Then de_log_exc
			Else '' ENd as de_mensagem
from
(
select convert(int, substring(dest.de_chave_acesso,26,9)) as nr_nf,
Case When nc.nr_nf is not null Then nc.dh_emissao
	 When np.nr_nf is not null Then np.dh_emissao
	 When ne.nr_nf is not null Then ne.dh_exclusao ENd as dh_status_clamed,
Case When nc.nr_nf is not null Then '1' -- foi importada na nf_compracompra
	 When np.nr_nf is not null Then '2' -- esta na nf_compra_pendente
	 When ne.nr_nf is not null Then '3' --  esta foi excluida
	 When lp.nr_nf is not null Then '4' -- tem log na importa$$HEX2$$e700e300$$ENDHEX$$o do XML
	 Else '0' ENd as id_status_clamed,
	 lp.de_log,
	 'RESP: ' || us.nr_matricula || ' - ' || us.nm_usuario || '- MOTIVO: ' || ne.de_motivo as de_log_exc,
	dest.*
from
(select 
	f.cd_filial, 
	f.nm_fantasia, 
	(select cd_chave_sap from dbo.integracao_sap i
		where i.cd_empresa = 1000
	  	and i.cd_tabela = 'FILIAL'
	  	and i.cd_chave_legado = convert(varchar, f.cd_filial)) as cd_filial_sap,
	nd.de_chave_acesso, 
	nd.nr_cgc_origem,
	upper(nd.nm_razao_social_origem) as nm_razao_social_origem, 
	nd.dh_emissao,
	nd.vl_nf,
	nd.dh_inclusao as dh_status_sefaz,
	Case nd.id_situacao_nf 
	When '1' Then 'USO AUTORIZADO'
	When '2' Then 'USO DENEGADO'
	When '3' Then 'NF-e CANCELADA'
	Else nd.id_situacao_nf ENd as de_situacao_nf,
	nd.id_situacao_nf,
	Case nd.id_tipo_nf
	When '0' Then 'ENTRADA'
	When '1' Then 'SAIDA' ENd as id_tipo_nf,
	Case WHen nd.id_finnfe <> '1' then 'ESTORNO' else 'NORMAL' End as id_finnfe,
	nd.id_manifestacao,
	Case nd.id_manifestacao 
	When '210200' Then 'CONFIRMACAO DE OPERACAO PELO DESTINATARIO'
	When '210210' Then 'CIENCIA DA OPERACAO PELO DESTINATARIO'
	When '210220' Then 'DESCONHECIMENTO DA OPERACAO PELO DESTINATARIO'
	When '210240' Then 'OPERACAO NAO REALIZADA' End as de_manifestacao
from dbo.nfe_destinadas nd
	left join filial f on f.nr_cgc = nd.nr_cgc_destino and f.id_situacao = 'A'
	left join cidade c on c.cd_cidade = f.cd_cidade
where nd.dh_emissao BETWEEN :pdh_emissao_inicio and :pdh_emissao_fim
and nr_cgc_origem not like '84683481%'
and nr_cgc_destino not in ( '84683481000177', '84683481019943')
and id_tipo_nf =  '1' -- SAIDAS
and nd.cd_tipo_operacao_mult is null
and exists (select * from fornecedor fo
			   where fo.nr_cgc = nd.nr_cgc_origem
				  and coalesce(fo.id_distribuidora, 'N') = 'S')
and nd.id_situacao_nf = (select max(aux.id_situacao_nf) from dbo.nfe_destinadas aux where aux.de_chave_acesso = nd.de_chave_acesso )
) dest 
	left join nf_compra nc on nc.de_chave_acesso = dest.de_chave_acesso
	left join nf_compra_pendente np on np.de_chave_acesso = dest.de_chave_acesso
	left join log_exclusao_nf_compra ne on ne.de_chave_acesso = dest.de_chave_acesso
	left join log_importacao_nf_ped_elet lp on lp.de_chave_acesso = dest.de_chave_acesso
	left join usuario us on us.nr_matricula = ne.nr_matricula_responsavel
) Aux
Where 1=1" arguments=(("pdh_emissao_inicio", datetime),("pdh_emissao_fim", datetime))  sort="nfe_destinadas_dh_emissao A " )
