table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_convenio dbname="contrato_preco_convenio_desc.cd_convenio" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=nr_contrato dbname="contrato_preco_convenio_desc.nr_contrato" )
 column=(type=char(1) update=yes updatewhereclause=yes key=yes name=cd_grupo dbname="contrato_preco_convenio_desc.cd_grupo" )
 column=(type=char(1) update=yes updatewhereclause=yes key=yes name=id_lei_generico dbname="contrato_preco_convenio_desc.id_lei_generico" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto dbname="contrato_preco_convenio_desc.pc_desconto" )
 column=(type=char(11) updatewhereclause=yes name=de_tipo dbname="de_tipo" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_alteracao dbname="contrato_preco_convenio_desc.nr_matricula_alteracao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_alteracao dbname="contrato_preco_convenio_desc.dh_alteracao" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_somente_produto_tarjado dbname="id_somente_produto_tarjado" values="	S/	N" )
 retrieve="select cd_convenio, nr_contrato, cd_grupo, id_lei_generico, pc_desconto,
	Case id_lei_generico 
		when 'G' then 'GEN$$HEX1$$c900$$ENDHEX$$RICO'
		when 'R' then 'REFER$$HEX1$$ca00$$ENDHEX$$NCIA'
		when 'E' then 'EQUIVALENTE'
		when 'S' then 'SIMILAR'
		when 'O' then 'OUTROS' End as de_tipo,
	nr_matricula_alteracao,
	dh_alteracao,
	coalesce(id_somente_produto_tarjado, 'N') id_somente_produto_tarjado
from dbo.contrato_preco_convenio_desc 
where cd_convenio = :pl_cd_convenio
and nr_contrato = :pl_nr_contrato
and cd_grupo = '1'" update="contrato_preco_convenio_desc" updatewhere=0 updatekeyinplace=yes arguments=(("pl_cd_convenio", number),("pl_nr_contrato", number)) )
