table(column=(type=long update=yes updatewhereclause=yes name=cd_convenio dbname="contrato_preco_convenio_prd.cd_convenio" )
 column=(type=long update=yes updatewhereclause=yes name=nr_contrato dbname="contrato_preco_convenio_prd.nr_contrato" )
 column=(type=long update=yes updatewhereclause=yes name=cd_produto dbname="contrato_preco_convenio_prd.cd_produto" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=pc_desconto dbname="contrato_preco_convenio_prd.pc_desconto" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_atualizacao_desconto dbname="contrato_preco_convenio_prd.dh_atualizacao_desconto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="produto_geral.id_lei_generico" )
 column=(type=char(11) updatewhereclause=yes name=de_lei_generico dbname="de_lei_generico" )
 column=(type=char(100) updatewhereclause=yes name=de_tarja dbname="tarja.de_tarja" )
 retrieve="select cp.cd_convenio, 
		cp.nr_contrato, 
		cp.cd_produto, 
		cp.pc_desconto, 
		cp.dh_atualizacao_desconto,  
		pg.de_produto||' : '||pg.de_apresentacao_venda as de_produto,
		pg.id_lei_generico,
		Case pg.id_lei_generico
				when 'G' then 'GEN$$HEX1$$c900$$ENDHEX$$RICO'
				when 'R' then 'REFER$$HEX1$$ca00$$ENDHEX$$NCIA'
				when 'E' then 'EQUIVALENTE'
				when 'S' then 'SIMILAR'
				when 'O' then 'OUTROS' end as de_lei_generico,
		tj.de_tarja
from contrato_preco_convenio_prd cp
	inner join produto_geral pg on pg.cd_produto = cp.cd_produto 
		and pg.id_situacao in ('A', 'P')
Left Outer Join tarja As tj 
		On tj.cd_tarja = coalesce(pg.cd_tarja, 4)
where cp.cd_convenio = :pl_cd_convenio
and cp.nr_contrato = :pl_nr_contrato" arguments=(("pl_cd_convenio", number),("pl_nr_contrato", number))  sort="de_produto A " )
