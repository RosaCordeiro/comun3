table(column=(type=long updatewhereclause=yes name=cd_produto dbname="resumo_reposicao_estoque.cd_produto" )
 column=(type=char(101) updatewhereclause=yes name=de_apresentacao dbname="De_Apresentacao" )
 column=(type=char(51) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=vw_classificacao_produto_grupoproduto dbname="vw_classificacao_produto.GrupoProduto" )
 column=(type=char(1) updatewhereclause=yes name=situacaoproduto dbname="produto_geral.SituacaoProduto" values="ATIVO	A/INATIVO	I/" )
 column=(type=long updatewhereclause=yes name=qtd_pedido dbname="Qtd_Pedido" )
 column=(type=decimal(2) updatewhereclause=yes name=media_dia dbname="Media_Dia" )
 column=(type=decimal(2) updatewhereclause=yes name=media_mes dbname="Media_Mes" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="vw_saldo_atual_produto.qt_saldo_final" )
 column=(type=long updatewhereclause=yes name=dias_estoque dbname="Dias_Estoque" )
 column=(type=decimal(2) updatewhereclause=yes name=sugestao_compra dbname="Sugestao_Compra" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="produto_geral.cd_fornecedor_usual" )
 column=(type=long updatewhereclause=yes name=qtd_falta dbname="qtd_falta" )
 column=(type=long updatewhereclause=yes name=qtd_recebida dbname="qtd_recebida" )
 retrieve="    select	r.cd_produto,  
		d.de_produto + ':' + d.de_apresentacao_venda as De_Apresentacao,
		substring(d.cd_fornecedor_usual,1,4) + '-' + substring(d.cd_fornecedor_usual,5,5) + ':' + f1.nm_fantasia as nm_fantasia ,
        cp.de_grupo as GrupoProduto ,
        d.id_situacao as SituacaoProduto ,
       	0 Qtd_Pedido,
		0.00 Media_Dia,
		0.00 Media_Mes,	
		s.qt_saldo_final	,
		0 Dias_Estoque,
		0.00 Sugestao_Compra,		
		d.cd_fornecedor_usual,
         0 as qtd_falta	,
		0 as qtd_recebida
from resumo_reposicao_estoque r
inner join filial f on f.cd_filial  = r.cd_filial
inner join produto_central c on c.cd_produto = r.cd_produto
inner join produto_geral d 	on d.cd_produto  = c.cd_produto 
inner join vw_porte_filial v on v.cd_filial = r.cd_filial
inner join vw_saldo_atual_produto s on r.cd_filial = s.cd_filial and r.cd_produto = s.cd_produto
inner join fornecedor f1 on f1.cd_fornecedor  = d.cd_fornecedor_usual
inner join vw_classificacao_produto As cp On cp.cd_subcategoria = d.cd_subcategoria
where c.cd_mix_produto in (select m.cd_mix_produto
									  from mix_produto_filial m
									where m.cd_filial = r.cd_filial)
and f.cd_filial = 534
and cp.cd_grupo = '5'
and d.id_situacao  = 'A'" )
