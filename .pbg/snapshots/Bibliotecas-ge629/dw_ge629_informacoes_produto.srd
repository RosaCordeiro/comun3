table(column=(type=long updatewhereclause=yes name=cd_produto dbname="resumo_reposicao_estoque.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=long updatewhereclause=yes name=qt_filial dbname="qt_filial" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_reposicao dbname="resumo_reposicao_estoque.id_tipo_reposicao" )
 column=(type=long updatewhereclause=yes name=qt_est_transito dbname="qt_est_transito" )
 retrieve="SELECT re.cd_produto,
pg.de_produto,
sum(re.qt_estoque_filial) as qt_filial,
re.id_tipo_reposicao,
0 qt_est_transito
FROM resumo_reposicao_estoque re
INNER JOIN produto_geral pg
ON re.cd_produto = pg.cd_produto
WHERE re.cd_produto = :as_produto
and re.cd_filial = 600
" arguments=(("as_produto", number)) )
