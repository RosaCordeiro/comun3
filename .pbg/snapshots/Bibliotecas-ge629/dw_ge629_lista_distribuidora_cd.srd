table(column=(type=long updatewhereclause=yes key=yes name=cd_produto dbname="produto_central.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_compra dbname="produto_geral.cd_unidade_medida_compra" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="produto_geral.id_lei_generico" )
 column=(type=char(1) updatewhereclause=yes name=cd_curva_abc_perini dbname="produto_central.cd_curva_abc_perini" )
 column=(type=char(1) updatewhereclause=yes name=cd_curva_abc_filiais dbname="produto_central.cd_curva_abc_filiais" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="produto_geral.cd_fornecedor_usual" )
 column=(type=char(95) updatewhereclause=yes name=nm_fornecedor dbname="nm_fornecedor" )
 column=(type=long updatewhereclause=yes name=nr_divisao dbname="fornecedor_divisao_produto.nr_divisao" )
 column=(type=char(49) updatewhereclause=yes name=nm_comprador dbname="nm_comprador" )
 column=(type=long updatewhereclause=yes name=qt_saldo_final dbname="saldo_produto.qt_saldo_final" )
 column=(type=long updatewhereclause=yes name=qt_estoque_base dbname="resumo_estoque_base_filiais.qt_estoque_base" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_custo_gerencial dbname="saldo_produto.vl_custo_gerencial" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_bloqueia_compra_pescador dbname="produto_central.id_bloqueia_compra_pescador" values="	S/	N" )
 column=(type=datetime update=yes updatewhereclause=yes name=dt_inicio_bloq_compra_pescador dbname="produto_central.dt_inicio_bloq_compra_pescador" )
 column=(type=datetime update=yes updatewhereclause=yes name=dt_fim_bloq_compra_pescador dbname="produto_central.dt_fim_bloq_compra_pescador" )
 column=(type=long updatewhereclause=yes name=qt_est_transito dbname="qt_est_transito" )
 column=(type=long updatewhereclause=yes name=qt_saldo_filiais dbname="qt_saldo_filiais" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_media_venda dbname="qt_media_venda" )
 column=(type=long updatewhereclause=yes name=qt_saldo_colocado dbname="qt_saldo_colocado" )
 retrieve="SELECT
   pc.cd_produto,
   pg.de_produto + ' : ' + pg.de_apresentacao_estoque AS de_produto,
   pg.cd_unidade_medida_compra,
   pg.id_lei_generico,
   pc.cd_curva_abc_perini,
   pc.cd_curva_abc_filiais,
   pg.cd_fornecedor_usual,
   f.cd_fornecedor + ' - ' + f.nm_fantasia + ' - ' + f.nm_razao_social AS nm_fornecedor,
   fdp.nr_divisao,
   fd.nr_matricula_comprador + ' - ' + u.nm_usuario AS nm_comprador,
   sp.qt_saldo_final,
   bf.qt_estoque_base,
   sp.vl_custo_gerencial,
   pc.id_bloqueia_compra_pescador,
   pc.dt_inicio_bloq_compra_pescador,
   pc.dt_fim_bloq_compra_pescador,
   0 AS qt_est_transito,
   sf.qt_saldo AS qt_saldo_filiais,
	CAST(0.00 AS DECIMAL(10, 2)) AS qt_media_venda,
	0 AS qt_saldo_colocado
FROM
    produto_central pc
INNER JOIN
    produto_geral pg
    ON pc.cd_produto = pg.cd_produto
INNER JOIN
    saldo_produto sp
    ON pg.cd_produto = sp.cd_produto
    AND sp.cd_filial = 534
    AND sp.dh_saldo = :arg_data_saldo_produto
LEFT JOIN
    resumo_estoque_base_filiais bf
    ON bf.cd_produto = pg.cd_produto
INNER JOIN
    fornecedor f
    ON f.cd_fornecedor = pg.cd_fornecedor_usual
INNER JOIN
    fornecedor_divisao fd
    ON f.cd_fornecedor = fd.cd_fornecedor
INNER JOIN
    fornecedor_divisao_produto fdp
    ON fd.cd_fornecedor = fdp.cd_fornecedor
    AND fd.nr_divisao = fdp.nr_divisao
    AND fdp.cd_produto = pg.cd_produto
INNER JOIN
    usuario u
    ON fd.nr_matricula_comprador = u.nr_matricula
LEFT JOIN (
    SELECT 
        sp2.cd_produto, 
        SUM(sp2.qt_saldo_final) AS qt_saldo
    FROM 
        saldo_produto sp2
    WHERE 
        sp2.dh_saldo = :arg_data_saldo_produto
        AND sp2.cd_filial NOT IN (1, 2, 534)
    GROUP BY 
        sp2.cd_produto
) AS sf
ON sf.cd_produto = pg.cd_produto
WHERE 
    sp.cd_filial = 534
" update="produto_central" updatewhere=0 updatekeyinplace=no arguments=(("arg_data_saldo_produto", date)) )
