 column=(type=char(1) updatewhereclause=yes name=nm_rede_convenio dbname="nm_rede_convenio" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="convenio.dh_inclusao" )
 column=(type=char(1) updatewhereclause=yes name=convenio_id_produtor_rural dbname="convenio.id_produtor_rural" )
 column=(type=char(11) updatewhereclause=yes name=convenio_nr_cpf dbname="convenio.nr_cpf" )
 column=(type=datetime updatewhereclause=yes name=dh_atualizacao dbname="convenio.dh_atualizacao" )
