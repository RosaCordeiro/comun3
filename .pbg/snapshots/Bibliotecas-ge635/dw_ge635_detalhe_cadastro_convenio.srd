 retrieve="  SELECT convenio.cd_convenio,   
         convenio.nr_cgc,   
         convenio.nr_inscricao_estadual,   
         convenio.de_endereco,  
	convenio.nr_endereco,
         convenio.de_bairro,   
         convenio.nr_telefone,   
         convenio.nr_fax,   
         convenio.nm_contato,   
         convenio.nr_cep,   
         convenio.nr_dia_base,   
         convenio.id_ordem_compra,   
         convenio.de_comentario,   
         convenio.qt_dias_vencimento,   
         convenio.nr_dias_lote,   
         convenio.cd_cidade,   
         convenio.cd_filial_centralizadora,   
         convenio.cd_portador,   
         convenio.id_paga_comissao,   
         convenio.nm_fantasia,   
         convenio.nm_razao_social,   
         '' nm_fantasia_localizacao,   
         cidade.nm_cidade,   
         convenio.pc_taxa_administracao,   
         convenio.dh_atualizacao_conveniado,   
         convenio.cd_layout_arquivo,   
         convenio.cd_layout_relatorio,   
         filial.nm_fantasia,   
         convenio.pc_abatimento_titulo,   
         convenio.pc_desconto_taxa_entrega,   
         convenio.vl_limite,   
         convenio.id_cartao_magnetico,   
         convenio.nr_matricula_alteracao,   
         convenio.id_senha_cartao,   
         convenio.cd_convenio_edm,   
         convenio.dh_alteracao,   
         isnull(convenio.id_site, 'N') id_site,   
         convenio.de_endereco_email_envio_xml,   
         convenio.vl_minimo_isencao_frete,   
         convenio.vl_minimo_entrega,   
         convenio.nm_contato2,   
         convenio.nr_matricula_responsavel_cia,
	'' nm_usuario_responsavel,
         convenio.de_endereco_email,
        convenio.nr_dia_vencimento_titulo,
	    isnull(convenio.id_gera_nfe, 'N') id_gera_nfe,
        '' nm_rede_convenio,
        convenio.dh_inclusao,
        convenio.id_produtor_rural,
	    convenio.nr_cpf,
        convenio.dh_atualizacao,
	    convenio.nr_matricula_atualizacao,
		convenio.id_notificacao_cobranca,
		convenio.id_tipo_controle,
		convenio.cd_cliente_sap,
		convenio.dh_exportacao_sap,
		coalesce(convenio.id_imprime_comprovante_venda, 'S') id_imprime_comprovante_venda
    FROM convenio,   
         cidade,   
         filial  
   WHERE ( cidade.cd_cidade = convenio.cd_cidade ) and  
         ( filial.cd_filial = convenio.cd_filial_centralizadora ) and  
         ( ( convenio.cd_convenio = :cd_convenio ) )    
" update="convenio" updatewhere=0 updatekeyinplace=no arguments=(("cd_convenio", number)) )
