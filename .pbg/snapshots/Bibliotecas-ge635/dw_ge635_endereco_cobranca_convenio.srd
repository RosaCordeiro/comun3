 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"convenio_endereco~" )  TABLE(NAME=~"cidade~" )  TABLE(NAME=~"usuario~" ALIAS=~"usuario_a~" )  TABLE(NAME=~"usuario~" ALIAS=~"usuario_b~" ) COLUMN(NAME=~"convenio_endereco.cd_convenio~") COLUMN(NAME=~"convenio_endereco.id_tipo_endereco~") COLUMN(NAME=~"convenio_endereco.cd_cidade~") COLUMN(NAME=~"convenio_endereco.de_endereco~") COLUMN(NAME=~"convenio_endereco.nr_endereco~") COLUMN(NAME=~"convenio_endereco.de_complemento~") COLUMN(NAME=~"convenio_endereco.de_bairro~") COLUMN(NAME=~"convenio_endereco.nr_cep~") COLUMN(NAME=~"convenio_endereco.nm_contato~") COLUMN(NAME=~"convenio_endereco.nr_telefone~") COLUMN(NAME=~"convenio_endereco.nr_fax~") COLUMN(NAME=~"convenio_endereco.dh_inclusao~") COLUMN(NAME=~"convenio_endereco.dh_atualizacao~") COLUMN(NAME=~"convenio_endereco.nr_matricula_inclusao~") COLUMN(NAME=~"convenio_endereco.nr_matricula_alteracao~") COLUMN(NAME=~"cidade.nm_cidade~") COLUMN(NAME=~"usuario_a.nm_usuario~") COLUMN(NAME=~"usuario_b.nm_usuario~")    JOIN (LEFT=~"convenio_endereco.cd_cidade~"    OP =~"=~"RIGHT=~"cidade.cd_cidade~" )    JOIN (LEFT=~"usuario_a.nr_matricula~"    OP =~"=~"RIGHT=~"convenio_endereco.nr_matricula_inclusao~" )    JOIN (LEFT=~"usuario_b.nr_matricula~"    OP =~"=~"RIGHT=~"convenio_endereco.nr_matricula_alteracao~" )WHERE(    EXP1 =~"convenio_endereco.cd_convenio~"   OP =~"=~"    EXP2 =~":pl_convenio~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"convenio_endereco.id_tipo_endereco~"   OP =~"=~"    EXP2 =~"'CO'~" ) ) ARG(NAME = ~"pl_convenio~" TYPE = number) " update="convenio_endereco" updatewhere=0 updatekeyinplace=no arguments=(("pl_convenio", number)) )
