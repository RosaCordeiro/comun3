table(column=(type=long updatewhereclause=yes name=cd_convenio dbname="cd_convenio" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) update=yes updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(1) updatewhereclause=yes name=id_permite_cadastramento dbname="id_permite_cadastramento" )
 column=(type=char(2) updatewhereclause=yes name=uf dbname="cidade.cd_unidade_federacao" )
 column=(type=char(2) updatewhereclause=yes name=id_rede dbname="vw_filial.id_rede" )
 retrieve="  SELECT 0 cd_convenio,
         filial.cd_filial,   
         filial.nm_fantasia,   
         ''id_permite_cadastramento,
         cidade.cd_unidade_federacao,
         vw_filial.id_rede
    FROM filial,
                 cidade,
                vw_filial
where filial.id_situacao = 'A' 
and filial.cd_cidade = cidade.cd_cidade 
and vw_filial.cd_filial = filial.cd_filial
and not exists (select 1 from convenio_filial 
   WHERE filial.cd_filial 				 = convenio_filial.cd_filial 
     and convenio_filial.cd_convenio = :cd_convenio)
" update="filial" updatewhere=1 updatekeyinplace=no arguments=(("cd_convenio", number))  sort="nm_fantasia A " )
