table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_convenio dbname="convenio_filial.cd_convenio" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_filial dbname="convenio_filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_permite_cadastramento dbname="convenio_filial.id_permite_cadastramento" initial="N" values="	S/	N" )
 column=(type=char(1) updatewhereclause=yes name=uf dbname="UF" )
 column=(type=char(1) updatewhereclause=yes name=id_rede dbname="id_rede" )
 retrieve="  SELECT convenio_filial.cd_convenio,   
         convenio_filial.cd_filial,   
         filial.nm_fantasia,   
         convenio_filial.id_permite_cadastramento ,
         '' UF,
	'' id_rede
    FROM convenio_filial,   
         filial  
   WHERE filial.cd_filial 				 = convenio_filial.cd_filial 
     and convenio_filial.cd_convenio = :cd_convenio 
" update="convenio_filial" updatewhere=2 updatekeyinplace=yes arguments=(("cd_convenio", number))  sort="cd_filial A " )
