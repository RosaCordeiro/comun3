table(column=(type=char(7) updatewhereclause=yes name=nr_placa dbname="veiculo.nr_placa" dbalias="v.nr_placa" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="veiculo.id_situacao" dbalias="v.id_situacao" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo_veiculo dbname="veiculo.id_tipo_veiculo" dbalias="v.id_tipo_veiculo" )
 column=(type=date updatewhereclause=yes name=dh_alvara_sanitario dbname="dh_alvara_sanitario" )
 column=(type=char(25) updatewhereclause=yes name=status_alvara dbname="status_alvara" )
 retrieve="SELECT v.nr_placa,
		 v.id_situacao,
		 v.id_tipo_veiculo,
		 CAST (v.dh_alvara_sanitario AS DATE) AS dh_alvara_sanitario,
		 CASE
			WHEN DATEDIFF (DAY, CURRENT_DATE (), v.dh_alvara_sanitario) < 0 THEN 'ALVARA SANITARIO VENCIDO'
			WHEN DATEDIFF (DAY, CURRENT_DATE (), v.dh_alvara_sanitario) > 0 AND DATEDIFF (DAY, CURRENT_DATE (), v.dh_alvara_sanitario) <= 30 THEN 'RENOVACAO ALVARA PENDENTE'
		 END AS status_alvara
  FROM veiculo v
 WHERE v.id_situacao = 'A'
	AND (DATEDIFF (DAY, CURRENT_DATE (), v.dh_alvara_sanitario) < 0
        OR
        DATEDIFF (DAY, CURRENT_DATE (), v.dh_alvara_sanitario  ) > 0 AND DATEDIFF (DAY, CURRENT_DATE (), v.dh_alvara_sanitario) <= 30)" )
