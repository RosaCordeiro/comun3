table(column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_filial dbname="nm_filial" )
 column=(type=long updatewhereclause=yes name=nr_pedido_filial dbname="nr_pedido_filial" )
 column=(type=long updatewhereclause=yes name=nr_pedido_distribuidora dbname="nr_pedido_distribuidora" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="cd_distribuidora" )
 column=(type=char(40) updatewhereclause=yes name=de_distribuidora dbname="de_distribuidora" )
 column=(type=long updatewhereclause=yes name=qt_saldo_momento dbname="qt_saldo_momento" )
 column=(type=long updatewhereclause=yes name=qt_demanda dbname="qt_demanda" )
 column=(type=long updatewhereclause=yes name=qt_pedido_dist dbname="qt_pedido_dist" )
 column=(type=long updatewhereclause=yes name=qt_atendida dbname="qt_atendida" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 column=(type=char(1) updatewhereclause=yes name=cd_curva_abc_filiais dbname="cd_curva_abc_filiais" )
 column=(type=decimal(11) updatewhereclause=yes name=venda_perdida dbname="venda_perdida" )
 column=(type=decimal(11) updatewhereclause=yes name=custo_venda_perdida dbname="custo_venda_perdida" )
 column=(type=decimal(28) updatewhereclause=yes name=pc_demanda_atendida dbname="pc_demanda_atendida" )
 column=(type=char(1) updatewhereclause=yes name=id_ruptura_geral dbname="id_ruptura_geral" )
 column=(type=char(1) updatewhereclause=yes name=id_ruptura_estadual dbname="id_ruptura_estadual" )
 column=(type=char(1) updatewhereclause=yes name=id_bloqueio_preco dbname="id_bloqueio_preco" )
 retrieve="SELECT
	aad.cd_filial,
	aad.nm_filial,
	aad.nr_pedido_filial,
	aad.nr_pedido_distribuidora, 
	aad.dh_emissao,
	aad.cd_distribuidora,
	aad.de_distribuidora,
	aad.qt_saldo_momento,
	aad.qt_demanda,
	aad.qt_pedido_dist,
	aad.qt_atendida,
	aad.qt_faturada,
	aad.cd_curva_abc_filiais,
	case when aad.qt_faturada + aad.qt_saldo_momento >= aad.qt_demanda_diaria then 0 else aad.qt_demanda_diaria * (aad.vl_venda / aad.vl_fator_conversao) end  as venda_perdida,
	case when aad.qt_faturada + aad.qt_saldo_momento >= aad.qt_demanda_diaria then 0 else aad.qt_demanda_diaria * (aad.vl_custo / aad.vl_fator_conversao) end  as custo_venda_perdida,
	Round((((Cast(aad.qt_faturada as decimal(12,2)) / Cast(aad.qt_demanda as decimal(12,2))) * aad.qt_demanda) / aad.qt_demanda) * 100.00, 2) as pc_demanda_atendida,
	aad.id_ruptura_geral,
	aad.id_ruptura_estadual,
	aad.id_bloqueio_preco
FROM
	dbo.avaliar_atendimento_dist aad (INDEX idx_adr_3)
WHERE
	aad.cd_produto	= :acd_produto
	AND aad.dh_emissao BETWEEN :adh_inicio and :adh_fim" arguments=(("adh_inicio", date),("adh_fim", date),("acd_produto", number)) )
