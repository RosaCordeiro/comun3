table(column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(100) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=reccorencia_faltas_filiais dbname="reccorencia_faltas_filiais" )
 column=(type=decimal(11) updatewhereclause=yes name=venda_perdida dbname="venda_perdida" )
 column=(type=decimal(11) updatewhereclause=yes name=custo_venda_perdida dbname="custo_venda_perdida" )
 column=(type=decimal(28) updatewhereclause=yes name=pc_demanda_atendida dbname="pc_demanda_atendida" )
 column=(type=long updatewhereclause=yes name=qt_demanda dbname="qt_demanda" )
 column=(type=long updatewhereclause=yes name=qt_pedido_dist dbname="qt_pedido_dist" )
 column=(type=long updatewhereclause=yes name=qt_atendida dbname="qt_atendida" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_problema dbname="qt_problema" )
 column=(type=long updatewhereclause=yes name=qt_sem_destino dbname="qt_sem_destino" )
 column=(type=long updatewhereclause=yes name=qt_demanda_ruptura_geral dbname="qt_demanda_ruptura_geral" )
 column=(type=long updatewhereclause=yes name=qt_demanda_ruptura_estadual dbname="qt_demanda_ruptura_estadual" )
 column=(type=long updatewhereclause=yes name=qt_demanda_bloqueio_preco dbname="qt_demanda_bloqueio_preco" )
 column=(type=long updatewhereclause=yes name=qt_demanda_bloqueio_dist dbname="qt_demanda_bloqueio_dist" )
 column=(type=long updatewhereclause=yes name=qt_nao_solicitada dbname="qt_nao_solicitada" )
 column=(type=long updatewhereclause=yes name=qt_nao_atendida dbname="qt_nao_atendida" )
 column=(type=long updatewhereclause=yes name=qt_nao_faturada dbname="qt_nao_faturada" )
 retrieve="SELECT
	aad.cd_produto,
	aad.de_produto,
	sum(case when aad.qt_faturada + aad.qt_saldo_momento >= aad.qt_demanda_diaria then 0 else 1 end) as reccorencia_faltas_filiais,
	sum(coalesce(case when aad.qt_faturada + aad.qt_saldo_momento >= aad.qt_demanda_diaria then 0 else aad.qt_demanda_diaria * (aad.vl_venda / aad.vl_fator_conversao) end, 0))  as venda_perdida,
	sum(coalesce(case when aad.qt_faturada + aad.qt_saldo_momento >= aad.qt_demanda_diaria then 0 else aad.qt_demanda_diaria * (aad.vl_custo / aad.vl_fator_conversao) end, 0))  as custo_venda_perdida,
	Round((sum((Cast(aad.qt_faturada as decimal(12,2)) / Cast(aad.qt_demanda as decimal(12,2))) * aad.qt_demanda) / sum(aad.qt_demanda)) * 100.00, 2) as pc_demanda_atendida, 
	sum(Coalesce(aad.qt_demanda, 0)) as qt_demanda,
	sum(aad.qt_pedido_dist) as qt_pedido_dist,
	sum(aad.qt_atendida) as qt_atendida,
	sum(Coalesce(aad.qt_faturada, 0)) as qt_faturada, 
	sum(case when Coalesce(aad.qt_faturada, 0) > Coalesce(aad.qt_demanda, 0) and 1 <> 1 then 0 else Coalesce(aad.qt_demanda, 0) - Coalesce(aad.qt_faturada, 0) end) as qt_problema,
	sum(case when aad.cd_distribuidora is null then aad.qt_demanda else 0 end) as qt_sem_destino,
	sum(case when aad.cd_distribuidora is null and aad.id_ruptura_geral = 'S' then aad.qt_demanda else 0 end) as qt_demanda_ruptura_geral,
	sum(case when aad.cd_distribuidora is null and aad.id_ruptura_geral <> 'S' and aad.id_ruptura_estadual = 'S' then aad.qt_demanda else 0 end) as qt_demanda_ruptura_estadual,
	sum(case when aad.cd_distribuidora is null and aad.id_ruptura_geral <> 'S' and aad.id_ruptura_estadual <> 'S' and aad.id_bloqueio_preco = 'S' then aad.qt_demanda else 0 end) as qt_demanda_bloqueio_preco,
	sum(case when aad.cd_distribuidora is null and aad.id_ruptura_geral <> 'S' and aad.id_ruptura_estadual <> 'S' and aad.id_bloqueio_preco <> 'S' then aad.qt_demanda else 0 end) as qt_demanda_bloqueio_dist,
	sum(case when aad.qt_pedido_dist is not null and aad.cd_distribuidora is not null then aad.qt_demanda - aad.qt_pedido_dist else 0 end) as qt_nao_solicitada,
	sum(case when aad.qt_pedido_dist > 0 then aad.qt_pedido_dist - aad.qt_atendida else 0 end) as qt_nao_atendida,
	sum(case when aad.qt_atendida > 0 then aad.qt_atendida - aad.qt_faturada  else 0 end) as qt_nao_faturada
FROM
	dbo.avaliar_atendimento_dist aad (INDEX idx_adr_1)
WHERE
	aad.dh_emissao BETWEEN :adh_inicio and :adh_fim

GROUP BY
	aad.cd_produto,
	aad.de_produto" arguments=(("adh_inicio", date),("adh_fim", date)) )
