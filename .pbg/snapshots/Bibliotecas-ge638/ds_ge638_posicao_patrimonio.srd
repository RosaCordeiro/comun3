table(column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="titulo_receber.cd_cliente" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="nm_cliente" )
 column=(type=char(20) updatewhereclause=yes name=cd_cliente_sap dbname="cd_cliente_sap" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total dbname="vl_total" )
 retrieve="select t.cd_cliente, c.nm_cliente, c.cd_cliente_sap, sum(case when mt.cd_tipo_movimento in (1,4) then 1 else -1 end * (mt.vl_movimento - coalesce(mt.vl_juros_recebidos,0) + coalesce(mt.vl_desconto_concedido,0) - coalesce(mt.vl_despesas_recebidas,0) - coalesce(mt.vl_multa_recebida,0))) as vl_total
from movimento_titulo_receber mt
inner join titulo_receber t
	on t.nr_titulo = mt.nr_titulo
inner join cliente c (index pk_cliente)
	on c.cd_cliente = t.cd_cliente
inner join nf_diversa n
	on n.cd_filial_origem = t.cd_filial_nf
	and n.nr_nf = t.nr_nf
	and n.de_serie = t.de_serie
	and n.de_especie = t.de_especie
Where t.dh_emissao <= :dh_posicao
	and (t.dh_baixa > :dh_posicao or t.id_situacao = 'A')
	and t.id_tipo_titulo = 'CR'
	and mt.dh_movimento <= :dh_posicao
     and coalesce(t.id_perdas_lucros, 'N') = 'N'
group by t.cd_cliente, c.nm_cliente, c.cd_cliente_sap

UNION ALL

select t.cd_cliente, c.nm_cliente, c.cd_cliente_sap, sum(case when mt.cd_tipo_movimento in (1,4) then 1 else -1 end * (mt.vl_movimento - coalesce(mt.vl_juros_recebidos,0) + coalesce(mt.vl_desconto_concedido,0) - coalesce(mt.vl_despesas_recebidas,0) - coalesce(mt.vl_multa_recebida,0))) as vl_total
from movimento_titulo_receber mt
inner join titulo_receber t
	on t.nr_titulo = mt.nr_titulo
inner join cliente c (index pk_cliente)
	on c.cd_cliente = t.cd_cliente
inner join integracao_sap intsap 
	on intsap.cd_empresa = 1000
	and intsap.cd_tabela = 'FILIAL'
	and intsap.cd_chave_legado = cast(t.cd_filial_nf as varchar)
inner join j_1bnfdoc_1 j1 (index idx_filial_nota)
	on j1.branch = intsap.cd_chave_sap
	and j1.nfnum = t.nr_nf /* Nota do T$$HEX1$$ed00$$ENDHEX$$tulo */
	and j1.id_substituida = 'N'
inner join j_1bnfdoc_2 j2 (index pk_j_1bnfdoc_2)
	on j2.mandt = j1.mandt
	and j2.docnum = j1.docnum
	and j2.nr_sequencial = j1.nr_sequencial
	and j2.series = t.de_serie /* Serie NF T$$HEX1$$ed00$$ENDHEX$$tulo */
	and j2.nftype = 'ZL' /* Venda de Ativo */
left outer join nf_diversa nfdiv
	on nfdiv.cd_filial_origem = t.cd_filial_nf
	and nfdiv.nr_nf = t.nr_nf
	and nfdiv.de_serie = t.de_serie
	and nfdiv.de_especie = t.de_especie
Where t.dh_emissao <= :dh_posicao
	and (t.dh_baixa > :dh_posicao or t.id_situacao = 'A')
	and t.id_tipo_titulo = 'CR'
	and mt.dh_movimento <= :dh_posicao
	and coalesce(t.id_perdas_lucros, 'N') = 'N'
	and nfdiv.nr_nf is null /* N$$HEX1$$e300$$ENDHEX$$o tenha nota diversa (j$$HEX1$$e100$$ENDHEX$$ retorna na query de cima) */
	and t.cd_filial_nf in(2,534) /* Matriz ou CD */
group by t.cd_cliente, c.nm_cliente, c.cd_cliente_sap" arguments=(("dh_posicao", date))  sort="nm_cliente A " )
