table(column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="cd_cliente" )
 column=(type=char(40) updatewhereclause=yes name=nm_cliente dbname="nm_cliente" )
 column=(type=char(20) updatewhereclause=yes name=cd_cliente_sap dbname="cd_cliente_sap" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total dbname="vl_total" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_outros dbname="vl_outros" )
 retrieve="select 	t.cd_cliente, 
			c.nm_cliente, 
			c.cd_cliente_sap, 
			sum(case when mt.cd_tipo_movimento in (1,4) then 1 else -1 end * (mt.vl_movimento - coalesce(mt.vl_juros_recebidos,0) + coalesce(mt.vl_desconto_concedido,0) - coalesce(mt.vl_despesas_recebidas,0) - coalesce(mt.vl_multa_recebida,0))) as vl_total,
			0 as vl_outros
from titulo_receber t (index idx_docto_sap)
inner join movimento_titulo_receber mt
	on t.nr_titulo = mt.nr_titulo
inner join cliente c (index pk_cliente)
	on c.cd_cliente = t.cd_cliente
Where t.dh_emissao <= :dh_posicao
	and (t.dh_baixa > :dh_posicao or t.id_situacao = 'A')
	and t.id_tipo_titulo = 'CR'
	and mt.dh_movimento <= :dh_posicao
	and coalesce(t.id_perdas_lucros, 'N') = 'N'
	and t.nr_documento_sap is not null
	and t.nr_conta_sap = '0011201067' /* Verbas e Acordos Comerciais */
group by t.cd_cliente, c.nm_cliente, c.cd_cliente_sap

union

select 	c.cd_cliente, 
			c.nm_cliente, 
			c.cd_cliente_sap, 
			0 as vl_total,
			sum(crm.vl_movimento * CASE WHEN ctm.id_outro_credito='S' THEN 1 ELSE -1 END) as vl_outros
from contas_receber_movimento crm
inner join cliente c (index pk_cliente)
	on c.cd_cliente = crm.cd_conta
inner join contas_receber_tipo_movimento ctm
	on ctm.cd_tipo_movimento = crm.cd_tipo_movimento
left outer join titulo_receber tr 
	on tr.nr_titulo = case when crm.id_tipo_lancto='X' then crm.de_atribuicao else null end
Where  crm.id_tipo_conta = 'CR'
	and crm.dh_movimento >= '20240501' /* Data inicio verbas */
	and crm.dh_movimento <= :dh_posicao
	and crm.id_tipo_lancto in ('1','X') /* Verbas e Acordos Comerciais */
	and (crm.id_tipo_lancto='1' or tr.nr_conta_sap='0011201067')
	and crm.cd_tipo_movimento in (select c1.cd_tipo_movimento 
											from contas_receber_tipo_movimento c1
											where c1.id_tipo_conta = 'CR'
												and (c1.id_outro_credito='S' or c1.id_outro_debito='S'))
group by c.cd_cliente, c.nm_cliente, c.cd_cliente_sap" arguments=(("dh_posicao", date)) )
