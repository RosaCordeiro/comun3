table(column=(type=char(11) updatewhereclause=yes name=cd_conta dbname="contas_receber_saldo.cd_conta" )
 column=(type=char(20) updatewhereclause=yes name=cd_cliente_sap dbname="cd_cliente_sap" )
 column=(type=char(3) updatewhereclause=yes name=id_tipo_conta dbname="contas_receber_saldo.id_tipo_conta" values="CONV$$HEX1$$ca00$$ENDHEX$$NIO	CV/CONTA CORRENTE	CC/CREDI$$HEX1$$c100$$ENDHEX$$RIO	CR/FORNECEDOR	FO/LUCROS E PERDAS	LP/PATRIM$$HEX1$$d400$$ENDHEX$$NIO	PT/" )
 column=(type=char(40) updatewhereclause=yes name=nm_conta dbname="cliente.nm_conta" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_vendas dbname="contas_receber_saldo.vl_vendas" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_titulos dbname="contas_receber_saldo.vl_titulos" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_outros dbname="contas_receber_saldo.vl_outros" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total dbname="vl_total" )
 retrieve="select s.cd_conta,   
	    coalesce(c.cd_cliente_sap, cv.cd_cliente_sap) as cd_cliente_sap,
       s.id_tipo_conta,   
       c.nm_cliente nm_conta,
       s.vl_vendas,   
       s.vl_titulos,   
       s.vl_outros, 
	  coalesce(s.vl_vendas, 0) + coalesce(s.vl_titulos, 0) - coalesce(s.vl_outros, 0) as vl_total
from contas_receber_saldo s
inner join cliente c
  on c.cd_cliente    = s.cd_conta
  and s.id_tipo_conta <> 'CV'
inner join convenio cv
 on cv.cd_convenio = case when s.id_tipo_conta = 'CV' then cast(s.cd_conta as integer) else null end
  and s.id_tipo_conta = 'CV'
where s.id_tipo_conta = 'CC'"  sort="id_tipo_conta A nm_conta A " )
group(level=1 header.height=80 trailer.height=72 by=("id_tipo_conta" ) header.color="536870912" header.transparency="0" header.gradient.color="8421504" header.gradient.transparency="0" header.gradient.angle="0" header.brushmode="0" header.gradient.repetition.mode="0" header.gradient.repetition.count="0" header.gradient.repetition.length="100" header.gradient.focus="0" header.gradient.scale="100" header.gradient.spread="100" trailer.color="536870912" trailer.transparency="0" trailer.gradient.color="8421504" trailer.gradient.transparency="0" trailer.gradient.angle="0" trailer.brushmode="0" trailer.gradient.repetition.mode="0" trailer.gradient.repetition.count="0" trailer.gradient.repetition.length="100" trailer.gradient.focus="0" trailer.gradient.scale="100" trailer.gradient.spread="100" )
