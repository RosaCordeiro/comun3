table(column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="produto_excecao_corte_cd.cd_produto" )
 column=(type=char(100) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(49) updatewhereclause=yes name=usuario_atualizacao dbname="usuario_atualizacao" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="produto_excecao_corte_cd.id_situacao" initial="S" values="	A/	I" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_inicio dbname="produto_excecao_corte_cd.dh_inicio" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_fim dbname="produto_excecao_corte_cd.dh_fim" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_atualizacao dbname="produto_excecao_corte_cd.dh_atualizacao" )
 column=(type=char(20) update=yes updatewhereclause=yes name=nr_matricula_atualizacao dbname="produto_excecao_corte_cd.nr_matricula_atualizacao" )
 retrieve="SELECT	 pe.cd_produto,
			(pg.de_produto + pg.de_apresentacao_estoque) as de_produto,
			(u.nr_matricula + ' - ' + u.nm_usuario) as usuario_atualizacao,
         pe.id_situacao,   
         pe.dh_inicio,   
         pe.dh_fim,   
         pe.dh_atualizacao,   
         pe.nr_matricula_atualizacao 
    FROM produto_excecao_corte_cd pe
	INNER JOIN usuario u
	on pe.nr_matricula_atualizacao= u.nr_matricula
	INNER JOIN dbo.produto_geral pg
	on pg.cd_produto = pe.cd_produto
" update="produto_excecao_corte_cd" updatewhere=0 updatekeyinplace=no )
