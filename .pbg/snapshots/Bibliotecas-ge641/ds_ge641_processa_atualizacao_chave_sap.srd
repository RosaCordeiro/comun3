table(column=(type=char(40) updatewhereclause=yes name=nr_atualizacao dbname="nr_atualizacao" )
 column=(type=char(60) update=yes updatewhereclause=yes name=cd_chave_interface dbname="log_exportacao_sap.cd_chave_interface" dbalias="lo.cd_chave_interface" )
 column=(type=char(1) updatewhereclause=yes name=id_tipo dbname="id_tipo" )
 retrieve="select	
	cast(lo.nr_atualizacao  as varchar(40)) as nr_atualizacao,
	lo.cd_chave_interface,
	'N' as id_tipo
From 
	log_exportacao_sap lo
Inner Join 
	wms_int_sap wis 
	On wis.nr_integracao = cast(lo.cd_chave as integer)
Left Outer Join 
	fornecedor f 
	On f.cd_fornecedor = wis.cd_fornecedor 
Left Outer Join 
	fornecedor t 
	On t.cd_fornecedor = wis.cd_transportadora 
Left Outer Join 
	motivo_devolucao_compra m 
   On (m.cd_motivo_devolucao = wis.cd_motivo_devolucao)
where 
	lo.id_tipo_nf						= 'WMD' 
	and lo.id_status_integracao	= 'C' 
	and (lo.cd_chave_interface 		is null or lo.cd_chave_interface = '')
	and wis.id_situacao 				= 'C'
Union
select
	cast(lo.nr_atualizacao  as varchar(40)) as nr_atualizacao,
	lo.cd_chave_interface,
	'N' as id_tipo
From
	log_exportacao_sap lo
Inner Join
	wms_int_sap wis 
	On wis.nr_integracao = cast(lo.cd_chave as integer)
Left Outer Join
	fornecedor f 
	On f.cd_fornecedor = wis.cd_fornecedor 
Left Outer Join
	fornecedor t 
	On t.cd_fornecedor = wis.cd_transportadora 
Left Outer Join
	motivo_devolucao_compra m 
   On (m.cd_motivo_devolucao = wis.cd_motivo_devolucao)
where
	lo.id_tipo_nf						in ('WMA', 'WMI', 'WMT')
	and lo.id_status_integracao 	= 'C' 
	and (lo.cd_chave_interface 		is null or lo.cd_chave_interface = '')
Union
select
	cast(lo.nr_atualizacao  as varchar(40)) as nr_atualizacao,
	lo.cd_chave_interface,
	'N' as id_tipo
From
	log_exportacao_sap lo
where
	lo.id_tipo_nf						in ('WMM')
	and lo.id_status_integracao 	= 'C' 
	and (lo.cd_chave_interface 		is null or lo.cd_chave_interface = '')
Union
select
	le.nr_exportacao as nr_atualizacao,
	cd_varchar3,
	'E' as id_tipo
From
	log_exportacao le
WHERE
	le.cd_tipo_exportacao			= 4
	and le.id_situacao_exportacao	= 'C'
	and (le.cd_varchar3 				is null or le.cd_varchar3 = '')" )
