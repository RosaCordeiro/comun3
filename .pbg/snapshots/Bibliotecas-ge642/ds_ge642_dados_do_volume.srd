table(column=(type=decimal(0) updatewhereclause=yes name=nr_chave_volume dbname="wms_segregado_receb_dev.nr_chave_volume" )
 column=(type=long updatewhereclause=yes name=cd_filial_origem dbname="wms_segregado_receb_dev.cd_filial_origem" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="wms_segregado_receb_dev.nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="wms_segregado_receb_dev.de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="wms_segregado_receb_dev.de_serie" )
 column=(type=long updatewhereclause=yes name=nr_volume dbname="wms_segregado_receb_dev.nr_volume" )
 column=(type=char(20) updatewhereclause=yes name=de_tipo_retirada dbname="tipo_retirada_estoque.de_tipo_retirada" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 retrieve="  SELECT srd.nr_chave_volume,   
         srd.cd_filial_origem,   
         srd.nr_nf,   
         srd.de_especie,   
         srd.de_serie,   
         srd.nr_volume,   
         tre.de_tipo_retirada,   
         f.nm_fantasia  
    FROM wms_segregado_receb_dev srd,   
         tipo_retirada_estoque tre,   
         filial f
   WHERE tre.cd_tipo_retirada = srd.id_tipo_retirada and  
         f.cd_filial = srd.cd_filial_origem
	  AND srd.dh_cancelamento IS NULL
" )
