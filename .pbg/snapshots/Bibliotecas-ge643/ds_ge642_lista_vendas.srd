table(column=(type=char(7) updatewhereclause=yes name=ano_mes dbname="ano_mes" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="nr_sequencial" )
 column=(type=char(50) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(5) updatewhereclause=yes name=cd_natureza_operacao dbname="cd_natureza_operacao" )
 column=(type=char(12) updatewhereclause=yes name=id_pis_cofins_prod dbname="id_pis_cofins_prod" )
 column=(type=long updatewhereclause=yes name=nr_classificacao_fiscal dbname="nr_classificacao_fiscal" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_bruto dbname="vl_total_bruto" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_total_liquido dbname="vl_total_liquido" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="cd_unidade_federacao" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=long updatewhereclause=yes name=qt_vendida dbname="qt_vendida" )
 column=(type=char(1) updatewhereclause=yes name=cd_cst_origem dbname="cd_cst_origem" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_tributacao dbname="cd_cst_tributacao" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_bc_icms dbname="vl_bc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms dbname="pc_icms" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_fcp dbname="pc_fcp" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_icms dbname="vl_icms" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_pis dbname="cd_cst_pis" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_bc_pis dbname="vl_bc_pis" )
 column=(type=decimal(19) updatewhereclause=yes name=vl_pis dbname="vl_pis" )
 column=(type=char(2) updatewhereclause=yes name=cd_cst_cofins dbname="cd_cst_cofins" )
 column=(type=decimal(15) updatewhereclause=yes name=vl_bc_cofins dbname="vl_bc_cofins" )
 column=(type=decimal(18) updatewhereclause=yes name=vl_cofins dbname="vl_cofins" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_bc_icms_efetivo dbname="vl_bc_icms_efetivo" )
 column=(type=decimal(4) updatewhereclause=yes name=pc_icms_efetivo dbname="pc_icms_efetivo" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_efetivo dbname="vl_icms_efetivo" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso dbname="de_chave_acesso" )
 column=(type=long updatewhereclause=yes name=nf_ecf dbname="nf_ecf" )
 column=(type=long updatewhereclause=yes name=nr_operacao_ecf dbname="nr_operacao_ecf" )
 column=(type=long updatewhereclause=yes name=nr_coo_ecf dbname="nr_coo_ecf" )
 column=(type=char(20) updatewhereclause=yes name=nr_serie_ecf dbname="nr_serie_ecf" )
 column=(type=char(30) updatewhereclause=yes name=nr_serie_mfd_ecf dbname="nr_serie_mfd_ecf" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_icms_atual dbname="pc_icms_atual" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_fcp_atual dbname="pc_fcp_atual" )
 retrieve="select substring(CONVERT( CHAR(10), n.dh_movimentacao_caixa, 111 ), 1, 7) ano_mes,
          n.cd_filial,  
          n.de_especie,
          n.de_serie,
        i.cd_produto, 
          i.nr_sequencial,
        cast(p.de_produto ||': '|| p.de_apresentacao_venda as varchar(50)) as de_produto, 
        cast(i.cd_natureza_operacao as varchar(5)) as cd_natureza_operacao, 
        cast(case coalesce(hp.id_situacao_pis_cofins,p.id_situacao_pis_cofins) when 'P' then 'POSITIVA' when 'N' then 'NEGATIVA' else 'TRIBUTADA' end as varchar(12)) as id_pis_cofins_prod, 
        coalesce(hp.nr_classificacao_fiscal, p.nr_classificacao_fiscal) as nr_classificacao_fiscal, 
        sum(i.qt_vendida * vl_preco_unitario) as vl_total_bruto, 
        sum((i.qt_vendida * i.vl_preco_praticado) - round( i.qt_vendida * i.vl_preco_praticado * (coalesce(n.pc_desconto,0) / 100), 2))  as vl_total_liquido, 
        n.dh_movimentacao_caixa,
        cf.cd_unidade_federacao,
        n.nr_nf, 
        sum(i.qt_vendida) as qt_vendida, 
        i.cd_cst_origem, 
          i.cd_cst_tributacao,
          sum(CASE WHEN i.cd_natureza_operacao in (5102, 6102) and coalesce(i.cd_cst_tributacao, substring(i.cd_situacao_tributaria, 2, 1)||'0')='00' THEN (i.qt_vendida * i.vl_preco_praticado) - round( i.qt_vendida * i.vl_preco_praticado * (coalesce(n.pc_desconto,0) / 100), 2) ELSE 0.00 END) as vl_bc_icms, 
        coalesce(hpu.pc_icms, aicms.pc_icms) as pc_icms, 
        coalesce(hpu.pc_fcp, aicms.pc_fcp) as pc_fcp, 
          sum(CASE WHEN i.cd_natureza_operacao in (5102, 6102) and coalesce(i.cd_cst_tributacao, substring(i.cd_situacao_tributaria, 2, 1)||'0')='00' THEN round((i.qt_vendida * i.vl_preco_praticado) * i.pc_icms / 100 - round( i.qt_vendida * i.vl_preco_praticado * (coalesce(n.pc_desconto,0) / 100), 2),2) ELSE 0.00 END) as vl_icms, 
          i.cd_cst_pis,
        sum(case when i.cd_cst_pis in ('01', '50') or (coalesce(hp.id_situacao_pis_cofins, p.id_situacao_pis_cofins) = 'T' and i.cd_cst_pis is null) then (i.qt_vendida * i.vl_preco_praticado) - round( i.qt_vendida * i.vl_preco_praticado * (coalesce(n.pc_desconto,0) / 100), 2) else 0.00 end) as vl_bc_pis, 
        sum(case when i.cd_cst_pis in ('01', '50') or (coalesce(hp.id_situacao_pis_cofins, p.id_situacao_pis_cofins) = 'T' and i.cd_cst_pis is null) then round(((i.qt_vendida * i.vl_preco_praticado) - round( i.qt_vendida * i.vl_preco_praticado * (coalesce(n.pc_desconto,0) / 100), 2)) * 0.0165, 2) else 0.00 end) as vl_pis, 
          i.cd_cst_cofins,
        sum(case when i.cd_cst_cofins in ('01', '50') or (coalesce(hp.id_situacao_pis_cofins, p.id_situacao_pis_cofins) = 'T' and i.cd_cst_cofins is null) then (i.qt_vendida * i.vl_preco_praticado) - round( i.qt_vendida * i.vl_preco_praticado * (coalesce(n.pc_desconto,0) / 100), 2) else 0.00 end) as vl_bc_cofins, 
        sum(case when i.cd_cst_cofins in ('01', '50') or (coalesce(hp.id_situacao_pis_cofins, p.id_situacao_pis_cofins) = 'T' and i.cd_cst_cofins is null) then round(((i.qt_vendida * i.vl_preco_praticado) - round( i.qt_vendida * i.vl_preco_praticado * (coalesce(n.pc_desconto,0) / 100), 2)) * 0.076, 2) else 0.00 end) as vl_cofins, 
        sum(i.vl_bc_icms_efetivo) as vl_bc_icms_efetivo, 
        i.pc_icms_efetivo, 
        sum(i.vl_icms_efetivo) as vl_icms_efetivo, 
        nfe.de_chave_acesso, 
          CASE WHEN n.de_especie = 'CF' THEN n.nr_ecf ELSE null END as nf_ecf,
          CASE WHEN n.de_especie = 'CF' THEN n.nr_operacao_ecf ELSE null END as nr_operacao_ecf,
          CASE WHEN n.de_especie = 'CF' THEN n.nr_coo_ecf ELSE null END as nr_coo_ecf,
          CASE WHEN n.de_especie = 'CF' THEN imp.nr_serie ELSE null END as nr_serie_ecf,
          CASE WHEN n.de_especie = 'CF' THEN imp.nr_serie_mfd ELSE null END as nr_serie_mfd_ecf,
        aicms.pc_icms as pc_icms_atual, 
        aicms.pc_fcp as pc_fcp_atual
from nf_venda n (index idx_data_filial)   
    left join nf_venda_nfe nfe (index pk_nf_venda_nfe)      on nfe.cd_filial = n.cd_filial+0      and nfe.nr_nf = n.nr_nf+0      and nfe.de_serie = n.de_serie      and nfe.de_especie = n.de_especie 
    inner join item_nf_venda i (index pk_item_nf_venda)     on i.cd_filial = n.cd_filial+0  and i.nr_nf = n.nr_nf+0     and i.de_serie = n.de_serie     and i.de_especie = n.de_especie 
    inner join produto_geral p (index pk_produto_geral)     on p.cd_produto = i.cd_produto+0 
    inner join filial f (index pk_filial)   on f.cd_filial = n.cd_filial+0 
    inner join cidade cf (index pk_cidade)  on cf.cd_cidade = f.cd_cidade+0 
    left outer join historico_produto hp (index pk_historico_produto)   on hp.cd_produto = p.cd_produto+0   and hp.dh_historico = cast(cast(year(n.dh_movimentacao_caixa) as varchar)||'/'||cast(month(n.dh_movimentacao_caixa) as varchar)||'/01' as datetime)
    left outer join historico_produto_uf hpu (index pk_historico_produto_uf)    on hpu.cd_produto = hp.cd_produto+0     and hpu.dh_historico = hp.dh_historico  and hpu.cd_unidade_federacao = cf.cd_unidade_federacao 
    left outer join produto_uf pu (index pk_produto_uf)     on pu.cd_produto = p.cd_produto+0   and pu.cd_unidade_federacao = cf.cd_unidade_federacao 
    left outer join tipo_icms aicms (index pk_tipo_icms)    on aicms.cd_tipo_icms = pu.cd_tipo_icms 
     left outer join impressora_fiscal imp (index pk_impressora_fiscal) on imp.cd_filial = n.cd_filial and imp.nr_ecf = n.nr_nf
Where  n.dh_cancelamento is null 
    and n.nr_nf_anexa is null 
     and n.cd_filial = :filial
    and n.dh_movimentacao_caixa >= :inicio
    and n.dh_movimentacao_caixa < :fim 
    and i.cd_natureza_operacao in (5405, 6405)
    --and coalesce(hp.id_situacao_pis_cofins, p.id_situacao_pis_cofins) = 'T'
     and (i.cd_cst_pis in ('01', '50') or (coalesce(hp.id_situacao_pis_cofins, p.id_situacao_pis_cofins) = 'T' and i.cd_cst_pis is null)) // mes 2023/08 tira erro da CST do PIS
group by n.cd_filial, 
          n.de_especie,
          n.de_serie,
          i.nr_sequencial,
            cast(i.cd_natureza_operacao as varchar(5)), 
            cast(case coalesce(hp.id_situacao_pis_cofins,p.id_situacao_pis_cofins) when 'P' then 'POSITIVA' when 'N' then 'NEGATIVA' else 'TRIBUTADA' end as varchar(12)), 
            coalesce(hp.nr_classificacao_fiscal, p.nr_classificacao_fiscal), 
            i.cd_produto, 
            cast(p.de_produto ||': '|| p.de_apresentacao_venda as varchar(50)), 
            n.dh_movimentacao_caixa,
            cf.cd_unidade_federacao,
            n.nr_nf,
            i.cd_cst_origem,
               i.cd_cst_tributacao,
               i.cd_cst_pis,
               i.cd_cst_cofins,
            i.pc_icms, 
            i.pc_icms_efetivo, 
            nfe.de_chave_acesso, 
          CASE WHEN n.de_especie = 'CF' THEN n.nr_ecf ELSE null END ,
          CASE WHEN n.de_especie = 'CF' THEN n.nr_operacao_ecf ELSE null END ,
          CASE WHEN n.de_especie = 'CF' THEN n.nr_coo_ecf ELSE null END ,
          CASE WHEN n.de_especie = 'CF' THEN imp.nr_serie ELSE null END ,
          CASE WHEN n.de_especie = 'CF' THEN imp.nr_serie_mfd ELSE null END,
            aicms.pc_icms, 
            aicms.pc_fcp, 
            coalesce(hpu.pc_icms, aicms.pc_icms), 
            coalesce(hpu.pc_fcp, aicms.pc_fcp)


" arguments=(("filial", number),("inicio", date),("fim", date)) )
