table(column=(type=char(7) updatewhereclause=yes name=ano_mes dbname="credito_pis_cofins.ano_mes" )
 column=(type=long updatewhereclause=yes name=cd_natureza_operacao dbname="credito_pis_cofins.cd_natureza_operacao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_liquido dbname="vl_total_liquido" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_icms_efetivo dbname="vl_icms_efetivo" )
 retrieve="SELECT ano_mes, cd_natureza_operacao, sum(vl_total_liquido) vl_total_liquido, sum(coalesce(vl_icms_efetivo, vl_icms_efetivo_calc)) vl_icms_efetivo
FROM dbo.credito_pis_cofins cpc 
where ano_mes = :ps_ano_mes
and dh_movimentacao_caixa >= '20170315'
group by ano_mes, cd_natureza_operacao" arguments=(("ps_ano_mes", string)) )
