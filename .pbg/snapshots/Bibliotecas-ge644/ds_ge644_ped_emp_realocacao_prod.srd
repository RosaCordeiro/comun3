table(column=(type=char(100) updatewhereclause=yes name=produto dbname="produto" )
 column=(type=char(30) updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_aprovada dbname="pedido_empurrado_produto.qt_aprovada" dbalias="pep.qt_aprovada" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_empurrado.cd_filial" dbalias="pe.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_pedido_empurrado dbname="pedido_empurrado.nr_pedido_empurrado" dbalias="pe.nr_pedido_empurrado" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_situacao dbname="pedido_empurrado.id_situacao" dbalias="pe.id_situacao" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_processado dbname="pedido_empurrado.id_processado" dbalias="pe.id_processado" )
 column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="pedido_empurrado.dh_emissao" dbalias="pe.dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao dbname="pedido_empurrado.dh_inclusao" dbalias="pe.dh_inclusao" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_cancelamento dbname="pedido_empurrado.dh_cancelamento" dbalias="pe.dh_cancelamento" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_cancelamento dbname="pedido_empurrado.nr_matricula_cancelamento" dbalias="pe.nr_matricula_cancelamento" )
 column=(type=char(50) update=yes updatewhereclause=yes name=de_motivo_cancelamento dbname="pedido_empurrado.de_motivo_cancelamento" dbalias="pe.de_motivo_cancelamento" )
 column=(type=long updatewhereclause=yes name=qt_empurrada dbname="pedido_empurrado_produto.qt_empurrada" dbalias="pep.qt_empurrada" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="pedido_empurrado_produto.qt_faturada" dbalias="pep.qt_faturada" )
 column=(type=long updatewhereclause=yes name=qt_faltante dbname="qt_faltante" )
 retrieve="SELECT	(pg.de_produto + pg.de_apresentacao_estoque) as produto,
			(CONVERT(VARCHAR, pep.cd_produto)) as cd_produto,
			pep.qt_aprovada,
			pe.cd_filial,
			pe.nr_pedido_empurrado,
			pe.id_situacao,
			pe.id_processado,
			pe.dh_emissao,
			pe.dh_inclusao,
			pe.dh_cancelamento,
			pe.nr_matricula_cancelamento,
			pe.de_motivo_cancelamento,
			pep.qt_empurrada,
			pep.qt_faturada,
			(pep.qt_empurrada - pep.qt_faturada) as qt_faltante
FROM pedido_empurrado pe
INNER JOIN dbo.pedido_empurrado_produto pep
	ON pe.cd_filial 						= pep.cd_filial
	AND pe.nr_pedido_empurrado 		= pep.nr_pedido_empurrado
INNER JOIN pedido_filial_prd_empurrado pfpe
	ON pfpe.cd_filial 					= pep.cd_filial
	AND pfpe.nr_pedido_empurrado 	= pep.nr_pedido_empurrado
	AND pfpe.cd_produto 				= pep.cd_produto
INNER JOIN pedido_filial pf
	ON pf.cd_filial 						= pfpe.cd_filial
	AND pf.nr_pedido_filial 			= pfpe.nr_pedido_filial
INNER JOIN pedido_filial_produto pfp
	ON pfp.cd_filial 					= pfpe.cd_filial
	AND pfp.nr_pedido_filial			= pfpe.nr_pedido_filial
	AND pfp.cd_produto					= pfpe.cd_produto
INNER JOIN pedido_distribuidora pd
	ON pfp.cd_filial = pd.cd_filial
	AND pfp.nr_pedido_distribuidora = pd.nr_pedido_distribuidora
INNER JOIN produto_geral pg
	ON pg.cd_produto = pfp.cd_produto
WHERE pe.dh_emissao BETWEEN :dt_inicio AND :dt_fim
	AND pe.id_tipo_pedido			= 'U'
	AND pe.id_reserva_saldo_cd	= 'S'
	AND pep.qt_faturada			< pep.qt_empurrada
	AND pd.id_situacao				= 'F'
	AND pe.id_situacao				= :situacao_pedido	
	AND pe.cd_filial 				= :filial
	AND pe.nr_pedido_empurrado	= :pedido_empurrado" arguments=(("dt_inicio", date),("dt_fim", date),("situacao_pedido", string),("filial", number),("pedido_empurrado", number)) )
