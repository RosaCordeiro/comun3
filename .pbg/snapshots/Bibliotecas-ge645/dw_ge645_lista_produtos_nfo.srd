table(column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_int_sap_detalhe.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=nm_produto dbname="nm_produto" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="wms_int_sap_detalhe.nr_lote" )
 column=(type=long updatewhereclause=yes name=qt_lote dbname="wms_int_sap_detalhe.qt_lote" )
 column=(type=char(44) updatewhereclause=yes name=de_chave_acesso_origem dbname="wms_int_sap_auxiliar.de_chave_acesso_origem" )
 retrieve="SELECT b.cd_produto,
    pg.de_produto + ' : ' + pg.de_apresentacao_estoque AS nm_produto,
    b.nr_lote,
    b.qt_lote,
    a.de_chave_acesso_origem
FROM wms_int_sap_auxiliar a
    INNER JOIN wms_int_sap_detalhe b ON b.nr_integracao = a.nr_integracao
                                        AND b.nr_sequencial = a.nr_sequencial
    INNER JOIN produto_geral       pg ON pg.cd_produto = b.cd_produto
WHERE a.nr_integracao = :an_nr_integracao" arguments=(("an_nr_integracao", number)) )
