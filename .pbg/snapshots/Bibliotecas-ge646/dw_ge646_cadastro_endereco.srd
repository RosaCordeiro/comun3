table(column=(type=long updatewhereclause=yes identity=yes name=id_controle dbname="wms_locais_perm_por_tp_apres.id_controle" )
 column=(type=char(65) updatewhereclause=yes name=apresentacao dbname="apresentacao" )
 column=(type=char(53) updatewhereclause=yes name=bairro dbname="bairro" )
 column=(type=char(2) update=yes updatewhereclause=yes key=yes name=id_apresentacao dbname="wms_locais_perm_por_tp_apres.id_apresentacao" )
 column=(type=char(1) update=yes updatewhereclause=yes key=yes name=cd_bairro dbname="wms_locais_perm_por_tp_apres.cd_bairro" )
 column=(type=char(2) update=yes updatewhereclause=yes key=yes name=cd_rua dbname="wms_locais_perm_por_tp_apres.cd_rua" initial="01" )
 retrieve="	SELECT  
	wl.id_controle,   
	'(' + CAST(tp.id_apresentacao AS VARCHAR) + ') - ' + tp.de_apresentacao AS apresentacao, 
	CAST(wl.cd_bairro AS VARCHAR) + ' - ' + wb.nm_bairro AS bairro,
	wl.id_apresentacao,
	wl.cd_bairro,
	wl.cd_rua
FROM 
	wms_locais_perm_por_tp_apres wl
	INNER JOIN wms_bairro wb	
		ON wl.cd_bairro = wb.cd_bairro 
	INNER JOIN wms_rua wr
		ON wl.cd_rua = wr.cd_rua 
	INNER JOIN tipo_apresentacao_produto tp
		ON wl.id_apresentacao = tp.id_apresentacao
	WHERE 1=1" update="wms_locais_perm_por_tp_apres" updatewhere=0 updatekeyinplace=no )
