table(column=(type=decimal(0) updatewhereclause=yes identity=yes name=nr_controle dbname="wms_segregado_recebimento.nr_controle" )
 column=(type=long updatewhereclause=yes name=qt_saldo_wms dbname="wms_localizacao.qt_saldo_wms" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_localizacao.cd_produto" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="wms_localizacao.cd_endereco" )
 column=(type=long updatewhereclause=yes name=qt_caixa_padrao dbname="wms_localizacao.qt_caixa_padrao" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="wms_localizacao.nr_lote" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="wms_localizacao.dh_validade" )
 retrieve="select wsr.nr_controle, 
	    wl.qt_saldo as qt_saldo_wms,
	    wl.cd_produto,
	    wl.cd_endereco,
	    wl.qt_caixa_padrao,
	    wl.nr_lote,
	    wl.dh_validade 
  from wms_segregado_recebimento wsr
 inner join dbo.wms_localizacao wl on wl.cd_endereco = wsr.cd_endereco 
											 and wl.cd_produto = wsr.cd_produto 
											 and wl.nr_lote = wsr.nr_lote 
											 and wl.dh_validade = wsr.dh_validade 
 where wl.qt_saldo <> wsr.qt_lote
 union
 select null,
 		  wl.qt_saldo as qt_saldo_wms,
 		  wl.cd_produto,
	     wl.cd_endereco,
	     wl.qt_caixa_padrao,
	     wl.nr_lote,
	     wl.dh_validade 
   from dbo.wms_localizacao wl 
  inner join dbo.wms_endereco we on we.cd_endereco = wl.cd_endereco 
  where we.cd_bairro = 'A'
 	 and not exists (select 1
 							 from wms_segregado_recebimento wsr
 							where wl.cd_endereco = wsr.cd_endereco 
							  and wl.cd_produto = wsr.cd_produto 
							  and wl.nr_lote = wsr.nr_lote 
							  and wl.dh_validade = wsr.dh_validade)
union
select wsr.nr_controle, 
	    0 as qt_saldo_wms,
	    wsr.cd_produto,
	    wsr.cd_endereco,
	    1 as qt_caixa_padrao, 
	    wsr.nr_lote,
	    wsr.dh_validade 
  from wms_segregado_recebimento wsr
 inner join dbo.wms_endereco we on we.cd_endereco = wsr.cd_endereco 
  where we.cd_bairro = 'A'
 	 and not exists (select 1
 							 from wms_localizacao wl
 							where wl.cd_endereco = wsr.cd_endereco 
							  and wl.cd_produto = wsr.cd_produto 
							  and wl.nr_lote = wsr.nr_lote 
							  and wl.dh_validade = wsr.dh_validade)" )
