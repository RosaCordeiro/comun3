table(column=(type=datetime updatewhereclause=yes name=dh_emissao dbname="dh_emissao" )
 column=(type=datetime updatewhereclause=yes name=dh_envio_site dbname="dh_envio_site" )
 column=(type=datetime updatewhereclause=yes name=dh_liberacao_agendamento dbname="dh_liberacao_agendamento" )
 column=(type=long updatewhereclause=yes key=yes name=cd_produto dbname="cd_produto" )
 column=(type=decimal(4) updatewhereclause=yes name=qt_tributada dbname="qt_tributada" )
 column=(type=char(60) updatewhereclause=yes name=nm_razao_social dbname="nm_razao_social" )
 column=(type=long updatewhereclause=yes name=nr_pedido_central dbname="nr_pedido_central" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=char(44) updatewhereclause=yes key=yes name=de_chave_acesso dbname="de_chave_acesso" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_desconsidera_rateio dbname="dh_desconsidera_rateio" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_entregue_cd dbname="id_entregue_cd" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_comprador dbname="nr_matricula_comprador" )
 retrieve="SELECT	a.dh_emissao,
			a.dh_envio_site,
			a.dh_liberacao_agendamento,
			ai.cd_produto,
			ai.qt_tributada,
			a.nm_razao_social,
			a.nr_pedido_central,
			a.nr_nf,
			a.de_especie,
			a.de_serie,
			a.de_chave_acesso,
			ai.dh_desconsidera_rateio,
			ai.id_entregue_cd,
			pc.nr_matricula_comprador
FROM	nf_agendamento_ent_item ai
INNER JOIN	nf_agendamento_ent a	ON	ai.de_chave_acesso = a.de_chave_acesso
INNER JOIN	produto_central	pc	ON	pc.cd_produto	= ai.cd_produto
WHERE	ai.id_entregue_cd = :id_entregue
AND	a.dh_liberacao_agendamento between :data_inicio and :data_fim
ORDER BY pc.nr_matricula_comprador
" update="nf_agendamento_ent_item" updatewhere=0 updatekeyinplace=yes arguments=(("id_entregue", string),("data_inicio", date),("data_fim", date)) )
