table(column=(type=long updatewhereclause=yes key=yes name=cd_produto dbname="produto_central.cd_produto" )
 column=(type=char(103) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(3) updatewhereclause=yes name=cd_unidade_medida_compra dbname="produto_geral.cd_unidade_medida_compra" )
 column=(type=char(1) updatewhereclause=yes name=id_lei_generico dbname="produto_geral.id_lei_generico" )
 column=(type=char(1) updatewhereclause=yes name=cd_curva_abc_perini dbname="produto_central.cd_curva_abc_perini" )
 column=(type=char(1) updatewhereclause=yes name=cd_curva_abc_filiais dbname="produto_central.cd_curva_abc_filiais" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor_usual dbname="produto_geral.cd_fornecedor_usual" )
 column=(type=char(95) updatewhereclause=yes name=nm_fornecedor dbname="nm_fornecedor" )
 column=(type=long updatewhereclause=yes name=nr_divisao dbname="fornecedor_divisao_produto.nr_divisao" )
 column=(type=char(49) updatewhereclause=yes name=nm_comprador dbname="nm_comprador" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_cons_agend_saldo_cd_pesc dbname="produto_central.id_cons_agend_saldo_cd_pesc" values="	S/	N" )
 retrieve="SELECT
   pc.cd_produto,
   pg.de_produto + ' : ' + pg.de_apresentacao_estoque AS de_produto,
   pg.cd_unidade_medida_compra,
   pg.id_lei_generico,
   pc.cd_curva_abc_perini,
   pc.cd_curva_abc_filiais,
   pg.cd_fornecedor_usual,
   f.cd_fornecedor + ' - ' + f.nm_fantasia + ' - ' + f.nm_razao_social AS nm_fornecedor,
   fdp.nr_divisao,
   fd.nr_matricula_comprador + ' - ' + u.nm_usuario AS nm_comprador,
	pc.id_cons_agend_saldo_cd_pesc
FROM
    produto_central pc
INNER JOIN
    produto_geral pg
    ON pc.cd_produto = pg.cd_produto
LEFT JOIN
    resumo_estoque_base_filiais bf
    ON bf.cd_produto = pg.cd_produto
INNER JOIN
    fornecedor f
    ON f.cd_fornecedor = pg.cd_fornecedor_usual
INNER JOIN
    fornecedor_divisao fd
    ON f.cd_fornecedor = fd.cd_fornecedor
INNER JOIN
    fornecedor_divisao_produto fdp
    ON fd.cd_fornecedor = fdp.cd_fornecedor
    AND fd.nr_divisao = fdp.nr_divisao
    AND fdp.cd_produto = pg.cd_produto
INNER JOIN
    usuario u
    ON fd.nr_matricula_comprador = u.nr_matricula
WHERE 
    1=1
" update="produto_central" updatewhere=0 updatekeyinplace=no  sort="cd_produto A " )
