 column=(type=char(24) updatewhereclause=yes name=codcargo dbname="vdc_lista_colaboradores.codcargo" )
 column=(type=char(30) updatewhereclause=yes name=descargo dbname="descargo" )
 column=(type=datetime updatewhereclause=yes name=datafa dbname="vdc_lista_colaboradores.datafa" )
 column=(type=decimal(0) updatewhereclause=yes name=sitafa dbname="vdc_lista_colaboradores.sitafa" )
 column=(type=char(30) updatewhereclause=yes name=dessit dbname="dessit" )
 column=(type=decimal(0) updatewhereclause=yes name=tipsit dbname="vdc_lista_colaboradores.tipsit" )
 retrieve="select 	TO_CHAR(matricula) as matricula, 
			nome, 
			datadm, 
			comissao, 
			filial, 
			cbo as cargo_cbo,  
			numcpf,
			codcargo, 
			upper(descargo) as descargo,
			datafa,
			sitafa,
			upper(dessit) as dessit,
			tipsit
from vdc_lista_colaboradores 
where empresa = 1 
	and tipcol = 1 " )
