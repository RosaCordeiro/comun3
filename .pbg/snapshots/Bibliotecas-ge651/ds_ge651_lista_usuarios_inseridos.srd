 retrieve="SELECT	TO_CHAR(matricula) AS nr_matricula,
			nome                       AS nm_usuario,
			comissao,
			filial                      AS cd_filial,
			cbo,
			numcpf,
			codcar				AS cd_cargo,
			idade					AS idade
  FROM vdc_mantem_usuario
ORDER BY 1" )
