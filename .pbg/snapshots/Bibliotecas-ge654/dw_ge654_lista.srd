table(column=(type=long updatewhereclause=yes name=cd_filial dbname="filial.cd_filial" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="filial.nm_fantasia" )
 column=(type=char(40) updatewhereclause=yes name=cd_filial_sap dbname="cd_filial_sap" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="nf_devolucao_venda.dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nf_devolucao_venda.nr_nf" )
 column=(type=long updatewhereclause=yes name=nr_pedido_ecommerce dbname="nf_venda.nr_pedido_ecommerce" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="nf_devolucao_venda.cd_convenio" )
 column=(type=char(60) updatewhereclause=yes name=nm_convenio dbname="convenio.nm_convenio" )
 column=(type=char(15) updatewhereclause=yes name=cd_conveniado dbname="nf_devolucao_venda.cd_conveniado" )
 column=(type=char(40) updatewhereclause=yes name=nm_conveniado dbname="conveniado.nm_conveniado" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="nf_devolucao_venda.vl_total_nf" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="nf_devolucao_venda.dh_cancelamento" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa_venda dbname="nf_venda.dh_movimentacao_caixa_venda" )
 column=(type=long updatewhereclause=yes name=nr_nf_venda dbname="nf_devolucao_venda.nr_nf_venda" )
 column=(type=char(3) updatewhereclause=yes name=de_especie_venda dbname="nf_devolucao_venda.de_especie_venda" )
 column=(type=char(3) updatewhereclause=yes name=de_serie_venda dbname="nf_devolucao_venda.de_serie_venda" )
 column=(type=long updatewhereclause=yes name=nr_lote_convenio dbname="nf_venda.nr_lote_convenio" )
 retrieve="select f.cd_filial,
		f.nm_fantasia,
		(select cd_chave_sap from integracao_sap where cd_empresa = 1000 and cd_tabela = 'FILIAL' and cd_chave_legado = convert(varchar, f.cd_filial)) as cd_filial_sap,
		nd.dh_movimentacao_caixa,
		nd.nr_nf,
		nv.nr_pedido_ecommerce,
		nd.cd_convenio,
		cv.nm_fantasia as nm_convenio,
		nd.cd_conveniado,
		cd.nm_conveniado,
		nd.vl_total_nf,
		nd.dh_cancelamento,
		nv.dh_movimentacao_caixa as dh_movimentacao_caixa_venda,  
		nd.nr_nf_venda,
		nd.de_especie_venda,
		nd.de_serie_venda,
		nv.nr_lote_convenio 
from nf_devolucao_venda nd
	inner join filial f on f.cd_filial = nd.cd_filial 
	inner join nf_venda nv on nv.cd_filial = nd.cd_filial_venda and nv.nr_nf = nd.nr_nf_venda and nv.de_especie = nd.de_especie_venda and nv.de_serie = nd.de_serie_venda 
	inner join convenio cv on cv.cd_convenio = nd.cd_convenio 
	inner join conveniado cd on cd.cd_convenio = nd.cd_convenio and cd.cd_conveniado = nd.cd_conveniado 
Where nd.dh_movimentacao_caixa BETWEEN :pdt_ini and :pdt_fim
and nv.nr_pedido_ecommerce is not null
" arguments=(("pdt_ini", datetime),("pdt_fim", datetime))  sort="dh_movimentacao_caixa A cd_filial A nr_nf A " )
