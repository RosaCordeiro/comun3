table(column=(type=char(9) updatewhereclause=yes name=cd_distribuidora dbname="distribuidora_produto.cd_distribuidora" )
 column=(type=char(2) updatewhereclause=yes name=cd_unidade_federacao dbname="distribuidora_produto.cd_unidade_federacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="fornecedor.nm_razao_social" )
 retrieve="Select Distinct dp.cd_distribuidora, 
		dp.cd_unidade_federacao,
		f.nm_razao_social
From distribuidora_produto dp
Inner Join fornecedor f
	On dp.cd_distribuidora = f.cd_fornecedor 
Inner Join produto_geral pg
	On pg.cd_produto = dp.cd_produto
Inner Join cidade c
	On c.cd_unidade_federacao = dp.cd_unidade_federacao 
Inner Join vw_filial fi
	On fi.cd_cidade = c.cd_cidade 
Inner Join filial_distribuidora fd
	On fd.cd_filial = fi.cd_filial
	And fd.cd_distribuidora = f.cd_fornecedor
Inner Join distribuidora_uf du
	On du.cd_distribuidora = f.cd_fornecedor
	And c.cd_unidade_federacao = du.cd_unidade_federacao
Where f.id_distribuidora = 'S'
	And f.id_situacao = 'A'
	And pg.id_situacao = 'A'
	And fd.id_situacao = 'A'
	And coalesce(f.id_arquivo_preco_diario, 'S') = 'S'
	And Not Exists (Select * From controle_arquivo_preco_distrib capd 
							Where Cast(capd.dh_arquivo  as Date) = (Select par.dh_movimentacao From parametro par Where id_parametro = '1')
							And capd.cd_distribuidora = dp.cd_distribuidora
							And capd.cd_uf = dp.cd_unidade_federacao)
Order By dp.cd_distribuidora" )
