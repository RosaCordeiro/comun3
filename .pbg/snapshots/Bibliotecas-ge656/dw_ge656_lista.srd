table(column=(type=char(3) updatewhereclause=yes name=id_tipo_conta dbname="id_tipo_conta" values="CONTA CORRENTE	CC/CREDI$$HEX1$$c100$$ENDHEX$$RIO	CR/CONV$$HEX1$$ca00$$ENDHEX$$NIO	CV/FORNECEDOR	FO/LUCROS E PERDAS	LP/PATRIM$$HEX1$$d400$$ENDHEX$$NIO	PT/VERBA	VB/" )
 column=(type=char(11) updatewhereclause=yes name=cd_conta dbname="contas_receber_movimento.cd_conta" )
 column=(type=char(20) updatewhereclause=yes name=cd_cliente_sap dbname="cd_cliente_sap" )
 column=(type=char(60) updatewhereclause=yes name=nm_cliente dbname="nm_cliente" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_movimento dbname="contas_receber_tipo_movimento.de_tipo_movimento" )
 column=(type=datetime updatewhereclause=yes name=dh_movimento dbname="contas_receber_movimento.dh_movimento" )
 column=(type=datetime updatewhereclause=yes name=dh_sistema dbname="contas_receber_movimento.dh_sistema" )
 column=(type=char(1) updatewhereclause=yes name=id_credito_debito dbname="contas_receber_tipo_movimento.id_credito_debito" values="CR$$HEX1$$c900$$ENDHEX$$DITO	C/D$$HEX1$$c900$$ENDHEX$$BITO	D/" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_movimento dbname="contas_receber_movimento.vl_movimento" )
 column=(type=char(30) updatewhereclause=yes name=nr_documento dbname="contas_receber_movimento.nr_documento" )
 column=(type=char(40) updatewhereclause=yes name=de_historico dbname="contas_receber_movimento.de_historico" )
 column=(type=char(1) updatewhereclause=yes name=id_atualizacao_saldo dbname="contas_receber_tipo_movimento.id_atualizacao_saldo" values="ATUALIZA SALDO	1/ATUALIZA T$$HEX1$$cd00$$ENDHEX$$TULO	2/OUTROS	3/" )
 retrieve="select 	Case when (nd.nr_nf is null and j_1bnfdoc.nr_nf is null) then 
				Case when t.nr_conta_sap='0011201067' or m.id_tipo_lancto='1' Then 
					'VB'
				Else m.id_tipo_conta end
			else 'PT' end as id_tipo_conta, 
			m.cd_conta, 
			coalesce(cl.cd_cliente_sap, cv.cd_cliente_sap) as cd_cliente_sap,
			coalesce(cv.nm_fantasia, cl.nm_cliente) as nm_cliente, 
			tm.de_tipo_movimento, 
			m.dh_movimento,
			m.dh_sistema,
			tm.id_credito_debito,
			m.vl_movimento,
			m.nr_documento,
			m.de_historico,
			tm.id_atualizacao_saldo
from contas_receber_movimento m 
inner join contas_receber_tipo_movimento tm
	on tm.cd_tipo_movimento = m.cd_tipo_movimento
left outer join convenio cv
	on cv.cd_convenio = case when m.id_tipo_conta = 'CV' then cast(m.cd_conta as integer) else null end
	and m.id_tipo_conta = 'CV'
left outer join titulo_receber t
	on m.id_tipo_conta = 'CR'
	and t.nr_titulo = substring(m.nr_documento,1,4)||substring(m.nr_documento,6,7)||substring(m.nr_documento,14,2)
left outer join nf_diversa nd
	on nd.cd_filial_origem = t.cd_filial_nf
	and nd.nr_nf = t.nr_nf
	and nd.de_serie = t.de_serie
	and nd.de_especie = t.de_especie
left outer join (
	select 
		cast(isap.cd_chave_legado as integer) cd_filial_origem,
		j1.nfnum as nr_nf,
		'NFE' de_especie,
		j2.series as de_serie
	from j_1bnfdoc_1 j1
		inner join j_1bnfdoc_2 j2
			on j2.mandt = j1.mandt 
			and j2.docnum = j1.docnum 
			and j2.nr_sequencial = j1.nr_sequencial
			and j2.nftype = 'ZL' /* Venda de Ativo */
		inner join integracao_sap isap
			on isap.cd_empresa = 1000
			and isap.cd_tabela = 'FILIAL'
			and isap.cd_chave_sap = j1.branch
) as j_1bnfdoc
	on j_1bnfdoc.cd_filial_origem = t.cd_filial_nf
	and j_1bnfdoc.nr_nf = t.nr_nf
	and j_1bnfdoc.de_serie = t.de_serie
	and j_1bnfdoc.de_especie = t.de_especie
left outer join cliente cl
	on cl.cd_cliente = m.cd_conta
	and m.id_tipo_conta <> 'CV'"  sort="dh_sistema A " )
