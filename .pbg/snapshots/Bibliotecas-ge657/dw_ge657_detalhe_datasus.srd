table(column=(type=decimal(0) updatewhereclause=yes key=yes name=cd_registro dbname="fpb_datasus_consolidado.cd_registro" )
 column=(type=char(50) updatewhereclause=yes name=nr_autorizacao dbname="fpb_datasus_consolidado.nr_autorizacao" )
 column=(type=char(20) updatewhereclause=yes name=nr_cupom dbname="fpb_datasus_consolidado.nr_cupom" )
 column=(type=char(14) updatewhereclause=yes name=nr_cpf dbname="fpb_datasus_consolidado.nr_cpf" )
 column=(type=datetime updatewhereclause=yes name=dh_autorizacao dbname="fpb_datasus_consolidado.dh_autorizacao" )
 column=(type=char(50) updatewhereclause=yes name=de_ean dbname="fpb_datasus_consolidado.de_ean" )
 column=(type=long updatewhereclause=yes name=qt_autorizada dbname="fpb_datasus_consolidado.qt_autorizada" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_venda dbname="fpb_datasus_consolidado.vl_venda" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_ms dbname="fpb_datasus_consolidado.vl_ms" )
 column=(type=char(4) updatewhereclause=yes name=id_status dbname="fpb_datasus_consolidado.id_status" )
 retrieve="select d.cd_registro,
		d.nr_autorizacao,
		d.nr_cupom,
		d.nr_cpf,
		d.dh_autorizacao,
		d.cd_ean_produto as de_ean,
		d.qt_autorizada,
		d.vl_venda,
		d.vl_ms,
		d.id_status
from dbo.fpb_datasus_consolidado d
where d.cd_filial = :pl_filial
	and d.nr_autorizacao = :ps_autorizacao" update="fpb_datasus_consolidado" updatewhere=0 updatekeyinplace=no arguments=(("pl_filial", number),("ps_autorizacao", string)) )
