table(column=(type=char(2) updatewhereclause=yes name=de_conciliacao dbname="de_conciliacao" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_nf dbname="nr_nf" )
 column=(type=char(3) updatewhereclause=yes name=de_especie dbname="de_especie" )
 column=(type=char(3) updatewhereclause=yes name=de_serie dbname="de_serie" )
 column=(type=datetime updatewhereclause=yes name=dh_movimentacao_caixa dbname="dh_movimentacao_caixa" )
 column=(type=long updatewhereclause=yes name=cd_convenio_venda dbname="cd_convenio_venda" )
 column=(type=char(50) updatewhereclause=yes name=nr_autorizacao_datasus dbname="nr_autorizacao_datasus" )
 column=(type=char(20) updatewhereclause=yes name=nr_cartao dbname="nr_cartao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_pago_avista dbname="vl_pago_avista" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total_nf dbname="vl_total_nf" )
 column=(type=long updatewhereclause=yes name=cd_convenio dbname="cd_convenio" )
 column=(type=char(60) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nf_nr_lote_convenio dbname="nr_lote_convenio" )
 column=(type=datetime updatewhereclause=yes name=dh_cancelamento dbname="dh_cancelamento" )
 column=(type=datetime updatewhereclause=yes name=dh_devolucao dbname="dh_devolucao" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_prev_pagto dbname="vl_prev_pagto" )
 column=(type=long updatewhereclause=yes name=nr_sequencial_pbm dbname="nr_sequencial_pbm" )
 retrieve="SELECT	'OK' as de_conciliacao, --Encontrou nota valida e autorizacao ativa
		nf.cd_filial,   
		nf.nr_nf,   
		nf.de_especie,   
		nf.de_serie,   
		nf.dh_movimentacao_caixa,   
		nf.cd_convenio as cd_convenio_venda,
     	vp.nr_autorizacao_datasus, 
		vp.nr_cartao,
		nf.pc_desconto,     
		nf.vl_pago_avista,
		nf.vl_total_nf,
		cv.cd_convenio,
		cv.nm_fantasia,
		nf.nr_lote_convenio, 
		nf.dh_cancelamento,
		nf.dh_devolucao,
		nf.vl_total_nf - nf.vl_pago_avista AS vl_prev_pagto, --PAGO PBM
		vp.nr_sequencial_pbm		
FROM dbo.venda_pbm vp (index idx_fil_dt_conv)
INNER JOIN dbo.nf_venda nf (index pk_nf_venda)
	on 	nf.cd_filial 		= vp.cd_filial+0
	and 	nf.nr_nf 			= vp.nr_nf+0
	and	nf.de_especie 	= vp.de_especie 
	and	nf.de_serie 		= vp.de_serie 
INNER JOIN dbo.convenio cv (index pk_convenio)
	on cv.cd_convenio 	= vp.cd_convenio 
WHERE vp.dh_venda between :dt_inicio and :dt_fim
    and nf.nr_nf_anexa is null
	--and vp.cd_convenio_pbm = 'CT000160'
	--and vp.nr_comprovante_venda = 'AVFARPOP'
	--and vp.cd_convenio_pbm = '55102'
	and vp.cd_convenio = 55102
	and (nf.dh_cancelamento is NULL and nf.dh_devolucao is null)
	and exists (select fpb.cd_registro from dbo.fpb_datasus_consolidado fpb 
				where fpb.cd_filial = vp.cd_filial 
					and fpb.nr_autorizacao = vp.nr_autorizacao_datasus
				    and CAST(fpb.dh_autorizacao AS date) = CAST(vp.dh_venda AS date)
					and fpb.id_status = '00RV')
	and not exists (select fpb.cd_registro from dbo.fpb_datasus_consolidado fpb 
				where fpb.cd_filial = vp.cd_filial 
					and fpb.nr_autorizacao = vp.nr_autorizacao_datasus
				    and CAST(fpb.dh_autorizacao AS date) = CAST(vp.dh_venda AS date)
					and fpb.id_status = 'EST')
					
UNION ALL					
					
SELECT	'OK' as de_conciliacao, --encontrou nota cancelada/devolvida e autorizacao cancelada
		nf.cd_filial,   
		nf.nr_nf,   
		nf.de_especie,   
		nf.de_serie,   
		nf.dh_movimentacao_caixa,   
		nf.cd_convenio as cd_convenio_venda,
     	vp.nr_autorizacao_datasus, 
		vp.nr_cartao,
		nf.pc_desconto,     
		nf.vl_pago_avista,
		nf.vl_total_nf,
		cv.cd_convenio,
		cv.nm_fantasia,
		nf.nr_lote_convenio, 
		nf.dh_cancelamento,
		nf.dh_devolucao,
		nf.vl_total_nf - nf.vl_pago_avista AS vl_prev_pagto, --PAGO PBM
		vp.nr_sequencial_pbm		
FROM dbo.venda_pbm vp (index idx_fil_dt_conv)
INNER JOIN dbo.nf_venda nf (index pk_nf_venda)
	on 	nf.cd_filial 		= vp.cd_filial+0
	and 	nf.nr_nf 			= vp.nr_nf+0
	and	nf.de_especie 	= vp.de_especie 
	and	nf.de_serie 		= vp.de_serie 
INNER JOIN dbo.convenio cv (index pk_convenio)
	on cv.cd_convenio 	= vp.cd_convenio 
WHERE vp.dh_venda between :dt_inicio and :dt_fim
    and nf.nr_nf_anexa is null
--	and vp.cd_convenio_pbm = 'CT000160'
--	and vp.nr_comprovante_venda = 'AVFARPOP'
--	and vp.cd_convenio_pbm = '55102'
	and vp.cd_convenio = 55102
	and (nf.dh_cancelamento <> null or nf.dh_devolucao <> null)
	and exists (select fpb.cd_registro from dbo.fpb_datasus_consolidado fpb 
				where fpb.cd_filial = vp.cd_filial 
					and fpb.nr_autorizacao = vp.nr_autorizacao_datasus
				    and CAST(fpb.dh_autorizacao AS date) = CAST(vp.dh_venda AS date)
					and fpb.id_status = 'EST')
								
UNION ALL					
					
SELECT	'SV' as de_conciliacao, --SOMENTE VENDA NAO CANC/DEVOLVIDA E SEM AUT.DATASUS
		nf.cd_filial,   
		nf.nr_nf,   
		nf.de_especie,   
		nf.de_serie,   
		nf.dh_movimentacao_caixa,   
		nf.cd_convenio as cd_convenio_venda,
     	vp.nr_autorizacao_datasus, 
		vp.nr_cartao,
		nf.pc_desconto,     
		nf.vl_pago_avista,
		nf.vl_total_nf,
		cv.cd_convenio,
		cv.nm_fantasia,
		nf.nr_lote_convenio,
		nf.dh_cancelamento,
		nf.dh_devolucao,		
		nf.vl_total_nf - nf.vl_pago_avista AS vl_prev_pagto, 
		vp.nr_sequencial_pbm		 
FROM dbo.venda_pbm vp (index idx_fil_dt_conv)
INNER JOIN dbo.nf_venda nf (index pk_nf_venda)
	on 	nf.cd_filial 		= vp.cd_filial+0
	and 	nf.nr_nf 			= vp.nr_nf+0
	and	nf.de_especie 	= vp.de_especie 
	and	nf.de_serie 		= vp.de_serie 
INNER JOIN dbo.convenio cv (index pk_convenio)
	on cv.cd_convenio 	= vp.cd_convenio 
WHERE vp.dh_venda between :dt_inicio and :dt_fim
    and nf.nr_nf_anexa is null
--	and vp.cd_convenio_pbm = 'CT000160'
--	and vp.nr_comprovante_venda = 'AVFARPOP'
--	and vp.cd_convenio_pbm = '55102'
	and vp.cd_convenio = 55102
	and (nf.dh_cancelamento is NULL and nf.dh_devolucao is null)
	and not exists (select fpb.cd_registro from dbo.fpb_datasus_consolidado fpb 
				where fpb.cd_filial = vp.cd_filial 
					and fpb.nr_autorizacao = vp.nr_autorizacao_datasus
					and CAST(fpb.dh_autorizacao AS date) = CAST(vp.dh_venda AS date) 
					and fpb.id_status = '00RV')

UNION ALL

SELECT	'SV' as de_conciliacao, --SOMENTE VENDA CANC/DEVOLVIDA E SEM AUT.DATASUS
		nf.cd_filial,   
		nf.nr_nf,   
		nf.de_especie,   
		nf.de_serie,   
		nf.dh_movimentacao_caixa,   
		nf.cd_convenio as cd_convenio_venda,
     	vp.nr_autorizacao_datasus, 
		vp.nr_cartao,
		nf.pc_desconto,     
		nf.vl_pago_avista,
		nf.vl_total_nf,
		cv.cd_convenio,
		cv.nm_fantasia,
		nf.nr_lote_convenio,
		nf.dh_cancelamento,
		nf.dh_devolucao,		
		nf.vl_total_nf - nf.vl_pago_avista AS vl_prev_pagto, 
		vp.nr_sequencial_pbm		 
FROM dbo.venda_pbm vp (index idx_fil_dt_conv)
INNER JOIN dbo.nf_venda nf (index pk_nf_venda)
	on 	nf.cd_filial 		= vp.cd_filial+0
	and 	nf.nr_nf 			= vp.nr_nf+0
	and	nf.de_especie 	= vp.de_especie 
	and	nf.de_serie 		= vp.de_serie 
INNER JOIN dbo.convenio cv (index pk_convenio)
	on cv.cd_convenio 	= vp.cd_convenio 
WHERE vp.dh_venda between :dt_inicio and :dt_fim
    and nf.nr_nf_anexa is null
--	and vp.cd_convenio_pbm = 'CT000160'
--	and vp.nr_comprovante_venda = 'AVFARPOP'
--	and vp.cd_convenio_pbm = '55102'
	and vp.cd_convenio = 55102
	and (nf.dh_cancelamento is not NULL or nf.dh_devolucao is not null)
	and not exists (select fpb.cd_registro from dbo.fpb_datasus_consolidado fpb 
				where fpb.cd_filial = vp.cd_filial 
					and fpb.nr_autorizacao = vp.nr_autorizacao_datasus
					and CAST(fpb.dh_autorizacao AS date) = CAST(vp.dh_venda AS date) 
					and fpb.id_status = '00RV')
	and exists (select vpp.nr_nf from dbo.venda_pbm_produto vpp 
				where vpp.cd_filial = vp.cd_filial 
					and vpp.nr_nf = vp.nr_nf 
					and vpp.de_especie = vp.de_especie 
					and vpp.de_serie = vp.de_serie
					and vpp.nr_sequencial_pbm = vp.nr_sequencial_pbm)

UNION ALL

SELECT	'CA' as de_conciliacao, -- VENDA CANCELADA/DEVOLVIDA E AUT. ATIVA
		nf.cd_filial,   
		nf.nr_nf,   
		nf.de_especie,   
		nf.de_serie,   
		nf.dh_movimentacao_caixa,   
		nf.cd_convenio as cd_convenio_venda,
     	vp.nr_autorizacao_datasus, 
		vp.nr_cartao,
		nf.pc_desconto,     
		nf.vl_pago_avista,
		nf.vl_total_nf,
		cv.cd_convenio,
		cv.nm_fantasia,
		nf.nr_lote_convenio,
		nf.dh_cancelamento,
		nf.dh_devolucao,		
		nf.vl_total_nf - nf.vl_pago_avista AS vl_prev_pagto, 
		vp.nr_sequencial_pbm		 
FROM dbo.venda_pbm vp (index idx_fil_dt_conv)
INNER JOIN dbo.nf_venda nf (index pk_nf_venda)
	on 	nf.cd_filial 		= vp.cd_filial+0
	and 	nf.nr_nf 			= vp.nr_nf+0
	and	nf.de_especie 	= vp.de_especie 
	and	nf.de_serie 		= vp.de_serie 
INNER JOIN dbo.convenio cv (index pk_convenio)
	on cv.cd_convenio 	= vp.cd_convenio 
WHERE vp.dh_venda between :dt_inicio and :dt_fim
    and nf.nr_nf_anexa is null
--	and vp.cd_convenio_pbm = 'CT000160'
--	and vp.nr_comprovante_venda = 'AVFARPOP'
--	and vp.cd_convenio_pbm = '55102'
	and vp.cd_convenio = 55102
	and (nf.dh_cancelamento <> null or nf.dh_devolucao <> null)	
	and exists (select fpb.cd_registro from dbo.fpb_datasus_consolidado fpb 
				where fpb.cd_filial = vp.cd_filial 
					and fpb.nr_autorizacao = vp.nr_autorizacao_datasus
					and CAST(fpb.dh_autorizacao AS date) = CAST(vp.dh_venda AS date) 
					and fpb.id_status = '00RV')
	and not exists (select fpb.cd_registro from dbo.fpb_datasus_consolidado fpb 
				where fpb.cd_filial = vp.cd_filial 
					and fpb.nr_autorizacao = vp.nr_autorizacao_datasus
				    and CAST(fpb.dh_autorizacao AS date) = CAST(vp.dh_venda AS date)
					and fpb.id_status = 'EST')
	and exists (select vpp.nr_nf from dbo.venda_pbm_produto vpp 
				where vpp.cd_filial = vp.cd_filial 
					and vpp.nr_nf = vp.nr_nf 
					and vpp.de_especie = vp.de_especie 
					and vpp.de_serie = vp.de_serie
					and vpp.nr_sequencial_pbm = vp.nr_sequencial_pbm)
					
UNION ALL

SELECT	'SD' as de_conciliacao, --SOMENTE DATASUS ativa
		fpb.cd_filial,   		
		coalesce(cast(fpb.nr_cupom as int),0) as nr_nf,   
		'' as de_especie,   
		'' as de_serie,   
		fpb.dh_autorizacao as dh_movimentacao_caixa,   
		52575 as cd_convenio_venda,
		fpb.nr_autorizacao as nr_autorizacao_datasus,
		fpb.nr_cpf as nr_cartao,
		0 as pc_desconto,     
		0 as vl_pago_avista,
		CAST(fpb.vl_ms AS DECIMAL(10, 2)) as vl_total_nf,
		52575 as cd_convenio,
		'FARMACIA POPULAR - DATASUS' AS nm_fantasia,
		null as nr_lote_convenio,
		null AS dh_cancelamento,
		null AS dh_devolucao,
		CAST(fpb.vl_ms AS DECIMAL(10, 2)) as vl_prev_pagto, 
		0 as nr_sequencial_pbm		
FROM dbo.fpb_datasus_consolidado fpb
WHERE  cast(fpb.dh_autorizacao as date) between :dt_inicio and :dt_fim
	and fpb.id_status = '00RV'  --SE NAO TEM VENDA, O QUE ESTA ESTORNADO NO DATASUS NAO E LISTADO
	and not exists (select vp.nr_nf from dbo.venda_pbm vp
				where fpb.cd_filial = vp.cd_filial 
					and fpb.nr_autorizacao = vp.nr_autorizacao_datasus
					and CAST(fpb.dh_autorizacao AS date) = CAST(vp.dh_venda AS date))" arguments=(("dt_inicio", date),("dt_fim", date))  sort="dh_movimentacao_caixa A cd_filial A " )
