table(column=(type=long updatewhereclause=yes name=cd_filial dbname="pedido_empurrado.cd_filial" dbalias="a.cd_filial" )
 column=(type=long updatewhereclause=yes name=nr_pedido_empurrado dbname="pedido_empurrado.nr_pedido_empurrado" dbalias="a.nr_pedido_empurrado" )
 column=(type=char(1) update=yes updatewhereclause=yes name=id_processado dbname="pedido_empurrado.id_processado" dbalias="a.id_processado" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="pedido_empurrado_produto.cd_produto" dbalias="b.cd_produto" )
 column=(type=long updatewhereclause=yes name=qt_empurrada dbname="pedido_empurrado_produto.qt_empurrada" dbalias="b.qt_empurrada" )
 column=(type=long updatewhereclause=yes name=qt_aprovada dbname="pedido_empurrado_produto.qt_aprovada" dbalias="b.qt_aprovada" )
 column=(type=long updatewhereclause=yes name=qt_faturada dbname="qt_faturada" )
 retrieve="Select a.cd_filial,
		a.nr_pedido_empurrado,
		a.id_processado,
       	b.cd_produto,
       	b.qt_empurrada,
       	b.qt_aprovada,
       	coalesce(b.qt_faturada,0) as qt_faturada
From pedido_empurrado_produto b
Inner Join pedido_empurrado a
	On a.cd_filial           = b.cd_filial
	And a.nr_pedido_empurrado = b.nr_pedido_empurrado
Inner Join produto_central c
	On c.cd_produto          = b.cd_produto
Inner Join produto_geral g
	On g.cd_produto          = b.cd_produto
Where b.id_situacao = 'C'
  And coalesce(id_reserva_saldo_cd, 'N') = 'N'
  And a.dh_cancelamento is null   
  And a.cd_distribuidora is null
  And coalesce(b.id_ecommerce, 'N') = 'N'
  And coalesce(b.dh_aprovacao,a.dh_inclusao) < :dh_atendimento
  And (b.qt_aprovada - b.qt_faturada - (Select coalesce(sum(y.qt_atendida), 0)
														From pedido_distribuidora x
														Inner Join pedido_distribuidora_produto y
																On y.cd_filial = x.cd_filial
																And y.nr_pedido_distribuidora = x.nr_pedido_distribuidora
														Where x.cd_filial = a.cd_filial
														And y.cd_produto = b.cd_produto
														And x.id_situacao in ('C', 'S'))) > 0									
Order by a.cd_filial DESC" arguments=(("dh_atendimento", datetime)) )
