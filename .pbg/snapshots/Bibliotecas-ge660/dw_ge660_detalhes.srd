table(column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="nm_fantasia" )
 column=(type=long updatewhereclause=yes name=nr_pedido dbname="nr_pedido" )
 column=(type=char(20) updatewhereclause=yes name=nr_pedido_ecommerce dbname="nr_pedido_ecommerce" )
 column=(type=char(2) updatewhereclause=yes name=id_rede_ecommerce dbname="id_rede_ecommerce" )
 column=(type=char(9) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 column=(type=datetime updatewhereclause=yes name=dh_compra dbname="dh_compra" )
 column=(type=datetime updatewhereclause=yes name=dh_faturado dbname="dh_faturado" )
 column=(type=datetime updatewhereclause=yes name=dh_entrega dbname="dh_entrega" )
 column=(type=decimal(2) updatewhereclause=yes name=vl_total dbname="vl_total" )
 column=(type=decimal(17) updatewhereclause=yes name=vl_repasse dbname="vl_repasse" )
 column=(type=decimal(6) updatewhereclause=yes name=valor_taxa dbname="valor_taxa" )
 column=(type=decimal(2) updatewhereclause=yes name=valor_split dbname="valor_split" )
 column=(type=date updatewhereclause=yes name=p_dh_inicio dbname="p_dh_inicio" )
 column=(type=date updatewhereclause=yes name=p_dh_fim dbname="p_dh_fim" )
 column=(type=decimal(17) updatewhereclause=yes name=vl_repasse_liquido dbname="vl_repasse_liquido" )
 retrieve="select Aux.*,  
		Aux.vl_repasse - Aux.valor_taxa - valor_split as vl_repasse_liquido
From
(
select f.cd_fornecedor,
		f.nm_fantasia, 
		pe.nr_pedido,
		pe.nr_pedido_ecommerce,
		pa.id_rede_ecommerce,
		pe.id_situacao,
		pe.dh_compra,
		pe.dh_faturado,
		pe.dh_entrega,
		pe.vl_total,
		ROUND(SUM((pp.pc_comissao/100) * pp.vl_preco_promocao * pp.qt_pedida) , 2) as vl_repasse,
		Round(dbo.retorna_valor_comissao_cartao(pe.dh_compra, cp.cd_conta_fluxo_caixa, pe.nr_parcelas, pe.vl_total, null, 'C', pe.nr_pedido),2) as valor_taxa,
		(select convert(decimal(5,2), vl_parametro) from parametro_geral where cd_parametro = 'VL_SPLIT_PAGAMENTO_TUNA') as valor_split,
		Convert(date,:pdh_ini) as p_dh_inicio,
		Convert(date,:pdh_fim) as p_dh_fim
from pedido_ecommerce pe
	inner join pedido_ecommerce_auxiliar pa on pa.cd_filial_ecommerce = pe.cd_filial_ecommerce and pa.nr_pedido = pe.nr_pedido 
	inner join fornecedor f on f.cd_fornecedor = pa.cd_fornecedor_entrega 
	inner join pedido_ecommerce_produto pp on pp.cd_filial_ecommerce = pe.cd_filial_ecommerce and pp.nr_pedido = pe.nr_pedido
	inner join tipo_pagamento_ecommerce te on te.nm_administradora_cartao = pa.nm_administradora_cartao  
	inner join dbo.cartao_produto cp on cp.nm_produto = te.nm_administradora_cartao 	
Where pe.id_ecommerce = '2' 
and pe.dh_compra BETWEEN :pdh_ini and :pdh_fim
and pa.id_tipo_pedido in ('PRP','DRC', 'FRM')
and pa.cd_fornecedor_entrega = :ps_cd_fornecedor
group by f.cd_fornecedor,
		f.nm_fantasia,
		pe.nr_pedido,
		pe.nr_pedido_ecommerce,
		pa.id_rede_ecommerce,
		pe.id_situacao,
		pe.dh_compra,
		pe.dh_faturado,
		pe.dh_entrega,
		pe.vl_total,
		Round(dbo.retorna_valor_comissao_cartao(pe.dh_compra, cp.cd_conta_fluxo_caixa, pe.nr_parcelas, pe.vl_total, null, 'C', pe.nr_pedido),2)
) Aux	" arguments=(("pdh_ini", datetime),("pdh_fim", datetime),("ps_cd_fornecedor", string)) )
