table(column=(type=long updatewhereclause=yes name=cd_produto_central dbname="produto_central.cd_produto" dbalias="pc.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" dbalias="pg.de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="produto_geral.de_apresentacao_venda" dbalias="pg.de_apresentacao_venda" )
 column=(type=long updatewhereclause=yes name=nr_embalagem_padrao dbname="produto_geral.nr_embalagem_padrao" dbalias="pg.nr_embalagem_padrao" )
 column=(type=char(20) updatewhereclause=yes name=de_codigo_barras dbname="produto_geral.de_codigo_barras" dbalias="pg.de_codigo_barras" )
 column=(type=long updatewhereclause=yes name=cd_filial dbname="cd_filial" )
