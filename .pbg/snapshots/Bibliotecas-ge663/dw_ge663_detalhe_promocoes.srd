 column=(type=long updatewhereclause=yes name=cd_promocao dbname="cd_promocao" )
 column=(type=char(1) updatewhereclause=yes name=de_apresentacao_venda_produto_desconto dbname="de_apresentacao_venda_produto_desconto" )
 column=(type=char(1) updatewhereclause=yes name=de_frase_informativa_produto_desconto dbname="de_frase_informativa_produto_desconto" )
 column=(type=char(1) updatewhereclause=yes name=de_resumida_produto_desconto dbname="de_resumida_produto_desconto" )
 column=(type=char(1) updatewhereclause=yes name=dt_vigencia_final dbname="dt_vigencia_final" )
 column=(type=char(1) updatewhereclause=yes name=dt_vigencia_inicial dbname="dt_vigencia_inicial" )
 column=(type=char(1) updatewhereclause=yes name=id_exibe_frase_informativa dbname="id_exibe_frase_informativa" )
 column=(type=char(1) updatewhereclause=yes name=id_exibe_frase_informativa_produto_desconto dbname="id_exibe_frase_informativa_produto_desconto" )
 column=(type=char(1) updatewhereclause=yes name=de_gtin dbname="de_gtin" )
 column=(type=char(1) updatewhereclause=yes name=de_gtin_produto_desconto dbname="de_gtin_produto_desconto" )
 column=(type=long updatewhereclause=yes name=ce_gtin_produto_desconto dbname="" )
 column=(type=long updatewhereclause=yes name=pc_desconto dbname="pc_desconto" )
 column=(type=long updatewhereclause=yes name=qt_compre dbname="qt_compre" )
 column=(type=long updatewhereclause=yes name=qt_itens dbname="qt_itens" )
 column=(type=long updatewhereclause=yes name=qt_leve dbname="qt_leve" )
 column=(type=long updatewhereclause=yes name=qt_pague dbname="qt_pague" )
 column=(type=long updatewhereclause=yes name=qt_produto_desconto dbname="qt_produto_desconto" )
 column=(type=long updatewhereclause=yes name=ct_produto_desconto dbname="" )
 column=(type=long updatewhereclause=yes name=vl_preco_atacado dbname="vl_preco_atacado" )
 column=(type=long updatewhereclause=yes name=cl_preco_atacado dbname="" )
 column=(type=long updatewhereclause=yes name=vl_preco_regular dbname="vl_preco_regular" )
 column=(type=long updatewhereclause=yes name=cl_preco_regular dbname="" )
 column=(type=long updatewhereclause=yes name=vl_preco_unitario dbname="vl_preco_unitario" )
 retrieve="Select	pc.cd_produto,
			pg.de_produto,
			pg.de_apresentacao_venda,
			pg.nr_embalagem_padrao,
			pg.de_codigo_barras,
			0 as cd_filial,
			0 as cd_preco_grupo,
			0 as cd_produto,
			0 as cd_produto_desconto,
			0 as cd_promocao,
			'' as de_apresentacao_venda_produto_desconto,
			'' as de_frase_informativa_produto_desconto,
			'' as de_resumida_produto_desconto,
			'' as dt_vigencia_final,
			'' as dt_vigencia_inicial,
			'' as id_exibe_frase_informativa,
			'' as id_exibe_frase_informativa_produto_desconto,
			'' as de_gtin,
			'' as de_gtin_produto_desconto,
			0,00 as pc_desconto,
			0 as qt_compre,
			0 as qt_itens,
			0 as qt_leve,
			0 as qt_pague,
			0 as qt_produto_desconto,
			0,00 as vl_preco_atacado,
			0,00 as vl_preco_regular,
			0,00 as vl_preco_unitario
From produto_geral As pg
	Inner Join produto_central As pc
		On pc.cd_produto = pg.cd_produto
	Left Outer Join fabricante As fa
		On fa.cd_fabricante = pg.cd_fabricante
	Left Outer Join fornecedor As fo
		On fo.cd_fornecedor = pg.cd_fornecedor_usual
	Left Outer Join vw_classificacao_produto As cp
		On cp.cd_subcategoria = pg.cd_subcategoria
	Left Outer Join marca_produto As mp
		On mp.cd_marca = pg.cd_marca
	Left Outer Join dcb_produto As dcb
		On dcb.cd_dcb = pg.cd_dcb
	Left Outer Join grupo_alteracao_preco As gap
		On gap.cd_grupo = pc.cd_grupo_alteracao_preco
	Left Outer Join marca_ecommerce As me
		On me.cd_marca = pg.cd_marca_ecommerce
	Left Outer Join usuario As us
		On us.nr_matricula = pc.nr_matric_solicitacao_alt_sit
	Left Outer Join categoria_ecommerce As ce
		On ce.cd_categoria = pc.cd_categoria_ecommerce
	Left Outer Join segmento_ims As si
		On si.cd_segmento = pc.cd_segmento_ims 
	Left Outer Join area_farmacia As af
		On af.cd_area_farmacia = pg.cd_area_farmacia 
	Left Outer Join tarja As tj 
		On tj.cd_tarja = pg.cd_tarja 
	Left Outer Join cronicidade As cr 
		On cr.cd_cronicidade = pg.cd_cronicidade 
	Left Outer Join grupo_mercadorias As gm 
		On gm.cd_grupo  = pg.cd_grupo_mercadoria_sap 	
Where pg.cd_produto = :produto" arguments=(("produto", number)) )
