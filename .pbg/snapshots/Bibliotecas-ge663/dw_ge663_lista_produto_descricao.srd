table(column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="produto_geral.de_produto" )
 column=(type=char(100) updatewhereclause=yes name=de_produto_primaria dbname="produto_central.de_produto_primaria" )
 column=(type=char(100) updatewhereclause=yes name=de_produto_secundaria dbname="produto_central.de_produto_secundaria" )
 column=(type=char(140) updatewhereclause=yes name=de_texto_legal dbname="produto_central.de_texto_legal" )
 column=(type=long updatewhereclause=yes name=cd_texto_min_saude dbname="produto_central.cd_texto_min_saude" )
 column=(type=char(1) updatewhereclause=yes name=id_permite_publicidade dbname="produto_central.id_permite_publicidade" )
 column=(type=char(1) updatewhereclause=yes name=id_publi_obriga_texto_legal dbname="produto_central.id_publi_obriga_texto_legal" )
 column=(type=char(1) updatewhereclause=yes name=id_lib_marketing_externo dbname="produto_central.id_lib_marketing_externo" )
 column=(type=char(1) updatewhereclause=yes name=id_lib_marketing_interno dbname="produto_central.id_lib_marketing_interno" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="produto_geral.id_situacao" )
 retrieve="Select
	pg.cd_produto,
	pg.de_produto,
	pc.de_produto_primaria,
	pc.de_produto_secundaria,
	pc.de_texto_legal,
	pc.cd_texto_min_saude,
	pc.id_permite_publicidade,
	pc.id_publi_obriga_texto_legal,
	pc.id_lib_marketing_externo,
	pc.id_lib_marketing_interno,
	pg.id_situacao
From 
	produto_geral As pg
Inner Join 
	produto_central As pc
	On pc.cd_produto = pg.cd_produto
Left Outer Join 
	fabricante As fa
	On fa.cd_fabricante = pg.cd_fabricante
Left Outer Join 
	fornecedor As fo
	On fo.cd_fornecedor = pg.cd_fornecedor_usual
Left Outer Join 
	vw_classificacao_produto As cp
	On cp.cd_subcategoria = pg.cd_subcategoria
Left Outer Join 
	marca_produto As mp
	On mp.cd_marca = pg.cd_marca
Left Outer Join 
	dcb_produto As dcb
	On dcb.cd_dcb = pg.cd_dcb
Left Outer Join 
	grupo_alteracao_preco As gap
	On gap.cd_grupo = pc.cd_grupo_alteracao_preco
Left Outer Join 
	marca_ecommerce As me
	On me.cd_marca = pg.cd_marca_ecommerce
Left Outer Join 
	usuario As us
	On us.nr_matricula = pc.nr_matric_solicitacao_alt_sit
Left Outer Join 
	categoria_ecommerce As ce
	On ce.cd_categoria = pc.cd_categoria_ecommerce
Left Outer Join 
	segmento_ims As si
	On si.cd_segmento = pc.cd_segmento_ims 
Left Outer Join 
	area_farmacia As af
	On af.cd_area_farmacia = pg.cd_area_farmacia 
Left Outer Join 
	tarja As tj 
	On tj.cd_tarja = pg.cd_tarja 
Left Outer Join 
	cronicidade As cr 
	On cr.cd_cronicidade = pg.cd_cronicidade 
Left Outer Join 
	grupo_mercadorias As gm 
	On gm.cd_grupo  = pg.cd_grupo_mercadoria_sap
where	pg.cd_produto in (:produto)" arguments=(("produto", numberlist)) )
