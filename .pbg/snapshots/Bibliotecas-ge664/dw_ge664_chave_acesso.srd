table(column=(type=char(44) updatewhereclause=yes key=yes name=de_chave_acesso dbname="nfe_sem_pedido.de_chave_acesso" )
 column=(type=datetime updatewhereclause=yes name=dh_inclusao_chave dbname="nfe_sem_pedido.dh_inclusao_chave" )
 column=(type=long update=yes updatewhereclause=yes name=nr_pedido dbname="nfe_sem_pedido.nr_pedido" )
 column=(type=datetime update=yes updatewhereclause=yes name=dh_registro_pedido dbname="nfe_sem_pedido.dh_registro_pedido" )
 column=(type=char(6) update=yes updatewhereclause=yes name=nr_matricula_registro_pedido dbname="nfe_sem_pedido.nr_matricula_registro_pedido" )
 column=(type=datetime updatewhereclause=yes name=dh_importacao_nfe dbname="nfe_sem_pedido.dh_importacao_nfe" )
 column=(type=char(44) updatewhereclause=yes name=localizacao dbname="localizacao" )
 column=(type=char(40) updatewhereclause=yes name=nm_usuario dbname="usuario.nm_usuario" )
 retrieve="  SELECT nsp.de_chave_acesso,   
         nsp.dh_inclusao_chave,   
         nsp.nr_pedido,   
         nsp.dh_registro_pedido,   
         nsp.nr_matricula_registro_pedido,   
         nsp.dh_importacao_nfe,   
         SPACE (44) AS localizacao,   
         u.nm_usuario  
    FROM nfe_sem_pedido nsp
	 LEFT JOIN usuario u
				ON	u.nr_matricula = nsp.nr_matricula_registro_pedido
   WHERE nsp.de_chave_acesso = :as_chave_acesso
" update="nfe_sem_pedido" updatewhere=1 updatekeyinplace=no arguments=(("as_chave_acesso", string)) )
