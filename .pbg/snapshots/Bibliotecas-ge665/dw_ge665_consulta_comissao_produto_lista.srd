table(column=(type=long updatewhereclause=yes name=cd_produto dbname="cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=cd_produto_sap dbname="cd_produto_sap" )
 column=(type=char(60) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=de_apresentacao_venda dbname="de_apresentacao_venda" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_produto dbname="id_situacao_produto" values="ATIVO	A/INATIVO	I/PENDENTE	P/" )
 column=(type=char(40) updatewhereclause=yes name=de_tipo_comissao dbname="de_tipo_comissao" )
 column=(type=decimal(2) updatewhereclause=yes name=pc_comissao dbname="pc_comissao" )
 column=(type=datetime updatewhereclause=yes name=dh_inicio dbname="dh_inicio" )
 column=(type=datetime updatewhereclause=yes name=dh_termino dbname="dh_termino" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao_comissao dbname="id_situacao_comissao" values="VIGENTE	V/EXPIRADA	X/FUTURA	F/" )
 column=(type=char(1) updatewhereclause=yes name=id_marca_propria dbname="id_marca_propria" values="SIM	S/N$$HEX1$$c300$$ENDHEX$$O	N/" )
 column=(type=char(40) updatewhereclause=yes name=de_marca dbname="de_marca" )
 column=(type=long updatewhereclause=yes name=cd_categ_mercadologica dbname="cd_categ_mercadologica" )
 column=(type=char(50) updatewhereclause=yes name=de_categoria_mercadologica dbname="de_categoria_mercadologica" )
 column=(type=char(9) updatewhereclause=yes name=cd_fornecedor dbname="cd_fornecedor" )
 column=(type=char(40) updatewhereclause=yes name=nm_razao_social dbname="nm_razao_social" )
 column=(type=char(6) updatewhereclause=yes name=nr_matricula_comprador dbname="nr_matricula_comprador" )
 column=(type=char(40) updatewhereclause=yes name=nm_comprador dbname="nm_comprador" )
 column=(type=char(37) updatewhereclause=yes name=status_integracao_comissao dbname="status_integracao_comissao" )
 retrieve="SELECT 
	pg.cd_produto,
	pg.cd_produto_sap,
	pg.de_produto,
	pg.de_apresentacao_venda,
	pg.id_situacao as id_situacao_produto,
	tc.de_tipo_comissao,
	tcps.pc_comissao,
	tcps.dh_inicio,
	tcps.dh_termino,
	case 
		when getdate() between tcps.dh_inicio and tcps.dh_termino then 'V' 
		when getdate() > tcps.dh_termino then 'X'
		when getdate() < tcps.dh_inicio then 'F' 
	end as id_situacao_comissao,
	Coalesce(mp.id_marca_propria, 'N') as id_marca_propria,
	mp.de_marca,
	pc.cd_categ_mercadologica,
	cm.de_categoria_mercadologica,
	f.cd_fornecedor,
	f.nm_razao_social,
	fd.nr_matricula_comprador,
	u.nm_usuario as nm_comprador,
	case 
		when getdate() between tcps.dh_inicio and tcps.dh_termino and tcp.pc_comissao = tcps.pc_comissao then 'OK'
		when not getdate() between tcps.dh_inicio and tcps.dh_termino then 'OK'
		else 'Verificar comiss$$HEX1$$e300$$ENDHEX$$o atual SAP x Sybase'
	end status_integracao_comissao
FROM 
	tipo_comissao_produto_sap tcps
INNER JOIN 
	produto_geral pg
	ON pg.cd_produto = tcps.cd_produto
LEFT JOIN
	marca_produto mp
	ON mp.cd_marca = pg.cd_marca 
LEFT JOIN
	produto_central pc
	ON pc.cd_produto = pg.cd_produto
LEFT JOIN
	tipo_comissao tc
	ON tc.cd_tipo_comissao = tcps.cd_tipo_comissao
LEFT JOIN	
	categoria_mercadologica cm
	ON cm.cd_categ_mercadologica = pc.cd_categ_mercadologica 
LEFT JOIN
	fornecedor f
	ON f.cd_fornecedor = pg.cd_fornecedor_usual
LEFT JOIN
	fornecedor_divisao_produto fdp
	ON fdp.cd_fornecedor = f.cd_fornecedor 
	AND fdp.cd_produto = pg.cd_produto
LEFT JOIN 
	fornecedor_divisao fd
	ON fd.cd_fornecedor = fdp.cd_fornecedor 
	AND fd.nr_divisao = fdp.nr_divisao 
LEFT JOIN 
	usuario u
	ON u.nr_matricula = fd.nr_matricula_comprador 
LEFT JOIN
	tipo_comissao_produto tcp
	ON tcp.cd_produto = tcps.cd_produto
	AND tcp.cd_tipo_comissao = tcps.cd_tipo_comissao " )
