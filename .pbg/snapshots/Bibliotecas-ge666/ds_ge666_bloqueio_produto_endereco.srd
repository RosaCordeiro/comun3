table(column=(type=long updatewhereclause=yes name=nr_wms_localizacao_bloqueio dbname="wms_localizacao_bloqueio.nr_wms_localizacao_bloqueio" dbalias="wlb.nr_wms_localizacao_bloqueio" )
 column=(type=char(8) updatewhereclause=yes name=cd_endereco dbname="wms_localizacao_bloqueio.cd_endereco" dbalias="wlb.cd_endereco" )
 column=(type=long updatewhereclause=yes name=cd_produto dbname="produto_geral.cd_produto" dbalias="pg.cd_produto" )
 column=(type=char(136) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=long updatewhereclause=yes name=nr_sequencial dbname="wms_localizacao_bloqueio.nr_sequencial" dbalias="wlb.nr_sequencial" )
 column=(type=long updatewhereclause=yes name=qt_caixa_padrao dbname="wms_localizacao_bloqueio.qt_caixa_padrao" dbalias="wlb.qt_caixa_padrao" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="wms_localizacao_bloqueio.nr_lote" dbalias="wlb.nr_lote" )
 column=(type=date updatewhereclause=yes name=dh_inicio dbname="wms_localizacao_bloqueio.dh_inicio" dbalias="wlb.dh_inicio" )
 column=(type=date updatewhereclause=yes name=dh_termino dbname="wms_localizacao_bloqueio.dh_termino" dbalias="wlb.dh_termino" )
 column=(type=char(1) updatewhereclause=yes name=id_situacao dbname="id_situacao" )
 retrieve="    
 SELECT 
	wlb.nr_wms_localizacao_bloqueio,
	wlb.cd_endereco,
	pg.cd_produto,
	'(' + CAST(pg.cd_produto AS VARCHAR) + ') ' + pg.de_produto + ' : ' + pg.de_apresentacao_estoque AS de_produto,
	wlb.nr_sequencial,
	wlb.qt_caixa_padrao,
	wlb.nr_lote,
	wlb.dh_inicio,
	wlb.dh_termino,
	'V' AS id_situacao
FROM 
	wms_localizacao_bloqueio wlb
INNER JOIN produto_geral pg ON pg.cd_produto = wlb.cd_produto
WHERE 
	wlb.dh_inicio = :adt_hoje
	AND wlb.dh_termino >= :adt_hoje

UNION ALL

SELECT 
	wlb.nr_wms_localizacao_bloqueio,
	wlb.cd_endereco,
	pg.cd_produto,
	'(' + CAST(pg.cd_produto AS VARCHAR) + ') ' + pg.de_produto + ' : ' + pg.de_apresentacao_estoque AS de_produto,
	wlb.nr_sequencial,
	wlb.qt_caixa_padrao,
	wlb.nr_lote,
	wlb.dh_inicio,
	wlb.dh_termino,
	'E' AS id_situacao
FROM 
	wms_localizacao_bloqueio wlb
INNER JOIN produto_geral pg ON pg.cd_produto = wlb.cd_produto
WHERE 
	wlb.dh_termino = DATEADD(day, -1, :adt_hoje)
" arguments=(("adt_hoje", date)) )
