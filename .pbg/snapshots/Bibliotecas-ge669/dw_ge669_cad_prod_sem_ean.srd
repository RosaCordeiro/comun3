table(column=(type=char(9) update=yes updatewhereclause=yes key=yes name=cd_distribuidora dbname="distribuidora_produto_sem_ean.cd_distribuidora" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=cd_produto dbname="distribuidora_produto_sem_ean.cd_produto" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=cd_produto_distribuidora dbname="distribuidora_produto_sem_ean.cd_produto_distribuidora" )
 column=(type=char(100) updatewhereclause=yes name=de_produto dbname="de_produto" )
 column=(type=char(40) updatewhereclause=yes name=nm_fantasia dbname="fornecedor.nm_fantasia" )
 retrieve="SELECT pe.cd_distribuidora,
	pe.cd_produto,
	pe.cd_produto_distribuidora,
	(pg.de_produto + pg.de_apresentacao_venda) as de_produto,
	f.nm_fantasia
FROM distribuidora_produto_sem_ean pe 
	inner join fornecedor f		on f.cd_fornecedor = pe.cd_distribuidora
	inner join produto_geral pg	on pg.cd_produto = pe.cd_produto
WHERE 0 = 0
" update="distribuidora_produto_sem_ean" updatewhere=0 updatekeyinplace=no )
