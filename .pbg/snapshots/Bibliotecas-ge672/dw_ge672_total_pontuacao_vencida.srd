table(column=(type=char(11) updatewhereclause=yes name=cd_cliente dbname="cd_cliente" )
 column=(type=decimal(2) updatewhereclause=yes name=qt_pontos_vencidos dbname="qt_pontos_vencidos" )
 retrieve="select m.cd_cliente, 
       sum(case t.id_credito_debito
                when 'C' then m.qt_saldo_pontos
                when 'D' then m.qt_saldo_pontos * -1
           end) qt_pontos_vencidos
from pontuacao_clube_movimento m (index idx_situacao_data),
     pontuacao_clube_tipo_movimento t
where m.id_situacao_pontos = 'D'
  and m.dh_movimento <= :data_limite
  and t.cd_tipo_movimento = m.cd_tipo_movimento
group by m.cd_cliente
having sum(case t.id_credito_debito
                when 'C' then m.qt_saldo_pontos
                when 'D' then m.qt_saldo_pontos * -1
           end) > 0" arguments=(("data_limite", date)) )
