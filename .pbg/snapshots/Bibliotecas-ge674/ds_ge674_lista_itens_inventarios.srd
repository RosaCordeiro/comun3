table(column=(type=long updatewhereclause=yes name=cd_produto dbname="wms_inventario_ajuste.cd_produto" dbalias="wia.cd_produto" )
 column=(type=char(20) updatewhereclause=yes name=nr_lote dbname="wms_inventario_ajuste.nr_lote" dbalias="wia.nr_lote" )
 column=(type=long updatewhereclause=yes name=qt_ajustada dbname="qt_ajustada" )
 column=(type=datetime updatewhereclause=yes name=dh_validade dbname="wms_inventario_ajuste.dh_validade" dbalias="wia.dh_validade" )
 column=(type=char(1) updatewhereclause=yes name=id_entrada_saida dbname="wms_inventario_ajuste.id_entrada_saida" dbalias="wia.id_entrada_saida" )
 column=(type=char(4) updatewhereclause=yes name=cd_deposito_entrada dbname="cd_deposito_entrada" )
 column=(type=char(4) updatewhereclause=yes name=cd_deposito_saida dbname="cd_deposito_saida" )
 retrieve="SELECT
    wia.cd_produto,
    wia.nr_lote,
    SUM(wia.qt_ajuste * wia.qt_caixa_padrao) AS qt_ajustada,
    wia.dh_validade,
    wia.id_entrada_saida,
    CASE WHEN wia.id_entrada_saida = 'S' THEN NULL  ELSE '0001' END AS cd_deposito_entrada,
    CASE WHEN wia.id_entrada_saida = 'S' THEN '0001' ELSE NULL  END AS cd_deposito_saida
FROM wms_inventario wi
INNER JOIN wms_inventario_ajuste wia
    ON wi.nr_inventario = wia.nr_inventario
WHERE wi.nr_inventario = :al_nr_inventario
	and (wia.id_entrada_saida = :as_id_entrada_saida or 'T' = :as_id_entrada_saida)
GROUP BY
    wia.cd_produto,
    wia.nr_lote,
    wia.dh_validade,
    wia.id_entrada_saida" arguments=(("al_nr_inventario", number),("as_id_entrada_saida", string)) )
